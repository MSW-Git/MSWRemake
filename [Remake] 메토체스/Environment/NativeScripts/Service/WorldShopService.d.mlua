---@sealed
---@description "Provides functions related to purchasing products in the world through paid goods."
@Service
script WorldShopService extends Service

	---@sealed
	@ExecSpace("ServerOnly")
	method boolean, string AddToStorageAndWait(string purchaseId, string userId) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void CloseStorage() end

	---@sealed
	@ExecSpace("ServerOnly")
	method table, string ForceChangeStorageProductStatusByOperationAndWait(string purchaseId, string purchaserUserId, string statusName, string requestorUserId) end

	---@sealed
	@ExecSpace("ServerOnly")
	method table, string ForceFinishPurchaseForOperationAndWait(string purchaserUserId, string purchaseId, string requestorUserId) end

	---@sealed
	@ExecSpace("ClientOnly")
	method integer GetLocalStorageCountAndWait() end

	---@description "Acquires the product information. Script executions are suspended during the operation. The release environment allows obtaining the badge information in Waiting, Ing, and End statuses, while the maker environment allows obtaining the badge information in Register, Waiting, Ing, and End statuses."
	---@sealed
	method WorldShopProduct GetProductAndWait(string productId) end

	---@description "Obtains an entity that can check the information of products matching the search condition. Script executions are suspended during the operation. The release environment allows the search of products in Waiting, Ing, and End statuses, while the maker environment allows the search of products in Register, Waiting, Ing, and End statuses."
	---@sealed
	method WorldShopProductPages GetProductsAndWait(WorldShopProductType productType, WorldShopProductStatus productStatus) end

	---@sealed
	@ExecSpace("ServerOnly")
	method table, string GetPurchaseDetailForOperationAndWait(string purchaseId, integer orderNumber, string requestorUserId) end

	---@sealed
	method integer GetStorageCountAndWait(string purchaserUserId, string productId) end

	---@sealed
	method table GetStorageListAndWait(string purchaserUserId, int32 page, int32 size, string productId, string filter, string requestorUserId) end

	---@sealed
	@ExecSpace("ServerOnly")
	method table, string GetStorageProductForOperationAndWait(string purchaseId, string purchaserUserId, string requestorUserId) end

	---@sealed
	@ExecSpace("ServerOnly")
	method int32 GiveAvatarItemsAndWait(string userId, table<string> itemIds) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void OpenStorage() end

	---@sealed
	@ExecSpace("ClientOnly")
	method void OpenStorageOperation() end

	---@description "Displays the product purchase window. If you are unable to purchase the item, the reason is displayed."
	---@sealed
	@ExecSpace("ClientOnly")
	method void PromptPurchase(string productId) end

	---@description "Specifies a callback that issues a product when purchasing a product. The callback should check the purchase information against the received WorldShopPurchaseInfo and return true if the product payment is successful, otherwise false."
	---@sealed
	@ExecSpace("ServerOnly")
	method void SetProcessPurchaseCallback(func<WorldShopPurchaseInfo> -> boolean callback) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void SetProcessPurchaseFinishedCallback(func<string, string, boolean> callback) end

	---@sealed
	@ExecSpace("ServerOnly")
	method void SetProcessStorageCoolingOffCallback(func<WorldShopPurchaseInfo, boolean, string> callback) end

	---@sealed
	@ExecSpace("ServerOnly")
	method void SetProcessStorageUseCallback(func<WorldShopPurchaseInfo> -> boolean callback) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void SetPromptPurchaseFinishedCallback(func<string, string, boolean> callback) end

	---@description "Checks if the user has a pass. Script executions are suspended during the operation. In the World being created, you start without a pass."
	---@sealed
	method boolean UserHasPassAndWait(string userId, string productId) end

end