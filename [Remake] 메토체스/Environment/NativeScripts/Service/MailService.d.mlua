---@sealed
---@description "This is the superclass of all Services. Provides basic functions of Service."
@Service
script MailService extends Service

	---@sealed
	@ExecSpace("ClientOnly")
	method int32 GetLocalUserMailCountAndWait(boolean forceRefresh) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void GetLocalUserMailCountAsync(boolean forceRefresh, func<int32> callback) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void OpenMailOperation() end

	---@sealed
	@ExecSpace("ClientOnly")
	method void OpenMailbox() end

	---@sealed
	@ExecSpace("ServerOnly")
	method boolean, integer SendUserMailAndWait(string receiverProfileCode, MailSendUserRequest userMailSendData) end

	---@sealed
	@ExecSpace("ServerOnly")
	method void SendUserMailAsync(string receiverProfileCode, MailSendUserRequest userMailSendData, func<boolean, integer> callbackFunction) end

	---@sealed
	@ExecSpace("ServerOnly")
	method void SetCheckMailReceivableCallback(func<string, List<MailRewardItemData>, string> -> string callback) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void SetMailboxVisibility(boolean visible) end

	---@sealed
	@ExecSpace("ServerOnly")
	method void SetReceiveRewardCallback(func<string, MailRewardItemData, integer, integer, string, string> -> string callback) end

	emitter EmitMailsClientReceiveEvent(MailsClientReceiveEvent event) end

	emitter EmitMailsServerReceiveEvent(MailsServerReceiveEvent event) end

	emitter EmitMailSentEvent(MailSentEvent event) end

end