@Event
script SkillHit extends EventType

	property Entity Attacker = nil

	property Entity Target = nil

	property table InitialDamages = {}

	property table FinalDamages = {}

	property boolean IsCritical = false

	@Description("지속 데미지를 주는 스킬인 경우, 몇 번째 타격인지를 검사하는 함수입니다.")
	property number HitCount = 0

end