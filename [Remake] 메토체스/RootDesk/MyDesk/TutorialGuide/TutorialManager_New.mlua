					self:CallAdviceMessage("AD117_1_1")
				end		
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent2(KeyDownEvent event)
		-- ESC 키 입력 시 특정 튜토리얼 상황에서 다음 단계로 진행
		--------------- Native Event Sender Info ----------------
		-- Sender: InputService
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local key = event.key
		local gameManager = self.Entity.GameManager
		---------------------------------------------------------
		local mapName = self.Entity.CurrentMap.Name
		
		if key == KeyboardKey.Escape and self.Entity.CurrentMap.MapComponent.IsDynamicMap == true then -- mapName == "Arena"  then
			if gameManager.ModeType == "Tutorial" then
				if _UI_TutorialLogic.AdviceID == "AD129_2" or _UI_TutorialLogic.AdviceID == "AD129_1"  then
					_UI_TutorialLogic:ActivateInteractionArrow("Dictionary",false)
					self:CallAdviceMessage("AD130_1")
				elseif _UI_TutorialLogic.AdviceID == "AD131_2" or _UI_TutorialLogic.AdviceID == "AD131_1" then
					self:CallAdviceMessage("AD132_1")
					_UI_TutorialLogic:ActivateInteractionArrow("Statistics",false)
				end
			end
		end
		
	end

end