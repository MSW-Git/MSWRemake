		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		local gameManager = _UserService.LocalPlayer.GameManager
		---------------------------------------------------------
		if gameManager.ModeType == "Tutorial" then
			if gameManager.Stage == 2 and gameManager.Round == 1 then
				if _UI_TutorialLogic.AdviceID == "AD117_5" then
