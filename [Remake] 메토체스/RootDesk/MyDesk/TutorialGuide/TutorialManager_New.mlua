	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 튜토리얼 중 키보드와 마우스 입력에 따른 상호작용 처리
		--------------- Native Event Sender Info ----------------
		-- Sender: InputService
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local key = event.key
		local gameManager = self.Entity.GameManager
		local teamManager = self.Entity.TeamManager
		---------------------------------------------------------
		local unitInfoPanel = _EntityService:GetEntityByPath("/ui/UnitInfoPopupGroup/Popup_UnitInfo")
		local mapName = self.Entity.CurrentMap.Name
		if gameManager.ModeType == "Tutorial" and self.Entity.CurrentMap.MapComponent.IsDynamicMap == true then --mapName == "Arena" then
			if key == KeyboardKey.Space then
				_UI_TutorialLogic:ClickAdviceMessage()
			elseif key == KeyboardKey.Mouse1 then
				--마우스 우클릭 시 주황버섯일 경우
				if
					gameManager.Stage == 2 and gameManager.Round == 1 and
					unitInfoPanel.Enable == true and
					_UI_UnitInfoPopup.ConnectedEntity.UnitInfo.charID == "C10002"
				then
					if _UI_TutorialLogic.AdviceID == "AD122_1_1" then
						self:CallAdviceMessage("AD122_2_1")
					end
				end
			elseif key == KeyboardKey.Mouse0 then
				--마우스 좌클릭
				if gameManager.Stage == 2 and gameManager.Round == 1 then
					if _UI_TutorialLogic.AdviceID == "AD122_3_1" and _EntityService:GetEntityByPath("/ui/UnitInfoPopupGroup/Popup_UnitInfo").Enable == false then
						--유닛 정보가 꺼져있으면 넘어가기
						self:CallAdviceMessage("AD122_4_1")
					end
				end
			else
				return
		
			end
		end 
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "17aec8b5-3ecc-4068-ac5c-1f7010607b40")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 호버 상태 변경 시 특정 조건에서 안내 메시지 표시
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local state = event.state
		local gameManager = self.Entity.GameManager
		---------------------------------------------------------
		if state == ButtonState.Hover then
			if gameManager.ModeType == "Tutorial" then
				if _UI_TutorialLogic.AdviceID == "AD122_2_2" then
		
					self:CallAdviceMessage("AD122_3_1")
				end
			end
		end
		
	end

	@ExecSpace("ClientOnly")
