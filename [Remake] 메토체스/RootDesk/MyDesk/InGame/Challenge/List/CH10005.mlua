@Component
script CH10005 extends ChallengeComponent

	@ExecSpace("ServerOnly")
	method void StartGameHandler(any event)
		__base:StartGameHandler(event)
		
		-- 77 코인으로 게임 시작
		---------------------------------------------------------
		local user = self.Entity.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		local runeParent = user:GetChildByName("RuneCardParent")
		local userPControl = user.TM_PropertyControl
		local runeID = "RC20017"
		----------------------------------------------------------------
		teamManager:AddGolds(61, "coach")
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 2 스테이지부터 소지한 코인이 100코인을 넘지 못하면 1 코인당 아군의 가해량 1% 감소
		---------------------------------------------------------
		local user = self.Entity.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		---------------------------------------------------------
		if gameManager.Stage >= 2 and teamManager.Golds < 100 then
			local amount = 100 - teamManager.Golds
			
			for _, myUnit in pairs(teamManager.OwnUnits) do
				_StatusChangeLogic:GetBuff(myUnit, "Multi_DealingDamageRate", - amount, -1)
			end
		end
	end

end