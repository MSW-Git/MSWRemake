@Component
script C30011_Mushmom_Skill extends Component

	property number skillAnimLength = 2.6

	property string attackEffectRUID = "bee623021dc54be384ae5d60566e5b57"

	property string hitEffectRUID = "09a4878dec8643f7b1da2bebfc94ee95"

	property number SkillTime = 2.6

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		animComponent:PlayAnimation(1, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		
		
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		local function SkillPlay()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				-- 무적, 은신 상태 넣기
				_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0001", 1.5)
				_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0002", 1.5)
			end
		end
		
		local function skillMotionFnc()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetSkillMotion(targetUnit)
			end
		end
		
		
		_TimerService:SetTimerOnce(SkillPlay, 0.5)
		_TimerService:SetTimerOnce(skillMotionFnc, 1.8)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0100",self.Entity.UnitInfo.OwnerId)
		
		--그림자
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		self:SetShadow(skillRate,self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSkillMotion(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local unitSprite = unitInfo.spriteRenderer
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		local enemies = {}
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
		local moveTileInfo = _BTLogic_New:getTile(myUnit, checkEnemies, "EmptyTileWithMostEnemies_All_1")
		
		---@type Entity
		local moveTile = moveTileInfo[1]
		local nextMoveTileVerticalNum = moveTileInfo[2]
		local nextMoveTileHorizontalNum = moveTileInfo[3] * 2 - ((nextMoveTileVerticalNum+1)%2)
		
		if not isvalid(moveTile) then
			moveTile = unitInfo.setTile
			nextMoveTileVerticalNum = moveTile.TileComponent_New.verticalNum
			nextMoveTileHorizontalNum = moveTile.TileComponent_New.horizontalNum * 2 - ((nextMoveTileVerticalNum+1)%2)
		end
		
		
		unitInfo:SetPropertyToServer("setTile", moveTile, "All", true)
		
		
		-- 레이어 설정
		myUnit.UnitAnimationComponent:SetLayerOrder(nextMoveTileVerticalNum, user.OwnerId)
		
		
		local function skillDamageFnc()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetAttackEffect(unitInfo.OwnerId)
				local attackEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				attackEnemies = _BTLogic_New:getTargets(moveTile, attackEnemies, "Around_1_1")
				
				if isvalid(attackEnemies) then
					local hitCount = 0
					for _, enemy in pairs(attackEnemies) do
						if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
							self:SetSkillDamage(enemy)
							hitCount +=1
						end
					end
					_AchievementService:UpdateProgress_Char(unitInfo,hitCount,user) -- 머쉬룸 도전과제
				end
			end
		end
		
		_TimerService:SetTimerOnce(skillDamageFnc, 0.35 / _BTLogic_New.SSpeedValue)
		
		--연출
		self:PlaySkillEffect(0.35 / _BTLogic_New.SSpeedValue, moveTile, unitInfo.OwnerId)
	end

	@ExecSpace("Client")
	method void SetAttackEffect()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = 1,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.attackEffectRUID, myUnit, Vector3(0, 0, 0), 0, Vector3(2, 2, 2), false, options)
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		self:HitEffect(targetUnit, unitInfo.OwnerId)
		
		local physicalDamage = unitStatus.MaxHP * _S01_SkillDescLogic.C30011_Active_SDamage_MaxHP[unitInfo.level]
		
		local damageInfo = _StatusChangeLogic:CheckDamage(physicalDamage, myUnit, targetUnit, 0, "Physical")
		_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "skill")
		
		local stunTime = tonumber(_S01_SkillDescLogic.C30011_Active_StunTime_Int[unitInfo.level])
		_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0004", stunTime)
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void SetPosition(number x, number y)
		self.Entity.TransformComponent.WorldPosition = Vector3(x,y,0)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity Tile)
		--범위 표시
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Tile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
		
		--각 캐릭터별 범위 공격용 이펙트
		if _ESCMenuService.skillEffectAlpha > 0 then
			local destroyandparticle = function()
				local particle = _ParticleService:PlayBasicParticleAttached(BasicParticleType.TinyExplosion, self.Entity, Vector3.zero, 0, Vector3(1.2,1,1), false, 
								{["SortingLayer"] = "Layer1", ["OrderInLayer"] = -1, ["PlaySpeed"] = 0.8, ["ParticleSize"] = 0.5,["ParticleSpeed"] = 1.5,["ParticleCount"] = 0.5,["ParticleLifeTime"] = 0.1, ["Alpha"] = _ESCMenuService.skillEffectAlpha/100})
				
				_TimerService:SetTimerOnce(function() _ParticleService:RemoveParticle(particle) end,0.5)
				
			end
			_TimerService:SetTimerOnce(destroyandparticle, time)
		end
	end

	@ExecSpace("Client")
	method void SetShadow(number time)
		--그림자가 점점 작아집니다
		local scale = Vector3.one
		local setscale = function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Scale = scale 
			scale.x -= 1/30
			scale.y -= 1/30
			
			if self.Entity.UnitAnimationComponent.SetAnimType ~= "Skill" then
				self.Entity:GetChildByName("Shadow").TransformComponent.Scale = Vector3.one 
			end
		end
		
		for i = 1, 30 do
			_TimerService:SetTimerOnce(setscale, (i/100)+0.68)
		end
		
		--그림자 원상복구
		local scale2 = Vector3.zero
		local init = function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Scale = scale2
			scale2.x += 1/30
			scale2.y += 1/30
		end
		
		for i = 1, 30 do
			_TimerService:SetTimerOnce(init, (i/100)+1)
		end
	end

end