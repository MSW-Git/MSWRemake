@Component
script C10008_MemoryMonk_Skill extends Component

	property number skillAnimLength = 1.28

	property string hitEffectRUID = "97264b894f9f46ec96ff82ad1d65d0ba"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength  * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		--log(myUnit.Name .. " use Skill")
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		local enemies = {}
		
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		
		local function hitSkill()
		
			if not _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Skill") then
				local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				targetUnit = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "Nearest")
			end
			
			if isvalid(targetUnit) and _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				local targetInfo = targetUnit.UnitInfo
				local enemies2 = {}
				if unitInfo.TeamType == "Enemy" then
					enemies2 = _BTLogic_New:getEntities(teamManager.OwnUnits, "AttackAble")
				elseif unitInfo.TeamType == "User" then
					enemies2 = _BTLogic_New:getEntities(teamManager.EnemyUnits, "AttackAble")
				end
			
				local attackEnemies = _BTLogic_New:getTargets(targetInfo.setTile, enemies2, "Around_0_1")
			
				if isvalid(attackEnemies) then
					for _, enemy in pairs(attackEnemies) do
						if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
							self:SetSkillDamage(enemy)
		
						end
					end
				end
			end
		
		end
		
		_TimerService:SetTimerOnce(hitSkill, 0.79 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0055", self.Entity.UnitInfo.OwnerId)
		
		--연출
		self:PlaySkillEffect(0.79 / skillRate,targetUnit.UnitInfo.setTile,self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local skillSetDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C10008_Active_SDamage_Magic[unitInfo.level]
			
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Magical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "skill")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity Tile)
		--범위 표시
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Tile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
		
		--charge파티클을 씌웁니다.
		local chargeparticle = _ParticleService:PlayBasicParticleAttached(BasicParticleType.LightningOrbSharp, Tile, Vector3(0,0.5,0), 0, Vector3(0.8,0.8,1), false,
							{["SortingLayer"] = "Foreground", ["OrderInLayer"] = 5, ["PlaySpeed"] = 1, ["ParticleSize"] = 1, ["ParticleSpeed"] = 1, ["ParticleCount"] = 1, ["ParticleLifeTime"] = 1, ["Color"] = Color.FromHexCode("#7db99d")})
		
		--각 캐릭터별 범위 공격용 이펙트
		local destroyandparticle = function()
			_ParticleService:RemoveParticle(chargeparticle)
			_EffectService:PlayEffectAttached("eda2b26cef044260a72a83b8add9b99e", Tile, Vector3(0, 0.5, 0), 0, Vector3(2, 2, 1), false, {["SortingLayer"] = "Foreground", ["OrderInLayer"] = 5})
		end
		_TimerService:SetTimerOnce(destroyandparticle, time)
	end

end