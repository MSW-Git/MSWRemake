@Component
script C50004_Cygnus_Skill extends Component

	property number skillAnimLength = 1.56

	property string BuffEffectRUID = "0a8c5973bb83485993c0c6eac6d91c85"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		--------------------------------------------------
		-- 가장 낮은 체력 유닛(인원은 레벨에 따라)을 찾아 회복합니다.
		--------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		local myTeams = {}
		if unitInfo.TeamType == "User" then
			myTeams = teamManager.OwnUnits
		elseif unitInfo.TeamType == "Enemy" then
			myTeams = teamManager.EnemyUnits
		end
		
		local checkMyTeams = _BTLogic_New:getEntities(myTeams, "Alive")
		local cureUnitCount = _S01_SkillDescLogic.C50004_Active_SkillCount_Int[unitInfo.level]
		local getHPTeams = _BTLogic_New:getTargets(unitInfo.setTile, checkMyTeams, "HP_Low_" .. math.floor(cureUnitCount))
		
		local getHPAmount = unitStatus.MagicalAttack * _S01_SkillDescLogic.C50004_Active_GetHP_Magic[unitInfo.level]
		local getAttackAmount = _S01_SkillDescLogic.C50004_Active_GetAttack_Int[unitInfo.level]
		
		
		for _, unit in pairs(getHPTeams) do
			if _BTLogic_New:CheckAttackAble(myUnit, unit, "Skill") then
				_StatusChangeLogic:SetVariableStatus(myUnit, unit, "HP", getHPAmount, "skill")
				
				_StatusChangeLogic:GetBuff(unit, "Add_PhysicalAttack", getAttackAmount, -1)
				_StatusChangeLogic:GetBuff(unit, "Add_MagicalAttack", getAttackAmount, -1)
				
				self:SetBuffEffect(unit, unitInfo.OwnerId)
			end
		end
		
		--사운드
		_PlaySoundLogic:PlaySound("M0136",self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Client")
	method void SetBuffEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- buffeffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"] = Color(1, 1, 1, _ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.BuffEffectRUID, targetUnit, Vector3.zero, 0, Vector3.one, false, options)
	end

end