@Component
script C20006_MasterSoulTeddy_Skill extends Component

	@ExecSpace("Server")
	method void SetBattle()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		if isvalid(unitInfo.AttackComponent) then
			unitInfo.AttackComponent.onSkill = true
		end
		
		--사운드 없음
	end

end