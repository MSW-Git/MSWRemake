@Component
script C10006_StoneBall_Skill extends Component

	property number skillAnimLength = 1.56

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength  * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		
		
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		--log(myUnit.Name .. " use Skill")
		
		local function GetBuff()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetBuff()
			end
		end
		
		_TimerService:SetTimerOnce(GetBuff, 0.8 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0053", self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetBuff()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local getHP = _S01_SkillDescLogic.C10006_Active_GetHP_Int[unitInfo.level] + unitStatus.MaxHP * _S01_SkillDescLogic.C10006_Active_GetHP_MaxHPPer[unitInfo.level]
		local getPhysicalAttack = unitStatus.MagicalAttack * _S01_SkillDescLogic.C10006_Active_GetPhysicalAttack_Magic[unitInfo.level]
		
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "HP", getHP, "skill")
		_StatusChangeLogic:GetBuff(myUnit, "Add_PhysicalAttack", getPhysicalAttack, -1)
		
		--연출
		_GeneralDirectorLogic:BattleBuffEffect(self.Entity, _RuneCardDirectEnum.HP, self.Entity.UnitInfo.OwnerId)
	end

end