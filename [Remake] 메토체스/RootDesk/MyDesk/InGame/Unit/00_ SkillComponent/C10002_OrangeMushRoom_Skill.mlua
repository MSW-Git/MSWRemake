@Component
script C10002_OrangeMushRoom_Skill extends Component

	property number skillAnimLength = 2

	property string attackEffectRUID = "bee623021dc54be384ae5d60566e5b57"

	property string hitEffectRUID = "09a4878dec8643f7b1da2bebfc94ee95"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength  * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		--log(myUnit.Name .. " use Skill")
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		
		local function hitSkill()
			local hitCount = 0
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetAttackEffect(unitInfo.OwnerId)
				
				local enemies = {}
				if unitInfo.TeamType == "Enemy" then
					enemies = _BTLogic_New:getEntities(teamManager.OwnUnits, "AttackAble")
				elseif unitInfo.TeamType == "User" then
					enemies = _BTLogic_New:getEntities(teamManager.EnemyUnits, "AttackAble")
				end
				
				local attackEnemies = _BTLogic_New:getTargets(unitInfo.setTile, enemies, "Around_1_1")
					
				if isvalid(attackEnemies) then
					for _, enemy in pairs(attackEnemies) do
						if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
							self:SetSkillDamage(enemy)
							hitCount+=1
						end
					end
				end
			end
			-- 주황버섯 도전과제 
				_AchievementService:UpdateProgress_Char(unitInfo,hitCount,user) 
		
		end
		
		_TimerService:SetTimerOnce(hitSkill, 1.6 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0051",self.Entity.UnitInfo.OwnerId)
		
		--스킬 이펙트
		self:PlaySkillEffect(1.6 / skillRate, unitInfo.setTile, self.Entity.UnitInfo.OwnerId)
		
		--그림자
		self:SetShadow(1.6 / skillRate, self.Entity.UnitInfo.OwnerId)
		
		
	end

	@ExecSpace("Client")
	method void SetAttackEffect()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = 1,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.attackEffectRUID, myUnit, Vector3(0, 0, 0), 0, Vector3(1.5, 1.5, 1.5), false, options)
		
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local skillSetDamage = unitStatus.PhysicalAttack * _S01_SkillDescLogic.C10002_Active_SDamage_Physic[unitInfo.level] + unitStatus.MagicalAttack * _S01_SkillDescLogic.C10002_Active_SDamage_Magic[unitInfo.level]
			
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "skill")
			
			local debuffTime = tonumber(_S01_SkillDescLogic.C10002_Active_HealingDecreaseTime_Int[unitInfo.level])
			_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0010", debuffTime)
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity Tile)
		--범위 표시
		
		local tiles = {}
		if self.Entity.UnitInfo.TeamType=="User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Tile)
		end
		
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
		
		--각 캐릭터별 범위 공격용 이펙트
		if _ESCMenuService.skillEffectAlpha>0 then
			local destroyandparticle=function()
				local particle=_ParticleService:PlayBasicParticleAttached(BasicParticleType.TinyExplosion,self.Entity,Vector3(0,0,0),0,Vector3(1.2,1,1),false,{["SortingLayer"]="Layer1",["OrderInLayer"]=-1,["PlaySpeed"]=0.8,["ParticleSize"]=0.5,["ParticleSpeed"]=1.5
																				,["ParticleCount"]=0.5,["ParticleLifeTime"]=0.1, ["Alpha"]=_ESCMenuService.skillEffectAlpha/100})
				
				_TimerService:SetTimerOnce(function() _ParticleService:RemoveParticle(particle) end,0.5)
				
			end
			_TimerService:SetTimerOnce(destroyandparticle, time)
		end
	end

	@ExecSpace("Client")
	method void SetShadow(number time)
		--그림자가 점점 작아집니다
		local scale = Vector3.one
		local setscale = function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Scale = scale 
			scale.x -= 1/30
			scale.y -= 1/30
			
			if self.Entity.UnitAnimationComponent.SetAnimType ~= "Skill" then
				self.Entity:GetChildByName("Shadow").TransformComponent.Scale = Vector3.one 
			end
		end
		
		for i = 1, 30 do
			_TimerService:SetTimerOnce(setscale, ((i*0.4/time) / 60) + time*5/10)
		end
		
		--그림자 원상복구
		local init = function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Scale = Vector3.one
		end
		
		_TimerService:SetTimerOnce(init, 9*time/10)
	end

end