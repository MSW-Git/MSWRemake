@Component
script SkillComponent extends Component

	property string SkillType = "Skill"

	property number SkillAnimLength = 0

	property number PlayRate = 0

	property string AttackEffectRUID = ""

	property string HitEffectRUID = ""

	property string SkillSoundID = ""

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		-- 대상 유닛에게 기본 액티브 스킬을 사용하고 애니메이션과 사운드를 재생
		-- 기본 Active 스킬을 사용하는 함수입니다.
		-----------------------------------------------------
		-- 유닛 관련 기본 세팅
		
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local unitStatistics = myUnit.UnitBattleStatistics
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		-----------------------------------------------------
		-- 유저 관련 기본 세팅
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		-----------------------------------------------------
		-- 스킬 애니메이션을 재생합니다.
		-- 유닛의 상태를 바꿉니다.
		
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		local animComponent = myUnit.UnitAnimationComponent
		animComponent:PlayAnimation(self.PlayRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		-----------------------------------------------------
		-- 스킬 사운드를 재생합니다.
		
		if self.SkillSoundID ~= "" then
			_PlaySoundLogic:PlaySound(self.SkillSoundID, unitInfo.OwnerId)
		end
	end

end