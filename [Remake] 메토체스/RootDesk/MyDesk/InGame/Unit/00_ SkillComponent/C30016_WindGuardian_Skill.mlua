@Component
script C30016_WindGuardian_Skill extends Component

	property number skillAnimLength = 1.89

	property number SkillTime = 1.89

	property string attackEffectRUID = "eaeb165ec6464169858400d23875229f"

	property string hitEffectRUID = "683a372afbf54960875c3f61b96c49b6"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		animComponent:PlayAnimation(1, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		--log(myUnit.Name .. " use Skill")
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		local enemies = {}
		
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		
		
		local function attackEffect()
			if not _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Skill") then
				local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				targetUnit = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "Nearest")
			end
			
			if isvalid(targetUnit) and _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetAttackEffect(targetUnit, unitInfo.OwnerId)
			end
		end
		
		local function hitSkill()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				enemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				
				local attackEnemies = _BTLogic_New:getTargets(targetInfo.setTile, enemies, "Around_0_1")
			
				if isvalid(attackEnemies) then
					for _, enemy in pairs(attackEnemies) do
						if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
							self:SetSkillDamage(enemy)
						end
					end
				end
			end
		end
		
		_TimerService:SetTimerOnce(attackEffect, 0)
		_TimerService:SetTimerOnce(hitSkill, 1.05)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0074",self.Entity.UnitInfo.OwnerId)
		
		--범위 연출
		self:PlayRangeSkillEffect(1.05,targetUnit,unitInfo.OwnerId)
	end

	@ExecSpace("Client")
	method void SetAttackEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = 1,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.attackEffectRUID, targetUnit, Vector3(0, 0, 0), 0, Vector3(1.2, 1.2, 1.2), false, options)
		
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			-- 무장해제
			local debuffTime = tonumber(_S01_SkillDescLogic.C30016_Active_DebuffTime_Int[unitInfo.level])
			_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0006", debuffTime)
			
			-- 스킬 데미지
			local skillSetDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C30016_Active_SDamage_Magic[unitInfo.level]
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Magical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "skill")
			
			
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.5, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlayRangeSkillEffect(number time, Entity targetUnit)
		--범위 표시
		--local range=_SpawnService:SpawnByModelId("model://ddb8dc6e-88f6-4c9b-978f-523d71988570","Range",Vector3(0,0,0),targetUnit)
		
		--[[if self.Entity.UnitInfo.TeamType=="User" then
			range.SpriteRendererComponent.Color=Color.FromHexCode("#5eff00")
		else
			range.SpriteRendererComponent.Color=Color.FromHexCode("#ff7800")
		end
		
		local alpha=0
		
		--범위 표시 스프라이트가 점점 진해집니다.
		local setalpha=function()
			if isvalid(range) then
				range.SpriteRendererComponent.Color.a=alpha
				alpha+=(1/60*0.5*_ESCMenuService.skillEffectAlpha/100)
			end
		end
		
		for i=1,60 do
			_TimerService:SetTimerOnce(setalpha,(i*time)/60)
		end
		
		--각 캐릭터별 범위 공격용 이펙트
		local destroyandparticle=function()
			range.Enable=false
			_TimerService:SetTimerOnce(function() range:Destroy() end,0.5)
			
		end
		_TimerService:SetTimerOnce(destroyandparticle, time)]]--
	end

end