@Component
script C50008_Papulatus_Skill extends Component

	property number skillAnimLength = 2.45

	property string SkillObjRUID = "7f1c784f4b974ccf9de19110f1b19e8e"

	property string HitEffectRUID = "da224164f93d4c57975ae06dfddfa7c1"

	property string SuicideEffectRUID = "9336ae65126c45768938d68752305c1c"

	property string SuicideHitEfectRUID = "ff7ce0277274403196ccaa77faa3f230"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		local myTeams = {}
		local enemies = {}
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
			myTeams = teamManager.OwnUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
			myTeams = teamManager.EnemyUnits
		end
		
		
		-- 1. 체력 회복
		-- 2. 시계 설치 후 폭파
		
		if unitInfo.unitPhaseNumber == 1 then
			-- 체력 회복
			local function healingFnc()
				if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
					local checkMyTeams = _BTLogic_New:getEntities(myTeams, "Alive")
					local getHP = unitStatus.MagicalAttack * _S01_SkillDescLogic.C50008_Active_GetHP_Magic[unitInfo.level]
					local targets = _BTLogic_New:getTargets(unitInfo.setTile, checkMyTeams, "HPper_Low_2")
					
					_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "HP", getHP, "skill")
					
					if isvalid(targets) then
						if targets[1] ~= myUnit then
							_StatusChangeLogic:SetVariableStatus(myUnit, targets[1], "HP", getHP, "skill")
											
							--회복 이펙트
							--_CustomizedBattleEffectService:PlayEffectAttached("08ae116f052540318d4174cca7dcfca6",targets[1],Vector3.zero,0,Vector3.one,false,{},unitInfo.OwnerId)
						elseif isvalid(targets[2]) then
							_StatusChangeLogic:SetVariableStatus(myUnit, targets[2], "HP", getHP, "skill")	
							
							--회복 이펙트
							--_CustomizedBattleEffectService:PlayEffectAttached("08ae116f052540318d4174cca7dcfca6",targets[2],Vector3.zero,0,Vector3.one,false,{},unitInfo.OwnerId)
						end
					end
				end
			end
			
			---@type Entity, Entity
			local target, targetTile = nil, nil
			
			-- 시계 설치
			local function setObj()
				local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				target = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "HPper_High")
					
				if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
					if isvalid(target) then
						targetTile = target.UnitInfo.setTile
						self:SetSkillObj(targetTile)
						
						self:PlaySkillEffect(1.3, targetTile, unitInfo.OwnerId)
					end
				end
				
				--사운드
				_PlaySoundLogic:PlaySound("M0140", self.Entity.UnitInfo.OwnerId)
			end
			
			-- 데미지
			local function damageFnc()
				if isvalid(targetTile) then
					self:SetSkillDamage(targetTile)
				end
				--사운드
				_PlaySoundLogic:StopSound("M0140", self.Entity.UnitInfo.OwnerId)
				_PlaySoundLogic:PlaySound("M0141", self.Entity.UnitInfo.OwnerId)
			end
			
			
			_TimerService:SetTimerOnce(healingFnc, 0.35)
			_TimerService:SetTimerOnce(setObj, 1.15)
			_TimerService:SetTimerOnce(damageFnc, 2.15)
		elseif unitInfo.unitPhaseNumber == 2 then
			-- 체력 회복
			local function healingFnc()
				if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
					local checkMyTeams = _BTLogic_New:getEntities(myTeams, "Alive")
					local getHP = unitStatus.MagicalAttack * _S01_SkillDescLogic.C50008_Active_GetHP_Magic[unitInfo.level]
					local targets = _BTLogic_New:getTargets(unitInfo.setTile, checkMyTeams, "HPper_Low_2")
					
					_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "HP", getHP, "skill")
					
					if isvalid(targets) then
						if targets[1] ~= myUnit then
							_StatusChangeLogic:SetVariableStatus(myUnit, targets[1], "HP", getHP, "skill")
						elseif isvalid(targets[2]) then
							_StatusChangeLogic:SetVariableStatus(myUnit, targets[2], "HP", getHP, "skill")	
						end
					end
				end
			end
			
			---@type Entity, Entity
			local target, targetTile = nil, nil
			
			-- 시계 설치
			local function setObj()
				local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				target = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "HPper_High")
				
				if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
					if isvalid(target) then
						targetTile = target.UnitInfo.setTile
						self:SetSkillObj(targetTile)
					end
					
					self:PlaySkillEffect(1.3, targetTile, unitInfo.OwnerId)
				end
			end
			
			-- 데미지
			local function damageFnc()
				if isvalid(targetTile) then
					self:SetSkillDamage(targetTile)
				end
			end
			
			
			_TimerService:SetTimerOnce(healingFnc, 0.25 / skillRate)
			_TimerService:SetTimerOnce(setObj, 1.19 / skillRate)
			_TimerService:SetTimerOnce(damageFnc, 2.19 / skillRate)
		end
	end

	@ExecSpace("Server")
	method void SetSkillObj(Entity setTile)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = 1}
		_CustomizedBattleEffectService:PlayEffectAttached(self.SkillObjRUID, setTile, Vector3(0, 0, 0), 0, Vector3.one, false, options, unitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetTile)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		local enemies = {}
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		
		local attackEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
		attackEnemies = _BTLogic_New:getTargets(targetTile, attackEnemies, "Around_0_1")
		
		local skillDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C50008_Active_SDamage_Magic[unitInfo.level]
		
		for _, enemy in pairs(attackEnemies) do
			local damageInfo = _StatusChangeLogic:CheckDamage(skillDamage, myUnit, enemy, 0, "Magical")
			_StatusChangeLogic:HitDamage(myUnit, enemy, 0, damageInfo[1], damageInfo[2], "skill")
			
			self:HitEffect(enemy, "skill", unitInfo.OwnerId)
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit, string type)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		local ruid = ""
		local scale = 1
		if type == "skill" then
			ruid = self.HitEffectRUID
		elseif type == "suicide" then
			ruid = self.SuicideHitEfectRUID
			scale = 2
		end
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(ruid, targetUnit, Vector3(0, 0, 0), 0, Vector3.one * scale, false, options)
	end

	@ExecSpace("Server")
	method void PhaseChange()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		-----------------------------------------------------
		-- 4초간 무적/행동불가 및 회복
		_StatusChangeLogic:SetStatus(myUnit, self.Entity, "SE0001", 3.5)
		self.Entity.UnitAIWanderComponent.setBattle = false
		unitStatus:SetProperty("state", "Idle", "")
		
		-- 페이즈 변경
		unitInfo:SetPropertyToServer("unitPhaseNumber", 2, nil, true)
		
		-- 일정 시간 후 자폭 데미지 부여
		local function suicideFnc()
			self:SetSuicideDamage(unitInfo.setTile)
		end
		
		_TimerService:SetTimerOnce(suicideFnc, 2.8)
		
		
		-- 4초 후, 다시 전투 참여
		local function ChangedFnc()
			self.Entity.UnitAIWanderComponent.setBattle = true
		end
		
		_TimerService:SetTimerOnce(ChangedFnc, 3.49)
		
		-- 페이즈 변경 애니메이션
		-- unitStatus:SetProperty("state", "SetMotion", "")
		self:PhaseChangeAnimationSet(unitInfo.OwnerId)
		
		-- 연출
		self:PlaySkillEffect(2.8, unitInfo.setTile, unitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSuicideDamage(Entity targetTile)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		local enemies = {}
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		
		local attackEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
		attackEnemies = _BTLogic_New:getTargets(targetTile, attackEnemies, "Around_0_1")
		
		local skillDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C50008_Passive_SelfDestructionDamage_Magic[unitInfo.level] +
							unitStatus.MaxHP * _S01_SkillDescLogic.C50008_Passive_SelfDestructionDamage_MaxHP[unitInfo.level]
		
		for _, enemy in pairs(attackEnemies) do
			local damageInfo = _StatusChangeLogic:CheckDamage(skillDamage, myUnit, enemy, 1, "Magical")
			_StatusChangeLogic:HitDamage(myUnit, enemy, 0, damageInfo[1], damageInfo[2], "skill")
			
			self:HitEffect(enemy, "suicide", unitInfo.OwnerId)
		end
	end

	@ExecSpace("Client")
	method void PhaseChangeAnimationSet()
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local spriteRenderer = unitInfo.spriteRenderer
		local spriteRUID = "eb4c95aed8754125b30ec1131ad467f4"
		
		if isvalid(unitInfo.spriteRenderer) then
			spriteRenderer.SpriteRendererComponent.PlayRate = 1
			spriteRenderer.SpriteRendererComponent.SpriteRUID = spriteRUID
			
			--그림자
			self.Entity:GetChildByName("Shadow").UnitShadowComponent:Init("C50008_2",self.Entity.UnitInfo.level)
		end
	end

	@ExecSpace("Server")
	method void Reset()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		-- 페이즈 변경
		unitInfo:SetPropertyToServer("unitPhaseNumber", 1, nil, true)
		animComponent:PlayAnimation(1, "Idle", myUnit, unitInfo.OwnerId)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity Targettile)
		--범위 표시
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Targettile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Targettile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
	end

end