		end
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_SI10008()
		-- 시기의 옥석
		-- 전투 시작 시, 가해량 +100%, 피해량 -50%, 공속 +300%
		--------------------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
