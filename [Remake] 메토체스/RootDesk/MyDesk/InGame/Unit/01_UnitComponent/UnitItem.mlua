		--------------------------------------------------------------
		_StatusChangeLogic:GetBuff(unit, "Multi_DealingDamageRate", 100, -1)
		_StatusChangeLogic:GetBuff(unit, "DamageDecrease_Per", 50, -1)
		_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", 300, -1)
	end

	method boolean IsEquipingItem(string itemID)
		-- 이 유닛이 itemID에 해당하는 아이템을 장착하고 있는지 여부를 검사, 장착하고 있으면 true를 반환합니다.
		----------------------------------------------------------------
		local equippedIDList = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedIDList do
			local targetID = _UtilLogic:Split(equippedIDList[1])[1]
			
			if itemID == targetID then
				return true
			end
		end
		
		return false
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleDefaultAttack(DefaultAttack event)
		self:OnDefaultAttack(event.target)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleSkillUse(SkillUse event)
		self:OnUseSkill()
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleAttacked(Attacked event)
		-- Parameters
		local Attacker = event.Attacker
		local Target = event.Target
		local InitialDamages = event.InitialDamages
		local FinalDamages = event.FinalDamages
		local IsCritical = event.IsCritical
		local AttackType = event.AttackType
		---------------------------------------------------------
		self:OnAttacked()
		self:OnAttacked_Damage(Attacker, FinalDamages)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleDefaultAttackHit(DefaultAttackHit event)
		-- Parameters
		local Attacker = event.Attacker
		local Target = event.Target
		local InitialDamages = event.InitialDamages
		local FinalDamages = event.FinalDamages
		local IsCritical = event.IsCritical
		local HitCount = event.HitCount
		---------------------------------------------------------
		self:OnDefaultAttackHit(Target,HitCount)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleSkillHit(SkillHit event)
		-- Parameters
		local Attacker = event.Attacker
		local Target = event.Target
		local InitialDamages = event.InitialDamages
		local FinalDamages = event.FinalDamages
		local IsCritical = event.IsCritical
		---------------------------------------------------------
		self:OnSkillHit(Target)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleVamp(Vamp event)
		-- Parameters
		local VampRate = event.VampRate
		local VampAmount = event.VampAmount
		local Attacker = event.Attacker
		local Victim = event.Victim
		---------------------------------------------------------
		if Attacker == self.Entity then 
			self:OnVamp(VampAmount, VampRate)
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleKillUnit(KillUnit event)
		-- Parameters
		local Attacker = event.Attacker
		local Target = event.Target
		-- local DeadTile = event.DeadTile
		-- local AttackType = event.AttackType
		---------------------------------------------------------
		-- 상대 유닛을 킬할 때
		if self.Entity == Attacker then
			self:OnKillUnit()
		end
	end

end