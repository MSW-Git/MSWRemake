	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10033()
		-- NI10033 산타 장갑: 
			-- 이 아이템을 장착하면 다른 아이템을 장착할 수 없습니다. 
			-- 전투 시작 시, 무작위 아이템 2개를 장착합니다.
		--------------------------------------------------------
		local unitInfo = self.Entity.UnitInfo
		
		local userId = unitInfo.OwnerId
		local user = _UserService:GetUserEntityByUserId(userId)
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		
		-- 룬 체크 여부
		local rc20033Checked = false
		
		-- 유닛 팀 타입 확인
		if unitInfo.TeamType == "User" then
			-- 유저의 유닛인 경우
			if userPControl.Rune_SetCheck["RC20033"] > 0 then
				rc20033Checked = true
			end
		else
			-- 적 유닛인 경우
			for _, runeID in pairs(teamManager.EnemyOwnedRunes) do
				if runeID == "RC20033" then
					rc20033Checked = true
					break
				end
			end
		end
		
		
		-- 룬 On
		if rc20033Checked then
			-- RC20033 룬 On
			local RC20033_DataSet = _DataService:GetTable("CharMostItemSet")
			local charBestItemRow = RC20033_DataSet:FindRow("CharID", unitInfo.charID)
			
			---@type table<string>
			local setItemList = {}
			
			for i = 1, 8 do
				table.insert(setItemList, charBestItemRow:GetItem( string.format("ItemID_%d", i) ).."_copied" )
			end
			
			for i = 1, 2 do
				local randItemIdx = _UtilLogic:RandomIntegerRange(1, #setItemList)
				local randItemID = setItemList[randItemIdx]
				self.Entity.UnitStatus:SetProperty("EquippedItemIDList", randItemID, "insert,-1")
				
				table.remove(setItemList, randItemIdx)
			end
		-- 룬 Off
		else
			local stage = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId).GameManager.Stage
			local isFullNI = false
			-- 1~6스테이지 : 스테이지에 따라 무작위 확률로 (완성템1개+재료템1개) 또는 (완성템 2개) 착용
			if stage <= 6 then
				local prob = 15*stage -- 스테이지 * 15%
				local randValue = _UtilLogic:RandomIntegerRange(1, 100)
				if randValue <= prob then
					isFullNI = true
				else
					isFullNI = false
				end
			end
			
			local getTargetNormalItemIndex = function()
				local index = _UtilLogic:RandomIntegerRange(1,35)
				if index < 33 then
					return index
				else
					return index+1
				end
			end
			-- 모두 완성 아이템인 경우
			if isFullNI then
				for i=1,2 do
					local randItemID = "NI100".. string.format("%02d", getTargetNormalItemIndex()).."_copied"
					self.Entity.UnitStatus:SetProperty("EquippedItemIDList", randItemID, "insert,-1")
				end
			-- 완성템1개 + 재료템1개 인 경우
			else
				local randItemID1 = "NI100".. string.format("%02d", getTargetNormalItemIndex()).."_copied"
				self.Entity.UnitStatus:SetProperty("EquippedItemIDList", randItemID1, "insert,-1")
				
				local randItemID2 = "MI100".. string.format("%02d",_UtilLogic:RandomIntegerRange(1,8)).."_copied"
				self.Entity.UnitStatus:SetProperty("EquippedItemIDList", randItemID2, "insert,-1")
			end
		end
		
		
		self.Entity.UnitItem:RefreshItemStatus()
		--self.Entity.UnitStatus:SetUnitStatus(false)	-- 아이템 장착한 유닛의 스탯 갱신
		
		_ItemSetLogic:PlayItemEquipDirection(self.Entity, user.OwnerId)-- 아이템 장착 연출
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10034()
		--NI10034 : 스킬 사용 시, 가장 가까운 아군 1명 및 자신에게 MP 10 제공
		-----------------------------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		
		local ownerUserID = unitInfo.OwnerId
		
		local user = _UserService:GetUserEntityByUserId(ownerUserID)
		local teamManager = user.TeamManager
		
		---@type table<Entity>
		local allies = nil
		
		if unitInfo.TeamType == "User" then
			allies = _BTLogic_New:getEntities(teamManager.OwnUnits,"Alive")
		
		elseif unitInfo.TeamType == "Enemy" then
			allies = _BTLogic_New:getEntities(teamManager.EnemyUnits,"Alive")
		end
		-----------------------------------------------------------------------
		local unitStatus = unit.UnitStatus
		local recoverAmount = 10 --unitStatus.MaxMP * 0.3 -- 유닛 MaxMP의 30%
		
		-- 자기 자신이 마나 획득
		local castRound = string.format("%d-%d", user.GameManager.Stage, user.GameManager.Round)
		local getMPSelf = function()
			-- 예외 처리 : 전투 종료 상태인지
			if user.GameManager.PhaseType ~= "Battle" then
				return
			end
			
			-- 예외 처리 : 다른 라운드인지
			local currentRound = string.format("%d-%d", user.GameManager.Stage, user.GameManager.Round) 
			if castRound ~= currentRound then
				return
			end
			------------------------------------------------
			_StatusChangeLogic:SetVariableStatus(self.Entity, self.Entity, "MP", recoverAmount, "item")
		end
		_TimerService:SetTimerOnce(getMPSelf, 0.5)
		
		_GeneralDirectorLogic:BattleBuffEffect(self.Entity, _RuneCardDirectEnum.MP, self.Entity.UnitInfo.OwnerId)
		
		-- 가장 가까운 아군 1명이 마나 획득
		local mainTile = unitInfo.setTile
		local targets = _BTLogic_New:getTargets(mainTile, allies, "Nearest_2") --가장 가까운 아군 2명 가져온 후 자기 자신 제외
		
		if targets ~= nil then
			for i=1, #targets do
				
				if targets[i] == self.Entity then --자기 자신 제외
					continue
				end
		
				_StatusChangeLogic:SetVariableStatus(self.Entity, targets[i], "MP", recoverAmount, "item")
				
				--연출용 이펙트
				_GeneralDirectorLogic:BattleBuffEffect(targets[i],_RuneCardDirectEnum.MP,self.Entity.UnitInfo.OwnerId)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10035()
		-- 스킬 사용 시 자기 자신을 제외한 체력 비율이 가장 낮은 아군에게 4초간 소모한 마나의 200%만큼 보호막 부여
		--------------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local mainTile = unitInfo.setTile
		local ownerUserID = unitInfo.OwnerId
		
		local user = _UserService:GetUserEntityByUserId(ownerUserID)
		local teamManager = user.TeamManager
		--------------------------------
		-- 타겟 검색
		---@type table<Entity>
		local allies = nil
		if unitInfo.TeamType == "User" then
			allies =  _BTLogic_New:getEntities(teamManager.OwnUnits,"Alive")
		elseif unitInfo.TeamType == "Enemy" then
			allies = _BTLogic_New:getEntities(teamManager.EnemyUnits,"Alive")
		end
		local target = _BTLogic_New:getTarget(mainTile, allies, "HPper_Low_ExceptionMe")
		--------------------------------
		local shieldAmount = unitStatus.MaxMP * 2 -- 보호막 획득량
		--------------------------------
		-- 타겟에게 보호막 적용
		if isvalid(target) == true then
			_StatusChangeLogic:SetShield(self.Entity, target, shieldAmount, 4, "NI10035")
		end
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_SI10001()
		--[[
		 [방해꾼]의 가면 : 
		아군 방해꾼 캐릭터 중 하나에게 가면을 줄 수 있습니다. 
		전투 시작 시 가면을 가진 아군 캐릭터와 반대편에 있는 적 캐릭터가 서로 위치를 바꿉니다. 
		위치를 바꾼 아군 방해꾼은 은신 상태가 됩니다.
		]]
		--------------------------------------------------------------------
		local owner = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
		local teamManager = owner.TeamManager
		local synergyManager = owner.SynergyManager_New
		local teamType = self.Entity.UnitInfo.TeamType
		--------------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		local runeCheckedAddPer = 1
		--------------------------------------------------------------------
		local duration = 4
		
		-- 활성화된 시너지 숫자 체크
		local activatedSynergyCount = 0
		if teamType == "Enemy" then
			activatedSynergyCount = teamManager.EnemyOwnedFieldSynergy["S10011"]
			
			if synergyManager.Enemy_SynergyRuneOn["S10011"] then
				runeCheckedAddPer += 0.5 * synergyManager.Enemy_SynergyRuneOn["S10011"]
			end
		else
			activatedSynergyCount = teamManager.OnFieldSynergy["S10011"]
			
			if synergyManager.SynergyRuneOn["S10011"] > 0 then
				runeCheckedAddPer += 0.5 * synergyManager.SynergyRuneOn["S10011"]
			end
		end
		
		-- 활성화된 시너지 숫자에 따라 지속시간 변경
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
			log_error("activatedSynergyCount is nil")
			return
		elseif activatedSynergyCount < 5 then
			duration = 3
		elseif activatedSynergyCount < 7 then
			duration = 4.5
		elseif activatedSynergyCount < 9 then
			duration = 6
		else
			duration = -1
		end
		
		duration *= runeCheckedAddPer
		--------------------------------------------------------
		-- 서로 위치를 바꿉니다.
		
		-- 	1. 바꿀 위치를 찾습니다.
		local standingTile = self.Entity.UnitInfo.setTile
		local verIdx = standingTile.TileComponent_New.verticalNum
		local horIdx = 18 - standingTile.TileComponent_New.horizontalNum*2 + (verIdx%2)
		local standardTile = owner.GameManager.RoomTile[string.format("%d,%d", horIdx, verIdx)]
		
		
		--  2. 적 후보를 가져옵니다.
		---@type table<Entity>
		local enemies = {}
		if teamType == "Enemy" then
			table.initialize(enemies, teamManager.OwnUnits)
			for i=#enemies, 1, -1 do
				-- 필드 위 유닛이 아닌 경우
				if enemies[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(enemies, i)
				-- 제외 유닛 (C00003)
				elseif enemies[i].UnitInfo.charID == "C00003" then
					table.remove(enemies, i)
				else
					-- 방해꾼의 가면 아이템을 든 유닛의 경우
					for _, itemID in pairs(enemies[i].UnitStatus.EquippedItemIDList) do
						if isvalid(itemID) and itemID == "SI10001" then
							table.remove(enemies, i)
						end
					end
				end
			end
		else
			table.initialize(enemies, teamManager.EnemyUnits)
			for i=#enemies, 1, -1 do
				-- 필드 위 유닛이 아닌 경우
				if enemies[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(enemies, i)
				-- 제외 유닛 (C00003)
				elseif enemies[i].UnitInfo.charID == "C00003" then
					table.remove(enemies, i)
				else
					-- 방해꾼의 가면 아이템을 든 유닛의 경우
					for _, itemID in pairs(enemies[i].UnitStatus.EquippedItemIDList) do
						if isvalid(itemID) and itemID == "SI10001" then
							table.remove(enemies, i)
						end
					end
				end
			end
		end
		
		
		-- A. 룬카드 시너지 활성화 시, 같은 행의 적 유닛에게 마나 과부하를 부여합니다.
		if runeCheckedAddPer > 1 then
			for _, enemy in pairs(enemies) do
				if self.Entity.UnitInfo.setTileVerticalNum == enemy.UnitInfo.setTileVerticalNum then
					_StatusChangeLogic:SetStatus(self.Entity, enemy, "SE0013", -1)
				end
			end
		end
		
		
		--  3. 바꿀 위치에서 가장 가까운 적을 가져옵니다. (빈 칸일 경우 대비)
		local target = _BTLogic_New:getTarget(standardTile, enemies, "Nearest")
		if isvalid(target) == false then
			--log("위치를 바꿀 대상이 없습니다.")
			return
		end
		
		--  4. 해당 유닛이 가진 타일을 찾습니다.
		local targetTile = target.UnitInfo.setTile
		
		--  5. 위치를 바꿉니다. (셋하면 자동 교체)
		self.Entity.UnitInfo:SetPropertyToServer("setTile", targetTile, "All", true)
		target.UnitInfo:SetPropertyToServer("setTile", standingTile, "All", true)
		
		--  5.1 시너지가 5 시너지 이상인 경우, 물리 방어력 및 마법 방어력의 50%를 강탈합니다.
		if activatedSynergyCount >= 5 then
			-- 획득
			_StatusChangeLogic:GetBuff(self.Entity, "Add_Defence", target.UnitStatus.Defence * 0.5, -1)
			_StatusChangeLogic:GetBuff(self.Entity, "Add_MagicalResistance", target.UnitStatus.MagicalResistance * 0.5, -1)
			-- 감소
			_StatusChangeLogic:GetBuff(target, "Add_Defence", -target.UnitStatus.Defence * 0.5, -1)
			_StatusChangeLogic:GetBuff(target, "Add_MagicalResistance", -target.UnitStatus.MagicalResistance * 0.5, -1)
			
			-- 이펙트
			_TimerService:SetTimerOnce(function() _SynergyBattleDirectorLogic:S10011TakePower(self.Entity,target,self.Entity.UnitInfo.OwnerId) end , 0.2)
		end 
		
		
		--  6. 위치 변경 이펙트 재생
		_SynergyBattleDirectorLogic:S10011ChangePos(self.Entity,target,self.Entity.UnitInfo.OwnerId)
		
		--------------------------------------------------------
		-- 은신 상태가 됩니다.
		if duration > 0 then	-- (3)(5)(7) : 지속시간동안 은신
			_StatusChangeLogic:SetStatus(self.Entity, self.Entity, "SE0002", duration)
		else					-- (9) 방해꾼 : 모든 아군이 처치될 때까지 은신
			local gameManager = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId).GameManager
			local timerID = 0
			local castRound = string.format("%d-%d", gameManager.Stage, gameManager.Round)
			local hide = function()
				-- 종료 조건1. 모든 아군이 처치됨 (나만 남음)
				local leftTeamMatesCount = 0
				if self.Entity.UnitInfo.TeamType == "User" then
					leftTeamMatesCount = gameManager.MyUnitCount 
				elseif self.Entity.UnitInfo.TeamType == "Enemy" then
					leftTeamMatesCount = gameManager.EnemyCount
				end
				
				if leftTeamMatesCount <= 1 then
					_TimerService:ClearTimer(timerID)
				end
				
				-- 종료 조건2. 전투가 끝나거나 라운드 다름
				local thisRound = string.format("%d-%d", gameManager.Stage, gameManager.Round) 
				if gameManager.PhaseType ~= "Battle" or thisRound ~= castRound then
					_TimerService:ClearTimer(timerID)
				end
				----------------------------------------------------------------------------
				_StatusChangeLogic:SetStatus(self.Entity, self.Entity, "SE0002", 1)
			end
			timerID = _TimerService:SetTimerRepeat(hide, 1, 0)
			
			local timerID2 = 0
			local makeSlow = function()
				-- 종료 조건
				local thisRound = string.format("%d-%d", gameManager.Stage, gameManager.Round) 
				if gameManager.PhaseType ~= "Battle" or thisRound ~= castRound then
					_TimerService:ClearTimer(timerID2)
				end
				----------------------------------------------------------------------------
				-- 주변 1칸 내 모든 적 3초간 둔화
				local targets = _BTLogic_New:getTargets(self.Entity.UnitInfo.setTile, enemies, "Around_1_1") 
				for _, target in pairs(targets) do
					_StatusChangeLogic:SetStatus(self.Entity, target, "SE0014", 3)
				end
			end
			timerID2 = _TimerService:SetTimerRepeat(makeSlow, 3, 0)
		end
		--------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_KillUnit_SI10001()
		--[[
		 [방해꾼]의 가면 : 
		아군 방해꾼 캐릭터 중 하나에게 가면을 줄 수 있습니다. 
		전투 시작 시 가면을 가진 아군 캐릭터와 반대편에 있는 적 캐릭터가 서로 위치를 바꿉니다. 
		위치를 바꾼 아군 방해꾼은 은신 상태가 됩니다.
		]]
		--------------------------------------------------------------------
		local owner = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
		local teamManager = owner.TeamManager
		local synergyManager = owner.SynergyManager_New
		local teamType = self.Entity.UnitInfo.TeamType
		--------------------------------------------------------------------
		-- 활성화된 시너지 숫자 체크
		local activatedSynergyCount = 0
		if teamType == "Enemy" then
			activatedSynergyCount = teamManager.EnemyOwnedFieldSynergy["S10011"]
		else
			activatedSynergyCount = teamManager.OnFieldSynergy["S10011"]
		end
		--------------------------------------------------------------------
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 7 then
			return
		end
		
		-- 7 방해꾼 이상 : 해당 유닛이 킬을 먹으면, 2초간 은신
		_StatusChangeLogic:SetStatus(self.Entity, self.Entity, "SE0002", 2)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_SI10002()
		-- 분노의 옥석
		-- 죽음에 다다를 때 죽지 않고 2.4초간 무적
		--------------------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		--------------------------------------------------------------
		self.ItemAbilityStacks["SI10002"] -= 1
		--------------------------------------------------------------
		_StatusChangeLogic:SetVariableStatus(unit, unit, "HP", 1, "Item")
		_StatusChangeLogic:SetStatus(unit, unit, "SE0001", 2.4)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_SI10003()
		-- 질투의 옥석
		-- 인접한 아군 유닛 수만큼 방어력 및 마법 방어력 15씩 증가
		--------------------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		--------------------------------------------------------------
		local teamTable = {}
		if unitInfo.TeamType == "User" then
			teamTable = teamManager.OwnUnits
		else
			teamTable = teamManager.EnemyUnits
		end
		
		local checkUnits = _BTLogic_New:getTargets(unitInfo.setTile, teamTable, "Around_1_1")
		
		_StatusChangeLogic:GetBuff(unit, "Add_Defence", 15 * #checkUnits, -1)
		_StatusChangeLogic:GetBuff(unit, "Add_MagicalResistance", 15 * #checkUnits, -1)
	end

