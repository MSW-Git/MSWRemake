@Component
script UnitItem extends Component

	property SyncTable<string, number> ItemAbilityStacks

	property SyncTable<number> InBattleAbilityStacks

	property boolean IsBattlePhase = false

	property SyncTable<string, number> AddedStatus

	property SyncTable<string, number> MultiplyStatus

	property number DefaultAttackCount = 0

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 아이템 컴포넌트 초기화 및 스택 초기화
		self:ClearAllStacks()
		self:InitAllProperties()
		
		local statusType = {
			"MaxHP",						-- 최대 체력
		
			"MaxMP",						-- 최대 마나
			"MP",							-- 시작 마나
		
			"PhysicalAttack",				-- 공격력
			"MagicalAttack",				-- 마력
			"Defence",						-- 물리 방어력
			"MagicalResistance",			-- 마법 방어력
			"AttackSpeed",					-- 공격속도
			"AttackRange",					-- 공격 사거리
			"SkillRange",					-- 스킬 사거리
			"CriticalPercent",				-- 크리티컬 확률
			"CriticalDamagePercent",		-- 크리티컬 데미지
			"BloodAbsorptionPercent",		-- 흡혈률
			"MoveSpeed",					-- 이동속도
			"DealingDamageRate",			-- 가해량 비율
		--	"TakingDamageRate",				-- 피해량 비율
		--	"TakingDamageBonusAmount",		-- 피해량 증가
			"MPBonusWhenAttack",			-- 공격 시 마나 획득량
			"MPBonusWhenBeAttacked",		-- 피격 시 마나 획득량
			"HPRecoverRate", 				-- 체력 회복 효과 비율
			"StatusEffectRemainTimeRate",	-- 제어 효과 지속시간 비율
		}
		
		-- 초기화 : 매 함수 실행마다 모든 값을 다시 계산하므로, 기본값으로 리셋합니다. 
		for i=1, #statusType do
			self.AddedStatus[statusType[i]] = 0
			self.MultiplyStatus[statusType[i]] = 0
		end
	end

	@ExecSpace("ServerOnly")
	method void RefreshItemStatus()
		-- 아이템을 장착할 때, 아이템으로 얻는 스탯 효과를 갱신하는 함수입니다.
		--------------------------------------------------------------------------
		local itemTable = _DataService:GetTable("ItemStatus")
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		local equippedItemList = unitStatus.EquippedItemIDList
		--------------------------------------------------------------------------
		local beforeValue_add = {}
		local beforeValue_multi = {}
		local isChanged = {}
		
		-- 모든 아이템으로 얻은 스탯값을 초기화합니다.
		for k,v in pairs(self.AddedStatus) do
			beforeValue_add[k] = v
			self.AddedStatus[k] = 0
			isChanged[k] = false
		end
		
		for k,v in pairs(self.MultiplyStatus) do
			beforeValue_multi[k] = v
			self.MultiplyStatus[k] = 0
			isChanged[k] = false
		end
		--------------------------------------------------------------------------
		-- 시너지 관련 체크 필요 아이템들
		local s31_items = {"SI10002", "SI10003", "SI10004", "SI10005", "SI10006", "SI10007", "SI10008"}
		--------------------------------------------------------------------------
		for i=1, #equippedItemList do
			local itemID = _UtilLogic:Split(equippedItemList[i], "_")[1]
			local row = itemTable:FindRow("ItemID", itemID)
			
			-- 기본 스탯
			self.MultiplyStatus["PhysicalAttack"] += tonumber(row:GetItem("PhysicalAttack")) 
			self.MultiplyStatus["MagicalAttack"] += tonumber(row:GetItem("MagicalAttack")) 
			self.AddedStatus["MaxHP"] += tonumber(row:GetItem("MaxHP")) 
			self.AddedStatus["MP"] += tonumber(row:GetItem("MP")) 
			self.AddedStatus["Defence"] += tonumber(row:GetItem("Defence")) 
			self.AddedStatus["MagicalResistance"] += tonumber(row:GetItem("MagicalResistance")) 
			self.MultiplyStatus["AttackSpeed"] += tonumber(row:GetItem("AttackSpeed"))
			self.AddedStatus["CriticalPercent"] += tonumber(row:GetItem("CriticalPercent")) 
			self.AddedStatus["CriticalDamagePercent"] += tonumber(row:GetItem("CriticalDamagePercent")) 
			self.AddedStatus["BloodAbsorptionPercent"] += tonumber(row:GetItem("BloodAbsorptionPercent")) 
			self.MultiplyStatus["MoveSpeed"] += tonumber(row:GetItem("MoveSpeed"))
			
			-- 아랫마을 유닛이 시너지 관련 아이템을 장착한다면, 최대 체력 100 증가
			for _, checkItemID in pairs(s31_items) do
				if checkItemID == itemID then
					if unitInfo:DoesHaveSynergy("S10031") then
						self.AddedStatus["MaxHP"] += 100
					end
				end
			end
		end
		
		for k, v in pairs(beforeValue_add) do
			if v ~= self.AddedStatus[k] then
				isChanged[k] = true
			end
		end
		
		for k, v in pairs(beforeValue_multi) do
			if v ~= self.MultiplyStatus[k] then
				isChanged[k] = true
			end
		end
		
		local user = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
		local gameManager = user.GameManager
		for k, v in pairs(isChanged) do
			if v == true then
				if gameManager.PhaseType == "Battle" then
					self.Entity.UnitStatus:SetUnitStatusByStat(true, k)
				else
					self.Entity.UnitStatus:SetUnitStatusByStat(false, k)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void InitAllProperties()
		self.ItemAbilityStacks["SI10002"] = 1	-- 분노의 옥석 : 무적 처리 체크
	end

	@ExecSpace("ServerOnly")
	method void OnSettingPhase()
		-- 준비 > 세팅 > 전투 중 '세팅' 단계가 시작되면 실행합니다.
		-------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			if equippedItem[i] == "NI10033" then
				self:UseItemAbility_NI10033()
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBattleStart()
		-- 전투 시작 시 효과
		self.IsBattlePhase = true
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			local itemID = _UtilLogic:Split(equippedItem[i], "_")[1] -- string.sub(equippedItem[i], 1, 6)
			
			if itemID == "NI10001" then		-- 화염의 카타나
				self:UseItemAbility_NI10001()
				
			elseif itemID == "NI10002" then -- 스틸 미셀 
				self:UseItemAbility_NI10002()
				
			elseif itemID == "NI10017" then -- 에스터 실드
				self:UseItemAbility_NI10017()
				
			elseif itemID == "NI10019" then -- 타임리스 귀고리
				self:UseItemAbility_NI10019()
				
			elseif itemID == "NI10021" or itemID == "NI10026" then -- 2초마다 최대 체력의 4% 회복
				self:UseItemAbility_NI10021()
		
			elseif itemID == "NI10024" then -- 사파이어 귀고리
				self:UseItemAbility_NI10024()
				
			elseif itemID == "NI10027" then	-- 전투 시작 후 5초마다 마력 +30 (중첩 가능)
				self:UseItemAbility_NI10027()
				
			elseif itemID == "NI10030" then -- 별빛 팔찌
				self:UseItemAbility_NI10030()
				
			elseif itemID == "SI10001" then --방해꾼의 가면
				self:UseItemAbility_SI10001()
		
			elseif itemID == "SI10003" then -- 질투의 옥석
				self:UseItemAbility_SI10003()
						
			elseif itemID == "SI10005" then -- 후회의 옥석
				local function Set()
					if self.IsBattlePhase then
						self.InBattleAbilityStacks[i] += 1
					end
				end
				_TimerService:SetTimerOnce(Set, 10)
				
			elseif itemID == "SI10008" then -- 시기의 옥석
				self:UseItemAbility_SI10008()
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnEquippedChangedDuringBattlePhase(number idx)
		-- 전투 중 idx번 슬롯에 아이템을 장착한 경우, 해당 아이템의 전투 시작 효과를 발동시키기 위한 함수입니다.
		--------------------------------------------------------------------------------
		-- 예외처리 : 전투 중이 아닌데 이 함수를 호출한 경우 (아이템 장착 시 자동 호출), return
		local user = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
		if user.GameManager.PhaseType ~= "Battle" then return end
		--------------------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		local itemID = _UtilLogic:Split(equippedItem[idx], "_")[1]
		
		
		if itemID == "NI10001" then -- 화염의 카타나
			self:UseItemAbility_NI10001()
			
		elseif itemID == "NI10019" then --타임리스 귀고리
			self:UseItemAbility_NI10019()
			
		elseif itemID == "NI10021" then --파란색 가운
			self:UseItemAbility_NI10021()
		
		elseif itemID == "NI10024" then --사파이어 귀고리
			self:UseItemAbility_NI10024()
			
		elseif itemID == "NI10027" then -- 자쿰의 나뭇가지
			self:UseItemAbility_NI10027()	
			
		elseif itemID == "NI10033" then --산타 장갑
			self:UseItemAbility_NI10033()
			
		end
	end

	@ExecSpace("ServerOnly")
	method void OnAttacked()
		-- 피격 시 발동되는 효과
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		local hpRate = self.Entity.UnitStatus.HP / self.Entity.UnitStatus.MaxHP
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
		
			if itemID == "NI10002" or itemID == "NI10030" then	-- 전투 당 1번, 남은 체력이 30%가 되면 최대 체력의 20%만큼 보호막 획득.
				if hpRate <= 0.3 and self.InBattleAbilityStacks[i] < 1 then
					self:UseItemAbility_ShieldByHP()
					self.InBattleAbilityStacks[i] += 1
				end
				
			elseif itemID =="NI10004" or itemID == "NI10018" then -- 전투 당 1번, 체력이 60%가 되면 2초간 은신 및 무적
				if hpRate <=0.6 and self.InBattleAbilityStacks[i] < 1 then
					self:UseItemAbility_NI10004()
					self.InBattleAbilityStacks[i] += 1
				end			
		
			elseif 	itemID =="NI10015" then -- 권투 글러브
				self:UseItemAbility_NI10015(i)
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method void OnAttacked_Damage(Entity attacker, table finalDamages)
		-- 공격자가 특정 아이템을 가지고 있을 경우 발동되는 효과 
		------------------------------------------------------------------
		if isvalid(attacker) == false then
			return
		end
		------------------------------------------------------------------
		local totalDamage = 0
		for _, damage in pairs(finalDamages) do
			totalDamage += damage
		end
		------------------------------------------------------------------
		local equippedItem = attacker.UnitStatus.EquippedItemIDList
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
		
			if itemID == "NI10003" or itemID == "NI10023" then 		-- 가해량의 일부만큼 체력 가장 낮은 아군 치유
				self:UseItemAbility_NI10023(attacker, totalDamage)
			elseif itemID == "NI10006" or itemID == "NI10028" then	-- 화상 상태인 적을 공격 시 8%의 추가 고정 피해를 입힙니다.
				if self.Entity.UnitStatus.StatusTime["SE0017"] > 0 then
					_StatusChangeLogic:HitDamage(attacker, self.Entity, 0, 0, totalDamage*0.08, "finalBonusDamage")
				end
			elseif itemID == "NI10007" then
				local prob = _UtilLogic:RandomIntegerRange(1, 100)
				if finalDamages[1] > 0 and prob <= 20 then	-- 물리 피해 적중 시 20% 확률로
					attacker.UnitItem:UseItemAbility_NI10007(self.Entity)
				end
				
			elseif itemID == "NI10010" then							-- 물리 방어 약화 상태인 적을 공격 시 8%의 추가 고정 피해
				if self.Entity.UnitStatus.StatusTime["SE0008"] > 0 then
					_StatusChangeLogic:HitDamage(attacker, self.Entity, 0, 0, totalDamage*0.08, "finalBonusDamage")
				end
			elseif itemID == "NI10011" then							-- 마법 방어 약화 상태인 적을 공격 시 8%의 추가 고정 피해
				if self.Entity.UnitStatus.StatusTime["SE0009"] > 0 then
					_StatusChangeLogic:HitDamage(attacker, self.Entity, 0, 0, totalDamage*0.08, "finalBonusDamage")
				end
			elseif itemID == "NI10029" then
				local prob = _UtilLogic:RandomIntegerRange(1, 100)
				if finalDamages[2] > 0 and prob <= 40 then -- 마법 피해 적중 시 40% 확률로
					attacker.UnitItem:UseItemAbility_NI10007(self.Entity)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnUseSkill()
		-- 스킬 사용 시 효과
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
			
			if itemID == "NI10012" then --드래곤 샤인 보우
				self.InBattleAbilityStacks[i] = self.InBattleAbilityStacks[i] +1 -- 스킬 사용 후 기본 공격시 특수 효과 적용 
			
			elseif itemID == "NI10020" or itemID == "NI10025" then	
				self:UseItemAbility_NI10020(itemID)	-- 스킬 사용 시, 4초동안 최대 마나만큼 보호막 획득
				
			elseif itemID == "NI10034" then -- 스킬 사용 시, 가장 가까운 아군 2명 및 자신에게 MP 10 제공
				self:UseItemAbility_NI10034()
				
			elseif itemID == "NI10032" then	--골드 드롭 귀고리
				self:UseItemAbility_NI10032()
				
			elseif itemID == "NI10035" then -- 스킬 사용 시 체력이 가장 낮은 아군에게 4초간 소모한 마나의 200%만큼 보호막 부여
				self:UseItemAbility_NI10035()
				
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnKillUnit()
		-- 스킬 사용 시 효과
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
			
			if itemID == "SI10004" then -- 식탐의 옥석 보유
				self:UseItemAbility_SI10004()
			elseif itemID == "SI10001" then
				self:UseItemAbility_KillUnit_SI10001()
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnDefaultAttack(Entity target)
		-- 공격 시 효과
		------------------------------------------------------------------
		--기본 공격 횟수 기록 
		self.DefaultAttackCount = self.DefaultAttackCount + 1
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
			
			if itemID == "NI10009" then 		-- 신속의 날개
				self.InBattleAbilityStacks[i] += 1
				self:UseItemAbility_NI10009()
				
			elseif itemID == "NI10015" then 	-- 파란색 권투 글러브
				self:UseItemAbility_NI10015(i)
				
			elseif itemID == "SI10007" then 	-- 탐욕의 옥석
				self:UseItemAbility_SI10007()
			end	
		end
		
	end

	@ExecSpace("ServerOnly")
	method void OnDefaultAttackHit(Entity target, integer hitCount)
		-- 기본 공격 적중 시 효과
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
			
			if itemID == "NI10006" then --소드 귀고리 : 기본 공격 적중 시 적 화상
				self:UseItemAbility_NI10006(target)
					
						
			elseif itemID == "NI10008" then --붉은 채찍
				-- 첫 번째 타격이면서 세 번째 기본 공격 적중 시 효과 적용 
				if hitCount == 1 and self.DefaultAttackCount % 3 == 0 then 
					self:UseItemAbility_NI10008(target)
				end
				
			elseif itemID == "NI10010" then --냄비 뚜껑
				self:UseItemAbility_NI10010(target)
		        --if self.AbilityStatkcs[i] % 3 == 0 then --세번째 기본 공격 시 특수효과 적용
		        --    self:UseItemAbility_NI10010(target)
		        --end	
				
			elseif itemID == "NI10011" then --화이트 네쉐르
				self:UseItemAbility_NI10011(target)
		        --if self.AbilityStatkcs[i] % 3 == 0 then --세번째 기본 공격 시 특수효과 적용
		        --    self:UseItemAbility_NI10011(target)
		        --end	
		
			elseif itemID == "NI10012" then --드래곤 샤인 보우
				if self.InBattleAbilityStacks[i] > 0 then 
					self:UseItemAbility_NI10012(target)
					self.InBattleAbilityStacks[i] = 0
				end
		
				
			elseif itemID == "NI10028" then --레드 해골 귀고리		
				self:UseItemAbility_NI10028(target)
		
			elseif itemID == "SI10005" then -- 후회의 옥석
				if self.InBattleAbilityStacks[i] >= 1 then
					self:UseItemAbility_SI10005(target)
				end
				
			elseif itemID == "SI10006" then -- 후회의 옥석
				self:UseItemAbility_SI10006(target)
			end
		
		end
	end

	@ExecSpace("ServerOnly")
	method void OnSkillHit(Entity target)
		-- 스킬 적중 시 효과
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
		
			if itemID == "NI10006" then --소드 귀고리
				self:UseItemAbility_NI10006(target)
				
			elseif itemID == "NI10010" then	-- 냄비 뚜껑
				self:UseItemAbility_NI10010(target)	
				
			elseif itemID == "NI10011" then	-- 화이트 네쉐르
				self:UseItemAbility_NI10011(target)		
				
			elseif itemID == "NI10028" then --레드 해골 귀고리		
				self:UseItemAbility_NI10028(target)
		
			end
		
		end
	end

	@ExecSpace("ServerOnly")
	method void OnVamp(number vampAmount, number vampRate)
		-- 흡혈 시 발동되는 효과
		------------------------------------------------------------------
		local equippedItem = self.Entity.UnitStatus.EquippedItemIDList
		for i=1, #equippedItem do
			local itemID =  _UtilLogic:Split(equippedItem[i], "_")[1]
		end
	end

	@ExecSpace("ServerOnly")
	method void ClearAllStacks()
		-- 모든 아이템의 사용 효과, 누적 스택 등의 값을 초기화하는 함수
		-- 라운드가 종료되면 호출됩니다.
		self.IsBattlePhase = false
		-------------------------------------------
		for i=1, 3 do
			self.InBattleAbilityStacks[i] = 0
		end
		self.DefaultAttackCount = 0 --기본 공격 타수 기록
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10001()
		-- 화염의 카타나 : 전투 시작 후 5초마다 공격력 +15% (중첩 가능)
		local gameManager = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId).GameManager
		local timerID = 0
		local castingRound = string.format("%d-%d", gameManager.Stage, gameManager.Round)
		local getBuff = function()	
			local phaseType = gameManager.PhaseType
			local currentRound = string.format("%d-%d", gameManager.Stage, gameManager.Round)
			if phaseType ~= "Battle" or self.Entity.UnitStatus:IsDead() or castingRound ~= currentRound then
				_TimerService:ClearTimer(timerID)
			else
				_StatusChangeLogic:GetBuff(self.Entity, "Multi_PhysicalAttack", 15, -1)
			end
		end
		
		timerID = _TimerService:SetTimerRepeat(getBuff, 5, 5)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10002()
		--NI10002 스틸 미셀: 전투 시작 후 15초간 기절 등 상태이상으로부터 면역 상태가 됩니다.
		
		_StatusChangeLogic:SetStatus(self.Entity, self.Entity, "SE0016", 15)
	end

