	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10007(Entity target)
		-- (NI10007) 물리 공격 적중 시 20% 확률로 대상을 마나 과부하 상태로 만듭니다. 
		-- (NI10029) 마법 공격 적중 시 40% 확률로 대상을 마나 과부하 상태로 만듭니다. 
		-- (공통) 이 효과로 적을 마나 과부하 상태로 만들 때마다 전투 종료 시까지 최종 가해량이 6% 증가합니다. (중첩 가능)
		-----------------------------------------------------------------
		-- 마나 과부하가 걸린 상태가 아니라면, 버프 획득
		if target.UnitStatus.StatusEffect["SE0013"] == false then
			_StatusChangeLogic:GetBuff(self.Entity, "Add_DealingDamageRate", 6, -1)
		end
		
		_StatusChangeLogic:SetStatus(self.Entity, target, "SE0013", -1)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10008(Entity target)
		--NI10008 붉은 채찍: 세 번째 기본 공격 적중 시 주변 1칸 내 적에게 70%의 추가 물리 피해
		-----------------------------------------------------------------
		-- 예외 및 종료 처리
		if self.Entity.UnitAIWanderComponent.Enable == false then
			return
		end
		
		local unitInfo = self.Entity.UnitInfo
		
		local userId = unitInfo.OwnerId
		local user = _UserService:GetUserEntityByUserId(userId)
		local teamManager = user.TeamManager
		
		if user.GameManager.PhaseType ~= "Battle" then
			return
		end
		--------------------------------------------------------
		-- 대상 주변 1칸 내 적에게 70%의 추가 물리 피해
		local enemies = nil
		if unitInfo.TeamType == "User" then
			enemies = _BTLogic_New:getEntities(teamManager.EnemyUnits,"Alive") 
		elseif unitInfo.TeamType == "Enemy" then
			enemies = _BTLogic_New:getEntities(teamManager.OwnUnits,"Alive") 
		end
		
		if isvalid(target) == false or isvalid(target.UnitInfo.setTile) == false then
			log("target is nil 이어서 붉은채찍 효과 발동 안함")
			return
		end
		
		local targets = _BTLogic_New:getTargets(target.UnitInfo.setTile, enemies, "Around_1_1" )
		if targets ~= nil then
			
			_CustomizedBattleEffectService:PlayEffectAttached(
				"17f01e6848794daa8dba0e4b542d9d14",
				target,
				Vector3.zero,
				0,
				1 * Vector3.one,
				false,
				nil,
				unitInfo.OwnerId)
			
			for i=1, #targets do
				
				local attackDamange = self.Entity.UnitStatus.PhysicalAttack * 0.7
		
				_StatusChangeLogic:HitDamage(self.Entity, targets[i], attackDamange, 0, 0, "item")			
			end
		
		end
	end

