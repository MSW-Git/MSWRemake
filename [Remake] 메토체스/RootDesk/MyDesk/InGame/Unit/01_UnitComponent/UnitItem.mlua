	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10012(Entity target)
		--NI10012 드래곤 샤인 보우: 스킬 사용 후 다음 기본 공격시 마력의 200%에 해당하는 추가 마법 피해를 줍니다.
		-----------------------------------------------------------------
