			{["Color"]=Color.FromHexCode("#c2fff1")},
			self.Entity.UnitInfo.OwnerId)
		
		_StatusChangeLogic:HitDamage(self.Entity, target, 0, damage, 0, "item")
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10015(integer equippedItemIdx)
		--NI10015 파란색 권투 글러브: 공격하거나 피해를 받으면 입는 피해량 -0.4%, 가해량 +0.8% (최대 25스택)
		------------------------------------------------------
		local maxStack = 25 -- 최대 중첩 가능 수
		------------------------------------------------------
		-- 최대 중첩 시 호출 X
		if self.InBattleAbilityStacks[equippedItemIdx] >= maxStack then
			return
		end
		
		----공격하거나 피해를 받으면 공격력 1% 증가, 주문력 1 증가
		--_StatusChangeLogic:GetBuff(self.Entity, "Multi_PhysicalAttack", 1, -1)
		--_StatusChangeLogic:GetBuff(self.Entity, "Add_MagicalAttack", 1, -1)
		--
		
		-- 공격하거나 피해를 받으면 입는 피해량 -0.4%, 가해량 +0.8%
		_StatusChangeLogic:GetBuff(self.Entity, "Add_DealingDamageRate", 0.8, -1)
		_StatusChangeLogic:GetBuff(self.Entity, "DamageDecrease_Per", 0.4, -1)
		
		-- 중첩 회수 증가
		self.InBattleAbilityStacks[equippedItemIdx] += 1
		
		---- 최대 스택 도달 시 버프
		--if self.AbilityStatkcs[equippedItemIdx] >= maxStack then
		--    _StatusChangeLogic:GetBuff(self.Entity, "Multi_AttackSpeed", 40, -1)
		--end
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10017()
		--NI10017 에스터 실드:--전투 시작: 본인을 제외한 주변 1칸 내 아군에게 물리 방어력 +20, 마법방어력 +20 제공 
		-----------------------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local mainTile = unitInfo.setTile
		local ownerUserID = unitInfo.OwnerId
		
		local user = _UserService:GetUserEntityByUserId(ownerUserID)
		local teamManager = user.TeamManager
		
		---@type table<Entity>
		local allies = nil
		
		if unitInfo.TeamType == "User" then
			allies = _BTLogic_New:getEntities(teamManager.OwnUnits,"Alive") 
		
		elseif unitInfo.TeamType == "Enemy" then
			allies = _BTLogic_New:getEntities(teamManager.EnemyUnits,"Alive") 
		end
		-----------------------------------------------------------------
		
		local magicalDefence = 20 --물리 방어력 +20
		local physicalDefence = 20 --마법 방어력 +20
		
		local targets = _BTLogic_New:getTargets(mainTile, allies, "Around_1_1")
		
		if targets ~= nil then
			for i=1, #targets do
				
				if targets[i] == self.Entity then --본인 제외
					continue
				end
				
				_StatusChangeLogic:GetBuff(targets[i], "Add_MagicalResistance", magicalDefence, -1) --아군에게 마법 방어력 제공
				_StatusChangeLogic:GetBuff(targets[i], "Add_Defence", physicalDefence, -1) --아군에게 마법 방어력 제공
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10019()
		--NI10019 타임리스 귀고리: 2초마다 파동을 일으켜 주변 2칸 내 무작위 적 하나에게 75의 물리 피해를 입히고, 6초간 물리 방어 약화 적용
		--------------------------------------------------------
		local timerID = 0
		local makeWave = function()
			-- 예외 및 종료 처리
			if self.Entity.UnitAIWanderComponent.Enable == false then	-- 이 유닛이 사망하면 종료
				_TimerService:ClearTimer(timerID)
				return
			end
			
			local unitInfo = self.Entity.UnitInfo
			local userId = unitInfo.OwnerId
			
			local user = _UserService:GetUserEntityByUserId(userId)
			
			if not isvalid(user) then return end
			local teamManager = user.TeamManager
			
			if user.GameManager.PhaseType ~= "Battle" then	-- 전투 단계가 아니면 종료
				_TimerService:ClearTimer(timerID)
				return
			end
			--------------------------------------------------------
			-- 2칸 내 무작위 적 하나에게 물리 피해를 입히고, 6초간 물리 방어 약화 적용
			local enemies = nil
			if unitInfo.TeamType == "User" then
				enemies = _BTLogic_New:getEntities(teamManager.EnemyUnits,"Alive") 
				
			elseif unitInfo.TeamType == "Enemy" then
				enemies = _BTLogic_New:getEntities(teamManager.OwnUnits,"Alive")
			end
			
			local targets = _BTLogic_New:getTargets(self.Entity.UnitInfo.setTile, enemies, "Around_1_2")
			
			if targets ~= nil then
				local targetIdx = _UtilLogic:RandomIntegerRange(1, #targets)
				local target = targets[targetIdx]
				
				if isvalid(target) then
					_StatusChangeLogic:HitDamage(self.Entity, target, 75, 0, 0, "item") -- 75의 물리 피해
					_StatusChangeLogic:SetStatus(self.Entity, target, "SE0008", 6) -- 6초간 물리 방어 약화
				
					--연출용 이펙트
					_CustomizedBattleEffectService:PlayEffectAttached(
					"86163af626a44495aeee476d2b4e0c8b",
					target,
					Vector3(0,0.3,0),
					0,
					1.5 * Vector3.one,
					false,
					nil,
					userId)
					
					--파동 연출
					if not isvalid(self.Entity:GetChildByName("NI10019Wave")) then
						local particle=_SpawnService:SpawnByModelId("model://6c7ba8dd-5135-4f26-bc36-100c0542e1ab","NI10019Wave",Vector3(0,0.3,0),self.Entity)
						
						self.Entity:GetChildByName("NI10019Wave").SpriteParticleComponent.Enable=false
						
						particle.SpriteParticleComponent.SpriteRUID=""
						particle.SpriteParticleComponent.Color=Color.yellow
						_GeneralDirectorLogic:SetEffectAlpha(particle,userId)
					end
		
					self.Entity:GetChildByName("NI10019Wave").SpriteParticleComponent.Enable=true
					_TimerService:SetTimerOnce(function() self.Entity:GetChildByName("NI10019Wave").Enable=false end , 1)
				end
			end
		end
		timerID = _TimerService:SetTimerRepeat(makeWave, 2, 2)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10020(string itemID)
		-- NI10020, NI10025 : 스킬 사용 시 4초동안 최대 마나의 100%만큼 보호막 획득
		----------------------------------------------------------------------------
		local shieldAmount = self.Entity.UnitStatus.MaxMP
		
		_StatusChangeLogic:SetShield(self.Entity, self.Entity, shieldAmount, 4, itemID)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10021()
		--NI10021 파란색 가운: 2초마다 최대 체력의 5% 회복
		--------------------------------------------------------
		local timerID = 0
		local recover = function()
			-- 예외 및 종료 처리
			if self.Entity.UnitAIWanderComponent.Enable == false then -- 이 유닛이 사망하면 종료
				_TimerService:ClearTimer(timerID)
				return
			end
			
			local unitInfo = self.Entity.UnitInfo
			local userId = unitInfo.OwnerId
			local user = _UserService:GetUserEntityByUserId(userId)
			
			local teamManager = user.TeamManager
			
			if user.GameManager.PhaseType ~= "Battle" then	-- 전투 단계가 아니면 종료
				_TimerService:ClearTimer(timerID)
				return
			end
			--------------------------------------------------------
			-- 최대 체력의 3%만큼 회복
			local recoverAmount = self.Entity.UnitStatus.MaxHP * 0.03
			_StatusChangeLogic:SetVariableStatus(self.Entity, self.Entity, "HP", recoverAmount, "item")
		end
		timerID = _TimerService:SetTimerRepeat(recover, 2, 2)
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10023(Entity attaker, number amount)
		-- 가한 피해량의 20%만큼 체력 비율이 가장 낮은 아군 치유
		--------------------------------------------------------
		local unit = attaker
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local mainTile = unitInfo.setTile
		local ownerUserID = unitInfo.OwnerId
		
		local user = _UserService:GetUserEntityByUserId(ownerUserID)
		local teamManager = user.TeamManager
		
		-- 치유 대상을 결정합니다.
		---@type table<Entity>
		local allies = nil
		
		if unitInfo.TeamType == "User" then
			allies = _BTLogic_New:getEntities(teamManager.OwnUnits,"Alive")
			
		elseif unitInfo.TeamType == "Enemy" then
			allies = _BTLogic_New:getEntities(teamManager.EnemyUnits,"Alive")
		
		end
		--------------------------------------------------------
		-- 치유를 적용합니다.
		
		local cureAmount = amount * 0.2
		local targets = _BTLogic_New:getTargets(mainTile, allies, "HPper_Low_1") --체력이 가장 낮은 아군
		
		if targets ~= nil then
			for i=1, #targets do
		--		log("백의의서 / 회복량: ",cureAmount,"치유 대상:",targets[i].UnitInfo.unitName,"아이템 착용자:",attaker.UnitInfo.unitName)
				_StatusChangeLogic:SetVariableStatus(attaker, targets[i], "HP", cureAmount, "item") --아군 회복
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10024()
		--NI10024 사파이어  귀고리: 2초마다 마법 폭발을 일으켜 주변 2칸 내 무작위 적 하나에게 75의 마법 피해를 입히고, 6초간 마법 방어 약화 적용
		--------------------------------------------------------
		local timerID = 0
		local explosion = function()
			-- 예외 및 종료 처리
			if self.Entity.UnitAIWanderComponent.Enable == false then	-- 이 유닛이 사망하면
				_TimerService:ClearTimer(timerID)
				return
			end
			
			local unitInfo = self.Entity.UnitInfo
			local userId = unitInfo.OwnerId
			
			local user = _UserService:GetUserEntityByUserId(userId)
			if not isvalid(user) then return end
			local teamManager = user.TeamManager
			
			if user.GameManager.PhaseType ~= "Battle" then		-- 전투 단계가 아니라면 종료
				_TimerService:ClearTimer(timerID)
				return
			end
			--------------------------------------------------------
			-- 2칸 내 무작위 적 하나에게 120의 마법 피해를 입히고, 6초간 마법 방어 약화 적용
			local enemies = nil
			if unitInfo.TeamType == "User" then
				enemies =  _BTLogic_New:getEntities(teamManager.EnemyUnits, "Alive")
			elseif unitInfo.TeamType == "Enemy" then
				enemies = _BTLogic_New:getEntities(teamManager.OwnUnits, "Alive")
			end
			
			local targets = _BTLogic_New:getTargets(self.Entity.UnitInfo.setTile, enemies, "Around_1_2")
			if targets ~= nil then
				local targetIdx = _UtilLogic:RandomIntegerRange(1, #targets)
				local target = targets[targetIdx]
				
				if isvalid(target) then
					_StatusChangeLogic:HitDamage(self.Entity, target, 0, 75, 0, "item")
					_StatusChangeLogic:SetStatus(self.Entity, target, "SE0009", 6)
					
					--연출용 이펙트
					_CustomizedBattleEffectService:PlayEffectAttached(
					"fe94ad1182714953b695e42a8ee57d27",
					target,
					Vector3(0,0.3,0),
					0,
					Vector3.one*1,
					false,
					nil,
					unitInfo.OwnerId)	
				end
			end
		end
		timerID = _TimerService:SetTimerRepeat(explosion, 2, 2)
		--------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void UseItemAbility_NI10027()
		-- 전투 시작 후 5초마다 마력 +15% (중첩 가능)
		--------------------------------------------------------------------
		local gameManager = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId).GameManager
		local timerID = 0
		local castingRound = string.format("%d-%d", gameManager.Stage, gameManager.Round)
		local getBuff = function()	
			local phaseType = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId).GameManager.PhaseType
			local currentRound = string.format("%d-%d", gameManager.Stage, gameManager.Round)
			if phaseType ~= "Battle" or self.Entity.UnitStatus:IsDead() or castingRound ~= currentRound then
				_TimerService:ClearTimer(timerID)
			else
				_StatusChangeLogic:GetBuff(self.Entity, "Multi_MagicalAttack", 15, -1)
			end
		end
		
		timerID = _TimerService:SetTimerRepeat(getBuff, 5, 5)
	end

