	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		-- 유닛 클릭 이벤트 처리 (드래그 시작)
		if _InputService:IsPointerOverUI() then
			log("마우스가 UI 위에 있음")
			return
		end
		---------------------------------------------------------
		-- Parameters
		local TouchId = event.TouchId
		--log("touchID = ", TouchId)
		--local TouchPoint = event.TouchPoint
		local user = _UserService.LocalPlayer
		---------------------------------------------------------
		-- self:TouchCheck(user)
		
		-- 좌클릭
		if TouchId == 1 then
			-- 준비 단계가 아니면 실행하지 못하게 합니다.
			if user.GameManager.PhaseType ~= "Ready" then
				return
			end
			
			-- 튜토리얼 모드 예외 처리
			if user.GameManager.ModeType == "Tutorial" then
				if user.TutorialManager_New.AllowDragAllChar == false then
				--현재 모든 캐릭터를 옮길 수 있는지?
					if self.charID == user.TutorialManager_New.CurrentDraggableCharID then
						--유일하게 옮길 수 있는 캐릭터인지?
					else
						_UIToast:ShowMessageByLocalizingKey("Toast_TargetCharError")
						--못 옮기면 리턴
						return
					end
				else
					
				end
			end
			
			if (self.TeamType == "User") and (self.Entity.UnitAIWanderComponent.Enable == false) then
				-----------------------------------
				-- 예외 처리
				if self.charID == "C00002" then
					-- 도도는 잡을 수 없음
					return
				end
				-----------------------------------
				_UnitSetLogic_New:DragUnit(self.Entity, self.charID)
				
				local resellCost = self.cost * 3 ^ (self.level - 1)
				if self.level > 1 and self.cost > 1 then
					resellCost -= 1
				end
				_UserService.LocalPlayer.CharacterShopManager_New:UI_ShowSellUI(true, resellCost)
				--_CharacterShopManager:SellInfoToClient(self.Entity, userId)
			
				--타일 표시
				_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",true)
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchReleaseEvent(TouchReleaseEvent event)
		-- 유닛 터치 릴리즈 이벤트 처리 (드래그 종료)
		--[[--------------- Native Event Sender Info ----------------
		-- Sender: TouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		local user = _UserService.LocalPlayer
		local userId = user.OwnerId
		---------------------------------------------------------
		if (userId == self.unitOwnerID) then
			log("Unit TouchRelease Check")
			if not self.Entity.UnitAIWanderComponent.Enable then
				_UnitSetLogic_New.SelectTile = self.setTile
			end
			_ItemSetLogic:SetSelectUnit(self.unitOwnerID, self.Entity)
		end]]
	end

end