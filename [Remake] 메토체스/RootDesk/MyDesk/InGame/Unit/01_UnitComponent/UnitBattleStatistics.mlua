	@ExecSpace("ServerOnly")
	method void SetPropertyWithKey(string propertyName, string key, string value)
		-- 특정 키로 전투 통계 프로퍼티 값을 설정
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		
		if not isvalid(user) then
			return
		end
		
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		
		self:SetPropertyInClientWithKey(propertyName, key, value, user.OwnerId)
		
		if propertyName == "SetCharID" then
			self.SetCharID[key] = value
		elseif propertyName == "SetCharLevel" then
			value = tonumber(value)
			self.SetCharLevel[key] = value
		elseif propertyName == "SetItemList" then
			self.SetItemList[key] = value
		elseif propertyName == "PhysicalDamageDealt" then
			value = tonumber(value)
			if isvalid(self.PhysicalDamageDealt[key]) then
				self.PhysicalDamageDealt[key] += value
			else
				self.PhysicalDamageDealt[key] = value
			end
		elseif propertyName == "MagicalDamageDealt" then
			value = tonumber(value)
			if isvalid(self.MagicalDamageDealt[key]) then
				self.MagicalDamageDealt[key] += value
			else
				self.MagicalDamageDealt[key] = value
			end
		elseif propertyName == "TrueDamageDealt" then
			value = tonumber(value)
			if isvalid(self.TrueDamageDealt[key]) then
				self.TrueDamageDealt[key] += value
			else
				self.TrueDamageDealt[key] = value
			end
		elseif propertyName == "PhysicalDamageTaken" then
			value = tonumber(value)
			if isvalid(self.PhysicalDamageTaken[key]) then
				self.PhysicalDamageTaken[key] += value
			else
				self.PhysicalDamageTaken[key] = value
			end
		elseif propertyName == "MagicalDamageTaken" then
			value = tonumber(value)
			if isvalid(self.MagicalDamageTaken[key]) then
				self.MagicalDamageTaken[key] += value
			else
				self.MagicalDamageTaken[key] = value
			end
		elseif propertyName == "TrueDamageTaken" then
			value = tonumber(value)
			if isvalid(self.TrueDamageTaken[key]) then
				self.TrueDamageTaken[key] += value
			else
				self.TrueDamageTaken[key] = value
			end
		elseif propertyName == "PhysicalDamageAbsorbed" then
			value = tonumber(value)
			if isvalid(self.PhysicalDamageAbsorbed[key]) then
				self.PhysicalDamageAbsorbed[key] += value
			else
				self.PhysicalDamageAbsorbed[key] = value
			end
		elseif propertyName == "MagicalDamageAbsorbed" then
			value = tonumber(value)
			if isvalid(self.MagicalDamageAbsorbed[key]) then
				self.MagicalDamageAbsorbed[key] += value
			else
				self.MagicalDamageAbsorbed[key] = value
			end
		elseif propertyName == "TrueDamageAbsorbed" then
			value = tonumber(value)
			if isvalid(self.TrueDamageAbsorbed[key]) then
				self.TrueDamageAbsorbed[key] += value
			else
				self.TrueDamageAbsorbed[key] = value
			end
		elseif propertyName == "HPAmountGainedByHealing" then
			value = tonumber(value)
			if isvalid(self.HPAmountGainedByHealing[key]) then
				self.HPAmountGainedByHealing[key] += value
			else
				self.HPAmountGainedByHealing[key] = value
			end
		elseif propertyName == "HPAmountGainedByBloodAbsorption" then
			value = tonumber(value)
			if isvalid(self.HPAmountGainedByBloodAbsorption[key]) then
				self.HPAmountGainedByBloodAbsorption[key] += value
			else
				self.HPAmountGainedByBloodAbsorption[key] = value
			end
		elseif propertyName == "ShieldAmountGained" then
			value = tonumber(value)
			if isvalid(self.ShieldAmountGained[key]) then
				self.ShieldAmountGained[key] += value
			else
				self.ShieldAmountGained[key] = value
			end
		elseif propertyName == "HPAmountProvidedToHealing" then
			value = tonumber(value)
			if isvalid(self.HPAmountProvidedToHealing[key]) then
				self.HPAmountProvidedToHealing[key] += value
			else
				self.HPAmountProvidedToHealing[key] = value
			end
		elseif propertyName == "ShieldAmountProvided" then
			value = tonumber(value)
			if isvalid(self.ShieldAmountProvided[key]) then
				self.ShieldAmountProvided[key] += value
			else
				self.ShieldAmountProvided[key] = value
			end
		elseif propertyName == "SkillCountUsed" then
			value = tonumber(value)
			if isvalid(self.SkillCountUsed[key]) then
				self.SkillCountUsed[key] += value
			else
				self.SkillCountUsed[key] = value
			end
		elseif propertyName == "MaximumHP" then
			value = tonumber(value)
			if isvalid(self.MaximumHP[key]) then
				self.MaximumHP[key] = math.max(value, self.MaximumHP[key])
			else
				self.MaximumHP[key] = value
			end
		elseif propertyName == "MaximumPhysicalAttack" then
			value = tonumber(value)
			if isvalid(self.MaximumPhysicalAttack[key]) then
				self.MaximumPhysicalAttack[key] = math.max(value, self.MaximumPhysicalAttack[key])
			else
				self.MaximumPhysicalAttack[key] = value
			end
		elseif propertyName == "MaximumMagicalAttack" then
			value = tonumber(value)
			if isvalid(self.MaximumMagicalAttack[key]) then
				self.MaximumMagicalAttack[key] = math.max(value, self.MaximumMagicalAttack[key])
			else
				self.MaximumMagicalAttack[key] = value
			end
		elseif propertyName == "MaximumAttackSpeed" then
			value = tonumber(value)
			if isvalid(self.MaximumAttackSpeed[key]) then
				self.MaximumAttackSpeed[key] = math.max(value, self.MaximumAttackSpeed[key])
			else
				self.MaximumAttackSpeed[key] = value
			end
		elseif propertyName == "MaximumDamagePerSecond" then
			value = tonumber(value)
			if isvalid(self.PhysicalDamageDealt[key]) and isvalid(self.MagicalDamageDealt[key]) and isvalid(self.TrueDamageDealt[key]) then
				local totalDamageDealt = self.PhysicalDamageDealt[key] + self.MagicalDamageDealt[key] + self.TrueDamageDealt[key]
				local nowBattleTime = 0
				if gameManager.IsPlayedOvertime then
					nowBattleTime = 45 - gameManager.BattleTime
				else
					nowBattleTime = 30 - gameManager.BattleTime
				end
				value = totalDamageDealt / nowBattleTime
				
				
				if isvalid(self.MaximumDamagePerSecond[key]) then
					self.MaximumDamagePerSecond[key] = math.max(value, self.MaximumDamagePerSecond[key])
				else
					self.MaximumDamagePerSecond[key] = value
				end
			end
		elseif propertyName == "MaximumDefence" then
			value = tonumber(value)
			if isvalid(self.MaximumDefence[key]) then
				self.MaximumDefence[key] = math.max(value, self.MaximumDefence[key])
			else
				self.MaximumDefence[key] = value
			end
		elseif propertyName == "MaximumMagicalResistance" then
			value = tonumber(value)
			if isvalid(self.MaximumMagicalResistance[key]) then
				self.MaximumMagicalResistance[key] = math.max(value, self.MaximumMagicalResistance[key])
			else
				self.MaximumMagicalResistance[key] = value
			end
		elseif propertyName == "MaximumSkillusedPerMinute" then
			value = tonumber(value)
			if isvalid(self.SkillCountUsed[key]) then
				local nowBattleTime = 0
				if gameManager.IsPlayedOvertime then
					nowBattleTime = 45 - gameManager.BattleTime
				else
					nowBattleTime = 30 - gameManager.BattleTime
				end
				
				value = self.SkillCountUsed[key] * 60 / nowBattleTime
				
				if isvalid(self.SkillusedPerMinute[key]) then
					self.SkillusedPerMinute[key] = math.max(value, self.SkillusedPerMinute[key])
				else
					self.SkillusedPerMinute[key] = value
				end
			end
		elseif propertyName == "MaximumAttackRange" then
			value = tonumber(value)
			if isvalid(self.MaximumAttackRange[key]) then
				self.MaximumAttackRange[key] = math.max(value, self.MaximumAttackRange[key])
			else
				self.MaximumAttackRange[key] = value
			end
		elseif propertyName == "MaximumMoveSpeed" then
			value = tonumber(value)
			if isvalid(self.MaximumMoveSpeed[key]) then
				self.MaximumMoveSpeed[key] = math.max(value, self.MaximumMoveSpeed[key])
			else
				self.MaximumMoveSpeed[key] = value
			end
		elseif propertyName == "MaximumCriticalPercent" then
			value = tonumber(value)
			if isvalid(self.MaximumCriticalPercent[key]) then
				self.MaximumCriticalPercent[key] = math.max(value, self.MaximumCriticalPercent[key])
			else
				self.MaximumCriticalPercent[key] = value
			end
		elseif propertyName == "MaximumCriticalDamagePercent" then
			value = tonumber(value)
			if isvalid(self.MaximumCriticalDamagePercent[key]) then
				self.MaximumCriticalDamagePercent[key] = math.max(value, self.MaximumCriticalDamagePercent[key])
			else
				self.MaximumCriticalDamagePercent[key] = value
			end
		elseif propertyName == "MaximumBloodAbsorptionPercent" then
			value = tonumber(value)
			if isvalid(self.MaximumBloodAbsorptionPercent[key]) then
				self.MaximumBloodAbsorptionPercent[key] = math.max(value, self.MaximumBloodAbsorptionPercent[key])
			else
				self.MaximumBloodAbsorptionPercent[key] = value
			end
		elseif propertyName == "DeadTime" then
			value = tonumber(value)
			self.DeadTime[key] = value
		end
		
	end

