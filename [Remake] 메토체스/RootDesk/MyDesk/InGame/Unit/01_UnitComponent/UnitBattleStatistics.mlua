@Component
script UnitBattleStatistics extends Component

	property SyncTable<string, string> SetCharID

	property SyncTable<string, number> SetCharLevel

	property SyncTable<string, string> SetItemList

	@Description("해당 라운드(Key)동안 가한 물리 피해량")
	property SyncTable<string, number> PhysicalDamageDealt

	@Description("해당 라운드(Key)동안 가한 마법 피해량")
	property SyncTable<string, number> MagicalDamageDealt

	@Description([[해당 라운드(Key)동안 가한 고정 
피해량]])
	property SyncTable<string, number> TrueDamageDealt

	@Description("해당 라운드(Key)동안 받은 물리 피해량")
	property SyncTable<string, number> PhysicalDamageTaken

	@Description("해당 라운드(Key)동안 받은 마법 피해량")
	property SyncTable<string, number> MagicalDamageTaken

	@Description("해당 라운드(Key)동안 받은 고정 피해량")
	property SyncTable<string, number> TrueDamageTaken

	@Description("해당 라운드(Key)동안 흡수한 물리 피해량 (방어력, 피해 감소 등)")
	property SyncTable<string, number> PhysicalDamageAbsorbed

	@Description("해당 라운드(Key)동안 흡수한 마법 피해량 (방어력, 피해 감소 등)")
	property SyncTable<string, number> MagicalDamageAbsorbed

	@Description("해당 라운드(Key)동안 흡수한 고정 피해량 (방어력, 피해 감소 등)")
	property SyncTable<string, number> TrueDamageAbsorbed

	@Description("해당 라운드(Key)동안 치유로 회복한 힐량")
	property SyncTable<string, number> HPAmountGainedByHealing

	@Description("해당 라운드(Key)동안 흡혈로 회복한 힐량")
	property SyncTable<string, number> HPAmountGainedByBloodAbsorption

	@Description("해당 라운드(Key)동안 획득한 보호막의 양")
	property SyncTable<string, number> ShieldAmountGained

	@Description("해당 라운드(Key)동안 치유를 사용해 회복시킨 체력의 양")
	property SyncTable<string, number> HPAmountProvidedToHealing

	@Description("해당 라운드(Key)동안 보호막을 제공한 양")
	property SyncTable<string, number> ShieldAmountProvided

	@Description("해당 라운드(Key)동안 사용한 스킬 횟수")
	property SyncTable<string, number> SkillCountUsed

	@Description("해당 라운드(Key)동안 가장 높았던 체력 수치")
	property SyncTable<string, number> MaximumHP

	@Description("해당 라운드(Key)동안 가장 높았던 공격력 수치")
	property SyncTable<string, number> MaximumPhysicalAttack

	@Description("해당 라운드(Key)동안 가장 높았던 마력 수치")
	property SyncTable<string, number> MaximumMagicalAttack

	@Description("해당 라운드(Key)동안 가장 높았던 공격 속도")
	property SyncTable<string, number> MaximumAttackSpeed

	@Description("해당 라운드(Key)동안 가장 높았던 DPS")
	property SyncTable<string, number> MaximumDamagePerSecond

	@Description("해당 라운드(Key)동안 가장 높았던 방어력")
	property SyncTable<string, number> MaximumDefence

	@Description("해당 라운드(Key)동안 가장 높았던 마법 저항력")
	property SyncTable<string, number> MaximumMagicalResistance

	@Description("해당 라운드(Key)동안 가장 높았던 분당 스킬 사용 횟수")
	property SyncTable<string, number> SkillusedPerMinute

	@Description("해당 라운드(Key)동안 가장 높았던 사거리")
	property SyncTable<string, number> MaximumAttackRange

	@Description("해당 라운드(Key)동안 가장 높았던 이동 속도")
	property SyncTable<string, number> MaximumMoveSpeed

	property SyncTable<string, number> MaximumAttackDamage

	property SyncTable<string, number> MaximumBloodAbsorptionPercent

	property SyncTable<string, number> MaximumCriticalPercent

	property SyncTable<string, number> MaximumCriticalDamagePercent

	property SyncTable<string, number> DeadTime

	@ExecSpace("ServerOnly")
	method void RoundPropertyInitialize(string charID)
		-- 라운드마다, 각 프로퍼티 값 초기화
		-------------------------------------------------
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		
		-- 8-3 반복 플레이 처리
		if roundKey == "8-3" then
			roundKey = string.format("%s-%d", roundKey, gameManager.Round8_3Num)
		end
		
		-- log(string.format("round %s = %s_Entity Set %s", roundKey, unit.Id, charID))
		-------------------------------------------------
		-- id 세팅
		self.SetCharID[roundKey] = charID
		self.SetCharLevel[roundKey] = unitInfo.level
		
		local itemListStringValue = ""
		for _, itemID in pairs(unitStatus.EquippedItemIDList) do
			itemListStringValue = itemListStringValue .. string.format("%s.", itemID)
		end
		
		if itemListStringValue == "" then
			itemListStringValue = "NIL"
		else
			itemListStringValue = string.sub(itemListStringValue, 1, -2)
		end
		
		self.SetItemList[roundKey] = itemListStringValue
		-------------------------------------------------
		-- 누적 값 0으로 초기화
		-------------------------------------------------
		self.PhysicalDamageDealt[roundKey] = 0
		self.MagicalDamageDealt[roundKey] = 0
		self.TrueDamageDealt[roundKey] = 0
		self.PhysicalDamageTaken[roundKey] = 0
		self.MagicalDamageTaken[roundKey] = 0
		self.TrueDamageTaken[roundKey] = 0
		self.PhysicalDamageAbsorbed[roundKey] = 0
		self.MagicalDamageAbsorbed[roundKey] = 0
		self.TrueDamageAbsorbed[roundKey] = 0
		self.HPAmountGainedByHealing[roundKey] = 0
		self.HPAmountGainedByBloodAbsorption[roundKey] = 0
		self.ShieldAmountGained[roundKey] = 0
		self.HPAmountProvidedToHealing[roundKey] = 0
		self.ShieldAmountProvided[roundKey] = 0
		self.SkillCountUsed[roundKey] = 0
		-------------------------------------------------
		-- 도달 값(최대치) 초기 값 입력
		-------------------------------------------------
		self.MaximumHP[roundKey] = unitStatus.MaxHP
		self.MaximumPhysicalAttack[roundKey] = unitStatus.PhysicalAttack
		self.MaximumMagicalAttack[roundKey] = unitStatus.MagicalAttack
		self.MaximumAttackSpeed[roundKey] = unitStatus.AttackSpeed 
		self.MaximumDamagePerSecond[roundKey] = 0
		self.MaximumDefence[roundKey] = unitStatus.Defence
		self.MaximumMagicalResistance[roundKey] = unitStatus.MagicalResistance
		self.SkillusedPerMinute[roundKey] = 0
		self.MaximumAttackRange[roundKey] = unitStatus.AttackRange
		self.MaximumMoveSpeed[roundKey] = unitStatus.MoveSpeed
		self.MaximumBloodAbsorptionPercent[roundKey] = unitStatus.BloodAbsorptionPercent
		-------------------------------------------------
		
		self:RoundPropertyInitializeToClient(charID, user, user.OwnerId)
	end

	@ExecSpace("ServerOnly")
	method void SetProperty(string propertyName, number amount, boolean sync)
		-- 전투 통계 프로퍼티 값을 설정하고 누적
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		
		
		if not isvalid(user) then
			return
		end
		
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		
		-- 8-3 반복 플레이 처리
		local setKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		if setKey == "8-3" then
			setKey = string.format("%s-%d", setKey, gameManager.Round8_3Num)
		end
		
		if gameManager.Stage <= 0 or gameManager.Round <= 0 then
			return
		end
		
		if propertyName == "PhysicalDamageDealt" then
			if isvalid(self.PhysicalDamageDealt[setKey]) then
				self.PhysicalDamageDealt[setKey] += amount
			else
				self.PhysicalDamageDealt[setKey] = amount
			end
		elseif propertyName == "MagicalDamageDealt" then
			if isvalid(self.MagicalDamageDealt[setKey]) then
				self.MagicalDamageDealt[setKey] += amount
			else
				self.MagicalDamageDealt[setKey] = amount
			end
		elseif propertyName == "TrueDamageDealt" then
			if isvalid(self.TrueDamageDealt[setKey]) then
				self.TrueDamageDealt[setKey] += amount
			else
				self.TrueDamageDealt[setKey] = amount
			end
		elseif propertyName == "PhysicalDamageTaken" then
			if isvalid(self.PhysicalDamageTaken[setKey]) then
				self.PhysicalDamageTaken[setKey] += amount
			else
				self.PhysicalDamageTaken[setKey] = amount
			end
			
		elseif propertyName == "MagicalDamageTaken" then
			if isvalid(self.MagicalDamageTaken[setKey]) then
				self.MagicalDamageTaken[setKey] += amount
			else
				self.MagicalDamageTaken[setKey] = amount
			end
		elseif propertyName == "TrueDamageTaken" then
			if isvalid(self.TrueDamageTaken[setKey]) then
				self.TrueDamageTaken[setKey] += amount
			else
				self.TrueDamageTaken[setKey] = amount
			end
		elseif propertyName == "PhysicalDamageAbsorbed" then
			if isvalid(self.PhysicalDamageAbsorbed[setKey]) then
				self.PhysicalDamageAbsorbed[setKey] += amount
			else
				self.PhysicalDamageAbsorbed[setKey] = amount
			end
		elseif propertyName == "MagicalDamageAbsorbed" then
			if isvalid(self.MagicalDamageAbsorbed[setKey]) then
				self.MagicalDamageAbsorbed[setKey] += amount
			else
				self.MagicalDamageAbsorbed[setKey] = amount
			end
		elseif propertyName == "TrueDamageAbsorbed" then
			if isvalid(self.TrueDamageAbsorbed[setKey]) then
				self.TrueDamageAbsorbed[setKey] += amount
			else
				self.TrueDamageAbsorbed[setKey] = amount
			end
		elseif propertyName == "HPAmountGainedByHealing" then
			if isvalid(self.HPAmountGainedByHealing[setKey]) then
				self.HPAmountGainedByHealing[setKey] += amount
			else
				self.HPAmountGainedByHealing[setKey] = amount
			end
		elseif propertyName == "HPAmountGainedByBloodAbsorption" then
			if isvalid(self.HPAmountGainedByBloodAbsorption[setKey]) then
				self.HPAmountGainedByBloodAbsorption[setKey] += amount
			else
				self.HPAmountGainedByBloodAbsorption[setKey] = amount
			end
		elseif propertyName == "ShieldAmountGained" then
			if isvalid(self.ShieldAmountGained[setKey]) then
				self.ShieldAmountGained[setKey] += amount
			else
				self.ShieldAmountGained[setKey] = amount
			end
		elseif propertyName == "HPAmountProvidedToHealing" then
			if isvalid(self.HPAmountProvidedToHealing[setKey]) then
				self.HPAmountProvidedToHealing[setKey] += amount
			else
				self.HPAmountProvidedToHealing[setKey] = amount
			end
		elseif propertyName == "ShieldAmountProvided" then
			if isvalid(self.ShieldAmountProvided[setKey]) then
				self.ShieldAmountProvided[setKey] += amount
			else
				self.ShieldAmountProvided[setKey] = amount
			end
		elseif propertyName == "SkillCountUsed" then
			if isvalid(self.SkillCountUsed[setKey]) then
				self.SkillCountUsed[setKey] += amount
			else
				self.SkillCountUsed[setKey] = amount
			end
		elseif propertyName == "MaximumHP" then
			if isvalid(self.MaximumHP[setKey]) then
				self.MaximumHP[setKey] = math.max(amount, self.MaximumHP[setKey])
			else
				self.MaximumHP[setKey] = amount
			end
		elseif propertyName == "MaximumPhysicalAttack" then
			if isvalid(self.MaximumPhysicalAttack[setKey]) then
				self.MaximumPhysicalAttack[setKey] = math.max(amount, self.MaximumPhysicalAttack[setKey])
			else
				self.MaximumPhysicalAttack[setKey] = amount
			end
		elseif propertyName == "MaximumMagicalAttack" then
			if isvalid(self.MaximumMagicalAttack[setKey]) then
				self.MaximumMagicalAttack[setKey] = math.max(amount, self.MaximumMagicalAttack[setKey])
			else
				self.MaximumMagicalAttack[setKey] = amount
			end
		elseif propertyName == "MaximumAttackSpeed" then
			if isvalid(self.MaximumAttackSpeed[setKey]) then
				self.MaximumAttackSpeed[setKey] = math.max(amount, self.MaximumAttackSpeed[setKey])
			else
				self.MaximumAttackSpeed[setKey] = amount
			end
		elseif propertyName == "MaximumDamagePerSecond" then
			if isvalid(self.PhysicalDamageDealt[setKey]) and isvalid(self.MagicalDamageDealt[setKey]) and isvalid(self.TrueDamageDealt[setKey]) then
				local totalDamageDealt = self.PhysicalDamageDealt[setKey] + self.MagicalDamageDealt[setKey] + self.TrueDamageDealt[setKey]
				local nowBattleTime = 0
				if gameManager.IsPlayedOvertime then
					nowBattleTime = 45 - gameManager.BattleTime
				else
					nowBattleTime = 30 - gameManager.BattleTime
				end
				
				if nowBattleTime <= 0 then
					nowBattleTime = 0.1
				end
				
				amount = totalDamageDealt / nowBattleTime
				
				
				if isvalid(self.MaximumDamagePerSecond[setKey]) then
					self.MaximumDamagePerSecond[setKey] = math.max(amount, self.MaximumDamagePerSecond[setKey])
				else
					self.MaximumDamagePerSecond[setKey] = amount
				end
			end
		elseif propertyName == "MaximumDefence" then
			if isvalid(self.MaximumDefence[setKey]) then
				self.MaximumDefence[setKey] = math.max(amount, self.MaximumDefence[setKey])
			else
				self.MaximumDefence[setKey] = amount
			end
		elseif propertyName == "MaximumMagicalResistance" then
			if isvalid(self.MaximumMagicalResistance[setKey]) then
				self.MaximumMagicalResistance[setKey] = math.max(amount, self.MaximumMagicalResistance[setKey])
			else
				self.MaximumMagicalResistance[setKey] = amount
			end
		elseif propertyName == "SkillusedPerMinute" then
			if isvalid(self.SkillCountUsed[setKey]) then
				local nowBattleTime = 0
				if gameManager.IsPlayedOvertime then
					nowBattleTime = 45 - gameManager.BattleTime
				else
					nowBattleTime = 30 - gameManager.BattleTime
				end
				
				if nowBattleTime <= 0 then
					nowBattleTime = 0.1
				end
				
				amount = self.SkillCountUsed[setKey] * 60 / nowBattleTime
				
				if isvalid(self.SkillusedPerMinute[setKey]) then
					self.SkillusedPerMinute[setKey] = math.max(amount, self.SkillusedPerMinute[setKey])
				else
					self.SkillusedPerMinute[setKey] = amount
				end
			end
		elseif propertyName == "MaximumAttackRange" then
			if isvalid(self.MaximumAttackRange[setKey]) then
				self.MaximumAttackRange[setKey] = math.max(amount, self.MaximumAttackRange[setKey])
			else
				self.MaximumAttackRange[setKey] = amount
			end
		elseif propertyName == "MaximumMoveSpeed" then
			if isvalid(self.MaximumMoveSpeed[setKey]) then
				self.MaximumMoveSpeed[setKey] = math.max(amount, self.MaximumMoveSpeed[setKey])
			else
				self.MaximumMoveSpeed[setKey] = amount
			end
		elseif propertyName == "MaximumCriticalPercent" then
			if isvalid(self.MaximumCriticalPercent[setKey]) then
				self.MaximumCriticalPercent[setKey] = math.max(amount, self.MaximumCriticalPercent[setKey])
			else
				self.MaximumCriticalPercent[setKey] = amount
			end
		elseif propertyName == "MaximumCriticalDamagePercent" then
			if isvalid(self.MaximumCriticalDamagePercent[setKey]) then
				self.MaximumCriticalDamagePercent[setKey] = math.max(amount, self.MaximumCriticalDamagePercent[setKey])
			else
				self.MaximumCriticalDamagePercent[setKey] = amount
			end
		elseif propertyName == "MaximumBloodAbsorptionPercent" then
			if isvalid(self.MaximumBloodAbsorptionPercent[setKey]) then
				self.MaximumBloodAbsorptionPercent[setKey] = math.max(amount, self.MaximumBloodAbsorptionPercent[setKey])
			else
				self.MaximumBloodAbsorptionPercent[setKey] = amount
			end
		elseif propertyName == "DeadTime" then
			self.DeadTime[setKey] = amount
		end
		
		if sync then
			self:SetPropertyToClient(propertyName, amount, unitInfo.OwnerId)
		end
	end

	@ExecSpace("Client")
	method void SetPropertyToClient(string propertyName, number amount)
		-- 클라이언트에서 전투 통계 프로퍼티 값을 설정
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		
		-- 8-3 반복 플레이 처리
		local setKey = roundKey
		if setKey == "8-3" then
			setKey = "8-3-1"
			for i = 1, 5 do
				local checkKey = string.format("%s-%d", roundKey, i)
				if isvalid(self.SetCharID[checkKey]) then
					setKey = checkKey
				else
					break
				end
			end	
		end
		
		-- log(setKey, propertyName, amount)
		
		if propertyName == "PhysicalDamageDealt" then
			if isvalid(self.PhysicalDamageDealt[setKey]) then
				self.PhysicalDamageDealt[setKey] += amount
			else
				self.PhysicalDamageDealt[setKey] = amount
			end
		elseif propertyName == "MagicalDamageDealt" then
			if isvalid(self.MagicalDamageDealt[setKey]) then
				self.MagicalDamageDealt[setKey] += amount
			else
				self.MagicalDamageDealt[setKey] = amount
			end
		elseif propertyName == "TrueDamageDealt" then
			if isvalid(self.TrueDamageDealt[setKey]) then
				self.TrueDamageDealt[setKey] += amount
			else
				self.TrueDamageDealt[setKey] = amount
			end
		elseif propertyName == "PhysicalDamageTaken" then
			if isvalid(self.PhysicalDamageTaken[setKey]) then
				self.PhysicalDamageTaken[setKey] += amount
			else
				self.PhysicalDamageTaken[setKey] = amount
			end
		elseif propertyName == "MagicalDamageTaken" then
			if isvalid(self.MagicalDamageTaken[setKey]) then
				self.MagicalDamageTaken[setKey] += amount
			else
				self.MagicalDamageTaken[setKey] = amount
			end
		elseif propertyName == "TrueDamageTaken" then
			if isvalid(self.TrueDamageTaken[setKey]) then
				self.TrueDamageTaken[setKey] += amount
			else
				self.TrueDamageTaken[setKey] = amount
			end
		elseif propertyName == "PhysicalDamageAbsorbed" then
			if isvalid(self.PhysicalDamageAbsorbed[setKey]) then
				self.PhysicalDamageAbsorbed[setKey] += amount
			else
				self.PhysicalDamageAbsorbed[setKey] = amount
			end
		elseif propertyName == "MagicalDamageAbsorbed" then
			if isvalid(self.MagicalDamageAbsorbed[setKey]) then
				self.MagicalDamageAbsorbed[setKey] += amount
			else
				self.MagicalDamageAbsorbed[setKey] = amount
			end
		elseif propertyName == "TrueDamageAbsorbed" then
			if isvalid(self.TrueDamageAbsorbed[setKey]) then
				self.TrueDamageAbsorbed[setKey] += amount
			else
				self.TrueDamageAbsorbed[setKey] = amount
			end
		elseif propertyName == "HPAmountGainedByHealing" then
			if isvalid(self.HPAmountGainedByHealing[setKey]) then
				self.HPAmountGainedByHealing[setKey] += amount
			else
				self.HPAmountGainedByHealing[setKey] = amount
			end
		elseif propertyName == "HPAmountGainedByBloodAbsorption" then
			if isvalid(self.HPAmountGainedByBloodAbsorption[setKey]) then
				self.HPAmountGainedByBloodAbsorption[setKey] += amount
			else
				self.HPAmountGainedByBloodAbsorption[setKey] = amount
			end
		elseif propertyName == "ShieldAmountGained" then
			if isvalid(self.ShieldAmountGained[setKey]) then
				self.ShieldAmountGained[setKey] += amount
			else
				self.ShieldAmountGained[setKey] = amount
			end
		elseif propertyName == "HPAmountProvidedToHealing" then
			if isvalid(self.HPAmountProvidedToHealing[setKey]) then
				self.HPAmountProvidedToHealing[setKey] += amount
			else
				self.HPAmountProvidedToHealing[setKey] = amount
			end
		elseif propertyName == "ShieldAmountProvided" then
			if isvalid(self.ShieldAmountProvided[setKey]) then
				self.ShieldAmountProvided[setKey] += amount
			else
				self.ShieldAmountProvided[setKey] = amount
			end
		elseif propertyName == "SkillCountUsed" then
			if isvalid(self.SkillCountUsed[setKey]) then
				self.SkillCountUsed[setKey] += amount
			else
				self.SkillCountUsed[setKey] = amount
			end
		elseif propertyName == "MaximumHP" then
			if isvalid(self.MaximumHP[setKey]) then
				self.MaximumHP[setKey] = math.max(amount, self.MaximumHP[setKey])
			else
				self.MaximumHP[setKey] = amount
			end
		elseif propertyName == "MaximumPhysicalAttack" then
			if isvalid(self.MaximumPhysicalAttack[setKey]) then
				self.MaximumPhysicalAttack[setKey] = math.max(amount, self.MaximumPhysicalAttack[setKey])
			else
				self.MaximumPhysicalAttack[setKey] = amount
			end
		elseif propertyName == "MaximumMagicalAttack" then
			if isvalid(self.MaximumMagicalAttack[setKey]) then
				self.MaximumMagicalAttack[setKey] = math.max(amount, self.MaximumMagicalAttack[setKey])
			else
				self.MaximumMagicalAttack[setKey] = amount
			end
		elseif propertyName == "MaximumAttackSpeed" then
			if isvalid(self.MaximumAttackSpeed[setKey]) then
				self.MaximumAttackSpeed[setKey] = math.max(amount, self.MaximumAttackSpeed[setKey])
			else
				self.MaximumAttackSpeed[setKey] = amount
			end
		elseif propertyName == "MaximumDamagePerSecond" then
			if isvalid(self.MaximumDamagePerSecond[setKey]) then
				self.MaximumDamagePerSecond[setKey] = math.max(amount, self.MaximumDamagePerSecond[setKey])
			else
				self.MaximumDamagePerSecond[setKey] = amount
			end
		elseif propertyName == "MaximumDefence" then
			if isvalid(self.MaximumDefence[setKey]) then
				self.MaximumDefence[setKey] = math.max(amount, self.MaximumDefence[setKey])
			else
				self.MaximumDefence[setKey] = amount
			end
		elseif propertyName == "MaximumMagicalResistance" then
			if isvalid(self.MaximumMagicalResistance[setKey]) then
				self.MaximumMagicalResistance[setKey] = math.max(amount, self.MaximumMagicalResistance[setKey])
			else
