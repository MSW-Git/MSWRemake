@Component
script UnitStatus extends Component

	property number MaxHP = 0

	property number HP = 100

	property number MaxMP = 0

	property number MP = 0

	property number PhysicalAttack = 0

	property number MagicalAttack = 0

	property number Defence = 0

	property number MagicalResistance = 0

	property number AttackSpeed = 0

	property number AttackRange = 0

	property number SkillRange = 0

	property number Shield = 0

	property number CriticalPercent = 0

	@Description("크리티컬 적용 시 데미지 비율입니다. (기본값 140, % 단위로 적용)")
	property number CriticalDamagePercent = 140

	@Description("흡혈률 (단위 정수)")
	property number BloodAbsorptionPercent = 0

	property number MoveSpeed = 1

	@Description("공격 시 추가 마나 획득량")
	property number MPBonusWhenAttack = 0

	@Description("피격 시 추가 마나 획득량")
	property number MPBonusWhenBeAttacked = 0

	@Description("가하는 피해량 비율 (기본값 100)")
	property number DealingDamageRate = 100

	property number HPRecoverRate = 100

	@Description("상태이상 지속 시간 비율입니다. 기본값은 1입니다. ")
	property number StatusEffectRemainTimeRate = 100

	property SyncTable<string, number> StackProperty

	property SyncTable<string, boolean> StatusEffect

	property SyncTable<string, number> StatusTime

	@Description("(전투에서 사용) 현재 공격 대상입니다.")
	property Entity Target = nil

	@Description("보유한 아이템 목록입니다. value(string) = ItemID")
	property SyncTable<string> EquippedItemIDList

	property string state = ""

	@Description("입는 피해량 감소 관련 스탯을 모아놓은 테이블입니다. key(string)는 감소 타입을, value(number)는 감소량을 나타냅니다. 타입은 SetUnitStatus(~)함수의 takingDamageDecreaseCoefType을 참고하세요.")
	property SyncTable<string, number> DamageDecrease

	property SyncTable<string, number> DefaultStatus

	@Description("기본값에 더해지는 스탯값 (정수 단위). ")
	property SyncTable<string, number> AddedStatus

	@Description("곱해지는 스탯값. %단위로 작성합니다.")
	property SyncTable<string, number> MultiplyStatus

	property table BuffTable = {}

	property table Shields = {}

	property Vector2 SetPos = Vector2(0,0)

	property number ActionTimer = 0

	property string ActionType = ""

	property integer SE0017_Timer = 0

	method void OnBeginPlay()
		self._T.syncTypes = {
		    ["MaxHP"] 						= "number",
		    ["HP"] 							= "number",
		    ["Shield"] 						= "number",
		    ["MaxMP"] 						= "number",
		    ["MP"] 							= "number",
		    ["PhysicalAttack"] 				= "number",
		    ["MagicalAttack"]				= "number",
		    ["Defence"] 					= "number",
		    ["MagicalResistance"]			= "number",
		    ["AttackSpeed"]					= "number",
		    ["AttackRange"] 				= "number",
		    ["CriticalPercent"] 			= "number",
		    ["CriticalDamagePercent"] 		= "number",
			["BloodAbsorptionPercent"]		= "number",
		    ["MoveSpeed"] 					= "number",
		    ["MPBonusWhenAttack"]			= "number",
		    ["MPBonusWhenBeAttacked"]		= "number",
		    ["DealingDamageRate"]			= "number",
		    ["HPRecoverRate"]				= "number",
		    ["StatusEffectRemainTimeRate"]	= "number",
		    ["StackProperty"]				= "table",
		    ["StatusEffect"]				= "table",
		    ["StatusTime"]					= "table", 
		    ["Target"] 						= "Entity",
		    ["EquippedItemIDList"] 			= "table",
		    ["state"] 						= "string",
		    ["DamageDecrease"]				= "table",
		    ["DefaultStatus"]				= "table",
		    ["AddedStatus"]					= "table",
		    ["MultiplyStatus"]				= "table",
		    ["BuffTable"]					= "table",
		    ["Shields"]						= "table",
		}
		
		self._T.needSync = {
		    ["MaxHP"] 						= true,
		    ["HP"] 							= true,
		    ["Shield"] 						= true,
		    ["MaxMP"] 						= true,
		    ["MP"] 							= true,
		    ["PhysicalAttack"] 				= true,
		    ["MagicalAttack"]				= true,
		    ["Defence"] 					= true,
		    ["MagicalResistance"]			= true,
		    ["AttackSpeed"]					= true,
		    ["AttackRange"] 				= true,
		    ["CriticalPercent"] 			= true,
		    ["CriticalDamagePercent"] 		= true,
			["BloodAbsorptionPercent"]		= true,
		    ["MoveSpeed"] 					= true,
		    ["MPBonusWhenAttack"]				= false,
		    ["MPBonusWhenBeAttacked"]			= false,
		    ["DealingDamageRate"]				= true,
		    ["HPRecoverRate"]					= false,
		    ["StatusEffectRemainTimeRate"]		= false,
		    ["StackProperty"]					= false,
		    ["StatusEffect"]					= false,
		    ["StatusTime"]						= false,
		    ["Target"] 						= true,
		    ["EquippedItemIDList"] 			= true,
		    ["state"] 						= true,
		    ["DamageDecrease"]					= true,
		    ["DefaultStatus"]					= false,
		    ["AddedStatus"]						= false,
		    ["MultiplyStatus"]					= false,
		    ["BuffTable"]						= false,
		    ["Shields"]							= false,
		}
		
		
		if self:IsServer() then
			local statusEffectDB = _DataService:GetTable("StatusEffect")
			for i = 1, statusEffectDB:GetRowCount() do
				local effectID = statusEffectDB:GetRow(i):GetItem("ID")
				self.StatusEffect[effectID] = false
				self.StatusTime[effectID] = 0
			end
			
			local statusType = {
				"MaxHP",						-- 최대 체력
				"MaxMP",						-- 최대 마나
				"MP",							-- 시작 마나
				"PhysicalAttack",				-- 공격력
				"MagicalAttack",				-- 마력
				"Defence",						-- 물리 방어력
				"MagicalResistance",			-- 마법 방어력
				"AttackSpeed",					-- 공격속도
				"AttackRange",					-- 공격 사거리
				"CriticalPercent",				-- 크리티컬 확률
				"CriticalDamagePercent",		-- 크리티컬 데미지
				"BloodAbsorptionPercent",		-- 흡혈률
				"MoveSpeed",					-- 이동속도
				"DealingDamageRate",			-- 가해량 비율
			--	"TakingDamageRate",				-- 피해량 비율
			--	"TakingDamageBonusAmount",		-- 피해량 증가
				"MPBonusWhenAttack",			-- 공격 시 마나 획득량
				"MPBonusWhenBeAttacked",		-- 피격 시 마나 획득량
				"HPRecoverRate", 				-- 체력 회복 효과 비율
				"StatusEffectRemainTimeRate",	-- 제어 효과 지속시간 비율
			}
			
			-- 초기화 : 매 함수 실행마다 모든 값을 다시 계산하므로, 기본값으로 리셋합니다. 
			for i=1, #statusType do
				self.DefaultStatus[statusType[i]] = 0
				self.AddedStatus[statusType[i]] = 0
				self.MultiplyStatus[statusType[i]] = 0
			end
			
			-- self:SetDefaultStatus()
			
			
		end
	end

	@ExecSpace("Server")
	method void SetDefaultStatus()
		local unitInfo = self.Entity.UnitInfo
		local setId = unitInfo.charID .. math.floor(unitInfo.level)
		
		local charStatusRow = _DataService:GetTable("CharacterStatus"):FindRow("SetID", setId)
		local charSharedStatusDB = _DataService:GetTable("CharacterSharedStatus")
		
		local statusType = {
			"MaxHP",
			"MaxMP",
			"MP",
			"PhysicalAttack",
			"MagicalAttack",
			"Defence",
			"MagicalResistance",
			"AttackSpeed",
			"AttackRange",
			"SkillRange"
		}
		
		-- 기본값을 계산합니다.
		for i=1, #statusType do
			local statusName = statusType[i] 
			local defaultValue = tonumber(charStatusRow:GetItem(statusName))
			self.DefaultStatus[statusType[i]] = defaultValue
		end
		
		-- 공용값을 계산합니다.
		local sharingStatus = {
			["CriticalPercent"] = 10,
			["CriticalDamagePercent"] = 140,
			["BloodAbsorptionPercent"] = 0,
			["MoveSpeed"] = 1,						-- 이동속도
			["DealingDamageRate"] = 100,			-- 가해 데미지 비율	(%)
			["MPBonusWhenAttack"] = 0,				-- 공격 시 추가 마나 획득량
			["MPBonusWhenBeAttacked"] = 0,			-- 피격 시 추가 마나 획득량
			["HPRecoverRate"] = 100, 				-- 체력 회복 효과 비율 (%)
			["StatusEffectRemainTimeRate"] = 100,	-- 제어 효과 지속시간 비율 (%)
		}
		
		for key, value in pairs(sharingStatus) do
			self.DefaultStatus[key] = value
		end
		
		-- 피격 데미지 관련 값을 결정합니다.
		local takingDamageCoefType = {
			"Per",
			"Magic_Per",
			"Physic_Per",
			"MaxHP_Per",
			"Int",
			"Magic",
			"Physic",
			"MaxHP",
		}
		for i=1, #takingDamageCoefType do
			self.DamageDecrease[takingDamageCoefType[i]] = 0
		end
		
		-- 버프 및 보호막을 제거합니다.
		table.clear(self.BuffTable) 
		table.clear(self.Shields)
		
		-- 시너지(개인)에 의한 변화
		for key, value in pairs(self.Entity.UnitSynergy.SynergyStack) do
			if key == "S10007" then
				self.DefaultStatus["PhysicalAttack"] *= (100-value)/100
				self.DefaultStatus["MagicalAttack"] *= (100-value)/100
				self.DefaultStatus["MaxHP"] *= (100-value)/100
			end
		end
					
		
		-- 최종 스탯 갱신
		self:SetUnitStatus(false)
	end

	@ExecSpace("Server")
	method void SetUnitStatus(boolean isBattleUnit)
		-- 유닛의 각종 스탯을 계산하는 함수입니다.
		-- 아이템 장착, 버프 획득 등 모든 스탯 변화 상황이 발생할 때 호출합니다.
		--------------------------------------------------------------------
		if not isBattleUnit then
			self:SetProperty("state", "Idle", "")
		end
		
		--------------------------------------------------------------------
		local unit = self.Entity
		local unitItem = unit.UnitItem
		local unitInfo = unit.UnitInfo
		local setId = unitInfo.charID .. math.floor(unitInfo.level)
		--------------------------------------------------------------------
		local statusType = {
			"MaxHP",						-- 최대 체력
			"MaxMP",						-- 최대 마나
			"MP",							-- 시작 마나
			"PhysicalAttack",				-- 공격력
			"MagicalAttack",				-- 마력
			"Defence",						-- 물리 방어력
			"MagicalResistance",			-- 마법 방어력
			"AttackSpeed",					-- 공격속도
			"AttackRange",					-- 공격 사거리
			"SkillRange",					-- 스킬 사거리
			"CriticalPercent",				-- 크리티컬 확률
			"CriticalDamagePercent",		-- 크리티컬 데미지
			"BloodAbsorptionPercent",		-- 흡혈률
			"MoveSpeed",					-- 이동속도
			"DealingDamageRate",			-- 가해량 비율
		--	"TakingDamageRate",				-- 피해량 비율
		--	"TakingDamageBonusAmount",		-- 피해량 증가
			"MPBonusWhenAttack",			-- 공격 시 마나 획득량
			"MPBonusWhenBeAttacked",		-- 피격 시 마나 획득량
			"HPRecoverRate", 				-- 체력 회복 효과 비율
			"StatusEffectRemainTimeRate",	-- 제어 효과 지속시간 비율
		}
		
		-- (입는) 피해량 감소 계수
		local takingDamageDecreaseCoefType = {
			"Per",			-- %로 감소
			"Magic_Per",	-- 마력에 비례하여 %로 감소
			"Physic_Per",	-- 공격력에 비례하여 %로 감소
			"MaxHP_Per",	-- 최대 체력에 비례하여 %로 감소
			"Int",			-- 정수 감소
			"Magic",		-- 마력에 비례하여 정수 감소
			"Physic",		-- 공격력에 비례하여 정수 감소
			"MaxHP"			-- 최대 체력에 비례하여 정수 감소
		}
		--------------------------------------------------------------------
		-- 계산 순서는 다음과 같습니다.
			-- (1) 캐릭터 기본값	(DefaultStatus) : 캐릭터 별 등급에 따라 변경되거나, 공통값을 사용합니다.
			-- (2) 정수 증가분		(AddedStatus)	: 정수 증가분끼리 모두 더합니다.
			-- (3) 배율 증가분		(MultiplyStatus): 배율 증가분끼리 모두 더합니다.
			-- (4) 최종 스탯 = (캐릭터 기본값 + 정수 증가분) * (1 + 배율 증가분)
		--------------------------------------------------------------------
		local beforeHP = self.MaxHP
		local beforeStartMP = (self.DefaultStatus["MP"] + self.AddedStatus["MP"]) * (1+self.MultiplyStatus["MP"]/100)
		
		-- 초기화 : 매 함수 실행마다 모든 값을 다시 계산하므로, 기본값으로 리셋합니다. 
		for i=1, #statusType do
			self.AddedStatus[statusType[i]] = 0
			self.MultiplyStatus[statusType[i]] = 0
		end
		
		for i=1, #takingDamageDecreaseCoefType do
			self.DamageDecrease[takingDamageDecreaseCoefType[i]] = 0
		end
		--------------------------------------------------------------------
		-- 아이템에 의한 변화
		local item_addedStat = self.Entity.UnitItem.AddedStatus
		local item_multiStat = self.Entity.UnitItem.MultiplyStatus
		for k, v in pairs(item_addedStat) do
			self.AddedStatus[k] += v
		end
		for k, v in pairs(item_multiStat) do
			self.MultiplyStatus[k] += v
		end
		
		-- 특수 능력 예외 처리
		for i=1, #self.EquippedItemIDList do
			local itemID = _UtilLogic:Split(self.EquippedItemIDList[i], "_")[1]
			
		    --if itemID == "NI10001" or itemID == "NI10027" then
		    --    self.AddedStatus["DealingDamageRate"] += 8		-- 가해량 8% 증가
		    --elseif itemID == "NI10007" then
		    --    self.AddedStatus["MPBonusWhenAttack"] += 5			-- 공격 시 마나 5 추가 획득
		    --elseif itemID == "NI10013" then
		    --    self.AddedStatus["AttackRange"] += 1					-- 공격 사거리 +1
		    --elseif itemID == "NI10016" or itemID == "NI10022" then
		    --    self.DamageDecrease["Per"] += 8						-- 입는 피해량 8% 감소
		    --elseif itemID == "NI10020" then
		    --    self.AddedStatus["MPBonusWhenBeAttacked"] += 1		-- 피격 시 마나 1 추가 획득
		    --elseif itemID == "NI10004" or itemID == "NI10023" then
		    --    self.AddedStatus["BloodAbsorptionPercent"] += 25	-- 흡혈 25% 증
		    --elseif itemID == "NI10031" then
		    --    self.AddedStatus["CriticalDamagePercent"] += 20		-- 크리티컬 데미지 +20%
		    --elseif itemID == "NI10034" then
		    --    self.AddedStatus["MaxMP"] -= 10		-- 최대 마나 10 감소
		    --end
			
			if itemID == "NI10003" or itemID == "NI10004" or itemID == "NI10018" or itemID == "NI10023" then
				self.AddedStatus["BloodAbsorptionPercent"] += 20	-- 흡혈 +20%
			elseif itemID == "NI10005" then
				self.AddedStatus["DealingDamageRate"] += 20			-- 최종 가해량 +20%
			elseif itemID == "NI10013" then
		        self.AddedStatus["AttackRange"] += 1				-- 공격 사거리 +1
			elseif itemID == "NI10014" then
				self.AddedStatus["MPBonusWhenAttack"] += 5			-- 공격 시 마나 5 추가 획득
			elseif itemID == "NI10016" or itemID == "NI10022" then
		        self.DamageDecrease["Per"] += 10					-- 입는 피해량 10% 감소
			elseif itemID == "NI10020" or itemID == "NI10025" then
		        self.AddedStatus["MPBonusWhenBeAttacked"] += 1		-- 피격 시 마나 1 추가 획득
			elseif itemID == "NI10031" then
		        self.AddedStatus["CriticalDamagePercent"] += 25		-- 크리티컬 데미지 +25%
			elseif itemID == "NI10036" then
				self.MultiplyStatus["MaxHP"] += 9					-- 최대 체력 +9%
			end
		end
		--------------------------------------------------------------------
		-- 시너지에 의한 변화
		
		-- 시너지/개인 변화
			for key, value in pairs(self.Entity.UnitSynergy.SynergyStack) do
				if key == "S10003_TakingDamageDecreaseRate" then
					self.DamageDecrease["Per"] += value
				elseif key == "S10004" then
					self.MultiplyStatus["MagicalAttack"] += value 
				elseif key == "S10006_PhysicsAttack" then
					self.MultiplyStatus["PhysicalAttack"] += value
				elseif key == "S10006_GetPhysicalAttack" then
					self.MultiplyStatus["PhysicalAttack"] += value
				elseif key == "S10006_Vamp" then
					self.AddedStatus["BloodAbsorptionPercent"] += value
				elseif key == "S10007" then
		            --self.MultiplyStatus["PhysicalAttack"] -= value
		            --self.MultiplyStatus["MagicalAttack"] -= value
		            --self.MultiplyStatus["MaxHP"] -= value
				elseif key == "S10008_MoveSpeed" then
					self.MultiplyStatus["MoveSpeed"] += value
				elseif key == "S10010_AttackSpeed" then
					self.MultiplyStatus["AttackSpeed"] += value
				elseif key == "S10010_AttackRange" then
					self.AddedStatus["AttackRange"] += value
				elseif key == "S10017_BuffAfterRevive" then
					self.AddedStatus["BloodAbsorptionPercent"] += value
					self.MultiplyStatus["MoveSpeed"] += value
					self.DamageDecrease["Per"] -= value
				elseif key == "S10019" then
					self.MultiplyStatus["MaxHP"] += value
					self.MultiplyStatus["MagicalAttack"] += value
				elseif key == "S10021" then
					self.AddedStatus["DealingDamageRate"] += value
				elseif key == "S10022_Time" then
					if value > 0 then
						local buffValue = self.Entity.UnitSynergy.SynergyStack["S10022_Stat"]
						self.AddedStatus["Defence"] += buffValue
						self.AddedStatus["MagicalResistance"] += buffValue
						self.MultiplyStatus["AttackSpeed"] += buffValue
					end
				elseif key == "S10023_MaxHP" then
					self.MultiplyStatus["MaxHP"] += value
				elseif key == "S10023_Attack" then
					self.MultiplyStatus["PhysicalAttack"] += value
					self.MultiplyStatus["MagicalAttack"] += value
				elseif key == "S10025" then
					self.MultiplyStatus["MaxHP"] += value
					self.MultiplyStatus["PhysicalAttack"] += value
					self.MultiplyStatus["MagicalAttack"] += value
				elseif key == "S10027" then
					self.MultiplyStatus["MaxHP"] += value
				elseif key == "S10031_HP" then
					self.AddedStatus["MaxHP"] += value
				elseif key == "S10032_HP" then
					self.AddedStatus["MaxHP"] += value
				elseif key == "S10032_DEF" then
					self.AddedStatus["Defence"] += value
					self.AddedStatus["MagicalResistance"] += value
				elseif key == "S10032_ATK" then
					self.MultiplyStatus["PhysicalAttack"] += value
					self.MultiplyStatus["MagicalAttack"] += value
				elseif key == "S10033_MaxMP" then
					self.MultiplyStatus["MaxMP"] += value
				elseif key == "S10034_Critical" then
					self.AddedStatus["CriticalPercent"] += value
				elseif key == "S10034_CriticalDamage" then
					self.AddedStatus["CriticalDamagePercent"] += value
				elseif key == "S10035_AttackSpeed" then
					self.MultiplyStatus["AttackSpeed"] += value
				elseif key == "S10035_Attack" then
					self.MultiplyStatus["PhysicalAttack"] += value
					self.MultiplyStatus["MagicalAttack"] += value
				end
			end
		
		-- 시너지/팀에 의한 변화
		local teamType = self.Entity.UnitInfo.TeamType
		local userId = self.Entity.UnitInfo.OwnerId
		
		---@type table<string, number>
		local teamSynergyStack = {}
		if _UtilLogic:IsNilorEmptyString(userId) == false then
			local user = _UserService:GetUserEntityByUserId(userId)
			
			if _UtilLogic:IsNilorEmptyString(teamType) == false then
				if teamType == "Enemy" then
					table.initialize(teamSynergyStack, user.SynergyManager_New.Enemy_SynergyStack)
				else
					table.initialize(teamSynergyStack, user.SynergyManager_New.SynergyStack)
				end
			end
		end
		
		if isvalid(teamSynergyStack) == true then
			for key, value in pairs(teamSynergyStack) do
				if key == "S10004_Default" then
					self.MultiplyStatus["MagicalAttack"] += value
				elseif key == "S10009" then
					self.AddedStatus["MaxHP"] += value
				elseif key == "S10014" then
					self.MultiplyStatus["AttackSpeed"] += value
				elseif key == "S10024_Armor" then
					self.AddedStatus["Defence"] += value
					self.AddedStatus["MagicalResistance"] += value
				elseif key == "S10024_AttackSpeed" then
					self.MultiplyStatus["AttackSpeed"] += value
				elseif key == "S10024_Power" then
					self.MultiplyStatus["PhysicalAttack"] += value
					self.MultiplyStatus["MagicalAttack"] += value
				elseif key == "S10024_HPnMP" then
					self.AddedStatus["MaxHP"] += (5*value)
					self.AddedStatus["MP"] += value
				end
			end
		end 
		--------------------------------------------------------------------
		-- 룬에 의한 변화
		
		--------------------------------------------------------------------
		-- 스택(패시브)에 의한 변화
		for type, stack in pairs(self.StackProperty) do
			local types = _UtilLogic:Split(type, "_")
			
			if types[1] == "Add" then
				self.AddedStatus[types[2]] += stack
			elseif types[1] == "Multi" then
				self.MultiplyStatus[types[2]] += stack
			end
			
		end
		--------------------------------------------------------------------
		-- 버프/디버프에 의한 변화
		for i=1, #self.BuffTable do
			---@type table<string, any>
			local buff = self.BuffTable[i]
			local statType = buff["StatusType"]
			local duration = buff["EndTime"]
			local amount = buff["Amount"]
			
			if string.sub(statType, 1, 14) == "DamageDecrease" then
				local decreaseType = string.sub(statType, 16, -1)
				self.DamageDecrease[decreaseType] += amount
			elseif string.sub(statType, 1, 3) == "Add" then
				local addType = string.sub(statType, 5, -1)
				self.AddedStatus[addType] += amount
				
			elseif string.sub(statType, 1, 5) == "Multi" then
				local multiType = string.sub(statType, 7, -1)
				self.MultiplyStatus[multiType] += amount
			end
		end
		--------------------------------------------------------------------
		-- 상태이상에 의한 변화
		if self.StatusEffect["SE0008"] == true then			-- 물리 방어 약화
			self.MultiplyStatus["Defence"] -= 30
		end 
		
		if self.StatusEffect["SE0009"] == true then			-- 마법 방어 약화
			self.MultiplyStatus["MagicalResistance"] -= 30
		end 
		
		if self.StatusEffect["SE0010"] == true then			-- 회복력 감소
			self.MultiplyStatus["HPRecoverRate"] -= 33
		end 
		
		if self.StatusEffect["SE0013"] == true then			-- 마나 과부하
			self.MultiplyStatus["MaxMP"] += 35
		end
		
		if self.StatusEffect["SE0014"] == true then			-- 둔화
			self.MultiplyStatus["AttackSpeed"] -= 30
			self.MultiplyStatus["MoveSpeed"] -= 30
		end
		
		if self.StatusEffect["SE0015"] == true then			-- 낙인
			self.DamageDecrease["Per"] -= 10
		end
		---------------------------------------------------------------------------------------
		-- 최종 반영
		---@type table<string, number>
		local finalValues = {}
		for i=1, #statusType do
			local statusName = statusType[i]
			finalValues[statusType[i]] = 
				((self.DefaultStatus[statusName] + self.AddedStatus[statusName]) * (1+self.MultiplyStatus[statusName]/100)) 
			
			if finalValues[statusType[i]] <= 0 then
				finalValues[statusType[i]] = 0
			end
		end
		---------------------------------------------------------------------------------------
		-- 최대치 제한 적용
		if finalValues["Defence"] < 0 then					-- 물리 방어력 최소치는 0
			finalValues["Defence"] = 0
		end
		
		if finalValues["MagicalResistance"] < 0 then		-- 마법 방어력 최소치는 0
			finalValues["MagicalResistance"] = 0
		end
		
		if finalValues["AttackSpeed"] > 15 then		-- 공격속도 최대치는 15
			finalValues["AttackSpeed"] = 15
		end
		
		if finalValues["CriticalPercent"] > 100 then
			-- 크리티컬 확률 100% 초과 시, 초과 수치의 0.5배만큼 크리티컬 데미지 증가
			local exceededValue = finalValues["CriticalPercent"] - 100 
			finalValues["CriticalPercent"] = 100
			finalValues["CriticalDamagePercent"] += exceededValue * 0.5
		end
		
		if self.DamageDecrease["Per"] > 75 then
			-- 피해량 감소 최대 75%로 제한
			self.DamageDecrease["Per"] = 75
		end
		
		
		--log("마나"..self.Entity.UnitInfo.unitName.."/ "..finalValues["MP"])
		--log(self.Entity.UnitInfo.unitName,string.format("공격속도 = %.2f (기본 %.2f * 멀티량 %d)", finalValues["AttackSpeed"], self.DefaultStatus["AttackSpeed"], self.MultiplyStatus["AttackSpeed"]))
		--------------------------
		-- 수치 적용
		--------------------------
		self:SetProperty("PhysicalAttack", finalValues["PhysicalAttack"], "")
		self:SetProperty("MagicalAttack", finalValues["MagicalAttack"], "")
		self:SetProperty("MaxHP", finalValues["MaxHP"], "")
		self:SetProperty("MaxMP", finalValues["MaxMP"], "")
		self:SetProperty("Defence", finalValues["Defence"], "")
		self:SetProperty("MagicalResistance", finalValues["MagicalResistance"], "")
		self:SetProperty("AttackSpeed", finalValues["AttackSpeed"], "")
		self:SetProperty("AttackRange", finalValues["AttackRange"], "")
		self:SetProperty("SkillRange", finalValues["SkillRange"], "")
		self:SetProperty("CriticalPercent", finalValues["CriticalPercent"], "")
		self:SetProperty("CriticalDamagePercent", finalValues["CriticalDamagePercent"], "")
		self:SetProperty("BloodAbsorptionPercent", finalValues["BloodAbsorptionPercent"], "")
		self:SetProperty("MoveSpeed", finalValues["MoveSpeed"], "")
		self:SetProperty("DealingDamageRate", finalValues["DealingDamageRate"], "")
		self:SetProperty("DamageDecrease", nil, "")
		self:SetProperty("MPBonusWhenAttack", finalValues["MPBonusWhenAttack"], "")
		self:SetProperty("MPBonusWhenBeAttacked", finalValues["MPBonusWhenBeAttacked"], "")
		self:SetProperty("HPRecoverRate", finalValues["HPRecoverRate"], "")
		self:SetProperty("StatusEffectRemainTimeRate", finalValues["StatusEffectRemainTimeRate"], "")
		
		--------------------------
		-- 전투 유닛인 경우, 스탯 변경 전/후 체력 및 마나를 비교하여 증감량만 적용합니다.
		local afterMP = finalValues["MP"]
		
		if isBattleUnit == true then
			local HPGap = self.MaxHP - beforeHP
			if HPGap > 0 then	-- Max HP가 증가한 경우
				_StatusChangeLogic:SetVariableStatus(self.Entity, self.Entity, "HP", HPGap, "skill")
				-- self:SetProperty("HP", self.HP + HPGap, "")
				
				-- 팀 체력 적용 (+ 예외 처리)
				if self.Entity.UnitInfo.charID == "C00002" and self.Entity.UnitInfo.setTile.Name == "DoDoTile_1" then
					-- 도도는 전장 투입 전까지 팀 체력에 포함 X
				else
					local user = _UserService:GetUserEntityByUserId(userId)
					user.GameManager:RefreshUI_TeamHPInfo(self.Entity.UnitInfo.TeamType, true, HPGap, userId)
					--log(self.Entity.UnitInfo.charID..": hp max가 증가하여 팀 hp max 증가: ", self.Entity.UnitInfo.TeamType, HPGap)
				end
		
			end
			
			local MPGap = afterMP - beforeStartMP
			if MPGap > 0 then	-- Max MP가 증가한 경우
				_StatusChangeLogic:SetVariableStatus(self.Entity, self.Entity, "MP", MPGap, "skill")
				-- self:SetProperty("MP", self.MP + MPGap, "")
			end
			--------------------------
		-- 일반 유닛인 경우, 다시 계산한 값을 적용합니다.
		else 
			self:SetProperty("HP", self.MaxHP, "")
			self:SetProperty("MP", math.min(math.max(0, finalValues["MP"]), self.MaxMP), "")
		end
		---------------------------------------------------------------------------------------
		self:SetUnitStatusUI(self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Client")
	method void SetUnitStatusUI()
		_UnitInfoUILogic:SetBar(self.Entity)
		_UnitInfoUILogic:SetItemList(self.Entity)
	end

	@ExecSpace("ServerOnly")
	method void Dead()
		-- 유닛이 죽으면 호출되는 함수입니다.
		
		local unit = self.Entity
		local unitInfo = unit.UnitInfo
		local userId = unitInfo.OwnerId
		local user = _UserService:GetUserEntityByUserId(userId)
		local modeType = _UtilLogic:Split(user.GameManager.ModeType,"_")[1]
		local modeLevel = user.GameManager.ModeLevel
		----------------------------------------------------------------------------------------------------
		-- 부활 조건 체크
		--------------------------------------------------
		-- 빅토리아 아일랜드
		if unit.UnitSynergy:S10017_Revive() == true then
			if unitInfo.TeamType == "User" then 
				-- 업적 AC007009: 시너지 [빅토리아 아일랜드]효과로 유닛 {0}회 부활시키기
				if modeType == "Rank" or (modeType == "Single" and modeLevel >4) then 			
					_AchievementService:UpdateAchievement("AC007009",1,user)
				end
			end
			return
		else
			_SynergyBattleDirectorLogic:S10017SurviveEffect(unit,false,"Battle",userId) -- 부활이펙트가 있을 경우, 삭제
			_SynergyBattleDirectorLogic:S10016ColdAir(unit,false,0,"Battle",userId)--엘나스 냉기 초기화
		end
		--------------------------------------------------
		-- 루시드
		local skillCompo = unitInfo.SkillComponent
		if isvalid(skillCompo) then
			if isvalid(skillCompo.Revive) then
				if skillCompo.Revive then
					skillCompo:SetPassive()
					-- [업적] 루시드 도전과제: 부활하기
					_AchievementService:UpdateProgress_Char(unitInfo,1,user) 
					return
				end
			end
		end
		--------------------------------------------------
		--헥터 : 위협 줬던 유닛들의 이펙트 삭제
		if isvalid(unit.C10011_Hector_Skill) then
			for target,_ in pairs(unit.C10011_Hector_Skill.AttackedEnemy) do
				_GeneralDirectorLogic:RemoveHectorEffect(target,user.GameManager.PhaseType,unitInfo.OwnerId)
			end
		end
		--------------------------------------------------
		-- 분노의 옥석 : 3초간 무적
		local check = false
		for _, itemID in pairs(unit.UnitStatus.EquippedItemIDList) do
			if itemID == "SI10002" then
				check = true
				break
			end
		end
		
		if check and unit.UnitItem.ItemAbilityStacks["SI10002"] >= 1 then
			unit.UnitItem:UseItemAbility_SI10002()
			return
		end
		----------------------------------------------------------------------------------------------------
		if unit.UnitAIWanderComponent.Enable then
			local gameManager = user.GameManager
			local nowBattleTime = 0
			if gameManager.IsPlayedOvertime then
				nowBattleTime = 45 - gameManager.BattleTime
			else
				nowBattleTime = 30 - gameManager.BattleTime
			end
				
			unit.UnitBattleStatistics:SetProperty("DeadTime", nowBattleTime, true)
			unit.UnitAIWanderComponent:BattleEnd()
			unit.UnitAIWanderComponent.Enable = false
			
			unitInfo:SetPropertyToServer("setTile", nil, "All", true)
			
			if unitInfo.TeamType == "Enemy" then
				--log("Dead Enemy Count - 1")
				user.GameManager.EnemyCount -= 1
			elseif unitInfo.TeamType == "User" then
				--log("Dead User Count - 1")
				user.GameManager.MyUnitCount -= 1
			end
			--[[
			log("Dead Unit Name = ", self.Entity.UnitInfo.unitName)
			log("Dead Unit TeamType = ", unitInfo.TeamType)
			log(user.GameManager.MyUnitCount, "MyUnitCount")
			log(user.GameManager.EnemyCount, "EnemyCount")
			]]--
		
			self:SetProperty("state", "Dead", "")
			self.Entity.UnitAnimationComponent:PlayAnimation(1, "Dead", self.Entity, self.Entity.UnitInfo.OwnerId)
			
			-- 적/아군에 따라 다른 사운드 재생
			if self.Entity.UnitInfo.TeamType == "Enemy" then
				_PlaySoundLogic:PlaySound("M0143",self.Entity.UnitInfo.OwnerId)
			else
				_PlaySoundLogic:PlaySound("M0144",self.Entity.UnitInfo.OwnerId)
			end
		else
			--log("Dead 꼬인거 같은데요")
		end
	end

	@ExecSpace("Client")
	method void SetUniInfoPopup(string updatedDataName)
		-- 우클릭으로 보는 유닛 정보 팝업을 갱신하도록 하는 함수입니다.
		-- 우클릭으로 보고 있을 때에만 갱신을 요청합니다.
		
		-- updatedDataName : 업데이트된 프로퍼티. "Level", "HP", "MP", "Stat", "Item", "All" 이 있습니다.
		----------------------------------------------------------------
		-- 이 유닛이 배치용 유닛인 경우
		if _UI_UnitInfoPopup.ConnectedEntity == self.Entity then
			_UI_UnitInfoPopup:UI_Update(self, updatedDataName)
			
			
		end
	end

	@ExecSpace("Server")
	method void SetProperty(string name, any value, string tableFunctionType)
		-- 이 컴포넌트의 Property들은 특정 유저의 클라이언트에만 sync 되어야 하고, sync 상태를 유지해야 합니다.
		-- 따라서 이 컴포넌트의 Property들을 변경할 때에는 직접 변경하지 않고 이 함수를 거치도록 합니다.
		-- ** 프로퍼티 타입이 table인 경우 : tableFunctionType에 
			-- "clear"를 넣으면 해당 테이블을 clear, 
			-- "insert,pos"를 넣으면 해당 테이블 pos에 value를 삽입 (맨 뒤인 경우 pos = -1)
			-- "remove,pos"를 넣으면 해당 테이블 pos에 value를 삽입 (맨 뒤인 경우 pos = -1)
		-------------------------------------------------
		-- 2024. 04. 11. 데이터 기록용 코드 추가
		local unitBattleStatistics = self.Entity.UnitBattleStatistics
		-------------------------------------------------
		local ownerID = self.Entity.UnitInfo.OwnerId
		local beforeValue = nil
		-------------------------------------------------
		if 		name == "MaxHP"			then 
			beforeValue = self.MaxHP
			self.MaxHP = value 
		elseif 	name == "HP" 			then
			beforeValue = self.HP
			self.HP = value
			if value <= 0.0 then
				self:Dead()
			end
		elseif 	name == "Shield" 		then
			beforeValue = self.Shield 
			self.Shield = value
		elseif 	name == "MaxMP" 		then
			beforeValue = self.MaxMP 
			self.MaxMP = value
		elseif 	name == "MP" 			then 
			beforeValue = self.MP
			self.MP = value
		elseif 	name == "PhysicalAttack" 	then
			beforeValue = self.PhysicalAttack
			self.PhysicalAttack = value
			unitBattleStatistics:SetProperty("MaximumPhysicalAttack", self.PhysicalAttack, true)
		elseif 	name == "MagicalAttack" 	then
			beforeValue = self.MagicalAttack
			self.MagicalAttack = value
			unitBattleStatistics:SetProperty("MaximumMagicalAttack", self.MagicalAttack, true)
		elseif 	name == "Defence" 			then
			beforeValue = self.Defence
			self.Defence = value
			unitBattleStatistics:SetProperty("MaximumDefence", self.Defence, true)
		elseif 	name == "MagicalResistance" then
			beforeValue = self.MagicalResistance
			self.MagicalResistance = value
			unitBattleStatistics:SetProperty("MaximumMagicalResistance", self.MagicalResistance, true)
		elseif 	name == "AttackSpeed" 		then
			beforeValue = self.AttackSpeed
			self.AttackSpeed = value
			unitBattleStatistics:SetProperty("MaximumAttackSpeed", self.AttackSpeed, true)
		elseif 	name == "AttackRange" 		then
			beforeValue = self.AttackRange
			self.AttackRange = value
			unitBattleStatistics:SetProperty("MaximumAttackRange", self.AttackRange, true)
		elseif 	name == "SkillRange" 		then
			beforeValue = self.SkillRange
			self.SkillRange = value
		elseif 	name == "CriticalPercent" 			then
			beforeValue = self.CriticalPercent
			self.CriticalPercent = value
			unitBattleStatistics:SetProperty("MaximumCriticalPercent", self.CriticalPercent, true)
		elseif 	name == "CriticalDamagePercent" 	then
			beforeValue = self.CriticalDamagePercent
			self.CriticalDamagePercent = value
			unitBattleStatistics:SetProperty("MaximumCriticalDamagePercent", self.CriticalDamagePercent, true)
		elseif 	name == "BloodAbsorptionPercent" 	then
			beforeValue = self.BloodAbsorptionPercent
			self.BloodAbsorptionPercent = value
			unitBattleStatistics:SetProperty("MaximumBloodAbsorptionPercent", self.BloodAbsorptionPercent, true)
		elseif 	name == "MoveSpeed" 		then
			beforeValue = self.MoveSpeed
			self.MoveSpeed = value
		
			unitBattleStatistics:SetProperty("MaximumMoveSpeed", self.MoveSpeed, true)
		elseif 	name == "Target" 			then self.Target = value
		elseif 	name == "state" 			then self.state = value
		elseif  name == "EquippedItemIDList"		then
			local type = _UtilLogic:Split(tableFunctionType, ",")
			if type[1] == "clear" then
				table.clear(self.EquippedItemIDList)
			elseif type[1] == "insert" then
				if tonumber(type[2]) == -1 then
					table.insert(self.EquippedItemIDList, value)
					self.Entity.UnitItem:OnEquippedChangedDuringBattlePhase(#self.EquippedItemIDList)
					
				else 
					table.insert(self.EquippedItemIDList, tonumber(type[2]), value)
					self.Entity.UnitItem:OnEquippedChangedDuringBattlePhase(tonumber(type[2]))
					
				end
				
			elseif type[1] == "remove" then
				if tonumber(type[2]) == -1 then
					table.remove(self.EquippedItemIDList)
				else
					table.remove(self.EquippedItemIDList, tonumber(type[2]))
				end
			elseif type[1] == "replace" then
				local idx = tonumber(type[2])
				if idx == nil or idx < 1 or idx > 3 then
					return
				else
					self.EquippedItemIDList[idx] = value
				end
			end
			self.Entity.UnitItem:RefreshItemStatus()
		elseif name == "DealingDamageRate" 			then	self.DealingDamageRate = value
		elseif name == "DamageDecrease" 			then	value = _UtilLogic:TableToString(self.DamageDecrease)
		elseif name == "MPBonusWhenAttack" 			then	self.MPBonusWhenAttack = value
		elseif name == "MPBonusWhenBeAttacked" 		then	self.MPBonusWhenBeAttacked = value
		elseif name == "HPRecoverRate" 				then	self.HPRecoverRate = value
		elseif name == "StatusEffectRemainTimeRate"	then	self.StatusEffectRemainTimeRate = value
		else
			log_warning("이 프로퍼티는 별도의 함수를 통해 조절해주세요")
			return
		end
		-------------------------------------------------
		-- 클라이언트와 동기화합니다. 단, 다음의 경우 동기화하지 않고 종료합니다.
			-- 1) 동기화가 필요 없는 변수인 경우
			-- 2) 동기화가 필요한 변수이나, 값이 달라지지 않은 경우
		if self._T.needSync[name] == true then
			if isvalid(beforeValue) == true then
				if beforeValue ~= 0 and beforeValue == value then
					return
				end
			end
			
			if self._T.syncTypes[name] == "number" then
				self:SyncPropertyToClient(name, tostring(value), "", ownerID)
				
			elseif self._T.syncTypes[name] == "table" then
				self:SyncPropertyToClient(name, value, tableFunctionType, ownerID)
				
			elseif self._T.syncTypes[name] == "string" then
				self:SyncPropertyToClient(name, value, "", ownerID)
				
			elseif self._T.syncTypes[name] == "Entity" then
				self:SyncPropertyToClient(name, value.Id, "", ownerID)
			end
			
		end
	end

	@ExecSpace("Client")
	method void SyncPropertyToClient(string name, string value, string tableFunctionType)
		local unitInfo = self.Entity.UnitInfo
		-------------------------------------------------
		if self._T.syncTypes[name] == "number" then
			value = tonumber(value)
		elseif self._T.syncTypes[name] == "table" then
			--
			
		elseif self._T.syncTypes[name] == "string" then
			--
			
		elseif self._T.syncTypes[name] == "Entity" then
			value = _EntityService:GetEntity(value)
		
		end
		-------------------------------------------------
		if 		name == "MaxHP" 		then
			self.MaxHP = value
			_UnitInfoUILogic:SetBar(self.Entity)
			_UnitInfoUILogic:SetBarcode(self.Entity)
			self:SetUniInfoPopup("HP")
		elseif 	name == "HP" 			then
			self.HP = value
			self:SetUniInfoPopup("HP")
			if value > 0 then
				_UnitInfoUILogic:SetBar(self.Entity)		
			end
		elseif 	name == "Shield" 		then 
			self.Shield = value
			self:SetUniInfoPopup("HP")
			if value > 0 then
				_UnitInfoUILogic:SetBar(self.Entity)
			end
		elseif 	name == "MaxMP" 		then
			self.MaxMP = value
			self:SetUniInfoPopup("MP")
		elseif 	name == "MP" 			then
			self.MP = value
			self:SetUniInfoPopup("MP")
			_UnitInfoUILogic:SetBar(self.Entity)
		elseif 	name == "PhysicalAttack" then 
			self.PhysicalAttack = value 
			self:SetUniInfoPopup("Stat")
		elseif 	name == "MagicalAttack" then 
			self.MagicalAttack = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "Defence" then 
			self.Defence = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "MagicalResistance" then 
			self.MagicalResistance = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "AttackSpeed" then 
			self.AttackSpeed = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "AttackRange" then 
			self.AttackRange = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "SkillRange" then 
			self.SkillRange = value
		elseif 	name == "CriticalPercent" then 
			self.CriticalPercent = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "CriticalDamagePercent" then 
			self.CriticalDamagePercent = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "BloodAbsorptionPercent" 	then
			self.BloodAbsorptionPercent = value
			self:SetUniInfoPopup("Stat")
		elseif 	name == "MoveSpeed" 		then 
			self.MoveSpeed = value
			self:SetUniInfoPopup("Stat")
		elseif name == "DealingDamageRate" then
			self.DealingDamageRate = value
			self:SetUniInfoPopup("Stat")
		elseif name == "DamageDecrease" then
			local damageDecList = _UtilLogic:StringToTable(value)
			table.initialize(self.DamageDecrease, damageDecList)
			self:SetUniInfoPopup("Stat")
		elseif 	name == "Target" 			then self.Target = value
		elseif 	name == "state" 			then self.state = value
		elseif  name == "EquippedItemIDList"		then
			local type = _UtilLogic:Split(tableFunctionType, ",")
			if type[1] == "clear" then
				table.clear(self.EquippedItemIDList)
			elseif type[1] == "insert" then
				if tonumber(type[2]) == -1 then
					table.insert(self.EquippedItemIDList, value)
				else 
					
					table.insert(self.EquippedItemIDList, tonumber(type[2]), value)
				end
			elseif type[1] == "remove" then
				if tonumber(type[2]) == -1 then
					table.remove(self.EquippedItemIDList)
				else
					table.remove(self.EquippedItemIDList, tonumber(type[2]))
				end
			elseif type[1] == "replace" then
				local idx = tonumber(type[2])
				if idx == nil or idx < 1 or idx > 3 then
					return
				else
					self.EquippedItemIDList[idx] = value
				end
			end
			
			self:SetUniInfoPopup("Item")
			_UnitInfoUILogic:SetItemList(self.Entity)
		else
			log_warning("이 프로퍼티는 별도의 함수를 통해 조절해주세요")
			return
		end
		-------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void ApplyStatusEffect_SE0017(boolean enable)
		-- 화상 상태이상을 최초로 활성화 또는 비활성화할 때 호출하는 함수입니다.
		if enable == true then
			local timerID = 0
			local getDamage = function()
				-- 예외 처리
				local user = _UserService:GetUserEntityByUserId(self.Entity.UnitInfo.OwnerId)
				if isvalid(user) == false or user.GameManager.PhaseType ~= "Battle" then
					_TimerService:ClearTimer(timerID)
					return
				end
				--------------------------------------------------------------
				local damamge = self.MaxHP * 0.01
				_StatusChangeLogic:HitDamage(nil, self.Entity, 0, 0, damamge, "StatusEffect")
			end
			timerID = _TimerService:SetTimerRepeat(getDamage, 1, 1) 
			self.SE0017_Timer = timerID
			
		else
			if self.SE0017_Timer > 0 then
				_TimerService:ClearTimer(self.SE0017_Timer)
				self.SE0017_Timer = 0
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SetActionType(string type)
		if self.ActionType == "Move" and type ~= "Idle" and type ~= "Move" then
			self.Entity.UnitAIWanderComponent.running = false
		end
		
		self.ActionType = type
	end

	@ExecSpace("ServerOnly")
	method boolean IsDead()
		if self.Entity.UnitAIWanderComponent.Enable == false then
			return true
		else
			return false
		end
	end

	@ExecSpace("Server")
	method void SetUnitStatusByStat(boolean isBattleUnit, string stat)
		-- 유닛의 각종 스탯을 계산하는 함수입니다.
		-- 아이템 장착, 버프 획득 등 모든 스탯 변화 상황이 발생할 때 호출합니다.
		--------------------------------------------------------------------
		-- 계산 순서는 다음과 같습니다.
			-- (1) 캐릭터 기본값	(DefaultStatus) : 캐릭터 별 등급에 따라 변경되거나, 공통값을 사용합니다.
			-- (2) 정수 증가분		(AddedStatus)	: 정수 증가분끼리 모두 더합니다.
			-- (3) 배율 증가분		(MultiplyStatus): 배율 증가분끼리 모두 더합니다.
			-- (4) 최종 스탯 = (캐릭터 기본값 + 정수 증가분) * (1 + 배율 증가분)
		
		-- 테스트용
		local charID = self.Entity.UnitInfo.charID
		-- 테스트용
		
		
		if isBattleUnit == false and self.state ~= "Idle" then
			self:SetProperty("state", "Idle", "")
		end
		
		local beforeValue = 0
		if stat == "MP" then
			beforeValue = (self.DefaultStatus[stat] + self.AddedStatus[stat]) * (1+self.MultiplyStatus[stat]/100)
		end
		
		-- 기본값
		local initDefaultBonusValue = function()
			self.AddedStatus[stat] = 0
			self.MultiplyStatus[stat] = 0
		end
		
		-- 아이템에 의한 변화 (기본값)
		local calculateItemStatValue = function()
			local unitItem = self.Entity.UnitItem
			
			self.AddedStatus[stat] += unitItem.AddedStatus[stat]
			self.MultiplyStatus[stat] += unitItem.MultiplyStatus[stat]
		end
		
		
		-- 아이템 특수능력에 의한 변화
		local calculateItemSpecialStatus = function()
			for i=1, #self.EquippedItemIDList do
				local itemID = _UtilLogic:Split(self.EquippedItemIDList[i], "_")[1]
				
				if (stat == "BloodAbsorptionPercent") and (itemID == "NI10003" or itemID == "NI10004" or itemID == "NI10018" or itemID == "NI10023") then
					self.AddedStatus["BloodAbsorptionPercent"] += 20	-- 흡혈 +20%
				elseif stat == "DealingDamageRate" and itemID == "NI10005" then
					self.AddedStatus["DealingDamageRate"] += 20			-- 최종 가해량 +20%
				elseif stat == "AttackRange" and itemID == "NI10013" then
			        self.AddedStatus["AttackRange"] += 1				-- 공격 사거리 +1
				elseif stat == "AttackRange" and itemID == "NI10014" then
					self.AddedStatus["MPBonusWhenAttack"] += 5			-- 공격 시 마나 5 추가 획득
				elseif stat == "DamageDecrease" and (itemID == "NI10016" or itemID == "NI10022") then
			        self.DamageDecrease["Per"] += 10					-- 입는 피해량 10% 감소
				elseif stat == "MPBonusWhenBeAttacked" and (itemID == "NI10020" or itemID == "NI10025") then
			        self.AddedStatus["MPBonusWhenBeAttacked"] += 1		-- 피격 시 마나 1 추가 획득
				elseif stat == "CriticalDamagePercent" and itemID == "NI10031" then
			        self.AddedStatus["CriticalDamagePercent"] += 25		-- 크리티컬 데미지 +25%
				elseif stat == "MaxHP" and  itemID == "NI10036" then
					self.MultiplyStatus["MaxHP"] += 9					-- 최대 체력 +9%
				end
			end
		end
		
		local personalSynergy = self.Entity.UnitSynergy.SynergyStack
		local teamType = self.Entity.UnitInfo.TeamType
		local userId = self.Entity.UnitInfo.OwnerId
		local user = _UserService:GetUserEntityByUserId(userId)
		---@type table<string, number>
		local teamSynergyStack = nil
		if _UtilLogic:IsNilorEmptyString(teamType) == false then
			if teamType == "Enemy" then
				teamSynergyStack = user.SynergyManager_New.Enemy_SynergyStack 
			else
				teamSynergyStack = user.SynergyManager_New.SynergyStack
			end	
		end
		
		if stat == "DamageDecrease" then
			-- (입는) 피해량 감소 계수
			self.DamageDecrease["Per"] = 0			-- %로 감소
			self.DamageDecrease["Magic_Per"] = 0	-- 마력에 비례하여 %로 감소
			self.DamageDecrease["Physic_Per"] = 0		-- 공격력에 비례하여 %로 감소
			self.DamageDecrease["MaxHP_Per"] = 0		-- 최대 체력에 비례하여 %로 감소
			self.DamageDecrease["Int"] = 0			-- 정수 감소
			self.DamageDecrease["Magic"] = 0			-- 마력에 비례하여 정수 감소
			self.DamageDecrease["Physic"] = 0			-- 공격력에 비례하여 정수 감소
			self.DamageDecrease["MaxHP"] = 0			-- 최대 체력에 비례하여 정수 감소
			
			
			calculateItemSpecialStatus()
			
			if isvalid(personalSynergy["S10003_TakingDamageDecreaseRate"]) == true then
				self.DamageDecrease["Per"] += personalSynergy["S10003_TakingDamageDecreaseRate"]
			end
			if isvalid(personalSynergy["S10017_BuffAfterRevive"]) == true then
				self.DamageDecrease["Per"] -= personalSynergy["S10017_BuffAfterRevive"]
			end
			
			if self.StatusEffect["SE0015"] == true then			-- 낙인
				self.DamageDecrease["Per"] -= 10
			end
			
		else
			if stat == "MaxHP" then
				beforeValue = self.MaxHP
			elseif stat == "MaxMP" then
				beforeValue = (self.DefaultStatus["MP"] + self.AddedStatus["MP"]) * (1+self.MultiplyStatus["MP"]/100)
			end 
			
			initDefaultBonusValue()
			calculateItemStatValue()
			calculateItemSpecialStatus()
			
			-- stat : 증감할 스탯 타입
			-- isPositive : 증가인지, 감소인지
			-- isMulti : 증감할 스탯 연산 유형 (add, multi)
			-- synTypeKey : 체크할 시너지 관련 키
			local checkPersonalSynergy = function(stat, isPositive, isMulti, synTypeKey)
				if isvalid(personalSynergy[synTypeKey]) == true then
					if isMulti then
						if isPositive then
							self.MultiplyStatus[stat] += personalSynergy[synTypeKey]
						else
							self.MultiplyStatus[stat] -= personalSynergy[synTypeKey]
						end
					else
						if isPositive then
							self.AddedStatus[stat] += personalSynergy[synTypeKey]
						else
							self.AddedStatus[stat] -= personalSynergy[synTypeKey]
						end
					end
				end
			end
			
			local checkTeamSynergy = function(stat, isPositive, isMulti, coef, synTypeKey)
				if isvalid(teamSynergyStack[synTypeKey]) == true then
					if isMulti then
						if isPositive then
							self.MultiplyStatus[stat] += (coef * teamSynergyStack[synTypeKey])
						else
							self.MultiplyStatus[stat] -= (coef * teamSynergyStack[synTypeKey])
						end
					else
						if isPositive then
							self.AddedStatus[stat] += (coef * teamSynergyStack[synTypeKey])
						else
							self.AddedStatus[stat] -= (coef * teamSynergyStack[synTypeKey])
						end
					end
				end
			end
			
			if stat == "MaxHP" then
				--checkPersonalSynergy(stat, true, true, "S10019")
				checkPersonalSynergy(stat, true, true, "S10023_MaxHP")
				checkPersonalSynergy(stat, true, true, "S10025")
				checkPersonalSynergy(stat, true, true, "S10027")
				checkPersonalSynergy(stat, true, false, "S10031_HP")
				checkPersonalSynergy(stat, true, false, "S10032_HP")
				checkPersonalSynergy(stat, true, true, "S10033_MaxMP")
				
				checkTeamSynergy(stat, true, false, 1, "S10009")
				checkTeamSynergy(stat, true, false, 5, "S10024_HPnMP")
				
			elseif stat == "MaxMP" then
				if self.StatusEffect["SE0013"] == true then			-- 마나 과부하
					self.MultiplyStatus["MaxMP"] += 35
				end
			elseif stat == "MP" then
				checkTeamSynergy(stat, true, false, 1, "S10024_HPnMP")
				
			elseif stat == "PhysicalAttack" then
				checkPersonalSynergy(stat, true, true, "S10006_GetPhysicalAttack")
				checkPersonalSynergy(stat, true, true, "S10023_Attack")
				checkPersonalSynergy(stat, true, true, "S10025")
				checkPersonalSynergy(stat, true, true, "S10032_ATK")
				checkPersonalSynergy(stat, true, true, "S10035_Attack")
				
				checkTeamSynergy(stat, true, true, 1, "S10024_Power")
				
			elseif stat == "MagicalAttack" then
				checkPersonalSynergy(stat, true, true, "S10004")
				--checkPersonalSynergy(stat, true, true, "S10019")
				checkPersonalSynergy(stat, true, true, "S10023_Attack")
				checkPersonalSynergy(stat, true, true, "S10025")
				checkPersonalSynergy(stat, true, true, "S10032_ATK")
				checkPersonalSynergy(stat, true, true, "S10035_Attack")
				
				checkTeamSynergy(stat, true, true, 1, "S10004_Default")
				checkTeamSynergy(stat, true, true, 1, "S10024_Power")
				
			elseif stat == "Defence" then		
				if isvalid(personalSynergy["S10022_Time"]) == true and personalSynergy["S10022_Time"] > 0 then
					self.AddedStatus[stat] += personalSynergy["S10022_Stat"]
				end
				
				checkPersonalSynergy(stat, true, false, "S10032_DEF")
				checkTeamSynergy(stat, true, false, 1, "S10024_Armor")
				
				if self.StatusEffect["SE0008"] == true then			-- 물리 방어 약화
					self.MultiplyStatus["Defence"] -= 30
				end
				
			elseif stat == "MagicalResistance" then
				if isvalid(personalSynergy["S10022_Time"]) == true and personalSynergy["S10022_Time"] > 0 then
					self.AddedStatus[stat] += personalSynergy["S10022_Stat"]
				end
				
				checkPersonalSynergy(stat, true, false, "S10032_DEF")
				checkTeamSynergy(stat, true, false, 1, "S10024_Armor")
				
				if self.StatusEffect["SE0009"] == true then			-- 마법 방어 약화
					self.MultiplyStatus["MagicalResistance"] -= 30
				end 
				
			elseif stat == "AttackSpeed" then
				checkPersonalSynergy(stat, true, true, "S10010_AttackSpeed")
				checkPersonalSynergy(stat, true, true, "S10035_AttackSpeed")
				if isvalid(personalSynergy["S10022_Time"]) == true and personalSynergy["S10022_Time"] > 0 then
					self.MultiplyStatus[stat] += personalSynergy["S10022_Stat"]
				end
						
				checkTeamSynergy(stat, true, true, 1, "S10014")
				checkTeamSynergy(stat, true, true, 1, "S10024_AttackSpeed")
				
				if self.StatusEffect["SE0014"] == true then			-- 둔화
					self.MultiplyStatus["AttackSpeed"] -= 30
				end
				
			elseif stat == "AttackRange" then
				checkPersonalSynergy(stat, true, false, "S10010_AttackRange")
				
			elseif stat == "SkillRange" then
			elseif stat == "CriticalPercent" then
				checkPersonalSynergy(stat, true, false, "S10034_Critical")
			elseif stat == "CriticalDamagePercent" then
				checkPersonalSynergy(stat, true, false, "S10034_CriticalDamage")
			elseif stat == "BloodAbsorptionPercent" then
				checkPersonalSynergy(stat, true, false, "S10006_Vamp")
				checkPersonalSynergy(stat, true, false, "S10017_BuffAfterRevive")
				
			elseif stat == "MoveSpeed" then
				checkPersonalSynergy(stat, true, true, "S10008_MoveSpeed")
				checkPersonalSynergy(stat, true, true, "S10017_BuffAfterRevive")
				
				if self.StatusEffect["SE0014"] == true then			-- 둔화
					self.MultiplyStatus["MoveSpeed"] -= 30
				end
				
			elseif stat == "DealingDamageRate" then
				checkPersonalSynergy(stat, true, false, "S10021")
				
			elseif stat == "MPBonusWhenAttack" then
			elseif stat == "MPBonusWhenBeAttacked" then
			elseif stat == "HPRecoverRate" then
				if self.StatusEffect["SE0010"] == true then			-- 회복력 감소
					self.MultiplyStatus["HPRecoverRate"] -= 33
				end 
			elseif stat == "StatusEffectRemainTimeRate" then
			end
		end
		--------------------------------------------------------------------
		-- 스택(패시브)에 의한 변화
		for type, stack in pairs(self.StackProperty) do
			local types = _UtilLogic:Split(type, "_")
			
			if types[1] == "DamageDecrease" and stat == "DamageDecrease" then
				local damageDecreaseType = types[2]
				self.DamageDecrease[damageDecreaseType] += stack
			elseif isvalid(types[2]) == true and types[2] == stat then
				if types[1] == "Add" then
					self.AddedStatus[types[2]] += stack
				elseif types[1] == "Multi" then
					self.MultiplyStatus[types[2]] += stack
				end
			end
		end
		--------------------------------------------------------------------
		-- 버프/디버프에 의한 변화
		for i=1, #self.BuffTable do
			---@type table<string, any>
			local buff = self.BuffTable[i]
			local statTypes = _UtilLogic:Split(buff["StatusType"], "_")
			local duration = buff["EndTime"]
			local amount = buff["Amount"]
			
			if statTypes[1] == "DamageDecrease" and stat == "DamageDecrease" then
				local damageDecreaseType = statTypes[2]
				self.DamageDecrease[damageDecreaseType] += amount
			elseif isvalid(statTypes[2]) == true then
				if statTypes[2] == stat then
					if statTypes[1] == "Add" then
						self.AddedStatus[stat] += amount
					elseif statTypes[1] == "Multi" then
						self.MultiplyStatus[stat] += amount
					end
				end
			end
		end
		--------------------------------------------------------------------
		-- 최대치 제한 적용한 최종값 계산
		if stat == "DamageDecrease" then
			if self.DamageDecrease["Per"] > 75 then
				self.DamageDecrease["Per"] = 75
			end
			
			self:SetProperty(stat, nil, "")
		else
			local finalValue = (self.DefaultStatus[stat] + self.AddedStatus[stat]) * (1 + self.MultiplyStatus[stat]/100) 
			
			if finalValue < 0 then	-- 최소치 0 적용
				if stat == "DealingDamageRate" or stat == "HPRecoverRate" then	
				else
					finalValue = 0
				end
			end
			
			-- 공격속도 15.0 최대치 적용
			if stat == "AttackSpeed" and finalValue > 15 then
				finalValue = 15
			end
			
			-- 크리티컬 확률 100% 초과 시, 초과 수치의 0.5배만큼 크리티컬 데미지 증가
			if stat == "CriticalPercent" then
				self.Entity.UnitStatus.StackProperty["Add_CriticalDamagePercent_ByCriticalChance"] = 0
		
				if finalValue > 100 then
					local exceededValue = finalValue - 100
					_StatusChangeLogic:SetStack(self.Entity, "Add_CriticalDamagePercent_ByCriticalChance", 0.5 * exceededValue)
					finalValue = 100
				end
				
				-- 크리 확률 계산 시, 크뎀을 반드시 함께 계산
				self:SetUnitStatusByStat(isBattleUnit, "CriticalDamagePercent")
			end
			
			self:SetProperty(stat, finalValue, "")	-- 최종 수치 적용
			
			if stat == "MaxHP" then	-- 최대 체력 증가(+) && 전투 중인 경우, 변동값에 대해 기존 체력에 적용
				if isBattleUnit then
					local hpGap = self.MaxHP - beforeValue
					if hpGap > 0 then
						_StatusChangeLogic:SetVariableStatus(self.Entity, self.Entity, "HP", hpGap, "skill")
						
						-- 팀 체력 적용 (+ 예외 처리)
						if self.Entity.UnitInfo.charID == "C00002" and self.Entity.UnitInfo.setTile.Name == "DoDoTile_1" then
							-- 도도는 전장 투입 전까지 팀 체력에 포함 X
						else
							user.GameManager:RefreshUI_TeamHPInfo(self.Entity.UnitInfo.TeamType, true, hpGap, userId)
							--log(self.Entity.UnitInfo.charID..": hp max가 증가하여 팀 hp max 증가: ", self.Entity.UnitInfo.TeamType, hpGap)
						end
					end
				else
					self:SetProperty("HP", self.MaxHP, "")
				end
				
			elseif stat == "MP" then
				if isBattleUnit then
					local MPGap = finalValue - beforeValue
					if MPGap > 0 then	-- 시작 MP가 증가한 경우 && 전투 중인 경우, 변동값에 대해 보유 마나에 적용
						_StatusChangeLogic:SetVariableStatus(self.Entity, self.Entity, "MP", MPGap, "skill")
					end
				else
					self:SetProperty("MP", math.min(math.max(0, finalValue), self.MaxMP), "")
				end
			end
			
		end
		---------------------------------------------------------------------------------------
		self:SetUnitStatusUI(self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void CleanProperty()
		self.MaxHP = 0
		self.HP = 100
		self.MaxMP = 0
		self.MP = 0
		self.PhysicalAttack = 0
		self.MagicalAttack = 0
		self.Defence = 0
		self.MagicalResistance = 0
		self.AttackSpeed = 0
		self.AttackRange = 0
		self.SkillRange = 0
		self.CriticalPercent = 10
		self.CriticalDamagePercent = 140
		self.BloodAbsorptionPercent = 0
		self.MoveSpeed = 1
		self.DealingDamageRate = 100
		table.clear(self.DamageDecrease)
		self.MPBonusWhenAttack = 0
		self.MPBonusWhenBeAttacked = 0
		self.HPRecoverRate = 100
		self.StatusEffectRemainTimeRate = 100
	end

end