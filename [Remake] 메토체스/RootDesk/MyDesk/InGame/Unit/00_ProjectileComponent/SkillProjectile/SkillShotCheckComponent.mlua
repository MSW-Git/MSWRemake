@Component
script SkillShotCheckComponent extends Component

	property boolean Shots = false

	property number ShotTimer = 0

	property string ProjOwnerID = ""

	@ExecSpace("ServerOnly")
	method void SetOwnerID(string ownerID)
		-- 스킬 발사체의 소유자 ID를 서버와 클라이언트에 설정
		self.ProjOwnerID = ownerID
		local errorCode, returnValue = 
			pcall(function()
				self:SetOwnerIDInClient(ownerID, self.ProjOwnerID)
			end)
	end

	@ExecSpace("Client")
	method void SetOwnerIDInClient(string ownerID)
		-- 클라이언트에서 스킬 발사체의 소유자 ID를 설정
		self.ProjOwnerID = ownerID
	end

end