@Component
script C20018_PompomTree_Attack extends Component

	@Sync
	property number playRate = 0

	property string setEffectRUID = "5c682a5b8e5a4334b01fefcc02755d59"

	property string buffEffectRUID = "86163af626a44495aeee476d2b4e0c8b"

	@ExecSpace("Server")
	method void Buff(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		
		-- target 찾기
		local myTeamUnits = {}
		if unitInfo.TeamType == "User" then
			myTeamUnits = teamManager.OwnUnits
		elseif unitInfo.TeamType == "Enemy" then
			myTeamUnits = teamManager.EnemyUnits
		end
		
		local checkMyTeamUnits = _BTLogic_New:getEntities(myTeamUnits, "Alive")
		checkMyTeamUnits = _BTLogic_New:getTargets(unitInfo.setTile, checkMyTeamUnits, "Around_1_10")
		local target = _BTLogic_New:getTarget(unitInfo.setTile, checkMyTeamUnits, "Nearest")
		
		if not isvalid(target) then
			target = myUnit
		end
		
		self:SetBuffEffect(unitInfo.OwnerId)
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 0.7) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", target, unitInfo.OwnerId)
		
		-- Set Damage
		local function buff()
			if _BTLogic_New:CheckAttackAble(myUnit, target, "Attack") then
		   		self:SetBuff(target)
			end
		end
		_TimerService:SetTimerOnce(buff, 0.4 / self.playRate)
		
		unitStatus:SetProperty("state", "Attack", "")
		
		--임시 사운드 없음
	end

	@ExecSpace("Server")
	method void SetBuff(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			local animComponent = myUnit.UnitAnimationComponent
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			
			self:BuffEffect(targetUnit, unitInfo.OwnerId)
			
			-- 체력 회복
			local getHPAmount = unitStatus.MagicalAttack * _S01_SkillDescLogic.C20018_Passive_GetHP_Magic[unitInfo.level]
			
			_StatusChangeLogic:SetVariableStatus(myUnit, targetUnit, "HP", getHPAmount, "buff")
		end
	end

	@ExecSpace("Client")
	method void BuffEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- buffeffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.buffEffectRUID, targetUnit, Vector3.zero, 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void SetBuffEffect()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- buffeffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.setEffectRUID, myUnit, Vector3.zero, 0, Vector3.one, false, options)
	end

end