@Component
script C50008_Papulatus_Attack extends Component

	@Sync
	property number playRate = 0

	property string hitEffectRUID = "e862ecd74f63407d98442fbf4aac10f9"

	property string hitEffect2RUID = "feb553ecf06440f4b4899353c0dbf73e"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- ATTACK RUID
		unitStatus:SetProperty("state", "Attack", "")
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		if unitInfo.unitPhaseNumber == 1 then
			self.playRate = (unitStatus.AttackSpeed * 2.22) * _BTLogic_New.ASpeedValue
			animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
			
			local function damage()
				local enemies = {}
				if unitInfo.TeamType == "User" then
					enemies = teamManager.EnemyUnits
				elseif unitInfo.TeamType == "Enemy" then
					enemies = teamManager.OwnUnits
				end
				
				local attackEnemies = _BTLogic_New:getTargets(unitInfo.setTile, enemies, "Around_1_1")
				attackEnemies = _BTLogic_New:getEntities(attackEnemies, "AttackAble")
				
				
				for _, enemy in pairs(attackEnemies) do
					if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Attack") then
						self:SetDamage(enemy)
					end
				end
			end
			
			_TimerService:SetTimerOnce(damage, 0.85 / self.playRate)
			
			
		elseif unitInfo.unitPhaseNumber == 2 then
			self.playRate = (unitStatus.AttackSpeed * 1.89) * _BTLogic_New.ASpeedValue
			animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
			
			-- Set Damage
			local function damage()
				if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
			   		self:SetDamage(targetUnit)
				end
			end
			_TimerService:SetTimerOnce(damage, 0.95 / self.playRate)
		end
		
		--사운드
		_PlaySoundLogic:PlaySound("M0132",self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
		
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.unitPhaseNumber, unitInfo.OwnerId)
			
			local attackDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C50008_Passive_AttackToPhase1_Magic[unitInfo.level] +
								unitStatus.MaxHP * _S01_SkillDescLogic.C50008_Passive_AttackToPhase1_MaxHP[unitInfo.level]
			
			local damageInfo = _StatusChangeLogic:CheckDamage(attackDamage, myUnit, targetUnit, 0, "Magical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "defaultAttack")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit, number phaseNum)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		local ruid = ""
		if phaseNum == 1 then
			ruid = self.hitEffectRUID
		elseif phaseNum == 2 then
			ruid = self.hitEffect2RUID
		end
		
		
		-- hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(ruid, targetUnit, Vector3(0, 0.3, 0), 0, Vector3(1.5, 1.5, 1.5), false, options)
	end

end