@Component
script C10003_MutantSnail_Attack extends Component

	@Sync
	property number playRate = 0

	property string hitEffectRUID = "5a92e2d402784e8cac09fc19dbf30122"

	property boolean onSkill = false

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 2.07) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		
		-- Set Damage
		local function damage()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetDamage(targetUnit)
			end
		end
		_TimerService:SetTimerOnce(damage, 0.72 / self.playRate)
		
		
		unitStatus:SetProperty("state", "Attack", "")
		
		--사운드
		_PlaySoundLogic:PlaySound("M0042",self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local physicalDamage = unitStatus.PhysicalAttack
			
			if self.onSkill then
				physicalDamage += unitStatus.PhysicalAttack * _S01_SkillDescLogic.C10003_Active_Attack_Physic[unitInfo.level]
				self.onSkill = false
				self:PlayBuffEffect(self.Entity.UnitInfo.OwnerId)
			end
			
			
			local damageInfo = _StatusChangeLogic:CheckDamage(physicalDamage, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "defaultAttack")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlayBuffEffect()
		_GeneralDirectorLogic:BattleDebuffEffect(self.Entity,_RuneCardDirectEnum.PhysicalAttack)
	end

end