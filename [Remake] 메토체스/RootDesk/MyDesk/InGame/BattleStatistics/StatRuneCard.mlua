@Component
script StatRuneCard extends Component

	property string CurrentRuneCardID = ""

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스가 룬 카드 위에 올라갔을 때 룬 카드 정보 툴팁을 표시
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		
		local rundCardDataSet = _DataService:GetTable("RuneInfo")
		
		if _UtilLogic:IsNilorEmptyString(self.CurrentRuneCardID) == false then
			---@type RuneCardDictionaryData
			local runeData = _DictionaryDataManager.RuneDataList[self.CurrentRuneCardID]
			
			local gradeNum = 1
			local grade = runeData.Grade
			if grade == "Rare" then gradeNum = 2
			elseif grade == "Epic" then gradeNum = 3
			elseif grade == "Legendary" then gradeNum = 4 end
			
			local cost = {
				["Normal"] = 4,
				["Rare"] = 7,
				["Epic"] = 12,
				["Legendary"] = 25
			}
			
			_UI_Tooltip:SetRuneInfoUI(
				true, 
				runeData.IconRUID,
				_LocalizationService:GetText("RuneCard_"..self.CurrentRuneCardID.."_Name"),
				_LocalizationService:GetText("RuneCard_"..self.CurrentRuneCardID.."_Desc"),
				gradeNum, 
				cost[grade], false, false, 0, "BattleStat")
			_UI_Tooltip:SetMouseHoveredUI(self.Entity)
		end
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스가 룬 카드에서 벗어났을 때 룬 카드 정보 툴팁을 숨김
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		_UI_Tooltip:SetRuneInfoUI(false, "", "", "", 1, 1, false, false, nil, "BattleStat")
		_UI_Tooltip:SetMouseHoveredUI(nil)
	end

end