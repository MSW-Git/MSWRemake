@Component
script TeamBattleStatistics extends Component

	property SyncTable<string, string> SetRuneCard

	property SyncTable<string, string> EnemySetRuneCard

	property SyncTable<string, string> SetEnemyNameKey

	property SyncTable<string> SetMyCoaches

	property SyncTable<string, string> SetEnemyPresetID

	property SyncTable<string, string> SetRoundResult

	property SyncTable<string, number> SetRankAmount

	@ExecSpace("ServerOnly")
	method void RoundPropertyInitialize()
		-- 전투 시작 시, 각 프로퍼티에 초기값 기록
		--------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		
		-- 8-3 반복 플레이 처리
		if roundKey == "8-3" then
			local setCount = 0
			for i = 1, 5 do
				setCount = i
				local checkKey = string.format("%s-%d", roundKey, i)
				if not isvalid(self.SetRuneCard[checkKey]) then
					roundKey = checkKey
					break
				end
			end	
		end
		--------------------------------------------------
		local ownRunesStringValue = ""
		for _, runeIDs in pairs(teamManager.OwnRunes) do
			local runeID = _UtilLogic:Split(runeIDs, "_")[1]
			ownRunesStringValue = ownRunesStringValue .. string.format("%s.", runeID)
		end
		
		if ownRunesStringValue == "" then
			ownRunesStringValue = "NIL"
		else
			ownRunesStringValue = string.sub(ownRunesStringValue, 1, -2)
		end
		--------------------------------------------------
		local enemyRunesStringValue = ""
		for _, runeID in pairs(teamManager.EnemyOwnedRunes) do
			enemyRunesStringValue = enemyRunesStringValue .. string.format("%s.", runeID)
		end
		
		if enemyRunesStringValue == "" then
			enemyRunesStringValue = "NIL"
		else
			enemyRunesStringValue = string.sub(enemyRunesStringValue, 1, -2)
		end
		
		self.SetRuneCard[roundKey] = ownRunesStringValue
		self.EnemySetRuneCard[roundKey] = enemyRunesStringValue
		
		self:RoundPropertyInitializeToClient(user.OwnerId)
	end

	@ExecSpace("Client")
	method void RoundPropertyInitializeToClient()
		-- 전투 시작 시, 각 프로퍼티에 초기값 기록
		--------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		
		-- 8-3 반복 플레이 처리
		if roundKey == "8-3" then
			local setCount = 0
			for i = 1, 5 do
				setCount = i
				local checkKey = string.format("%s-%d", roundKey, i)
				if not isvalid(self.SetRuneCard[checkKey]) then
					roundKey = checkKey
					break
				end
			end	
		end
		--------------------------------------------------
		local ownRunesStringValue = ""
		for _, runeIDs in pairs(teamManager.OwnRunes) do
			local runeID = _UtilLogic:Split(runeIDs, "_")[1]
			ownRunesStringValue = ownRunesStringValue .. string.format("%s.", runeID)
		end
		
		if ownRunesStringValue == "" then
			ownRunesStringValue = "NIL"
		else
			ownRunesStringValue = string.sub(ownRunesStringValue, 1, -2)
		end
		--------------------------------------------------
		local enemyRunesStringValue = ""
		for _, runeID in pairs(teamManager.EnemyOwnedRunes) do
			enemyRunesStringValue = enemyRunesStringValue .. string.format("%s.", runeID)
		end
		
		if enemyRunesStringValue == "" then
			enemyRunesStringValue = "NIL"
		else
			enemyRunesStringValue = string.sub(enemyRunesStringValue, 1, -2)
		end
		
		self.SetRuneCard[roundKey] = ownRunesStringValue
		self.EnemySetRuneCard[roundKey] = enemyRunesStringValue
	end

	@ExecSpace("ServerOnly")
	method void PropertyClear()
		local user = self.Entity
		
		table.clear(self.SetRuneCard)
		table.clear(self.EnemySetRuneCard)
		table.clear(self.SetEnemyNameKey)
		table.clear(self.SetMyCoaches)
		table.clear(self.SetEnemyPresetID)
		table.clear(self.SetRoundResult)
		table.clear(self.SetRankAmount)
		
		self:PropertyClearToClient(user.OwnerId)
	end

	@ExecSpace("Client")
	method void PropertyClearToClient()
		table.clear(self.SetRuneCard)
		table.clear(self.EnemySetRuneCard)
		table.clear(self.SetEnemyNameKey)
		table.clear(self.SetMyCoaches)
		table.clear(self.SetEnemyPresetID)
		table.clear(self.SetRoundResult)
		table.clear(self.SetRankAmount)
	end

	@ExecSpace("ServerOnly")
	method void SetProperty(string name, string value)
		-- 프로퍼티에 기록
		--------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		
		-- 8-3 반복 플레이 처리
		local setKey = roundKey
		if setKey == "8-3" then
			setKey = "8-3-1"
			for i = 1, 5 do
				local checkKey = string.format("%s-%d", roundKey, i)
				if not isvalid(self.SetRoundResult[checkKey]) then
					setKey = checkKey
					break
				end
			end	
		end
		--------------------------------------------------
		if name == "SetEnemyNameKey" then
			self.SetEnemyNameKey[setKey] = value
		elseif name == "SetEnemyPresetID" then
			self.SetEnemyPresetID[setKey] = value
		elseif name == "SetRoundResult" then
			self.SetRoundResult[setKey] = value
		end
		
		self:SetPropertyToClient(name, value)
	end

	@ExecSpace("Client")
	method void SetPropertyToClient(string name, string value)
		-- 프로퍼티에 기록
		--------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
		
		-- 8-3 반복 플레이 처리
		local setKey = roundKey
		if setKey == "8-3" then
			setKey = "8-3-1"
			for i = 1, 5 do
				local checkKey = string.format("%s-%d", roundKey, i)
				if isvalid(self.SetRuneCard[checkKey]) then
					setKey = checkKey
				else
					break
				end
			end	
		end
		--------------------------------------------------
		if name == "SetEnemyNameKey" then
			self.SetEnemyNameKey[setKey] = value
		elseif name == "SetEnemyPresetID" then
			self.SetEnemyPresetID[setKey] = value
		elseif name == "SetRoundResult" then
			self.SetRoundResult[setKey] = value
			
			--스테이지 이동 연출 UI에 반영
			local win=true
			if value=="L" then
				win=false
			end
			_BackgroundChangeLogic:SetWinLoseUI(gameManager.Stage,gameManager.Round,win)
		end
	end

	@ExecSpace("ServerOnly")
	method void SetPropertyWithKey(string name, string key, string value)
		-- 프로퍼티에 기록
		--------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		--------------------------------------------------
		if name == "SetEnemyNameKey" then
			self.SetEnemyNameKey[key] = value
		elseif name == "SetRuneCard" then
			self.SetRuneCard[key] = value
		elseif name == "EnemySetRuneCard" then
			self.EnemySetRuneCard[key] = value
		elseif name == "SetEnemyPresetID" then
			self.SetEnemyPresetID[key] = value
		elseif name == "SetRoundResult" then
			self.SetRoundResult[key] = value
		end
		
		self:SetPropertyToClientWithKey(name, key, value, user.OwnerId)
	end

	@ExecSpace("Client")
	method void SetPropertyToClientWithKey(string name, string key, string value)
		-- 프로퍼티에 기록
		--------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		--------------------------------------------------
		if name == "SetEnemyNameKey" then
			self.SetEnemyNameKey[key] = value
		elseif name == "SetRuneCard" then
			self.SetRuneCard[key] = value
		elseif name == "EnemySetRuneCard" then
			self.EnemySetRuneCard[key] = value
		elseif name == "SetEnemyPresetID" then
			self.SetEnemyPresetID[key] = value
		elseif name == "SetRoundResult" then
			self.SetRoundResult[key] = value
			
			--스테이지 이동 연출 UI에 반영
			local stageround=_UtilLogic:Split(key,"-")
			local win=true
			if value=="L" then
				win=false
			end
			_BackgroundChangeLogic:SetWinLoseUI(tonumber(stageround[1]),tonumber(stageround[2]),win)
		end
	end

	@ExecSpace("ServerOnly")
	method void SetCoachesProperty(string loadValue)
		-- 게임 시작 시, 코치 리스트 기록
		--------------------------------------------------
		local user = self.Entity
		local coachManager = user.CoachManager
		table.clear(self.SetMyCoaches)
		--------------------------------------------------
		if isvalid(loadValue) then
			local setMyCoaches_Value = _UtilLogic:Split(loadValue, ",")
			for _, coachID in pairs(setMyCoaches_Value) do
				table.insert(self.SetMyCoaches, coachID)
			end
		else
			for _, coachID in pairs(coachManager.PlayCoachesID) do
				table.insert(self.SetMyCoaches, coachID)
			end
		end
		
		self:SetCoachesPropertyToClient(loadValue, user.OwnerId)
	end

	@ExecSpace("Client")
	method void SetCoachesPropertyToClient(string loadValue)
		-- 게임 시작 시, 코치 리스트 기록
		--------------------------------------------------
		local user = self.Entity
		local coachManager = user.CoachManager
		--------------------------------------------------
		if isvalid(loadValue) then
			local setMyCoaches_Value = _UtilLogic:Split(loadValue, ",")
			for _, coachID in pairs(setMyCoaches_Value) do
				table.insert(self.SetMyCoaches, coachID)
			end
		else
			for _, coachID in pairs(coachManager.PlayCoachesID) do
				table.insert(self.SetMyCoaches, coachID)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SetRankCountProperty(string checkKey, number amount, string type)
		local user = self.Entity
		local units = _UnitSetLogic_New.UnitsParentEntity[user.OwnerId]
		
		if type == "SetBattle" then
			-- checkKey를 stage-round 키로 사용합니다.
			-- 8-3 반복 플레이 처리
			if checkKey == "8-3" then
				local setCount = 0
				for i = 1, 5 do
					setCount = i
					local cKey = string.format("%s-%d", checkKey, i)
					if not isvalid(self.SetRuneCard[cKey]) then
						checkKey = cKey
						break
					end
				end	
			end
			
			-- 카운트
			local countTable = {["CT10005"] = 0, ["CT10010"] = 0, ["CT10012"] = 0}
			
			for _, unit in pairs(units.Children) do
				local unitInfo = unit.UnitInfo
				if unitInfo.use then
					if unitInfo:IsOnFieldUnit() and unitInfo.TeamType == "User" then
						-- 최종 팀 가치 (전장 유닛)  CT10005
						if unitInfo.level == 1 then
							countTable["CT10005"] += unitInfo.cost
						elseif unitInfo.cost == 1 then
							countTable["CT10005"] += ( 3^(unitInfo.level - 1) * unitInfo.cost )
						else
							countTable["CT10005"] += ( 3^(unitInfo.level - 1) * unitInfo.cost ) - 1
						end
						
						-- 최종 라운드에 장착한 완성 아이템 개수 (상징 아이템 포함)  CT10010
						for _, itemID in pairs(unit.UnitStatus.EquippedItemIDList) do
							local itemType = string.sub(itemID, 1, 2)
							if itemType == "NI" or itemType == "EI" then
								countTable["CT10010"] += 1
							end
						end
						
						-- 최종 배치된 캐릭터의 성급이 낮을수록 높은 점수 부여  CT10012
						countTable["CT10012"] += unitInfo.level
						
					end
				end
			end
			
			-- 최종 팀 가치 (전장 유닛)  CT10005
			self.SetRankAmount["CT10005"] = countTable["CT10005"]
			-- 최종 라운드에 장착한 완성 아이템 개수 (상징 아이템 포함)  CT10010
			self.SetRankAmount["CT10010"] = countTable["CT10010"]
			-- 최종 배치된 캐릭터의 성급이 낮을수록 높은 점수 부여  CT10012
			self.SetRankAmount["CT10012"] = countTable["CT10012"]
			
			
			
		elseif type == "EndBattle" then
			-- checkKey를 stage-round 키로 사용합니다.
			-- 8-3 반복 플레이 처리
			if checkKey == "8-3" then
				local setCount = 0
				for i = 1, 5 do
					setCount = i
					local cKey = string.format("%s-%d", checkKey, i)
					if not isvalid(self.SetRuneCard[cKey]) then
						checkKey = cKey
						break
					end
				end	
			end
			
			-- 카운트
			local countTable = {["CT10002"] = 0, ["CT10003"] = 0, ["CT10011"] = 0, ["CT10015"] = 0}
			
			for _, unit in pairs(units.Children) do
				local unitInfo = unit.UnitInfo
				local unitBStat = unit.UnitBattleStatistics
				if unitInfo.use and unitInfo.TeamType == "User" and isvalid(unitBStat.SetCharID[checkKey]) then
					-- 단일 유닛이 가장 높은 가해량을 기록  CT10002
					local damageDealt = unitBStat.PhysicalDamageDealt[checkKey] + unitBStat.MagicalDamageDealt[checkKey] + unitBStat.TrueDamageDealt[checkKey]
					countTable["CT10002"] = math.max(countTable["CT10002"], damageDealt)
					
					-- 단일 유닛이 가장 높은 피해량을 기록  CT10003
					local damageTaken = unitBStat.PhysicalDamageTaken[checkKey] + unitBStat.MagicalDamageTaken[checkKey] + unitBStat.TrueDamageTaken[checkKey]
					countTable["CT10003"] = math.max(countTable["CT10003"], damageTaken)
					
					-- 단일 유닛이 가장 높은 회복량을 기록  CT10011
					countTable["CT10011"] = math.max(countTable["CT10011"], unitBStat.HPAmountGainedByHealing[checkKey])
					
					-- 단일 유닛의 가장 높은 스킬 사용 횟수  CT10015
					countTable["CT10015"] = math.max(countTable["CT10015"], unitBStat.SkillCountUsed[checkKey])
				end
			end
			
			-- 단일 유닛이 가장 높은 가해량을 기록  CT10002
			-- 단일 유닛이 가장 높은 피해량을 기록  CT10003
			-- 단일 유닛이 가장 높은 회복량을 기록  CT10011
			-- 단일 유닛의 가장 높은 스킬 횟수  CT10015
			local keyTable = {"CT10002", "CT10003", "CT10011", "CT10015"}
			
			for _, key in pairs(keyTable) do
				if isvalid(self.SetRankAmount[key]) then
					self.SetRankAmount[key] = math.max(self.SetRankAmount[key], countTable[key])
				else
					self.SetRankAmount[key] = countTable[key]
				end
			end
			
			
			
		elseif type == "Add" then
			-- 모든 라운드 동안 생존한 아군 수 (누적)  CT10004
			-- 아이템 구매 횟수  CT10013
			if isvalid(self.SetRankAmount[checkKey]) then
				self.SetRankAmount[checkKey] += amount
			else
				self.SetRankAmount[checkKey] = amount
			end
		elseif type == "Set" then
			-- DB 불러올 때 사용
			self.SetRankAmount[checkKey] = amount
		end
	end

end