@Logic
script LoadResourcesInfo extends Logic

	property boolean Initialize = false

	property table UILocalPositionScale = {}

	property table ColliderOffsetScale = {}

	@ExecSpace("ClientOnly")
	method void ResourceLoad()
		--빠른 리소스로드속도를 위해 미리 다운받습니다.
		-------------------------------------------------------
		-- 튜토리얼 리소스 다운로드
		local masksetpos = _DataService:GetTable("MaskSetPos")
		local masksetposruid = {}
		for i = 1, masksetpos:GetRowCount() do
			if masksetpos:GetCell(i, "MaskRUID") ~= "nil" then
				table.insert(masksetposruid, masksetpos:GetCell(i, "MaskRUID"))
			end
			
			if masksetpos:GetCell(i, "OverImageRUID") ~= "nil" then
				table.insert(masksetposruid, masksetpos:GetCell(i, "OverImageRUID"))
			end
		end
		
		for i = 1, #masksetposruid do
			local RUID = masksetposruid[i]
			local maxWidth = 0
			local maxHeight = 0
			local maxPivotX = 0
			local maxPivotY = 0
			local RectSize = Vector2(0, 0)
					
			local sprite = _ResourceService:LoadSpriteAndWait(RUID)
			maxWidth = math.max(maxWidth, sprite .Width)
			maxHeight = math.max(maxHeight, sprite .Height)
			maxPivotX = maxWidth*sprite.Pivot.x
			maxPivotY = maxHeight*sprite.Pivot.y
			
			--UI : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth, maxHeight)
			local scale = Vector2(0, 0)
			if RectSize.x <= 20 and RectSize.y <= 20 then
				scale = Vector2(1.5, 1.5)
			else
				scale = Vector2(1, 1)
			end
				
			local pos = Vector2(0-((maxWidth/2)-maxPivotX)*scale.x, 0-((maxHeight/2)-maxPivotY)*scale.y)
			
			self.UILocalPositionScale[RUID] = {}
			self.UILocalPositionScale[RUID]["scale"] = scale
			self.UILocalPositionScale[RUID]["pos"] = pos
			
			--콜라이더 : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth/100, maxHeight/100)
			local midPivot = Vector2(((maxWidth/2)-maxPivotX)/100, ((maxHeight/2)-maxPivotY)/100)
			
			self.ColliderOffsetScale[RUID] = {}
			self.ColliderOffsetScale[RUID]["scale"] = RectSize
			self.ColliderOffsetScale[RUID]["pos"] = midPivot
		end
		
		--코치 IDLE 리소스 다운로드
		local coachinfo = _DataService:GetTable("CoachInfo")
		local profileruid = {}
		for i = 1, coachinfo:GetRowCount() do
			table.insert(profileruid, coachinfo:GetCell(i, "ProfileRUID"))
		end
		
		_ResourceService:PreloadAsync(profileruid,function() end)
		
		for i = 1, #profileruid do
			local RUID = profileruid[i]
			local maxWidth = 0
			local maxHeight = 0
			local maxPivotX = 0
			local maxPivotY = 0
			local RectSize = Vector2(0, 0)
					
			local sprite = _ResourceService:LoadSpriteAndWait(RUID)
			maxWidth = math.max(maxWidth, sprite .Width)
			maxHeight = math.max(maxHeight, sprite .Height)
			maxPivotX = maxWidth*sprite.Pivot.x
			maxPivotY = maxHeight*sprite.Pivot.y
			
			--UI : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth, maxHeight)
			local scale = Vector2(0, 0)
			if RectSize.x <= 20 and RectSize.y <= 20 then
				scale = Vector2(1.5, 1.5)
			else
				scale = Vector2(1, 1)
			end
				
			local pos = Vector2(0-((maxWidth/2)-maxPivotX)*scale.x, 0-((maxHeight/2)-maxPivotY)*scale.y)
			
			self.UILocalPositionScale[RUID] = {}
			self.UILocalPositionScale[RUID]["scale"] = scale
			self.UILocalPositionScale[RUID]["pos"] = pos
			
			--콜라이더 : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth/100, maxHeight/100)
			local midPivot = Vector2(((maxWidth/2)-maxPivotX)/100, ((maxHeight/2)-maxPivotY)/100)
			
			self.ColliderOffsetScale[RUID] = {}
			self.ColliderOffsetScale[RUID]["scale"] = RectSize
			self.ColliderOffsetScale[RUID]["pos"] = midPivot
		end
		--------------------------------------------------------------
		--캐릭터 IDLE 리소스 다운로드
		local characterinfo = _DataService:GetTable("CharacterInfo")
		local characterinforuid = {}
		for i = 1, characterinfo:GetRowCount() do
			if not _UtilLogic:IsNilorEmptyString(characterinfo:GetCell(i, 9)) then
				table.insert(characterinforuid, characterinfo:GetCell(i, 9))
			end
		end
		
		_ResourceService:PreloadAsync(characterinforuid, function() end)
		
		for i = 1, #characterinforuid do
			local RUID = characterinforuid[i]
			local maxWidth = 0
			local maxHeight = 0
			local maxPivotX = 0
			local maxPivotY = 0
			local RectSize=Vector2(0, 0)
					
			local anim = _ResourceService:LoadAnimationClipAndWait(RUID)	
			local frame = anim.Frames[1]
			maxWidth = math.max(maxWidth, frame.FrameSprite.Width)
			maxHeight = math.max(maxHeight, frame.FrameSprite.Height)
			maxPivotX = maxWidth*frame.FrameSprite.Pivot.x
			maxPivotY = maxHeight*frame.FrameSprite.Pivot.y
			
			--UI : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth, maxHeight)
			local scale = Vector2(0, 0)
			if RectSize.x <= 20 and RectSize.y <= 20 then
				scale=Vector2(1.5, 1.5)
			else
				scale=Vector2(1, 1)
			end
				
			local pos=Vector2(0-((maxWidth/2)-maxPivotX)*scale.x, 0-((maxHeight/2)-maxPivotY)*scale.y)
			
			self.UILocalPositionScale[RUID] = {}
			self.UILocalPositionScale[RUID]["scale"] = scale
			self.UILocalPositionScale[RUID]["pos"] = pos
			self.UILocalPositionScale[frame.FrameSprite.RUID] = {}
			self.UILocalPositionScale[frame.FrameSprite.RUID]["scale"] = scale
			self.UILocalPositionScale[frame.FrameSprite.RUID]["pos"] = pos
			
			--콜라이더 : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth/100, maxHeight/100)
			local midPivot=Vector2(((maxWidth/2)-maxPivotX)/100, ((maxHeight/2)-maxPivotY)/100)
			
			self.ColliderOffsetScale[RUID] = {}
			self.ColliderOffsetScale[RUID]["scale"] = RectSize
			self.ColliderOffsetScale[RUID]["pos"] = midPivot
			self.ColliderOffsetScale[frame.FrameSprite.RUID] = {}
			self.ColliderOffsetScale[frame.FrameSprite.RUID]["scale"] = RectSize
			self.ColliderOffsetScale[frame.FrameSprite.RUID]["pos"] = midPivot
		end
		
		-------------------------------------------------------
		--룬카드 아이콘 리소스 다운로드
		local runeinfo = _DataService:GetTable("RuneInfo")
		local iconruid = {}
		for i = 1, runeinfo:GetRowCount() do
			table.insert(iconruid,runeinfo:GetCell(i, "IconRUID"))
		end
		
		_ResourceService:PreloadAsync(iconruid, function() end)
		
		for i = 1, #iconruid do
			local RUID = iconruid[i]
			local maxWidth = 0
			local maxHeight = 0
			local maxPivotX = 0
			local maxPivotY = 0
			local RectSize = Vector2(0,0)
					
			local sprite = _ResourceService:LoadSpriteAndWait(RUID)
			maxWidth = math.max(maxWidth, sprite .Width)
			maxHeight = math.max(maxHeight, sprite .Height)
			maxPivotX = maxWidth*sprite.Pivot.x
			maxPivotY = maxHeight*sprite.Pivot.y
			
			--UI : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth, maxHeight)
			local scale=Vector2(0, 0)
			if RectSize.x <= 20 and RectSize.y <= 20 then
				scale=Vector2(1.5, 1.5)
			else
				scale=Vector2(1, 1)
			end
				
			local pos=Vector2(0-((maxWidth/2)-maxPivotX)*scale.x, 0-((maxHeight/2)-maxPivotY)*scale.y)
			
			self.UILocalPositionScale[RUID] = {}
			self.UILocalPositionScale[RUID]["scale"] = scale
			self.UILocalPositionScale[RUID]["pos"] = pos
			
			--콜라이더 : 픽셀값을 좌표값으로 변경
			RectSize = Vector2(maxWidth/100, maxHeight/100)
			local midPivot = Vector2(((maxWidth/2)-maxPivotX)/100, ((maxHeight/2)-maxPivotY)/100)
			
			self.ColliderOffsetScale[RUID] = {}
			self.ColliderOffsetScale[RUID]["scale"] = RectSize
			self.ColliderOffsetScale[RUID]["pos"] = midPivot
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self:ResourceLoad()
	end

	@ExecSpace("ClientOnly")
	method table GetUILocalPositionScale(string RUID)
		--UI에서 리소스를 적절하게 맞추고 싶을 때 사용하세요
		--resourceinfo["scale"]=Vector2스케일, resourceinfo["pos"]=Vector2오프셋을 인자로 보냅니다
		--localscale, localposition 프로퍼티에 적용해야합니다.
		
		local resourceinfo = {}
		--이전에 한 번 받은 정보인지 확인합니다.
		
		-- 0911 수정
		if isvalid(self.UILocalPositionScale[RUID]) and self.UILocalPositionScale[RUID]["scale"] ~= nil	then
			resourceinfo["scale"] = self.UILocalPositionScale[RUID]["scale"]
			resourceinfo["pos"] = self.UILocalPositionScale[RUID]["pos"]
			return resourceinfo
		else
			self.UILocalPositionScale[RUID] = {}
		end
		------------------------------------------------------------------------------------------
		
		--없으면 리소스정보 로드
		local maxWidth = 0
		local maxHeight = 0
		local maxPivotX = 0
		local maxPivotY = 0
		local RectSize = Vector2(0, 0)
		
		local frame = nil
		if _ResourceService:GetTypeAndWait(RUID)==ResourceType.AnimationClip then
			local anim = _ResourceService:LoadAnimationClipAndWait(RUID)
			frame = anim.Frames[1]
			
			maxWidth = math.max(maxWidth, frame.FrameSprite.Width)
			maxHeight = math.max(maxHeight, frame.FrameSprite.Height)
			maxPivotX = maxWidth*frame.FrameSprite.Pivot.x
			maxPivotY = maxHeight*frame.FrameSprite.Pivot.y
		elseif _ResourceService:GetTypeAndWait(RUID) == ResourceType.Sprite then
			frame = _ResourceService:LoadSpriteAndWait(RUID)
			
			maxWidth = math.max(maxWidth, frame.Width)
			maxHeight = math.max(maxHeight, frame.Height)
			maxPivotX = maxWidth*frame.Pivot.x
			maxPivotY = maxHeight*frame.Pivot.y
		end	
				
		--픽셀값을 좌표값으로 변경
		RectSize = Vector2(maxWidth, maxHeight)
		local scale = Vector2(0,0)
		if RectSize.x <= 20 and RectSize.y <= 20 then
			scale = Vector2(1.5,1.5)
		else
			scale = Vector2(1,1)
		end
			
		local pos = Vector2(0-((maxWidth/2)-maxPivotX)*scale.x, 0-((maxHeight/2)-maxPivotY)*scale.y)
		
		resourceinfo["scale"] = scale
		resourceinfo["pos"] = pos
		self.UILocalPositionScale[RUID]["scale"] = scale
		self.UILocalPositionScale[RUID]["pos"] = pos
		
		return resourceinfo
	end

	@ExecSpace("ClientOnly")
	method table GetColliderOffsetScale(string RUID)
		--TriggerComponent, physicsColliderComponent같이 충돌범위 offset, scale을 지정할 때 사용합니다
		--resourceinfo["scale"]=Vector2스케일, resourceinfo["pos"]=Vector2오프셋을 인자로 보냅니다
		
		local resourceinfo = {}
		--이전에 한 번 받은 정보인지 확인합니다.
		if isvalid(self.ColliderOffsetScale[RUID]) and self.ColliderOffsetScale[RUID]["scale"] ~= nil then
			resourceinfo["scale"] = self.ColliderOffsetScale[RUID]["scale"]
			resourceinfo["pos"] = self.ColliderOffsetScale[RUID]["pos"]
			return resourceinfo
		else
			self.ColliderOffsetScale[RUID] = {}
		end
		
		
		--리소스정보 로드
		local maxWidth = 0
		local maxHeight = 0
		local maxPivotX = 0
		local maxPivotY = 0
		local RectSize= Vector2(0, 0)
		local midPivot = Vector2(0, 0)
				
		local frame=nil
		if _ResourceService:GetTypeAndWait(RUID) == ResourceType.AnimationClip then
			local anim = _ResourceService:LoadAnimationClipAndWait(RUID)
			frame = anim.Frames[1]
		elseif _ResourceService:GetTypeAndWait(RUID) == ResourceType.Sprite then
			frame = _ResourceService:LoadSpriteAndWait(RUID)
		end
		
		if not isvalid(frame) or frame == nil then
			log_error("이용할 수 없는 RUID입니다. : "..RUID)
			
			resourceinfo["scale"] = Vector2(1, 1)
			resourceinfo["pos"] = Vector2(0, 0)
			
			return resourceinfo
		end
		
		maxWidth = math.max(maxWidth, frame.FrameSprite.Width)
		maxHeight = math.max(maxHeight, frame.FrameSprite.Height)
		maxPivotX = maxWidth*frame.FrameSprite.Pivot.x
		maxPivotY = maxHeight*frame.FrameSprite.Pivot.y
				
		--픽셀값을 좌표값으로 변경
		RectSize = Vector2(maxWidth/100, maxHeight/100)
		midPivot = Vector2(((maxWidth/2)-maxPivotX)/100, ((maxHeight/2)-maxPivotY)/100)
		
		resourceinfo["scale"] = RectSize
		resourceinfo["pos"] = midPivot
		self.ColliderOffsetScale[RUID]["scale"] = RectSize
		self.ColliderOffsetScale[RUID]["pos"] = midPivot
		
		return resourceinfo
	end

end