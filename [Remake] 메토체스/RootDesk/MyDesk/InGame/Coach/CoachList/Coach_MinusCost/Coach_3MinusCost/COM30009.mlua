@Component
script COM30009 extends CoachComponent

	@ExecSpace("ServerOnly")
	method void BuyUnitHandler(any event)
		__base:BuyUnitHandler(event)
		-- 캐릭터 상점에서 하나만 구매할 수 있습니다. 새로고침 사용 후 초기화됩니다.
		-----------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		local userPControl = user.TM_PropertyControl
		-----------------------------------------------------
		userPControl.Shop_CanPurchaseCharacter = false
		
		self:PlayAbilityEffect("true",user.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void ReRollCharacterShopHandler(any event)
		__base:ReRollCharacterShopHandler(event)
		-- 캐릭터 상점에서 하나만 구매할 수 있습니다. 새로고침 사용 후 초기화됩니다.
		-----------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		local userPControl = user.TM_PropertyControl
		-----------------------------------------------------
		userPControl.Shop_CanPurchaseCharacter = true
		
		self:PlayAbilityEffect("false",user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayAbilityEffect(string data)
		__base:PlayAbilityEffect(data)
		
		--------------------------------------------------------------
		local userEntity = _UserService.LocalPlayer
		local gameMap = userEntity.CurrentMap
		local coachArea = gameMap:GetChildByName("CoachArea")
		local coachInfo = _DataService:GetTable("CoachInfo")
		--------------------------------------------------------------
		local coachlist=userEntity.CoachManager.PlayCoachesID 
		
		for i=1,#coachlist do
			if coachlist[i] == "COM30009" then
				local coachEntity = coachArea:GetChildByName(string.format("Coach_%d", i))
				--발동연출
				if data=="true" then
					coachEntity.CoachIngameComponent:PlayCoachAbilityEffect(coachlist[i])
				end
				
				--효과연출
				if data=="true" then
					_GeneralDirectorLogic:LockCharacterShopSlot(5,true)
				else
					_GeneralDirectorLogic:LockCharacterShopSlot(5,false)
				end
				break
			end
		end
	end

end