@Component
script PEN30016 extends PenaltyComponent

	property number SetTime = 2

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 후 4초마다, 무작위 적 하나가 2초간 은신 상태가 됩니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local timer = 0
		----------------------------------------------------------------
		local function setFnc()
			if isvalid(user) == false then
				_TimerService:ClearTimer(timer)
				return
			end
			
			local ableEnemies = {}
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(ableEnemies, unit)
				end
			end
			
			if #ableEnemies <= 0 then
				_TimerService:ClearTimer(timer)
			else
				local checkIdx = _UtilLogic:RandomIntegerRange(1, #ableEnemies)
				
				_StatusChangeLogic:SetStatus(ableEnemies[checkIdx], ableEnemies[checkIdx], "SE0002", self.SetTime)
			end
				
		end
		
		timer = _TimerService:SetTimerRepeat(setFnc, 4, 4)
	end

end