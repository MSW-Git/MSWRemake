	@ExecSpace("ServerOnly")
	method void EmblemSynergyUpdate(Entity unit, string ItemID)
		-- 상징 아이템이 장착 해제될 때, 시너지에 반영하는 함수입니다.
		----------------------------------
		local userID = unit.UnitInfo.OwnerId
		local user = _UserService:GetUserEntityByUserId(userID)
		local teamManager = user.TeamManager
		
		local keyHead = string.sub(ItemID,1,2)
		local keyTail = string.sub(ItemID, 3, -1)
					
		local synergyID = "S"..keyTail
					
		-- 단, 전장에 해당 유닛과 동일한 ID를 가진 아군 유닛이 있고 동일한 메달을 장착한 경우는 예외처리
		local targetUnitCharID = unit.UnitInfo.charID
		local ownUnits = user.TeamManager.OwnUnits
		local hasSameCharWithSameEmblem = false 
		for _, unitToCompare in pairs(ownUnits) do
			if unitToCompare.UnitInfo:IsOnFieldUnit() then	-- 전장 위 유닛이고
				if unitToCompare ~= unit and unitToCompare.UnitInfo.charID == targetUnitCharID then	-- 동일한 캐릭터이며
					local itemListToCompare = unitToCompare.UnitStatus.EquippedItemIDList
					for _, equippedItemIDtoCompare in pairs(itemListToCompare) do
						local itemIDtoCompare = _UtilLogic:Split(equippedItemIDtoCompare, "_")[1]
									
						if itemIDtoCompare == ItemID then -- 동일한 상징 아이템을 장착했다면
							hasSameCharWithSameEmblem = true
						end
					end
				end
			end
		end
					
		if hasSameCharWithSameEmblem == false then
			teamManager:GetOnFieldSynergyCount(synergyID, -1)
		else
			log("동일한 메달을 장착한 동일한 캐릭터가 전장에 남아 있으므로, 시너지를 제거하지 않습니다")
		end
	end

	@ExecSpace("ServerOnly")
	method table GetItemList(string userId, string iType)
		-- 지정된 타입과 시즌에 맞는 아이템 목록을 반환하는 함수
		local user = _UserService:GetUserEntityByUserId(userId)
		local gameManager = user.GameManager
		local setVersion = string.format("%.1f", gameManager.ModeSetVersion)
		
		local itemDataSet = _DataService:GetTable("ItemStatus")
		local itemSeasonCheckTable = _DataService:GetTable("ItemListBySeason")
		
		local itemTable = {}
		
		for i=1, itemDataSet:GetRowCount() do
			local row = itemDataSet:GetRow(i)
			
			local type = row:GetItem("Type")
			local itemID = row:GetItem("ItemID")
			local checked = itemSeasonCheckTable:FindRow("ItemID", itemID):GetItem(setVersion)
			if checked == "TRUE" and (type == iType or iType == "All") then
				table.insert(itemTable, itemID)
			end
		end
		
		return itemTable
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: InputService
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Mouse0 then
			log("cursor Pos = ", _InputService:GetCursorPosition())
			log("해상도 = ", self.MouseChaser.Parent.UITransformComponent.RectSize)
			log("uilogic = ", _UILogic.ScreenWidth, _UILogic.ScreenHeight)
		end
	end

end