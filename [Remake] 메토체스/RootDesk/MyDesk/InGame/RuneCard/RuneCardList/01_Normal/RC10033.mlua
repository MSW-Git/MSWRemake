@Component
script RC10033 extends RuneCardComponent

	property boolean ItemGetCheck = true

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투에 참여할 때, 전투에 참여한 캐릭터들 중 2성 이상이 있는지 없는지 체크합니다.
		-- 하나도 없으면 황금 보따리를 얻습니다.
		---------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		---------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitInfo.level > 1 then
						self.ItemGetCheck = false
						break
					end
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 전투 때 체크한 결과를 토대로, 황금보따리를 지급합니다.
		---------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local gameManager = user.GameManager
		---------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			if self.ItemGetCheck then
				local itemIdx = 3
				if gameManager.Stage > 4 then
					itemIdx = 4
				end
				_ItemSetLogic:GetConsumableItem(user.OwnerId, itemIdx)
				local items=#user.TeamManager.OwnItems
				self:PlayEffect(items, itemIdx, user.PlayerComponent.UserId)
			end
			
			self.ItemGetCheck = true
		end
		
		
	end

	@ExecSpace("Client")
	method void PlayEffect(integer items, integer ItemId)
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		--룬 카드 발동 연출 없음
		
		--룬 카드 효과 연출
		_RuneCardDirector:RuneCardItemDirector_Ready(items, "RC10033","CI000"..tostring(math.floor(ItemId)), index)
	end

end