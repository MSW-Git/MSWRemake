@Component
script RC10038 extends RuneCardComponent

	property number SetHPAmount = 200

	property number SetAmount = 15

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시 사거리가 3 이상인 아군 유닛이 최대 체력 200, 공격력 15, 마력 15을 얻습니다.
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		------------------------------------------------------------
		
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable and unit.UnitStatus.AttackRange >= 3 then
					_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetHPAmount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAmount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAmount, -1)
					table.insert(units, unit)
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable and unit.UnitStatus.AttackRange >= 3 then
					_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetHPAmount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAmount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAmount, -1)
					table.insert(enemy, unit)
				end
			end
		end
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		local stringHPValue = string.format("%d", self.SetHPAmount)
		local stringValue = string.format("%d", self.SetAmount)
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.PhysicalAttack, _RuneCardDirectEnum.MagicalAttack}, {stringHPValue, stringValue, stringValue}, false)
		end
		
		if #enemy > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.PhysicalAttack, _RuneCardDirectEnum.MagicalAttack}, {stringHPValue, stringValue, stringValue}, true)
		end
	end

end