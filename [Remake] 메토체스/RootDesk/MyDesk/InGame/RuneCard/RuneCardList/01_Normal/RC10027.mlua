@Component
script RC10027 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void OpenItemBoxHandler(any event)
		__base:OpenItemBoxHandler(event)
		
		-- 아이템 박스를 열 때마다, 35% 확률로 소모품 아이템을 생성합니다.
		---------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		---------------------------------------------------------------------
		if self.SetTeamType == "User" then
			local per = _UtilLogic:RandomDouble()
			
			if per < 0.35 then
				_ItemSetLogic:GetConsumableItem(user.OwnerId, -1)
				local items = #user.TeamManager.OwnItems -- 아이템 생성 위치
				local itemID = user.TeamManager.OwnItems[items]
				self:PlayEffect(items, itemID, user.PlayerComponent.UserId)
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(integer Items, string ItemID)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		------------------------------------------------------------
		
		--룬 카드 발동 연출 없음
		
		
		--룬 카드 효과 연출
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:RuneCardItemDirector_Ready(Items, "RC10027", ItemID, index)
	end

end