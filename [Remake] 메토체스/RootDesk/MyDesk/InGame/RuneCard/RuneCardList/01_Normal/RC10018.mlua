@Component
script RC10018 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		-- 라운드를 시작할 때 3성 캐릭터를 보유한 상태라면, 해당 캐릭터의 1성 유닛을 획득합니다. (단 대상이 셋 이상이라면, 무작위로 셋 선택하여 획득)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local teamManager = user.TeamManager
		-------------------------------------------------------------
		if self.SetTeamType == "User" then
			local checkedUnitID = {}
			-- 3성 유닛 선별
			for _, unit in pairs(teamManager.OwnUnits) do
				local unitInfo = unit.UnitInfo
				
				if unitInfo.level == 3 and unitInfo.cost ~= 0 then
					table.insert(checkedUnitID, unitInfo.charID)
				end
			end
			
			-- 3성 유닛이 셋 초과인지 확인
			if #checkedUnitID > 3 then
				-- 무작위 셋 선택 획
				for i = 1, 3 do
					local charIdx = _UtilLogic:RandomIntegerRange(1, #checkedUnitID)
					_UnitSetLogic_New:SpawnUnit(user.OwnerId, checkedUnitID[charIdx], 1, "Force")
					table.remove(checkedUnitID, charIdx)
				end
			else
				for _, charID in pairs(checkedUnitID) do
					_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
				end
			end
			
			-- 연출
			if #checkedUnitID > 0 then
				self:PlayEffect(user.PlayerComponent.UserId)
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect()
		--유닛 소환 사운드
		_PlaySoundLogic:PlaySound("M0005")
		
		--룬 카드 발동 연출
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:ShakingCard_Ready(index)
	end

end