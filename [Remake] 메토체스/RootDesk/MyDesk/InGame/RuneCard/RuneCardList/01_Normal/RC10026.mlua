@Component
script RC10026 extends RuneCardComponent

	property number SetPercent = 0.5

	@ExecSpace("ServerOnly")
	method void ReRollCharacterShopHandler(any event)
		__base:ReRollCharacterShopHandler(event)
		
		-- 상점을 새로고침 할 때마다 +2 스택
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		--------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self:SetRuneStackInfo(self.RuneStack + 2)
			self:PlayEffect(self.RuneStack, "", "", true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void BuyUnitHandler(any event)
		__base:BuyUnitHandler(event)
		
		-- 상점에서 캐릭터를 구매할 때마다 -1 스택
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		--------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self:SetRuneStackInfo(math.max(0, self.RuneStack - 1))
			self:PlayEffect(self.RuneStack, "", "", true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시, 1스택 당 모든 아군의 공격 속도가 0.5%만큼 증가합니다.
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local addMultiAttackSpeed = self.SetPercent * self.RuneStack
		local units = {}
		local enemy = {}
		--------------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", addMultiAttackSpeed, -1)
					table.insert(units, unit)
				end
			end
		else
			-- 스택 임의로 넣어줘야 함 (스테이지 비례)
			local setStage = gameManager.Stage - 1
			self:SetRuneStackInfo(_UtilLogic:RandomIntegerRange(setStage * 6, setStage * 6 + gameManager.Round * 2))
			addMultiAttackSpeed = self.SetPercent * self.RuneStack
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", addMultiAttackSpeed, -1)
					table.insert(enemy, unit)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(self.RuneStack, units, enemy, false, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(number stack, string units, string enemy, boolean Ready)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		if stack < 0 then stack = 0 end
		
		if Ready == false then
			if stack == 0 then return end
			--룬 카드 발동 연출
			if #units > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
				_RuneCardDirector:ShakingCard_Battle(index, false)
				local value = stack*self.SetPercent
				_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.AttackSpeed}, {tostring(value).."%"}, false)
			end
			
			if #enemy > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,true)
				_RuneCardDirector:ShakingCard_Battle(index, true)
				local value = stack*self.SetPercent
				_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.AttackSpeed}, {tostring(value).."%"}, true)
			end
			
		else
		
			if _RuneCardDirector.RuneCardManagingValue["RC10026"][self.Entity.Id] > stack then
				--발동 연출
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
				_RuneCardDirector:ShakingCard_Ready(index)
				-- +1
				_RuneCardDirector:IconToastDirector_Ready(index, 0, "-1")
				_RuneCardDirector.RuneCardManagingValue["RC10026"][self.Entity.Id] = stack
				_RuneCardDirector:CheckRuneCardManagingValue("RC10026", index)
				
			elseif _RuneCardDirector.RuneCardManagingValue["RC10026"][self.Entity.Id] < stack then
				--발동 연출
				local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
				_RuneCardDirector:ShakingCard_Ready(index)
				-- -1
				_RuneCardDirector:IconToastDirector_Ready(index, 0, "+2")
				_RuneCardDirector.RuneCardManagingValue["RC10026"][self.Entity.Id] = stack
				_RuneCardDirector:CheckRuneCardManagingValue("RC10026", index)
				
			else
				--연출없음
				
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		_RuneCardDirector.RuneCardManagingValue["RC10026"][self.Entity.Id] = stack
		_RuneCardDirector:CheckRuneCardManagingValue("RC10026", runeindex)
	end

end