@Component
script RC10003 extends RuneCardComponent

	property number AddMultiAttackSpeed = 0

	property number SetPercent = 5

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 전투 시작 시 보유한 룬 카드 1개마다 모든 아군의 공격 속도가 5%씩 증가합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self.AddMultiAttackSpeed = #teamManager.OwnRunes * self.SetPercent
		else
			self.AddMultiAttackSpeed = #teamManager.EnemyOwnedRunes * self.SetPercent
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시 보유한 룬 카드 1개마다 모든 아군의 공격 속도가 5%씩 증가합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		----------------------------------------------------------------------
		
		if self.SetTeamType == "User" then
			self.AddMultiAttackSpeed = #teamManager.OwnRunes * self.SetPercent
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", self.AddMultiAttackSpeed, -1)
					table.insert(units, unit)
				end
			end
		else
			self.AddMultiAttackSpeed = #teamManager.EnemyOwnedRunes * self.SetPercent
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", self.AddMultiAttackSpeed, -1)
					table.insert(enemy, unit)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void BuyRuneCardHandler(any event)
		__base:BuyRuneCardHandler(event)
		
		-- 전투 시작 시 보유한 룬 카드 1개마다 모든 아군의 공격 속도가 5%씩 증가합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self.AddMultiAttackSpeed = #teamManager.OwnRunes * self.SetPercent
		else
			self.AddMultiAttackSpeed = #teamManager.EnemyOwnedRunes * self.SetPercent
		end
	end

	@ExecSpace("ServerOnly")
	method void SellRuneCardHandler(any event)
		__base:SellRuneCardHandler(event)
		
		-- 전투 시작 시 보유한 룬 카드 1개마다 모든 아군의 공격 속도가 5%씩 증가합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self.AddMultiAttackSpeed = #teamManager.OwnRunes * self.SetPercent
		else
			self.AddMultiAttackSpeed = #teamManager.EnemyOwnedRunes * self.SetPercent
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		
		--룬 카드 발동 연출
		if #units > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			local value = math.floor(self.SetPercent*#teamManager.OwnRunes)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.AttackSpeed}, {tostring(value).."%"}, false)
		end
		
		if #enemy > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			local value = math.floor(self.SetPercent*#teamManager.EnemyOwnedRunes)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.AttackSpeed}, {tostring(value).."%"}, true)
		end
		
		
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		-- 전투 시작 시 보유한 룬 카드 1개마다 모든 아군의 공격 속도가 5%씩 증가합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self.AddMultiAttackSpeed = #teamManager.OwnRunes * self.SetPercent
		else
			self.AddMultiAttackSpeed = #teamManager.EnemyOwnedRunes * self.SetPercent
		end
		
		__base:InGameDataLoadHandler(event)
	end

end