@Component
script RC10009 extends RuneCardComponent

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 황금 카르마의 가위를 획득합니다.
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		-------------------------------------------------------------
		if self.SetTeamType == "User" then
			_ItemSetLogic:GetConsumableItem(user.OwnerId, 2)
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 황금 카르마의 가위를 획득합니다.
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		-------------------------------------------------------------
		if self.SetTeamType == "User" then
			for idx, itemID in pairs(user.TeamManager.OwnItems) do
				if itemID == "CI0002" then
					table.remove(user.TeamManager.OwnItems, idx)
					break
				end
			end
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				_ItemSetLogic:GetConsumableItem(user.OwnerId, 2)
			else
				-- 비활성화 시
				for idx, itemID in pairs(user.TeamManager.OwnItems) do
					if itemID == "CI0002" then
						table.remove(user.TeamManager.OwnItems, idx)
						break
					end
				end
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end