@Component
script RC20054 extends RuneCardComponent

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 전직교관 시너지 효과
		-- 전직교관의 고유 보너스 효과가 100% 추가 적용됩니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10024"] += 1
		else
			synergyManager.Enemy_SynergyRuneOn["S10024"] += 1
		end
		
		synergyManager:S10024(self.SetTeamType)
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 전직교관 시너지 효과
		-- 전직교관의 고유 보너스 효과가 100% 추가 적용됩니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10024"] -= 1
		else
			synergyManager.Enemy_SynergyRuneOn["S10024"] -= 1
		end
		
		synergyManager:S10024(self.SetTeamType)
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		local synergyID = "S10024"
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				synergyManager.SynergyRuneOn[synergyID] += 1
			else
				-- 비활성화 시
				synergyManager.SynergyRuneOn[synergyID] -= 1
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end