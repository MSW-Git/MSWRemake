@Component
script RC20003 extends RuneCardComponent

	property number AddDealingDamageRatePer = 0

	property number SetPercent = 10

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 전투 시작 시, 빈 룬 카드 슬롯마다 아군이 8%의 가해량을 얻습니다.
		-- 이 카드는 빈 슬롯으로 간주합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Rune_UnCountableNumberOfMyTeam += 1
		else
			userPControl.Rune_UnCountableNumberOfEnemy += 1
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시, 빈 룬 카드 슬롯마다 아군이 8%의 가해량을 얻습니다.
		-- 이 카드는 빈 슬롯으로 간주합니다.
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local units = {}
		local enemy = {}
		----------------------------------------------------------------------
		if self.OnActive then
			if self.SetTeamType == "User" then
				self.AddDealingDamageRatePer = (5 - #teamManager.OwnRunes + userPControl.Rune_UnCountableNumberOfMyTeam) * self.SetPercent
				for _, unit in pairs(teamManager.OwnUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", self.AddDealingDamageRatePer, -1)
						table.insert(units, unit)
					end
				end
			else
				self.AddDealingDamageRatePer = (5 - #teamManager.EnemyOwnedRunes + userPControl.Rune_UnCountableNumberOfEnemy) * self.SetPercent
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", self.AddDealingDamageRatePer, -1)
						table.insert(enemy, unit)
					end
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, self.AddDealingDamageRatePer, user.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Rune_UnCountableNumberOfMyTeam -= 1
		else
			userPControl.Rune_UnCountableNumberOfEnemy -= 1
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy, number dealingdamage)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		
		--룬 카드 발동 연출
		if #units > 0 then
			if dealingdamage <= 0 then return end -- 비활성화 상태
			
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
			local value = math.floor(dealingdamage)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.DealingDamageRate},{tostring(value).."%"}, false)
		end
		
		if #enemy > 0 then
			if dealingdamage <= 0 then return end -- 비활성화 상태
			
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			local value = math.floor(dealingdamage)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.DealingDamageRate}, {tostring(value).."%"}, true)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				userPControl.Rune_UnCountableNumberOfMyTeam += 1
			else
				-- 비활성화 시
				userPControl.Rune_UnCountableNumberOfMyTeam -= 1
			end
		end
		
		__base:SetActiveHandler(event)
	end

end