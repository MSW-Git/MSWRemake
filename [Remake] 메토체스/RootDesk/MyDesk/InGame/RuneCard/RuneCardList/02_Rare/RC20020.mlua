@Component
script RC20020 extends RuneCardComponent

	property number GetMaxCoin = 60

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 라운드가 시작 될 때, 이 카드 오른쪽의 카드를 파괴합니다.
		-- 파괴한 카드의 판매 가치의 2배만큼 코인을 획득합니다.
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local ownRunes = teamManager.OwnRunes 
		local specialShopManager = user.SpecialShopManager
		local runeID = "RC20020"
		--------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			if not self.Copied then
				-- 현재 카드의 인덱스 찾기
				local slotIdx = 0
				for i, runeIDs in pairs(ownRunes) do
					local checkRuneID = _UtilLogic:Split(runeIDs, "_")[1]
					if checkRuneID == runeID then
						slotIdx = i
						break
					end
				end
				
				if slotIdx ~= 0 and slotIdx ~= 5 then
					if isvalid(ownRunes[slotIdx + 1]) then
						-- 파괴할 룬 ID 확인
						local runeIDInfo =  _UtilLogic:Split(ownRunes[slotIdx + 1], "_")
						if isvalid(runeIDInfo) then
							local checkRuneID = runeIDInfo[1]
							local checkRuneUID = tonumber(runeIDInfo[2])
							-- 판매 가치 확인 후, 코인 획득
							local resellRune = teamManager:FindRuneCardComponent(checkRuneID, checkRuneUID)
							local resellCost = resellRune.ResellCost
							local runeSetUID = resellRune.UID
							
							local getCost = math.min(self.GetMaxCoin, resellCost * 3)
							
							
							-- Copy 상태면, 2번 획득
							if isvalid(self.CopiedComponent) then
								_TimerService:SetTimerOnce(function() teamManager:AddGolds(getCost, "runeCard") end , 1.5)
								_TimerService:SetTimerOnce(function() self:PlayEffect(getCost, slotIdx + 1, user.PlayerComponent.UserId) end , 1.5)
								-- 업적: 룬카드 [골드리치 주니어]효과로 룬 카드를 판매하여 60코인 획득하기 
								_AchievementService:UpdateProgress_RuneCard("AC004007", getCost, user)
							end
							
							_TimerService:SetTimerOnce(function() teamManager:AddGolds(getCost, "runeCard") end , 1.5)
							_TimerService:SetTimerOnce(function() self:PlayEffect(getCost, slotIdx + 1, user.PlayerComponent.UserId) end , 1.5)
							
							-- 업적: 룬카드 [골드리치 주니어]효과로 룬 카드를 판매하여 60코인 획득하기 
							_AchievementService:UpdateAchievement("AC004007",getCost,user)
							
							specialShopManager:RemoveRuneCard(checkRuneID, runeSetUID) -- 파괴
						end
					end
				end
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(integer values, integer destroyindex)
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		
		--룬 카드 효과 연출
		_RuneCardDirector:RuneCardCoinDirector(index, values)
		
	end

end