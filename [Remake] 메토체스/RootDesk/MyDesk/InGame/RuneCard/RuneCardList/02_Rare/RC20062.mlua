@Component
script RC20062 extends RuneCardComponent

	property SyncTable<Entity> ShadowUnits

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 그림자 시너지 효과
		-- 시너지 활성화 시 전투가 시작되면 그림자 유닛의 공격 속도가 30% 증가하며, 쉐도우 파트너의 스탯 또한 기존 유닛의 100%로 적용됩니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local unitParentsEntity = _UnitSetLogic_New.UnitsParentEntity[user.OwnerId]
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10007"] += 1
			
			for i = 1, 2 do
				local shadowUnit = unitParentsEntity:GetChildByName(string.format("BTUnit_Shadow%d",i))
				shadowUnit.UnitSynergy.SynergyStack["S10007"] = 0
				--shadowUnit.UnitStatus:SetUnitStatus(false)
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				table.insert(self.ShadowUnits, shadowUnit)
			end
		else
			synergyManager.Enemy_SynergyRuneOn["S10007"] += 1
			
			for i = 1, 2 do
				local shadowUnit = unitParentsEntity:GetChildByName(string.format("EnemyUnit_Shadow%d",i))
				shadowUnit.UnitSynergy.SynergyStack["S10007"] = 0
				--shadowUnit.UnitStatus:SetUnitStatus(false)
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				table.insert(self.ShadowUnits, shadowUnit)
			end
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 그림자 시너지 효과
		-- 시너지 활성화 시 전투가 시작되면 그림자 유닛의 공격 속도가 30% 증가하며, 쉐도우 파트너의 스탯 또한 기존 유닛의 100%로 적용됩니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10007"] -= 1
		else
			synergyManager.Enemy_SynergyRuneOn["S10007"] -= 1
		end
		
		for _, shadowUnit in pairs(self.ShadowUnits) do
			shadowUnit.UnitSynergy.SynergyStack["S10007"] = 50
			--shadowUnit.UnitStatus:SetUnitStatus(false)
			shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
			shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
			shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 그림자 시너지 효과
		-- 시너지 활성화 시 전투가 시작되면 그림자 유닛의 공격 속도가 30% 증가합니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local synergyManager = user.SynergyManager_New
		local units={}
		local enemy={}
		--------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitInfo:DoesHaveSynergy("S10007") then
						_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", 30, -1)
						table.insert(units,unit)
					end
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitInfo:DoesHaveSynergy("S10007") then
						_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", 30, -1)
						table.insert(enemy,unit)
					end
				end
			end
		end
		
		units=_UtilLogic:TableToString(units)
		enemy=_UtilLogic:TableToString(enemy)
		self:PlayEffect(units,enemy,user.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local unitParentsEntity = _UnitSetLogic_New.UnitsParentEntity[user.OwnerId]
		local synergyManager = user.SynergyManager_New
		local synergyID = "S10007"
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				synergyManager.SynergyRuneOn[synergyID] += 1
				
				for i = 1, 2 do
					local shadowUnit = unitParentsEntity:GetChildByName(string.format("BTUnit_Shadow%d",i))
					shadowUnit.UnitSynergy.SynergyStack["S10007"] = 0
					--shadowUnit.UnitStatus:SetUnitStatus(false)
					
					shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
					shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
					shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
					table.insert(self.ShadowUnits, shadowUnit)
				end
			else
				-- 비활성화 시
				synergyManager.SynergyRuneOn[synergyID] -= 1
				for _, shadowUnit in pairs(self.ShadowUnits) do
					shadowUnit.UnitSynergy.SynergyStack["S10007"] = 50
					--shadowUnit.UnitStatus:SetUnitStatus(false)
					
					shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
					shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
					shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				end
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		-- 그림자 시너지 효과
		-- 시너지 활성화 시 전투가 시작되면 그림자 유닛의 공격 속도가 30% 증가하며, 쉐도우 파트너의 스탯 또한 기존 유닛의 100%로 적용됩니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local unitParentsEntity = _UnitSetLogic_New.UnitsParentEntity[user.OwnerId]
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			for i = 1, 2 do
				local shadowUnit = unitParentsEntity:GetChildByName(string.format("BTUnit_Shadow%d",i))
				shadowUnit.UnitSynergy.SynergyStack["S10007"] = 0
				--shadowUnit.UnitStatus:SetUnitStatus(false)
				
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				table.insert(self.ShadowUnits, shadowUnit)
			end
		else
			for i = 1, 2 do
				local shadowUnit = unitParentsEntity:GetChildByName(string.format("EnemyUnit_Shadow%d",i))
				shadowUnit.UnitSynergy.SynergyStack["S10007"] = 0
				--shadowUnit.UnitStatus:SetUnitStatus(false)
				
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
				shadowUnit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				table.insert(self.ShadowUnits, shadowUnit)
			end
		end
		
		__base:InGameDataLoadHandler(event)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units=_UtilLogic:StringToTable(units)
		enemy=_UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		
	end

end