@Component
script RC20016 extends RuneCardComponent

	property number SetMinusHPPercent = 50

	property number SetPlusHPPercent = 30

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시 무작위 아군 둘의 체력이 50% 감소합니다. 대신 나머지 유닛의 최대 체력이 30% 늘어납니다.
		-------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local units={}
		local enemy={}
		-------------------------------------------------------------------
		
		---@type table<Entity>
		local setUnits = {}
		
		if self.SetTeamType == "User" then
			-- 전장 유닛 체크하기
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(setUnits, unit)
				end
			end
			
			-- 2기 골라서 체력 감소
			for i = 1, 2 do
				if #setUnits > 0 then
					local unitIdx = _UtilLogic:RandomIntegerRange(1, #setUnits)
					local selectUnit = setUnits[unitIdx]
					_StatusChangeLogic:SetVariableStatus(selectUnit, selectUnit, "HP", -selectUnit.UnitStatus.MaxHP * self.SetMinusHPPercent / 100, "rune")
					table.insert(units, selectUnit)
					table.remove(setUnits, unitIdx)
				end
			end
			
			
			-- 나머지 유닛들은 최대 체력 증가
			if #setUnits > 0 then
				for _, unit in pairs(setUnits) do
					_StatusChangeLogic:GetBuff(unit, "Multi_MaxHP", 30, -1)
				end
			end
		else
			-- 전장 유닛 체크하기
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(setUnits, unit)
				end
			end
			
			-- 2기 골라서 체력 감소
			for i = 1, 2 do
				if #setUnits > 0 then
					local unitIdx = _UtilLogic:RandomIntegerRange(1, #setUnits)
					local selectUnit = setUnits[unitIdx]
					_StatusChangeLogic:SetVariableStatus(selectUnit, selectUnit, "HP", -selectUnit.UnitStatus.MaxHP * self.SetMinusHPPercent / 100, "rune")
					table.insert(enemy, selectUnit)
					table.remove(setUnits, unitIdx)
				end
			end
			
			
			-- 나머지 유닛들은 최대 체력 증가
			if #setUnits > 0 then
				for _, unit in pairs(setUnits) do
					_StatusChangeLogic:GetBuff(unit, "Multi_MaxHP", self.SetPlusHPPercent, -1)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		local stringPlusValue = string.format("%d%%", self.SetPlusHPPercent)
		local stringMinusValue = string.format("-%d%%", self.SetMinusHPPercent)
		
		--룬 카드 발동 연출
		if #units > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.HP},{stringPlusValue, stringMinusValue}, false)
		end
			
		if #enemy>0 then
			local index=_RuneCardDirector:GetRuneCardIndex(self.Entity,true)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.HP},{stringPlusValue, stringMinusValue}, true)
		end
		
		--룬 카드 효과 연출
		for i = 1, #units do
			units[i].UnitAnimationComponent:PlayHitDirection()
		end
		
		for i = 1, #enemy do
			enemy[i].UnitAnimationComponent:PlayHitDirection()
		end
		
		
	end

end