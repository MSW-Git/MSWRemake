@Component
script RC20051 extends RuneCardComponent

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 오르비스 시너지 효과
		-- 마법석의 적용 범위가 1칸 늘어나며, 보호막 제공 간격이 1초 줄어듭니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10021"] += 1
			
			-- 마법석 적용 범위 재설정해서 보여줘야 함
			synergyManager:OnActivatedSynergyCountChanged("S10021", 0)
			synergyManager:OnActivatedSynergyCountChanged("S10021", teamManager.OnFieldSynergy["S10021"])
		else
			synergyManager.Enemy_SynergyRuneOn["S10021"] += 1
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 오르비스 시너지 효과
		-- 마법석의 적용 범위가 1칸 늘어나며, 보호막 제공 간격이 2초 줄어듭니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10021"] -= 1
			
			-- 마법석 적용 범위 재설정해서 보여줘야 함
			synergyManager:OnActivatedSynergyCountChanged("S10021", 0)
			synergyManager:OnActivatedSynergyCountChanged("S10021", teamManager.OnFieldSynergy["S10021"])
		else
			synergyManager.Enemy_SynergyRuneOn["S10021"] -= 1
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local synergyManager = user.SynergyManager_New
		local synergyID = "S10021"
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				synergyManager.SynergyRuneOn[synergyID] += 1
				
			else
				-- 비활성화 시
				synergyManager.SynergyRuneOn[synergyID] -= 1
			end
			
			-- 마법석 적용 범위 재설정해서 보여줘야 함
			synergyManager:OnActivatedSynergyCountChanged("S10021", 0)
			synergyManager:OnActivatedSynergyCountChanged("S10021", teamManager.OnFieldSynergy["S10021"])
		end
		
		
		__base:SetActiveHandler(event)
	end

end