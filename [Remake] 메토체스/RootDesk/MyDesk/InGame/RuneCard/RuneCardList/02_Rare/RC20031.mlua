@Component
script RC20031 extends RuneCardComponent

	property number SetShieldAmount = 150

	@ExecSpace("ServerOnly")
	method void WinBattleHandler(any event)
		__base:WinBattleHandler(event)
		
		-- 전투 승리 시, 살아남은 아군 유닛들 중 HP가 최대인 아군 유닛 당 +100의 보호막을 다음 라운드에 모든 아군 유닛이 획득합니다.
		-- 보호막은 한 라운드씩만 적용됩니다.
		-------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		-------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					log(unit.UnitInfo.charID, unit.UnitStatus.HP, unit.UnitStatus.MaxHP)
					
					if unit.UnitStatus.HP > 0 then
						self:SetRuneStackInfo(self.RuneStack + 1)
					end
				end
			end
			self:PlayEffect(false,true,false,self.RuneStack,user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 승리 시, 살아남은 아군 유닛들 중 HP가 최대인 아군 유닛 당 +100의 보호막을 다음 라운드에 모든 아군 유닛이 획득합니다.
		-- 보호막은 한 라운드씩만 적용됩니다.
		-------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		-------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:SetShield(unit, unit, self.RuneStack * self.SetShieldAmount, -1, "RC20031")
				end
			end
			if self.RuneStack > 0 then
				self:PlayEffect(true,true,false,self.RuneStack,user.PlayerComponent.UserId)
			end
		else
			-- 스택 쌓아줘야 함
			self.RuneStack = _UtilLogic:RandomIntegerRange(1, gameManager.Stage + 1)
			
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:SetShield(unit, unit, self.RuneStack * self.SetShieldAmount, -1, "RC20031")
				end
			end
			if self.RuneStack > 0 then
				self:PlayEffect(true,true,true,self.RuneStack,user.PlayerComponent.UserId)
			end
		end
		
		self.RuneStack = 0
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean Battle, boolean win, boolean enemy, integer value)
		if Battle then
			if enemy then
				local index=_RuneCardDirector:GetRuneCardIndex(self.Entity,true)
				_RuneCardDirector:ShakingCard_Battle(index,true)
				_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.Shield},{tostring(math.floor(value*self.SetShieldAmount))},enemy)
				
			else
				local index=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
				_RuneCardDirector.RuneCardManagingValue["RC20031"][self.Entity.Id]=0
				_RuneCardDirector:CheckRuneCardManagingValue("RC20031",index)
				_RuneCardDirector:ShakingCard_Battle(index,false)
				_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.Shield},{tostring(math.floor(value*self.SetShieldAmount))},enemy)
			end
		
		elseif Battle==false then
			if win then
				local index=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
				_RuneCardDirector:ShakingCard_Battle(index,false)
				_RuneCardDirector:IconToastDirector_Battle(index,{0},{tostring(math.floor(value))},false)
				_RuneCardDirector.RuneCardManagingValue["RC20031"][self.Entity.Id]=value
				_RuneCardDirector:CheckRuneCardManagingValue("RC20031",index)
			else
				local index=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
				_RuneCardDirector.RuneCardManagingValue["RC20031"][self.Entity.Id]=0
				_RuneCardDirector:CheckRuneCardManagingValue("RC20031",index)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void LoseBattleHandler(any event)
		__base:LoseBattleHandler(event)
		-- 전투 승리 시, 살아남은 아군 유닛들 중 HP가 최대인 아군 유닛 당 +100의 보호막을 다음 라운드에 모든 아군 유닛이 획득합니다.
		-- 보호막은 한 라운드씩만 적용됩니다.
		-------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		-------------------------------------------------------
		if self.SetTeamType == "User" then
			--self:PlayEffect(false,false,false,user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack,user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		_RuneCardDirector.RuneCardManagingValue["RC20031"][self.Entity.Id]=stack
		_RuneCardDirector:CheckRuneCardManagingValue("RC20031",runeindex)
	end

end