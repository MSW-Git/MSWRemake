@Component
script RC20021 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void LevelUpUnitHandler(any event)
		__base:LevelUpUnitHandler(event)
		
		-- 캐릭터를 2성이나 3성으로 만들 때마다, 해당 캐릭터의 단계만큼 코인을 얻습니다.
		----------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		
		---@type Entity
		local unit = event.Unit
		
		---@type number
		local level = event.SetLevel
		local cost = event.UnitCost
		----------------------------------------------------------------------------
		if self.SetTeamType == "User" and unit.UnitInfo.TeamType == self.SetTeamType then
			if self.UsedRuneAbility == false then
				local getCoins = cost*(3^(level-1)) - math.min(1, cost-1)
				
				self:PlayEffect("Coin", getCoins, user.PlayerComponent.UserId)
				teamManager:AddGolds(getCoins, "runeCard")
				
				self.UsedRuneAbility = true
			end
			
		end
		
		-- 적은 사용하지 않는 룬카드
	end

	@ExecSpace("Client")
	method void PlayEffect(string type, integer coins)
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		
		if type == "Coin" then
			_RuneCardDirector.RuneCardManagingValue["RC20021"][self.Entity.Id] = 1
			_RuneCardDirector:CheckRuneCardManagingValue("RC20021", runeindex)
			_RuneCardDirector:RuneCardCoinDirector(runeindex, coins)
		
		elseif type == "Init" then
			_RuneCardDirector.RuneCardManagingValue["RC20021"][self.Entity.Id] = 0
			_RuneCardDirector:CheckRuneCardManagingValue("RC20021", runeindex)
			
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(not self.UsedRuneAbility, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(boolean ability)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		if ability then
			_RuneCardDirector.RuneCardManagingValue["RC20021"][self.Entity.Id] = 0
		else
			_RuneCardDirector.RuneCardManagingValue["RC20021"][self.Entity.Id] = 1
		end
		
		_RuneCardDirector:CheckRuneCardManagingValue("RC20021", runeindex)
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = false
			self:PlayEffect("Init", 0, user.PlayerComponent.UserId)
		end
	end

end