@Component
script RC20035 extends RuneCardComponent

	property boolean checked = false

	property number SetDamagePercent = 25

	@ExecSpace("ServerOnly")
	method void DeadUnitHandler(any event)
		__base:DeadUnitHandler(event)
		
		-- 전투 시작 후, 처음 사망한 유닛이 아군이면 해당 유닛 주변 2칸 내 적에게 최대 체력의 25%만큼 고정피해를 입힙니다.
		------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		
		---@type Entity
		local target = event.Target
		local targetTile = event.DeadTile
		------------------------------------------------------------------
		-- 처음 사망한 유닛이 해당 룬카드의 팀인지 확인
		-- 오르비스 마법석 제외
		if self.checked and target.UnitInfo.charID ~= "C00003" then
			if self.SetTeamType == target.UnitInfo.TeamType then
				local checkEnemies = {}
				
				if self.SetTeamType == "User" then
					checkEnemies = _BTLogic_New:getEntities(teamManager.EnemyUnits, "AttackAble")
				else
					checkEnemies = _BTLogic_New:getEntities(teamManager.OwnUnits, "AttackAble")
				end
				
				local attackEnemies = _BTLogic_New:getTargets(targetTile, checkEnemies, "Around_1_2")
				
				local setTrueDamage = target.UnitStatus.MaxHP * self.SetDamagePercent / 100
				
				for _, unit in pairs(attackEnemies) do
					_StatusChangeLogic:SetVariableStatus(target, unit, "HP", -setTrueDamage, "rune")
					_CustomizedBattleEffectService:PlayDamageSkin(unit, "True", setTrueDamage, false, user.OwnerId)
				end
				local damageunits = _UtilLogic:TableToString(attackEnemies)
				self:PlayEffect(target, damageunits, user.PlayerComponent.UserId)
			end
			self.checked = false
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		self.checked = true
	end

	@ExecSpace("Client")
	method void PlayEffect(Entity unit, string damageunits)
		damageunits = _UtilLogic:StringToTable(damageunits)
		local map = _UserService.LocalPlayer.CurrentMap
		
		if #damageunits == 0 then return end
		
		for i = 1, #damageunits do
			local pos=damageunits[i].TransformComponent.WorldPosition:Clone()
			_EffectService:PlayEffect("c3de06f6c0584321a5cb7b8adc799f64", map, pos, 0, Vector3(0.5,0.5,1), false, {["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)})
		end
		
		_PlaySoundLogic:PlaySound("M0161")
		
		local stringValue = string.format("%d%%", self.SetDamagePercent)
		
		if unit.UnitInfo.TeamType == "User" then
			local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.DealingDamageRate}, {stringValue}, false)
		
		else
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.DealingDamageRate}, {stringValue}, true)
		end
		
		
	end

end