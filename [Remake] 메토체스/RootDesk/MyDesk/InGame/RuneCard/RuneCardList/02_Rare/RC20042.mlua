@Component
script RC20042 extends RuneCardComponent

	property number SetPercent = 15

	@ExecSpace("ServerOnly")
	method void BuyUnitHandler(any event)
		__base:BuyUnitHandler(event)
		
		-- 새로 구매하는 캐릭터들이 영구적으로 15%의 공격 속도를 획득합니다.
		-----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		
		---@type Entity
		local unit = event.Unit
		local units={}
		-----------------------------------------------------------------------
		if self.SetTeamType == unit.UnitInfo.TeamType then
			_StatusChangeLogic:SetStack(unit, "Multi_AttackSpeed", self.SetPercent)
			
			table.insert(units,unit)
			units=_UtilLogic:TableToString(units)
			self:PlayEffect(false, units, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 새로 구매하는 캐릭터들이 영구적으로 15%의 공격 속도를 획득합니다.
		-- 적에겐, 시작하는 시점에 15%의 공격 속도를 올려줍니다.
		-----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units={}
		-----------------------------------------------------------------------
		if self.SetTeamType == "Enemy" then
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:SetStack(unit, "Multi_AttackSpeed", self.SetPercent)
					table.insert(units,unit)
				end
			end
			
			units=_UtilLogic:TableToString(units)
			self:PlayEffect(true, units, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean Enemy, string unit)
		local stringValue = string.format("%d%%", self.SetPercent)
		
		unit = _UtilLogic:StringToTable(unit)
		
		if Enemy then
			--룬 카드 발동 연출
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Ready(index, _RuneCardDirectEnum.AttackSpeed, stringValue)
		else
			--룬 카드 발동 연출
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:IconToastDirector_Ready(index, _RuneCardDirectEnum.AttackSpeed, stringValue)
		end
	end

end