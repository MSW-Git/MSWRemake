@Component
script RC20009 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void LoseBattleHandler(any event)
		__base:LoseBattleHandler(event)
		
		-- 상대 유닛이 3기 이상 남은 상태로 전투에서 패배하면, 데미지를 입지 않습니다.
		-- 한 번 효과가 발동되면 해당 룬 카드는 파괴됩니다.
		------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		
		---@type number
		local enemyCount = event.surviveUnitCount
		------------------------------------------------------
		if self.SetTeamType == "User" and enemyCount >= 3  then
			if not self.Copied then
				self:PlayEffect(teamManager.HP, user.PlayerComponent.UserId)
				teamManager.HP += 1
				
				-- 룬 카드 삭제 필요
				specialShopManager:RemoveRuneCard("RC20009", self.UID)
				if isvalid(self.CopiedComponent) then
					specialShopManager:RemoveRuneCard("RC40003", self.UID)
				end
				
				-- 업적: 룬카드 [토푸]로 하트 차감 방어하기 
				_AchievementService:UpdateProgress_RuneCard("AC004006", 1, user)
				
			else
				-- 룬 카드 삭제 필요
				specialShopManager:RemoveRuneCard("RC20009", self.UID)
				if isvalid(self.CopiedComponent) then
					specialShopManager:RemoveRuneCard("RC40003", self.UID)
				end
			end
			
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(integer lifecount)
		-- 하트 방어 연출
		_TimerService:SetTimerOnce(function() _RuneCardDirector:RC20009Director(lifecount) end , 0.6)
	end

end