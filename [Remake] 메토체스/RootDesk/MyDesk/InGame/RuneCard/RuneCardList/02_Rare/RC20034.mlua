@Component
script RC20034 extends RuneCardComponent

	property number SetMinusSlotCount = 2

	property number SetMinusRerollCost = 1

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 상점 캐릭터 판매 칸이 2칸 줄어듭니다. 대신 새로고침 비용이 1코인 줄어듭니다. (새로고침 비용은 1코인 아래로 내려갈 수 없습니다.)
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		--------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Shop_UseCharSlotCount -= self.SetMinusSlotCount
			userPControl.Reroll_Cost -= self.SetMinusRerollCost
			self:PlayEffect(true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 상점 캐릭터 판매 칸이 2칸 줄어듭니다. 대신 새로고침 비용이 1코인 줄어듭니다. (새로고침 비용은 1코인 아래로 내려갈 수 없습니다.)
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		--------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Shop_UseCharSlotCount += self.SetMinusSlotCount
			userPControl.Reroll_Cost += self.SetMinusRerollCost
			self:PlayEffect(false, user.PlayerComponent.UserId)
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean buy)
		_RuneCardDirector.RuneCardManagingValue["RC20034"][self.Entity.Id] = buy
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:CheckRuneCardManagingValue("RC20034", index)
		
		if buy == false then
			_GeneralDirectorLogic:LockCharacterShopSlot(2, false)
		end
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				userPControl.Shop_UseCharSlotCount -= self.SetMinusSlotCount
				userPControl.Reroll_Cost -= self.SetMinusRerollCost
				self:PlayEffect(true,user.PlayerComponent.UserId)
			else
				-- 비활성화 시
				userPControl.Shop_UseCharSlotCount += self.SetMinusSlotCount
				userPControl.Reroll_Cost += self.SetMinusRerollCost
				self:PlayEffect(false,user.PlayerComponent.UserId)
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end