@Component
script RC20025 extends RuneCardComponent

	property number SetAmount = 100

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투에 배치한 1, 3, 5 단계 아군 캐릭터 하나당 모든 아군의 체력이 100 증가합니다.
		----------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		----------------------------------------------------------------------------
		---@type table<Entity>
		local checkUnits = {}
		local costCount = 0
		
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(checkUnits, unit)
					if unit.UnitInfo.cost%2 == 1 and unit.UnitInfo.cost > 0 then
						costCount += 1
					end
					table.insert(units, unit)
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(checkUnits, unit)
					if unit.UnitInfo.cost%2 == 1 and unit.UnitInfo.cost > 0 then
						costCount += 1
					end
					table.insert(enemy, unit)
				end
			end
		end
		
		for _, unit in pairs(checkUnits) do
			_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetAmount * costCount, -1)
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, costCount, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy, integer value)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		if value == 0 then return end
		
		--룬 카드 발동 연출
		if #units > 0 then
			local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.MaxHP}, {tostring(math.floor(self.SetAmount*value))}, false)
		end
		
		if #enemy>0 then
			local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.MaxHP}, {tostring(math.floor(self.SetAmount*value))}, true)
		end
	end

end