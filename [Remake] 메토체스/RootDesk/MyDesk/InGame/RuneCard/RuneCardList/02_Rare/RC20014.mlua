@Component
script RC20014 extends RuneCardComponent

	property number CheckedRerollCount = 0

	@ExecSpace("ServerOnly")
	method void BuyUnitHandler(any event)
		__base:BuyUnitHandler(event)
		
		-- 각 라운드마다 처음으로 얻는 3코스트 이하 유닛의 복사본을 얻습니다.
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local unit = event.Unit
		local charID = event.CharID
		--------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			if self.UsedRuneAbility and unit.UnitInfo.cost <= 3 then
				self.UsedRuneAbility = false
				_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
				self:PlayEffect(self.CheckedRerollCount, false, user.PlayerComponent.UserId)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 각 라운드마다 처음으로 얻는 3코스트 이하 유닛의 복사본을 얻습니다.
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = true
			self.CheckedRerollCount = 0
			self:PlayEffect(self.CheckedRerollCount, true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 각 라운드마다 처음으로 얻는 3코스트 이하 유닛의 복사본을 얻습니다.
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = true
			self:PlayEffect(self.CheckedRerollCount, true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void ReRollCharacterShopHandler(any event)
		__base:ReRollCharacterShopHandler(event)
		-- 한 라운드에 새로고침을 3번 할 경우, 이 효과는 무효화됩니다.
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		--------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self.CheckedRerollCount += 1
			
			if self.CheckedRerollCount >= 3 then
				self.UsedRuneAbility = false
			end
			
			self:PlayEffect(self.CheckedRerollCount, self.UsedRuneAbility, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(integer count, boolean ability)
		--발동 연출
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		self.UsedRuneAbility = ability
		if count > 3 or ability == false then
			count = 3
		end
		_RuneCardDirector.RuneCardManagingValue["RC20014"][self.Entity.Id] = count
		_RuneCardDirector:CheckRuneCardManagingValue("RC20014", index)
		
		if ability then
			_RuneCardDirector:ChangeShopCharacterValues()
		else
			_RuneCardDirector:RC20014Director(1,"stopnum")
		end 
		
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.UsedRuneAbility, self.CheckedRerollCount, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(boolean ability, integer count)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		if ability then
			if count > 3 then
				count = 3
			end
			_RuneCardDirector.RuneCardManagingValue["RC20014"][self.Entity.Id] = count
		else
			_RuneCardDirector.RuneCardManagingValue["RC20014"][self.Entity.Id] = 3
		end
		
		_RuneCardDirector:CheckRuneCardManagingValue("RC20014", runeindex)
		
		if ability then
			_RuneCardDirector:ChangeShopCharacterValues()
		end
	end

end