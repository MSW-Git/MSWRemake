@Component
script RC20068 extends RuneCardComponent

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 마가티아 시너지 효과
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		local stringValueTable = {"Zenumist", "Alcadno"}
		-- 1번 : '제뉴미스트'
		-- 2번 : '알카드노'
		if isvalid(synergyManager.SynergyRuneOn["S10032"]) and synergyManager.SynergyRuneOn["S10032"] > 0 then
			self.RuneStack = synergyManager.SynergyStack["S10032_Type"]
			log("이미 있음 : ", synergyManager.SynergyStack["S10032_Type"])
		else
			self.RuneStack = _UtilLogic:RandomIntegerRange(1,2)
			log("새로 입력 : ", self.RuneStack)
		end
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10032"] += 1
			synergyManager.SynergyStack["S10032_Type"] = self.RuneStack
		else
			synergyManager.Enemy_SynergyRuneOn["S10032"] += 1
			synergyManager.Enemy_SynergyStack["S10032_Type"] = self.RuneStack
		end
		
		self:SetStringTypeValue(stringValueTable[self.RuneStack])
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 마가티아 시너지 효과
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10032"] -= 1
			if synergyManager.SynergyRuneOn["S10032"] <= 0 then
				synergyManager.SynergyStack["S10032_Type"] = 0
			end
		else
			synergyManager.Enemy_SynergyRuneOn["S10032"] -= 1
			if synergyManager.Enemy_SynergyRuneOn["S10032"] <= 0 then
				synergyManager.Enemy_SynergyStack["S10032_Type"] = 0
			end
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		local synergyID = "S10032"
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				synergyManager.SynergyRuneOn[synergyID] += 1
			else
				-- 비활성화 시
				synergyManager.SynergyRuneOn[synergyID] -= 1
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end