@Component
script RC20039 extends RuneCardComponent

	property number CheckChangePercent = 5

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 준비 단계가 시작될 때, 대기석의 모든 캐릭터들은 같은 비용의 무작위 유닛으로 변경됩니다.
		-- 10% 확률로 비용이 1 높은 무작위 유닛으로 변경됩니다.
		---------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local charShopManager = user.CharacterShopManager_New
		---------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			local costOneCharCount = 0
			
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitInfo.setTileVerticalNum == 0 then
					local per = _UtilLogic:RandomDouble()
					local cost = unit.UnitInfo.cost
					local beforecost = unit.UnitInfo.cost -- 연출용 코드
					local level = unit.UnitInfo.level
					
					if per < 0.1 then
						cost = math.min(5, cost+1)
					end
					
					local charID = charShopManager:ChooseRandomCharacterFromSameCost(cost, "reroll")
					
					_TimerService:SetTimerOnce(function() unit.UnitInfo:ChangeCharInfo(charID, level, cost) end , 1.4)
					if cost == beforecost then
						self:PlayEffect(unit, 6, user.PlayerComponent.UserId)
					else
						self:PlayEffect(unit, cost, user.PlayerComponent.UserId)
					end
				end
			end
			
			local function mergeCheck()
				_UnitSetLogic_New:CheckUnitMerging(user.OwnerId)
			end
			
			_TimerService:SetTimerOnce(mergeCheck, 2)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(Entity Unit, integer Cost)
		_PlaySoundLogic:PlaySound("M0162")
		--유닛들의 터치리시브 컴포를 끕니다
		Unit.TouchReceiveComponent.Enable = false
		
		--룬 카드 발동 연출
		local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:ShakingCard_Ready(index)
		
		--룬 카드 효과 연출
		_RuneCardDirector:ChangeUnifEffect(Unit, Cost)
		
		--유닛들의 터치리시브 컴포를 킵니다
		_TimerService:SetTimerOnce(function() Unit.TouchReceiveComponent.Enable=true end , 1.4)
	end

end