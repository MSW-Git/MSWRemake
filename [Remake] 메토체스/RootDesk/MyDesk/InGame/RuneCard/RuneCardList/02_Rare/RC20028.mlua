@Component
script RC20028 extends RuneCardComponent

	property number SetAmount = 8

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투에 배치한 2, 4단계 아군 캐릭터 하나당 모든 아군의 공격력과 마력이 6 증가합니다.
		----------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		----------------------------------------------------------------------------
		---@type table<Entity>
		local checkUnits = {}
		local costCount = 0
		
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(checkUnits, unit)
					if unit.UnitInfo.cost%2 == 0 and unit.UnitInfo.cost > 0 then
						costCount += 1
					end
					table.insert(units, unit)
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					table.insert(checkUnits, unit)
					if unit.UnitInfo.cost%2 == 0 and unit.UnitInfo.cost > 0 then
						costCount += 1
					end
					table.insert(enemy, unit)
				end
			end
		end
		
		for _, unit in pairs(checkUnits) do
			_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAmount * costCount, -1)
			_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAmount * costCount, -1)
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, costCount, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy, integer values)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		if values == 0 then return end
		
		--룬 카드 발동 연출
		if #units > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.MagicalAttack, _RuneCardDirectEnum.PhysicalAttack}, {tostring(math.floor(self.SetAmount*values)), tostring(math.floor(self.SetAmount*values))}, false)
		end
		
		if #enemy > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,true)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.MagicalAttack, _RuneCardDirectEnum.PhysicalAttack}, {tostring(math.floor(self.SetAmount*values)), tostring(math.floor(self.SetAmount*values))}, true)
		end
	end

end