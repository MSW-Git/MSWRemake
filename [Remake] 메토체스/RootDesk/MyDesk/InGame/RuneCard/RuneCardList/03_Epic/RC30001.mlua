@Component
script RC30001 extends RuneCardComponent

	property boolean Checked = false

	property SyncTable<Entity, number> SkillUseCountTable

	property string CheckedCharID = ""

	property number SkillUseCount = 0

	property number NeedCount = 6

	@ExecSpace("ServerOnly")
	method void OnSkillUseHandler(any event)
		__base:OnSkillUseHandler(event)
		
		-- 매 전투 라운드마다 6번째로 스킬을 사용한 유닛을 체크합니다.
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local spriteRUID=""
		
		---@type Entity
		local attacker = event.Attacker
		-------------------------------------------------------------
		if self.SetTeamType == attacker.UnitInfo.TeamType and self.SetTeamType == "User" and attacker.UnitInfo.cost ~= 0 then
			if not self.Checked then
				self.SkillUseCount += 1
				
				if self.SkillUseCount >= self.NeedCount then
					self.Checked = true
					self.CheckedCharID = attacker.UnitInfo.charID
					self:PlayEffect(false, attacker, user.PlayerComponent.UserId)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 캐릭터를 복사하여 획득합니다.
		-------------------------------------------------
		local user = self.Entity.Parent.Parent
		-------------------------------------------------
		if self.SetTeamType == "User" then
			if self.Checked then
				_UnitSetLogic_New:SpawnUnit(user.OwnerId, self.CheckedCharID, 1, "Force")
				self:PlayEffect(true, nil, user.PlayerComponent.UserId)
		
				-- 업적: 룬카드 [기억하고 있는자]로 n번 복사하기 
				_AchievementService:UpdateProgress_RuneCard("AC004009",1,user)
					
			end
		end
		
		-- 스킬 체크 초기화
		self.Checked = false
		self.CheckedCharID = ""
		self.SkillUseCount = 0
		
		-- table.clear(self.SkillUseCountTable)
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean Init, Entity unit)
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		--룬 카드 발동 연출
		if Init == false then
			_RuneCardDirector:ShakingCard_Battle(index, false)
		else
			_RuneCardDirector:ShakingCard_Ready(index)
		end
		
		--특수연출/룬 카드 효과 연출
		local RUID = ""
		if isvalid(unit) then
			RUID = unit.UnitInfo.spriteRenderer.SpriteRendererComponent.SpriteRUID
		else
			RUID = "0129ee9aa3e74f7ebfa5e8275e04023e"
		end
		 _RuneCardDirector:RC30001Director(RUID, Init, index)
	end

end