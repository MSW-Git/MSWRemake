@Component
script RC30010 extends RuneCardComponent

	property number NeedCount = 7

	@ExecSpace("ServerOnly")
	method void EndRoundHandler(any event)
		__base:EndRoundHandler(event)
		
		-- 7번의 전투 후, 이 카드를 파괴하고 강력한 무작위 보상을 얻습니다.
		------------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local specialShopManager = user.SpecialShopManager
		------------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self:SetRuneStackInfo(self.RuneStack -1)
			
			if self.RuneStack <= 0 then
				-- 보상
				_TimerService:SetTimerOnce(function() self:GetReward() end , 1.5)
				local removecard=function()
					if not self.Copied then
						-- 룬 카드 삭제 필요
						specialShopManager:RemoveRuneCard("RC30010", self.UID)
					else
						specialShopManager:RemoveRuneCard("RC40003", self.UID)
					end
				end
				_TimerService:SetTimerOnce(removecard,2.2)
		
				-- 업적: 룬카드 [피그미]로 강력한 무작위 보상 얻기 
				_AchievementService:UpdateProgress_RuneCard("AC004010",1,user)
				
			else
				local value=self.RuneStack
				_TimerService:SetTimerOnce(function() self:PlayEffect("", 0, 0, value, false, user.PlayerComponent.UserId) end , 1.5)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void LoseBattleHandler(any event)
		__base:LoseBattleHandler(event)
		
		-- 전투에서 패배할 때마다 보상을 얻는 시점이 한 턴 가속됩니다.
		------------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local specialShopManager = user.SpecialShopManager
		------------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			self:SetRuneStackInfo(self.RuneStack -1)
			
			local value=self.RuneStack
			self:PlayEffect("", 0, 0, value,false,user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void GetReward()
		-- 확률에 따라 보상이 지급됩니다.
		------------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userId = user.OwnerId
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		local charShopManager = user.CharacterShopManager_New
		--연출용 변수들
		local itemlist = {}
		local golds = 0
		------------------------------------------------------------------------------
		-- (20%) 80골드 + 완성템 상자 1개
		-- (20%) 40골드 + 완성템 상자 5개
		-- (20%) 40골드 + 황금 보따리 2개 + 무작위 5등급 캐릭터 *4
		-- (20%) 25골드 + 수상한 초대장 6개
		-- (20%) 25골드 + 메달 상자 1개 + 완성템 상자 4개
		------------------------------------------------------------------------------
		local per = _UtilLogic:RandomIntegerRange(1, 100)
		------------------------------------------------------------------------------
		if per <= 20 then
			-- 80골드 + 완성 아이템 상자 1개
			teamManager:AddGolds(80, "runeCard")
			golds=80
			_ItemSetLogic:GetItemBox(userId, 4)
			table.insert(itemlist,"IB00004")
		------------------------------------------------
		elseif per <= 40 then
			-- 40골드 + 완성 아이템 상자 5개
			teamManager:AddGolds(40, "runeCard")
			golds=40
			for i = 1, 5 do
				_ItemSetLogic:GetItemBox(userId, 4)
				table.insert(itemlist,"IB00004")
			end
		------------------------------------------------
		elseif per <= 60 then
			-- 40골드 + 황금 보따리 2개 + 무작위 5등급 캐릭터 4명
			teamManager:AddGolds(40, "runeCard")
			golds=40
			for i = 1, 4 do
				if i <= 2 then
					_ItemSetLogic:GetConsumableItem(userId, 5)
					table.insert(itemlist,"CI0005")
				end
				
				local charId = charShopManager:ChooseRandomCharacterFromSameCost(5, "Add3Level")
				_UnitSetLogic_New:SpawnUnit(userId, charId, 1, "Force")
			end
		------------------------------------------------
		elseif per <= 80 then
			-- 25골드 + 수상한 초대장 6개
			teamManager:AddGolds(25, "runeCard")
			golds=25
			for i = 1, 6 do
				_ItemSetLogic:GetConsumableItem(userId, 8)
				table.insert(itemlist,"CI0008")
			end
		------------------------------------------------
		else
			-- 25골드 + 메달 상자 1개 + 완성 아이템 상자 4개
			teamManager:AddGolds(25, "runeCard")
			golds=25
			_ItemSetLogic:GetItemBox(userId, 14)
			table.insert(itemlist,"IB00014")
			for i = 1 ,4 do
				_ItemSetLogic:GetItemBox(userId, 4)
				table.insert(itemlist,"IB00004")
			end
		end
		------------------------------------------------
		local items = #user.TeamManager.OwnItems
		itemlist = _UtilLogic:TableToString(itemlist)
		self:PlayEffect(itemlist, items, golds, self.RuneStack, true, user.PlayerComponent.UserId)
		
	end

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		self:SetRuneStackInfo(self.NeedCount)
	end

	@ExecSpace("Client")
	method void PlayEffect(string itemlist, integer items, integer Golds, integer stackvalue, boolean Reward)
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		itemlist = _UtilLogic:StringToTable(itemlist)
		stackvalue = math.abs(stackvalue-self.NeedCount)
		
		if stackvalue >= 0 and stackvalue < self.NeedCount then
			--스택될 때
			_RuneCardDirector:ShakingCard_Ready(index)
			_RuneCardDirector:IconToastDirector_Ready(index, 0, "+1")
				
			_RuneCardDirector.RuneCardManagingValue["RC30010"][self.Entity.Id]=stackvalue / _RuneCardDirector.RuneCardMaxStack["RC30010"]
			_RuneCardDirector:CheckRuneCardManagingValue("RC30010", index)
		elseif stackvalue >= _RuneCardDirector.RuneCardMaxStack["RC30010"] then
			--보상 획득할 때
			if Reward then
				_RuneCardDirector:DestroyRuneCard(index, false)
				local rewarddirector = function()
					_RuneCardDirector:RuneCardCoinDirector(index, Golds)
					for i = #itemlist, 1, -1 do
						_RuneCardDirector:RuneCardItemDirector_Ready(items,"RC30010", itemlist[i], index)
						items -= 1
					end
					_RuneCardDirector.RuneCardManagingValue["RC30010"][self.Entity.Id] = 0
					_RuneCardDirector:CheckRuneCardManagingValue("RC30010", index)
				end
				_TimerService:SetTimerOnce(rewarddirector, 0.5)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector.RuneCardManagingValue["RC30010"][self.Entity.Id] = stack / _RuneCardDirector.RuneCardMaxStack["RC30010"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC30010", runeindex)
	end

end