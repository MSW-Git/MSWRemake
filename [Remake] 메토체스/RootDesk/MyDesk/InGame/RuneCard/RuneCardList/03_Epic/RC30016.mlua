@Component
script RC30016 extends RuneCardComponent

	property number SetPercent = 30

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시, 전장에 동일한 캐릭터가 셋 이상 있다면 모든 아군이 30%의 최대 체력을 추가로 얻습니다.
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		------------------------------------------------------------
		local idCountCheckTable = {}
		
		if self.SetTeamType == "User" then
			-- 셋 이상 있는지 체크
			local checked = false
			
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					local charID = unit.UnitInfo.charID
					if not isvalid(idCountCheckTable[charID]) then
						idCountCheckTable[charID] = 1
					else
						idCountCheckTable[charID] += 1
						if idCountCheckTable[charID] >= 3 then
							checked = true
							break
						end
					end
				end
			end
			
			if checked then
				for _, unit in pairs(teamManager.OwnUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:GetBuff(unit, "Multi_MaxHP", self.SetPercent, -1)
						table.insert(units, unit)
					end
				end
				units = _UtilLogic:TableToString(units)
				enemy = _UtilLogic:TableToString(enemy)
				self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
			end
		else
			-- 셋 이상 있는지 체크
			local checked = false
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					local charID = unit.UnitInfo.charID
					if not isvalid(idCountCheckTable[charID]) then
						idCountCheckTable[charID] = 1
					else
						idCountCheckTable[charID] += 1
						if idCountCheckTable[charID] >= 3 then
							checked = true
							break
						end
					end
				end
			end
			
			if checked then
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:GetBuff(unit, "Multi_MaxHP", self.SetPercent, -1)
						table.insert(enemy, unit)
					end
				end
				units = _UtilLogic:TableToString(units)
				enemy = _UtilLogic:TableToString(enemy)
				self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		local stringValue = string.format("%d%%", self.SetPercent)
		
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MaxHP}, {stringValue}, false)
		end
		
		if #enemy > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MaxHP}, {stringValue}, true)
		end
		
		
	end

end