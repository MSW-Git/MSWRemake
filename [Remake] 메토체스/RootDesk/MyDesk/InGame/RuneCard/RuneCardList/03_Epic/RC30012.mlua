@Component
script RC30012 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void SetBattleHandler(any event)
		__base:SetBattleHandler(event)
		
		-- 전투 시작 시, 무작위 아군 유닛 하나를 복사해 전투에 참여시킵니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------------
		-- 오르비스 마법석, 도도, 예티와 페페 등 특수 몬스터만 복제하지 않도록 예외처리
		-- unit.UnitInfo.cost ~= 0
		----------------------------------------------------------------
		local battleUnits = {}
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitInfo:IsOnFieldUnit() and unit.UnitInfo.cost ~= 0 then
					table.insert(battleUnits, unit)
				end
			end
			self:PlayEffect(false,user.PlayerComponent.UserId)
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitInfo:IsOnFieldUnit() and unit.UnitInfo.cost ~= 0 then
					table.insert(battleUnits, unit)
				end
			end
			self:PlayEffect(true,user.PlayerComponent.UserId)
		end
		
		if #battleUnits > 0 then
			-- 유닛 소환
			
			---@type Entity
			local copyUnit = battleUnits[_UtilLogic:RandomIntegerRange(1, #battleUnits)]
			local copyUnitInfo = copyUnit.UnitInfo
			local copyUnitStatus = copyUnit.UnitStatus
			local setTileInfo = _BTLogic_New:getTile(copyUnit, nil, "EmptyTileNearestToTheUnit_Team")
			
			local spawnUnit = _UnitSetLogic_New:SpawnOnetimeUnit(user.OwnerId, copyUnitInfo.charID, setTileInfo[1], copyUnitInfo.level, copyUnitInfo.TeamType, true)
			
			
			-- 아이템 장착
			if #copyUnitStatus.EquippedItemIDList > 0 then
				for _, itemID in pairs(copyUnitStatus.EquippedItemIDList) do
					_ItemSetLogic:EquipItemThroughItemID(spawnUnit, itemID .. "_copied")
				end
			end
			
			-- 업적: 룬카드 [프란시스]로 3성 유닛 복사하기 
			if self.SetTeamType == "User" and copyUnitInfo.level == 3 then
				_AchievementService:UpdateProgress_RuneCard("AC004011", 1, user)
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		------------------------------------------------------------
		
		--룬 카드 발동 연출
		if enemy == false then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
		end
		
		if enemy then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
		end
		
	end

end