@Component
script RC30017 extends RuneCardComponent

	property boolean ItemGetCheck = false

	property table itemindex = {}

	property number NeedCount = 30

	@ExecSpace("ServerOnly")
	method void OnSkillUseHandler(any event)
		__base:OnSkillUseHandler(event)
		
		-- 아군이 스킬을 30번 사용할 때마다, 무작위 조합 아이템을 획득합니다.
		--------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		
		---@type Entity
		local attacker = event.Attacker
		local items = 0
		local itemID = ""
		--------------------------------------------------------------------------
		if self.SetTeamType == "User" and attacker.UnitInfo.TeamType == "User" then
			self:SetRuneStackInfo(self.RuneStack + 1)
			
			if self.RuneStack >= self.NeedCount then
				self:SetRuneStackInfo(self.RuneStack - self.NeedCount)
				_ItemSetLogic:GetMaterialItem(user.OwnerId, 0)
				items=#user.TeamManager.OwnItems
				itemID=user.TeamManager.OwnItems[items]
				self.ItemGetCheck=true
				
				--업적: 룬카드 [윈스턴]으로 조합 아이템 {0}개 획득하기
				_AchievementService:UpdateProgress_RuneCard("AC004012", 1, user)
			end
			
			local value = self.RuneStack
			self:PlayEffect(value, items, true, itemID, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(integer Stack, integer items, boolean InBattle, string ItemID)
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		----------------------------------------------------------------
		--발동 연출 없음
			
		--특수 연출
		
		_RuneCardDirector.RuneCardManagingValue["RC30017"][self.Entity.Id] = Stack / _RuneCardDirector.RuneCardMaxStack["RC30017"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC30017", index)
		if Stack == 0 then
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:RuneCardItemDirector_Battle(ItemID, index)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector.RuneCardManagingValue["RC30017"][self.Entity.Id] = stack / _RuneCardDirector.RuneCardMaxStack["RC30017"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC30017", runeindex)
	end

end