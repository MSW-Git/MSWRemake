@Component
script RC40001 extends RuneCardComponent

	property number SetAddAttackRangeAmount = 2

	property number SetAddDealingDamagePercent = 50

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 사거리가 5 이상인 아군 유닛의 가해량이 100% 증가합니다.
		-----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		-----------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitStatus.AttackRange >= 5 then
						_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", self.SetAddDealingDamagePercent, -1)
						table.insert(units, unit)
					end
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitStatus.AttackRange >= 5 then
						_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", self.SetAddDealingDamagePercent, -1)
						table.insert(enemy, unit)
					end
				end
			end
		end
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void SetBattleHandler(any event)
		__base:SetBattleHandler(event)
		
		-- 전투 시작 시, 모든 아군의 공격 사거리가 2 증가합니다.
		-----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		-----------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitInfo:IsOnFieldUnit() then
					_StatusChangeLogic:GetBuff(unit, "Add_AttackRange", self.SetAddAttackRangeAmount, -1)
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitInfo:IsOnFieldUnit() then
					_StatusChangeLogic:GetBuff(unit, "Add_AttackRange", self.SetAddAttackRangeAmount, -1)
				end
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		_PlaySoundLogic:PlaySound("M0163")
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.DealingDamageRate}, {"100%"}, false)
		end
		
		if #enemy > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.DealingDamageRate}, {"100%"}, true)
		end
		
		--룬 카드 효과 연출
		for i = 1, #units do
			_RuneCardDirector:RC40001Director(units[i])
		end
		
		for i = 1, #enemy do
			_RuneCardDirector:RC40001Director(enemy[i])
		end
	end

end