@Component
script RC40003 extends RuneCardComponent

	property string CopyRuneID = ""

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 오른쪽 룬 카드를 복제합니다.
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			for runeIdx, runeIDs in pairs(teamManager.OwnRunes) do
				local checkRuneID = _UtilLogic:Split(runeIDs, "_")[1]
				if checkRuneID == "RC40003" then
					if isvalid(teamManager.OwnRunes[runeIdx + 1]) then
						self.CopyRuneID = _UtilLogic:Split(teamManager.OwnRunes[runeIdx + 1], "_")[1]
					end
					break
				end
			end
		else
			for runeIdx, checkRuneID in pairs(teamManager.EnemyOwnedRunes) do
				if checkRuneID == "RC40003" then
					if isvalid(teamManager.EnemyOwnedRunes[runeIdx + 1]) then
						self.CopyRuneID = teamManager.EnemyOwnedRunes[runeIdx + 1]
					end
					break
				end
			end
		end
		
		if self.CopyRuneID ~= "" then
			self:CopiedComponent(false)
		end
	end

	@ExecSpace("ServerOnly")
	method void ChangeRuneCardOrderHandler(any event)
		__base:ChangeRuneCardOrderHandler(event)
		
		-- 오른쪽 룬 카드를 복제합니다.
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local beforeID = self.CopyRuneID
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			for runeIdx, runeIDs in pairs(teamManager.OwnRunes) do
				local runeID = _UtilLogic:Split(runeIDs, "_")[1]
				if runeID == "RC40003" then
					if isvalid(teamManager.OwnRunes[runeIdx + 1]) then
						self.CopyRuneID = _UtilLogic:Split(teamManager.OwnRunes[runeIdx + 1], "_")[1]
					else
						self.CopyRuneID = ""
					end
					break
				end
			end
		else
			for runeIdx, runeID in pairs(teamManager.EnemyOwnedRunes) do
				if runeID == "RC40003" then
					if isvalid(teamManager.EnemyOwnedRunes[runeIdx + 1]) then
						self.CopyRuneID = teamManager.EnemyOwnedRunes[runeIdx + 1]
					else
						self.CopyRuneID = ""
					end
					break
				end
			end
		end
		
		if beforeID ~= self.CopyRuneID then
			if beforeID ~= "" then
				---@type RuneCardComponent
				local removeComponent = self.Entity:GetComponent(beforeID)
				removeComponent:SellThisRuneCard(beforeID)
				
				if beforeID =="RC20014" then
					_RuneCardDirector:InitRuneCardManagingValue("RC20014", self.Entity.Id, user.PlayerComponent.UserId)
					_RuneCardDirector:ChangeShopCharacterValues(user.PlayerComponent.UserId)
				end
			end
			if self.CopyRuneID ~= "" then
				self:CopiedComponent(false)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void BuyRuneCardHandler(any event)
		__base:BuyRuneCardHandler(event)
		
		-- 오른쪽 룬 카드를 복제합니다.
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local beforeID = self.CopyRuneID
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			for runeIdx, runeIDs in pairs(teamManager.OwnRunes) do
				local runeID = _UtilLogic:Split(runeIDs, "_")[1]
				if runeID == "RC40003" then
					if isvalid(teamManager.OwnRunes[runeIdx + 1]) then
						self.CopyRuneID = _UtilLogic:Split(teamManager.OwnRunes[runeIdx + 1], "_")[1]
					else
						self.CopyRuneID = ""
					end
					break
				end
			end
		else
			for runeIdx, runeID in pairs(teamManager.EnemyOwnedRunes) do
				if runeID == "RC40003" then
					if isvalid(teamManager.EnemyOwnedRunes[runeIdx + 1]) then
						self.CopyRuneID = teamManager.EnemyOwnedRunes[runeIdx + 1]
					else
						self.CopyRuneID = ""
					end
					break
				end
			end
		end
		
		if beforeID ~= self.CopyRuneID then
			log(beforeID, self.CopyRuneID)
			if beforeID ~= "" then
				---@type RuneCardComponent
				local removeComponent = self.Entity:GetComponent(beforeID)
				removeComponent:SellThisRuneCard(beforeID)
			end
			if self.CopyRuneID ~= "" then
				self:CopiedComponent(false)
			end
		end
	end

