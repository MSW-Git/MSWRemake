	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 삭제하기 전, 복제한 컴포넌트를 삭제합니다.
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.CopyRuneID ~= "" then
			---@type RuneCardComponent
			local removeComponent = self.Entity:GetComponent(self.CopyRuneID)
			removeComponent:SellThisRuneCard(self.CopyRuneID)
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void CopiedComponent(boolean checkLoad)
		-- 룬카드 복제할 때, 기존 룬카드 컴포넌트 가져와서 프로퍼티 체크 필요한지 확인
		-------------------------------------------------------------------------------------
		---@type RuneCardComponent
		local checkedCompo = nil
		for _, RuneEntity in pairs(self.Entity.Parent.Children) do
			checkedCompo = RuneEntity:GetComponent(self.CopyRuneID)
			if isvalid(checkedCompo) then
				break
			end
		end
		local user = self.Entity.Parent.Parent
		-------------------------------------------------------------------------------------
		---@type RuneCardComponent
		local setComponent = self.Entity:AddComponent(self.CopyRuneID)
		setComponent:SetCopiedProperty(true)
		setComponent.RC40003_Component = self
		
		if isvalid(checkedCompo) then
			setComponent.CopiedComponent = checkedCompo
			checkedCompo.CopiedComponent = setComponent
		end
		
		if checkLoad then
			setComponent.SetTeamType = self.SetTeamType
			setComponent:InGameDataLoadHandler(nil)
		else
			setComponent:BuyThisRuneCard(self.CopyRuneID)
		end
		
		
		if isvalid(checkedCompo) then
			setComponent.UsedRuneAbility =  checkedCompo.UsedRuneAbility
			setComponent.RuneStack = checkedCompo.RuneStack
		end
		
		if self.CopyRuneID == "RC20008"then
			---@type RC20008
			local setComponent2 = setComponent
			local checkSynergyID = setComponent2.checkSynergyID 
			self:Set20008Value(checkSynergyID, user.PlayerComponent.UserId)
		else
			self:SetDirectorValue(setComponent.RuneStack, self.CopyRuneID,setComponent.UsedRuneAbility, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Client")
	method void SetDirectorValue(integer values, string ID, boolean IsAblility)
		if isvalid(_RuneCardDirector.RuneCardManagingValue[ID]) then
			if ID == "RC10010" or ID == "RC20014" or ID == "RC20034" then
				_RuneCardDirector.RuneCardManagingValue[ID][self.Entity.Id] = IsAblility
			else
				if isvalid(_RuneCardDirector.RuneCardMaxStack[ID]) then
					_RuneCardDirector.RuneCardManagingValue[ID][self.Entity.Id] = values / _RuneCardDirector.RuneCardMaxStack[ID]
				else
					_RuneCardDirector.RuneCardManagingValue[ID][self.Entity.Id] = values
				end
			end
		end
	end

	@ExecSpace("Client")
	method void Set20008Value(string ID)
		local synergyTable = _DataService:GetTable("SynergyInfo")
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector.RuneCardManagingValue["RC20008"][self.Entity.Id] = synergyTable:FindRow("SynergyID", ID):GetItem("IconRUID")
		_RuneCardDirector:RC20008Director(index, false)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local active = event.active
		local teamManager = user.TeamManager
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				for runeIdx, runeID in pairs(teamManager.OwnRunes) do
					if runeID == "RC40003" then
						if isvalid(teamManager.OwnRunes[runeIdx + 1]) then
							self.CopyRuneID = teamManager.OwnRunes[runeIdx + 1]
						end
						break
					end
				end
			else
				-- 비활성화 시
				if self.CopyRuneID ~= "" then
					---@type RuneCardComponent
					local removeComponent = self.Entity:GetComponent(self.CopyRuneID)
					removeComponent:SellThisRuneCard(self.CopyRuneID)
				end
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		-- 오른쪽 룬 카드를 복제합니다.
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			for runeIdx, runeIDs in pairs(teamManager.OwnRunes) do
				local runeID = _UtilLogic:Split(runeIDs, "_")[1]
				if runeID == "RC40003" then
					if isvalid(teamManager.OwnRunes[runeIdx + 1]) then
						self.CopyRuneID = _UtilLogic:Split(teamManager.OwnRunes[runeIdx + 1], "_")[1]
					end
					break
				end
			end
		else
			for runeIdx, runeID in pairs(teamManager.EnemyOwnedRunes) do
				if runeID == "RC40003" then
					if isvalid(teamManager.EnemyOwnedRunes[runeIdx + 1]) then
						self.CopyRuneID = teamManager.EnemyOwnedRunes[runeIdx + 1]
					end
					break
				end
			end
		end
		
		if self.CopyRuneID ~= "" then
			self:CopiedComponent(true)
		end
		
		__base:InGameDataLoadHandler(event)
	end

end