@Logic
script SampleClientSpawnLogic extends Logic

	@ExecSpace("ServerOnly")
	method void SpawnUnitSample(string userId, string calledBy)
		-- 유닛으로 사용할 엔티티 샘플을 미리 스폰해두는 함수입니다.
		-- 유저당 자신의 유닛으로 사용할 30 유닛, 적의 유닛으로 사용할 20 유닛이 스폰됩니다.
		------------------------------------------------------------
		-- 이미 소환되어 있는 경우, 재소환 없이 유닛 초기화
		local user = _UserService:GetUserEntityByUserId(userId)
		local unitsSample = user.CurrentMap:GetChildByName("UnitsSample")
		------------------------------------------------------------
		if not isvalid(_UnitSetLogic_New.UnitsParentEntity[userId]) then
			_UnitSetLogic_New:SetUnitsParentEntity(userId, unitsSample:Clone("Units_" .. userId))
		else
			_UnitSetLogic_New:SetUnitsParentEntityInClient(userId, _UnitSetLogic_New.UnitsParentEntity[userId], userId)
		end
		
		local units = _UnitSetLogic_New.UnitsParentEntity[userId]
		
		local unitSetCount = 0
		local unitSetTimer = 0
		local function unitSampleSpawnFnc()
			unitSetCount += 1
			
			if isvalid(user) == false then
				_TimerService:ClearTimer(unitSetTimer)
			end
			
			-- 기본 아군 유닛
			if unitSetCount <= 30 then
				local bName = string.format("BTUnit_%d", unitSetCount)
				local bUnit = units:GetChildByName(bName)
				if not isvalid(bUnit) then
					bUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", bName, Vector3(999,999,0), units)
				end
				if calledBy == "start" then
					self:SpawnUnitChildren(bUnit, userId)
				end
				bUnit.UnitBattleStatistics:PropertyClear()
				bUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
				bUnit.UnitInfo:SetPropertyToServer("TeamType", "User", nil, true)
				bUnit.UnitInfo:CleanCharInfo()
			-- [시간의 신전] 시너지 : 도도
			elseif unitSetCount <= 31 then
				local bUnit = units:GetChildByName("BTUnit_DoDo")
				if not isvalid(bUnit) then
					bUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", "BTUnit_DoDo", Vector3(999,999,0), units)
				end
				if calledBy == "start" then
					self:SpawnUnitChildren(bUnit, userId)
				end
				bUnit.UnitBattleStatistics:PropertyClear()
				bUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
				bUnit.UnitInfo:SetPropertyToServer("TeamType", "User", nil, true)
				bUnit.UnitInfo.IsResellable = false
				bUnit.UnitInfo.IsMergableUnit = false
				bUnit.UnitInfo:SetPropertyToServer("IsItemEquippable", false, "", true)	-- 아이템 장착 가능 여부
				bUnit.UnitInfo.IsMovableByPlayer = false
				bUnit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", false, "", true)
				bUnit.UnitInfo.IsAppliableSynergy = false
				bUnit.UnitInfo:CleanCharInfo()
			-- 적 유닛
			elseif unitSetCount <= 51 then
				local eName = string.format("EnemyUnit_%d", unitSetCount - 31)
				local eUnit = units:GetChildByName(eName)
				if not isvalid(eUnit) then
					eUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", eName, Vector3(999,999,0), units)
				end
				if calledBy == "start" then
					self:SpawnUnitChildren(eUnit, userId)
				end
				eUnit.UnitBattleStatistics:PropertyClear()
				eUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
				eUnit.UnitInfo:SetPropertyToServer("TeamType", "Enemy", nil, true)
				eUnit.UnitInfo:CleanCharInfo()
			-- [시간의 신전] 시너지 : 도도 (적)
			elseif unitSetCount <= 52 then
				local eUnit = units:GetChildByName("EnemyUnit_DoDo")
				if not isvalid(eUnit) then
					eUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", "EnemyUnit_DoDo", Vector3(999,999,0), units)
				end
				if calledBy == "start" then
					self:SpawnUnitChildren(eUnit, userId)
				end
				eUnit.UnitBattleStatistics:PropertyClear()
				eUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
				eUnit.UnitInfo:SetPropertyToServer("TeamType", "Enemy", nil, true)
				eUnit.UnitInfo.IsResellable = false
				eUnit.UnitInfo.IsMergableUnit = false
				eUnit.UnitInfo:SetPropertyToServer("IsItemEquippable", false, "", true)	-- 아이템 장착 가능 여부
				eUnit.UnitInfo.IsMovableByPlayer = false
				eUnit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", false, "", true)
				eUnit.UnitInfo.IsAppliableSynergy = false
				eUnit.UnitInfo:CleanCharInfo()
			-- [그림자] 시너지
			elseif unitSetCount <= 53 then
				for i=1, 2 do
					local bName = string.format("BTUnit_Shadow%d",i)
					local bUnit = units:GetChildByName(bName)
					if not isvalid(bUnit) then
						bUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", bName, Vector3(999,999,0), units)
					end
					if calledBy == "start" then
						self:SpawnUnitChildren(bUnit, userId)
					end
					bUnit.UnitBattleStatistics:PropertyClear()
					bUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
					bUnit.UnitInfo:SetPropertyToServer("TeamType", "User", nil, true)
					bUnit.UnitAnimationComponent:SetDefaultColor(Color.black, userId)
					bUnit.UnitInfo.IsResellable = false
					bUnit.UnitInfo.IsMergableUnit = false
					bUnit.UnitInfo:SetPropertyToServer("IsItemEquippable", false, "", true)	-- 아이템 장착 가능 여부
					bUnit.UnitInfo.IsMovableByPlayer = true
					bUnit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", false, "", true)
					bUnit.UnitInfo.IsAppliableSynergy = true
					bUnit.UnitInfo:CleanCharInfo()
					bUnit.UnitSynergy.SynergyStack["S10007"] = 50
				end
			-- [그림자] 시너지 - 적
			elseif unitSetCount <= 54 then
				for i=1, 2 do
					local eName = string.format("EnemyUnit_Shadow%d",i)
					local eUnit = units:GetChildByName(eName)
					if not isvalid(eUnit) then
						eUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", eName, Vector3(999,999,0), units)
					end
					if calledBy == "start" then
						self:SpawnUnitChildren(eUnit, userId)
					end
					eUnit.UnitBattleStatistics:PropertyClear()
					eUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
					eUnit.UnitInfo:SetPropertyToServer("TeamType", "Enemy", nil, true)
					eUnit.UnitAnimationComponent:SetDefaultColor(Color.black, userId)
					eUnit.UnitInfo:CleanCharInfo()
					eUnit.UnitSynergy.SynergyStack["S10007"] = 50
				end
			-- [오르비스] 시너지
			elseif unitSetCount <= 55 then
				for i=1, 3 do
					local bName = string.format("BTUnit_OrbisStone%d",i)
					local bUnit = units:GetChildByName(bName)
					if not isvalid(bUnit) then
						bUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", bName, Vector3(999,999,0), units)
					end
					if calledBy == "start" then
						self:SpawnUnitChildren(bUnit, userId)
					end
					bUnit.UnitBattleStatistics:PropertyClear()	
					bUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
					bUnit.UnitInfo:SetPropertyToServer("TeamType", "User", nil, true)
					bUnit.UnitInfo.IsResellable = false
					bUnit.UnitInfo.IsMergableUnit = false
					bUnit.UnitInfo:SetPropertyToServer("IsItemEquippable", false, "", true)	-- 아이템 장착 가능 여부
					bUnit.UnitInfo.IsMovableByPlayer = true
					bUnit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", false, "", true)
					bUnit.UnitInfo.IsAppliableSynergy = false
					bUnit.UnitInfo:CleanCharInfo()
				end
			-- [오르비스] 시너지 - 적
			elseif unitSetCount <= 56 then
				for i=1, 3 do
					local eName = string.format("EnemyUnit_OrbisStone%d",i)
					local eUnit = units:GetChildByName(eName)
					if not isvalid(eUnit) then
						eUnit = _SpawnService:SpawnByModelId("model://ab1e4f74-1b50-4da4-8bf8-45d297894887", eName, Vector3(999,999,0), units)
					end
					if calledBy == "start" then
						self:SpawnUnitChildren(eUnit, userId)
					end
					eUnit.UnitBattleStatistics:PropertyClear()
					eUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
					eUnit.UnitInfo:SetPropertyToServer("TeamType", "Enemy", nil, true)
					eUnit.UnitInfo:CleanCharInfo()
				end
			else
				if isvalid(_UserService:GetUserEntityByUserId(userId)) then
					_UserService:GetUserEntityByUserId(userId).LoadingManager.LoadedCount["UnitSampleSpawn"] = 1
				end
				_TimerService:ClearTimer(unitSetTimer)
			end
			
		end
		unitSetTimer = _TimerService:SetTimerRepeat(unitSampleSpawnFnc, 0.15, 0)
		
	end

	@ExecSpace("Client")
	method void SpawnUnitChildren(Entity unit)
		-- 유닛에 필요한 자식 컴포넌트들을 생성하는 함수
		_SpawnService:SpawnByModelId("model://7f6de017-ea1a-4f26-a9d2-5fef345a5b97", "InfoTile", Vector3(0,0,1000), unit)
		_SpawnService:SpawnByModelId("model://256f6314-d350-47da-932b-16b0900069b0", "OverTile", Vector3(0,0,1000), unit)
		_SpawnService:SpawnByModelId("model://17f591d0-0b8e-4ce1-be4f-bafc286b47c4", "Shadow", Vector3(0,0,0), unit)
		-- _SpawnService:SpawnByModelId("model://6fc80012-0752-456f-96ed-8b8b1e56a5a3", "SpriteRenderer", Vector3(0,0,0), unit)
		_SpawnService:SpawnByModelId("model://5d07463e-9ad1-40ad-ba0d-bb55f2755678", "StatInfo", Vector3(0,0.65,1000), unit)
		_SpawnService:SpawnByModelId("model://2b95ad07-af32-4885-bb7e-ad6ba8925d93", "StatusEffects", Vector3(0,0,0), unit)
		unit.UnitAnimationComponent:SetStatusEffectLayerOrder()
		_SpawnService:SpawnByModelId("model://7e5b2022-47e2-4a48-8c85-37304f9d95b1", "SynergyTile", Vector3(0,0,0), unit)
	end

end