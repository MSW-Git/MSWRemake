	@ExecSpace("Client")
	method void InitOrbistile()
		-- 오르비스 타일 효과를 초기화하고 모든 타일의 오르비스 효과를 비활성화
		--[[local orbistile = self.Tile10021 -- 오르비스 타일
		for k, v in pairs (orbistile) do
			self:Set10021TilesEffect(k, nil)
		end]]--
		table.clear(self.Tile10021)
		
		for i = 1, 7 do --전장
			local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
			for j = 1, 9 do
				if isvalid(tilegroup:GetChildByName("Tile_"..tostring(j))) then
					local tileentity = tilegroup:GetChildByName("Tile_"..tostring(j))
					tileentity:GetChildByName("Orbis").SpriteRendererComponent.Color.a = 0.5
					tileentity:GetChildByName("Orbis").Enable = false
				end
			end
		end
	end

	@ExecSpace("Client")
	method void S10031Direction(integer count, boolean User)
		-- 동화 시너지 연출을 처리하며 캐릭터별로 다른 동화책 이펙트를 재생
		--사운드
		_PlaySoundLogic:PlaySound("M0213")
		_TimerService:SetTimerOnce(function() _PlaySoundLogic:PlaySound("M0214") end , 0.5)
		
		--이펙트
		self:PlayEffect("S10031", self.RUIDList["S10031"][1], User)
		self:PlayEffect("S10031", self.RUIDList["S10031"][2], User)
		self:PlayEffect("S10031", self.RUIDList["S10031"][3], User)
		
		-- 어떤 캐릭터냐에 따라 마지막 동화책 리소스는 달라짐
		local onfieldunits = self:GetOnFieldUnit("S10031", User)
		local ruidlist = _UtilLogic:Split(self.RUIDList["S10031"][4],",")
		
		for i = 1, #onfieldunits do
			if onfieldunits[i].UnitInfo.charID == "C10014" then -- 월묘
				
				self:PlayEffect_Solo("S10031", ruidlist[1], onfieldunits[i], User)
				goto skip
			end
			
			if onfieldunits[i].UnitInfo.charID == "C10015" or onfieldunits[1].UnitInfo.charID == "C30014" then -- 호돌이, 호걸
		
				self:PlayEffect_Solo("S10031", ruidlist[3], onfieldunits[i], User)
				goto skip
			end
			
			if onfieldunits[i].UnitInfo.charID == "C20014" then -- 깨비
		
				self:PlayEffect_Solo("S10031", ruidlist[2], onfieldunits[i], User)
				goto skip
			end
			
			if onfieldunits[i].UnitInfo.charID == "C40014" or onfieldunits[1].UnitInfo.charID == "C50009" then -- 구미호, 도깨비
		
				self:PlayEffect_Solo("S10031", ruidlist[4], onfieldunits[i], User)
				goto skip
			end
			
			if onfieldunits[i].UnitInfo.charID == "C20015" then -- 삼미호
		
				self:PlayEffect_Solo("S10031", ruidlist[5], onfieldunits[i], User)
				goto skip
			end
			
			-- 상징
			self:PlayEffect_Solo("S10031", ruidlist[6], onfieldunits[i], User)
			
			::skip::
		end
		
	end

	@ExecSpace("Client")
	method void PlayEffect_Solo(string SynergyID, string RUID, Entity Unit, boolean User)
		-- 특정 유닛에게만 개별적으로 이펙트를 재생 (동화 시너지 전용)
		--지정한 엔터티한테만 연출재생
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		local enemyunits = _UserService.LocalPlayer.TeamManager.EnemyUnits
		local effecttable = {}
		
		if not isvalid(self.RUIDInfo[RUID]) then
			return
		end
		
		local playeffect = function()
			--센터피봇사용여부 확인
			local stringposx = self.RUIDInfo[RUID]["PosX"]
			stringposx = self:GetPos(stringposx, Unit, User, true)
		
			local stringposy = self.RUIDInfo[RUID]["PosY"]
			stringposy = self:GetPos(stringposy, Unit, User, false)
					
			--유닛 뒤,앞 여부 확인
			local unitlayertype = Unit.SpriteRendererComponent.SortingLayer
			local effectlayer = Unit.SpriteRendererComponent.OrderInLayer
			if self.RUIDInfo[RUID]["Layer"] == "Front" then
				unitlayertype = "Foreground"
			else
				unitlayertype = "Layer1"
				effectlayer -= 1
			end
		
			--플립체크
			local flipx = false
			local flipy = false
			if self.RUIDInfo[RUID]["FlipX"] then
				flipx = true
			end
			if self.RUIDInfo[RUID]["FlipY"] then
				flipy = true
			end
					
			if User == false then
				flipx = not flipx
			end
					
			--이펙트
			local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"], ["SortingLayer"]=unitlayertype, ["OrderInLayer"]=effectlayer, ["FlipX"]=flipx, ["FlipY"]=flipy}
			local effect = _EffectService:PlayEffectAttached(RUID, Unit, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
												self.RUIDInfo[RUID]["Loop"], options)
			table.insert(effecttable,effect)
		end
		
		
		_TimerService:SetTimerOnce(playeffect, self.RUIDInfo[RUID]["DelayTime"])
		
		--루프도는 이펙트라면 제거까지 처리
		local removeeffect = function()
			if self.RUIDInfo[RUID]["Loop"] then
				for i = 1, #effecttable do
					_EffectService:RemoveEffect(effecttable[i])
				end
			else
				table.clear(effecttable)
			end
		end
		_TimerService:SetTimerOnce(removeeffect, self.RUIDInfo[RUID]["RemoveTime"])
	end

	@ExecSpace("Client")
	method void SetS10001StackText(integer Stack)
		-- 마스코트 시너지의 인기도 수치를 UI 텍스트에 업데이트
		--if _UserService.LocalPlayer.CurrentMap.Name ~= "Arena" then return end
		if _UserService.LocalPlayer.CurrentMap.MapComponent.IsDynamicMap == false then return end
		
		local mascot = _UserService.LocalPlayer.CurrentMap:GetChildByName("MascotSynergy"):GetChildByName("MascotEntity")--/maps/Arena/MascotEntity
		
		mascot.Parent:GetChildByName("Stack").TextComponent.Text = tostring(math.floor(Stack))
		
	end

end