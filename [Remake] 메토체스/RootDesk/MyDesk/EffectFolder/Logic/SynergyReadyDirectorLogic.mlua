@Logic
script SynergyReadyDirectorLogic extends Logic

	property table RUIDList = {}

	@Description("타일 위치에 효과를 넣어야하는 경우 사용")
	property table Tile10021 = {}

	property table OnFieldSynergy = {}

	property table RUIDInfo = {}

	property Entity Tile10025 = nil

	property table SynergyInfo = {}

	property Entity Tile10025_Enemy = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 클라이언트 시작 시 시너지 연출 관련 테이블 데이터를 로드
		self:LoadTable()
	end

	@ExecSpace("Client")
	method void LoadTable()
		-- 시너지 연출에 필요한 모든 리소스와 데이터를 메모리에 캐싱하여 성능 최적화
		--리소스들이 많아서 미리 캐싱해둡니다.
		local SynergyDirection = _DataService:GetTable("SynergyDirection")
		for i = 1, SynergyDirection:GetRowCount() do
			if isvalid(SynergyDirection:GetCell(i, 1)) then
				self.RUIDList[SynergyDirection:GetCell(i, 1)] = {}
		
			else
				break
			end
			
			local row=SynergyDirection:GetRow(i)
			--아트 리소스
			for j = 1, 5 do
				if not _UtilLogic:IsNilorEmptyString(row:GetItem("RUID"..j)) then
					table.insert(self.RUIDList[SynergyDirection:GetCell(i, 1)], row:GetItem("RUID"..j))
				end
			end
			
			--사운드리소스
			table.insert(self.RUIDList[SynergyDirection:GetCell(i, 1)], row:GetItem("SoundID"))	
		end
		
		--아트 리소스는 상세 정보도 미리 캐싱해둡니다.
		local SynergyDirectionInfo = _DataService:GetTable("SynergyDirectionRUIDInfo")
		
		local columns = SynergyDirectionInfo.Columns
		for i = 1, SynergyDirectionInfo:GetRowCount() do
				self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]
				={["AttachedType"] = SynergyDirectionInfo:GetCell(i, 2),
				["Rotation"] = tonumber(SynergyDirectionInfo:GetCell(i, 5)),
				["PlayRate"] = tonumber(SynergyDirectionInfo:GetCell(i, 6)),
				["RemoveTime"] = tonumber(SynergyDirectionInfo:GetCell(i, 8)),
				["DelayTime"] = tonumber(SynergyDirectionInfo:GetCell(i, 9)),
				["Layer"] = SynergyDirectionInfo:GetCell(i, 10)}
				
				--pos, scale들 벡터값으로 변경
				local posstring = _UtilLogic:Split(SynergyDirectionInfo:GetCell(i, 3), ",")
				self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["PosX"] = posstring[1]
				self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["PosY"] = posstring[2]
				
				local scalestring = _UtilLogic:Split(SynergyDirectionInfo:GetCell(i, 4), ",")
				self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["ScaleX"] = tonumber(scalestring[1])
				self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["ScaleY"] = tonumber(scalestring[2])
				
				--Loop 
				if SynergyDirectionInfo:GetCell(i, 7) == "FALSE" then
					self.RUIDInfo[SynergyDirectionInfo:GetCell(i,1)]["Loop"] = false
				else
					self.RUIDInfo[SynergyDirectionInfo:GetCell(i,1)]["Loop"] = true
				end
				
				--FlipX
				if SynergyDirectionInfo:GetCell(i, 11)=="FALSE" then
					self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["FlipX"] = false
				else
					self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["FlipX"] = true
				end
				
				--FlipY
				if SynergyDirectionInfo:GetCell(i, 12) == "FALSE" then
					self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["FlipY"] = false
				else
					self.RUIDInfo[SynergyDirectionInfo:GetCell(i, 1)]["FlipY"] = true
				end
		end
		
		----------------------------------------------------------------------------
		--각 시너지별 단계를 미리 캐싱해둡니다.
		local synergydata = _DataService:GetTable("SynergyInfo")
		
		local rows2 = synergydata:GetAllRow()
		
		for i, row in pairs(rows2) do
			local id = row:GetItem("SynergyID")
			
			local obj = {}
			self.SynergyInfo[id] = obj
			
			for i = 1, 5 do
				local synergycount = row:GetItem("NeedCount_step"..tostring(i))
				
				if isvalid(synergycount) then
					table.insert(self.SynergyInfo[id], tonumber(synergycount))
				end
			end
		end
		
	end

	@ExecSpace("Client")
	method void ReceiveFieldSynergyCount(string synergyID, integer count, boolean User)
		-- 필드 시너지 개수가 변경될 때 호출되어 해당 시너지의 연출을 재생
		-- 아군 시너지 일 때만 적용되는 연출들
		if User then
			--count가 줄어든 경우, 바로 리턴(전직교관 시너지 제외)
			if not isvalid(self.OnFieldSynergy[synergyID]) then
				self.OnFieldSynergy[synergyID] = 0
			end
			
			if synergyID ~= "S10024" and self.OnFieldSynergy[synergyID] > count then
				self.OnFieldSynergy[synergyID] = count
				
				--시간의 신전, 모험가, 마스코트 별도 처리 필요
				if synergyID == "S10023" then
					if count < self.SynergyInfo["S10023"][1] then
						self:S10023Direction(count, User)
					else
						local dollruid = _UtilLogic:Split(self.RUIDList["S10023"][3], ",")
						local doll = _EntityService:GetEntity("397fe794-b5e5-4d66-83f9-6429e37111eb")--/maps/Arena/AdventurerEntity
						doll:GetChildByName("sprite").SpriteRendererComponent.SpriteRUID = dollruid[math.floor(count/2)]
					end
				elseif synergyID == "S10001" then
					if count < self.SynergyInfo["S10001"][1] then
						self:S10001Direction(count, User)
					end
				elseif count < self.SynergyInfo["S10025"][1] and synergyID == "S10025" then
					self:S10025Direction(count, User)
				end
				return
			end
			
			self.OnFieldSynergy[synergyID] = count
			
			--시너지가 몇 단계인지? 딱 맞지 않으면 0을 반환
			local level = self:GetSynergyStep(synergyID, true, count)
			
			--시너지 ID를 확인하고 조건에 맞는 연출 호출. 특정 시너지 빼고는 level이 0인 애들은 바로 리턴
			--level이 0이어도 연출 호출하는 시너지
			if synergyID == "S10011" then
				self:S10011Direction(count, User)
				return
			elseif synergyID == "S10001" then
				self:S10001Direction(count, User)
				return
			elseif synergyID == "S10025" then
				self:S10025Direction(count, User)
				return
			elseif synergyID == "S10023" then
				self:S10023Direction(count, User)
				return
			end
			
			--그 외는 level이 0이면 리턴
			if level == 0 then return end
			
		-- 적군 시너지일 때만 적용되는 연출들		
		else
			--시너지 ID를 확인하고 조건에 맞는 연출 호출. 특정 시너지 빼고는 level이 0인 애들은 바로 리턴
			--level이 0이어도 연출 호출하는 시너지
			if synergyID == "S10025" then
				self:S10025Direction(count, User)
				return
			elseif synergyID == "S10023" then
				self:S10023Direction(count, User)
				return
			end
			
			--그 외는 level이 0이면 리턴
			local level = self:GetSynergyStep(synergyID, false, count)
			if level == 0 then return end
			
			if synergyID == "S10011" then
				self:S10011Direction(count, User)
			end
		end
			
		-- 아군/적군 관계없이 같은 로직 사용
		if synergyID == "S10005" then
			self:S10005Direction(count, User)
		elseif synergyID == "S10016" then
			self:S10016Direction(count, User)
		elseif synergyID == "S10019" then
			self:S10019Direction(count, User)
		elseif synergyID == "S10024" then
			self:S10024Direction(count, User)
		elseif synergyID == "S10020" then
			self:S10020Direction(count, User)
		elseif synergyID == "S10021" then
			self:S10021Direction(count, User)
		elseif synergyID == "S10015" then
			self:S10015Direction(count, User)
		elseif synergyID == "S10031" then
			self:S10031Direction(count,User)
		else
		--시너지 단계 관계없이 모두 동일 + 한 두개 애님만 붙이는 연출
			self:BasicDirection(synergyID, count,User)
		end
		
	end

	@ExecSpace("Client")
	method void BasicDirection(string synergyID, integer count, boolean User)
		-- 기본적인 시너지 연출을 재생 (사운드와 이펙트)
		if not isvalid(self.RUIDList[synergyID]) then return end
		
		--필드 위에 올라간 유닛들 중 시너지 일치하는 유닛들
		local RUIDList = self.RUIDList[synergyID][#self.RUIDList[synergyID]]
		RUIDList = _UtilLogic:Split(RUIDList, ",")
		
		for i = 1, #RUIDList do
			_PlaySoundLogic:PlaySound(RUIDList[i])
		end
		
		for i = 1, #self.RUIDList[synergyID]-1 do
			self:PlayEffect(synergyID, self.RUIDList[synergyID][i], User)
		end
	end

	@ExecSpace("Client")
	method void S10001Direction(integer count, boolean User)
		-- 마스코트 시너지 연출을 처리하고 인기도 시스템을 관리
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		local entity = map:GetChildByName("MascotSynergy"):GetChildByName("MascotEntity")--/maps/Arena/MascotEntity
		
		if count == self.SynergyInfo["S10001"][1] or count == self.SynergyInfo["S10001"][2] or count == self.SynergyInfo["S10001"][3] or count == self.SynergyInfo["S10001"][4] then
			--필드 위에 올라간 유닛들 중 마스코트 유닛들
			local onfieldunits = self:GetOnFieldUnit("S10001", User)
			
			_PlaySoundLogic:PlaySound("M0029")
			_PlaySoundLogic:PlaySound("M0169")
			
			--마스코트 유닛에게 이펙트
			for i = 1, #self.RUIDList["S10001"]-1 do
				self:PlayEffect("S10001",self.RUIDList["S10001"][i], User)
			end
			
			--인기도 엔터티 보여주기
			entity.Parent.Enable = true
			
			local stack = _UserService.LocalPlayer.SynergyManager_New.SynergyStack["S10001"]
			_SynergyReadyDirectorLogic:SetS10001StackText(stack)
			self:Set10001MascotInfo(stack)
		elseif count < self.SynergyInfo["S10001"][1] then
			--인기도 엔터티 끄기
			if entity.Parent.Enable then
				entity.Parent.Enable = false
			end
		end
	end

	@ExecSpace("Client")
	method void S10001GetReward(string data)
		-- 마스코트 시너지에서 인기도 보상을 받을 때의 연출을 처리
		--data키값 - Gold, Item, Char
		--Stack : 인기도
		
		data = _HttpService:JSONDecode(data)
		local mascot = _UserService.LocalPlayer.CurrentMap:GetChildByName("MascotSynergy"):GetChildByName("MascotEntity")
		----------------------------------------------------------------------
		--미리 아이템 슬롯 visible꺼두기, 레드닷도 꺼두기
		if isvalid(data["Item"]) then
			for i = 1, #data["Item"] do
				local parse = _UtilLogic:Split(data["Item"][i], ",")
				
				if tonumber(parse[2]) <= 10 then
					local invenslot = _EntityService:GetEntity("36df1686-bd85-4854-bde6-609ccf89e30b"):GetChildByName("Item_"..parse[2])
					invenslot.Visible = false
				end
			end
			
			local reddot = _EntityService:GetEntity("35568b5a-2b93-493a-8e13-6d3d808d5ef5") -- /ui/Arena_ReadyPhase/InventoryPanel/Button_NextPage/Reddot
			reddot.Visible = false
		end
		
		--UI끄기
		mascot.Parent:GetChildByName("Stack").Enable = false
		mascot.Parent:GetChildByName("Button_GetReward").Enable = false
		
		--보상 연출
		mascot.SpriteRendererComponent.SpriteRUID = "860206eed29d42cc96438087a7572ce3"
		
		-- 핑크빈 연출 : 애님 타이밍때문에 먼저 호출
		if data["Char"] > 0 then
			mascot:GetChildByName("PinkBean").Enable = true
			_TimerService:SetTimerOnce(function() mascot:GetChildByName("PinkBean").Enable = false end, 0.7)
		end
		
		local pos = _UILogic:WorldToScreenPosition(mascot.TransformComponent.WorldPosition:ToVector2())
		_GeneralDirectorLogic:PlayCoinDirector_Sprite(data["Gold"], pos, "Mascot")
		
		local rewarddirector = function()
			_PlaySoundLogic:PlaySound("M0151")
		
			
			if isvalid(data["Item"]) then -- 아이템 연출
				for i = 1, #data["Item"] do
					_GeneralDirectorLogic:InsertItemDirectorData("Mascot", pos, data["Item"][i])
				end
			end
		end
		
		_TimerService:SetTimerOnce(rewarddirector, 0.3)
		
		--관중엔터티 사라짐
		local Init = function()
			for i = 1, 5 do
				mascot:GetChildByName("Crowd"..tostring(i)).Enable = false
			end
		end
		
		_TimerService:SetTimerOnce(Init, 0.3)
		
		--상자 RUID 및 UI원상복구
		local Return = function()
			self:Set10001MascotInfo(data["Stack"])
			
			--UI켜기
			mascot.Parent:GetChildByName("Stack").Enable = true
		end
		
		_TimerService:SetTimerOnce(Return, 0.95)
	end

	@ExecSpace("Client")
	method void S10005Direction(integer count, boolean User)
		-- 시간의 신전 시너지 연출을 단계별로 처리
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		
		--공통
		_PlaySoundLogic:PlaySound("M0019")
		self:PlayEffect("S10005",self.RUIDList["S10005"][1],User)
		
		--단계별추가
		if count == self.SynergyInfo["S10005"][2] then
			_TimerService:SetTimerOnce(function()_PlaySoundLogic:PlaySound("M0020") end,1.5)
			self:PlayEffect("S10005", self.RUIDList["S10005"][2], User)
		elseif count == self.SynergyInfo["S10005"][3] then
			_TimerService:SetTimerOnce(function()_PlaySoundLogic:PlaySound("M0020") end,1.5)
			self:PlayEffect("S10005", self.RUIDList["S10005"][3], User)
		elseif count == self.SynergyInfo["S10005"][4] then
			_TimerService:SetTimerOnce(function()_PlaySoundLogic:PlaySound("M0020") end,1.5)
			self:PlayEffect("S10005", self.RUIDList["S10005"][4], User)
		end
			
	end

	@ExecSpace("Client")
	method void S10011Direction(integer count, boolean User)
		-- 도적 시너지 연출을 처리하고 첫 활성화 시 안내 메시지를 표시
		
		for i = 1, #self.SynergyInfo["S10011"] do
			if count == self.SynergyInfo["S10011"][i] then
				break
			else
				if i == #self.SynergyInfo["S10011"] then
					return
				end
			end
		end 
		
		--사운드
			_PlaySoundLogic:PlaySound("M0025")
			_PlaySoundLogic:PlaySound("M0154")
		
			--이펙트
			for i = 1, #self.RUIDList["S10011"]-1 do
				self:PlayEffect("S10011", self.RUIDList["S10011"][i], User)
			end
			
			if User and count == self.SynergyInfo["S10011"][1] then
				--안내메세지
				_UIToast:ShowMessageByLocalizingKey("ToastMessage_0001")
			end
	end

	@ExecSpace("Client")
	method void S10015Direction(integer count, boolean User)
		-- 시간의 신전 시너지 연출을 처리하며 도도 엔터티 중심으로 이펙트를 재생
		if count >= self.SynergyInfo["S10015"][1] then
			--사운드
			local soundruid = _UtilLogic:Split(self.RUIDList["S10015"][#self.RUIDList["S10015"]],",")
			if count == self.SynergyInfo["S10015"][1] or count == self.SynergyInfo["S10015"][2] or count == self.SynergyInfo["S10015"][3] then
				_PlaySoundLogic:PlaySound(soundruid[1])
				_PlaySoundLogic:PlaySound(soundruid[3])
			elseif count == self.SynergyInfo["S10015"][4] then
				_PlaySoundLogic:PlaySound(soundruid[2])
				_PlaySoundLogic:PlaySound(soundruid[4])
			end
			
			
			--필드 위에 올라간 유닛들 중 시간의 신전 유닛들
			local onfieldunits = self:GetOnFieldUnit("S10015", User)
			
			--도도 엔터티
			local map = _UserService.LocalPlayer.CurrentMap
			local dodo = map:GetChildByName("Units_".._UserService.LocalPlayer.PlayerComponent.UserId):GetChildByName("BTUnit_DoDo")
			local dodopos = dodo.TransformComponent.WorldPosition:Clone()
			
			if User == false then
				dodo = map:GetChildByName("Units_".._UserService.LocalPlayer.PlayerComponent.UserId):GetChildByName("EnemyUnit_DoDo")
				dodopos = dodo.TransformComponent.WorldPosition:Clone()
			end
			
			--10시너지 이펙트
			if count == self.SynergyInfo["S10015"][4] then
				self:PlayEffect("S10015", self.RUIDList["S10015"][4], User)
		
				local RUID = self.RUIDList["S10015"][2]
				
				--센터피봇사용여부 확인
				local stringposx = self.RUIDInfo[RUID]["PosX"]
				stringposx = self:GetPos(stringposx, dodo, User, true)
		
				local stringposy = self.RUIDInfo[RUID]["PosY"]
				stringposy = self:GetPos(stringposy, dodo, User, false)
				
				--유닛 뒤,앞 여부 확인
				local unitlayertype = dodo:GetChildByName("SpriteRenderer").SpriteRendererComponent.SortingLayer
				local effectlayer = dodo:GetChildByName("SpriteRenderer").SpriteRendererComponent.OrderInLayer
				if self.RUIDInfo[RUID]["Layer"] == "Front" then
					unitlayertype = "Foreground"
				else
					effectlayer -= 1
				end
					
				--플립체크
				local flipx = false
				local flipy = false
				if self.RUIDInfo[RUID]["FlipX"] then
					flipx = true
				end
				if self.RUIDInfo[RUID]["FlipY"] then
					flipy = true
				end
					
				if User == false then
					flipx = not flipx
					--flipy = not flipy
				end
				
				_EffectService:PlayEffectAttached(RUID, dodo, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
												self.RUIDInfo[RUID]["Loop"], {["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"],["SortingLayer"]=unitlayertype,["OrderInLayer"]=effectlayer,["FlipX"]=flipx,["FlipY"]=flipy})
			end
			 --3,5,7시너지 이펙트
			if count == self.SynergyInfo["S10015"][1] or count == self.SynergyInfo["S10015"][2] or count == self.SynergyInfo["S10015"][3] then
		
				self:PlayEffect("S10015", self.RUIDList["S10015"][3], User)
				
				local RUID = self.RUIDList["S10015"][1]
				
				--센터피봇사용여부 확인
				local stringposx = self.RUIDInfo[RUID]["PosX"]
				stringposx = self:GetPos(stringposx, dodo, User, true)
		
				local stringposy = self.RUIDInfo[RUID]["PosY"]
				stringposy = self:GetPos(stringposy, dodo, User, false)
				
				--유닛 뒤,앞 여부 확인
				local unitlayertype = dodo:GetChildByName("SpriteRenderer").SpriteRendererComponent.SortingLayer
				local effectlayer = dodo:GetChildByName("SpriteRenderer").SpriteRendererComponent.OrderInLayer
				if self.RUIDInfo[RUID]["Layer"] == "Front" then
					unitlayertype = "Foreground"
				else
					effectlayer -= 1
				end
					
				--플립체크
				local flipx = false
				local flipy = false
				if self.RUIDInfo[RUID]["FlipX"] then
					flipx = true
				end
				if self.RUIDInfo[RUID]["FlipY"] then
					flipy = true
				end
					
				if User == false then
					flipx = not flipx
					--flipy = not flipy
				end
				
				_EffectService:PlayEffectAttached(RUID, dodo, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"],self.RUIDInfo[RUID]["ScaleY"],1),
												 self.RUIDInfo[RUID]["Loop"], {["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"],["SortingLayer"]=unitlayertype,["OrderInLayer"]=effectlayer,["FlipX"]=flipx,["FlipY"]=flipy})
			end
		end
	end

	@ExecSpace("Client")
	method void S10016Direction(integer count, boolean User)
		-- 엘나스 시너지 연출로 전장을 얼음으로 덮고 눈보라 이펙트를 재생
		local map = _UserService.LocalPlayer.CurrentMap
		
		_PlaySoundLogic:PlaySound("M0027")
		--눈보라
		local snowy = _EntityService:GetEntity("e0ccec8a-5b2b-4d93-a131-5d09f00d5827")--/ui/SynergyDirection/EllnasSnowy
		snowy.Enable = true
		
		--엘나스 유닛 위에 눈
		self:PlayEffect("S10016", self.RUIDList["S10016"][1], User)
		
		--얼어붙은 전장
		for i = 1, 7 do
			local line = map:GetChildByName("Line_"..math.floor(i)).Children
			
			
			if User then
				for j = 1, 4 do
					line[j].Visible = true
					
					--엘나스 타일 제외 모두 visible 끄기
					line[j]:GetChildByName("Knight").Visible = false
					line[j]:GetChildByName("Orbis").Visible = false
					line[j]:GetChildByName("OnDraggingTile").Visible = false
					
					--엘나스 타일 켜두기
					line[j]:GetChildByName("Ellnas").Enable = true
					line[j]:GetChildByName("Ellnas").SpriteRendererComponent:ChangeMaterial("material://1b2281c1-5019-4e5f-ba83-7d75cbfe5f26")
				end
			else
				if math.fmod(i,2) == 1 then
					for j = 6, 9 do
						line[j].Visible = true
						
						--엘나스 타일 제외 모두 visible 끄기
						line[j]:GetChildByName("Knight").Visible = false
						line[j]:GetChildByName("Orbis").Visible = false
						line[j]:GetChildByName("OnDraggingTile").Visible = false
						
						--엘나스 타일 켜두기
						line[j]:GetChildByName("Ellnas").Enable = true
						line[j]:GetChildByName("Ellnas").SpriteRendererComponent:ChangeMaterial("material://1b2281c1-5019-4e5f-ba83-7d75cbfe5f26")
					end
				else
					for j = 5, 8 do
						line[j].Visible = true
						
						--엘나스 타일 제외 모두 visible 끄기
						line[j]:GetChildByName("Knight").Visible = false
						line[j]:GetChildByName("Orbis").Visible = false
						line[j]:GetChildByName("OnDraggingTile").Visible = false
						
						--엘나스 타일 켜두기
						line[j]:GetChildByName("Ellnas").Enable = true
						line[j]:GetChildByName("Ellnas").SpriteRendererComponent:ChangeMaterial("material://1b2281c1-5019-4e5f-ba83-7d75cbfe5f26")
					end
				end
			end
					
		end
		
		--이펙트
		self:PlayEffect("S10016", self.RUIDList["S10016"][2], User)
		local under = function()
			snowy.Enable = false
		end
		
		_TimerService:SetTimerOnce(under, 1.2)
		
		--타일 머티리얼 제거
		local destroy = function()
			for i = 1, 7 do
				local line = map:GetChildByName("Line_"..math.floor(i)).Children
				
				for j = 1, #line do
					line[j]:GetChildByName("Ellnas").Enable = false
					line[j]:GetChildByName("Ellnas").SpriteRendererComponent:ChangeMaterial("")
					
					line[j]:GetChildByName("Knight").Visible = true
					line[j]:GetChildByName("Orbis").Visible = true
					line[j]:GetChildByName("OnDraggingTile").Visible = true
					
					-- 기사단장, 오르비스 타일이 켜져있는 타일만 타일 visible 켜두기
					_GeneralDirectorLogic:OnOffTileVisible("Ellnas")
				end
				
			end
		end
		
		_TimerService:SetTimerOnce(destroy, 1.4)
	end

	@ExecSpace("Client")
	method void S10019Direction(integer count, boolean User)
		-- 루디브리엄 시너지 연출로 공장장 카호를 소환하고 관련 이펙트를 재생
		local map = _UserService.LocalPlayer.CurrentMap
