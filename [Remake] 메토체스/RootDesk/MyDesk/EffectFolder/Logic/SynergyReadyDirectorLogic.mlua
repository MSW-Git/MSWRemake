	@ExecSpace("Client")
	method void S10020Direction(integer count, boolean User)
		-- 아케인리버 시너지 연출로 각 유닛에 맞는 동료를 소환하고 이펙트를 적용
		local map = _UserService.LocalPlayer.CurrentMap
		_PlaySoundLogic:PlaySound("M0158")
		_TimerService:SetTimerOnce(function() _PlaySoundLogic:PlaySound("M0033") end, 1.5)
		
		--필드 위에 올라간 유닛들 중 아케인리버 유닛들
		local onfieldunits = self:GetOnFieldUnit("S10020", User)
		
		--동료(부하) 등장
		local colleaguelist = _UtilLogic:Split(self.RUIDList["S10020"][1],",")
		local unitlist = {"C10004","C20013","C20012","C50005"}
		for i = 1, #onfieldunits do
			for j = 1, #unitlist do
				if unitlist[j] == onfieldunits[i].UnitInfo.charID then
					local entity = _SpawnService:SpawnByModelId(colleaguelist[j], "Colleague", Vector3(0,0.3,0), onfieldunits[i])
					entity.ArcaneRiverColleague:SetColleagueVisible(4)
					break
				end
			end
		end
		
		--동료들이 사라지고 이펙트 두르기
		self:PlayEffect("S10020", self.RUIDList["S10020"][3], User)
	end

	@ExecSpace("Client")
	method void S10021Direction(integer count, boolean User)
		-- 오르비스 시너지 연출로 사운드와 이펙트를 재생
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		
		_PlaySoundLogic:PlaySound("M0034")
		_PlaySoundLogic:PlaySound("M0167")
		_PlaySoundLogic:PlaySound("M0168")
		
		--필드 위에 올라간 유닛들 중 오르비스 유닛들
		local onfieldunits = self:GetOnFieldUnit("S10021", User)
		
		--오르비스 유닛 이펙트
		self:PlayEffect("S10021", self.RUIDList["S10021"][1], User)
		self:PlayEffect("S10021", self.RUIDList["S10021"][2], User)
		
	end

	@ExecSpace("Client")
	method void Set10021TilesEffect(string ID, string Tiles)
		-- 오르비스 소환석의 영향을 받는 타일들의 시각적 효과를 관리
		--소환석 ID에 데이터가 있으면 우선 색상 원상복구
		local delay = 0
		if isvalid(self.Tile10021[ID]) then
			if #self.Tile10021[ID] == 0 then
				delay = 1
			else
				local stoneentity = _EntityService:GetEntity(ID)
				if stoneentity.UnitInfo.TeamType == "User" then
					for i = 1, #self.Tile10021[ID] do
						_GeneralDirectorLogic:OnOffTileVisible("Orbis")
						self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a -= 0.25
						
						if self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a <= 0.25 then
							self.Tile10021[ID][i]:GetChildByName("Orbis").Enable = false
							self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a = 0.5
						end
					end
				else
					for i=1,#self.Tile10021[ID] do
						_GeneralDirectorLogic:OnOffTileVisible("Orbis")
						self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a -= 0.25
						
						if self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a <= 0.25 then
							self.Tile10021[ID][i]:GetChildByName("Orbis").Enable = false
							self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a = 0.5
						end
					end
				end
			end
		else
			self.Tile10021[ID] = {}
			delay = 1
		end
		
		if _UtilLogic:IsNilorEmptyString(Tiles) then
			self.Tile10021[ID] = nil
			--return
			--table.clear(self.Tile10021[ID])
		else
			self.Tile10021[ID] = _UtilLogic:StringToTable(Tiles)
		end
		
		local orbis = function()
			--타일 데이터 갱신
			if not isvalid(self.Tile10021[ID]) then
				--self.Tile10021[ID] = nil
				return
				--table.clear(self.Tile10021[ID])
			else
				--self.Tile10021[ID] = _UtilLogic:StringToTable(Tiles)
				local stoneentity = _EntityService:GetEntity(ID)
				if stoneentity.UnitInfo.TeamType == "User" then
					--중립구역, 적전장 타일이 있다면 삭제
					for i = #self.Tile10021[ID], 1, -1 do
						if not isvalid(self.Tile10021[ID][i]) then
							table.remove(self.Tile10021[ID],i)
						else
							if tonumber(_UtilLogic:SubString(self.Tile10021[ID][i].Name, 6, 1)) >= 5 then -- 아군 소환석인 경우
								table.remove(self.Tile10021[ID],i)
							else
								
							end
						end
					end
				elseif stoneentity.UnitInfo.TeamType == "Enemy" then
					--중립구역, 아군전장 타일이 있다면 삭제
					for i = #self.Tile10021[ID],1,-1 do
						if not isvalid(self.Tile10021[ID][i]) then
							table.remove(self.Tile10021[ID],i)
						else
							local line = math.fmod(tonumber(_UtilLogic:SubString(self.Tile10021[ID][i].Parent.Name, 6, 1)), 2)
							local tile=tonumber(_UtilLogic:SubString(self.Tile10021[ID][i].Name,6,1))
							if line == 1 and tile <= 5 then -- 적군 소환석인 경우
								table.remove(self.Tile10021[ID],i)
							elseif line == 0 and tile < 5 then
								table.remove(self.Tile10021[ID],i)
							end
						end
					end
				end
			end
			
			--오르비스석 소환석 주변 타일들 색상 처리
			for i = 1, #self.Tile10021[ID] do
				self.Tile10021[ID][i].Visible = true
				self.Tile10021[ID][i]:GetChildByName("Orbis").Enable = true
				self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a = 0.5
				--중첩타일확인 후 알파값 조정
				for TileId, table in pairs(self.Tile10021) do
					if TileId ~= ID then
						for j = 1, #table do
							if self.Tile10021[ID][i] == table[j] then
								self.Tile10021[ID][i]:GetChildByName("Orbis").SpriteRendererComponent.Color.a += 0.25
								break
							end
						end
					end
				end
			end
			
			_GeneralDirectorLogic:OnOffTileVisible("Orbis")
		end
		_TimerService:SetTimerOnce(orbis, delay)
		
	end

	@ExecSpace("Client")
	method void S10023Direction(integer count, boolean User)
		-- 모험가 시너지 연출을 처리하고 시너지 단계에 따라 인형의 모습을 변경
		
		--local doll = _EntityService:GetEntity("397fe794-b5e5-4d66-83f9-6429e37111eb")--/maps/Arena/AdventurerEntity
		local dollruid = _UtilLogic:Split(self.RUIDList["S10023"][3],",")
		if count == self.SynergyInfo["S10023"][1] or count == self.SynergyInfo["S10023"][2] or count == self.SynergyInfo["S10023"][3] or count == self.SynergyInfo["S10023"][4] then
			_PlaySoundLogic:PlaySound("M0036")
			--필드 위에 올라간 유닛들 중 모험가 유닛들
			local onfieldunits = self:GetOnFieldUnit("S10023", User)
			
			--유닛 근처에 이펙트
			self:PlayEffect("S10023", self.RUIDList["S10023"][1], User)
		elseif count<self.SynergyInfo["S10023"][1] then
			-- doll.Enable = false
		end
	end

	@ExecSpace("Client")
	method void S10024Direction(integer count, boolean User)
		-- 전직교관 시너지 연출을 처리하며 교관 종류에 따라 다른 이펙트를 재생
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		local EnemyUnits = _UserService.LocalPlayer.TeamManager.EnemyUnits
		
		--사운드
		local soundruid = _UtilLogic:Split(self.RUIDList["S10024"][#self.RUIDList["S10024"]],",")
		
		--필드 위에 올라간 유닛들 중 전직교관 유닛들
		local onfieldunits = self:GetOnFieldUnit("S10024", User)
		if #onfieldunits < 1 then
			return
		end
		
		if count == 1 then
			_PlaySoundLogic:PlaySound(soundruid[1])
			--어떤 교관이 활성화했는지 체크
			local chlist = {"C20004", "C30010", "C30013", "C40002", "C50007"}
			local SynergyOnChID = 0
			for i = 1, #chlist do
				if chlist[i] == onfieldunits[1].UnitInfo.charID then
					SynergyOnChID = i
					break
				end
			end
			
		
			local ruidlist_1 = _UtilLogic:Split(self.RUIDList["S10024"][1],",")--전직교관에게 이펙트
			local ruidlist_2 = _UtilLogic:Split(self.RUIDList["S10024"][2],",")--아군에게 이펙트
			
			self:PlayEffect("S10024", ruidlist_1[SynergyOnChID],User)
			self:PlayEffect("S10024", ruidlist_2[SynergyOnChID],User)
			
		elseif count == 5 then
			_PlaySoundLogic:PlaySound(soundruid[2])
			local ruidlist_1 = _UtilLogic:Split(self.RUIDList["S10024"][3],",")--전직교관에게 이펙트
			local ruidlist_2 = _UtilLogic:Split(self.RUIDList["S10024"][4],",")--아군에게 이펙트
			
			for i = 1, #ruidlist_1 do
				self:PlayEffect("S10024", ruidlist_1[i],User)
			end
			
			for i = 1, #ruidlist_2 do
				self:PlayEffect("S10024", ruidlist_2[i],User)
			end
		end
		
	end

	@ExecSpace("Client")
	method void S10025Direction(integer count, boolean User)
		-- 기사단장 시너지 연출을 처리하고 성역 타일의 위치와 효과를 관리
		--시너지 단계와 관계없이 타일 위치 수시로 체크
		local map = _UserService.LocalPlayer.CurrentMap
		local tilepos = _UserService.LocalPlayer.SynergyManager_New.SynergyStack["S10025_Pos"]
		local enemytilepos = _UserService.LocalPlayer.SynergyManager_New.Enemy_SynergyStack["S10025_Pos"]
		
		local tileparent = map:GetChildByName("Line_"..tostring(math.floor(tilepos/1000)))
		local enemytileparent = map:GetChildByName("Line_"..tostring(math.floor(enemytilepos/1000)))
		local tileentity = tileparent:GetChildByName("Tile_"..tostring(math.floor(tilepos%1000)))
		local enemytileentity = enemytileparent:GetChildByName("Tile_"..tostring(math.floor(enemytilepos%1000)))
				
		self.Tile10025 = tileentity
		self.Tile10025_Enemy = enemytileentity
		
		if count == self.SynergyInfo["S10025"][1] or count == self.SynergyInfo["S10025"][2] or count == self.SynergyInfo["S10025"][3] or count == self.SynergyInfo["S10025"][4]  then
			local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
			
			if User == false then
				OwnUnits = _UserService.LocalPlayer.TeamManager.EnemyUnits
			end
			
			_PlaySoundLogic:PlaySound("M0032")
			--필드 위에 올라간 유닛들 중 기사단장 유닛들
			self:PlayEffect("S10025", self.RUIDList["S10025"][1], User)
			self:PlayEffect("S10025", self.RUIDList["S10025"][2], User)
			
			--2시너지라면 가호 이펙트 재생
			if count == self.SynergyInfo["S10025"][1] then
				self.Tile10025 = tileentity
				self.Tile10025_Enemy = enemytileentity
		
				self:S10025TileBless(User)
				
				--성역칸 위에 이미 유닛이 올라가있는지 확인
				for i = 1, #OwnUnits do
					if OwnUnits[i].UnitInfo.setTile == self.Tile10025 or OwnUnits[i].UnitInfo.setTile == self.Tile10025_Enemy  then
						self:S10025TileBuff(User)
						break
					end
				end 
			end
		elseif count < self.SynergyInfo["S10025"][1] and User then
			if not isvalid(self.Tile10025) then return end
			
			self.Tile10025:GetChildByName("Knight").Enable = false
			
			_GeneralDirectorLogic:OnOffTileVisible("Knight")
		end
	end

	@ExecSpace("Client")
	method void S10025TileBless(boolean User)
		-- 기사단장 시너지의 성역 타일에 축복 이펙트를 적용
		log("기사단장 연출")
		for i = 1, 2 do
			local RUID=self.RUIDList["S10025"][i+2]
			
			--센터피봇사용여부 확인
			local stringposx = self.RUIDInfo[RUID]["PosX"]
			stringposx = self:GetPos(stringposx, self.Tile10025, User, true)
				
			local stringposy = self.RUIDInfo[RUID]["PosY"]
			stringposy = self:GetPos(stringposy, self.Tile10025, User, false)
								
			--유닛 뒤,앞 여부 확인
			local unitlayertype = self.Tile10025.SpriteRendererComponent.SortingLayer
			local effectlayer = self.Tile10025.SpriteRendererComponent.OrderInLayer
			if self.RUIDInfo[RUID]["Layer"] == "Front" then
				unitlayertype = "Foreground"
			else
				unitlayertype = "Layer1"
				effectlayer += 1
			end
								
			--플립체크
			local flipx = false
			local flipy = false
			if self.RUIDInfo[RUID]["FlipX"] then
				flipx = true
			end
			if self.RUIDInfo[RUID]["FlipY"] then
				flipy = true
			end
								
			if User then
			--이펙트
				local effect = _EffectService:PlayEffectAttached(RUID, self.Tile10025, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
							self.RUIDInfo[RUID]["Loop"], {["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"],["SortingLayer"]=unitlayertype,["OrderInLayer"]=effectlayer,["FlipX"]=flipx,["FlipY"]=flipy})
			else
				local effect = _EffectService:PlayEffectAttached(RUID, self.Tile10025_Enemy, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
							self.RUIDInfo[RUID]["Loop"], {["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"],["SortingLayer"]=unitlayertype,["OrderInLayer"]=effectlayer,["FlipX"]=flipx,["FlipY"]=flipy})
			end
			
		end
		
		if User then
			self.Tile10025:GetChildByName("Knight").Enable = true
		else
			self.Tile10025_Enemy:GetChildByName("Knight").Enable = true
		end
		
		_GeneralDirectorLogic:OnOffTileVisible("Knight")
	end

	@ExecSpace("Client")
	method void S10025TileBuff(boolean User)
		-- 기사단장 시너지의 성역 타일 위에 유닛이 있을 때 버프 이펙트를 재생
		
		if not isvalid(self.OnFieldSynergy["S10025"]) then return end
		if not isvalid(self.Tile10025) then return end
		
			local RUID = self.RUIDList["S10025"][5]
			
			--센터피봇사용여부 확인
			local stringposx = self.RUIDInfo[RUID]["PosX"]
			stringposx = self:GetPos(stringposx, self.Tile10025, User, true)
				
			local stringposy = self.RUIDInfo[RUID]["PosY"]
			stringposy = self:GetPos(stringposy, self.Tile10025, User, false)
								
			--유닛 뒤,앞 여부 확인
			local unitlayertype = self.Tile10025.SpriteRendererComponent.SortingLayer
			local effectlayer = self.Tile10025.SpriteRendererComponent.OrderInLayer
			if self.RUIDInfo[RUID]["Layer"] == "Front" then
				unitlayertype = "Foreground"
			else
				unitlayertype = "Layer1"
				effectlayer -= 1
			end
								
			--플립체크
			local flipx = false
			local flipy = false
			if self.RUIDInfo[RUID]["FlipX"] then
				flipx = true
			end
			if self.RUIDInfo[RUID]["FlipY"] then
				flipy = true
			end
								
			if User then
		
			--이펙트
				if self.OnFieldSynergy["S10025"] >= 2 then
					 _EffectService:PlayEffectAttached(RUID, self.Tile10025, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
								self.RUIDInfo[RUID]["Loop"], {["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"],["SortingLayer"]=unitlayertype,["OrderInLayer"]=effectlayer,["FlipX"]=flipx,["FlipY"]=flipy})
				end
			else
				_EffectService:PlayEffectAttached(RUID, self.Tile10025_Enemy, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
							self.RUIDInfo[RUID]["Loop"], {["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"],["SortingLayer"]=unitlayertype,["OrderInLayer"]=effectlayer,["FlipX"]=flipx,["FlipY"]=flipy})
			end
	end

	@ExecSpace("Client")
	method table GetOnFieldUnit(string ID, boolean User)
		-- 필드에 배치된 유닛들 중 특정 시너지 ID를 가진 유닛들을 필터링하여 반환
		--필드 위에 올려진 유닛들 중 ID 시너지를 갖고 있는 유닛들을 반환
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		local EnemyUnits = _UserService.LocalPlayer.TeamManager.EnemyUnits
		
		local onfieldunits = {}
		if User then
			for i = 1, #OwnUnits do
				if isvalid(OwnUnits[i].UnitInfo) then
					if OwnUnits[i].UnitInfo:IsOnFieldUnit( ) then
						if OwnUnits[i].UnitInfo:DoesHaveSynergy(ID) then
							table.insert(onfieldunits,OwnUnits[i])
						end
					end
				else
					log("UnitInfo가 왜 없지 = ", OwnUnits[i].Name)
				end
				
			end
		else
			for i = 1, #EnemyUnits do
				if EnemyUnits[i].UnitInfo:DoesHaveSynergy(ID) then
					table.insert(onfieldunits,EnemyUnits[i])
				end
			end
		end
		
		return onfieldunits
	end

	@ExecSpace("Client")
	method integer GetSynergyStep(string SynergyID, boolean User, integer count)
		-- 시너지 개수에 따른 시너지 단계를 계산하여 반환 (0이면 비활성화)
		--copied가 들어온 경우를 대비한 코드
		local table = _UtilLogic:Split(SynergyID,"_")
		SynergyID = table[1]
		
		local synergyinfo = self.SynergyInfo
		
		if User then
			local onfieldunits = self.OnFieldSynergy[SynergyID]
				
			local data = synergyinfo[SynergyID]
			
			for i=1,#data do
				if onfieldunits == data[i]then
					return i
				end
			end
			return 0
		else
			local data = synergyinfo[SynergyID]
				
			for i = 1, #data do
				if count == data[i]then
					return i
				end
			end
			
			return 0
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(string SynergyID, string RUID, boolean User)
		-- 시너지 이펙트를 재생하며 부착 타입에 따라 맵, 시너지 유닛, 모든 유닛에 적용
		local map = _UserService.LocalPlayer.CurrentMap
		local OwnUnits = _UserService.LocalPlayer.TeamManager.OwnUnits
		local enemyunits = _UserService.LocalPlayer.TeamManager.EnemyUnits
		local effecttable = {}
		
		--필드 위에 올라간 유닛들 중 SynergyID를 갖고 있는 유닛
		local onfieldunits = self:GetOnFieldUnit(SynergyID, User)
		
		if not isvalid(self.RUIDInfo[RUID]) then
			return
		end
		
		--attach 위치 확인
		local attach = self.RUIDInfo[RUID]["AttachedType"]
		
		local playeffect = function()
			if attach == "Map" then
				local posx = 0
				local posy = 0
				posy = tonumber(self.RUIDInfo[RUID]["PosY"])
				if User then
					posx = tonumber(self.RUIDInfo[RUID]["PosX"])
				else
					posx = tonumber(self.RUIDInfo[RUID]["PosX"]) * -1
				end
				
				--이펙트
				local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"]}
				local effect = _EffectService:PlayEffect(RUID, map, Vector3(posx,posy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
														self.RUIDInfo[RUID]["Loop"], options)
				
				table.insert(effecttable,effect)
				
			elseif attach == "Synergy" then
				for i = 1, #onfieldunits do
					--센터피봇사용여부 확인
					local stringposx = self.RUIDInfo[RUID]["PosX"]
					stringposx = self:GetPos(stringposx, onfieldunits[i], User, true)
		
					local stringposy = self.RUIDInfo[RUID]["PosY"]
					stringposy = self:GetPos(stringposy, onfieldunits[i], User, false)
					
					--유닛 뒤,앞 여부 확인
					local unitlayertype = onfieldunits[i].SpriteRendererComponent.SortingLayer
					local effectlayer = onfieldunits[i].SpriteRendererComponent.OrderInLayer
					if self.RUIDInfo[RUID]["Layer"] == "Front" then
						unitlayertype = "Foreground"
					else
						unitlayertype = "Layer1"
						effectlayer -= 1
					end
		
					--플립체크
					local flipx = false
					local flipy = false
					if self.RUIDInfo[RUID]["FlipX"] then
						flipx = true
					end
					if self.RUIDInfo[RUID]["FlipY"] then
						flipy = true
					end
					
					if User == false then
						flipx = not flipx
					end
					
					--이펙트
					local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"], ["SortingLayer"]=unitlayertype, ["OrderInLayer"]=effectlayer, ["FlipX"]=flipx, ["FlipY"]=flipy}
					local effect = _EffectService:PlayEffectAttached(RUID, onfieldunits[i], Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
														self.RUIDInfo[RUID]["Loop"], options)
					table.insert(effecttable,effect)
				end
			else
				if User then
					for i = 1, #OwnUnits do
						if OwnUnits[i].UnitInfo:IsOnFieldUnit( ) then
							--센터피봇사용여부 확인
							local stringposx = self.RUIDInfo[RUID]["PosX"]
							stringposx = self:GetPos(stringposx, OwnUnits[i], User, true)
			
							local stringposy = self.RUIDInfo[RUID]["PosY"]
							stringposy = self:GetPos(stringposy, OwnUnits[i], User, false)
							
							--유닛 뒤,앞 여부 확인
							local unitlayertype = OwnUnits[i].SpriteRendererComponent.SortingLayer
							local effectlayer = OwnUnits[i].SpriteRendererComponent.OrderInLayer
							if self.RUIDInfo[RUID]["Layer"] == "Front" then
								unitlayertype = "Foreground"
							else
								effectlayer -= 1
							end
							
							--플립체크
							local flipx = false
							local flipy = false
							if self.RUIDInfo[RUID]["FlipX"] then
								flipx = true
							end
							if self.RUIDInfo[RUID]["FlipY"] then
								flipy = true
							end
							
							
							--이펙트
							local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"], ["SortingLayer"]=unitlayertype, ["OrderInLayer"]=effectlayer, ["FlipX"]=flipx, ["FlipY"]=flipy}
							local effect = _EffectService:PlayEffectAttached(RUID, OwnUnits[i], Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"],self.RUIDInfo[RUID]["ScaleY"],1),
																self.RUIDInfo[RUID]["Loop"], options)
							
							table.insert(effecttable, effect)
						end
					end
				else
					for i =1 , #enemyunits do
						--센터피봇사용여부 확인
						local stringposx = self.RUIDInfo[RUID]["PosX"]
						stringposx = self:GetPos(stringposx, enemyunits[i], User, true)
			
						local stringposy = self.RUIDInfo[RUID]["PosY"]
						stringposy = self:GetPos(stringposy, enemyunits[i], User, false)
		
						--유닛 뒤,앞 여부 확인
						local unitlayertype = enemyunits[i].SpriteRendererComponent.SortingLayer
						local effectlayer = enemyunits[i].SpriteRendererComponent.OrderInLayer
						if self.RUIDInfo[RUID]["Layer"] == "Front" then
							unitlayertype = "Foreground"
						else
							effectlayer -= 1
						end
						
						--플립체크
						local flipx = false
						local flipy = false
						if self.RUIDInfo[RUID]["FlipX"] == false then
							flipx = true
						end
						if self.RUIDInfo[RUID]["FlipY"] then
							flipy = true
						end
						
						
						
						--이펙트
						local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"], ["SortingLayer"]=unitlayertype, ["OrderInLayer"]=effectlayer, ["FlipX"]=flipx, ["FlipY"]=flipy}
						local effect = _EffectService:PlayEffectAttached(RUID, enemyunits[i], Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"],1),
																self.RUIDInfo[RUID]["Loop"], options)
							
						table.insert(effecttable,effect)
					end
				end
			end
		end
		
		_TimerService:SetTimerOnce(playeffect, self.RUIDInfo[RUID]["DelayTime"])
		
		--루프도는 이펙트라면 제거까지 처리
		local removeeffect = function()
			if self.RUIDInfo[RUID]["Loop"] then
				for i = 1, #effecttable do
					_EffectService:RemoveEffect(effecttable[i])
				end
			else
				table.clear(effecttable)
			end
		end
		_TimerService:SetTimerOnce(removeeffect, self.RUIDInfo[RUID]["RemoveTime"])
		
		
	end

	@ExecSpace("Client")
	method number GetPos(string Pos, Entity Unit, boolean User, boolean xPos)
		-- 이펙트 위치를 계산하며 pivot 기반 위치와 절대 위치를 지원
		if _UtilLogic:Contains(Pos,"pivot") then
			local centerpivot = Vector2(0,0)
			
			if isvalid(Unit.UnitInfo.CenterPivot) then
				centerpivot = Unit.UnitInfo.CenterPivot
			end
			local scale = Unit.UnitInfo.spriteRenderer.TransformComponent.Scale
			local split = _UtilLogic:Split(Pos,"+")
			Pos = centerpivot.x*scale.x
			
			if isvalid(split[2]) and xPos then
				if User then
					Pos += tonumber(split[2])
				else
					Pos -= tonumber(split[2])
				end
			elseif isvalid(split[2]) and xPos == false then 
				Pos += tonumber(split[2])
			end
		else
			Pos = tonumber(Pos)
		end
		
		return Pos
	end

	@ExecSpace("Client")
	method void Set10001MascotInfo(integer stack)
		-- 마스코트 시너지의 인기도에 따라 마스코트와 관중의 모습을 변경
		--if _UserService.LocalPlayer.CurrentMap.Name ~= "Arena" then return end
		if _UserService.LocalPlayer.CurrentMap.MapComponent.IsDynamicMap == false then return end
		
		local mascot = _UserService.LocalPlayer.CurrentMap:GetChildByName("MascotSynergy"):GetChildByName("MascotEntity")
		stack = _UserService.LocalPlayer.SynergyManager_New.SynergyStack["S10001"]  
		
		
		for i = 1, 5 do
			mascot:GetChildByName("Crowd"..tostring(i)).Enable = false
		end
		
		if _UserService.LocalPlayer.GameManager.PhaseType == "Ready" then
			mascot.Parent:GetChildByName("Button_GetReward").Enable = true
		end
		
		--stack에 따라 주변에 관중엔터티를 띄웁니다.
		if stack > 0 and stack < 50  then
			mascot:GetChildByName("Crowd1").Enable = true
			mascot.SpriteRendererComponent.SpriteRUID = "010b74f18dcd44fc9ff9b50b9f804747"
			_TweenLogic:ScaleTo(mascot,Vector2(0.4/1.2, 0.4/1.2), 0.3, EaseType.ExpoEaseOut)
		
			
		elseif stack >= 50 and stack < 100 then
			mascot:GetChildByName("Crowd2").Enable = true
			mascot.SpriteRendererComponent.SpriteRUID = "010b74f18dcd44fc9ff9b50b9f804747"
			_TweenLogic:ScaleTo(mascot,Vector2(0.4/1.2, 0.4/1.2), 0.3, EaseType.ExpoEaseOut)
		
			
		elseif stack >= 100 and stack < 200 then
			mascot:GetChildByName("Crowd3").Enable = true
			mascot.SpriteRendererComponent.SpriteRUID = "010b74f18dcd44fc9ff9b50b9f804747"
			_TweenLogic:ScaleTo(mascot,Vector2(0.5/1.2, 0.5/1.2),0.3,EaseType.ExpoEaseOut)
		
		
			
		elseif stack >= 200 and stack < 400 then
			mascot:GetChildByName("Crowd4").Enable = true
			mascot.SpriteRendererComponent.SpriteRUID = "ad9c258baa534442b94576d616ead6e5"
			_TweenLogic:ScaleTo(mascot,Vector2(0.5/1.2, 0.5/1.2),0.3,EaseType.ExpoEaseOut)
		
		
			
		elseif stack >= 400 then
			mascot:GetChildByName("Crowd5").Enable = true
			mascot.SpriteRendererComponent.SpriteRUID = "ad9c258baa534442b94576d616ead6e5"
			_TweenLogic:ScaleTo(mascot,Vector2(0.6/1.2, 0.6/1.2),0.3,EaseType.ExpoEaseOut)
		
			
		elseif stack == 0 then
			mascot.SpriteRendererComponent.SpriteRUID = "010b74f18dcd44fc9ff9b50b9f804747"
			mascot.Parent:GetChildByName("Button_GetReward").Enable = false
			_TweenLogic:ScaleTo(mascot,Vector2(0.4/1.2, 0.4/1.2), 0.3, EaseType.ExpoEaseOut)
		
			
		end
	end

	@ExecSpace("Client")
	method void S10007ShadowSpawnEffect(Entity Unit, boolean User)
		-- 그림자 시너지로 그림자 유닛이 소환될 때 소환 이펙트를 재생
		local map = _UserService.LocalPlayer.CurrentMap
		local RUID = self.RUIDList["S10007"][2]
		
		--센터피봇사용여부 확인
		local stringposx = self.RUIDInfo[RUID]["PosX"]
		stringposx = self:GetPos(stringposx, Unit, User, true)
		
		local stringposy = self.RUIDInfo[RUID]["PosY"]
		stringposy = self:GetPos(stringposy, Unit, User, false)
					
		--유닛 뒤,앞 여부 확인
		local unitlayertype = Unit.SpriteRendererComponent.SortingLayer
		local effectlayer = Unit.SpriteRendererComponent.OrderInLayer
		if self.RUIDInfo[RUID]["Layer"] == "Front" then
			unitlayertype = "Foreground"
		else
			effectlayer -= 1
		end
		
		local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"], ["SortingLayer"]=unitlayertype, ["OrderInLayer"]=effectlayer}
		_EffectService:PlayEffectAttached(RUID, Unit, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
														self.RUIDInfo[RUID]["Loop"],options)
	end

	@ExecSpace("Client")
	method void S10021SpawnStone(Entity Stone, boolean User)
		-- 오르비스 소환석이 소환될 때 소환 이펙트를 재생
		for i = 1, 2 do
			local RUID = self.RUIDList["S10021"][i+2]
			-- 센터피봇사용여부 확인
			local stringposx = self.RUIDInfo[RUID]["PosX"]
			stringposx = self:GetPos(stringposx, Stone, User, true)
				
			local stringposy = self.RUIDInfo[RUID]["PosY"]
			stringposy = self:GetPos(stringposy, Stone, User, false)
								
			-- 유닛 뒤,앞 여부 확인
			local unitlayertype = Stone.SpriteRendererComponent.SortingLayer
			local effectlayer = Stone.SpriteRendererComponent.OrderInLayer
			if self.RUIDInfo[RUID]["Layer"] == "Front" then
				unitlayertype = "Foreground"
			else
				effectlayer -= 1
			end
								
			-- 플립체크
			local flipx = false
			local flipy = false
			if self.RUIDInfo[RUID]["FlipX"] then
				flipx = true
			end
			if self.RUIDInfo[RUID]["FlipY"] then
				flipy = true
			end
								
								
			-- 이펙트
			local options={["PlayRate"]=self.RUIDInfo[RUID]["PlayRate"], ["SortingLayer"]=unitlayertype, ["OrderInLayer"]=effectlayer, ["FlipX"]=flipx, ["FlipY"]=flipy}
			local effect = _EffectService:PlayEffectAttached(RUID, Stone, Vector3(stringposx,stringposy,0), self.RUIDInfo[RUID]["Rotation"], Vector3(self.RUIDInfo[RUID]["ScaleX"], self.RUIDInfo[RUID]["ScaleY"], 1),
							self.RUIDInfo[RUID]["Loop"], options)
		end
