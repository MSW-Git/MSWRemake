		end
		
		if _UserService.LocalPlayer.TeamManager.HP < tonumber(_UtilLogic:SubString(self.Entity.Name,6,1)) then
			self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode("#3859ac")
