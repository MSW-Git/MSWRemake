@Component
script NumChange extends Component

	property number Timer = 0

	@ExecSpace("Client")
	method void Swaping(table Pool)
		-- 숫자 풀에서 순환하며 텍스트를 변경하는 애니메이션 시작
		local index = 1
		local swapingnum = function()
			self.Entity.TextComponent.Text =tostring(math.floor(Pool[index]))
			index += 1
			
			if index > #Pool then
				index = 1
			end
		end
		
		self.Timer=_TimerService:SetTimerRepeat(swapingnum, 0.7)
	end

	@ExecSpace("Client")
	method void StopTimer()
		-- 숫자 변경 타이머를 중지하고 초기화
		_TimerService:ClearTimer(self.Timer)
		self.Timer = 0
	end

	@ExecSpace("Client")
	method void StopNum(integer values)
		-- 타이머를 중지하고 최종 숫자 값으로 텍스트 설정
		self:StopTimer()
		self.Entity.TextComponent.Text = tostring(math.floor(values))
	end

end