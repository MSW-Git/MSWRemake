@Component
script RuneCardBuffComponent extends Component

	property integer Attack = 1

	property integer Speed = 2

	property integer Defense = 3

	property integer BloodSucking = 4

	property integer Weakening = 5

	property integer Debuff = 6

	property integer ChangeUnit = 7

	@ExecSpace("Client")
	method void ChangeUnitEffect(integer type, any value, string IconRUID)
		-- 룬카드 버프 효과에 따른 파티클 이펙트 생성 및 재생
		self.Entity.BasicParticleComponent.Enable = false
		self.Entity:GetChildByName("Icon").SpriteParticleComponent.Enable = false
		
		if type < 7 then
			local colorlist = {"#ff8b8b","#8bfbff","#ffd68b","#e88cef","#faff18","#000000"}
			
			self.Entity.BasicParticleComponent.Color = Color.FromHexCode(colorlist[type])
			self.Entity.BasicParticleComponent.ParticleType = BasicParticleType.UpperCylinder
			self.Entity:GetChildByName("Icon").SpriteParticleComponent.SpriteRUID = IconRUID
			
			if type == 6 then
				self.Entity.TransformComponent.Position.y += 1
				self.Entity.TransformComponent.ZRotation = 180
				self.Entity:GetChildByName("Icon").Enable = false
			end
			
			_TimerService:SetTimerOnce(function() self.Entity.BasicParticleComponent.Enable = true self.Entity:GetChildByName("Icon").SpriteParticleComponent.Enable = true end, 0.01)
			_TimerService:SetTimerOnce(function() self.Entity:Destroy() end, 1)
		elseif type==7 then
			--대기석 유닛 변화(룬 카드 덴마RC20039 효과)
			local colorlist = {"#8d8d8d","#54efaf","#81eff7","#d7b8ff","#ffd038","#ffffff"}
			self.Entity.BasicParticleComponent.Color = Color.FromHexCode(colorlist[value])
			
			self.Entity.BasicParticleComponent.ParticleType = BasicParticleType.SpinField
			self.Entity.BasicParticleComponent.Loop = true
			self.Entity.TransformComponent.Position.y += 0.5
			
			_TimerService:SetTimerOnce(function() self.Entity.BasicParticleComponent.Enable = true end, 0.01)
			
			local changeparticle = function()
				local pos = self.Entity.TransformComponent.Position:Clone()
				if value == 6 then
					_EffectService:PlayEffectAttached("a7963c601d544ee9b68b6e0db72e9b8e", self.Entity.Parent,Vector3(pos.x, pos.y-0.5 ,pos.z), 0, Vector3(1.5, 1.5, 1))
				else
					_EffectService:PlayEffectAttached("a7963c601d544ee9b68b6e0db72e9b8e", self.Entity.Parent, Vector3(pos.x, pos.y-0.5, pos.z), 0, Vector3(1.5, 1.5, 1), false, {["MaterialID"] = "material://a662a412-9e11-4249-b8ef-02515c716e8d"})
				end
				
				self.Entity:Destroy()
			end
			
			_TimerService:SetTimerOnce(changeparticle, 1)
			
		end
		
	end

	@ExecSpace("Client")
	method void Init_ver2(integer stattype, any value)
		-- 스탯 타입에 따른 버프 UI 초기화 및 설정
		self.Entity.Enable=true
		self.Entity.BasicParticleComponent.Enable=false
		local TextUI=self.Entity:GetChildByName("StatText")
		local IconUI=self.Entity:GetChildByName("Icon")
		
		if not isvalid(IconUI) then log_error("엔터티가 없음") return end
		
		if _UtilLogic:IsNilorEmptyString(_RuneCardDirectEnum.StatText[stattype]) then
			--아이콘
			IconUI.Enable=true
			IconUI.SpriteParticleComponent.Enable=false
			IconUI.SpriteParticleComponent.SpriteRUID=_RuneCardDirectEnum.StatIcon[stattype]
			
		else
			TextUI.TextComponent.Text=_RuneCardDirectEnum.StatText[stattype]
			
			TextUI.Enable=true
		end
		
		
		
		local colorlist_P={"#fffe00","","","#ff7700","#8000ff","","","#00dff1","#ffbb80","#c080ff","#c10000","#ff2780","#fff538","#0094ff","","","","#eaff80","#ff0000","#ff0000"}
		local colorlist_C={"#fffe00","","","#ff7700","#8000ff","","","#00dff1","#ff7700","#8100ff","#c10000","#ff0069","#fff200","#0094ff","","","","#d5ff00","#ff0000","#ff0000"}
		
		if _UtilLogic:IsNilorEmptyString(colorlist_P[stattype]) then self.Entity:Destroy() return end
		
		if self.Entity.Name == "Buff" then
			IconUI.SpriteParticleComponent.Color = Color.FromHexCode(colorlist_C[stattype])
		else
			IconUI.SpriteParticleComponent.Color = Color.FromHexCode(colorlist_C[stattype])
		end
		
		--전투 중에 발생한 버프는 이펙트 알파 설정값 적용
		if _UserService.LocalPlayer.GameManager.PhaseType == "Battle" or _UserService.LocalPlayer.GameManager.PhaseType == "Setting" then
			self.Entity.BasicParticleComponent.Color.a = _ESCMenuService.skillEffectAlpha/100
			IconUI.SpriteParticleComponent.Color.a = _ESCMenuService.skillEffectAlpha/100
			TextUI.TextComponent.FontColor.a = _ESCMenuService.skillEffectAlpha/100
		end
		
		self.Entity.BasicParticleComponent.ParticleType = BasicParticleType.UpperCylinder
		self.Entity.BasicParticleComponent.Color =  Color.FromHexCode(colorlist_P[stattype])
		
		self.Entity.BasicParticleComponent.Enable = true
		
		if TextUI.Enable then
			local startpos=TextUI.UITransformComponent.WorldPosition:Clone():ToVector2()
			if self.Entity.Name == "Buff" then
				_TweenLogic:MoveTo(TextUI, Vector2(startpos.x, startpos.y+0.3), 1, EaseType.Linear)
			else
				_TweenLogic:MoveTo(TextUI, Vector2(startpos.x, startpos.y-0.3), 1, EaseType.Linear)
			end
			
			_TimerService:SetTimerOnce(function() self.Entity:Destroy() end, 1)
		else
			IconUI.SpriteParticleComponent.Enable = true
			
			_TimerService:SetTimerOnce(function() self.Entity:Destroy() end, 1)
		end
		
	end

end