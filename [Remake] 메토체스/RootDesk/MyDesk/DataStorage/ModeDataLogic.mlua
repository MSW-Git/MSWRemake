@Logic
script ModeDataLogic extends Logic

	@Sync
	property string WorldVersion = ""

	@Sync
	@Description("현재 시즌")
	property number Season = 0

	@Sync
	@Description("현재 분기")
	property number OrdinalNumber = 0

	@Sync
	@Description("랭크모드의 이번 시즌/분기에 적용되는 페널티 리스트")
	property SyncTable<string> SetRankPenalties

	@Sync
	@Description("랭크모드 이번 시즌/분기에 적용되는 점수 기준")
	property string RankScoreCriteriaID = ""

	@Sync
	@Description("다음 분기 변경 시각")
	property SyncTable<string, integer> NextOrdinalUpdateTime

	property number OrdinalUpdateCheckTime = 0

	property number OrdinalUpdateFullTime = 0

	@Sync
	property number NowRankSeason = 0

	method void OnBeginPlay()
		-- 게임 시작 시 모드 데이터 초기화 및 시즌 정보 로드
		if self:IsServer() then
			log("ModeDataLogic : OnBeginPlay()")
			self:GetSeasonData()
			
			self.OrdinalUpdateCheckTime = 11
			self.OrdinalUpdateFullTime = 10
			
			self:GetLeftTimeToNextOrdinal()
		else
			local function rmBtnFnc()
				self:RefreshUI_RankModeButton()
			end
			
			_TimerService:SetTimerOnce(rmBtnFnc, 3)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 300초+ 무작위 시간마다 분기 업데이트 여부를 검사합니다.
		-----------------------------------------------------------
		self.OrdinalUpdateCheckTime += delta
		
		if self.OrdinalUpdateCheckTime > self.OrdinalUpdateFullTime then
		    -- 다음 검사 주기
		    self.OrdinalUpdateCheckTime = 0
			self.OrdinalUpdateFullTime = 60
			
			-- 현재 UTC Time을 기준으로 분기 숫자를 비교합니다.
			-- 업데이트가 필요한 경우, 업데이트를 진행합니다.	
			local season = self:GetVersionInfo("season")
			local ordinal = self:GetVersionInfo("ordinal")
			
			-- 업데이트 필요 여부 검사
			if season ~= self.Season or ordinal ~= self.OrdinalNumber then
				
				-- 이미 랭크모드 접속 중인 플레이어들 게임에서 추방
				local users = _UserService.UserEntities
				for userID, user in pairs(users) do
					if user.CurrentMap.MapComponent.IsDynamicMap == true and user.GameManager.ModeType == "Rank" then 
					--if user.CurrentMapName == "Arena" and user.GameManager.ModeType == "Rank" then
						user.GameManager:MoveToLobby("GameEnd")
						 _UIToast:ShowMessageByLocalizingKey("Ranking_CoolTime", userID)
					end
				end
				
				-- 업데이트 수행		
				self:GetSeasonData()
			 	self:RefreshUI_RankModeButton()
			end
			
			-- 다음 업데이트까지 남은 시간이 1시간 미만인 경우 랭크 모드 진입 불가
		    local leftTimeToNextUpdate = self:GetLeftTimeToNextOrdinal()
		    if leftTimeToNextUpdate["days"] <= 0 and leftTimeToNextUpdate["hours"] <= 0 then
		        _UIToast:ShowMessageByLocalizingKey("Ranking_CoolTime")
		        log("랭킹 갱신을 위해 다음 1시간동안 랭크 모드를 이용할 수 없습니다.")
		       self:RefreshUI_RankModeButton()
		    end
		    
		end
	end

	@ExecSpace("ServerOnly")
	method void CountUserToSeason(string userID)
		-- 해당 시즌에, 접속한 인원 수를 기록합니다.
		-- 유저가 해당 시즌에 처음으로 접속하면 이 함수를 호출합니다.
		
		----------------------------------------------------------------------------------
		local season = self:GetVersionInfo("season")
		local ordinalNumber = self:GetVersionInfo("ordinal")
		---------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local gameManager = user.GameManager
		----------------------------------------------------------------------------------
		-- 1-1. 유저가 해당 시즌에 처음 접속했는지 확인
		local recentSeason = -1
		local recentOrdinalNumber = -1
		local recentSeasonCheckFncCount = 0
		local function recentSeasonCheckFnc(e, key, value)
			if e ~= 0 then
				recentSeasonCheckFncCount += 1
				if recentSeasonCheckFncCount >= 10 then
					_UserService:KickUser(userID, KickReason.WorldError)
				else
					_DataStorageService:GetUserDataStorage(userID):GetAsync(string.format("RecentSeason_%s", _PlayerDataLogic.SetVer), recentSeasonCheckFnc)
				end
			else
				if isvalid(value) then
					local vTable = _UtilLogic:Split(value, "/")
					recentSeason = tonumber(vTable[1])
					if isvalid(vTable[2]) then
						recentOrdinalNumber = tonumber(vTable[2])
					end
				end
				
				-- 1-2. 처음 접속했다면, 기록
				local seasonInfo = string.format("%d/%d", season, ordinalNumber)
				
				if recentSeason == season and recentOrdinalNumber == ordinalNumber then
					-- 최근 시즌, 최근 분기인 경우 따로 기록 없이 넘어감
				else
					-- 시즌 바뀐 거 체크
					gameManager.ChangeSeason = true
					
					-- 최근 시즌 접속 기록
					local err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("RecentSeason_%s", _PlayerDataLogic.SetVer), seasonInfo)
					for i = 1, 10 do
						if err == 0 then
							break
						elseif i == 10 then
							_UserService:KickUser(userID, KickReason.WorldError)
						else
							err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("RecentSeason_%s", _PlayerDataLogic.SetVer), seasonInfo)
						end
					end
					
					-- 분기바뀔 때마다 티어 관련 업적 초기화
					_AchievementService:Request_RankInit(userID)
					
					-- 가장 최근에 접속한 시즌,분기의 랭크를 확인하고 최고 도달인 경우 기록
					if recentSeason ~= -1 and recentOrdinalNumber ~= -1 then
						_PlayerDataLogic:CheckPlayerHighRankData(userID, recentSeason, recentOrdinalNumber)
					end
				end
			end
		end
		
		_DataStorageService:GetUserDataStorage(userID):GetAsync(string.format("RecentSeason_%s", _PlayerDataLogic.SetVer), recentSeasonCheckFnc)
		-----------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void GetModeClearCountData(string userID)
		-- 클리어 카운트
		-------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local pDataComponent = user.PlayerDataComponent
		-------------------------------------------------------------
		-- 클리어 레벨 받아오기
		local geterr, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if geterr == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				geterr, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		log("ClearLevelByMode Load = ", cLevelStringValue)
		if isvalid(cLevelStringValue) and cLevelStringValue ~= "NIL" then
			-- Season/ClearLevel,Season/ClearLevel..
			
			local cTable = _UtilLogic:Split(cLevelStringValue, ",")
			for _, cValue in pairs(cTable) do
				local keyInfo = _UtilLogic:Split(cValue, "/")
				local key = keyInfo[1]
				local value = tonumber(keyInfo[2])
				
				pDataComponent.ClearLevelByMode[key] = value
			end
		end
		-------------------------------------------------------------
		-- 클리어 스테이지 받아오기
		local cs_err, cs_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearStageByModeData_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if cs_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				cs_err, cs_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearStageByModeData_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		if isvalid(cs_Value) then
			local csTable = _UtilLogic:StringToTable(cs_Value)
			for k, v in pairs(csTable) do
				pDataComponent.ClearStageByMode[k] = v
			end
		end
		-------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method SyncTable<string, number> SaveRankModeScoreData(boolean clear, number modeLevel, number stage, number round, string userID)
		-- 랭크 모드 점수를 측정하여 저장하는 함수입니다.
		------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		local coachManager = user.CoachManager
		local teamBStat = user.TeamBattleStatistics
		------------------------------------------------------------------
		-- return value
		local returnValue = {
			["Score_Default"] = 0,			-- 도달한 라운드 비례 점수
			["Score_RandomCriteria"] = 0,	-- 무작위 기준 점수
			["Rank"] = 1,					-- 도달한 순위
			["Rank_Rate"] = 0.01,			-- 도달한 순위가 상위 몇 %인지
		}
		
		-- 1. 점수 측정
		local score = 0
		
		-- (1,2 순위)_ 클리어 여부 및 도달 스테이지/라운드
		if clear then
			score = modeLevel * 2500000
		else
			score = (modeLevel-1) * 2500000 + ((stage - 1) * 3 + round) * 100000  
		end
		
		returnValue["Score_Default"] = score
		
		-- (3 순위)_ 현재 기준에 따라 점수 측정
		-- RankScoreCriteriaID
		if self.RankScoreCriteriaID == "CT10001" then
			-- 플레이 타임이 짧은 순서대로
			score += math.max(0, 100000 - gameManager.PlayTime)
		elseif self.RankScoreCriteriaID == "CT10002" then
			-- 단일 유닛이 가장 높은 가해량을 기록
			if isvalid(teamBStat.SetRankAmount["CT10002"]) then
				score += teamBStat.SetRankAmount["CT10002"] * 0.1
			end
		elseif self.RankScoreCriteriaID == "CT10003" then
			-- 단일 유닛이 가장 높은 피해량을 기록
			if isvalid(teamBStat.SetRankAmount["CT10003"]) then
				score += teamBStat.SetRankAmount["CT10003"] * 0.1
			end
		elseif self.RankScoreCriteriaID == "CT10004" then
			-- 모든 라운드 동안 생존한 아군 수 (누적)
			if isvalid(teamBStat.SetRankAmount["CT10004"]) then
				score += teamBStat.SetRankAmount["CT10004"]
			end
		elseif self.RankScoreCriteriaID == "CT10005" then
			-- 최종 팀 가치 (전장 유닛)
			if isvalid(teamBStat.SetRankAmount["CT10005"]) then
				score += teamBStat.SetRankAmount["CT10005"]
			end
		elseif self.RankScoreCriteriaID == "CT10006" then
			-- 룬 카드 총 가치
			local costTable = {4, 7, 12, 25}
			local totalCost = 0
			for _, runeUID in pairs(teamManager.OwnRunes) do
				local runeIDInfo = _UtilLogic:Split(runeUID, "_")
				local grade = math.floor(tonumber(string.sub(runeIDInfo[1], 3, -1)) / 10000)
				totalCost += costTable[grade]
			end
			score += (500 * totalCost)
		elseif self.RankScoreCriteriaID == "CT10007" then
			-- 남은 하트 수량
			score += (1000 * teamManager.HP)
		elseif self.RankScoreCriteriaID == "CT10008" then
			-- 활성화된 시너지 개수
			local activateSynergyCount = 0
			-- 시너지 활성화 여부 체크를 위해 최소로 필요한 숫자 테이블 가져오기
			local synergyTable = _DataService:GetTable("SynergyInfo")
			local tableRowCount = synergyTable:GetRowCount()
			local activateConditionTable = {}
			
			for i = 1, tableRowCount do
				local synergyRow = synergyTable:GetRow(i)
				local synergyID = synergyRow:GetItem("SynergyID")
				
				for i = 1, 5 do
					local count = synergyRow:GetItem(string.format("NeedCount_step%d", i))
					if isvalid(tonumber(count)) then
						activateConditionTable[synergyID] = tonumber(count)
						
						if i ~= 3 or activateConditionTable[synergyID] ~= 1 then
							-- 단일 고유 시너지가 아닌 경우
							if isvalid(teamManager.OnFieldSynergy[synergyID]) and (teamManager.OnFieldSynergy[synergyID] >= activateConditionTable[synergyID]) then
								activateSynergyCount += 1
							end
						end
						break
					end
				end
			end
			
			score += (1000 * activateSynergyCount)
		elseif self.RankScoreCriteriaID == "CT10009" then
			-- 게임 종료 후 남은 골드
			score += teamManager.Golds
		elseif self.RankScoreCriteriaID == "CT10010" then
			-- 최종 라운드에 장착한 완성 아이템 개수 (상징 아이템 포함)
			if isvalid(teamBStat.SetRankAmount["CT10010"]) then
				score += teamBStat.SetRankAmount["CT10010"]
			end
		elseif self.RankScoreCriteriaID == "CT10011" then
			-- 단일 유닛이 가장 높은 회복량을 기록
			if isvalid(teamBStat.SetRankAmount["CT10011"]) then
				score += teamBStat.SetRankAmount["CT10011"] * 0.1
			end
		elseif self.RankScoreCriteriaID == "CT10012" then
			-- 배치된 캐릭터의 성급이 낮을수록 높은 점수 부여
			if isvalid(teamBStat.SetRankAmount["CT10012"]) then
				score += (100000 - teamBStat.SetRankAmount["CT10012"])
			else
				score += 100000
			end
		elseif self.RankScoreCriteriaID == "CT10013" then
			-- 아이템 구매 횟수
			if isvalid(teamBStat.SetRankAmount["CT10013"]) then
				score += teamBStat.SetRankAmount["CT10013"]
			end
		elseif self.RankScoreCriteriaID == "CT10014" then
			-- 게임 종료 시, 사용중인 레어 룬카드의 개수
			local totalAmount = 0
			for _, runeUID in pairs(teamManager.OwnRunes) do
				local runeIDInfo = _UtilLogic:Split(runeUID, "_")
				local grade = math.floor(tonumber(string.sub(runeIDInfo[1], 3, -1)) / 10000)
				if grade == 2 then
					totalAmount += 1
				end
			end
			score += (500 * totalAmount)
		elseif self.RankScoreCriteriaID == "CT10015" then
			-- 단일 유닛의 가장 높은 스킬 횟수
			if isvalid(teamBStat.SetRankAmount["CT10015"]) then
				score += teamBStat.SetRankAmount["CT10015"]
			end
		elseif self.RankScoreCriteriaID == "CT10016" then
			-- 더 낮은 코치 비용
			local totalCost = 0
			for _, cost in pairs(coachManager.PlayCoachesCost) do
				totalCost += cost
			end
			score += (1000 * (7-totalCost))
		end
		
		score = math.floor(score)
		log(self.RankScoreCriteriaID, " Score = ", score)
		returnValue["Score_RandomCriteria"] = score - returnValue["Score_Default"]
		
		------------------------------------------------------------------
		local dbKey = string.format("RankModeRanking_%s_%d_%d", _PlayerDataLogic.SetVer, self.Season, self.OrdinalNumber)
		local rankingDB = _DataStorageService:GetSortableDataStorage(dbKey)
		------------------------------------------------------------------
		-- 데이터 불러오기
		local userDB = _DataStorageService:GetUserDataStorage(userID)
		local setKey = string.format("RankScore_%s_%d_%d", _PlayerDataLogic.SetVer, self.Season, self.OrdinalNumber)
		local keyInfo = DataStorageKeyInfo(userID, string.format("%d_%d", self.Season, self.OrdinalNumber), user.PlayerComponent.Nickname)
		
		local sethighScore = 0
		local geterr, sc_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(setKey)
		for i = 1, 10 do
			if geterr == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				geterr, sc_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(setKey)
			end
		end
		
		if isvalid(sc_Value) then
			sethighScore = tonumber(sc_Value)
		end
		------------------------------------------------------------------
		
		------------------------------------------------------------------
		
		-- 비교 후 점수 저장
		if sethighScore < score then
			-- 2. 순위 확인 및 데이터에 저장
			local fncCount = 0
			local function rankInFnc(error, key)
				if error ~= 0 then
					fncCount += 1
					if fncCount > 20 then
						log("점수 등록 실패")
						_UserService:KickUser(userID, KickReason.ETC)
						return
					end
					rankingDB:SetByInfoAsync(key, score, rankInFnc)
				else
					self:LoadRankingData(self.Season, self.OrdinalNumber)
				end
			end
			rankingDB:SetByInfoAsync(keyInfo, score, rankInFnc)
			
			-- 3. 분기 내 하이 스코어 유저 별 개인 데이터에 저장
			local userFncCount = 0
			local function scoreRecordFnc(error, key)
				if error ~= 0 then
					userFncCount += 1
					if userFncCount > 20 then
						log("점수 등록 실패")
						_UserService:KickUser(userID, KickReason.ETC)
						return
					end
					userDB:SetAsync(key, tostring(score), scoreRecordFnc)
				end
			end
			userDB:SetAsync(setKey, tostring(score), scoreRecordFnc)
		end
		------------------------------------------------------------------
		-- 4. 점수 
		return returnValue
	end

	@ExecSpace("Server")
	method table LoadRankingData(number season, number ordinalNum)
		-- 랭킹 데이터를 불러오는 곳입니다.
		-- (임시) 로그를 찍어 현재 순위가 어떻게 등록되어 있는지 확인합니다.
		------------------------------------------------------------------
		local dbKey = string.format("RankModeRanking_%s_%d_%d", _PlayerDataLogic.SetVer, self.Season, self.OrdinalNumber)
		local rankingDB = _DataStorageService:GetSortableDataStorage(dbKey)
		------------------------------------------------------------------
		
		local err, rankPages = rankingDB:GetSortedAndWait(SortDirection.Descending, 1, math.maxinteger)
		for i = 1, 10 do
			if err ~= 0 then
				err, rankPages = rankingDB:GetSortedAndWait(SortDirection.Descending, 1, math.maxinteger)
			else
				break
			end
		end
		
		if err ~= 0 then
			log("err")
			return
		end
		
		local rankingTable = {}
		
		
		local playerCount = 0
		while true do
			local items = rankPages:GetCurrentPageDatas()
			
			if #items > 0 then
				for _, item in pairs(items) do
					playerCount += 1
					rankingTable[playerCount] = item
					--log(string.format("Rank %d. %s = %d", playerCount, item.KeyInfo.Tag, item.Value))
				end
				
				if rankPages.IsLastPage == true then
					break
				elseif playerCount >= 200 then
					break
				else
					rankPages:MoveToNextPageAndWait()
				end
			else
				break
			end
		end
		
		return rankingTable
	end

	@ExecSpace("ServerOnly")
	method SyncTable<string, number> GetRankModeUserClearPercent(number season, number ordinalNum, string userID)
		-- 시즌 n차 기록 중에서 상위 몇 퍼센트인지 구합니다.
		-----------------------------------------------------------------------------------
		local key = string.format("RankModeClearUserCount_%s_%d_%d", _PlayerDataLogic.SetVer, season, ordinalNum)
		local sortableDataStorage = _DataStorageService:GetSortableDataStorage(key)
		-----------------------------------------------------------------------------------
		-- 0단계 기준 수 가져오기
		local err, allUserCount = sortableDataStorage:GetAndWait("Level_0")
		for i = 1, 10 do
			if err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				err, allUserCount = sortableDataStorage:GetAndWait("Level_0")
			end
		end
		
		if not isvalid(allUserCount) then
			allUserCount = 1
		end
		
		
		-- 현재 유저가 클리어한 단계 기준 수 가져오기
		local err2, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if err2 == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				err2, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		local setTable = {}
		setTable["All"] = 1
		setTable["Percent"] = -1
		
		local clearLevel = 0
		if isvalid(cLevelStringValue) and cLevelStringValue ~= "NIL" then
			local cTable = _UtilLogic:Split(cLevelStringValue, ",")
			for _, cValue in pairs(cTable) do
				local keyInfo = _UtilLogic:Split(cValue, "/")
				local clearKey = keyInfo[1]
				local clearRankLevel = tonumber(keyInfo[2])
				
				if clearKey == string.format("Rank_%d_%d", season, ordinalNum) then
					clearLevel = clearRankLevel
					break
				end
			end
		end
		
		
		if not isvalid(clearLevel) then
			return setTable
		end
		
		
		local modeLevelKey = string.format("Level_%d", clearLevel)
		local err3, userCountToClearedGrade = sortableDataStorage:GetAndWait(modeLevelKey)
		for i = 1, 10 do
			if err3 == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				err3, userCountToClearedGrade = sortableDataStorage:GetAndWait(modeLevelKey)
			end
		end
		
		if not isvalid(userCountToClearedGrade) then
			userCountToClearedGrade = allUserCount
		end
		
		setTable["All"] = allUserCount
		setTable["Percent"] = userCountToClearedGrade / allUserCount * 100
		
		return setTable
	end

	@ExecSpace("ServerOnly")
	method void GetSeasonData()
		-- 시즌 데이터를 불러오는 함수입니다.
		-----------------------------------------------------
		local season = self:GetVersionInfo("season")
		local ordinalNumber = self:GetVersionInfo("ordinal")
		local nowRankSeason = self:GetVersionInfo("RankSeason")
		self.WorldVersion = self:GetVersionInfo("WorldVersion")
		-----------------------------------------------------
		
		-- 25.06.20 신규 코드
		self.Season = season
		self.OrdinalNumber = ordinalNumber
		self.NowRankSeason = nowRankSeason
		
		local versionInfo = _DataService:GetTable("VersionInfo")
		local versionRow = versionInfo:FindRow("SeasonID", string.format("%d.%d", self.Season, self.OrdinalNumber))
			
			-- 랭크 패널티 설정
			local penalties = {
				[1] = "-",
				[2] = versionRow:GetItem("B1"),
				[3] = versionRow:GetItem("B2"),
				[4] = versionRow:GetItem("B3"),
			
				[5] = "-",
				[6] = versionRow:GetItem("S2"),
				[7] = versionRow:GetItem("S3"),
				[8] = versionRow:GetItem("G1"),
				[9] = versionRow:GetItem("G2"),
				[10] = versionRow:GetItem("G3"),
			
				[11] = "-",
				[12] = string.format("%s,%s", versionRow:GetItem("P1"), versionRow:GetItem("P2")),
				[13] = string.format("%s,%s", versionRow:GetItem("P3"), versionRow:GetItem("P4")),
			
				[14] = "-",
				[15] = string.format("%s,%s", versionRow:GetItem("D1"), versionRow:GetItem("D2")),
				[16] = string.format("%s,%s", versionRow:GetItem("D3"), versionRow:GetItem("D4")),
			
				[17] = "-",
				[18] = string.format("%s,%s", versionRow:GetItem("M1"), versionRow:GetItem("M2")),
				[19] = string.format("%s,%s", versionRow:GetItem("M3"), versionRow:GetItem("M4")),
				[20] = versionRow:GetItem("C"),
			}
			table.initialize(self.SetRankPenalties, penalties)
			log("RankPenalties = \n", self.SetRankPenalties)
		
			-- 랭크 기준 설정
			self.RankScoreCriteriaID = versionRow:GetItem("RankCriteria")
			log("RankCriteria = \n", self.RankScoreCriteriaID)
			
			-- 랭크모드 이어하기 데이터가 있는 유저는 날립니다 (접속중인 유저만 해당, 미접속중인 유저는 접속 시 날아감(다른코드에있음))
			local users = _UserService.UserEntities
			for _, user in pairs(users) do
				local gameManager = user.GameManager
			
				if gameManager.NeedDataLoadType == "Rank" then
					gameManager.SetSavedData = false
					_InGameInfoDataLogic:SetSavedDataDB(false, user)
				end
			end
		
			
		
		-----------------------------------------------------
		-- 25.06.20 이전 코드
		--[[
		-- 해당 시즌/분기의 데이터가 DB에 세팅되어 있는지 여부 확인
		local err, setSeason = _DataStorageService:GetGlobalDataStorage(string.format("SeasonData_%s", _PlayerDataLogic.SetVer)):GetAndWait("SetSeasonNum")
		for i = 1, 20 do
			if err == 0 then
				break
			elseif i == 20 then
				log("SeasonData 불러오기 실패")
			else
				err, setSeason = _DataStorageService:GetGlobalDataStorage(string.format("SeasonData_%s", _PlayerDataLogic.SetVer)):GetAndWait("SetSeasonNum")
			end
		end
		
		
		---@type table<string>
		local seasonInfo
		
		local seasonNum = string.format("%d_%d", season, ordinalNumber)
		if isvalid(setSeason) then
			seasonInfo = _UtilLogic:Split(setSeason, "_")
			-- 가장 최근 저장된 시즌 데이터 넘버가 최신이 아닌 경우
			if season ~= tonumber(seasonInfo[1]) then
				self:SetRankPenaltyAndRankScoreCriteriaData(seasonNum)
				self:SetSeasonData(season, ordinalNumber, nowRankSeason)
			-- 가장 최근 저장된 분기 데이터 넘버가 최신이 아닌 경우
			elseif ordinalNumber >= tonumber(seasonInfo[2]) then
				if ordinalNumber >= tonumber(seasonInfo[2]) + 2 then
					self:SetRankPenaltyAndRankScoreCriteriaData(seasonNum)
				end
				self:SetSeasonData(season, ordinalNumber, nowRankSeason)
			else
				self.NowRankSeason = nowRankSeason
			end
		else
			-- SetSeasonData
			seasonInfo = _UtilLogic:Split(seasonNum, "_")
			self:SetRankPenaltyAndRankScoreCriteriaData(seasonNum)
			self:SetSeasonData(season, ordinalNumber, nowRankSeason)
		end
		
		
		-----------------------------------------------------
		-- 시즌 단위로 불러와야 할 데이터
		self.Season = season
		-----------------------------------------------------
		-- 분기 단위로 불러와야 할 데이터
		self.OrdinalNumber = ordinalNumber
		local storageName = string.format("Season_%s_%d_%d", _PlayerDataLogic.SetVer, self.Season, self.OrdinalNumber)
		log("storageName = ", storageName)
		local storage = _DataStorageService:GetGlobalDataStorage(storageName)
		---------------------------------------------------------------
		-- RankPenalties1
		local p_err, pValue = storage:GetAndWait("SetRankPenalties")
		for i = 1, 20 do
			if p_err == 0 then
				break
			elseif i == 20 then
				log("SetRankPenalties 불러오기 실패")
			else
				p_err, pValue = storage:GetAndWait("SetRankPenalties")
			end
		end
		
		if isvalid(pValue) then
			table.clear(self.SetRankPenalties)
			local penaltiesData = _UtilLogic:StringToTable(pValue)
			log("임시로그: penaltiesData = ", penaltiesData)
			for _, penaltyIDs in pairs(penaltiesData) do
				table.insert(self.SetRankPenalties, penaltyIDs)
			end
			log("SetRankPenalties Set")
		end
		---------------------------------------------------------------
		-- RankScoreCriteriaType
		local c_err, cValue = storage:GetAndWait("RankScoreCriteriaID")
		for i = 1, 20 do
			if c_err == 0 then
				break
			elseif i == 20 then
				log("RankScoreCriteriaType 불러오기 실패")
			else
				c_err, cValue = storage:GetAndWait("RankScoreCriteriaID")
			end
		end
		
		log("cValue = ", cValue)
		
		if isvalid(cValue) then
			self.RankScoreCriteriaID = cValue
			log("RankScoreCriteriaID Set = ", cValue)
		end
		---------------------------------------------------------------
		]]
	end

	@ExecSpace("ServerOnly")
	method void SetSeasonData(number setSeasonNum, number setOrdinalNum, number setRankSeason)
		-- 시즌 데이터를 설정하는 곳입니다.
		-- 기존 : 분기 데이터 설정 따로 하며, 패널티랑 랭크 점수 측정 기준 데이터의 값을 설정하고 DB에 저장하는 방식
		-- 변경 (25.06.13.) : DB에 저장된 값을 불러와서 값을 설정 (패널티 및 랭크 점수 측정 기준 데이터 DB 저장은 이전 시즌에 미리 해두기)
		-----------------------------------------------------
		self.Season = setSeasonNum
		self.OrdinalNumber = setOrdinalNum
		self.NowRankSeason = setRankSeason
		-----------------------------------------------------
		-- 다음 시즌 패널티, 랭크 점수 측정 기준 데이터 DB 저장
		local nextSeason = string.format("%d_%d", setSeasonNum, setOrdinalNum + 1)
		self:SetRankPenaltyAndRankScoreCriteriaData(nextSeason)
	end

	@ExecSpace("Client")
	method string GetRankTierString(integer level)
		-- level에 해당하는 랭크모드의 티어를 string 형태로 반환합니다. (예: lv1 = 아이언, lv2 = 브론즈1, ...)
		--------------------------------------------------
		local rankModeInfo = _DataService:GetTable("RankModeInfo")
		
		local dataRow = rankModeInfo:FindRow("Level", string.format("%d", level))
		local tierName = dataRow:GetItem("Tier")
		local tierGrade = dataRow:GetItem("Tier_Grade")
		
		if tierGrade == "-" then
			return _LocalizationService:GetText("RankMode_"..tierName)
		else
			return _LocalizationService:GetText("RankMode_"..tierName).." "..tierGrade
		end
	end

	@ExecSpace("Client")
	method void RefreshUI_RankModeButton()
		------------------------------------------------------------------------
		local ui_rankModeButton = _EntityService:GetEntityByPath("/ui/Lobby_HUD/Button_RankMode")
		------------------------------------------------------------------------
		-- 다음 업데이트까지 1시간 남은 상태가 아닌가
		local leftTimeToNextUpdate = self:GetLeftTimeToNextOrdinal()
		
		if (leftTimeToNextUpdate["days"] <= 0 and leftTimeToNextUpdate["hours"] <= 0) then
			ui_rankModeButton.ButtonComponent.Enable = false
		------------------------------------------------------------------------		
		else
			local playerDataComponent = _UserService.LocalPlayer.PlayerDataComponent
			
			-- 모드 별 클리어한 레벨
			local singleModeClearedLevel = playerDataComponent.ClearLevelByMode[string.format("Single_%.1f", _ModeDataLogic.Season)] 
			local rankModeClearedLevel = playerDataComponent.ClearLevelByMode[string.format("Rank_%d_%d", _ModeDataLogic.Season, _ModeDataLogic.OrdinalNumber)]
			
			-- 싱글 모드 4단계를 클리어했는가
			if not isvalid(singleModeClearedLevel) then
				ui_rankModeButton.ButtonComponent.Enable = false
			elseif singleModeClearedLevel < 4 then
				ui_rankModeButton.ButtonComponent.Enable = false
			else
				ui_rankModeButton.ButtonComponent.Enable = true
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method any GetVersionInfo(string type)
		-- UTC.DateTime을 기반으로 현재의 월드 버전(string), 시즌, 분기 번호를 가져옵니다.
		-- type = "season" or "ordinal" or "WorldVersion"
		----------------------------------------------------------
		-- Get Current Date Time
		local utcNow = DateTime.UtcNow
		
		
		-- 게임 정보 테이블에서 열을 비교합니다.
		local versionInfo = _DataService:GetTable("VersionInfo")
		for i=1, versionInfo:GetRowCount() do
			local row = versionInfo:GetRow(i)
			local rowYear = tonumber(row:GetItem("Year"))
			local rowMonth = tonumber(row:GetItem("Month"))
			local rowDay = tonumber(row:GetItem("Day"))
			local rowHour = tonumber(row:GetItem("Hour"))
			local rowMinute = tonumber(row:GetItem("Minute"))
			
			local rowTime = DateTime(rowYear, rowMonth, rowDay, rowHour, rowMinute, 0)
			
			if utcNow >= rowTime then
				continue
			end
			-----------------------------------------
			i -= 1
			row = versionInfo:GetRow(i)
			local rowSeason = _UtilLogic:Split(row:GetItem("SeasonID"), ".")
			
			local returnValue = {
				["WorldVersion"] = row:GetItem("WorldVersion"),
				["season"] = tonumber(rowSeason[1]),
				["ordinal"] = tonumber(rowSeason[2]),
				["RankSeason"] = tonumber(row:GetItem("RankSeason")),
			}
				
			return returnValue[type]
		end
		
		
		return 0
	end

	method SyncTable<string, integer> GetLeftTimeToNextOrdinal()
		-- 다음 분기까지 남은 시간을 가져옵니다.
		-- ["days"], ["hours"], ["minutes", ["seconds"] 로 남은 일/시/분/초를 int32 타입으로 변환할 수 있습니다.
		----------------------------------------------------------------------------------
		-- Get Current Date Time
		local utcNow = DateTime.UtcNow
		local year = utcNow.Year
		local month = utcNow.Month
		local day = utcNow.Day
		----------------------------------------------------------------------------------
		-- [서버] 게임 정보 테이블에서 열을 비교합니다.
		if self:IsServer() then
			local versionInfo = _DataService:GetTable("VersionInfo")
			for i=1, versionInfo:GetRowCount() do
				local row = versionInfo:GetRow(i)
				
				local rowYear = tonumber(row:GetItem("Year"))
				local rowMonth = tonumber(row:GetItem("Month"))
				local rowDay = tonumber(row:GetItem("Day"))
				local rowHour = tonumber(row:GetItem("Hour"))
				local rowMinute = tonumber(row:GetItem("Minute"))
				
				local rowTime = DateTime(rowYear, rowMonth, rowDay, rowHour, rowMinute, 0)
				if utcNow >= rowTime then
					continue
				end
				
				-----------------------------------------		
				local nextOrdinalStartDate = rowTime
				
				self.NextOrdinalUpdateTime["Year"] = nextOrdinalStartDate.Year
				self.NextOrdinalUpdateTime["Month"] = nextOrdinalStartDate.Month
				self.NextOrdinalUpdateTime["Day"] = nextOrdinalStartDate.Day
				self.NextOrdinalUpdateTime["Hour"] = nextOrdinalStartDate.Hour
				self.NextOrdinalUpdateTime["Minute"] = nextOrdinalStartDate.Minute
			
				-----------------------------------------
				local subedTime = nextOrdinalStartDate - utcNow 
				return {
					["days"] = subedTime.Days,
					["hours"] = subedTime.Hours,
					["minutes"] = subedTime.Minutes,
					["seconds"] = subedTime.Seconds
				}
			end
		----------------------------------------------------------------------------------	
		-- [클라] 서버에서 저장해준 내용 기반으로 비교
		else		
			if self.NextOrdinalUpdateTime["Year"] == nil then
				return {
					["days"] = 999,
					["hours"] = 999,
					["minutes"] = 999,
					["seconds"] = 999,
				}
			end
			
			local nextOrdinalStartDate = DateTime(
				self.NextOrdinalUpdateTime["Year"], 
				self.NextOrdinalUpdateTime["Month"], 
				self.NextOrdinalUpdateTime["Day"],
				self.NextOrdinalUpdateTime["Hour"],
				self.NextOrdinalUpdateTime["Minute"],
				0)
			local subedTime = nextOrdinalStartDate - utcNow
			return {
					["days"] = subedTime.Days,
					["hours"] = subedTime.Hours,
					["minutes"] = subedTime.Minutes,
					["seconds"] = subedTime.Seconds
			}
		end
	end

	@ExecSpace("ServerOnly")
	method void SaveClearStageNumData(string modeType, number stage, string userID)
		-- 일정 순위권 밖의 유저는, 따로 순위를 측정하지 않고 현재 순위 구간을 보여줍니다 (상위 n%)
		-- 랭크 모드 난이도 별 클리어 수를 데이터로 저장해 이를 사용합니다.
		----------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		----------------------------------------------------------------------------------
		-- 데이터 기록
		local mType = _UtilLogic:Split(modeType, "_")
		
		if mType[1] == "Challenge" or mType[1] == "Single" then
			playerDataComponent.ClearStageByMode[modeType] = stage
		else
			playerDataComponent.ClearStageByMode[mType[1]] = stage
		end
		
		local stageTable = _UtilLogic:TableToString(playerDataComponent.ClearStageByMode)
		----------------------------------------------------------------------------------
		-- 클리어 스테이지 기록 저장
		local err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("ClearStageByModeData_%s", _PlayerDataLogic.SetVer), stageTable)
		for i = 1, 10 do
			if err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("ClearStageByModeData_%s", _PlayerDataLogic.SetVer), stageTable)
			end
		end
		----------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method boolean SaveModeClearCountData(string modeType, number modeLevel, string userID)
		-- 클리어한 타입, 레벨에 따라 데이터를 저장합니다.
		-- "최초 클리어하여 저장된 경우", true를 반환합니다. (아닌 경우 false)
		----------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local pDataComponent = user.PlayerDataComponent
		if modeType == "Rank" then
			modeType = string.format("Rank_%d_%d", self.Season, self.OrdinalNumber) 
		end
		local mType = _UtilLogic:Split(modeType, "_")
		local clearRankLevel = 0
		----------------------------------------------------------------------------------
		-- 클리어 레벨이 더 높은지 기존 데이터 불러와서 체크
		local geterr, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if geterr == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				geterr, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		if isvalid(cLevelStringValue) and cLevelStringValue ~= "NIL" then
			-- ModeType/ClearLevel,ModeType/ClearLevel..
			
			local cTable = _UtilLogic:Split(cLevelStringValue, ",")
			for _, cValue in pairs(cTable) do
				local keyInfo = _UtilLogic:Split(cValue, "/")
				local key = keyInfo[1]
				
				if key == modeType then
					clearRankLevel = tonumber(keyInfo[2])
					if modeLevel <= clearRankLevel then
						return false
					end
				end
			end
		end
		----------------------------------------------------------------------------------
		-- 랭크 타입의 경우
		if mType[1] == "Rank" then
			----------------------------------------------------------------------------------
			local clearRankLevelKey = string.format("RankModeClearUserCount_%s_%d_%d", _PlayerDataLogic.SetVer, self.Season, self.OrdinalNumber)
			local sortableDataStorage = _DataStorageService:GetSortableDataStorage(clearRankLevelKey)
			
			-- 단계 기준 클리어 인원 수 증가
			log(string.format("%d부터 %d까지", clearRankLevel + math.min(1, modeLevel), modeLevel))
			for checklevel = tonumber(clearRankLevel) + math.min(1, modeLevel), modeLevel do
				local levelKey = string.format("Level_%d", checklevel)
				local err2, value = sortableDataStorage:IncreaseAndWait(levelKey, 1)
				for i = 1, 10 do
					if err2 == 0 then
						break
					elseif i == 10 then
						_UserService:KickUser(userID, KickReason.WorldContent)
					else
						err2, value = sortableDataStorage:IncreaseAndWait(levelKey, 1)
					end
				end
			end
			----------------------------------------------------------------------------------
			-- 현재 클리어 랭크가 가장 높이 도달한 랭크인지 확인
			-- 데이터 불러오기
			local hl_err, hl_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighClearLevelInfo_%s", _PlayerDataLogic.SetVer))
			for i = 1, 10 do
				if hl_err == 0 then
					break
				elseif i == 10 then
					_UserService:KickUser(userID, KickReason.WorldContent)
				else
					hl_err, hl_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighClearLevelInfo_%s", _PlayerDataLogic.SetVer))
				end
			end
			
			local setRankHighLevel = 0
			
			if isvalid(hl_Value) then
				local vTable = _UtilLogic:Split(hl_Value, "/")
				setRankHighLevel = tonumber(vTable[1])
			end
			
			-- 비교 후 저장
			if setRankHighLevel < modeLevel then
				local saveValue = string.format("%d/%d/%d", modeLevel, self.Season, self.OrdinalNumber)
				pDataComponent.HighClearLevelInfo = saveValue
				
				local save_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("HighClearLevelInfo_%s", _PlayerDataLogic.SetVer), saveValue)
				for i = 1, 10 do
					if save_err == 0 then
						break
					elseif i == 10 then
						_UserService:KickUser(userID, KickReason.WorldContent)
					else
						save_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("HighClearLevelInfo_%s", _PlayerDataLogic.SetVer), saveValue)
					end
				end
			end
		end
		----------------------------------------------------------------------------------
		-- 프로퍼티 기록
		user.PlayerDataComponent.ClearLevelByMode[modeType] = tonumber(modeLevel)
		----------------------------------------------------------------------------------
		-- 클리어 기록 저장
		local stringValue = ""
		
		for k, v in pairs(user.PlayerDataComponent.ClearLevelByMode) do
			local keyInfo = string.format("%s/%d", k, v)
			
			stringValue = string.format("%s%s,", stringValue, keyInfo)
		end
		
		
		if stringValue == "" then
			stringValue = "NIL"
		else
			stringValue = string.sub(stringValue, 1, -2)
		end
		
		log("ClearLevelByMode Save = ", stringValue)
		local err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer), stringValue)
		for i = 1, 10 do
			if err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer), stringValue)
			end
		end
		
		return true
	end

	@ExecSpace("ServerOnly")
	method void CheckFirstRank(string userID)
		-- 랭크 첫 판인지 확인합니다.
		local modeType = string.format("Rank_%d_%d", _ModeDataLogic.Season, _ModeDataLogic.OrdinalNumber)
		----------------------------------------------------------------------------------
		-- 기존 데이터 불러와서 체크
		local geterr, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if geterr == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				geterr, cLevelStringValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ClearLevelByModeData_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		if isvalid(cLevelStringValue) and cLevelStringValue ~= "NIL" then
			-- 해당 타입 데이터가 있는지 확인
			local isFirst = true
			
			local cTable = _UtilLogic:Split(cLevelStringValue, ",")
			for _, cValue in pairs(cTable) do
				local keyInfo = _UtilLogic:Split(cValue, "/")
				local key = keyInfo[1]
				
				log("SaveModeClearCountData ClearKey = ", key, cValue)
				if key == modeType then
					isFirst = false
				end
			end
			
			if isFirst then
				self:SaveModeClearCountData(modeType, 0, userID)
			end
		else
			self:SaveModeClearCountData(modeType, 0, userID)
		end 
	end

	@ExecSpace("ServerOnly")
	method void SetRankPenaltyAndRankScoreCriteriaData(string setSeason)
		-- 패널티 및 랭크 점수 측정 기준 데이터 DB 저장하는 함수입니다.
		--------------------------------------------------------------------------------
		-- Penalty 설정
		local penaltyTable = _DataService:GetTable("PenaltyInfo")
		local rankmodeInfo = _DataService:GetTable("RankModeInfo")
		local rankScoreCriteriaInfo = _DataService:GetTable("RankScoreCriteriaInfo")
		
		local penaltyOne = {}
		local penaltyTwo = {}
		local penaltyThree = {}
		local penaltyFour = {}
		
		-- 이미 세팅된 패널티 리스트를 넣어두는 테이블
		local setPenaltyList = {}
		
		for i = 1, penaltyTable:GetRowCount() do
			local pLevel = tonumber(penaltyTable:GetRow(i):GetItem("Level"))
			local penaltyID = penaltyTable:GetRow(i):GetItem("PenaltyID")
			
			if pLevel == 1 then
				table.insert(penaltyOne, penaltyID)
			elseif pLevel == 2 then
				table.insert(penaltyTwo, penaltyID)
			elseif pLevel == 3 then
				table.insert(penaltyThree, penaltyID)
			elseif pLevel == 4 then
				table.insert(penaltyFour, penaltyID)
			end
		end
		
		-- 패널티 세팅 넘버
		
		-- 패널티 세팅
		for i = 1, 20 do
			local pInfo = rankmodeInfo:GetRow(i):GetItem("AddPenalty")
			local pIdxs = _UtilLogic:Split(pInfo, ",")
			local setIDs = ""
			if pIdxs[1] == "-" then
				setIDs = "-"
				table.insert(setPenaltyList, setIDs)
			else
				for j = 1, #pIdxs do
					if pIdxs[j] == "1" then
						local checkIdx = _UtilLogic:RandomIntegerRange(1, #penaltyOne)
						local setPID = penaltyOne[checkIdx]
						setIDs = string.format("%s%s,", setIDs, setPID)
						table.remove(penaltyOne, checkIdx)
					elseif pIdxs[j] == "2" then
						local checkIdx = _UtilLogic:RandomIntegerRange(1, #penaltyTwo)
						local setPID = penaltyTwo[checkIdx]
						setIDs = string.format("%s%s,", setIDs, setPID)
						table.remove(penaltyTwo, checkIdx)
					elseif pIdxs[j] == "3" then
						local checkIdx = _UtilLogic:RandomIntegerRange(1, #penaltyThree)
						local setPID = penaltyThree[checkIdx]
						setIDs = string.format("%s%s,", setIDs, setPID)
						table.remove(penaltyThree, checkIdx)
					elseif pIdxs[j] == "4" then
						local checkIdx = _UtilLogic:RandomIntegerRange(1, #penaltyFour)
						local setPID = penaltyFour[checkIdx]
						setIDs = string.format("%s%s,", setIDs, setPID)
						table.remove(penaltyFour, checkIdx)
					end
				end
				table.insert(setPenaltyList, string.sub(setIDs, 1, -2))
			end
		end
		
		
		log(setSeason, " setRankPenalties")
		log(setPenaltyList)
		-----------------------------------------------------
		-- 랭크 스코어 책정 기준 설정
		local getCTCount = rankScoreCriteriaInfo:GetRowCount()
		local setCriteriaNum = _UtilLogic:RandomIntegerRange(1, getCTCount)
		
		local rankScoreCriteriaID = rankScoreCriteriaInfo:GetRow(setCriteriaNum):GetItem("ID")
		--local rankScoreCriteriaID = rankScoreCriteriaInfo:GetRow(14):GetItem("ID")
		-----------------------------------------------------
		local storageName = string.format("Season_%s_%s", _PlayerDataLogic.SetVer, setSeason)
		-----------------------------------------------------
		-- Penalty 데이터 저장
		local pValue = _UtilLogic:TableToString(setPenaltyList)
		local p_err = _DataStorageService:GetGlobalDataStorage(storageName):SetAndWait("SetRankPenalties", pValue)
		for i = 1, 20 do
			if p_err == 0 then
				break
			elseif i == 20 then
				log("SetRankPenalties 저장 실패")
			else
				p_err = _DataStorageService:GetGlobalDataStorage(storageName):SetAndWait("SetRankPenalties", pValue)
			end
		end
		-----------------------------------------------------
		-- 해당 분기의 랭크 점수 측정 기준 데이터 저장
		local cType_Err = _DataStorageService:GetGlobalDataStorage(storageName):SetAndWait("RankScoreCriteriaID", rankScoreCriteriaID)
		for i = 1, 20 do
			if cType_Err == 0 then
				break
			elseif i == 20 then
				log("RankScoreCriteriaType 저장 실패")
			else
				cType_Err = _DataStorageService:GetGlobalDataStorage(storageName):SetAndWait("RankScoreCriteriaID", rankScoreCriteriaID)
			end
		end
		-----------------------------------------------------
		-- 지금까지 세팅된 시즌 데이터 저장
		local err2 = _DataStorageService:GetGlobalDataStorage(string.format("SeasonData_%s", _PlayerDataLogic.SetVer)):SetAndWait("SetSeasonNum", setSeason)
		for i = 1, 20 do
			if err2 == 0 then
				break
			elseif i == 20 then
				log("SeasonData 저장 실패")
			else
				err2 = _DataStorageService:GetGlobalDataStorage(string.format("SeasonData_%s", _PlayerDataLogic.SetVer)):SetAndWait("SetSeasonNum", setSeason)
			end
		end
		-----------------------------------------------------
	end

end