@Component
script CheatButton_DictionaryType extends Component

	@Description("이 버튼이 속하는 타입입니다. 1은 캐릭터, 2는 아이템, 3은 룬 카드 입니다.")
	property integer Type = 1

	@Description("획득할 캐릭터/아이템/룬 카드의 아이디입니다. 캐릭터나 룬 카드인 경우, 숫자만 입력합니다.")
	property string ID = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 타입별 치트 아이템 획득 버튼 클릭 처리
		if self.Type == 1 then
			_CheatManager:UseCheat("GetUnit_"..self.ID)
		elseif self.Type == 2 then
			_CheatManager:UseCheat("GetItem_"..self.ID)
		elseif self.Type == 3 then
			_CheatManager:UseCheat("GetRuneCard_"..self.ID)
		else
			log("wrong type")
		end
	end

end