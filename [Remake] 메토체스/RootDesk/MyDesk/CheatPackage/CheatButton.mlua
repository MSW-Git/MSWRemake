@Component
script CheatButton extends Component

	property string Key = ""

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 치트 버튼 클릭 시 해당 치트 명령어 실행
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		
		-- 0911 추가: 캐릭터 컬렉션 치트키는, 캐릭터ID/레벨을 함께 Input 받습니다. inputCompo를 두 개 받기 위해 여기 새로 조건을 걸어서 생성합니다.
		if self.Key == "GetCharacterCollect" 
			or self.Key == "GetPlayerOwnedCoach" 
			or  self.Key == "SetAchievementCount" then
			
			local inputs = self.Entity.Parent:GetChildComponentsByTypeName("TextInputComponent", true)
			
			local key = ""
			
			key = self.Key.."_"..inputs[1].Entity.TextComponent.Text.."_"..inputs[2].Entity.TextComponent.Text
			
			_CheatManager:UseCheat(key)
			
			return	
			
		end
		
		---------------------------------------------------------
		local inputCompo = self.Entity.Parent:GetFirstChildComponentByTypeName("TextInputComponent", true)
		if isvalid(inputCompo) then
			
			local key = ""
			
			if self.Key == "GetRuneCard" then 
				local head = "RC"
				local tail = inputCompo.Entity.TextComponent.Text
				key = self.Key.."_"..head..tail
				
			else
				local tail = inputCompo.Entity.TextComponent.Text
				key =  self.Key.."_"..tail
			
			end
			_CheatManager:UseCheat(key)
		else
			_CheatManager:UseCheat(self.Key)
		end
	end

end