@Logic
script CheatManager extends Logic

	property SyncTable<string> AllowedUsers

	property SyncTable<boolean> IsInitialized_DictUI

	@ExecSpace("Server")
	method void OpenCheatPanel()
		-- 치트 패널 열기 (권한 확인 후)
		if self:IsAllowedUser(senderUserId) == false then
			return
		end
		
		self:OpenCheatPanelOnClient(senderUserId)
	end

	@ExecSpace("Client")
	method void OpenCheatPanelOnClient()
		-- 클라이언트에서 치트 UI 활성화
		_EntityService:GetEntityByPath("/ui/EtcGroup").Enable = true
		_EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New").Enable = true
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 치트 허용 사용자 목록 초기화
		if Environment:IsPublishedPlay() then -- 출시 환경에서는 사용할 수 없습니다.
			return
		end
		
		local cheatAllowedUsers = {
			"", -- 여기에 계정 코드를 넣어주세요.
		}
		
		table.clear(self.AllowedUsers)
		for i=1, #cheatAllowedUsers do
			self.AllowedUsers[i] = string.sub(cheatAllowedUsers[i], 5, 17)
		end
	end

	@ExecSpace("Server")
	method boolean IsAllowedUser(string userID)
		-- 사용자가 치트 사용 권한이 있는지 확인
		local isAllowedUser = false
		local cuttedUserID = string.sub(userID, 5, 17)
		log("cuttedUserID = ", cuttedUserID)
		for i=1, #self.AllowedUsers do
			if cuttedUserID == self.AllowedUsers[i] then
				isAllowedUser = true
				break
			end
		end
		
		return isAllowedUser
	end

	@ExecSpace("Server")
	method boolean UseCheat(string cheatKey)
		-- 치트 키를 파싱하여 해당 치트 기능 실행
		-- 치트 사용 조건을 검증합니다.
		if self:IsAllowedUser(senderUserId) == false then
			return
		end
		------------------------------------------------------------------------------------------------------------
		local split = _UtilLogic:Split(cheatKey, "_")
		----------------------------------------------------
		-- 인게임 치트
		----------------------------------------------------
		if split[1] == "phaseOver" then
			self:Cheat_PhaseOver(senderUserId)
			-------------------------------
		elseif split[1] == "GoRound" then
		    local split2 = _UtilLogic:Split(split[2], "-")
		    local stage = tonumber(split2[1])
		    local round = tonumber(split2[2])
		    self:Cheat_GoStage(senderUserId, stage, round)
		    -------------------------------	
		elseif split[1] == "GetCoin" then
		    local amount = tonumber(split[2])
		    self:Cheat_GetCoin(senderUserId, amount)
			-------------------------------
		elseif split[1] == "ChangeLife" then
			local amount = tonumber(split[2])
			self:Cheat_ChangeLife(senderUserId, amount)
		elseif split[1] == "ChangeLevel" then
			local level = tonumber(split[2])
			self:Cheat_ChangeLevel(senderUserId, level)
		-------------------------------
		elseif split[1] == "GetUnit" then
		    local charID = "C"..split[2]
		    self:Cheat_GetCharacter(senderUserId, charID)
		-------------------------------
		elseif split[1] == "GetUnitBySynergy" then
		    local synergyID = "S"..split[2]
		    self:Cheat_GetCharacterBySynergy(senderUserId, synergyID)
		-------------------------------
		elseif split[1] == "GetItem" then
		    local itemID = split[2]
		    self:Cheat_GetItem(senderUserId,itemID)
		-------------------------------	
		elseif split[1] == "GetRuneCard" then
		    local runeID = "RC"..split[2]
		    self:Cheat_GetRuneCard(senderUserId, runeID)
		------------------------------------------------
		-- 아웃게임 치트
		------------------------------------------------
		elseif split[1] == "GetSyrup" then
		    local amount = tonumber(split[2])
		   	self:Cheat_OutGame_GetSyrup(senderUserId, amount)
		-------------------------------
		elseif split[1] == "GetRoyalSyrup" then
		    local amount = tonumber(split[2])
			self:Cheat_OutGame_GetRoyalSyrup(senderUserId, amount)
		-------------------------------
		elseif split[1] == "GetEXP" then
		    local amount = tonumber(split[2])
		   	self:Cheat_OutGame_GetEXP(senderUserId, amount)
		-------------------------------
		elseif split[1] == "ChangeLevelOutGame" then
		    local targetLV = tonumber(split[2])
		    self:Cheat_OutGame_ChangeLevel(senderUserId, targetLV)
		-------------------------------	
		elseif split[1] == "ChangeCoachOwn" then
		    local coachID = split[2]
		    local ownInfo = tonumber(split[3])
			self:Cheat_OutGame_ChangeCoachOwnInfo(senderUserId, coachID, ownInfo, 0, false)
		    
		elseif split[1] == "ChangeCoachOwnByCost" then
		    local cost = tonumber(split[2])
		    local ownInfo = tonumber(split[3])
		    self:Cheat_OutGame_ChangeCoachOwnInfo(senderUserId, "", ownInfo, cost, false)
			
		elseif split[1] == "ChangeCoachOwnAll" then
		    local ownInfo = tonumber(split[2])
			self:Cheat_OutGame_ChangeCoachOwnInfo(senderUserId, "", ownInfo, 0, true)
		-------------------------------	
		elseif split[1] == "SetAchievementCount" then
		    local achievementID = split[2]
		    local achievementCount = split[3]
		    self:Cheat_OutGame_SetAchievementProgress(senderUserId, achievementID,tonumber(achievementCount))
		-------------------------------	
		elseif split[1] == "CharCollectChange" then
		    local charID = split[2] -- ID or "All"
		    local collectInfo = split[3]
		    self:Cheat_OutGame_GetCollection_Character(senderUserId, charID, collectInfo)
		-------------------------------
		elseif split[1] == "CharCollectChange_All" then
			local grade = split[2]
			self:Cheat_OutGame_GetCollection_Character(senderUserId, "All", grade)
		-------------------------------
		elseif split[1] == "SynCollectChange" then
		    local synID = split[2] -- ID or "All"
		    local collectInfo = tonumber(split[3])
			self:Cheat_OutGame_GetCollection_Synergy(senderUserId, synID, collectInfo)
		-------------------------------
		elseif split[1] == "SynCollectChange_All" then
			local grade = tonumber(split[2])
			self:Cheat_OutGame_GetCollection_Synergy(senderUserId, "All", grade)
		-------------------------------
		elseif split[1] == "GetTitle" then
		    local titleID = split[2] -- ID or "All"
		    self:Cheat_OutGame_GetTitle(senderUserId, titleID)
			
		elseif split[1] == "RemoveTitle" then
		    local synID = split[2] -- ID or "All"
		    local collectInfo = split[3]
		-------------------------------	
		elseif split[1] == "SingleModeUnlock" then
		    local season = split[2] 
		    local unlockLevel = tonumber(split[3]) - 1
			self:Cheat_OutGame_OpenSingleModeLevel(senderUserId, season, unlockLevel)
			
		elseif split[1] == "RankModeUnlock" then
		    local unlockLevel = split[2] - 1
			self:Cheat_OutGame_OpenRankModeLevel(senderUserId, unlockLevel)
			
		elseif split[1] == "GetChallengeChance" then
			local amount = tonumber(split[2])
			self:Cheat_OutGame_GetChallengeChance(senderUserId, amount)
		end	
	end

	@ExecSpace("ServerOnly")
	method void Cheat_PhaseOver(string userID)
		-- 현재 페이즈 강제 종료
		local user = _UserService:GetUserEntityByUserId(userID)
		local gameManager = user.GameManager
		
		if gameManager.PhaseType == "Ready" then
			gameManager:GoToNextPhase()
		elseif gameManager.PhaseType == "Battle" then
			gameManager.EnemyCount = 0
		else
			log_warning("조금만 참아보세요")
		end
	end

	@ExecSpace("ServerOnly")
	method void Cheat_GoStage(string userId, integer stage, integer round)
		-- 지정된 스테이지-라운드로 이동
		-- 인게임 치트 : stage-round 라운드로 이동합니다.
		----------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		
		user.GameManager.Stage = stage
		user.GameManager.Round = round
		
		-- 이전 라운드까지의 승부는 승리한 것으로 간주합니다.
		for i=#user.TeamBattleStatistics.SetRoundResult, 24 do
			local setStage = math.floor((i+2)/3)
			local setRound = (i-1)%3 + 1
			if (setStage > stage) or (setStage == stage and setRound > round) then
				break
			end
			user.TeamBattleStatistics:SetPropertyWithKey("SetRoundResult", string.format("%d-%d", setStage, setRound), "W")
		end
		
		-- 1-1 라운드인 경우, 모든 정보를 리셋합니다.
		if stage == 1 and round == 1 then
			self:Cheat_ChangeLevel(userId, 3)
			self:Cheat_ChangeLife(userId, 5)
			user.GameManager.UsedRepechage = false
			log("1-1 치트 사용 >>> 팀 레벨, 하트 수, 패자부활권 사용 여부가 모두 리셋됩니다.")
		end
		
		--local recordText = ""
		--for i=1, 24 do
		--    local setStage = math.floor((i+2)/3)
		--    local setRound = (i-1)%3 + 1
		--    local roundKey = string.format("%d-%d", setStage, setRound)
		--    
		--    if setStage >= stage and setRound > round then 
		--        break
		--    end
		--    
		--    if user.TeamBattleStatistics.SetRoundResult[roundKey] == "W" then
		--        recordText = recordText..string.format("%d:win/", i)
		--    else
		--        recordText = recordText..string.format("%d:lose/", i)
		--    end
		--    
		--end
		--log("승패 기록= ", recordText)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_ChangeLife(string userID, integer amount)
		-- 팀 체력(하트) 변경
		-- 인게임 치트 : amount만큼으로 남은 하트 수를 변경합니다. 1 미만 / 5 초과는 불가.
		local user = _UserService:GetUserEntityByUserId(userID)
		if amount < 1 then	amount = 1 end
		if amount > 5 then	amount = 5 end
		
		user.TeamManager.HP = amount
	end

	@ExecSpace("ServerOnly")
	method void Cheat_ChangeLevel(string userID, integer level)
		-- 팀 레벨 변경
		local user = _UserService:GetUserEntityByUserId(userID)
		if level < 3 then level = 3 end
		if level > 10 then level = 10 end
		
		user.TeamManager.Level = level
	end

	@ExecSpace("ServerOnly")
	method void Cheat_GetCoin(string userId, number amount)
		-- 지정된 양의 코인 획득
		-- 인게임 치트 : amount만큼의 코인을 얻습니다.
		local user = _UserService:GetUserEntityByUserId(userId)
		user.TeamManager:AddGolds(amount, "cheat")
		local coin = user.TeamManager.Golds
	end

	@ExecSpace("ServerOnly")
	method void Cheat_GetCharacter(string userId, string charID)
		-- 지정된 캐릭터 1성 획득
		-- charID에 해당하는 캐릭터 1성을 얻습니다.
		local user = _UserService:GetUserEntityByUserId(userId)
		
		local data = _DataService:GetTable("CharacterInfo"):FindRow("CharID", charID)
		if not isvalid(data) then
			return
		end
		
		_UnitSetLogic_New:SpawnUnit(userId, charID, 1, "shop")
	end

	@ExecSpace("ServerOnly")
	method void Cheat_GetCharacterBySynergy(string userID, string synergyID)
		-- 시너지별 모든 캐릭터 1성 획득
		-- 시너지 아이디를 입력하면 그에 해당하는 모든 캐릭터의 1성을 얻습니다.
		
		local data = _DataService:GetTable("CharacterListbySynergy"):FindRow("SynergyID", synergyID)
		if isvalid(data) == false then
			log("CharacterListbySynergy 데이터셋에 존재하지 않습니다")
			return
		end
		
		for i=1, 10 do
			local charID = data:GetItem(string.format("Char_%d", i))
			if isvalid(charID) == true and charID ~= "" then
				self:Cheat_GetCharacter(userID, charID)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void Cheat_GetItem(string userId, string itemID)
		-- 지정된 아이템 획득
		-- 아이템 획득 치트입니다. 
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		
		-- 잘못된 아이템 id를 입력했을 경우
		local data = _DataService:GetTable("ItemStatus"):FindRow("ItemID",itemID)
		
		if not isvalid(data) then 
			return
		end
		------------------------------------------------------------------------
		table.insert(user.TeamManager.OwnItems, itemID)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_GetRuneCard(string userID, string runeID)
		-- 지정된 룬 카드 획득
		local user = _UserService:GetUserEntityByUserId(userID)
		------------------------------------------------------------------------
		-- 빈 칸이 있는가?
		if #user.TeamManager.OwnRunes >= 5 then
			log("보유 룬 카드가 5장 이상입니다.")
			return
		end
		
		-- 정상적인 코드인가?
		local runeDataSet = _DataService:GetTable("RuneInfo")
		local row = runeDataSet:FindRow("RuneID", runeID)
		if isvalid(row) == false then
			return
		end
		------------------------------------------------------
		-- 구매 처리
		user.SpecialShopManager:AddRCComponent(runeID, true, #user.TeamManager.OwnRunes, 0)
		------------------------------------------------------
		-- 룬 카드 구매 사운드
		_PlaySoundLogic:PlaySound("M0005", userID)
		------------------------------------------------------
		-- 이벤트 처리
		user:SendEvent(BuyRuneCard(runeID)) -- 에러 아님
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetSyrup(string userID, integer amount)
		-- 일반 시럽 획득
		local user = _UserService:GetUserEntityByUserId(userID)
		if amount < 0 then
			log("입력값이 0 미만")
			return
		end
		user.PlayerDataComponent:AddSyrup("Syrup", amount, "Cheat")
		log("시럽 추가")
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetRoyalSyrup(string userID, integer amount)
		-- 로얄 시럽 획득
		local user = _UserService:GetUserEntityByUserId(userID)
		if amount < 0 then
			log("입력값이 0 미만")
			return
		end
		
		user.PlayerDataComponent:AddSyrup("RoyalSyrup", amount, "Cheat")
		log("로얄시럽추가")
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetEXP(string userID, number amount)
		-- 경험치 획득 (레벨업 처리 포함)
		local user = _UserService:GetUserEntityByUserId(userID)
		local levelDelta = user.PlayerDataComponent:AddEXP(amount,"Cheat")
		if levelDelta > 0 then
			_TimerService:SetTimerOnce(function()
				_PlayerLevelLogic:EnableUI_LevelUpPopup(userID)
			end, 1)
		end
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_ChangeLevel(string userID, integer inputLevel)
		-- 플레이어 레벨 직접 변경
		-- inputLevel에 입력한 레벨까지 레벨을 올립니다.
		local user = _UserService:GetUserEntityByUserId(userID)
		
		if inputLevel < 0 then inputLevel = 0 end
		if inputLevel > 500 then inputLevel = 500 end
		
		user.PlayerDataComponent.Level = inputLevel
		user.PlayerDataComponent.EXP = 0
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_ChangeCoachOwnInfo(string userId, string coachID, integer ownedInfo, integer byCost, boolean isTargetingAll)
		-- 코치 소유 정보 변경 (개별/코스트별/전체)
		local user = _UserService:GetUserEntityByUserId(userId)
		local coachManager = user.CoachManager
		------------------------------------------------------------------------
		-- 특정 코스트에 대한 변경인 경우
		if byCost > 0 then
			for id, data in pairs(_CoachService.CoachData) do
				---@type CoachInfo
				local coachData = data
				
				if coachData.Cost == byCost then
					coachManager:ModifyPlayerOwnedCoachesID(id, ownedInfo,"Cheat")
				end
			end
		------------------------------------------------------------------------	
		-- 모든 코치에 대한 변경인 경우
		elseif isTargetingAll == true then
			for id, data in pairs(_CoachService.CoachData) do
				coachManager:ModifyPlayerOwnedCoachesID(id, ownedInfo,"Cheat")
			end
		------------------------------------------------------------------------	
		-- 특정 코치에 대한 변경인 경우
		else
			local data = _CoachService:GetCoachInfo(coachID)
			if not isvalid(data) then 
				return
			end
			coachManager:ModifyPlayerOwnedCoachesID(coachID, ownedInfo,"Cheat")
		end
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_SetAchievementProgress(string userId, string achievementID, integer achievementCount)
		-- 업적 진행도 설정
		local user = _UserService:GetUserEntityByUserId(userId)
		------------------------------------------------------------------------
		-- 잘못된 업적 id를 입력했을 경우
		local data =_AchievementService:GetAchievementInfo(achievementID)
		
		if not isvalid(data) then 
			return
		end
		------------------------------------------------------------------------
		_AchievementService:UpdateAchievement(achievementID,tonumber(achievementCount),user)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetCollection_Character(string userId, string charIDorName, string grade)
		-- 캐릭터 컬렉션 등급 설정
		local user = _UserService:GetUserEntityByUserId(userId)
		local collectionData = user.PlayerCollectionDataComponent
		
		------------------------------------------------------------------------
		-- 잘못된 캐릭터 id를 입력했을 경우
		local data = _DataService:GetTable("AvatarChangeData"):FindRow("CharID",charIDorName)
		local data2 = _DataService:GetTable("AvatarChangeData"):FindRow("Name", charIDorName)
		
		--------------------------전부다 추가--
		if charIDorName == "All" then
			
			local characterdata = user.PlayerCollectionDataComponent.CharacterCollection
			local charIDs = table.keys(characterdata)
			
			---@type table<string, integer>
			local cheatDataTable = {}
			
			for i=1, #charIDs do
				cheatDataTable[charIDs[i]] = tonumber(grade)
			end
			
			collectionData:UpdateCharacterCollectionData(cheatDataTable)
			return
		end
		--------------------------전부다 추가 끝
		
		
		if isvalid(data) == false and isvalid(data2) == false then 
			log("입력이 잘못됨")
			return
		end
		
		if tonumber(grade) >= 5 or tonumber(grade) <= 0 then
			log("레벨 입력이 잘못됨")
			return
		end
		------------------------------------------------------------------------
		local id = ""
		-- 캐릭터 ID 말고 이름 들어왔을 때의 처리.. ?
		if isvalid(data2) and not isvalid(data) then
			id = data2:GetItem("CharID")
		elseif isvalid(data) and not isvalid(data2) then
			id = charIDorName
		end
		
		---@type table
		local cheatDataTable = {}
		cheatDataTable[id] = tonumber(grade)
		
		collectionData:UpdateCharacterCollectionData(cheatDataTable)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetCollection_Synergy(string userId, string synergyID, integer grade)
		-- 시너지 컬렉션 등급 설정
		local user = _UserService:GetUserEntityByUserId(userId)
		local collectionData = user.PlayerCollectionDataComponent
		
		---@type table<string, integer>
		local updateList = {}
		
		if synergyID == "All" then
			
			local synergyDataSet = collectionData.SynergyCollection
			local ids = table.keys(synergyDataSet)
			
			for i=1, #ids do
				updateList[ids[i]] = tonumber(grade)
			end
			--local synergyDataSet = _DataService:GetTable("SyenrgyInfo")
			--for i=1, synergyDataSet:GetRowCount() do
				--local id = synergyDataSet:GetRow(i):GetItem("SynergyID")
				--updateList[id] = grade
			--end
		else
			updateList[synergyID] = grade
		end
		
		collectionData:UpdateSynergyCollectionData(updateList)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetTitle(string userId, string titleElementID)
		-- 타이틀 획득 (네임태그/키워드)
		local user = _UserService:GetUserEntityByUserId(userId)
		local titleManager = user.TitleManager
		
		------------------------------------------------------------------------
		-- 잘못된 타이틀 id를 입력했을 경우
		local data
		local category = string.sub(titleElementID, 1, 3)
		if category == "NT1" then
			data = _DataService:GetTable("Title_NameTagDataset"):FindRow("NameTagID",titleElementID)
			--네임태그
		elseif category == "KWF" then
			data = _DataService:GetTable("Title_KeyWordFrontDataset"):FindRow("KeyWordID",titleElementID)
			--키워드Front
		elseif category == "KWB" then
			data = _DataService:GetTable("Title_KeyWordBackDataset"):FindRow("KeyWordID",titleElementID)
			--키워드Back
		elseif category == "All" then
			titleManager:GetAllTitle()
			return
			--모든 타이틀 얻기
		else
			return
		end
		
		
		if not isvalid(data) then 
			return
		end
		------------------------------------------------------------------------
		titleManager:GetTitle(titleElementID, true)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_RemoveAllTitles(string userId)
		-- 모든 타이틀 제거
		local user = _UserService:GetUserEntityByUserId(userId)
		local titleManager = user.TitleManager
		--------------------------------------------------------------------------
		for id, value in pairs(titleManager.NameTagTable) do
			titleManager.NameTagTable[id] = false
		end
		
		for id, value in pairs(titleManager.KeyWordFrontTable) do
			titleManager.NameTagTable[id] = false
		end
		
		for id, value in pairs(titleManager.KeyWordBackTable) do
			titleManager.NameTagTable[id] = false
		end
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_OpenSingleModeLevel(string userId, string season, integer level)
		-- 싱글 모드 레벨 해금
		local user = _UserService:GetUserEntityByUserId(userId)
		
		local seasonNum = tonumber(season)
		local seasonText = string.format("%.1f", seasonNum)
		if _UtilLogic:IsNilorEmptyString(seasonText) == true then
			log("wrong season input")
			return
		end
		
		if level < 0 then
			log("클리어 레벨은 0단계 이상이어야 합니다.")
			return
		elseif level > 8 then
			log("클리어 레벨은 8단계 이하여야 합니다.")
			return
		end
		
		user.PlayerDataComponent.ClearLevelByMode["Single_"..season] = level
		_ModeDataLogic:SaveModeClearCountData("Single", level, userId)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_OpenRankModeLevel(string userID, integer level)
		-- 랭크 모드 레벨 해금
		local user = _UserService:GetUserEntityByUserId(userID)
		
		if level < 0 then
			log("클리어 레벨은 0단계 이상이어야 합니다.")
			return
		elseif level > 20 then
			log("클리어 레벨은 20단계 이하여야 합니다.")
			return
		end
		if isvalid(user.PlayerDataComponent.ClearLevelByMode[string.format("Rank_%d_%d", _ModeDataLogic.Season, _ModeDataLogic.OrdinalNumber)]) == false then
			user.PlayerDataComponent.ClearLevelByMode[string.format("Rank_%d_%d", _ModeDataLogic.Season, _ModeDataLogic.OrdinalNumber)] = 1
		else
			user.PlayerDataComponent.ClearLevelByMode[string.format("Rank_%d_%d", _ModeDataLogic.Season, _ModeDataLogic.OrdinalNumber)] += 1
		end
		
		_ModeDataLogic:SaveModeClearCountData("Rank", level, userID)
	end

	@ExecSpace("ServerOnly")
	method void Cheat_OutGame_GetChallengeChance(string userID, integer amount)
		-- 챌린지 모드 도전 횟수 설정
		if amount < 0 then
			amount = 0
		end
		local user = _UserService:GetUserEntityByUserId(userID)
		user.PlayerDataComponent:SetChallengeModeTryCount(amount)
	end

	@ExecSpace("Server")
	method void PrintUnitStatusInfo(Entity unit)
		-- 유닛의 현재 스테이터스 정보를 콘솔에 출력
		-- unit이 현재 보유한 스테이터스 구성을 가져옵니다.
		--------------------------------------------------------------------------
		local statusType = {
			"MaxHP",						-- 최대 체력
			"MaxMP",						-- 최대 마나
			"MP",							-- 시작 마나
			"PhysicalAttack",				-- 공격력
			"MagicalAttack",				-- 마력
			"Defence",						-- 물리 방어력
			"MagicalResistance",			-- 마법 방어력
			"AttackSpeed",					-- 공격속도
			"AttackRange",					-- 공격 사거리
			"SkillRange",					-- 스킬 사거리
			"CriticalPercent",				-- 크리티컬 확률
			"CriticalDamagePercent",		-- 크리티컬 데미지
			"BloodAbsorptionPercent",		-- 흡혈률
			"MoveSpeed",					-- 이동속도
			"DealingDamageRate",			-- 가해량 비율
		--	"TakingDamageRate",				-- 피해량 비율
		--	"TakingDamageBonusAmount",		-- 피해량 증가
			"MPBonusWhenAttack",			-- 공격 시 마나 획득량
			"MPBonusWhenBeAttacked",		-- 피격 시 마나 획득량
			"HPRecoverRate", 				-- 체력 회복 효과 비율
			"StatusEffectRemainTimeRate",	-- 제어 효과 지속시간 비율
		}
		
		local unitStatus = unit.UnitStatus
		local defaultValues = unitStatus.DefaultStatus
		local addedValues = unitStatus.AddedStatus
		local multiValues = unitStatus.MultiplyStatus
		
		for i=1, #statusType do
			local statusTypeName = statusType[i]
			local finalValues = ((defaultValues[statusTypeName] + addedValues[statusTypeName]) * (1+multiValues[statusTypeName]/100)) 
		end
		
		-- 보유 중인 버프
		local buffList = unitStatus.BuffTable
		for i=1, #buffList do
			local buff = buffList[i]
			local statType = buff["StatusType"]
			local duration = buff["EndTime"]
			local amount = buff["Amount"]
			log(string.format("%d번째 버프: %s타입을 %d만큼 증가, %d초간 지속", i, statType, amount, duration))
		end
		
		-- 영구 스택
		local stackList = unitStatus.StackProperty
		log("보유중인 스택 목록: ")
		-- 스택(패시브)에 의한 변화
		for type, stack in pairs(stackList) do
			local types = _UtilLogic:Split(type, "_")
			
			if types[1] == "Add" then
				log(types[2], "의 add타입 스택 : ", stack)
				
			elseif types[1] == "Multi" then
				log(types[2], "의 multi타입 스택 : ", stack)
			end
			
		end
	end

	@ExecSpace("Server")
	method void OpenCharShopBoard()
		-- 캐릭터 상점 보드 열기
		if self:IsAllowedUser(senderUserId) == false then
			return
		end
		
		self:OpenCharShopBoard_Client(senderUserId)
	end

	@ExecSpace("ClientOnly")
	method void RefreshCharShopBoard(SyncTable<string, number> leftUnitCount)
		-- 캐릭터 상점 보드 UI 갱신
		local ui_board = _EntityService:GetEntityByPath("/ui/EtcGroup/ShopLeftUnitCheckBoard/Board")
		local ui_cards = {}
		
		for charID, count in pairs(leftUnitCount) do
			local cost = tonumber(string.sub(charID, 2, 2))
			local idx = tonumber(string.sub(charID, 3, -1))
			ui_cards[charID] = ui_board:GetChildByName(string.format("Cost_%d", cost)):GetChildByName(string.format("Char_%d", idx))
		end
		
		--[[
		for charID, count in pairs(leftUnitCount) do
			---@type Entity
			local ui_card = ui_cards[charID]
			local ui_name = ui_card:GetChildByName("Name")
			local ui_count = ui_card:GetChildByName("Count")
			
			ui_name.TextComponent.Text = _LocalizationService:GetText(charID.."_Name")
			ui_count.TextComponent.Text = string.format("%d", count)
		end
		]]--
	end

	@ExecSpace("Client")
	method void OpenCharShopBoard_Client()
		-- 클라이언트에서 캐릭터 상점 보드 UI 활성화
		_EntityService:GetEntityByPath("/ui/EtcGroup").Enable = true
		_EntityService:GetEntityByPath("/ui/EtcGroup/ShopLeftUnitCheckBoard").Enable = true
	end

	@ExecSpace("ClientOnly")
	method void InitCheatDictUI(integer type)
		-- 치트 사전 UI 초기화 (캐릭터/아이템/룬카드)
		if self.IsInitialized_DictUI[type] == true then
			return
		end
		
		-- char
		if type == 1 then
			local charData = _DataService:GetTable("CharacterInfo")
			local ui_list = _EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList/ListBG/List_Char")
			local ui_originSlot = ui_list:GetChildByName("Slot")
			for i=1, charData:GetRowCount() do
				-- data
				local row = charData:GetRow(i)
				local charID = row:GetItem("CharID")
				local ruid = row:GetItem("IdleRUID")
				local grade = tonumber(row:GetItem("Cost"))
				
				-- ui
				local ui_slot = ui_list:GetChildByName(string.format("Slot_%d", i))
				if isvalid(ui_slot) == false then
					ui_slot = ui_originSlot:Clone(string.format("Slot_%d", i))
				end
				
				-- apply
				ui_slot.SpriteGUIRendererComponent.Color = _UI_Color.CharCost[grade]
				ui_slot:GetChildByName("Image").SpriteGUIRendererComponent.ImageRUID = ruid
				ui_slot.CheatButton_DictionaryType.ID = string.sub(charID, 2, -1)
			end
			
		-- items
		elseif type == 2 then
			local itemData = _DataService:GetTable("ItemStatus")
			local ui_list = _EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList/ListBG/List_Item")
			local ui_originSlot = ui_list:GetChildByName("Slot")
			for i=1, itemData:GetRowCount() do
				-- data
				local row = itemData:GetRow(i)
				local itemID = row:GetItem("ItemID")
				local ruid = row:GetItem("RUID")
				local itemType = row:GetItem("Type")
				
				-- ui
				local ui_slot = ui_list:GetChildByName(string.format("Slot_%d", i))
				if isvalid(ui_slot) == false then
					ui_slot = ui_originSlot:Clone(string.format("Slot_%d", i))
				end
				
				-- apply
				ui_slot.SpriteGUIRendererComponent.ImageRUID = _UI_Inventory.TypeBackgroundRUID[itemType]
				ui_slot:GetChildByName("Image").SpriteGUIRendererComponent.ImageRUID = ruid
				ui_slot.CheatButton_DictionaryType.ID = itemID
			end
			
		-- rune cards
		elseif type == 3 then
			local runeData = _DataService:GetTable("RuneInfo")
			local ui_list = _EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList/ListBG/List_Rune")
			local ui_originSlot = ui_list:GetChildByName("Slot")
			for i=1, runeData:GetRowCount() do
				-- data
				local row = runeData:GetRow(i)
				local runeID = row:GetItem("RuneID")
				local ruid = row:GetItem("IconRUID")
				local grade = row:GetItem("Grade")
				
				-- ui
				local ui_slot = ui_list:GetChildByName(string.format("Slot_%d", i))
				if isvalid(ui_slot) == false then
					ui_slot = ui_originSlot:Clone(string.format("Slot_%d", i))
				end
				
				-- apply
				ui_slot.SpriteGUIRendererComponent.Color = _UI_Color.RuneGrade[grade]
				ui_slot:GetChildByName("Image").SpriteGUIRendererComponent.ImageRUID = ruid
				ui_slot.CheatButton_DictionaryType.ID = string.sub(runeID, 3, -1)
			end
		end
		
		-- init complete
		self.IsInitialized_DictUI[type] = true
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 단축키로 치트 기능 실행
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.P then
			self:UseCheat("phaseOver")
		elseif key == KeyboardKey.F12 then
			self:OpenCheatPanel()
		elseif key == KeyboardKey.F11 then
			self:OpenCharShopBoard()
		elseif key == KeyboardKey.Home then
			local ui = _EntityService:GetEntityByPath("/ui")
			ui.Enable = not ui.Enable
		elseif key == KeyboardKey.F9 then
			log(_ModeDataLogic.SetRankPenalties)
		end
	end

	@EventSender("Entity", "a1b3f28f-f51d-470c-aedd-7ad76457e8e1")
