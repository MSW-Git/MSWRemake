	@EventSender("Entity", "9b731a77-bd8e-4c7c-b13c-60064b0c68c0")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 룬카드 치트 목록 표시
		_EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList").Enable = true
		
		_EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList/ListBG/List_Char").Enable = false
		_EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList/ListBG/List_Item").Enable = false
		_EntityService:GetEntityByPath("/ui/EtcGroup/CheatUI_New/CheatItemList/ListBG/List_Rune").Enable = true
		
		self:InitCheatDictUI(3)
	end

end