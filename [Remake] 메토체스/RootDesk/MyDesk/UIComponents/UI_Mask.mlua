@Component
script UI_Mask extends Component

	property Entity BG_center = nil

	property Entity BG_top = nil

	property Entity BG_bottom = nil

	property Entity BG_left = nil

	property Entity BG_right = nil

	property boolean IsHighlight = false

	@ExecSpace("ClientOnly")
	method void SetMask(Entity targetUI, any targetImageRUID)
		-- 타겟 UI를 기준으로 마스크를 설정하고 주변 배경을 어둡게 처리
		local screenSize = Vector2(_UILogic.ScreenWidth, _UILogic.ScreenHeight)
		self.Entity:SetEnable(true)
		
		
		
		--마스크 제외한 영역의 사이즈를 화면에 맞춥니다.
		self.BG_top.UITransformComponent.RectSize = screenSize *3
		self.BG_bottom.UITransformComponent.RectSize = screenSize *3
		
		self.BG_left.UITransformComponent.RectSize.x = screenSize.x*3
		self.BG_right.UITransformComponent.RectSize.x = screenSize.x*3
		
		-- 마스크의 사이즈를 타겟에 맞춥니다.
		-- 확실한 강조를 위해 타겟과 마스크 사이에 약간의 여유 공간을 둡니다.
		local mask = self.Entity
		mask.SpriteGUIRendererComponent.ImageRUID = targetImageRUID
		mask.UITransformComponent.RectSize = targetUI.UITransformComponent.RectSize
		
		
		--self.BG_center.UITransformComponent.RectSize.x = mask.UITransformComponent.RectSize.x
		--self.BG_center.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		self.BG_left.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		self.BG_right.UITransformComponent.RectSize.y= mask.UITransformComponent.RectSize.y
		
		--마스크의 위치를 타겟에 맞춥니다.
		self.Entity.UITransformComponent.WorldPosition = targetUI.UITransformComponent.WorldPosition
	end

	@ExecSpace("ClientOnly")
	method void SetMaskWithPos(number MaskWidth, number MaskHeight, Vector2 MaskPos)
		--마스크의 위치와 크기를 받아 설정합니다.
		local screenSize = Vector2(_UILogic.ScreenWidth, _UILogic.ScreenHeight)
		self.Entity:SetEnable(true)
		
		self.Entity.SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
		
		--마스크 제외한 영역의 사이즈를 화면에 맞춥니다.
		self.BG_top.UITransformComponent.RectSize = screenSize *3
		self.BG_bottom.UITransformComponent.RectSize= screenSize *3
		
		self.BG_left.UITransformComponent.RectSize.x = screenSize.x*2
		self.BG_right.UITransformComponent.RectSize.x = screenSize.x*2
		
		-- 마스크의 사이즈를 지정된 크기에 맞춥니다.
		local mask = self.Entity
		mask.UITransformComponent.RectSize.x = MaskWidth
		mask.UITransformComponent.RectSize.y = MaskHeight
		
		--self.BG_center.UITransformComponent.RectSize.x = mask.UITransformComponent.RectSize.x
		--self.BG_center.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		self.BG_left.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		self.BG_right.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		--마스크의 위치를 지정된 위치에 맞춥니다.
		self.Entity.UITransformComponent.Position.x = MaskPos.x
		self.Entity.UITransformComponent.Position.y = MaskPos.y
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 하이라이트 모드일 때 펄스 애니메이션을 적용
		if self.IsHighlight == true then
			local tween = _TweenLogic:ScaleTo(self.Entity, Vector2(1.2, 1.2), 1, EaseType.QuadEaseInOut)
			tween.LoopCount = -1
			tween.LoopType = TweenLoopType.PingPong
		end
	end

	@ExecSpace("ClientOnly")
	method void SetMaskWithRUID(string ruid)
		-- 리소스 ID를 사용하여 마스크 이미지와 크기를 설정
		local screenSize = Vector2(_UILogic.ScreenWidth, _UILogic.ScreenHeight)
		
		--마스크 제외한 영역의 사이즈를 화면에 맞춥니다.
		self.BG_top.UITransformComponent.RectSize = screenSize *3
		self.BG_bottom.UITransformComponent.RectSize = screenSize *3
		self.BG_left.UITransformComponent.RectSize.x = screenSize.x*3
		self.BG_right.UITransformComponent.RectSize.x = screenSize.x*3
		
		-- 마스크의 사이즈를 타겟에 맞춥니다.
		-- 확실한 강조를 위해 타겟과 마스크 사이에 약간의 여유 공간을 둡니다.
		local mask = self.Entity
		mask.SpriteGUIRendererComponent.ImageRUID = ruid
		
		mask.UITransformComponent.RectSize = _LoadResourcesInfo:GetColliderOffsetScale(ruid)["scale"]*100
		
		--self.BG_center.UITransformComponent.RectSize.x = mask.UITransformComponent.RectSize.x
		--self.BG_center.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		self.BG_left.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		self.BG_right.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		
		self.Entity:SetEnable(true)
	end

	@ExecSpace("ClientOnly")
	method void SetMaskSizeMatch()
		-- 현재 마스크 크기에 맞춰 배경 영역의 크기를 조정
		local screenSize = Vector2(_UILogic.ScreenWidth, _UILogic.ScreenHeight)
		
		--마스크 제외한 영역의 사이즈를 화면에 맞춥니다.
		self.BG_top.UITransformComponent.RectSize = screenSize *3
		self.BG_bottom.UITransformComponent.RectSize = screenSize *3
		self.BG_left.UITransformComponent.RectSize.x = screenSize.x*3
		self.BG_right.UITransformComponent.RectSize.x = screenSize.x*3
		
		-- 마스크의 사이즈를 타겟에 맞춥니다.
		-- 확실한 강조를 위해 타겟과 마스크 사이에 약간의 여유 공간을 둡니다.
		local mask = self.Entity
		
		--self.BG_center.UITransformComponent.RectSize.x = mask.UITransformComponent.RectSize.x
		--self.BG_center.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		self.BG_left.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		self.BG_right.UITransformComponent.RectSize.y = mask.UITransformComponent.RectSize.y
		
		self.Entity:SetEnable(true)
	end

end