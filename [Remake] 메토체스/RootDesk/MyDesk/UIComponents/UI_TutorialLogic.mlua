	@ExecSpace("ClientOnly")
	method void ActivateAdviceMessage(string adviceID)
		--안내 캐릭터의 안내 메시지를 활성화합니다.
		self.AdviceID = adviceID
		log(self.AdviceID)
		self.UI_AdviceMessageSet = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/AdviceMessageSet")
		local adviceChatBalloon_ui = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/AdviceMessageSet/AdviceMessage_ChatBalloon")
		local adviceText_ui = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/AdviceMessageSet/AdviceMessage_ChatBalloon/TutoGuide_Text")
		local adviceCharSprite = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/AdviceMessageSet/AdviceMessage_ChatBalloon/AdviceCharacterSprite")
		local nextButton_ui = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/AdviceMessageSet/AdviceMessage_ChatBalloon/NextImage")
		local adviceDataRow = self.Dataset_Advice:FindRow("AdviceID",self.AdviceID)
		local adviceText = adviceDataRow:GetItem("AdviceText")
		local mask_center = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/MaskSet/TutorialMask/BG_center")
		local adviceCharRUID = adviceDataRow:GetItem("AdviceCharImageRUID")
		local maxCount = tonumber(adviceDataRow:GetItem("MaxCount"))
		local currentCount = tonumber(string.sub(self.AdviceID,-1,-1))
		
		local user = _UserService.LocalPlayer
		local ownUnits = user.TeamManager.OwnUnits
		
		
		adviceText_ui.TextComponent.Text = _LocalizationService:GetText(adviceText)
		
		--안내 캐릭터의 이미지를 갱신합니다.
		adviceCharSprite.SpriteGUIRendererComponent.ImageRUID = adviceCharRUID
		
		
		self.MaskSetPosRow = _DataService:GetTable("MaskSetPos"):FindRow("AdviceID",adviceID)
		local blockMaskClick = self.MaskSetPosRow:GetItem("BlockMaskClick")
		
		
		--마스킹이 필요한지 확인합니다.
		local isMaskOn = self.MaskSetPosRow:GetItem("IsMaskOn")
		
		
		--마스크의 강조 대상을 클릭할수 있는지 확인합니다.
		if blockMaskClick == "TRUE" then
			mask_center.SpriteGUIRendererComponent.RaycastTarget = true
		else
			mask_center.SpriteGUIRendererComponent.RaycastTarget = false
		end
		
		--현재 화면의 해상도를 받아옵니다.
		self.screenSize = Vector2(_UILogic.ScreenWidth,_UILogic.ScreenHeight)
		
		
		self.maskAnchor = self.MaskSetPosRow:GetItem("MaskAnchor")
		
		--마스크의 앵커를 조정합니다.
		self.UI_TutorialMask.UITransformComponent.AlignmentOption = AlignmentType.CastFrom(self.maskAnchor)
		self.UI_MaskOverImage.UITransformComponent.AlignmentOption = AlignmentType.CastFrom(self.maskAnchor)
		
		--앵커에 따라 피봇을 조정하고, 피봇에 맞춰 위치를 조정합니다.
		
		local pivotX,pivotY
		if self.maskAnchor == "Center" then
			pivotX = 0.5
			pivotY = 0.5
		elseif self.maskAnchor == "BottomLeft" then
			pivotX = 0
			pivotY = 0
		elseif self.maskAnchor == "BottomCenter" then
			pivotX = 0.5
			pivotY = 0
		elseif self.maskAnchor == "TopLeft" then
			pivotX = 0
			pivotY = 1
		elseif self.maskAnchor == "TopCenter" then
			pivotX = 0.5
			pivotY = 1
		elseif self.maskAnchor == "TopRight" then
			pivotX = 1
			pivotY = 1
		end
		--마스크의 피봇값을 조정합니다.
		self.UI_TutorialMask.UITransformComponent.Pivot = Vector2(pivotX,pivotY)
		self.UI_MaskOverImage.UITransformComponent.Pivot = Vector2(pivotX,pivotY)
		--마스크의 위치를 조정합니다.
		
		local posX = tonumber(self.MaskSetPosRow:GetItem("posX"))
		local posY = tonumber(self.MaskSetPosRow:GetItem("posY"))
		
		local overImageRUID = self.MaskSetPosRow:GetItem("OverImageRUID")
		local maskRUID =self.MaskSetPosRow:GetItem("MaskRUID")
		local isMaskSetOn = self.MaskSetPosRow:GetItem("IsMaskOn")
		
		if isvalid(posX) and isvalid(posY) then
			if self.screenSize.y == 1080 then
		
				self.UI_TutorialMask.UITransformComponent.anchoredPosition = Vector2(posX,posY)
				self.UI_MaskOverImage.UITransformComponent.anchoredPosition = Vector2(posX,posY)
			else
				self.UI_TutorialMask.UITransformComponent.anchoredPosition = Vector2(posX,posY)
				self.UI_MaskOverImage.UITransformComponent.anchoredPosition = Vector2(posX,posY)
			end
		end
		
		self.UI_MaskSet.Enable = true
		
		if overImageRUID == "nil" then
			self.UI_MaskOverImage.Enable = false
		else
			self.UI_MaskOverImage.SpriteGUIRendererComponent.ImageRUID = overImageRUID
			self.UI_MaskOverImage.UITransformComponent.RectSize = _LoadResourcesInfo:GetColliderOffsetScale(overImageRUID)["scale"]*100
			if self.AdviceID == "ADUN3_1" then
				self.UI_MaskOverImage.Enable = false
			else
				self.UI_MaskOverImage.Enable = true
			end
		
		end
		
		--타겟에 마스킹을 적용합니다.
		if maskRUID == "nil"  then
			self.UI_TutorialMask.UI_Mask:SetMask(self.UI_AdviceMessageSet,"3e9d52ed52d64794bbd6f72bab8ee3d9")
		else
			self.UI_TutorialMask.UI_Mask:SetMaskWithRUID(maskRUID)
		end
		
		self.maskType = 0
		
		if overImageRUID == "927ddee89c2244649e5d7c1dad300a7b" then
			--대기석
			self.maskType = 1
		elseif overImageRUID == "b258f19fa36e4bfda88352cf9412a6e6" then
			--전장
			self.maskType = 2
		elseif overImageRUID == "7843345ddb79435bbd0a414a9a45513b" then
			--주황버섯
			self.maskType = 3
		end
		
		--마스크를 켜야하는지 확인합니다.
		if isMaskOn == "FALSE" then
			self.UI_TutorialMask.Enable = false
		
		else
			self.UI_TutorialMask.Enable = true
		
		end
		
		---------------------------------
		
		--다음 메시지가 있는지 확인합니다.
		if currentCount >= maxCount then
			nextButton_ui.Enable = false
		else
			nextButton_ui.Enable = true
		end
		---------------------------------
		
		self.UI_AdviceMessageSet.Enable = true
		--안내 메시지를 활성화합니다.
		self.UI_AdviceMessageSet.UI_AlphaDesolve:DesolveToEnable()
		
		
		--메시지별 기능을 활성화합니다.
		if isvalid(self.AdviceFuntionTable[self.AdviceID]) then
			self.AdviceFuntionTable[self.AdviceID]()
		end
	end

	@ExecSpace("ClientOnly")
	method void DeactivateAdviceMessage()
		--핑크빈의 메시지를 비활성화합니다.
		
		self.UI_AdviceMessageSet.Enable = false
		self:DeactivateMaskAndHighlight()
	end

	@ExecSpace("Client")
	method void BattleButtonOnOff(boolean onOff)
		--튜토리얼 진행 시, 전투 시작 버튼을 보이게/안 보이게 조절하는 함수입니다.
		local battlestartButton = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/DefaultPanel/Button_StartBattle")
		 
		if onOff == true then
			
		
		for i = 1,10 do
			if battlestartButton.Enable == true then
				break
			else
			_UserService.LocalPlayer.CharacterShopManager_New.SellUI_ButtonOriginState[1] = true
			battlestartButton.Enable = true
				self:ActivateInteractionArrow("BattleButton",true)
			end
		end
		
		elseif onOff == false then
			battlestartButton.Enable = false
		end
	end

	@ExecSpace("Client")
	method void SetDragGuide(string dragSprite, boolean onOff, Entity StartEntity, Entity EndEntity)
		---엔티티 간 상호작용 가이드를 활성화합니다.
		---------------------------------------------------------
		local user = _UserService.LocalPlayer
		local teamManager = user.TeamManager
		
		local arenaPath = self:SetArenaMapPath()
		self.UI_DragThis = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/DragGuide")
		local dragTarget = self.UI_DragThis:GetChildByName("DragImage")
		
		if isvalid(StartEntity) and isvalid(EndEntity) then
			local startVector
			local EndVector
		
			local startUnitInfo = StartEntity.UnitInfo
		
			local originalScale = tonumber(_DataService:GetTable("CharacterInfo"):FindRow("CharID", startUnitInfo.charID):GetItem("Scale"))
			-- local originalScale = 1
		
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", startUnitInfo.charID)
			local hpBarUIPosY = 0
		
			local data={}
			if isvalid(charRUIDRow) then
				data=_LoadResourcesInfo:GetColliderOffsetScale(charRUIDRow:GetItem("IdleRUID"))
				hpBarUIPosY = tonumber(charRUIDRow:GetItem(string.format("HPBarPosY_%d", startUnitInfo.level)))
			else
				log_error("ChatacterInfo테이블에 RUID가 없음 : "..startUnitInfo.charID)
				return
			end
			local gradeScale = {1, 1.2, 1.44}
		
			dragTarget.TransformComponent.Scale = Vector3.one * originalScale * gradeScale[startUnitInfo.level]
			dragTarget.SpriteRendererComponent.SpriteRUID = StartEntity.UnitInfo.spriteRenderer.SpriteRendererComponent.SpriteRUID
		
			startVector = Vector2(StartEntity.TransformComponent.WorldPosition.x,StartEntity.TransformComponent.WorldPosition.y)
		
			EndVector = Vector2(EndEntity.TransformComponent.WorldPosition.x,EndEntity.TransformComponent.WorldPosition.y)
			
			self.UI_DragThis.UITweenPosition.from = startVector
			self.UI_DragThis.UITweenPosition.to = EndVector
		else
			
		end
		
		if onOff == true then
			self.UI_DragThis.Enable = onOff
		else
			self.UI_DragThis.Enable = onOff
		end
		
	end

	@ExecSpace("Client")
	method void SetSkipButton(boolean onOff)
		-- 튜토리얼 스킵 버튼의 활성화 상태를 설정
		if onOff == true then
			self.UI_TutoStageSkipButton.Enable = true
		else
			self.UI_TutoStageSkipButton.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void DeactivateMaskAndHighlight()
		-- 튜토리얼 마스크와 강조 효과를 모두 비활성화
		--마스크와 마스크 강조를 모두 비활성화합니다.
		----------------------------------------
		self.UI_TutorialMask.Enable = false
		self.UI_MaskOverImage.Enable = false
		self.UI_MaskSet.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void ActivateInteractionArrow(string guideName, boolean onOff)
		-- 지정된 상호작용 화살표 가이드를 활성화하거나 비활성화
		local arrowGuide = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/InteractionGuide/Arrow")
		
		for i=1, #arrowGuide.Children do
			
			if guideName == "OffAll" then
				arrowGuide.Children[i].Enable = onOff
				continue
			end
			
			if string.sub(guideName,1,-2) == "ShopChar" then
		
			--상점 화살표(1,2,3,4,5)
				if guideName == "ShopCharAll" then
					arrowGuide.Children[i].Enable = onOff
					continue
				end
				
				if arrowGuide.Children[i].Name == guideName then
					arrowGuide.Children[i].Enable = onOff
					return
				end
			elseif string.sub(guideName,1,-2) == "ShopSpecial" then
				--아이템(1,2), 룬카드(3,4) 화살표
				if arrowGuide.Children[i].Name == guideName then
					arrowGuide.Children[i].Enable = onOff
					return
				end
			else
				if arrowGuide.Children[i].Name == guideName then
					arrowGuide.Children[i].Enable = onOff
					return
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void DeactivateAllTutorialUI()
		--튜토리얼에 관련된 모든 UI를 비활성화합니다.
		
		if self.UI_AdviceMessageSet.Enable == true then
			self.UI_AdviceMessageSet.UI_AlphaDesolve:DesolveToDisable()
		end
		
		local arenaPath = self:SetArenaMapPath()
		
		local battleButton = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/DefaultPanel/Button_StartBattle")
		battleButton.Enable = true
		
		self:ActivateInteractionArrow("OffAll",false)
		self:DeactivateMaskAndHighlight()
		self:SetDragGuide("",false,nil,nil)
		self.UI_Moveline.Enable = false
		self:SetSkipButton(false)
		self.UI_HPGauge = nil
		self.UI_UnitGuideLine.Enable = false
		local lineset = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/TutorialGuideLine")
		lineset.Enable = false
		_EntityService:GetEntityByPath("/ui/AchievementPopupGroup/Panel_CustomChatVer3").Visible = true
		self:SetUnitGuideLine_Entity(nil,nil,false)
	end

	@ExecSpace("ClientOnly")
	method void ClickAdviceMessage()
		-- 안내 메시지 클릭 시 다음 페이지로 이동하거나 종료
		local adviceDataRow = self.Dataset_Advice:FindRow("AdviceID",self.AdviceID)
		
		local maxCount = tonumber(adviceDataRow:GetItem("MaxCount"))
		local currentCount = tonumber(string.sub(self.AdviceID,-1,-1))
		
		local temp = currentCount + 1
		--현재 페이지가 마지막 페이지인지 확인합니다.
		if currentCount >= maxCount then
		
		else
			--마지막 페이지가 아닐 경우
			self.AdviceID = string.sub(self.AdviceID,1,-2)..temp
			self:ActivateAdviceMessage(self.AdviceID)
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowSynergyTile(string SynergyID, boolean OnOff)
		--지정한 시너지에 해당하는 캐릭터를 강조합니다.
		--------------
		local userId = _UserService.LocalPlayer.PlayerComponent.UserId
		
		if _UtilLogic:IsNilorEmptyString(userId) then return end
			
		local teamManager = _UserService.LocalPlayer.TeamManager
		local units = teamManager.OwnUnits
		
		for i=1, #units do
			local unit = units[i]
			local synergyList = unit.UnitInfo.synergyList
			for j=1, #synergyList do
				if synergyList[j] == SynergyID then
		
					--unit.UnitInfo:SetOutlineMaterial(OnOff, "synergy")
					_GeneralDirectorLogic:ShowSynergyTile(unit, OnOff)
					break
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowFieldTile(boolean OnOff)
		--전장 타일을 보여줍니다.
		--------------------
		_UserService.LocalPlayer.TutorialManager_New.AlwaysShowFieldTile = OnOff
		
		for i = 1, 7 do --전장
			local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
					
			for j = 1, 4 do
				tilegroup:GetChildByName("Tile_"..tostring(j)).Visible = OnOff
				tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("CanDragOffTile").Enable = OnOff
			end
		end
		_GeneralDirectorLogic:SetTileDirection_Main("OnDragging", OnOff)
	end

	@ExecSpace("ClientOnly")
	method void ShowTargetTile(Entity targetTile)
		--현재 목표로 하는 타일을 화면에 표시합니다.
		-------------------------------------
		for i = 1, 7 do --전장
			local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
					
			for j = 1, 4 do
				if isvalid(tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("TutorialTile")) then
					tilegroup:GetChildByName("Tile_"..tostring(j)):SetVisible(false)
					tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("TutorialTile").Enable = false
				end
		
			end
		end
		
		if isvalid(targetTile) then
			targetTile:SetVisible(true)
			targetTile:GetChildByName("TutorialTile").Enable = true
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method Entity checkAvailableTile(integer tileNum)
		--배치 전, 비어있는 타일을 탐색합니다.
		--2~6번 줄의 타일만 체크합니다.
		----------
		local user = _UserService.LocalPlayer
		local teamManager = user.TeamManager
		local ArenaMap = _EntityService:GetEntityByPath("/maps/Arena"..user.OwnerId)
		
		for i=2,6 do
			local targetTile = ArenaMap:GetChildByName("Line_"..tostring(8-i)):GetChildByName("Tile_"..tostring(tileNum))
			if not isvalid(teamManager.EntityOnTile[targetTile]) then
				return targetTile
			else
				log(teamManager.EntityOnTile[targetTile].Name)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method Entity checkTargetWaitLine(string charID)
		--지정한 캐릭터가 있는 대기석 타일을 탐색합니다.
		----------
		local user = _UserService.LocalPlayer
		
		local teamManager = user.TeamManager
		local ArenaMap = _EntityService:GetEntityByPath("/maps/Arena"..user.OwnerId)
		
		for i=1,9 do
			local targetTile = ArenaMap:GetChildByName("WaitLine"):GetChildByName("Tile_"..tostring(i))
			if isvalid(teamManager.EntityOnTile[targetTile]) then
				if charID == teamManager.EntityOnTile[targetTile].UnitInfo.charID then
					return targetTile
				end
			end
		end
		return nil
	end

	@ExecSpace("ClientOnly")
	method void showTargetWaitLine(Entity targetTile)
		--타겟 대기석을 보여줍니다.
		-------------------------
		--현재 목표로 하는 타일을 화면에 표시합니다.
		-------------------------------------
		 --대기석
		local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("WaitLine")
					
			for j = 1, 9 do
			--기타 타일 초기화
				local dragTile = tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("OnDraggingTile")
				tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("CanDragOffTile").Enable = false
				if isvalid(tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("TutorialTile")) then
					tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("TutorialTile").Enable = false
				end
				dragTile:SetVisible(false)
				
			end
		
		if isvalid(targetTile) then
			--선택된 그 타일
			if isvalid(targetTile:GetChildByName("TutorialTile")) then
				targetTile:GetChildByName("TutorialTile").Enable = true
			end
		end
		
	end

