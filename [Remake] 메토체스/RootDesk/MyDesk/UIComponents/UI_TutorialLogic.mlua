	@ExecSpace("Client")
	method void SetUnitGuideLine(Entity StartTile, Entity EndTile, boolean onOff)
		--유닛의 배치를 유도하는 선의 위치를 결정합니다. 
		---------------------------------------------------------
		local startVector
		local EndVector
		
		
		local lineHead = self.UI_UnitGuideLine:GetChildByName("GuideLineHead")
		local linePointList = self.UI_UnitGuideLine:GetChildByName("UnitGuideLine")
		
		
		if isvalid(StartTile) and isvalid(EndTile) then
			self.UI_UnitGuideLine:GetChildByName("UnitGuideLine").LineGUIRendererComponent.Enable = false
			--라인 포인트 초기화
			linePointList.LineGUIRendererComponent.Points:Clear()
			startVector = Vector2(StartTile.TransformComponent.WorldPosition.x*121,StartTile.TransformComponent.WorldPosition.y*121+60)
			EndVector = Vector2(EndTile.TransformComponent.WorldPosition.x*121,EndTile.TransformComponent.WorldPosition.y*121+60)
			
			--중간에 색깔 바뀌는 점의 좌표를 구하는 방정식
			
			--기울기
			local giulgi
			--시작 타일과 끝 타일의 위치에 따라 기준이 되는 x값을 변경
			if EndVector.x < startVector.x then
				giulgi = (startVector.y-EndVector.y) / (startVector.x-EndVector.x)
			else
				giulgi = (EndVector.y-startVector.y) / (EndVector.x-startVector.x)
			end
			
			--y절편
			local yIntercept
			if EndVector.x < startVector.x then
				yIntercept = startVector.y - giulgi*startVector.x
			else
				yIntercept = EndVector.y - giulgi*EndVector.x
			end
			--파란색 포인트의 x값
			local linePointBodyPosX
			--투명해지는 포인트의 x값 
			local linePointBodyTransparentPosX
			
			if EndVector.x < startVector.x then
				linePointBodyPosX = startVector.x - (startVector.x - EndVector.x) * 0.8
				linePointBodyTransparentPosX = startVector.x -(startVector.x - EndVector.x) * 0.2
			else
				linePointBodyPosX = EndVector.x -(EndVector.x -startVector.x) * 0.2
				linePointBodyTransparentPosX = EndVector.x -(EndVector.x - startVector.x) * 0.8
			end
			
			--파란색 포인트의 y값
			local linePointBodyPosY = linePointBodyPosX * giulgi + yIntercept
			--투명해지는 포인트의 y값
			local linePointBodyTransparentPosY = linePointBodyTransparentPosX * giulgi + yIntercept
			---------------------------
			
			linePointList.LineGUIRendererComponent.Points:Add(LinePoint(EndVector,Color(232/255,183/255,255/255,100),130))
			linePointList.LineGUIRendererComponent.Points:Add(LinePoint(Vector2(linePointBodyPosX,linePointBodyPosY),Color(102/255,185/255,255/255,100),130))
			linePointList.LineGUIRendererComponent.Points:Add(LinePoint(Vector2(linePointBodyTransparentPosX,linePointBodyTransparentPosY),Color(237/255,185/255,255/255,0),130))
			linePointList.LineGUIRendererComponent.Points:Add(LinePoint(startVector,Color(0,0,0,0),130))
			
			local linePointHead = self.UI_UnitGuideLine:GetChildByName("UnitGuideLine").LineGUIRendererComponent.Points[1]
			local linePointBody = self.UI_UnitGuideLine:GetChildByName("UnitGuideLine").LineGUIRendererComponent.Points[2]
			local linePointTransparentBody = self.UI_UnitGuideLine:GetChildByName("UnitGuideLine").LineGUIRendererComponent.Points[3]
			local linePointTail = self.UI_UnitGuideLine:GetChildByName("UnitGuideLine").LineGUIRendererComponent.Points[4]
			
			lineHead.UITransformComponent.Position = Vector3(EndVector.x,EndVector.y,0)
			
			
			self.UI_UnitGuideLine:GetChildByName("UnitGuideLine").LineGUIRendererComponent.Enable = true
		else
			
		end
		
		if onOff == true then
			self.UI_UnitGuideLine.Enable = true
		else
			self.UI_UnitGuideLine.Enable = false
		end
		
	end

	@ExecSpace("ClientOnly")
	method Entity GetArenaTile(integer LineNum, integer TileNum)
		--전장 타일 중에서 LineNum번째 가로줄의 TileNum번째 타일을 가져옵니다.
		local arenaPath = self:SetArenaMapPath()
		return  _EntityService:GetEntityByPath(arenaPath.."/Line_"..tostring(LineNum).."/Tile_"..tostring(TileNum))
	end

	@ExecSpace("Client")
	method void SetUnitGuideLine_Entity(Entity StartTile, Entity EndTile, boolean onOff)
		--유닛의 배치를 유도하는 선의 위치를 결정합니다. 
		---------------------------------------------------------
		local startVector
		local EndVector
		local arenaPath = self:SetArenaMapPath()
		local lineset = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/TutorialGuideLine")
		local lineHead = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/TutorialGuideLine/TutorialUnitGuideLineHead")
		local linePointList = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/TutorialGuideLine/TutorialUnitGuideLine")
		
		
		if isvalid(StartTile) and isvalid(EndTile) then
			linePointList.LineRendererComponent.Enable = false
			--라인 포인트 초기화
			linePointList.LineRendererComponent.Points:Clear()
			startVector = Vector2(StartTile.TransformComponent.WorldPosition.x,StartTile.TransformComponent.WorldPosition.y)
			EndVector = Vector2(EndTile.TransformComponent.WorldPosition.x,EndTile.TransformComponent.WorldPosition.y)
			
			--중간에 색깔 바뀌는 점의 좌표를 구하는 방정식
			
			--기울기
			local giulgi
			--시작 타일과 끝 타일의 위치에 따라 기준이 되는 x값을 변경
			if EndVector.x < startVector.x then
				giulgi = (startVector.y-EndVector.y) / (startVector.x-EndVector.x)
			else
				giulgi = (EndVector.y-startVector.y) / (EndVector.x-startVector.x)
			end
			
			--y절편
			local yIntercept
			if EndVector.x < startVector.x then
				yIntercept = startVector.y - giulgi*startVector.x
			else
				yIntercept = EndVector.y - giulgi*EndVector.x
			end
			--파란색 포인트의 x값
			local linePointBodyPosX
			--투명해지는 포인트의 x값 
			local linePointBodyTransparentPosX
			
			if EndVector.x < startVector.x then
				linePointBodyPosX = startVector.x - (startVector.x - EndVector.x) * 0.8
				linePointBodyTransparentPosX = startVector.x -(startVector.x - EndVector.x) * 0.2
			else
				linePointBodyPosX = EndVector.x -(EndVector.x -startVector.x) * 0.2
				linePointBodyTransparentPosX = EndVector.x -(EndVector.x - startVector.x) * 0.8
			end
			
			--파란색 포인트의 y값
			local linePointBodyPosY = linePointBodyPosX * giulgi + yIntercept
			--투명해지는 포인트의 y값
			local linePointBodyTransparentPosY = linePointBodyTransparentPosX * giulgi + yIntercept
			---------------------------
			
			linePointList.LineRendererComponent.Points:Add(LinePoint(EndVector,Color(232/255,183/255,255/255,100),1))
			linePointList.LineRendererComponent.Points:Add(LinePoint(Vector2(linePointBodyPosX,linePointBodyPosY),Color(102/255,185/255,255/255,100),1))
			linePointList.LineRendererComponent.Points:Add(LinePoint(Vector2(linePointBodyTransparentPosX,linePointBodyTransparentPosY),Color(237/255,185/255,255/255,0),1))
			linePointList.LineRendererComponent.Points:Add(LinePoint(startVector,Color(0,0,0,0),1))
			
			local linePointHead = linePointList.LineRendererComponent.Points[1]
			local linePointBody = linePointList.LineRendererComponent.Points[2]
			local linePointTransparentBody = linePointList.LineRendererComponent.Points[3]
			local linePointTail = linePointList.LineRendererComponent.Points[4]
			
			lineHead.UITransformComponent.WorldPosition = Vector3(EndVector.x,EndVector.y,0)
			
			
			linePointList .LineRendererComponent.Enable = true
		else
			
		end
		
		if onOff == true then
			lineset.Enable = true
		else
			lineset.Enable = false
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetMaskStretchAll(integer maskType)
		-- maskType에 따라 크기와 위치를 변경함.
		-- 1: 대기석, 2: 전장, 3: 주황버섯 클로즈업
		--------------------------
		
		--앵커를 StretchAll로 바꿉니다.
		self.UI_TutorialMask.UITransformComponent.AlignmentOption = AlignmentType.StretchAll
		self.UI_MaskOverImage.UITransformComponent.AlignmentOption = AlignmentType.StretchAll
		self.UI_TutorialMask.UITransformComponent.Pivot = Vector2(0.5,0.5)
		self.UI_MaskOverImage.UITransformComponent.Pivot = Vector2(0.5,0.5)
		
		self:GetMaskOffsetFromArena()
		
		--좌하단, 우상단의 좌표를 얻습니다.
		local bottomLeftPos = self:ScreenPostoUIPos(_UILogic:WorldToScreenPosition(self.offsetPointWorldPos[maskType][1]))
		local topRightPos = _UILogic:WorldToScreenPosition(self.offsetPointWorldPos[maskType][2])
		
		self.screenSize =  Vector2(_UILogic.ScreenWidth,_UILogic.ScreenHeight)
		
		--마스크 강조 이미지와 마스크의 사이즈에 위에서 얻은 좌표를 대입합니다.
		self.UI_TutorialMask.UITransformComponent.OffsetMin =
			 bottomLeftPos
		self.UI_TutorialMask.UITransformComponent.OffsetMax =
			self:ScreenPostoUIPos(topRightPos - self.screenSize)
		self.UI_MaskOverImage.UITransformComponent.OffsetMin =
			 bottomLeftPos
		self.UI_MaskOverImage.UITransformComponent.OffsetMax =
			self:ScreenPostoUIPos(topRightPos - self.screenSize)
		
		
		
		self.UI_TutorialMask.UI_Mask:SetMaskSizeMatch()
	end

	@ExecSpace("ClientOnly")
	method void GetMaskOffsetFromArena()
		--마스킹용 오프셋 좌표를 받아옵니다.
		
		local arenaPath = self:SetArenaMapPath()
		
		local standoffCornorBottomLeft = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/StandOffCornerBottomLeft").UITransformComponent.WorldPosition
		local standoffCornorTopRight = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/StandOffCornerTopRight").UITransformComponent.WorldPosition
		local battlefieldCornorBottomLeft = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/BattlefieldCornerBottomLeft").UITransformComponent.WorldPosition
		local battlefieldCornorTopRight = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/BattlefieldCornerTopRight").UITransformComponent.WorldPosition
		local orangeMushroomCornorBottomLeft = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/OrangeMushRoomBottomLeft").UITransformComponent.WorldPosition
		local orangeMushroomCornorTopRight = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/OrangeMushRoomTopRight").UITransformComponent.WorldPosition
		--
		
		self.offsetPointWorldPos = {
			{Vector2(standoffCornorBottomLeft.x, standoffCornorBottomLeft.y),Vector2(standoffCornorTopRight.x,standoffCornorTopRight.y)},
		{Vector2(battlefieldCornorBottomLeft.x,battlefieldCornorBottomLeft.y),Vector2(battlefieldCornorTopRight.x,battlefieldCornorTopRight .y)},
		{Vector2(orangeMushroomCornorBottomLeft.x,orangeMushroomCornorBottomLeft.y),Vector2(orangeMushroomCornorTopRight.x,orangeMushroomCornorTopRight.y)}
		}
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		--마스크가 켜져있는 경우, 현재 화면 크기를 받아와서 실시간으로 업데이트합니다.
		local user = _UserService.LocalPlayer
		local gameManager = user.GameManager
		
		if self.UI_MaskOverImage.Enable == true and self.maskType ~= 0 then
			self:SetMaskStretchAll(self.maskType)
		end
		
		
		self:SetDragItemGuide()
		
		if isvalid(self.UI_HPGauge) then
			self:SetHPGaugePos(user.TeamManager.OwnUnits[1])
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method Vector2 ScreenPostoUIPos(Vector2 Pos)
		--screenpos를 UIpos로 변경
		local height=_UILogic.ScreenHeight
		local width=_UILogic.ScreenWidth
		
		local currentScreenRatio = Vector2(width, height)
		
		local sampleUIEntity = _EntityService:GetEntityByPath("/ui/PopupGroup")
		local uiResolutionRatio = sampleUIEntity.UITransformComponent.RectSize.x / sampleUIEntity.UITransformComponent.RectSize.y
		Pos.x=Pos.x*currentScreenRatio.x/width
		Pos.y=Pos.y*currentScreenRatio.y/height
		
		return Pos
	end

	@ExecSpace("ClientOnly")
	method void SetDragItemGuide()
		---벡터 간 상호작용 가이드를 활성화합니다.
		
		local arenaPath = self:SetArenaMapPath()
		if self.ItemDragOnOff == false then
			if self.UI_DragThis == _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/DragGuide") then
				return
			end
			self.UI_DragThis.Enable = self.ItemDragOnOff
			return
		end
		--------------------------------------------------------
		self.UI_DragThis = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/InteractionGuide/DragThis")
		local item1 =  _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/ItemInventory_BG/Item_1")
		local itemStartPoint = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/ItemGuidePoint")
		itemStartPoint.UITransformComponent.Pivot = Vector2(0,0)
		itemStartPoint.UITransformComponent.AlignmentOption = AlignmentType.BottomLeft
		itemStartPoint.UITransformComponent.WorldPosition = item1.UITransformComponent.WorldPosition
		
		local itemPos = itemStartPoint.UITransformComponent.anchoredPosition
		local itemVector = Vector2(itemPos.x,itemPos.y)
		
		local itemImage = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_1/Icon")
		
		local startVector = itemVector
		local endVector = self:ScreenPostoUIPos(_UILogic:WorldToScreenPosition(Vector2(self.Entity_DragEndUnit.TransformComponent.WorldPosition.x,self.Entity_DragEndUnit.TransformComponent.WorldPosition.y)))
		-------------------------------------------------------
		self.UI_DragThis = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/InteractionGuide/DragThis")
		local dragTarget = self.UI_DragThis:GetChildByName("DragTarget")
		dragTarget.SpriteGUIRendererComponent.ImageRUID = itemImage.SpriteGUIRendererComponent.ImageRUID.DataId
		
		self.UI_DragThis.UITweenPosition.from = startVector
		self.UI_DragThis.UITweenPosition.to = endVector
		
		self.UI_DragThis.Enable = self.ItemDragOnOff
	end

	@ExecSpace("ClientOnly")
	method void SetHPGaugePos(Entity targetUnit)
		---게이지 안내 마스크의 현재 위치를 조정합니다.
		--------------------------
		local arenaPath = self:SetArenaMapPath()
		
		local arenaHPGauge = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/HPGauge")
		if arenaHPGauge.Enable == false then
			self.UI_HPGauge.Enable = false
			return
		end
		
		local barPosition =  self:ScreenPostoUIPos(_UILogic:WorldToScreenPosition(Vector2(arenaHPGauge.UITransformComponent.WorldPosition.x,arenaHPGauge.UITransformComponent.WorldPosition.y)))
		self.UI_HPGauge.UITransformComponent.anchoredPosition = barPosition
		
		if self.UI_HPGauge.UITransformComponent.anchoredPosition == barPosition then
			self.UI_HPGauge.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method string SetArenaMapPath()
		-- 현재 플레이어의 아레나 맵 경로를 생성하여 반환
		local user = _UserService.LocalPlayer
		
		local path = "/maps/Arena"..user.OwnerId
		
		return path
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력을 처리하여 튜토리얼 진행 및 UI 제어
		--------------- Native Event Sender Info ----------------
		-- Sender: InputService
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local key = event.key
		local user = _UserService.LocalPlayer
		---------------------------------------------------------
		if not isvalid(user) then
			return
		end
		
		if key == KeyboardKey.Mouse0 then
			if user.GameManager.ModeType == "Tutorial" then
				if self.UI_AdviceMessageSet.Enable == true then
					self:ClickAdviceMessage()
				end
			end
		elseif key == KeyboardKey.Escape and _UserService.LocalPlayer.CurrentMap.MapComponent.IsDynamicMap == true then -- mapName == "Arena"  then
			if  user.GameManager.ModeType == "Tutorial" then
				if self.AdviceID == "AD129_2" or self.AdviceID == "AD129_1"  then
					self:ActivateInteractionArrow("Dictionary",false)
					self:ActivateAdviceMessage("AD130_1")
				elseif self.AdviceID == "AD131_2" or self.AdviceID == "AD131_1" then
					self:ActivateAdviceMessage("AD132_1")
					self:ActivateInteractionArrow("Statistics",false)
				end
			end
		end
	end

