@Logic
script UI_TutorialLogic extends Logic

	property any Dataset_Advice = nil

	property any Dataset_MaskInfo = nil

	property any Dataset_MaskRUID = nil

	property table AdviceFuntionTable = {}

	property string AdviceID = ""

	property Entity UI_DragThis = "27add21b-1155-4502-b7b1-41dd187d2855"

	property Entity UI_TutoStageSkipButton = "49bfc1c5-c1a7-4026-9c87-fd23bc44d279"

	property Entity UI_TutorialSelect = "6bf75961-6b42-46d8-9b96-6d487c72cfd5"

	property Entity UI_TutorialMask = "49e4683e-d3aa-48f0-a5cd-695dcbaff25d"

	property Entity UI_AdviceMessageSet = "3d982635-5fc2-4ca8-9851-a67fe0c2cc90"

	property Entity UI_SkipSelectPopup = "6b082a16-7468-48f3-86a9-be14761abdfd"

	property Entity UI_AdviceImage = "3261b605-fc09-493b-9aef-b9331b759f8d"

	property Entity UI_HPGauge = nil

	property Entity UI_MaskOverImage = "8a874641-cdd4-483a-8fb5-16d208a45019"

	property Entity UI_MaskSet = "43e0da5f-0156-49fb-8684-ee208d45b962"

	property boolean keepUnitInfo = false

	property Entity UI_UnitGuideLine = "d6ab6ffa-70d0-4dd5-ae27-3bbdb9096e0b"

	property Vector2 screenSize = Vector2(0,0)

	property Entity UI_Moveline = "276a92e7-358d-4542-aabd-e59f2f7ff498"

	property table offsetPointWorldPos = {}

	property any MaskSetPosRow = nil

	property string maskAnchor = ""

	property integer maskType = 0

	property Entity Entity_DragStartItem = nil

	property Entity Entity_DragEndUnit = nil

	property boolean ItemDragOnOff = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 튜토리얼 시스템 초기화 및 필요한 데이터셋 로드
		self.Dataset_Advice = _DataService:GetTable("AdviceDataset")
		self.Dataset_MaskInfo = _DataService:GetTable("TutorialMaskPositionDataset")
		self.Dataset_MaskRUID = _DataService:GetTable("MaskRUIDDataset")
		
		local user = _UserService.LocalPlayer
		local ownUnits = user.TeamManager.OwnUnits
		local enemyUnits  = user.TeamManager.EnemyUnits
		local tutorialManager = user.TutorialManager_New
		local gameManager = user.GameManager
		local dragTarget = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/InteractionGuide/DragThis/DragTarget")
		local arenaPath = self:SetArenaMapPath()
		
		--필요한 함수를 AdviceFunctionTable에 등록합니다.
		--------------------------------------
		
		-- 1-1 -------
		self.AdviceFuntionTable["AD100_1"] = function()
			--입장 시 채팅창 안보이게 함
			_EntityService:GetEntityByPath("/ui/AchievementPopupGroup/Panel_CustomChatVer3").Visible = false
		end
		
		-- 주황버섯 구매 유도
		self.AdviceFuntionTable["AD100_7"] = function()
			self:ActivateInteractionArrow("ShopChar1",true)
		end
		
		
		-- 초보자 & 슬라임 구매 유도
		
		self.AdviceFuntionTable["AD101_2"] = function()
			tutorialManager:SetAllowFeature("DragAllChar",false)
			tutorialManager:SetAllowFeature("Char2",true)
			tutorialManager:SetAllowFeature("Char3",true)
			self:ActivateInteractionArrow("ShopChar2",true)
			self:ActivateInteractionArrow("ShopChar3",true)
			_TimerService:SetTimerOnce(function()
				tutorialManager:SetDraggableCharID(ownUnits[1].UnitInfo.charID)
			end ,0.5)
			
		end
		
		-- 주황버섯 배치 유도
		self.AdviceFuntionTable["AD102_2"] = function()
			self:showTargetWaitLine(self:checkTargetWaitLine("C10002"))
			self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10002"),self:GetArenaTile(4,4),true)
			tutorialManager:SetCurrentTargetTile(4,4)
			dragTarget.UITransformComponent.RectSize = Vector2(80,80)
			dragTarget.UITransformComponent.Position = Vector3(0,-25,0)
			self:SetDragGuide("6d381bea1bcb4504b518a1fbfa0904ac",true,ownUnits[1],tutorialManager.CurrentTargetTile)
			self:ShowFieldTile(true)
		end
		
		-- 주황버섯 배치 유도
		self.AdviceFuntionTable["AD103_1"] = function()
			self:SetUnitGuideLine_Entity(nil,nil,false)
			self:showTargetWaitLine(nil)
			self.UI_Moveline.Enable = false
			self:SetDragGuide("",false,nil,nil)
		end
		
		-- 초보자와 슬라임 배치 유도
		self.AdviceFuntionTable["AD103_2"] = function()
			
			if ownUnits[2].UnitInfo.charID == "C10001" then
				--슬라임
				dragTarget.UITransformComponent.RectSize = Vector2(80,80)
				dragTarget.UITransformComponent.Position = Vector3(0,-25,0)
				self:showTargetWaitLine(self:checkTargetWaitLine("C10001"))
				tutorialManager:SetCurrentTargetTile(3,4)
				self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10001"),self:GetArenaTile(3,4),true)
			else
				--초보자
				dragTarget.UITransformComponent.RectSize = Vector2(90,90)
				dragTarget.UITransformComponent.Position = Vector3(0,-50,0)
				self:showTargetWaitLine(self:checkTargetWaitLine("C10010"))
				tutorialManager:SetCurrentTargetTile(3,1)
				self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10010"),self:GetArenaTile(3,1),true)
			end
			_TimerService:SetTimerOnce(function()
				tutorialManager:SetDraggableCharID(ownUnits[2].UnitInfo.charID)
			end ,0.25)
			self:SetDragGuide(ownUnits[2]:GetChildByName("SpriteRenderer").SpriteRendererComponent.SpriteRUID,true,ownUnits[2],tutorialManager.CurrentTargetTile)
			self:ShowFieldTile(true)
		end
		
		self.AdviceFuntionTable["AD103_2_1"] = function()
			
			if ownUnits[3].UnitInfo.charID == "C10001" then
				--슬라임
				dragTarget.UITransformComponent.RectSize = Vector2(80,80)
				dragTarget.UITransformComponent.Position = Vector3(0,-25,0)
				self:showTargetWaitLine(self:checkTargetWaitLine("C10001"))
				tutorialManager:SetCurrentTargetTile(3,4)
				self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10001"),self:GetArenaTile(3,4),true)
			else
				--초보자
				dragTarget.UITransformComponent.RectSize = Vector2(90,90)
				dragTarget.UITransformComponent.Position = Vector3(0,-50,0)
				self:showTargetWaitLine(self:checkTargetWaitLine("C10010"))
				tutorialManager:SetCurrentTargetTile(3,1)
				self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10010"),self:GetArenaTile(3,1),true)
			end
			_TimerService:SetTimerOnce(function()
				tutorialManager:SetDraggableCharID(ownUnits[3].UnitInfo.charID)
			end ,0.25)
			self:SetDragGuide(ownUnits[3]:GetChildByName("SpriteRenderer").SpriteRendererComponent.SpriteRUID,true,ownUnits[3],tutorialManager.CurrentTargetTile)
			self:ShowFieldTile(true)
		end
		
		self.AdviceFuntionTable["AD104_1"] = function()
			dragTarget.UITransformComponent.Position = Vector3(0,0,0)
			self:SetUnitGuideLine_Entity(nil,nil,false)
			self:ShowFieldTile(false)
			self:showTargetWaitLine(nil)
			self.UI_Moveline.Enable = false
			self:SetDragGuide("",false,nil,nil)
			self:BattleButtonOnOff(true)
		end
		
		
		-- 전투 세팅 단계
		
		self.AdviceFuntionTable["AD105_3"] = function()
			_CameraService:ZoomTo(350,0.25)
			self:ActivateInteractionArrow("BattleButton",false)
			
			for i=1,#ownUnits do
				ownUnits[i]:GetChildByName("StatInfo"):GetChildByName("HPbar").SpriteGUIRendererComponent:ChangeMaterial("material://7ece7a5f-bb9f-4fa2-bfea-a20dabc8e19a")
			end
			for i=1,#enemyUnits do
				enemyUnits[i]:GetChildByName("StatInfo"):GetChildByName("HPbar").SpriteGUIRendererComponent:ChangeMaterial("material://7ece7a5f-bb9f-4fa2-bfea-a20dabc8e19a")
			end
			
			local arenaHPGauge = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/HPGauge")
			self.UI_HPGauge = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/HPGauge")
			arenaHPGauge.UITransformComponent.WorldPosition = Vector3(-0.985,0.71,0)
			arenaHPGauge.Enable = true
			
		end
		
		self.AdviceFuntionTable["AD105_4"] = function()
			local arenaHPGauge = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/HPGauge")
			
			self.UI_HPGauge.SpriteGUIRendererComponent.ImageRUID = "6ae6970a630940dd8793be0098ff3dbf"
			local HPGauge_Line = self.UI_HPGauge:GetChildByName("HPGaugeLine")
			HPGauge_Line.SpriteGUIRendererComponent.ImageRUID = "e5910f40f7ab4f27a0a3ad7929288668"
			arenaHPGauge.UITransformComponent.WorldPosition = Vector3(-0.985,0.665,0)
			for i=1,#ownUnits do
				ownUnits[i]:GetChildByName("StatInfo"):GetChildByName("HPbar").SpriteGUIRendererComponent:ChangeMaterial("")
				ownUnits[i]:GetChildByName("StatInfo"):GetChildByName("MPbar").SpriteGUIRendererComponent:ChangeMaterial("material://7ece7a5f-bb9f-4fa2-bfea-a20dabc8e19a")
			end
			for i=1,#enemyUnits do
				enemyUnits[i]:GetChildByName("StatInfo"):GetChildByName("HPbar").SpriteGUIRendererComponent:ChangeMaterial("")
				enemyUnits[i]:GetChildByName("StatInfo"):GetChildByName("MPbar").SpriteGUIRendererComponent:ChangeMaterial("material://7ece7a5f-bb9f-4fa2-bfea-a20dabc8e19a")
			end
			
		end
		
		self.AdviceFuntionTable["AD105_5"] = function()
			local arenaHPGauge = _EntityService:GetEntityByPath(arenaPath.."/TutorialGuideSet/HPGauge")
			arenaHPGauge.Enable = false
			self.UI_HPGauge.Enable = false
		
			_CameraService:ZoomTo(80,1)
			for i=1,#ownUnits do
				ownUnits[i]:GetChildByName("StatInfo"):GetChildByName("MPbar").SpriteGUIRendererComponent:ChangeMaterial("")
			end
			for i=1,#enemyUnits do
				enemyUnits[i]:GetChildByName("StatInfo"):GetChildByName("MPbar").SpriteGUIRendererComponent:ChangeMaterial("")
			end
			tutorialManager:SetBattleStart()
			self.UI_HPGauge = nil
		end
		
		self.AdviceFuntionTable["AD106_4"] = function()
		
			self:ActivateInteractionArrow("BattleEnd",true)
			
		end
		
		-- 1-2
		
		---------------
		
		self.AdviceFuntionTable["AD107_4"] = function()
			
			self:ActivateInteractionArrow("ShopChar1",true)
		end
		
		--노블레스 배치
		self.AdviceFuntionTable["AD108_1"] = function()
			
			tutorialManager:SetAllowFeature("AlwaysShowFieldTile",true)
			_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",true)
			_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",false)
			tutorialManager:SetCurrentTargetTile(4,4)
				
			_TimerService:SetTimerOnce(function()
				self:showTargetWaitLine(self:checkTargetWaitLine("C10009"))
						dragTarget.UITransformComponent.RectSize = Vector2(100,100)
				dragTarget.UITransformComponent.Position = Vector3(5,-40,0)
				self:SetDragGuide(ownUnits[4]:GetChildByName("SpriteRenderer").SpriteRendererComponent.SpriteRUID,true,ownUnits[4],ownUnits[1])
				self:ShowFieldTile(true)
				self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10009"),self:GetArenaTile(4,4),true)
			end,0.5)
		end
		
		--
		self.AdviceFuntionTable["AD109_1"] = function()
			self:SetUnitGuideLine_Entity(nil,nil,false)
			self:showTargetWaitLine(nil)
			self:ShowFieldTile(false)
			self.UI_Moveline.Enable = false
			tutorialManager:SetCurrentTargetTile(0,0)
			self:SetDragGuide("",false,nil,nil)
		end
		
		--
		self.AdviceFuntionTable["AD109_4"] = function()
			self:ActivateInteractionArrow("ShopChar2",true)
			tutorialManager:SetAllowFeature("Char2",true)
		end
		
		-- 스톤골렘 구매
		self.AdviceFuntionTable["AD110_1"] = function()
			self:setUnitArrow(1,true)
			self:setUnitArrow(2,true)
			tutorialManager:SetAllowFeature("AlwaysShowFieldTile",true)
			_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",true)
			_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",false)
			tutorialManager:SetAllowFeature("PlaceAllTile",true)
			tutorialManager:SetAllowFeature("DragAllChar",true)
			_TimerService:SetTimerOnce(function() self:ShowSynergyTile("S10017",true) end,0.5)
			
		end
		
		--빅토리아 아일랜드 시너지 활성화
		self.AdviceFuntionTable["AD111_1"] = function()
			self:ShowFieldTile(false)
			self:ShowSynergyTile("S10017",false)
			self:BattleButtonOnOff(true)
			tutorialManager:SetAllowFeature("DragAllChar",false)
			tutorialManager:SetAllowFeature("PlaceAllTile",false)
			self:SetDragGuide("",false,nil,nil)
			tutorialManager:SetDraggableCharID("C10013")
		end
		
		-- 1-3
		---------------
		self.AdviceFuntionTable["AD112_1"] = function() 
			tutorialManager:SetAllowFeature("DragAllChar",false)
			tutorialManager:SetDraggableCharID("C10010")
		end
		
		--초보자 배치
		self.AdviceFuntionTable["AD112_4"] = function() 
			tutorialManager:SetDraggableCharID("C10010")
			tutorialManager:SetAllowFeature("PlaceAllTile",false)
			tutorialManager:SetAllowFeature("AlwaysShowFieldTile",true)
			local targetTile = self:checkAvailableTile(1)
			tutorialManager:SetCurrentTargetTile(math.floor(targetTile.TileComponent_New.verticalNum),math.floor(targetTile.TileComponent_New.horizontalNum))
			if ownUnits[2].UnitInfo.charID == "C10001"  then
				self:SetDragGuide(ownUnits[3]:GetChildByName("SpriteRenderer").SpriteRendererComponent.SpriteRUID,true,ownUnits[3],targetTile)
			else
				self:SetDragGuide(ownUnits[2]:GetChildByName("SpriteRenderer").SpriteRendererComponent.SpriteRUID,true,ownUnits[2],targetTile)
			end
			
			local choboTile = self:checkTargetWaitLine("C10010")
			self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10010"),targetTile,true)
			self:showTargetWaitLine(self:checkTargetWaitLine("C10010"))
			_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",true)
		end
		
		self.AdviceFuntionTable["AD113_1"] = function() 
			self:ShowFieldTile(false)
			self:showTargetWaitLine(nil)
			self:SetUnitGuideLine_Entity(nil,nil,false)
			self:SetDragGuide("",false,nil,nil)
			self.UI_Moveline.Enable = false
			tutorialManager:SetAllowFeature("AlwaysShowFieldTile",false)
			_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",false)
			
		end
		
		self.AdviceFuntionTable["AD113_3"] = function()
			self:ActivateInteractionArrow("ShopChar4",true)
			tutorialManager:SetAllowFeature("Char4",true)
		end
		
		self.AdviceFuntionTable["AD114_2"] = function()
			self:ActivateInteractionArrow("ShopReroll",true)
		end
		
		--새로고침 후
		self.AdviceFuntionTable["AD115_1"] = function()
			_EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/ShopPanel/CharacterShop/Tooltip_Reroll").Enable = false
			self:ActivateInteractionArrow("ShopReroll",false)
			self:ActivateInteractionArrow("ShopChar3",true)
			self:ActivateInteractionArrow("ShopChar4",true)
			self:ActivateInteractionArrow("ShopChar5",true)
		end
		
		self.AdviceFuntionTable["AD116_1"] = function()
			self.UI_AdviceImage.Enable = true
			self.UI_AdviceImage.SpriteGUIRendererComponent.ImageRUID.DataId = "702c836d7fb04955935d528fa4eb5e8e"
		end
		
		self.AdviceFuntionTable["AD116_2"] = function()
			self.UI_AdviceImage.Enable = false
			self:BattleButtonOnOff(true)
		end
		
		-- 2-1
		---------------
		self.AdviceFuntionTable["AD117_5"] = function()
		
			self:ActivateInteractionArrow("ShopEXP",true)
		end
		
		self.AdviceFuntionTable["AD117_1_1"] = function()
		
			self:ActivateInteractionArrow("ShopEXP",true)
		end
		
		self.AdviceFuntionTable["AD118_1"] = function()
		
			self:ActivateInteractionArrow("ShopEXP",false)
		end
		--노블레스 배치
		self.AdviceFuntionTable["AD118_2"] = function()
			local targetTile = self:checkAvailableTile(4)
			tutorialManager:SetAllowFeature("PlaceAllTile",false)
			tutorialManager:SetCurrentTargetTile(math.floor(targetTile.TileComponent_New.verticalNum),math.floor(targetTile.TileComponent_New.horizontalNum))
			local noblesse
			for i=1,#ownUnits do
				if ownUnits[i].UnitInfo.charID == "C10009" then
					noblesse = ownUnits[i]
					break
				end
			end
			self:SetDragGuide("5b02b6c0f19b456cb8350e89bff8948b",true,noblesse,targetTile)
			local choboTile = self:checkTargetWaitLine("C10009")
			self:SetUnitGuideLine_Entity(self:checkTargetWaitLine("C10009"),targetTile,true)
			tutorialManager:SetDraggableCharID("C10009")
			
			self:showTargetWaitLine(self:checkTargetWaitLine("C10009"))
			self:ShowFieldTile(true)
		end
		
		self.AdviceFuntionTable["AD118_1_1"] = function()
			dragTarget.UITransformComponent.RectSize = Vector2(100,100)
			dragTarget.UITransformComponent.Position = Vector3(0,0,0)
			self:SetUnitGuideLine_Entity(nil,nil,false)
			self:showTargetWaitLine(nil)
			self.UI_Moveline.Enable = false
			self:ShowFieldTile(false)
			tutorialManager:SetCurrentTargetTile(0,0)
			self:SetDragGuide("",false,nil,nil)
		end
		
		self.AdviceFuntionTable["AD118_1_3"] = function()
			
			tutorialManager:SetDraggableCharID("")
			self:ActivateInteractionArrow("ShopSpecial1",true)
		end
		
		self.AdviceFuntionTable["AD119_1"] = function()
			
		end
		
		self.AdviceFuntionTable["AD119_3"] = function()
			
			tutorialManager:SetAllowFeature("Char3",true)
			self:ActivateInteractionArrow("ShopChar3",true)
			self.UI_DragThis = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/InteractionGuide/DragThis")
		end
		
		--추억의 사제에게 카알 대검 장착시키기
		self.AdviceFuntionTable["AD120_1"] = function() 
			dragTarget.SpriteGUIRendererComponent.FlipX = false
			dragTarget.UITransformComponent.Position.y = -5
			dragTarget.SpriteGUIRendererComponent.PreserveSprite = PreserveSpriteType.AspectOnly
			dragTarget.UITransformComponent.RectSize = Vector2(55,55)
			tutorialManager:SetItemTargetCharID("C10008") 
		
			_TimerService:SetTimerOnce(function()
			---@type Entity
			local timePriest
			for i=1,#ownUnits do
				if ownUnits[i].UnitInfo.charID == "C10008" then
					timePriest = ownUnits[i]
						self.Entity_DragEndUnit = timePriest
					break
				end
			end
			self:SetTutoTileRUID(self:checkTargetWaitLine("C10008"),true)
			self:showTargetWaitLine(self:checkTargetWaitLine("C10008"))
		
			self.ItemDragOnOff = true
			end,1)
		end
		
		self.AdviceFuntionTable["AD121_1"] = function()
			self:showTargetWaitLine(nil)
			self.UI_Moveline.Enable = false
			self.ItemDragOnOff = false
			tutorialManager:SetAllowFeature("PlaceAllTile",false)
			dragTarget.UITransformComponent.Position.y = -50
		end
		
		self.AdviceFuntionTable["AD121_3"] = function() --추억의 사제 판매
			tutorialManager:SetDraggableCharID("C10008")
			self:SetTutoTileRUID(self:checkTargetWaitLine("C10008"),false)
			self:showTargetWaitLine(self:checkTargetWaitLine("C10008"))
			local timePriest
			for i=1,#ownUnits do
				if ownUnits[i].UnitInfo.charID == "C10008" then
					timePriest = ownUnits[i]
					self.Entity_DragEndUnit = timePriest
					break
				end
			end
			local sellUI = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/Panel_SellCharacter")
		
			self:setUnitArrow(3,true)
		end
		
		self.AdviceFuntionTable["AD122_1"] = function()
			self:showTargetWaitLine(nil)
			dragTarget.UITransformComponent.Position.y = -5
		
		end
		--아이템 장착
		self.AdviceFuntionTable["AD122_4"] = function() --AD122_4
			tutorialManager:SetItemTargetCharID("C10002")
			dragTarget.UITransformComponent.anchoredPosition = Vector2(0,-5)
			dragTarget.UITransformComponent.RectSize = Vector2(55,55)
			_TimerService:SetTimerOnce(function()
				---@type Entity
			local orangeMushroom
			for i=1,#ownUnits do
				if ownUnits[i].UnitInfo.charID == "C10002" then
					orangeMushroom = ownUnits[i]
					self.Entity_DragEndUnit = orangeMushroom
					break
				end
			end
			_TimerService:SetTimerOnce(function() 
			local itemImage = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_1/Icon")
			self:ShowTargetTile(self:CheckFieldcharTile("C10002"))
			self.ItemDragOnOff = true
			end, 0.25)
			end,1)
		end
		
		--주황버섯에게 카알 대검 장착
		self.AdviceFuntionTable["AD122_1_1"] = function()
			
			self:ShowTargetTile(self:CheckFieldcharTile("C10002"))
			self.keepUnitInfo = true
			self.UI_Moveline.Enable = false
			self.ItemDragOnOff = false
		end
		
		self.AdviceFuntionTable["AD122_2_1"] = function()
			self:ShowTargetTile(nil)
			
		end
		
		self.AdviceFuntionTable["AD122_3_1"] = function()
			self.keepUnitInfo = false
		end
		
		--전투 시작 버튼에 화살표로 강조
		self.AdviceFuntionTable["AD122_4_1"] = function()
			self:BattleButtonOnOff(true)
		end
		
		-- 2-2
		---------------
		
		self.AdviceFuntionTable["AD123_2"] = function()
		
			self:ActivateInteractionArrow("ShopSpecial1",true)
		end
		
		self.AdviceFuntionTable["AD124_1"] = function() -- 아이템 장착한 캐릭터에게 아이템 합성하기
			---@type Entity
			local itemHolder
			for i=1,#ownUnits do
				if ownUnits[i]:GetChildByName("StatInfo"):GetChildByName("ItemList").Enable == true then
					itemHolder = ownUnits[i]
					self.Entity_DragEndUnit = itemHolder
					break
				end
			end
			tutorialManager:SetItemTargetCharID(itemHolder.UnitInfo.charID)
			---@type Entity
			local itemImage
			if _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_2/Icon").Enable == true then
				itemImage = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_2/Icon")
			else
				itemImage = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_1/Icon")
			end
			if itemHolder == nil then
				
			else
				self:ShowTargetTile(self:CheckFieldcharTile(itemHolder.UnitInfo.charID))
			
				self.ItemDragOnOff = true
			end
		
		
			dragTarget.SpriteGUIRendererComponent.FlipX = false
		end
		
		self.AdviceFuntionTable["AD125_1"] = function() -- 아이템 합성
			self:ShowTargetTile(nil)
			self.ItemDragOnOff = false
			dragTarget.SpriteGUIRendererComponent.FlipX = true
			self.UI_AdviceImage.SpriteGUIRendererComponent.ImageRUID  = "90672b4e821f4aabafc87120a816981d"
			self.UI_AdviceImage.Enable = true
		end
		
		--설명 보조용 이미지 OFF
		self.AdviceFuntionTable["AD125_2"] = function() 
		
			self.UI_AdviceImage.Enable = false
		end
		
		-- 카르마의 가위 지급
		self.AdviceFuntionTable["AD125_4"] = function() 
		
			---@type Entity
			local itemHolder
		
			for i=1,#ownUnits do
				if ownUnits[i]:GetChildByName("StatInfo"):GetChildByName("ItemList").Enable == true then
					itemHolder = ownUnits[i]
					self.Entity_DragEndUnit = itemHolder
					break
				end
			end
			tutorialManager:SetItemTargetCharID(itemHolder.UnitInfo.charID)
			local itemImage = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_1/Icon")
			self:ShowTargetTile(self:CheckFieldcharTile(itemHolder.UnitInfo.charID))
			dragTarget.UITransformComponent.anchoredPosition = Vector2(-20,-30)
			self.ItemDragOnOff = true
			dragTarget.SpriteGUIRendererComponent.FlipX = false
		end
		
		-- 카르마의 가위 사용
		self.AdviceFuntionTable["AD125_1_1"] = function()
			self:ShowTargetTile(nil)
			self.ItemDragOnOff = false 
		end
		
		-- 초보자에게 아이템 주기
		self.AdviceFuntionTable["AD125_1_3"] = function() 
		
			tutorialManager:SetItemTargetCharID("C10010")
			dragTarget.UITransformComponent.anchoredPosition = Vector2(0,-5)
			_TimerService:SetTimerOnce(function()
				---@type Entity
			local timePriest
			for i=1,#ownUnits do
				if ownUnits[i].UnitInfo.charID == "C10010" then
					timePriest = ownUnits[i]
						self.Entity_DragEndUnit = timePriest
					break
				end
			end
			self:ShowTargetTile(self:CheckFieldcharTile(timePriest.UnitInfo.charID))
			local itemImage = _EntityService:GetEntityByPath("/ui/Arena_ReadyPhase/InventoryPanel/Inventory/Item_1/Icon")
			self.ItemDragOnOff = true
			end,1)
		end
		
		self.AdviceFuntionTable["AD125_2_1"] = function()
			self:ShowTargetTile(nil)
			self.ItemDragOnOff = false 
			self:BattleButtonOnOff(true)
		end
		
		-- 2-3
		---------------
		
		-- 룬 카드 구매
		self.AdviceFuntionTable["AD126_2"] = function()
			self:ActivateInteractionArrow("ShopSpecial3",true)
			self:ActivateInteractionArrow("ShopSpecial4",true)
		end
		
		self.AdviceFuntionTable["AD127_4"] = function()
			
		end
		
		self.AdviceFuntionTable["AD127_7"] = function() self:BattleButtonOnOff(true) end
		
		-- 3-1
		---------------
		
		self.AdviceFuntionTable["AD128_2"] = function() self:ActivateInteractionArrow("Dictionary",true) end
		self.AdviceFuntionTable["AD129_2"] = function() self:ActivateInteractionArrow("Dictionary_Exit",true) end
		self.AdviceFuntionTable["AD130_2"] = function() self:ActivateInteractionArrow("Statistics",true) end
		self.AdviceFuntionTable["AD131_2"] = function() self:ActivateInteractionArrow("Statistics_Exit",true) end
		
		self.AdviceFuntionTable["ADUN2_1"] = function()
			_TimerService:SetTimerOnce(function()
				if self.AdviceID == "ADUN2_1" then
				self:DeactivateAdviceMessage()
				end
			end,8)
		end
		
		self.AdviceFuntionTable["ADUN3_1"] = function()
			_TimerService:SetTimerOnce(function() 
				self.UI_MaskOverImage.Enable = true
				self:ActivateInteractionArrow("BattleEnd",true)
			 end,0.5)
		end
		
		-- 보상 지급
		self.AdviceFuntionTable["AD132_3"] = function() 
			_UserService.LocalPlayer.TutorialManager_New:CheckIsRewardReceived()
		end
		
		--튜토리얼 끝
		self.AdviceFuntionTable["AD132_4"] = function() 
			self.UI_TutorialMask.Enable = false
			self.UI_AdviceMessageSet.Enable = false
			self:DeactivateAllTutorialUI()
			self.ItemDragOnOff = false
			self:SetDragGuide("",false,nil,nil)
			self:SetSkipButton(false)
			_UserService.LocalPlayer.GuideToRulesManager:InitGuideList()
			user.LoadingManager.Enable = true
			local usePortal = function()
				gameManager:MoveToLobby("SaveAndExit")
			end
			_TimerService:SetTimerOnce(usePortal, 1)
		end
		
		self.AdviceFuntionTable[""] = function() end
	end

	@ExecSpace("ClientOnly")
