	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2f791f2a-eb92-4875-93dd-f55f1cc61e24")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 튜토리얼 거부/스킵 버튼 클릭 시 로비로 이동 처리
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		local user = _UserService.LocalPlayer
		local gameManager = user.GameManager
		if user.PlayerDataComponent.TutorialRewardReceived == false then
			user.TutorialManager_New:SetTutorialRejected()
		else
			--그냥 진행
		end
		local selectUIBackground = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/BackGround")
		selectUIBackground.Enable = false
		self.UI_TutorialMask.Enable = false
		self.UI_SkipSelectPopup.Enable = false
		self.UI_TutorialSelect.Enable = false
		if gameManager.ModeType == "Tutorial" then
			self:DeactivateAdviceMessage()
			self:DeactivateAllTutorialUI()
			self:SetDragGuide("",false,nil,nil)
			
			self:SetSkipButton(false)
			user.LoadingManager.Enable = true
			local usePortal = function()
				gameManager:MoveToLobby("SaveAndExit")
			end
			_TimerService:SetTimerOnce(usePortal, 1)
		end
	end

