		-- 튜토리얼 진행 또는 스킵 선택 UI를 활성화
		local tutoSel = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip/TutoStageButton")
		--self:AdjustTutoSelectButtonSize("Reset")
		--튜토리얼을 진행할지 스킵할지 물어보는 UI를 활성화합니다.
		local tutoStagePlay = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay/TutorialSelectText")
		local tutoStagePlay_Front = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay_Front/TutorialSelectText")
		local tutoStageSkip = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip/TutorialSelectText")
		local YesButton = self.UI_SkipSelectPopup:GetChildByName("YesButton"):GetChildByName("UIText")
		local NoButton = self.UI_SkipSelectPopup:GetChildByName("NoButton"):GetChildByName("UIText")
		local tutoSkipTitle = self.UI_SkipSelectPopup:GetChildByName("TutorialTitleText")
		local tutoSkipDesc = self.UI_SkipSelectPopup:GetChildByName("TutorialDescText")
		
		--[[
		tutoStagePlay:GetChildByName("TutorialSelectText1").TextComponent.Text =_LocalizationService:GetText("TutorialSelectButton_Play1")
		tutoStagePlay:GetChildByName("TutorialSelectText2").TextComponent.Text =_LocalizationService:GetText("TutorialSelectButton_Play2")
		tutoStagePlay_Front:GetChildByName("TutorialSelectText1").TextComponent.Text =_LocalizationService:GetText("TutorialSelectButton_Play1")
		tutoStagePlay_Front:GetChildByName("TutorialSelectText2").TextComponent.Text =_LocalizationService:GetText("TutorialSelectButton_Play2")
		tutoStageSkip:GetChildByName("TutorialSelectText1").TextComponent.Text =_LocalizationService:GetText("TutorialSelectButton_Skip1")
		tutoStageSkip:GetChildByName("TutorialSelectText2").TextComponent.Text =_LocalizationService:GetText("TutorialSelectButton_Skip2")
		YesButton.TextComponent.Text = _LocalizationService:GetText("Yes")
		NoButton.TextComponent.Text = _LocalizationService:GetText("No")
		tutoSkipTitle.TextComponent.Text = _LocalizationService:GetText("TutorialSkipPopup")
		tutoSkipDesc.TextComponent.Text = _LocalizationService:GetText("TutorialSkipPopupMain1").."\n".._LocalizationService:GetText("TutorialSkipPopupMain2")]]
		
