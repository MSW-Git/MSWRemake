@Component
script UI_AlphaDesolve extends Component

	@DisplayName("RevealTime")
	@Description("디졸브 되기 전에 UI가 보이는 시간입니다.")
	property number RevealTime = 2

	@DisplayName("DesolveTime")
	@Description([[투명화 지속시간입니다.
DesolveInterval과 곱하면 투명화가 진행되는 시간이 됩니다.]])
	property number DesolveTime = 20

	@DisplayName("DesolveRate")
	@Description("투명도의 변화량입니다.")
	property number DesolveRate = 0.08

	@DisplayName("DesolveInterval")
	@Description([[투명화되는 사이의 간격입니다.
Desolve와 곱하면 투명화되는 시간이 됩니다.]])
	property number DesolveInterval = 0.02

	property boolean isOn = false

	property Entity FeedbackMessage = "fedc7158-3b18-4e56-94db-c0411e8e1d19"

	@ExecSpace("ClientOnly")
	method void DesolveToDisable()
		-- UI를 서서히 투명화하여 비활성화
		if self.isOn then
			self.Entity.Enable = true
			self.Entity.CanvasGroupComponent.GroupAlpha = 1
			_TimerService:SetTimerOnce(function() 
		for i = 1,self.DesolveTime do
			_TimerService:SetTimerOnce(function()
				self.Entity.CanvasGroupComponent.GroupAlpha = self.Entity.CanvasGroupComponent.GroupAlpha - self.DesolveRate
			end, self.DesolveInterval*i)
		end
			_TimerService:SetTimerOnce(function()
				self.Entity.Enable = false
				self.Entity.CanvasGroupComponent.GroupAlpha = 1
			 end, self.DesolveInterval*self.DesolveTime)
		end, self.RevealTime)
		end
	end

	@ExecSpace("ClientOnly")
	method void DesolveToEnable()
		-- UI를 서서히 나타나게 하여 활성화
		if self.isOn then
			self.Entity.CanvasGroupComponent.GroupAlpha = 0
			self.Entity.Enable = true 
			for i = 1,self.DesolveTime do
				_TimerService:SetTimerOnce(function()
				self.Entity.CanvasGroupComponent.GroupAlpha = self.Entity.CanvasGroupComponent.GroupAlpha + self.DesolveRate
				end, self.DesolveInterval*i)
			end
			_TimerService:SetTimerOnce(function()
				self.Entity.CanvasGroupComponent.GroupAlpha = 1
			end, self.DesolveInterval*self.DesolveTime)
		end
	end

	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 상태 변화 시 피드백 메시지 표시 처리
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local state = event.state
		---------------------------------------------------------
		local clickThisSprite = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/MissionUI/ClickThis")
		if state == ButtonState.Hover and Environment:IsPCPlatform() then
			if self.Entity.Id == "59bf1365-97d0-4093-9968-b91d00fbddb2" then
				self.FeedbackMessage.Enable = true
			end
		else
			if self.Entity.Id == "59bf1365-97d0-4093-9968-b91d00fbddb2" then
				self.FeedbackMessage.Enable = false
			end
		end
		
	end

end