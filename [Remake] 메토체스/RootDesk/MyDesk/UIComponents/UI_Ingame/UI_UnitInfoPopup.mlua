	@ExecSpace("ClientOnly")
	method void UI_ShowCoachInfoTooltip(string coachID)
		-- 코치 정보 툴팁을 표시합니다.
		local ui_coachInfoTooltip = _EntityService:GetEntityByPath("/ui/UnitInfoPopupGroup/Tooltip_CoachInfo")
		
		local ui_image = ui_coachInfoTooltip:GetChildByName("CoachSprite_BG"):GetChildByName("CoachSprite")
		local ui_name = ui_coachInfoTooltip:GetChildByName("Name")
		local ui_desc = ui_coachInfoTooltip:GetChildByName("Desc")
		
		local data = _CoachService:GetCoachInfo(coachID)
		
		ui_image.SpriteGUIRendererComponent.ImageRUID = data.ProfileRUID
		local resourceData = _LoadResourcesInfo:GetUILocalPositionScale(data.ProfileRUID)
		ui_image.SpriteGUIRendererComponent.LocalScale = resourceData["scale"] 
		ui_image.SpriteGUIRendererComponent.LocalPosition = resourceData["pos"]
		ui_name.TextComponent.Text = data.Name
		ui_desc.TextComponent.Text = data.Desc --_LocalizationService:GetText(coachID.."_Desc")
		
		local uiPos = _Util:ScreenPostoUIPos(_InputService:GetCursorPosition())
		-- 화면 밖으로 나가지 않도록 보정
		if uiPos.x < 0 then 
			uiPos.x = 0 
		end
		if uiPos.y > (1080 - ui_coachInfoTooltip.UITransformComponent.RectSize.y -10) then 
			uiPos.y = (1080 - ui_coachInfoTooltip.UITransformComponent.RectSize.y - 10) 
		end
		
		ui_coachInfoTooltip.UITransformComponent.anchoredPosition = uiPos 
		ui_coachInfoTooltip.Enable = true
	end

	@ExecSpace("Client")
	method void UI_ShowFromCharacterShop(boolean enable, string charID)
		-- 캐릭터 상점에서 각 상품에 우클릭하면, 해당 캐릭터의 상세 정보를 띠웁니다.
		-- 캐릭터 상점에서 각 상품에 우클릭하면, 해당 캐릭터의 상세 정보를 띄웁니다.
		-- 띄우는 기준은 1레벨입니다.
		
		local ui_tooptip = _EntityService:GetEntityByPath("/ui/UnitInfoPopupGroup/Popup_UnitInfo")
		
		if enable == true then
			
			local characterInfo = _DataService:GetTable("CharacterInfo")
			local charInfoRow = characterInfo:FindRow("CharID", charID)
			
			local characterSynergyInfo = _DataService:GetTable("CharacterSynergy")
			local charSynergyRow = characterSynergyInfo:FindRow("CharID", charID)
			
			local synergyInfo = _DataService:GetTable("SynergyInfo")
			
			local characterStatusInfo = _DataService:GetTable("CharacterStatus")
			local charStatRow = characterStatusInfo:FindRow("SetID", charID.."1") 
			
			-- 초상화 갱신
			local ui_portrait = ui_tooptip:GetChildByName("Portrait"):GetChildByName("Sprite_UnitImage")
			local spriteRUID = charInfoRow:GetItem("IdleRUID")		
			ui_portrait.SpriteGUIRendererComponent.ImageRUID = spriteRUID
			local resourceInfo = _LoadResourcesInfo:GetUILocalPositionScale(spriteRUID)
			ui_portrait.SpriteGUIRendererComponent.LocalScale = resourceInfo["scale"]
			ui_portrait.SpriteGUIRendererComponent.LocalPosition = resourceInfo["pos"]
			
			-- 판매 가격 및 별 등급 정보 갱신
			local cost = charInfoRow:GetItem("Cost")
			local ui_sellCost = ui_tooptip:GetChildByName("Text_SellCost")
			ui_sellCost.TextComponent.Text = cost
			ui_sellCost:GetChildByName("Star_1").Enable = true
			ui_sellCost:GetChildByName("Star_2").Enable = false
			ui_sellCost:GetChildByName("Star_3").Enable = false
			ui_sellCost.UITransformComponent.RectSize.x = 76
			
			-- 역할군 및 이름 갱신
			ui_tooptip:GetChildByName("Text_Role").TextComponent.Text = _LocalizationService:GetText("CharacterRole_"..charInfoRow:GetItem("Role"))
			ui_tooptip:GetChildByName("Text_Name").TextComponent.Text = _LocalizationService:GetText(charID.."_Name")
			
			-- 보유 시너지 정보 갱신
			local ui_synergies = ui_tooptip:GetChildByName("List_Synergy")
			for i=1, 3 do
				local findingKey = string.format("Synergy_%d", i)
				local synergyID = charSynergyRow:GetItem(findingKey)
				local ui_synergy = ui_synergies:GetChildByName(findingKey)
				
				if _UtilLogic:IsNilorEmptyString(synergyID) == false and synergyID ~= "-" then
					local synergyRow = synergyInfo:FindRow("SynergyID", synergyID)
					ui_synergy:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(synergyID.."_Name")
					ui_synergy:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = synergyRow:GetItem("IconRUID")
					ui_synergy.Enable = true
				else
					ui_synergy.Enable = false
				end
			end
			
			-- 체력 정보 갱신
			local ui_hp = ui_tooptip:GetChildByName("StatInfo_HP")
			ui_hp:GetChildByName("Guage_Shield").SpriteGUIRendererComponent.FillAmount = 0
			ui_hp:GetChildByName("Guage").SpriteGUIRendererComponent.FillAmount = 1
			ui_hp:GetChildByName("Text").TextComponent.Text = charStatRow:GetItem("MaxHP").." / "..charStatRow:GetItem("MaxHP")
			
			-- MP 정보 갱신
			local ui_mp = ui_tooptip:GetChildByName("StatInfo_MP")
			local startingMP = tonumber(charStatRow:GetItem("MP"))
			local mpMax = tonumber(charStatRow:GetItem("MaxMP"))
			if mpMax == 0 then
				ui_mp:GetChildByName("Guage").SpriteGUIRendererComponent.FillAmount = 0
				ui_mp:GetChildByName("Text").TextComponent.Text = "0 / 0"
			else
				ui_mp:GetChildByName("Guage").SpriteGUIRendererComponent.FillAmount = startingMP / mpMax
				ui_mp:GetChildByName("Text").TextComponent.Text = string.format("%d / %d", startingMP, mpMax)
			end
			
			-- 아이템 정보 갱신
			local ui_items = ui_tooptip:GetChildByName("List_Items")
			for i=1, 3 do
				local ui_item = ui_items:GetChildByName(string.format("Item_%d", i))
				ui_item.SpriteGUIRendererComponent.ImageRUID = "696b848aaaea4cecb750aa19feaecf73"
				
				local ui_item_icon = ui_item:GetChildByName("Icon")
				ui_item_icon.SpriteGUIRendererComponent.ImageRUID = ""
				ui_item_icon.SpriteGUIRendererComponent.Color.a = 0
			end
			
			-- 스탯 정보 갱신
			local stats = {
				charStatRow:GetItem("PhysicalAttack"),
				charStatRow:GetItem("MagicalAttack"),
				charStatRow:GetItem("AttackSpeed"),
				
				charStatRow:GetItem("Defence"),
				charStatRow:GetItem("MagicalResistance"),
				charStatRow:GetItem("AttackRange"),
				
				"10%",	-- 크리티컬 확률
				"140%",	-- 크리티컬 데미지
				"0%",	-- 흡혈
				
				"100%",	-- 이동속도
				"0%",	-- 가해량 증가
				"0%",	-- 피해량 감소
			}
			local ui_stats = ui_tooptip:GetChildByName("List_Stat")
			for i=1, 12 do
				local ui_stat = ui_stats:GetChildByName(string.format("Stat_%d", i))
				ui_stat:GetChildByName("Num").TextComponent.Text = stats[i]
			end
			
			-- 스킬 보기 버튼 / 추천 아이템 버튼을 비활성화합니다.
			ui_tooptip:GetChildByName("Button_SkillInfo").Enable = false
			ui_tooptip:GetChildByName("Button_RecommendedItems").Enable = false
			
		end
		
		ui_tooptip.Enable = enable
	end

