	@EventSender("Entity", "5356ff10-6b06-4843-8e20-5e94a2326b43")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 스킬 정보 버튼 호버 상태 변경 처리
		-- Parameters
		local state = event.state
		local Entity = _UI_Tooltip.UI_SkillInfoFromUnitInfo
		---------------------------------------------------------
		if state == ButtonState.Hover then
			_UI_Tooltip:SetSkillInfo(true, "unitInfo", _UI_UnitInfoPopup.ConnectedEntity.UnitInfo.charID)
			_UI_Tooltip:SetMouseHoveredUI(Entity)
			
			if Environment:IsPCPlatform() then
				if _InputService:IsPointerOverUI() == true then
					return
				else
					_UI_Tooltip:SetSkillInfo(false, "unitInfo", _UI_UnitInfoPopup.ConnectedEntity.UnitInfo.charID)
					_UI_Tooltip:SetMouseHoveredUI(nil)
				end
			end
			
		else
			_UI_Tooltip:SetSkillInfo(false, "unitInfo", _UI_UnitInfoPopup.ConnectedEntity.UnitInfo.charID)
			_UI_Tooltip:SetMouseHoveredUI(nil)
		end
	end

	@EventSender("Entity", "17aec8b5-3ecc-4068-ac5c-1f7010607b40")
	handler HandleButtonStateChangeEvent2(ButtonStateChangeEvent event)
		-- 추천 아이템 버튼 호버 상태 변경 처리
		-- Parameters
		local state = event.state
		local Entity = _EntityService:GetEntityByPath("/ui/UnitInfoPopupGroup/Popup_UnitInfo/Button_SkillInfo")
		---------------------------------------------------------
		if state == ButtonState.Hover then
			_UI_Tooltip.UI_RecommendItemInfo.Enable = true
			_UI_Tooltip.RealtimeUpdateTargetUI = _UI_Tooltip.UI_RecommendItemInfo
			--_UI_Tooltip:SetMouseHoveredUI(_UI_Tooltip.UI_RecommendItemInfo)
			
		else
			_UI_Tooltip.UI_RecommendItemInfo.Enable = false
			_UI_Tooltip.RealtimeUpdateTargetUI = nil
		end
	end

end