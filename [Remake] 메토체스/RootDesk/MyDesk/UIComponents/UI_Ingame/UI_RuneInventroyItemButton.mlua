@Component
script UI_RuneInventroyItemButton extends Component

	property string Name = ""

	property string Desc = ""

	property number Grade = 0

	property number Cost = 0

	property boolean Tag_Indestructible = false

	property boolean Tag_Deactivated = false

	property integer Tag_Incineration = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 룬 인벤토리 아이템 버튼 초기화
		
	end

	@ExecSpace("Client")
	method void SetProperty(string name, string desc, number grade, number cost, boolean tag_indestructible, boolean tag_deactivated, integer tag_incineration)
		-- 룬 카드의 속성 정보를 설정합니다.
		self.Name = name
		self.Desc = desc
		self.Grade = grade
		self.Cost = cost
		self.Tag_Indestructible = tag_indestructible
		self.Tag_Deactivated = tag_deactivated
		self.Tag_Incineration = tag_incineration
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 룬 인벤토리 버튼 호버 상태 변경 시 툴팁 표시
		-- Parameters
		local state = event.state
		local index=tonumber(_UtilLogic:SubString(self.Entity.Name,6,1))
		---------------------------------------------------------
		if Environment:IsPCPlatform() then
			if state == ButtonState.Hover then
				local spriteRUID = self.Entity:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID
				_UI_Tooltip:SetRuneInfoUI(true, spriteRUID, self.Name, self.Desc, self.Grade, self.Cost, 
					self.Tag_Indestructible, self.Tag_Deactivated, self.Tag_Incineration,
					"Inventory")
				
				--겔리메르에 마우스 오버했다면 강조처리 + 오른쪽카드도 강조
				local runeID = ""
				if isvalid(_UserService.LocalPlayer.TeamManager.OwnRunes[index]) then
					runeID = _UtilLogic:Split(_UserService.LocalPlayer.TeamManager.OwnRunes[index], "_")[1]
				end
				if runeID == "RC40003" and not isvalid(_RuneCardSetLogic.CurrentDraggingEntity) then
					_RuneCardDirector:RC40003Director(index,true,false)
				end
			else
				_UI_Tooltip:SetRuneInfoUI(false, "", self.Name, self.Desc, self.Grade, self.Cost, 
					self.Tag_Indestructible, self.Tag_Deactivated, self.Tag_Incineration,
					"Inventory")
				local runeID = ""
				if isvalid(_UserService.LocalPlayer.TeamManager.OwnRunes[index]) then
					runeID = _UtilLogic:Split(_UserService.LocalPlayer.TeamManager.OwnRunes[index], "_")[1]
				end
				if runeID == "RC40003" then
					_RuneCardDirector:RC40003Director(index,false,false)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchBeginDragEvent(UITouchBeginDragEvent event)
		-- 룬 카드 드래그 시작 시 처리
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		if TouchId == -1 then
			_RuneCardSetLogic:SetDraggingEntity(self.Entity)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEndDragEvent(UITouchEndDragEvent event)
		-- 룬 카드 드래그 종료 시 처리
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		local index=tonumber(_UtilLogic:SubString(self.Entity.Name,6,1))
		---------------------------------------------------------
		if TouchId == -1 then
			_RuneCardSetLogic:OnDraggingEnd()
			
			local runeID = _UtilLogic:Split(_UserService.LocalPlayer.TeamManager.OwnRunes[index], "_")[1]
			if runeID == "RC40003" then
				_RuneCardDirector:RC40003Director(index,true,false)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 룬 카드 슬롯에 마우스 진입 시 현재 호버링 슬롯 설정
		---- Parameters
		--local Entity = event.Entity
		--local TouchId = event.TouchId
		--local TouchPoint = event.TouchPoint
		--local index=tonumber(_UtilLogic:SubString(self.Entity.Name,6,1))
		-----------------------------------------------------------
		_RuneCardSetLogic:SetCurrentMouseHoveringSlot(self.Entity)
		--if isvalid(_RuneCardSetLogic.CurrentDraggingEntity) == true then
		--    if self.Entity ~= _RuneCardSetLogic.CurrentDraggingEntity then
		--        _RuneCardSetLogic:SwapUIPositionOnDrag(self.Entity)
		--        if _UserService.LocalPlayer.TeamManager.OwnRunes[index]=="RC40003" then
		--            _RuneCardDirector:RC40003Director(index,false,false)
		--        end
		--    end
		--end
	end

end