@Component
script UI_UnitInfo_ItemSlot extends Component

	property string itemID = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 유닛 아이템 슬롯에 마우스 진입 시 아이템 정보 툴팁 표시
		if self.itemID ~= nil and self.itemID ~= "" and _ItemCombineService.IsShowingCombineTableUI == false then
			_UI_Tooltip:SetItemInfo(true, self.itemID, "UnitInfo")
			_UI_Tooltip:SetMouseHoveredUI(self.Entity)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 유닛 아이템 슬롯에서 마우스 빠져나갈 시 아이템 정보 툴팁 숨김
		if self.itemID ~= nil and self.itemID ~= "" then
			_UI_Tooltip:SetItemInfo(false, self.itemID, "UnitInfo")
			_UI_Tooltip:SetMouseHoveredUI(nil)
		end
		
	end

	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 유닛 아이템 슬롯 우클릭 시 조합 테이블 툴팁 표시
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		if TouchId == -2 then
			_ItemCombineService.WatchingUI = "UnitInfo"
			_ItemCombineService.WatchingItemID = self.itemID
			_ItemCombineService:ShowCombineTableTooltip(self.itemID, "UnitInfo")
		end
	end

end