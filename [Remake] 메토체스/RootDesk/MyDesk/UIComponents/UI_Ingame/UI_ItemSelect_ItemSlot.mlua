@Component
script UI_ItemSelect_ItemSlot extends Component

	property string ItemID = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 아이템 선택 슬롯 마우스 오버 시 아웃라인 및 툴팁 표시
		self.Entity.SpriteGUIRendererComponent.Outline = true
		
		if _UtilLogic:IsNilorEmptyString(self.ItemID) == false and _ItemCombineService.IsShowingCombineTableUI == false then
			local slotIdx = string.sub(self.Entity.Name, 6, -1)
			_UI_Tooltip:SetItemInfo(true, self.ItemID, "ItemBox_"..slotIdx)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 아이템 선택 슬롯 마우스 아웃 시 아웃라인 및 툴팅 비활성화
		self.Entity.SpriteGUIRendererComponent.Outline = false
		
		_UI_Tooltip:SetItemInfo(false, self.ItemID, "ItemBox")
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 아이템 선택 슬롯 클릭 시 아이템 선택 및 우클릭 시 조합 테이블 표시
		-- Parameters
		-- local Entity = event.Entity
		local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		if TouchId == -1 then
			local user = _UserService.LocalPlayer
			local teamManager = user.TeamManager
			
			local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
			teamManager:GetItemFromItemBox(idx)
			
			local clonedEffect = self.Entity:GetChildByName("Effect"):Clone("effect_cloned")
			clonedEffect:Destroy(1)
			
			-- 잠시 버튼을 비활성화합니다.
			self.Entity.SpriteGUIRendererComponent.RaycastTarget = false
			_TimerService:SetTimerOnce(function()
				self.Entity.SpriteGUIRendererComponent.RaycastTarget = true
			end, 1.5)
		
			
		elseif TouchId == -2 then
			_ItemCombineService.WatchingUI = "ItemSelect"
			_ItemCombineService:ShowCombineTableTooltip(self.ItemID, "ItemSelect")
			
		end
	end

end