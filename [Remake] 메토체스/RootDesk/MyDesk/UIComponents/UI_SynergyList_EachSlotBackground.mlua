@Component
script UI_SynergyList_EachSlotBackground extends Component

	property Entity UI_Name = nil

	property Entity UI_Level = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 시너지 이름과 레벨 UI 요소를 찾아 저장
		self.UI_Name = self.Entity:GetChildByName("Name")
		self.UI_Level = self.Entity:GetChildByName("Level")
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 시너지 이름과 레벨 텍스트 크기에 맞춰 배경 크기를 동적으로 조정
		if self.Enable then
			local nameSize = math.abs(self.UI_Name.UITransformComponent.anchoredPosition.x) + self.UI_Name.UITransformComponent.RectSize.x
			local levelSize = math.abs(self.UI_Name.UITransformComponent.anchoredPosition.x) + self.UI_Level.UITransformComponent.RectSize.x
			
			self.Entity.UITransformComponent.RectSize.x = math.max(nameSize, levelSize) + 4
		end
	end

end