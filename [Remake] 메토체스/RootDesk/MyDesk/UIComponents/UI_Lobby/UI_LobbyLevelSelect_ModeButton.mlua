@Component
script UI_LobbyLevelSelect_ModeButton extends Component

	@HideFromInspector
	property integer animID = 0

	property string Mode = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 모드 버튼 호버 상태 변경 시 설명 텍스트 애니메이션 처리
		-- Parameters
		local state = event.state
		---------------------------------------------------------
		local ui_desc = self.Entity:GetChildByName("Text_Desc")
		if state == ButtonState.Hover then
			local t = 0
			local anim = function()
				t += 1
				local posY = _TweenLogic:Ease(-ui_desc.UITransformComponent.RectSize.y, 60, 30, EaseType.QuadEaseOut, t)
				ui_desc.UITransformComponent.anchoredPosition.y = posY
				
				-- end of anim
				if t >= 30 then
					_TimerService:ClearTimer(self.animID)
					self.animID = 0
				end
			end
			self.animID = _TimerService:SetTimerRepeat(anim, 0.01, 0)
			
		else
			if self.animID ~= 0 then
				_TimerService:ClearTimer(self.animID)
				self.animID = 0
			end
			
			ui_desc.UITransformComponent.anchoredPosition.y = -ui_desc.UITransformComponent.RectSize.y
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 모드 버튼 클릭 시 해당 모드로 전환
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		_UI_LobbyLevelSelect:OnButtonClick_ModeSelect(self.Mode)
	end

end