@Logic
script UI_PlayerTitleSetting extends Logic

	@DisplayName("현재 인덱스")
	property integer currentIndex = 0

	property string ListGoingForward = "None"

	property table KWFTable_owned = {}

	property table KWBTable_owned = {}

	property table NTTable_owned = {}

	property boolean itsOn = false

	property boolean ShowOwnedTitlesOnly = false

	property Entity ui_ShowOwnedOnlyButton = "d71bdbe2-e036-4def-8497-c83efc7bff17"

	property Entity ui_NameTagButton = "20842d23-9466-449f-a763-3e18fdad63f2"

	property Entity ui_KeyWordFrontButton = "5c183c0f-33e7-49be-9c51-7954bdc4f733"

	property Entity ui_KeyWordBackButton = "f815abf3-1c72-4656-b54f-f959336115d3"

	property Entity ui_PreviousArrowButton = "61327e70-95d6-4972-8014-4e8670ec3772"

	property Entity ui_NextArrowButton = "9c815e6a-9e7c-4881-a3f5-f0bf4a2f3b70"

	property Entity ui_TitlePanel = "23355290-4bb4-4ba1-9f8a-81e5fd3611f5"

	@ExecSpace("ClientOnly")
	method void InitOwnedTable()
		--현재 보유중인 칭호 요소의 테이블을 만듭니다.
		-------------------------------------------------
		local nametagTable = _DataService:GetTable("Title_NameTagDataset")
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		
		local kwbTable = _UserService.LocalPlayer.TitleManager.KeyWordBackTable
		local kwfTable = _UserService.LocalPlayer.TitleManager.KeyWordFrontTable
		local ntTable = _UserService.LocalPlayer.TitleManager.NameTagTable
		
		for i=1,nametagTable:GetRowCount() do
			local target = nametagTable:GetRow(i):GetItem("NameTagID")
			if ntTable[target] == true then
				table.insert(self.NTTable_owned,target)
			end
		end
		
		for i=1,keywordFrontTable:GetRowCount() do
			local target = keywordFrontTable:GetRow(i):GetItem("KeyWordID")
			if kwfTable[target] == true then
				table.insert(self.KWFTable_owned,target)
			end
		end
		
		for i=1,keywordBackTable:GetRowCount() do
			local target = keywordBackTable:GetRow(i):GetItem("KeyWordID")
			if kwbTable[target] == true then
				table.insert(self.KWBTable_owned,target)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void CheckOwnedOnly()
		-- 보유 칭호만 보기 옵션 토글 및 목록 갱신
		local titleManager = _UserService.LocalPlayer.TitleManager
		
		self.currentIndex = 0
		if self.ShowOwnedTitlesOnly then
			self.ShowOwnedTitlesOnly = false
			self.ui_ShowOwnedOnlyButton.SpriteGUIRendererComponent.ImageRUID = "7b35e63f0e1762a44873a3cbd6d41c8d"
		else
			self.ShowOwnedTitlesOnly = true
			self.ui_ShowOwnedOnlyButton.SpriteGUIRendererComponent.ImageRUID= "c9942c3eba92f8b4a9d925a4594df149"
		end
		
		if titleManager.currentSelectedElements == "KeyWordFront" then
			self.ui_KeyWordFrontButton.UI_PlayerTitleButton:callTitleElementList()
		elseif titleManager.currentSelectedElements == "KeyWordBack" then
			self.ui_KeyWordBackButton.UI_PlayerTitleButton:callTitleElementList()
		elseif titleManager.currentSelectedElements == "NameTag" then
			self.ui_NameTagButton.UI_PlayerTitleButton:callTitleElementList()
		end
	end

	@ExecSpace("ClientOnly")
	method void GetNextTitleList()
		-- 리스트에 다음 칭호 요소 8개를 갱신합니다.
		local nametagTable = _DataService:GetTable("Title_NameTagDataset")
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		local titleManager =  _UserService.LocalPlayer.TitleManager
		local tableLength
		
		self.ui_PreviousArrowButton.Enable = true
		
		if titleManager.currentSelectedElements == "KeyWordFront" then
			if  self.ShowOwnedTitlesOnly then
				tableLength = #self.KWFTable_owned
			else
				tableLength = keywordFrontTable:GetRowCount()
			end
			
		elseif titleManager.currentSelectedElements == "KeyWordBack" then
			if  self.ShowOwnedTitlesOnly then
				tableLength = #self.KWBTable_owned
			else
				tableLength = keywordBackTable:GetRowCount()
			end
		
		elseif titleManager.currentSelectedElements == "NameTag" then
			if  self.ShowOwnedTitlesOnly then
				tableLength = #self.NTTable_owned
			else
				tableLength = nametagTable:GetRowCount()
			end
		end
		
		if self.currentIndex+8 >= tableLength then
			self.ui_NextArrowButton.Enable = false
		else
			self.currentIndex = self.currentIndex + 8
		end
		
		if titleManager.currentSelectedElements == "KeyWordFront" then
			self.ui_KeyWordFrontButton.UI_PlayerTitleButton:callTitleElementList()
		elseif titleManager.currentSelectedElements == "KeyWordBack" then
			self.ui_KeyWordBackButton.UI_PlayerTitleButton:callTitleElementList()
		elseif titleManager.currentSelectedElements == "NameTag" then
			self.ui_NameTagButton.UI_PlayerTitleButton:callTitleElementList()
		end
	end

	@ExecSpace("ClientOnly")
	method void GetPreviousTitleList()
		-- 리스트에 이전 칭호 요소 8개를 갱신합니다.
		local nametagTable = _DataService:GetTable("Title_NameTagDataset")
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		local titleManager =  _UserService.LocalPlayer.TitleManager
		
		self.ui_NextArrowButton.Enable = true
		self.currentIndex = self.currentIndex - 8
		
		if self.currentIndex <= 0 then
			self.currentIndex = 0
			self.ui_PreviousArrowButton.Enable = false
		end
		
		if titleManager.currentSelectedElements == "KeyWordFront" then
			self.ui_KeyWordFrontButton.UI_PlayerTitleButton:callTitleElementList()
		elseif titleManager.currentSelectedElements == "KeyWordBack" then
			self.ui_KeyWordBackButton.UI_PlayerTitleButton:callTitleElementList()
		elseif titleManager.currentSelectedElements == "NameTag" then
			self.ui_NameTagButton.UI_PlayerTitleButton:callTitleElementList()
		end
	end

	@ExecSpace("Client")
	method void AddToOwnedTable(string TitleElementID)
		-- 새로 획득한 칭호 요소를 보유 목록에 추가
		local IDhead = string.sub(TitleElementID,1,3)
		---@type table
		local targetTable
		if IDhead == "NT1" then
			targetTable = self.NTTable_owned
		elseif IDhead == "KWF" then
			targetTable = self.KWFTable_owned
		elseif IDhead == "KWB" then
			targetTable = self.KWBTable_owned
		end
		
		for i=1,#targetTable do
			if targetTable[i] == TitleElementID then
				return
			end
		end
		if self.itsOn == false then
			
		else
			table.insert(targetTable,TitleElementID)
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "d71bdbe2-e036-4def-8497-c83efc7bff17")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 보유 칭호만 보기 버튼 클릭 시 필터 토글
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:CheckOwnedOnly()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "9c815e6a-9e7c-4881-a3f5-f0bf4a2f3b70")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 다음 페이지 화살표 버튼 클릭 시 목록 갱신
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:GetNextTitleList()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "61327e70-95d6-4972-8014-4e8670ec3772")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 이전 페이지 화살표 버튼 클릭 시 목록 갱신
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:GetPreviousTitleList()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "363539c7-c792-46db-8148-b33b484f9837")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 랜덤 칭호 조합 버튼 클릭 시 랜덤 칭호 생성
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		local titleManager = _UserService.LocalPlayer.TitleManager
		titleManager:Random_Title()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleMouseScrollEvent(MouseScrollEvent event)
		-- 마우스 스크롤로 칭호 목록 페이지 이동
		--------------- Native Event Sender Info ----------------
		-- Sender: InputService
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local ScrollDelta = event.ScrollDelta
		---------------------------------------------------------
		if self.ui_TitlePanel.Enable then
			if ScrollDelta >= 0 then
				if self.currentIndex <=0 then
				
				else
					self:GetPreviousTitleList()
				end
			else
				self:GetNextTitleList()
			end
		end
	end

end