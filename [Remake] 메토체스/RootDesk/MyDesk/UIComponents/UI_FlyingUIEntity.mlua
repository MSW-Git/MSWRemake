@Component
script UI_FlyingUIEntity extends Component

	property Vector2 StartPos = Vector2(0,0)

	property Vector2 Destination = Vector2(0,0)

	@HideFromInspector
	property number LiveTime = 0

	@Description("비행 연출에 걸리는 시간을 적어줍니다. ")
	property number DirectionTime = 1

	property Entity DestroyEffect = nil

	@Description("엔터티가 사라지는 연출 애님 재생 시간을 입력합니다.")
	property number DestroyEffectDuration = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- UI 엔터티를 시작점에서 목적지까지 비행 애니메이션으로 이동
		self.LiveTime += delta
		
		local PosX = _TweenLogic:Ease(self.StartPos.x, self.Destination.x, self.DirectionTime, EaseType.ExpoEaseOut, self.LiveTime)
		local PosY = _TweenLogic:Ease(self.StartPos.y, self.Destination.y, self.DirectionTime, EaseType.ExpoEaseOut, self.LiveTime)
		
		self.Entity.UITransformComponent.anchoredPosition = Vector2(PosX, PosY)
		
		if self.LiveTime >= self.DirectionTime then
			local clonedEffect = self.DestroyEffect:Clone("Effect_cloned")
			if self.Entity.Name ~= "coinSprite_cloned" then
				clonedEffect:AttachTo(self.Entity.Parent)
				clonedEffect.UITransformComponent.AlignmentOption = self.Entity.UITransformComponent.AlignmentOption
				if self.Entity.Parent.Name == "Arena_BattlePhase" then
					clonedEffect.UITransformComponent.Pivot=self.Entity.UITransformComponent.Pivot:Clone()
				end
			end
			clonedEffect.UITransformComponent.anchoredPosition = self.Entity.UITransformComponent.anchoredPosition:Clone()
			clonedEffect:Destroy(self.DestroyEffectDuration)
			self.Entity:Destroy()
		end
	end

end