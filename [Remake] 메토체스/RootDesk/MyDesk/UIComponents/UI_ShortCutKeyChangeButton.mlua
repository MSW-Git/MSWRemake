@Component
script UI_ShortCutKeyChangeButton extends Component

	property string Action = ""

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 단축키 변경 모드를 활성화
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		_ShortCutKeyService:ActivateChangingKeyMode(self.Action, true)
	end

end