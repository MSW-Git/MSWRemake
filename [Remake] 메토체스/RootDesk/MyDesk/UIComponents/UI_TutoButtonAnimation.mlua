@Logic
script UI_TutoButtonAnimation extends Logic

	property number TweenTime = 0.25

	property string TutoSelectState = "Reset"

	property Entity UI_SkipSelectPopup = "6b082a16-7468-48f3-86a9-be14761abdfd"

	@ExecSpace("ClientOnly")
	method void AdjustTutoSelectButtonSize(string SkipOrPlay)
		--튜토리얼을 진행할지 선택하는 버튼의 사이즈 조절 연출입니다.
		
		
		local tutoSkipEntity= _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip")
		local tutoPlayEntity = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay")
		local tutoPlayEntity_Front = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay_Front")
		--선택하지 않은 버튼의 텍스트를 선택한 버튼이 덮어씌우는 연출을 위해, 레이어 순서가 높은 버튼 하나를 더 만듭니다.
		
		local skipChar = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip/TutoStageButton/Sprite_Gosu")
		local playChar = tutoPlayEntity:GetChildByName("Sprite_Chobo")
		local playChar_Front =  tutoPlayEntity_Front:GetChildByName("Sprite_Chobo")
		local skipText = tutoSkipEntity:GetChildByName("TutorialSelectText")
		local playText = tutoPlayEntity:GetChildByName("TutorialSelectText")
		local playText_Front =  tutoPlayEntity_Front:GetChildByName("TutorialSelectText")
		local tutoPlayButton = tutoPlayEntity:GetChildByName("TutoStageButton")
		local tutoSkipButton = tutoSkipEntity:GetChildByName("TutoStageButton")
		local tutoPlayButton_Front =  tutoPlayEntity_Front:GetChildByName("TutoStageButton")
		local PlayInnerButton = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay/TutoStageButton/TutoPlay")
		local SkipInnerButton = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip/TutoStageButton/TutoSkip")
		local PlayInnerButton_Front =  _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay_Front/TutoStageButton/TutoPlay")
		local playGround = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay/TutoStageButton/Sprite_Ground")
		local playGround2 = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStagePlay_Front/TutoStageButton/Sprite_Ground")
		local skipCloud1 = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip/TutoStageButton/Sprite_Could1")
		local skipCloud2 = _EntityService:GetEntityByPath("/ui/TutorialSelectGroup/TutorialSelectUI/TutoStageSkip/TutoStageButton/Sprite_Cloud2")
		
		
		
		--각 버튼 요소의 크기&위치 값
		------------------------------------------------------------------------
		--PlayChar의 x값은 마이너스로 설정해주셔야 합니다.
		local PlayChar_Original_Position = Vector2(-298,96)
		local PlayChar_Selected_Position = Vector2(-141,133)
		local PlayChar_Unselected_Position = Vector2(-170,96)
		local PlayChar_Original_Scale = Vector2(418,444)
		local PlayChar_Selected_Scale = Vector2(587,623)
		
		local SkipChar_Original_Position = Vector2(0,123)
		local SkipChar_Selected_Position = Vector2(-20,168)
		local SkipChar_Unselected_Position = Vector2(0,123)
		local SkipChar_Original_Scale = Vector2(632,434)
		local SkipChar_Selected_Scale = Vector2(861,762)
		
		local PlayButton_Original_RectSize = Vector2(738,970)
		local PlayButton_Selected_RectSize = Vector2(880,1300)
		
		local SkipButton_Original_RectSize = Vector2(738,970)
		local SkipButton_Selected_RectSize = Vector2(880,1300)
		
		local PlayButton_Original_Position = Vector2(-300,0)
		local PlayButton_Selected_Position = Vector2(-142,0)
		local PlayButton_Unselected_Position = Vector2(-168,0)
		
		local SkipButton_Original_Position = Vector2(300,0)
		local SkipButton_Selected_Position = Vector2(204,0)
		local SkipButton_Unselected_Position = Vector2(228,0)
		
		local SkipText_Original_Position = Vector2(300,-250)
		local SkipText_Selected_Position = Vector2(204,-234)
		local SkipText_Unselected_Position = Vector2(228,-250)
		
		local PlayText_Original_Position = Vector2(-300,-250)
		local PlayText_Selected_Position = Vector2(-150,-230)
		local PlayText_Unselected_Position = Vector2(-178,-250)
		
		local PlayGround_Original_Position = Vector2(0,-283)
		local PlayGround_Selected_Position = Vector2(0,-316)
		local PlayGround_Unselected_Position = Vector2(0,-283)
		
		local PlayGround_Original_Scale = Vector2(1100,508)
		local PlayGround_Selected_Scale = Vector2(1223,564)
		local PlayGround_Unselected_Scale = Vector2(1100,508)
		
		local SkipCloud_Original_Position = Vector2(-344,374)
		local SkipCloud_Selected_Position = Vector2(-446,328)
		local SkipCloud_Unselected_Position = Vector2(-344,374)
		
		local SkipCloud2_Original_Position = Vector2(298,-164)
		local SkipCloud2_Selected_Position = Vector2(333,-158)
		local SkipCloud2_Unselected_Position = Vector2(298,-164)
		
		
		local PlayInnerButton_Original_Position = Vector2(-10,-346)
		local PlayInnerButton_Selected_Position = Vector2(-10,-418)
		local PlayInnerButton_Unselected_Position = Vector2(-10,-346)
		
		local SkipInnerButton_Original_Position = Vector2(-5,-346)
		local SkipInnerButton_Selected_Position = Vector2(-5,-418)
		local SkipInnerButton_Unselected_Position = Vector2(-5,-346)
		------------------------------------------------------------------------
		
		--재생시간 통일
		--------------------
		tutoPlayButton.UITweenScale.duration = self.TweenTime
		tutoSkipButton.UITweenScale.duration = self.TweenTime
		tutoPlayButton.UITweenPosition.duration = self.TweenTime
		tutoSkipButton.UITweenPosition.duration = self.TweenTime
		tutoPlayButton_Front.UITweenScale.duration = self.TweenTime
		tutoPlayButton_Front.UITweenPosition.duration = self.TweenTime
		playChar.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		skipChar.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		PlayInnerButton.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		SkipInnerButton.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		PlayInnerButton_Front.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		playText.UITweenPosition.duration = self.TweenTime
		skipText.UITweenPosition.duration = self.TweenTime
		playText.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		skipText.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		playText_Front.UITweenPosition.duration = self.TweenTime
		playChar.UITweenPosition.duration = self.TweenTime
		skipChar.UITweenPosition.duration = self.TweenTime
		playChar_Front.UITweenPosition.duration = self.TweenTime
		playChar.UITweenScale.duration = self.TweenTime
		skipChar.UITweenScale.duration = self.TweenTime
		playChar_Front.UITweenScale.duration = self.TweenTime
		playGround.UITweenPosition.duration = self.TweenTime
		playGround.UITweenScale.duration = self.TweenTime
		playGround2.UITweenPosition.duration = self.TweenTime
		playGround2.UITweenScale.duration = self.TweenTime
		skipCloud1.UITweenPosition.duration = self.TweenTime
		skipCloud2.UITweenPosition.duration = self.TweenTime
		skipCloud1.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		skipCloud2.UITweenAlpha_GroupCanvas.duration = self.TweenTime
		PlayInnerButton.UITweenPosition.duration = self.TweenTime
		SkipInnerButton.UITweenPosition.duration = self.TweenTime
		PlayInnerButton_Front.UITweenPosition.duration = self.TweenTime
		------------------
		
		if SkipOrPlay == "Skip" then
			
			--튜토리얼 스킵 버튼에 마우스를 올렸을 때 연출입니다.
			tutoPlayButton.UITweenScale.from = PlayButton_Original_RectSize
			tutoPlayButton.UITweenScale.to = PlayButton_Original_RectSize
			tutoPlayButton.UITweenPosition.from = PlayButton_Original_Position
			tutoPlayButton.UITweenPosition.to = PlayButton_Unselected_Position
			
			tutoPlayButton_Front.UITweenScale.from = PlayButton_Original_RectSize
			tutoPlayButton_Front.UITweenScale.to = PlayButton_Original_RectSize
			tutoPlayButton_Front.UITweenPosition.from = PlayButton_Original_Position
			tutoPlayButton_Front.UITweenPosition.to = PlayButton_Unselected_Position
			
			tutoSkipButton.UITweenScale.from = SkipButton_Original_RectSize
			tutoSkipButton.UITweenScale.to = SkipButton_Selected_RectSize
			tutoSkipButton.UITweenPosition.from = SkipButton_Original_Position
			tutoSkipButton.UITweenPosition.to = SkipButton_Selected_Position
			
			playChar.UITweenPosition.from = PlayChar_Original_Position
			playChar.UITweenPosition.to = PlayChar_Unselected_Position
			skipChar.UITweenPosition.from = SkipChar_Original_Position
			skipChar.UITweenPosition.to = SkipChar_Selected_Position
			playChar_Front.UITweenPosition.from = PlayChar_Original_Position
			playChar_Front.UITweenPosition.to = PlayChar_Unselected_Position
			
			playChar.UITweenScale.from =PlayChar_Original_Scale
			playChar.UITweenScale.to = PlayChar_Original_Scale
			skipChar.UITweenScale.from = SkipChar_Original_Scale
			skipChar.UITweenScale.to =SkipChar_Selected_Scale
			playChar_Front.UITweenScale.from = PlayChar_Original_Scale
			playChar_Front.UITweenScale.to = PlayChar_Original_Scale
			
			playText.UITweenPosition.from = PlayText_Original_Position
			playText.UITweenPosition.to = PlayText_Unselected_Position
			playText_Front.UITweenPosition.from = PlayText_Original_Position
			playText_Front.UITweenPosition.to = PlayText_Unselected_Position
			skipText.UITweenPosition.from = SkipText_Original_Position
			skipText.UITweenPosition.to = SkipText_Selected_Position
			
			playGround.UITweenPosition.from = PlayGround_Original_Position
			playGround.UITweenPosition.to = PlayGround_Unselected_Position
			playGround.UITweenScale.from = PlayGround_Original_Scale
			playGround.UITweenScale.to = PlayGround_Unselected_Scale
			
			playGround2.UITweenPosition.from = PlayGround_Original_Position
			playGround2.UITweenPosition.to = PlayGround_Unselected_Position
			playGround2.UITweenScale.from = PlayGround_Original_Scale
			playGround2.UITweenScale.to = PlayGround_Unselected_Scale
			
			skipCloud1.UITweenPosition.from = SkipCloud_Original_Position
			skipCloud1.UITweenPosition.to = SkipCloud_Selected_Position
			skipCloud2.UITweenPosition.from = SkipCloud2_Original_Position
			skipCloud2.UITweenPosition.to = SkipCloud2_Selected_Position
			
			SkipInnerButton.UITweenPosition.from = SkipInnerButton_Original_Position
			SkipInnerButton.UITweenPosition.to = SkipInnerButton_Selected_Position
			PlayInnerButton.UITweenPosition.from = PlayInnerButton_Original_Position
			PlayInnerButton_Front.UITweenPosition.from = PlayInnerButton_Original_Position
			PlayInnerButton.UITweenPosition.to = PlayInnerButton_Unselected_Position
			PlayInnerButton_Front.UITweenPosition.to = PlayInnerButton_Unselected_Position
			
			--머티리얼 적용
			playChar.SpriteGUIRendererComponent.MaterialId = "material://40103420-630e-47fc-bf71-054dc30194fe"
			skipChar.SpriteGUIRendererComponent.MaterialId = ""
			
			tutoPlayEntity_Front:SetVisible(false)
			--tutoPlayEntity_Front:SetEnable(false)
			
			--내부 버튼 레이캐스트 설정
			PlayInnerButton.SpriteGUIRendererComponent.RaycastTarget = false
			PlayInnerButton_Front.SpriteGUIRendererComponent.RaycastTarget = false
			SkipInnerButton.SpriteGUIRendererComponent.RaycastTarget = true
			
			--투명도 조절
			if skipChar.CanvasGroupComponent.GroupAlpha ~= 1 then
				skipText.UITweenAlpha_GroupCanvas.from = 0.3
				skipChar.UITweenAlpha_GroupCanvas.from = 0.35
				skipCloud1.UITweenAlpha_GroupCanvas.from = 0.1
				skipCloud2.UITweenAlpha_GroupCanvas.from = 0.1
			else
				skipChar.UITweenAlpha_GroupCanvas.from = 1
				skipText.UITweenAlpha_GroupCanvas.from = 1
				skipCloud1.UITweenAlpha_GroupCanvas.from = 1
				skipCloud2.UITweenAlpha_GroupCanvas.from = 1 
			end
			playChar.UITweenAlpha_GroupCanvas.from = 1
			playChar.UITweenAlpha_GroupCanvas.to = 0.35
			skipChar.UITweenAlpha_GroupCanvas.to = 1
			skipCloud1.UITweenAlpha_GroupCanvas.to = 1
			skipCloud2.UITweenAlpha_GroupCanvas.to = 1
			
			playText.UITweenAlpha_GroupCanvas.from = 1
			playText.UITweenAlpha_GroupCanvas.to = 0.3
			skipText.UITweenAlpha_GroupCanvas.to = 1
			
			--내부 버튼 투명도 조절
			SkipInnerButton.UITweenAlpha_GroupCanvas.from = 0
			SkipInnerButton.UITweenAlpha_GroupCanvas.to = 1
			PlayInnerButton.UITweenAlpha_GroupCanvas.from = 0
			PlayInnerButton_Front.UITweenAlpha_GroupCanvas.from = 0
			PlayInnerButton.UITweenAlpha_GroupCanvas.to = 0
			PlayInnerButton_Front.UITweenAlpha_GroupCanvas.to = 0
			----------
			
		elseif SkipOrPlay == "Play" then
			--튜토리얼 진행 버튼에 마우스를 올렸을 때 연출입니다.
			--tutoPlayEntity_Front:SetEnable(true)
			tutoPlayEntity_Front:SetVisible(true)
			tutoPlayButton.UITweenScale.from = PlayButton_Original_RectSize
			tutoPlayButton.UITweenScale.to = PlayButton_Selected_RectSize
			tutoPlayButton.UITweenPosition.from = PlayButton_Original_Position
			tutoPlayButton.UITweenPosition.to = PlayButton_Selected_Position
			
			tutoPlayButton_Front.UITweenScale.from = PlayButton_Original_RectSize
			tutoPlayButton_Front.UITweenScale.to = PlayButton_Selected_RectSize
			tutoPlayButton_Front.UITweenPosition.from = PlayButton_Original_Position
			tutoPlayButton_Front.UITweenPosition.to = PlayButton_Selected_Position
			
			tutoSkipButton.UITweenScale.from = SkipButton_Original_RectSize
			tutoSkipButton.UITweenScale.to = SkipButton_Original_RectSize
			tutoSkipButton.UITweenPosition.from = SkipButton_Original_Position
			tutoSkipButton.UITweenPosition.to = SkipButton_Unselected_Position
			
			playChar.UITweenPosition.from = PlayChar_Original_Position
			playChar.UITweenPosition.to = PlayChar_Selected_Position
			skipChar.UITweenPosition.from = SkipChar_Original_Position
			skipChar.UITweenPosition.to = SkipChar_Unselected_Position
			playChar_Front.UITweenPosition.from = PlayChar_Original_Position
			playChar_Front.UITweenPosition.to = PlayChar_Selected_Position
			
			playChar.UITweenScale.from = PlayChar_Original_Scale
			playChar.UITweenScale.to = PlayChar_Selected_Scale
			skipChar.UITweenScale.from = SkipChar_Original_Scale
			skipChar.UITweenScale.to = SkipChar_Original_Scale
			playChar_Front.UITweenScale.from = PlayChar_Original_Scale
			playChar_Front.UITweenScale.to = PlayChar_Selected_Scale
			
			playText.UITweenPosition.from = PlayText_Original_Position
			playText.UITweenPosition.to = PlayText_Selected_Position
			playText_Front.UITweenPosition.from =  PlayText_Original_Position
			playText_Front.UITweenPosition.to = PlayText_Selected_Position
			skipText.UITweenPosition.from = SkipText_Original_Position
			skipText.UITweenPosition.to =SkipText_Unselected_Position
			
			playGround.UITweenPosition.from = PlayGround_Original_Position
			playGround.UITweenPosition.to = PlayGround_Selected_Position
			playGround.UITweenScale.from = PlayGround_Original_Scale
			playGround.UITweenScale.to = PlayGround_Selected_Scale
			
			playGround2.UITweenPosition.from = PlayGround_Original_Position
			playGround2.UITweenPosition.to = PlayGround_Selected_Position
			playGround2.UITweenScale.from = PlayGround_Original_Scale
			playGround2.UITweenScale.to = PlayGround_Selected_Scale
			
			skipCloud1.UITweenPosition.from = SkipCloud_Original_Position
			skipCloud1.UITweenPosition.to = SkipCloud_Unselected_Position
			skipCloud2.UITweenPosition.from = SkipCloud2_Original_Position
			skipCloud2.UITweenPosition.to = SkipCloud2_Unselected_Position
			
			SkipInnerButton.UITweenPosition.from = SkipInnerButton_Original_Position
			SkipInnerButton.UITweenPosition.to = SkipInnerButton_Unselected_Position
			PlayInnerButton.UITweenPosition.from = PlayInnerButton_Original_Position
			PlayInnerButton_Front.UITweenPosition.from = PlayInnerButton_Original_Position
			PlayInnerButton.UITweenPosition.to = PlayInnerButton_Selected_Position
			PlayInnerButton_Front.UITweenPosition.to = PlayInnerButton_Selected_Position
			
			
			--머티리얼 적용
			playChar.SpriteGUIRendererComponent.MaterialId = ""
			skipChar.SpriteGUIRendererComponent.MaterialId = "material://701c33e0-03bd-441e-8346-8bcb0470f41d"
			
			--내부 버튼 레이캐스트 설정
			PlayInnerButton.SpriteGUIRendererComponent.RaycastTarget = true
			PlayInnerButton_Front.SpriteGUIRendererComponent.RaycastTarget = true
			SkipInnerButton.SpriteGUIRendererComponent.RaycastTarget = false
			
			--투명도 조절
			if playChar.CanvasGroupComponent.GroupAlpha ~= 1 then
				playChar.UITweenAlpha_GroupCanvas.from = 0.35
				playText.UITweenAlpha_GroupCanvas.from = 0.3
			else
				playChar.UITweenAlpha_GroupCanvas.from = 1
				playText.UITweenAlpha_GroupCanvas.from = 1
			end
			playChar.UITweenAlpha_GroupCanvas.to = 1
			skipChar.UITweenAlpha_GroupCanvas.from = 1
			skipChar.UITweenAlpha_GroupCanvas.to = 0.35
			playText.UITweenAlpha_GroupCanvas.to = 1
			skipText.UITweenAlpha_GroupCanvas.from = 1
			skipText.UITweenAlpha_GroupCanvas.to = 0.3
			
			skipCloud1.UITweenAlpha_GroupCanvas.from = 1
			skipCloud2.UITweenAlpha_GroupCanvas.from = 1
			skipCloud1.UITweenAlpha_GroupCanvas.to = 0.2
			skipCloud2.UITweenAlpha_GroupCanvas.to = 0.2
			
			--내부 버튼 투명도 조절
			SkipInnerButton.UITweenAlpha_GroupCanvas.from = 0
			SkipInnerButton.UITweenAlpha_GroupCanvas.to = 0
			PlayInnerButton.UITweenAlpha_GroupCanvas.from = 0
			PlayInnerButton_Front.UITweenAlpha_GroupCanvas.from = 0
			PlayInnerButton.UITweenAlpha_GroupCanvas.to = 1
			PlayInnerButton_Front.UITweenAlpha_GroupCanvas.to = 1
			--------------
		
		
			
			
		
		elseif SkipOrPlay == "Reset" then
			--팝업 바깥으로 마우스를 이동했을 때 연출입니다.
			--모든 버튼을 원래 크기로 되돌립니다.
			
			-- 실행 버튼 활성화 상태일 때
			if tutoPlayButton.UITweenScale.to == PlayButton_Selected_RectSize then
				
				tutoPlayButton.UITweenScale.from = PlayButton_Selected_RectSize
				tutoPlayButton.UITweenScale.to = PlayButton_Original_RectSize
				tutoPlayButton.UITweenPosition.from = PlayButton_Selected_Position
				tutoPlayButton.UITweenPosition.to = PlayButton_Original_Position
			
				tutoSkipButton.UITweenScale.from = SkipButton_Original_RectSize
				tutoSkipButton.UITweenScale.to = SkipButton_Original_RectSize
				tutoSkipButton.UITweenPosition.from = SkipButton_Unselected_Position
				tutoSkipButton.UITweenPosition.to = SkipButton_Original_Position
			
				tutoPlayButton_Front.UITweenScale.from = PlayButton_Selected_RectSize
				tutoPlayButton_Front.UITweenScale.to = PlayButton_Original_RectSize
				tutoPlayButton_Front.UITweenPosition.from = PlayButton_Selected_Position
				tutoPlayButton_Front.UITweenPosition.to = PlayButton_Original_Position
			
				playText.UITweenPosition.from = PlayText_Selected_Position
				playText.UITweenPosition.to = PlayText_Original_Position
				playText_Front.UITweenPosition.from =PlayText_Selected_Position
				playText_Front.UITweenPosition.to = PlayText_Original_Position
				skipText.UITweenPosition.from = SkipText_Unselected_Position
				skipText.UITweenPosition.to = SkipText_Original_Position
		
				playChar.UITweenPosition.from = PlayChar_Selected_Position
				playChar.UITweenPosition.to = PlayChar_Original_Position
				skipChar.UITweenPosition.from = SkipChar_Unselected_Position
				skipChar.UITweenPosition.to = SkipChar_Original_Position
				playChar_Front.UITweenPosition.from = PlayChar_Selected_Position
				playChar_Front.UITweenPosition.to = PlayChar_Original_Position
				
				playChar.UITweenScale.from = PlayChar_Selected_Scale
				playChar.UITweenScale.to = PlayChar_Original_Scale
				skipChar.UITweenScale.from = SkipChar_Original_Scale
				skipChar.UITweenScale.to =SkipChar_Original_Scale
				playChar_Front.UITweenScale.from = PlayChar_Selected_Scale
				playChar_Front.UITweenScale.to = PlayChar_Original_Scale
				
				playGround.UITweenPosition.from = PlayGround_Selected_Position
				playGround.UITweenPosition.to = PlayGround_Original_Position
				playGround.UITweenScale.from = PlayGround_Selected_Scale
				playGround.UITweenScale.to = PlayGround_Original_Scale
				
				playGround2.UITweenPosition.from = PlayGround_Selected_Position
				playGround2.UITweenPosition.to = PlayGround_Original_Position
				playGround2.UITweenScale.from = PlayGround_Selected_Scale
				playGround2.UITweenScale.to = PlayGround_Original_Scale
				
				skipCloud1.UITweenPosition.from = SkipCloud_Unselected_Position
				skipCloud1.UITweenPosition.to =SkipCloud_Original_Position 
				skipCloud2.UITweenPosition.from =  SkipCloud2_Unselected_Position
				skipCloud2.UITweenPosition.to = SkipCloud2_Original_Position
				
				SkipInnerButton.UITweenPosition.from = SkipInnerButton_Unselected_Position
			SkipInnerButton.UITweenPosition.to = SkipInnerButton_Original_Position
			PlayInnerButton.UITweenPosition.from = PlayInnerButton_Selected_Position
			PlayInnerButton_Front.UITweenPosition.from = PlayInnerButton_Selected_Position
			PlayInnerButton.UITweenPosition.to = PlayInnerButton_Original_Position
			PlayInnerButton_Front.UITweenPosition.to = PlayInnerButton_Original_Position
				
			-- 스킵 버튼 활성화 상태일 때
			elseif tutoSkipButton.UITweenScale.to == SkipButton_Selected_RectSize then
			
				tutoPlayButton.UITweenScale.from = PlayButton_Original_RectSize
				tutoPlayButton.UITweenScale.to = PlayButton_Original_RectSize
				tutoPlayButton.UITweenPosition.from = PlayButton_Unselected_Position
				tutoPlayButton.UITweenPosition.to = PlayButton_Original_Position
				
				tutoSkipButton.UITweenScale.from = SkipButton_Selected_RectSize
				tutoSkipButton.UITweenScale.to = SkipButton_Original_RectSize
				tutoSkipButton.UITweenPosition.from = SkipButton_Selected_Position
				tutoSkipButton.UITweenPosition.to =SkipButton_Original_Position
			
				tutoPlayButton_Front.UITweenScale.from = PlayButton_Original_RectSize
				tutoPlayButton_Front.UITweenScale.to = PlayButton_Original_RectSize
				tutoPlayButton_Front.UITweenPosition.from =  PlayButton_Unselected_Position
				tutoPlayButton_Front.UITweenPosition.to =  PlayButton_Original_Position
				
				playText.UITweenPosition.from = PlayText_Unselected_Position
				playText.UITweenPosition.to = PlayText_Original_Position
				playText_Front.UITweenPosition.from = PlayText_Unselected_Position
				playText_Front.UITweenPosition.to = PlayText_Original_Position
				skipText.UITweenPosition.from = SkipText_Selected_Position
				skipText.UITweenPosition.to = SkipText_Original_Position
		
				playChar.UITweenPosition.from = PlayChar_Unselected_Position
				playChar.UITweenPosition.to = PlayChar_Original_Position
				skipChar.UITweenPosition.from = SkipChar_Selected_Position
				skipChar.UITweenPosition.to = SkipChar_Original_Position
				playChar_Front.UITweenPosition.from = PlayChar_Unselected_Position
				playChar_Front.UITweenPosition.to = PlayChar_Original_Position
				
				playChar.UITweenScale.from =PlayChar_Original_Scale
				playChar.UITweenScale.to = PlayChar_Original_Scale
				skipChar.UITweenScale.from = SkipChar_Selected_Scale
				skipChar.UITweenScale.to =SkipChar_Original_Scale
				playChar_Front.UITweenScale.from = PlayChar_Original_Scale
				playChar_Front.UITweenScale.to = PlayChar_Original_Scale
				
				playGround.UITweenPosition.from = PlayGround_Unselected_Position
				playGround.UITweenPosition.to = PlayGround_Original_Position
				playGround.UITweenScale.from = PlayGround_Unselected_Scale
				playGround.UITweenScale.to = PlayGround_Original_Scale
				
				playGround2.UITweenPosition.from = PlayGround_Unselected_Position
				playGround2.UITweenPosition.to = PlayGround_Original_Position
				playGround2.UITweenScale.from = PlayGround_Unselected_Scale
				playGround2.UITweenScale.to = PlayGround_Original_Scale
				
				skipCloud1.UITweenPosition.from = SkipCloud_Selected_Position
				skipCloud1.UITweenPosition.to =SkipCloud_Original_Position 
				skipCloud2.UITweenPosition.from =  SkipCloud2_Selected_Position
				skipCloud2.UITweenPosition.to = SkipCloud2_Original_Position
				
				SkipInnerButton.UITweenPosition.to = SkipInnerButton_Original_Position
			SkipInnerButton.UITweenPosition.from = SkipInnerButton_Selected_Position
		
			
			PlayInnerButton.UITweenPosition.from = PlayInnerButton_Unselected_Position
			PlayInnerButton.UITweenPosition.to = PlayInnerButton_Original_Position
			PlayInnerButton_Front.UITweenPosition.from = PlayInnerButton_Unselected_Position
			PlayInnerButton_Front.UITweenPosition.to = PlayInnerButton_Original_Position
		
			
			end
			
			--머티리얼 적용
			playChar.SpriteGUIRendererComponent.MaterialId = ""
			skipChar.SpriteGUIRendererComponent.MaterialId = ""
			
			--투명도 조절
			if playChar.CanvasGroupComponent.GroupAlpha ~= 1 then
				playChar.UITweenAlpha_GroupCanvas.from = 0.35
				playText.UITweenAlpha_GroupCanvas.from = 0.3
			else
				playChar.UITweenAlpha_GroupCanvas.from = 1
				playText.UITweenAlpha_GroupCanvas.from = 1
			end
			if skipChar.CanvasGroupComponent.GroupAlpha ~= 1 then
				skipChar.UITweenAlpha_GroupCanvas.from = 0.35
				skipText.UITweenAlpha_GroupCanvas.from = 0.3
				skipCloud1.UITweenAlpha_GroupCanvas.from = 0.2
				skipCloud2.UITweenAlpha_GroupCanvas.from = 0.2
			else
				skipChar.UITweenAlpha_GroupCanvas.from = 1
				skipText.UITweenAlpha_GroupCanvas.from = 1
				skipCloud1.UITweenAlpha_GroupCanvas.from = 1
				skipCloud2.UITweenAlpha_GroupCanvas.from = 1
			end
			
			--내부 버튼 레이캐스트 설정
			PlayInnerButton.SpriteGUIRendererComponent.RaycastTarget = false
			PlayInnerButton_Front.SpriteGUIRendererComponent.RaycastTarget = false
			SkipInnerButton.SpriteGUIRendererComponent.RaycastTarget = false
			
			--내부 버튼 투명도 조절
			if PlayInnerButton.CanvasGroupComponent.GroupAlpha == 1 or PlayInnerButton_Front.CanvasGroupComponent.GroupAlpha == 1  then
				PlayInnerButton.UITweenAlpha_GroupCanvas.from = 1
				PlayInnerButton_Front.UITweenAlpha_GroupCanvas.from = 1
			else
				PlayInnerButton.UITweenAlpha_GroupCanvas.from = 0
				PlayInnerButton_Front.UITweenAlpha_GroupCanvas.from = 0
			end
			
			if SkipInnerButton.CanvasGroupComponent.GroupAlpha == 1 then
				SkipInnerButton.UITweenAlpha_GroupCanvas.from = 1
			else
				SkipInnerButton.UITweenAlpha_GroupCanvas.from = 0
			end
			
			playChar.UITweenAlpha_GroupCanvas.to = 1
			skipChar.UITweenAlpha_GroupCanvas.to = 1
			playText.UITweenAlpha_GroupCanvas.to = 1
			skipText.UITweenAlpha_GroupCanvas.to = 1
			skipCloud1.UITweenAlpha_GroupCanvas.to = 1
				skipCloud2.UITweenAlpha_GroupCanvas.to = 1
			
			PlayInnerButton_Front.UITweenAlpha_GroupCanvas.to = 0
			PlayInnerButton.UITweenAlpha_GroupCanvas.to = 0
			SkipInnerButton.UITweenAlpha_GroupCanvas.to = 0
			--------------
			
			
			
		end
		
		tutoSkipButton.UITweenScale:Play()
		tutoSkipButton.UITweenPosition:Play()
		tutoPlayButton.UITweenPosition:Play()
		tutoPlayButton.UITweenScale:Play()
		tutoPlayButton_Front.UITweenPosition:Play()
		tutoPlayButton_Front.UITweenScale:Play()
		playChar.UITweenAlpha_GroupCanvas:Play()
		skipChar.UITweenAlpha_GroupCanvas:Play()
		skipText.UITweenPosition:Play()
		playText.UITweenPosition:Play()
		playText.UITweenAlpha_GroupCanvas:Play()
		skipText.UITweenAlpha_GroupCanvas:Play()
		playText_Front.UITweenPosition:Play()
		playChar.UITweenPosition:Play()
		skipChar.UITweenPosition:Play()
		playChar_Front.UITweenPosition:Play()
		playChar.UITweenScale:Play()
		skipChar.UITweenScale:Play()
		playChar_Front.UITweenScale:Play()
		PlayInnerButton.UITweenAlpha_GroupCanvas:Play()
		SkipInnerButton.UITweenAlpha_GroupCanvas:Play()
		PlayInnerButton_Front.UITweenAlpha_GroupCanvas:Play()
		playGround.UITweenPosition:Play()
		playGround2.UITweenPosition:Play()
		skipCloud1.UITweenPosition:Play()
		skipCloud2.UITweenPosition:Play()
		skipCloud1.UITweenAlpha_GroupCanvas:Play()
		skipCloud2.UITweenAlpha_GroupCanvas:Play()
		playGround.UITweenScale:Play()
		playGround2.UITweenScale:Play()
		PlayInnerButton.UITweenPosition:Play()
		PlayInnerButton_Front.UITweenPosition:Play()
		SkipInnerButton.UITweenPosition:Play()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a418f331-4b26-4c7b-bf5d-bc96eaab1dc2")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 튜토리얼 플레이 버튼 클릭 시 상태 변경 및 애니메이션 처리
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		if self.UI_SkipSelectPopup.Enable == true then
			
		else
		if self.TutoSelectState == "Reset" then
			self.TutoSelectState = "Play"
		else
			self.TutoSelectState = "Reset"
			
		end
		self:AdjustTutoSelectButtonSize(self.TutoSelectState)
			
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2bf823f9-e6d4-4486-81be-96f3615e8a5b")
