@Component
script UI_ActivateTooltipOnMouseHover extends Component

	@Description("이 UI엔티티 위에 마우스를 올리면 활성화시킬 툴팁 UI입니다. 이 엔티티에 TouchReceiveComponent가 있어야 합니다.")
	property Entity TooltipUI = nil

	@Description("OnUpdate 함수를 통해 Position을 업데이트할 지 여부입니다. 이 값이 true이면 Anchor, anchoredPosition값을 참고하여 TooltipUI의 위치를 조절합니다.")
	property boolean PositionUpdate = false

	@Description("PositionUpdate가 true일 때, 툴팁이 참조할 모서리 영역입니다. 우상단은 (1, 1), 좌하단은 (-1, -1)로 사용합니다.")
	property Vector2 Anchor = Vector2(0,0)

	property Vector2 AnchoredPosition = Vector2(0,0)

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 툴팁 위치를 실시간으로 업데이트
		if self.PositionUpdate == true and self.TooltipUI.Enable then
			self.TooltipUI.UITransformComponent.anchoredPosition = Vector2(
				960 * self.Anchor.x + self.AnchoredPosition.x - self.Anchor.x * self.TooltipUI.UITransformComponent.RectSize.x * 0.5,
				540 * self.Anchor.y + self.AnchoredPosition.y - self.Anchor.y * self.TooltipUI.UITransformComponent.RectSize.y * 0.5
			)
		end
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스가 UI 영역에 진입했을 때 툴팁 활성화 (PC 플랫폼만)
		if Environment:IsPCPlatform() then
			self.TooltipUI.Enable = true
		end
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스가 UI 영역에서 벗어났을 때 툴팁 비활성화 (PC 플랫폼만)
		if Environment:IsPCPlatform() then
			self.TooltipUI.Enable = false
		end
	end

end