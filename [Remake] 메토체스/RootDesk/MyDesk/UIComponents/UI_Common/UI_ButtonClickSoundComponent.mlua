@Component
script UI_ButtonClickSoundComponent extends Component

	property string Soundtype = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 지정된 사운드 재생
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		if self.Soundtype ~= "" then
			_PlaySoundLogic:PlaySound(self.Soundtype)
		end
	end

	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- UI 터치 다운 시 지정된 사운드 재생
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		if self.Soundtype ~= "" then
			_PlaySoundLogic:PlaySound(self.Soundtype)
		end
		
	end

end