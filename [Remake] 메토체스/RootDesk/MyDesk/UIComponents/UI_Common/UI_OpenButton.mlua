@Component
script UI_OpenButton extends Component

	property Entity TargetUI = nil

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 지정된 대상 UI를 활성화
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.TargetUI.Enable = true
	end

end