@Component
script UI_Loading_TextBlinker extends Component

	property number Time = 0

	property Color Color1 = Color(224/255,234/255,242/255,1)

	property Color Color2 = Color(83/255,125/255,207/255,1)

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 텍스트 색상을 주기적으로 변경하여 깜빡임 효과 구현
		self.Time += delta
		
		if self.Time <= 1 then
			local color = Color.Lerp(self.Color1, self.Color2, self.Time / 1)
			self.Entity.TextComponent.FontColor = color
		elseif self.Time <= 2 then
			local color = Color.Lerp(self.Color2, self.Color1, (self.Time - 1) / 1)
			self.Entity.TextComponent.FontColor = color
		else
			self.Time = 0
		end
	end

end