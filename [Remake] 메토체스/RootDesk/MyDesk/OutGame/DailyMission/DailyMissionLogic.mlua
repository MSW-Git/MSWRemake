@Logic
script DailyMissionLogic extends Logic

	property SyncTable<string, string> MissionDesc

	property SyncTable<string, integer> MissionConditionLevel

	property SyncTable<string, integer> MissionCondition

	property SyncTable<string, integer> MissionRewardPoint

	property Entity UI_MissionList = "6d0bc8df-8efc-461d-b6e0-acf35f0f05df"

	property Entity UI_BonusGuage = "b0f2dbb0-2cc3-4fee-94ff-4fd57d0cacbe"

	property Entity UI_BonusPointText = "f585ec03-713d-48fc-ab68-8c943ece6996"

	property Entity UI_Button_BonusRewardReceive = "748ca4bb-ac40-4da0-9ab0-98a9c3cf15df"

	property Entity UI_RewardList = "31d7d0e1-66cc-49d3-a672-37c3f0e8c463"

	property integer DoingRefreshIndex = 0

	method void OnBeginPlay()
		-- 게임 시작 시 일일 미션 데이터셋을 로드하는 초기화 함수
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- 데이터셋에서 일일 미션 정보를 로드하여 내부 테이블에 저장하는 함수
		local dataSet = _DataService:GetTable("DailyMission")
		
		for i=1, dataSet:GetRowCount() do
			local row = dataSet:GetRow(i)
			
			local missionID = row:GetItem("MissionID")
			
			local desc = row:GetItem("Desc")
			local level = row:GetItem("Level")
			local condition = row:GetItem("Condition")
			local point = row:GetItem("Reward_Point")
			
			if level == "0" then
				self.MissionDesc[missionID] = _LocalizationService:GetText(desc)
			else
				self.MissionDesc[missionID] = _LocalizationService:GetTextFormat(desc, level)
			end
			
			self.MissionConditionLevel[missionID] = tonumber(level)
			self.MissionCondition[missionID] = tonumber(condition)
			self.MissionRewardPoint[missionID] = tonumber(point)
		end
	end

	@ExecSpace("Client")
	method void UI_RefreshMissionList()
		-- 일일 미션 목록 UI를 새로고침하는 함수
		local user = _UserService.LocalPlayer
		local dmCompo = user.DailyMissionComponent
		---------------------------------------------------------------
		for i=1, 3 do
			local ui_mission = self.UI_MissionList:GetChildByName(string.format("Mission_%d", i))
				
			ui_mission.UI_DailyMission_Slot.MissionIndex = i
			ui_mission.UI_DailyMission_Slot:RefreshUI()
		end
	end

	@ExecSpace("Client")
	method void UI_RefreshPointArea()
		-- 보너스 포인트 영역 UI를 새로고침하는 함수
		local user = _UserService.LocalPlayer
		local dmCompo = user.DailyMissionComponent
		---------------------------------------------------------------
		self.UI_BonusGuage.SpriteGUIRendererComponent.FillAmount = dmCompo.BonusPoint / 120
		self.UI_BonusPointText.TextComponent.Text = string.format("%d", dmCompo.BonusPoint)
		
		-- 보상 수령 상태에 따라 버튼 상태 변경
		local setButtonEnable = function()
			self.UI_Button_BonusRewardReceive.TextComponent.Text = "GetReward" -- Localization
			self.UI_Button_BonusRewardReceive.SpriteGUIRendererComponent.Color = Color.FromHexCode("#fff19c")
			self.UI_Button_BonusRewardReceive.ButtonComponent.Enable = true
		end
		
		local setButtonInprogress = function()
			self.UI_Button_BonusRewardReceive.TextComponent.Text = "InProgress" -- Localization
			self.UI_Button_BonusRewardReceive.SpriteGUIRendererComponent.Color = Color.FromHexCode("#444444")
			self.UI_Button_BonusRewardReceive.ButtonComponent.Enable = false
		end
		
		local setButtonDisable = function()
			self.UI_Button_BonusRewardReceive.TextComponent.Text = "CompleteReward" -- Localization
			self.UI_Button_BonusRewardReceive.SpriteGUIRendererComponent.Color = Color.FromHexCode("#444444")
			self.UI_Button_BonusRewardReceive.ButtonComponent.Enable = false
		end
		
		-- 보상 수령 여부에 따라, 각 보상에 체크 표시 활성화
		local rewardReceiveState = dmCompo.BonusRewardReceiveState
		for i=1, 6 do
			local slot = self.UI_RewardList:GetChildByName(string.format("Slot_%d", i))
			
			-- 보상을 받은 상태
			if rewardReceiveState >= i then
				slot:GetChildByName("RewardBG").Enable = false
				slot:GetChildByName("Sprite_Received").Enable = true
			else
				slot:GetChildByName("RewardBG").Enable = true
				slot:GetChildByName("Sprite_Received").Enable = false
			end
		end
		
		-- 보상 수령 여부 및 현재 포인트에 따라 [보상 받기] 버튼 변경
		local isReceivable = false
		local pointCondition = {20, 40, 60, 80, 100, 120}
		for i=1, 6 do
			if dmCompo.BonusRewardReceiveState < i and dmCompo.BonusPoint >= pointCondition[i] then
				isReceivable = true
			end
		end
		
		if isReceivable == true then
			setButtonEnable()
		else
			if dmCompo.BonusPoint < 120 then
				setButtonInprogress()
			else
				setButtonDisable()
			end
		end
	end

	@ExecSpace("Client")
	method void ShowUI_RefreshCheckPopup(integer missionIndex)
		-- 미션 새로고침 확인 팝업을 표시하는 함수
		self.DoingRefreshIndex = missionIndex
		
		_EntityService:GetEntityByPath("/ui/Lobby_DailyMission/Popup_RefreshCheck").Enable = true
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "748ca4bb-ac40-4da0-9ab0-98a9c3cf15df")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 보너스 보상 수령 버튼 클릭 이벤트 핸들러
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		if self._T.ButtonClickCooltime == nil then
			self._T.ButtonClickCooltime = false
		end
		
		if self._T.ButtonClickCooltime == true then
			return
		end
		
		_UserService.LocalPlayer.DailyMissionComponent:ReceiveBonusReward()
		
		self._T.ButtonClickCooltime = true
		_TimerService:SetTimerOnce(function()
			self._T.ButtonClickCooltime = false
		end, 1.5)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "35d6cdc8-9ead-4de9-a660-2e7b86e0a606")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 미션 새로고침 확인 버튼 클릭 이벤트 핸들러
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		if self.DoingRefreshIndex > 0 then
			_UserService.LocalPlayer.DailyMissionComponent:RefreshMission_Check(self.DoingRefreshIndex)	
		end
		
		-- 팝업 닫기
		_EntityService:GetEntityByPath("/ui/Lobby_DailyMission/Popup_RefreshCheck").Enable = false
	end

	@EventSender("Entity", "f67a9f83-39aa-4c4d-bf7c-9e127842af35")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- '다시 묻지 않기' 체크박스 토글 버튼 클릭 이벤트 핸들러
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		local ui_checkBox = _EntityService:GetEntityByPath("/ui/Lobby_DailyMission/Popup_RefreshCheck/Panel/Button_AskNoMore/Sprite_Checkbox/Sprite_Check")
		
		ui_checkBox.Enable = not ui_checkBox.Enable
	end

end