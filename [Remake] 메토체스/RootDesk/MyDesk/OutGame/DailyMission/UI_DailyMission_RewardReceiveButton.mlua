@Component
script UI_DailyMission_RewardReceiveButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 일일 미션 보상 수령 버튼 클릭 이벤트 핸들러
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		local missionIndex = self.Entity.Parent.UI_DailyMission_Slot.MissionIndex
		_UserService.LocalPlayer.DailyMissionComponent:ReceiveReward(missionIndex)
		
		-- 버튼 입력 쿨타임 적용
		Entity.ButtonComponent.Enable = false
		_TimerService:SetTimerOnce(function()
			Entity.ButtonComponent.Enable = true
		end, 1.5)
	end

end