@Component
script UI_DailyMisison_RefreshButton extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 일일 미션 새로고침 버튼 클릭 이벤트 핸들러
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		local missionIndex = self.Entity.Parent.UI_DailyMission_Slot.MissionIndex
		
		local ui_noAskCheckbox = _EntityService:GetEntityByPath("/ui/Lobby_DailyMission/Popup_RefreshCheck/Panel/Button_AskNoMore/Sprite_Checkbox/Sprite_Check")
		-- '다시 묻지 않기' 체크된 경우
		if ui_noAskCheckbox.Enable == true then
			_UserService.LocalPlayer.DailyMissionComponent:RefreshMission_Check(missionIndex)
			
			-- 버튼 입력 쿨타임 적용
			Entity.ButtonComponent.Enable = false
			_TimerService:SetTimerOnce(function()
				Entity.ButtonComponent.Enable = true
			end, 1.5)
		
		-- 그 외
		else
			_DailyMissionLogic:ShowUI_RefreshCheckPopup(missionIndex)
		end
	end

end