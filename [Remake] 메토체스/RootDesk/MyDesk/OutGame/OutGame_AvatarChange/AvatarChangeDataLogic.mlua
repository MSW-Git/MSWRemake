@Logic
script AvatarChangeDataLogic extends Logic

	property string newAvatarModel_ID = "model://2e4afeb8-55f6-4269-94d2-cd70ff176dca"

	property string newAvatarEffectModel_ID = "model://e3ebdd1a-7372-4d09-b560-f53de3d7e794"

	property table AvatarChangeData = {}

	method void OnBeginPlay()
		-------------------------------
		-- func: 데이터를 초기화 합니다. (클라/서버 동시 실행, 서버가 먼저 실행됩니다.)
		-- Logic으로, 서버 생성 시 1회 실행
		-------------------------------
		
		---@type MODUserDataSet
		local dataSet = _DataService:GetTable("AvatarChangeData")
		
		for i=1, dataSet:GetRowCount() do
			
			local row = dataSet:GetRow(i)
			
			local avatarChangeData = AvatarChangeData()
			avatarChangeData.CharID = row:GetItem("CharID")
			avatarChangeData.Scale = tonumber(row:GetItem("Scale"))
			avatarChangeData.MoveSpeed = tonumber(row:GetItem("MoveSpeed"))
			avatarChangeData.RUID_IDLE = row:GetItem("IDLE")
			avatarChangeData.RUID_MOVE = row:GetItem("MOVE")
			avatarChangeData.RUID_JUMP = row:GetItem("JUMP")
			avatarChangeData.RUID_ATTACK = row:GetItem("ATTACK")
			avatarChangeData.RUID_ATTACK_WAIT = row:GetItem("ATTACK_WAIT")
			
			self.AvatarChangeData[avatarChangeData.CharID] = avatarChangeData
		
		end
	end

end