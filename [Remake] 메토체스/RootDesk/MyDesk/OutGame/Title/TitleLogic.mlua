@Logic
script TitleLogic extends Logic

	property string UserTitle = ""

	@ExecSpace("Server")
	method void getOtherUserTitle(string userID)
		-- 다른 사용자의 칭호 데이터를 데이터베이스에서 가져와 클라이언트에 설정
		local userTitleKey = ""
		
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		-- 1. 데이터 갖고오기
		local eq_err, equipTitleValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait("EquippedTitle")
		for i = 1, 10 do
			if eq_err == 0 then
				break
			elseif i == 10 then
				
			else
				eq_err, equipTitleValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait("EquippedTitle")
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(equipTitleValue) then
			if equipTitleValue ~= "NIL" then
				local eqTable = _UtilLogic:Split(equipTitleValue, ",")
				
				for _, v in pairs(eqTable) do
					local keyInfo = _UtilLogic:Split(v, "_")
					
					local key = keyInfo[1]
					local value = keyInfo[2]
					
					if key == "KeyWordFront" then
						userTitleKey = value
					elseif key == "KeyWordBack" then
						userTitleKey = userTitleKey.."_"..value
					end
				end
			end
		end
		
		self:setTitle(userTitleKey,senderUserId)
	end

	@ExecSpace("Client")
	method void setTitle(string TitleID)
		-- 칭호 ID를 바탕으로 칭호 텍스트를 생성하고 표시
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		
		local titlekeyInfo = _UtilLogic:Split(TitleID, "_")
		local title = _LocalizationService:GetText(keywordFrontTable:FindRow("KeyWordID",titlekeyInfo[1]):GetItem("Name")).." ".._LocalizationService:GetText(keywordFrontTable:FindRow("KeyWordID", titlekeyInfo[2]):GetItem("Name"))
	end

end