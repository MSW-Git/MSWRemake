@Component
script UI_AchievementCategoryInfo extends Component

	property Entity BtnGroup = "a62cdc0a-e1d7-4a5b-90ca-37fde38fa59a"

	property string CategoryID = "1"

	property string CategoryState = ""

	property string CategoryRewardID = ""

	property Entity ProgressSlider = "3a071854-426a-4383-bcc2-cdfd147ce209"

	property Entity ProgressText = "8819d877-af8c-4de1-a9bd-0e12aa8edd19"

	property Entity Reward = "6be82763-c371-4fe2-b06e-6bd0cd71f69d"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		for _,btn in pairs(self.BtnGroup.Children) do 
		
		-- '카테고리 버튼' 버튼 클릭 이벤트 연결 
		btn:ConnectEvent(ButtonClickEvent,
				function() 
						self:OnClick_CategoryBtn(btn.Name)
				end	)
		end
		
		local rewardItemBtn = self.Entity:GetChildByName("RewardGroup")
		
		-- 보상 툴팁 연결 
		
		self.Reward:ConnectEvent(UITouchEnterEvent,
				function() 
						self:OnClickBtn_RewardItem()
				end	)
		
		self.Reward:ConnectEvent(UITouchExitEvent,
				function() 
					_UI_AchievementService.ToolTip.Enable = false
				end	)
	end

	@ExecSpace("Client")
	method void RenderAchievementCategoryInfo(string achievementCategoryID)
		-------------------------------------------------------------------
		-- func: 업적 카테고리 정보 UI 출력 데이터를 변경하는 함수 
		-------------------------------------------------------------------
		
		-- parameters
		self.CategoryID = achievementCategoryID
		local playerCategoryData = _UserService.LocalPlayer.AchievementManager.PlayerAchieveCategoryData[self.CategoryID]
		self.CategoryState = playerCategoryData['state']
		local completeCount = playerCategoryData['count']
		
		local data = _DataService:GetTable("AchievementCategory"):FindRow("CategoryID",self.CategoryID)
		
		-------------------------------------------------------------------
		-- 업적 카테고리 이름 
		local categoryTable = _DataService:GetTable("AchievementCategory")
		self.Entity:GetChildByName("CategoryName").TextComponent.Text = categoryTable:FindRow("CategoryID", string.format("%d", achievementCategoryID)):GetItem("Name")
		
		
		-------------------------------------------------------------------
		-- 업적 카테고리 보상 
		
		local rewardId = data:GetItem("RewardID")
		local rewardCount = data:GetItem("RewardCount")
		self.CategoryRewardID = rewardId
		
		self.Reward:GetChildByName("UISprite").SpriteGUIRendererComponent.ImageRUID = _UI_AchievementService:ReturnAchieveRewardRUID(rewardId)
		self.Reward:GetChildByName("UIText").TextComponent.Text = rewardCount
		
		-- 업적 카테고리 보상 버튼 
		
		for _,btn in pairs(self.BtnGroup.Children) do 
			if btn.Name == self.CategoryState then 
				btn.Enable = true 
			else 
				btn.Enable = false 
			end
		end 
		-------------------------------------------------------------------
		--업적 카테고리 진행률 
		
		local maxCount = _AchievementService.CategoryTotalNum[self.CategoryID]
		
		--log("카테고리아이디: ",self.CategoryID, " / 현재 달성 수: ", completeCount, " / 맥스: ", maxCount)
		
		--진행도 슬라이더바 값 세팅
			----------------------------------------------
			-- 0으로 초기화 해줘야 문제 발생 x
			self.ProgressSlider.SliderComponent.MaxValue = 0
			self.ProgressSlider.SliderComponent.Value = 0
			
		self.ProgressSlider.SliderComponent.MaxValue = tonumber(maxCount)
		self.ProgressSlider.SliderComponent.Value = tonumber(completeCount)
		
		--진행도 텍스트 값 세팅 
		self.ProgressText.TextComponent.Text = completeCount.."/"..maxCount
	end

	@ExecSpace("ClientOnly")
	method void UpdateCategoryInfoData(string categoryID)
		-------------------------------------------------------------------
		-- func: 업적 카테고리 정보 진행률 UI를 변경하는 함수 
		-------------------------------------------------------------------
		
		-- 켜져있는 카테고리가 아닌 경우에 요청이 들어왔다면(ex.다른 카테고리 업적 완료) UI를 갱신하지 않는다 
		if self.CategoryID ~= categoryID then 
			return
		end
		
		-- parameters
		local categoryData = _UserService.LocalPlayer.AchievementManager.PlayerAchieveCategoryData[self.CategoryID]
		local changeState = categoryData['state']
		local completeNum = categoryData['count']
		local completeDate = categoryData['date']
		-------------------------------------------------------------------
		--업적 카테고리 진행률 
		
		local maxCount = _AchievementService.CategoryTotalNum[categoryID]
		
			----------------------------------------------
			-- 0으로 초기화 해줘야 문제 발생 x
			self.ProgressSlider.SliderComponent.MaxValue = 0
			self.ProgressSlider.SliderComponent.Value = 0
		
		self.ProgressSlider.SliderComponent.MaxValue = tonumber(maxCount)
		self.ProgressSlider.SliderComponent.Value = tonumber(completeNum)
		self.ProgressText.TextComponent.Text = completeNum.."/"..maxCount
		
		
		local categoryList = _UI_AchievementService.AchievementUIComponent.CategoryList
		categoryList:GetChildByName(categoryID).UI_AchievementCategory:RefreshCompleteNum(completeNum)
		
		
		--------------------------------------------------------------
		--상태가 바뀌지 않았다면 갱신하지 않는다. 
		
		if self.CategoryState == changeState then 
			return
		end
		
		self.CategoryState = changeState
		
		if self.CategoryState == _AchievementStateEnum.Complete then 
			self.BtnGroup:GetChildByName("Complete").TextComponent.Text = completeDate.."\n".._LocalizationService:GetText("Complete")
		end
		
		--------------------------------------------------------------
		-- 다른 버튼 UI disable 
		for _,btn in pairs(self.BtnGroup.Children) do 
		
			if btn.Name == self.CategoryState then 
				btn.Enable = true 
			else 
				btn.Enable = false
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnClick_CategoryBtn(string uiName)
		-------------------------------------------------------------------------------
		-- func: 업적 카테고리 정보 UI 클릭시 각 버튼 상태에 따라 필요한 처리를 합니다. 
		-------------------------------------------------------------------------------
		
		if uiName == _AchievementStateEnum.InProgress then
			_UIToast:ShowMessageByLocalizingKey("AchievementInProgressDesc")
			
		elseif uiName == _AchievementStateEnum.RewardEarned then
			_UI_AchievementService:RequestEarnCategoryReward(self.CategoryID,_UserService.LocalPlayer)	
			
		elseif uiName == _AchievementStateEnum.Complete then
			_UIToast:ShowMessageByLocalizingKey("AchievementCompleteDesc")
		end 
	end

	@ExecSpace("ClientOnly")
	method void OnClickBtn_RewardItem()
		----------------------------------------------------------------------------------
		--[func] 업적 info UI의 보상 아이템 버튼 클릭 시, 해당 아이템의 툴팁 요청 함수
		----------------------------------------------------------------------------------
		
		_UI_AchievementService:ToolTipDataSetting(self.CategoryRewardID,self.Reward.Path)
	end

end