@Logic
script UI_AchievementPopup extends Logic

	property Entity UI_AchievePopup = "bc7c1049-1e9e-4b0f-9e10-098bb706b14b"

	property TextComponent AchieveName = "5eb0840e-0c27-42bd-b7b1-c2f50b99cc2b"

	property TextComponent AchieveCondition = "7671749a-96da-493c-b45f-e7c05fc034ed"

	property Entity ScoreGroup = "8e51d94c-f554-4087-8230-2245bb2dcb59"

	property Entity UI_Title = "113d6ddd-a364-4e02-a2d6-5cbe48ad0318"

	property table PopUpQueue = {}

	property boolean NowPopUp = false

	property boolean isActivated = true

	@ExecSpace("Client")
	method void InsertPopUpQueue(string achievementID, integer step, integer type)
		-------------------------------------------------------------------
		-- func: 완료한 업적을 테이블에 담아둡니다. 
		-------------------------------------------------------------------
		table.insert(self.PopUpQueue,#self.PopUpQueue+1,achievementID.."_"..step.."_"..string.format("%d", type))
		
		if not self.NowPopUp then 
			self:ShowMessage(achievementID,step, type)
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowMessage(string achievementID, integer step, integer type)
		-------------------------------------------------------------------
		-- func: 완료한 업적의 알림 UI내용을 세팅하고, 화면에 출력하는 함수
		-------------------------------------------------------------------
		self.UI_AchievePopup.Enable = false 		
		-- 알림 UI 상태 
		self.NowPopUp = true
		
		if type == 1 then
			-- param
			local data = _AchievementService:GetAchievementInfo(achievementID)
			local achievementScore = data.Score[step]
			local conditionKey = _LocalizationService:GetText(data.ConditionType[1].."_Name")
			local achieveName = _LocalizationService:GetTextFormat(data.NameKey,conditionKey)
			
			-------------------------------------------------------------------
			-- 업적 이름 
			self.AchieveName.Text = _UI_AchievementService:ReturnAchieveName(achievementID,step)
			
			-- 업적 조건 
			self.AchieveCondition.Text = _UI_AchievementService:ReturnAchieveCondition(achievementID,step)
			-------------------------------------------------------------------
			-- 업적 난이도 별 개수 
			for i,entity in pairs(self.ScoreGroup.Children) do 
				if i <=achievementScore then 
					entity.SpriteGUIRendererComponent.Color = Color.white
				else
					entity.SpriteGUIRendererComponent.Color = Color.gray		
				end
			end
			-------------------------------------------------------------------
			-- 배경
			self.UI_AchievePopup:GetChildByName("Background").SpriteGUIRendererComponent.Color = Color.FromHexCode("#ffff73")
			self.UI_Title.TextComponent.Text = "AchiPopup_Title1"
		elseif type == 2 then
			self.UI_AchievePopup:GetChildByName("Background").SpriteGUIRendererComponent.Color = Color.FromHexCode("#73e0ff")
			self.AchieveName.Text = _DailyMissionLogic.MissionDesc[achievementID]
			self.AchieveCondition.Text = _LocalizationService:GetText("DailyMissionPopupMessage")
			self.UI_Title.TextComponent.Text = "AchiPopup_Title2"
			
			local grade = tonumber(_UtilLogic:Split(achievementID, "_")[2])
			for i, entity in pairs(self.ScoreGroup.Children) do
				if i <= grade then
					entity.SpriteGUIRendererComponent.Color = Color.white
				else
					entity.SpriteGUIRendererComponent.Color = Color.gray
				end
			end
		end
		-------------------------------------------------------------------
		-- 게임 설정에서 팝업 옵션이 켜져있는지 확인하고, 켜져 있다면 재생합니다.
		if self.isActivated == false then
			self.UI_AchievePopup.Enable = false
		else
			self.UI_AchievePopup.Enable = true
			-- up
			local posY = 135
			local t1 = 0
			local move1 = function()
				t1 += 1
				posY = _TweenLogic:Ease(135, -35, 50, EaseType.BackEaseOut, t1)
				self.UI_AchievePopup.UITransformComponent.anchoredPosition.y = posY
			end
			for i=1, 50 do
				_TimerService:SetTimerOnce(move1, 0.01*i)
			end
			
			-- down
			local t2 = 0
			local move2 = function()
				t2 += 1
				posY = _TweenLogic:Ease(-35, 135, 50, EaseType.BackEaseIn, t2)
				self.UI_AchievePopup.UITransformComponent.anchoredPosition.y = posY
			end
			for i=1, 50 do
				_TimerService:SetTimerOnce(move2, 2.5 + 0.01*i)
			end
			
		end
		-------------------------------------------------------------------
		-- 출력한 업적알림은 테이블에서 삭제 
		table.remove(self.PopUpQueue,1)
		-------------------------------------------------------------------
		-- 테이블에 남은 업적이 있는지 확인 
		_TimerService:SetTimerOnce(function() 
			-- 남은 완료한 업적이 있는가? 
			if #table.keys(self.PopUpQueue) > 0 then 
				local achieveInfo = _UtilLogic:Split(self.PopUpQueue[1], "_")
				if #achieveInfo == 3 then
					self:ShowMessage(achieveInfo[1],tonumber(achieveInfo[2]),tonumber(achieveInfo[3]))
				else
					self:ShowMessage(achieveInfo[1].."_"..achieveInfo[2],tonumber(achieveInfo[3]),tonumber(achieveInfo[4]))
				end
				
			else
				self.NowPopUp = false
				self.UI_AchievePopup.Enable = false
			end
		
		end, 3.5)
	end

end