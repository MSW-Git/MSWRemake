@Logic
script UI_AchievementService extends Logic

	property Entity AchievementGroup = "2e06cc95-cfff-4a17-bc1a-45f1b31154a8"

	property Entity TotalCompleteSlider = "6ccc7c09-a9fb-4dd0-8042-4d3faf014577"

	property Entity TotalCompleteText = "609a035d-f822-4ee1-9ef5-4fc757dfa669"

	property Entity TotalScoreText = "adeb2534-c08d-43ed-82a6-a3b5fa8d654d"

	property Entity CategoryInfo = "4b67ac54-c607-4caa-90f7-4584973afef7"

	property Entity AchievementUI = "dbe34da2-193b-493e-8d0a-ae33207ccf6b"

	property UI_AchievementList AchievementUIComponent = "2e06cc95-cfff-4a17-bc1a-45f1b31154a8"

	property Entity BtnGroup = "a62cdc0a-e1d7-4a5b-90ca-37fde38fa59a"

	property Entity ToolTip = "2844d369-e27f-45ff-8a97-35e9ba7cf5c7"

	property string CategoryRewardId = ""

	property Entity AchievementStepList = "69d1ca32-145a-4cdf-ae7a-8a54b62ad27d"

	property ButtonComponent GetAllrewardButton = "ded50c5e-e786-4c13-97b5-ef78b86f56aa"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 툴팁 UI 끄기 
		self.ToolTip.Enable = false
		
		--업적 카테고리 초기화 
		local categoryInfo = _DataService:GetTable("AchievementCategory"):GetRow(1)
		self.AchievementUIComponent.AchievementCategory = categoryInfo:GetItem("CategoryID")
	end

	@ExecSpace("Server")
	method void RequestSetAchieveData(string categoryID, Entity player)
		--------------------------------------------------------------------------
		-- func: 업적 카테고리를 기준으로 업적 목록 UI의 내용 출력을 요청하는 함수
		--------------------------------------------------------------------------
		local userId = player.PlayerComponent.UserId
		
		player.AchievementManager:OnDataLoadComplete()
		
		self:RequestUpdateTotalAchieveInfo() -- 전체 업적 정보 변경 요청 
		self:RequestCategoryListDataSetting(userId) -- 업적 카테고리 목록 변경 요청 
		self:RequestChageCategory(categoryID,userId) -- 업적 카테고리 변경 요청 
	end

	@ExecSpace("Server")
	method void RequestEarnAllReward(string categoryID, Entity player)
		---------------------------------------------------------
		-- func: client -> server 업적 보상 일괄 획득 요청 
		
		---------------------------------------------------------
		
		--player.AchievementManager:EarnReward_All_inCategory(categoryID)
		player.AchievementManager:EarnReward_AllAchieve()
	end

	@ExecSpace("Server")
	method void RequestEarnAchievementListReward(string achievementID, integer befStep, Entity player)
		--------------------------------------------------------------------------
		-- func: client -> server 업적 보상 획득 요청 
		--------------------------------------------------------------------------
		
		player.AchievementManager:EarnReward_Achieve(achievementID,befStep)
	end

	@ExecSpace("Server")
	method void RequestEarnCategoryReward(string categoryId, Entity player)
		--------------------------------------------------------------------------
		-- func: client -> server 업적 카테고리 보상 획득 요청 
		--------------------------------------------------------------------------
		
		player.AchievementManager:EarnReward_AchieveCategory(categoryId)
	end

	@ExecSpace("Client")
	method void RequestChageCategory(string achievementCategoryID)
		-------------------------------------------------------------------
		--func: 업적 카테고리를 변경하는 함수 
		-------------------------------------------------------------------
			
		--업적 카테고리 버튼 상태 변경 
		for k, cell in pairs(self.AchievementUIComponent.CategoryList.Children) do 
		
		
			if cell.UI_AchievementCategory.CategoryID ~= achievementCategoryID then 
				cell.UI_AchievementCategory:ChageBtnSprite("off")
			else
				cell.UI_AchievementCategory:ChageBtnSprite("on")		
			end 	
			
		end
		-------------------------------------------------------------------
		--켜져있던 업적 목록 셀들 모두 꺼주기 
		
		for i, cell in pairs(self.AchievementUIComponent.AchievementList.Children)  do
		--	cell.Enable = false
		end
		
		-------------------------------------------------------------------
		--ui 데이터 출력 변경
		self.AchievementUIComponent.AchievementCategory = achievementCategoryID
		
		local categoryCount = _AchievementService.CategoryGroupNum[achievementCategoryID] 
		
		self.AchievementUIComponent.AchievementList.CustomScrollLayoutComponent:SetChildrenCount(tonumber(categoryCount)) -- 커스텀 스크롤 개수 초기화 
		
		--self.AchievementUIComponent.AchievementList.CustomScrollLayoutComponent.IsTouchEntered = true
		self.AchievementUIComponent.AchievementList.CustomScrollLayoutComponent:SetCurrentScroll(1)
		self.AchievementUIComponent:RefreshAchieveInfo(1,3)
		
		-------------------------------------------------------------------
		-- 업적 카테고리 정보 UI 데이터 세팅 
		self.CategoryInfo.UI_AchievementCategoryInfo:RenderAchievementCategoryInfo(achievementCategoryID)
	end

	@ExecSpace("Client")
	method void RequestUpdateCategory(string achievementCategoryID)
		--------------------------------------------------------------------------
		-- func: 업적 카테고리 UI 업데이트
		--------------------------------------------------------------------------
		
		self.CategoryInfo.UI_AchievementCategoryInfo:UpdateCategoryInfoData(achievementCategoryID)
	end

	@ExecSpace("Client")
	method void RequestRefreshAchievementData()
		--------------------------------------------------------------------------
		
		-- func: 개별 업적 정보 UI 갱신
		-------------------------------------------------------------------------
		self.AchievementUIComponent:UpdateAchievementData()
	end

	@ExecSpace("Client")
	method void RequestUpdateTotalAchieveInfo()
		-------------------------------------------------------------------------
		-- func: 전체 업적 완료 개수와 점수를 계산하여 UI에 그리도록 요청하는 함수 
		-------------------------------------------------------------------------
		
		local achieveCompleteNum = 0 -- 전체 업적 완료 개수 
		local achieveScore = 0 --전체 업적 점수 
		
		-- 업적 완료 개수 갱신 
		for achieveID,achieveData in pairs (_UserService.LocalPlayer.AchievementManager.PlayerAchievementData) do 
			
			for i=1 , #achieveData['state'] do 
				if achieveData['state'][i] == _AchievementStateEnum.Complete then 
					
					-- 총 업적 완료 개수 
					achieveCompleteNum +=1
					
					-- 총 업적 점수 
					local achieveInfo = _AchievementService:GetAchievementInfo(achieveID)
					achieveScore += achieveInfo.Score[i]
					
				end
			end
			
		end
		
		-------------------------------------------------------------------------
		-- 업적 전체 진행도 출력 
		local percent = ( math.floor( (achieveCompleteNum * 10000 + 0.5 ) / _AchievementService.MaxTotalCompleteNum ) ) / 100 --소수 둘째 자리까지 반올림하여 표시 
		self.TotalCompleteText.TextComponent.Text = percent.."%"
		self.TotalCompleteSlider.SliderComponent.Value = percent
		
		-------------------------------------------------------------------------
		--업적 점수 UI 갱신 
		
		self.TotalScoreText.TextComponent.Text = tostring(achieveScore)
	end

	@ExecSpace("Client")
	method void RequestCategoryListDataSetting()
		-------------------------------------------------------------------------
		-- func: 카테고리 목록 데이터 세팅 함수 
		-------------------------------------------------------------------------
		
		for _, row in pairs (_DataService:GetTable("AchievementCategory"):GetAllRow()) do 
			local id = row:GetItem("CategoryID")
			self.AchievementUIComponent.CategoryList:GetChildByName(id).UI_AchievementCategory:Init(id)
			self.AchievementUIComponent.CategoryList.ScrollLayoutGroupComponent:ResetScrollPosition(UITransformAxis.Vertical)
		end
	end

	@ExecSpace("Client")
	method void EnableRedDot(string categoryID)
		---------------------------------------------------------------
		-- Func: 레드닷 조건 체크하여 활성화 또는 비활성화하는 함수 
		---------------------------------------------------------------
		
		local achieveManager = _UserService.LocalPlayer.AchievementManager
		
		local categoryRedDot = false
		for achievementID,playerData in pairs(achieveManager.PlayerAchievementData) do 
		
			
			local achieveData = _AchievementService:GetAchievementInfo(achievementID)
			if not isvalid(achieveData) then 
				log_error("업적 레드닷 에러:",achievementID)
			end
			local maxStep = achieveData.MaxStep
		
			local category = achieveData.CategoryID
			
			--카테고리가 같은 업적이 아닌 경우 건너뛰기 
			if category ~= categoryID then 
				continue
			end
		
			-- 업적의 단계 중 하나라도 획득하지 않은 보상이 있는지 검색 
			local completeNum = 0
			for i= 1 ,maxStep do 	
			
				if playerData['state'][i] == _AchievementStateEnum.RewardEarned then 
					self:EnableRedDotByID(categoryID,true)
					self:EnableAllRewardButton(true)
					return
				end		
				
			end
		end
		
		---------------------------------------------------------------
		-- 업적 카테고리 보상도 획득가능한 상태인가?
		if achieveManager.PlayerAchieveCategoryData[categoryID]['state'] == _AchievementStateEnum.RewardEarned then 
			categoryRedDot = true 
		end
		
		---------------------------------------------------------------
		-- 업적 카테고리 레드닷 onoff
		
		self:EnableRedDotByID(categoryID,categoryRedDot)
		
		self:EnableAchieveBtnRedDot(categoryRedDot)
	end

	@ExecSpace("Client")
	method void EnableRedDotByID(string categoryID, boolean enable)
		---------------------------------------------------------------
		-- Func: 카테고리 id로 UI를 찾아서 레드닷 활성화 또는 비활성화 
		---------------------------------------------------------------
		
		local categoryUI = 	self.AchievementUIComponent.CategoryList:GetChildByName(categoryID)
		categoryUI:GetChildByName("RedDot").Enable = enable
	end

	@ExecSpace("Client")
	method void EnableAchieveBtnRedDot(boolean categoryRedDot)
		---------------------------------------------------------------
		-- Func: 업적 버튼 레드닷 onoff 
		---------------------------------------------------------------
		
		local achieveButton = _EntityService:GetEntityByPath("/ui/Lobby_HUD/List_LeftMenu/Button_Achievement"):GetChildByName("RedDot")
		if categoryRedDot then 
			achieveButton.Enable = true
		else
		
			local categoryList = self.AchievementUIComponent.CategoryList
			local buttonRedDot = false
			for _, categoryUI in pairs (categoryList.Children) do 
				
				if categoryUI:GetChildByName("RedDot").Enable then 
					buttonRedDot = true 
					break
				end
			end
			
			achieveButton.Enable = buttonRedDot
			
		end
	end

	@ExecSpace("ClientOnly")
	method string ReturnAchieveCondition(string achieveID, integer step)
		local achievementData = _AchievementService:GetAchievementInfo(achieveID)
		local maxConditionCount = achievementData.Count[step]
		local conditionType = achievementData.ConditionType[1]
		
		
		
		local desc = "" 
		local conditionText = ""
		if conditionType == "-1" then -- 조건 데이터가 없는 경우
			desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,maxConditionCount) 
			
		
		elseif achievementData.CategoryID =="2" or achievementData.CategoryID =="3" then -- 시너지 
			conditionText = _LocalizationService:GetText(conditionType.."_Name")	
			local runeCardKey = achievementData.ConditionType[2] 
			if isvalid(runeCardKey) then 
				local runeCard = _LocalizationService:GetText("RuneCard_"..runeCardKey.."_Name")
				desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,conditionText,maxConditionCount,runeCard) 
			else
				desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,conditionText,maxConditionCount) 
			end
		elseif achievementData.CategoryID =="4" then -- 룬카드
		
			conditionText = _LocalizationService:GetText("RuneCard_"..conditionType.."_Name")
			desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,conditionText,maxConditionCount) 
			
		elseif achievementData.CategoryID =="5" then -- 캐릭터 도전과제
			desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,maxConditionCount)
			
		elseif achievementData.CategoryID == "6" then -- 랭크모드
			conditionText = _ModeDataLogic:GetRankTierString(maxConditionCount)
		
			desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,conditionText)
			
		elseif achievementData.CategoryID == "7" then -- 전투의 달인
			if 	not _UtilLogic:IsNilorEmptyString(string.match(conditionType,"BattleStatUI")) or
				 not _UtilLogic:IsNilorEmptyString(string.match(conditionType,"Status")) then 
				
				conditionText = _LocalizationService:GetText(conditionType)
			else
				 conditionText = _LocalizationService:GetText(conditionType.."_Name")
					
			end		
			desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,conditionText,maxConditionCount) 
			
		elseif achievementData.CategoryID == "8" then -- 캐릭터 도전과제 
			conditionText = _LocalizationService:GetText(conditionType.."_Name")
			
			-- 도전과제 내용에 시너지가 들어가는 경우가 있어 추가
			local characterSynergyType = achievementData.ConditionType[2]
			
			if characterSynergyType ~= nil then
				local characterSynergy = _LocalizationService:GetText(characterSynergyType.."_Name")
				desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,characterSynergy,maxConditionCount) 
			else
				desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,maxConditionCount) 
			end
			
		
			desc = string.format("[%s] %s",conditionText,desc)
		
		else
			conditionText = _LocalizationService:GetText(conditionType)	
			desc =  _LocalizationService:GetTextFormat(achievementData.DescKey,conditionText,maxConditionCount) 
		end
		
		
		return desc
	end

	@ExecSpace("ClientOnly")
	method string ReturnAchieveCharacterID(string achieveID, integer step)
		local achievementData = _AchievementService:GetAchievementInfo(achieveID)
		local maxConditionCount = achievementData.Count[step]
		local conditionType = achievementData.ConditionType[1]
		
		if achievementData.CategoryID == "8" then
			return conditionType
		else
			log_warning("캐릭터 도전과제가 아닙니다.")
			return "-"
		end
	end

	@ExecSpace("ClientOnly")
	method string ReturnAchieveName(string achieveID, integer step)
		local achievementData = _AchievementService:GetAchievementInfo(achieveID)
		local maxCount = achievementData.Count[step]
		
		local achievementName = ""
		local conditionType = achievementData.ConditionType[1]
		--조건 데이터가 없는경우 
		if conditionType == "-1" then 
			achievementName =  _LocalizationService:GetText(achievementData.NameKey) 
		else
			local context = conditionType
			if achievementData.CategoryID == "2" or achievementData.CategoryID == "3" or achievementData.CategoryID == "8" then -- 2,3 시너지 8 캐릭터 도감
				context = _LocalizationService:GetTextFormat(conditionType.."_Name")
				
			elseif achievementData.CategoryID == "6" then -- 랭크모드
				context = _ModeDataLogic:GetRankTierString(maxCount)
			end
			
			achievementName =  _LocalizationService:GetTextFormat(achievementData.NameKey,context) 
		end
		
		
		if achievementData.MaxStep ~= 1 then 
			achievementName = achievementName.." "..step
		end
		
		return achievementName
	end

	@ExecSpace("ClientOnly")
	method string ReturnAchieveRewardRUID(string rewardID)
		
		local ruid 
		local keyHead = string.sub(rewardID,1,2)
		local keyHeadCharacter = string.sub(rewardID,1,1) 
		local characterInfo = _DataService:GetTable("CharacterInfo")
		
		if keyHead == "Sy" then --시럽
			ruid = "8b5c6b67662b449e9a28a830a228ec69"
		elseif	keyHead == "CO" then --코치
			local coachData = _CoachService:GetCoachInfo(rewardID)
			ruid =  coachData.ProfileRUID
		elseif	keyHead == "MC" then --마스터 코치
			rewardID = "CO"..string.sub(rewardID,3,string.len(rewardID))
			local coachData = _CoachService:GetCoachInfo(rewardID)
			ruid =  coachData.ProfileRUID
		elseif keyHead == "KW" then --키워드
			ruid = "da7b0a2ca68a4003bbba315f8ed227b3"
		elseif keyHead == "NT" then --네임택
			ruid = "7a88207c3ef44acda74da59c5c0981ed"
		elseif keyHeadCharacter == "C" then --캐릭터 변신 보상 
			ruid = characterInfo:FindRow("CharID",rewardID):GetItem("IdleRUID")
		else
			ruid = "f16ac8c0a4e94c5a92cf9bf018bce307"
		end
		
		return ruid
	end

	@ExecSpace("Client")
	method void ToolTipDataSetting(string rewardId, string entityPath)
		---------------------------------------------------------------
		-- Func: tooltip 내용을 출력하는 함수입니다. 
		---------------------------------------------------------------
		
		-- 보상이 없는 버튼을 클릭했다면 툴팁을 출력하지 않습니다. 
		if _UtilLogic:IsNilorEmptyString(rewardId) then 
			return 
		end
		
		-- Parameters
		
		local keyHead = string.sub(rewardId,1,2)
		local charKeyHead = string.sub(rewardId,1,1)
		local rewardName 
		local rewardDesc
		---------------------------------------------------------------
		--툴팁 이름 및 설명 
		
		if keyHead == "CO" then --코치
		
			local coachInfo = _CoachService:GetCoachInfo(rewardId)
			rewardName = coachInfo.Name 
			
			local nameKey = coachInfo.Name
			local coachEffect = coachInfo.Desc
				
			local achieveCoachDesc = _LocalizationService:GetText("Achievement_Coach_Desc")
		
			rewardDesc = string.format("%s%s",achieveCoachDesc,coachEffect)
		--[[elseif keyHead == "MC" then -- 마스터 코치 
			rewardId = "CO"..string.sub(rewardId,3,string.len(rewardId))
			local coachInfo = _CoachService:GetCoachInfo(rewardId)
			local masterKey = _LocalizationService:GetText("Master")
			rewardName = masterKey.." ".._LocalizationService:GetText("Coach_"..rewardId.."_Name") 
			
			
			local masterTooltip =  _LocalizationService:GetText("CoachShop_MasterCoachTooltip")
			local coachEffect = coachInfo.Desc
				
			local achieveCoachDesc = _LocalizationService:GetText("Achievement_Coach_Desc")
			rewardDesc = string.format("%s%s",achieveCoachDesc,coachEffect)]]--
		
				
		elseif charKeyHead == "C" then --변신
			local characterName = _LocalizationService:GetText(rewardId.."_Name")
			rewardName = characterName.." ".._LocalizationService:GetText("CharacterTransform")
			rewardDesc = _LocalizationService:GetTextFormat("Transform_Character_Desc",characterName)
			
		elseif keyHead =="NT" then --네임태그
		
			--로컬key 
			
			local nameKey = _DataService:GetTable("Title_NameTagDataset"):FindRow("NameTagID",rewardId):GetItem("Name")
			rewardName = _LocalizationService:GetText(nameKey)
			rewardDesc = _LocalizationService:GetText("NT_ToolTipDesc")
			
		elseif keyHead =="KW" then --키워드 
				
			local keywordKeyHead = string.sub(rewardId,1,3)
			
			--로컬key
			local nameKey = "툴팁 이름이 없습니다."
			
			if keywordKeyHead == "KWF" then -- 칭호 Front
		
				nameKey = _DataService:GetTable("Title_KeyWordFrontDataset"):FindRow("KeyWordID",rewardId):GetItem("Name")
		
			elseif keywordKeyHead == "KWB" then -- 칭호 Back
				
				nameKey = _DataService:GetTable("Title_KeyWordBackDataset"):FindRow("KeyWordID",rewardId):GetItem("Name")
		
			end
		
			rewardName = _LocalizationService:GetText(nameKey)
			rewardDesc = _LocalizationService:GetText("KW_ToolTipDesc")	
			
		elseif keyHead == "Sy" then -- 시럽
			rewardName = _LocalizationService:GetText(rewardId)
			rewardDesc = _LocalizationService:GetText(rewardId.."_Tooltip")
		else
			
			rewardName = "툴팁 이름이 없습니다."
			rewardDesc = "툴팁 설명이 없습니다"
		
		end
		
		
		-- 툴팁 팝업 위치 설정 
		local touchPos = _EntityService:GetEntityByPath(entityPath).UITransformComponent.WorldPosition
		
		self.ToolTip.UITransformComponent.WorldPosition = touchPos + Vector3(150,15,0)
		
		-- 툴팁 내용 설정 
		self.ToolTip:GetChildByName("UIText").TextComponent.Text = rewardName.."\n\n"..rewardDesc
		
		-- 툴팁 엔티티 켜기
		self.ToolTip.Enable = true 
		
		
		
		-- 2초 뒤 툴팁 팝업 자동 꺼짐 
		--_TimerService:SetTimerOnce(function() self.ToolTip.Enable = false end,2 )
	end

	@ExecSpace("Client")
	method void EnableRewardPopup(SyncTable<string, integer> rewards)
		-- 모두받기 버튼 비활성화----
		self:EnableAllRewardButton(false)
		-----------------------------
		
		local rewardUI = _EntityService:GetEntityByPath("/ui/Reward_Popup/Panel")
		
		local len = 0
		for k, v in pairs(rewards) do
			len += 1
		end
		
		if len > 0 then
			rewardUI.UI_RewardPopup:Open_N_UpdateRewardList(rewards)
		end
	end

	@ExecSpace("Client")
	method void EnableAllRewardButton(boolean enable)
		-----
		--해당 버튼은 기본으로 비활성화 되어 있어야 합니다
		-----
		self.GetAllrewardButton.Enable = enable
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6be82763-c371-4fe2-b06e-6bd0cd71f69d")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self:ToolTipDataSetting(self.CategoryRewardId,Entity.Path)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f7e10477-1a32-42eb-aa22-0c7f0e44c6ee")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:RequestSetAchieveData("1",_UserService.LocalPlayer)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "ded50c5e-e786-4c13-97b5-ef78b86f56aa")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		
		-- 선택한 카테고리 아이디 
		local categoryID = self.CategoryInfo.UI_AchievementCategoryInfo.CategoryID
		-- 보상 일괄 획득
		self:RequestEarnAllReward(categoryID,_UserService.LocalPlayer)
	end

end