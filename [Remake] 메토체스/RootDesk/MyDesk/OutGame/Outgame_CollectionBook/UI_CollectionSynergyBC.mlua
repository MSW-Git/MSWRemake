@Component
script UI_CollectionSynergyBC extends Component

	property integer season = 1

	property TextComponent t_name = nil

	property Entity badgeGroup = nil

	property string synergyID = ""

	property integer nowBadgeCount = 0

	property integer maxBadgeCount = 0

	@ExecSpace("ClientOnly")
	method void Initialize(string id, integer level)
		-- 시너지 컬렉션 카드를 초기화하고 모든 단계 배지 설정
		self.synergyID = id
		self.t_name = self.Entity:GetChildByName("t_name").TextComponent
		self.badgeGroup = self.Entity:GetChildByName("badgeGroup")
		
		
		-- 뱃지 갯수 셋팅 (수정)
		--[[---@type UserDataRow
		local row = _DictionaryDataManager:GetSynergy_Row(id)]]
		local data = _DictionaryDataManager.SynergyDataList[id]
		local count = 0
		for i=1 , 5 do
			if data.NeedCount_step[i] == "-" then 
				self.badgeGroup.Children[i].Enable = false
				continue 
			end
			count += 1
			self.badgeGroup.Children[i].Enable = true
			self.badgeGroup.Children[i].Children[1].Children[1].SpriteGUIRendererComponent.ImageRUID = data.IconRUID
			--self.badgeGroup.Children[i].Children[1].Children[1].SpriteGUIRendererComponent.ImageRUID = _DictionaryDataManager:GetSynergy_Row(id):GetItem("IconRUID")
		end
		
		self.maxBadgeCount = count
		
		-- 이름
		self.t_name.Text = _LocalizationService:GetText(id.."_Name")
		self:SetGrade(level)
	end

	@ExecSpace("ClientOnly")
	method void SetGrade(integer grade)
		------------------------------------------------------------------------
		-- 뱃지를 1개 이상 보유한 경우에만 배경 활성화
		------------------------------------------------------------------------
		if grade <= 0 then
			self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode("#152239")
			self.t_name.FontColor = Color.FromHexCode("#4f659b")
			
		-- 수집된 뱃지가 1개 이상  
		else
			self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode("#2F477A")
			self.t_name.FontColor = Color.FromHexCode("#BCC9DA")
		end
		------------------------------------------------------------------------
		-- 각 뱃지 이미지 변경
		------------------------------------------------------------------------
		for i = 1, 5 do
			-- 비활성화(해당x) 뱃지면 넘어감
			if self.badgeGroup.Children[i].Enable == false then 
				continue
			else
				-- 수집한 뱃지
				if i <= grade then
					--활성화 뱃지는 수집처리
					self.badgeGroup.Children[i]:GetChildByName("sp_enableBG").Enable = true
					self.badgeGroup.Children[i]:GetChildByName("t_Grade").TextComponent.FontColor = Color.FromHexCode("#BCC9DA")
				else
					self.badgeGroup.Children[i]:GetChildByName("sp_enableBG").Enable = false
					self.badgeGroup.Children[i]:GetChildByName("t_Grade").TextComponent.FontColor = Color.FromHexCode("#7d7d7d")
				end
			end
		end
	end

	@EventSender("LocalPlayer")
	handler HandleCollectionUpdateEvent(CollectionUpdateEvent event)
		-- 시너지 컬렉션 데이터 업데이트 시 해당 시너지의 등급 갱신
		--local season = event.season
		--if season ~= self.season then return end
		
		---@type table<string, integer>
		local SynergyUpdateList = event.SynergyUpdateList
		if SynergyUpdateList == nil then return end
		
		--log("이벤트! 시너지")
		
		for k, v in pairs(SynergyUpdateList) do
			if k == self.synergyID then
				self:SetGrade(v)
			end
		end
	end

end