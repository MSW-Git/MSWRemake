@Component
script UI_CollectionCharacterCard extends Component

	property string charID = ""

	property string season = "1.0"

	property TextComponent t_name = nil

	property SpriteGUIRendererComponent sp_RUID = nil

	property Entity starList = nil

	property integer m_collectLevel = -1

	@ExecSpace("ClientOnly")
	method void Initialize(string _charid, integer level)
		-- 엔티티 셋
		self.starList = self.Entity:GetChildByName("starList")
		self.t_name = self.Entity:GetChildByName("CardBG"):GetChildByName("sp_NameTag").Children[1].TextComponent
		self.sp_RUID = self.Entity:GetChildByName("CardBG"):GetChildByName("sp_charRUID").SpriteGUIRendererComponent
		
		self.charID = _charid
		
		local data = _DictionaryDataManager.CharDataList[_charid]
		local ruid = data.IdleRUID
		local resourceinfo  = _LoadResourcesInfo:GetUILocalPositionScale(ruid)
		self.sp_RUID.ImageRUID = ruid
		self.sp_RUID.LocalScale = resourceinfo["scale"]
		self.sp_RUID.LocalPosition = resourceinfo["pos"]
		self.sp_RUID.PlayRate = 0
		
		self.m_collectLevel = level
		
		self:Set_CollectLevel(level)
	end

	@ExecSpace("ClientOnly")
	method void Set_CollectLevel(integer collectLevel)
		-- 도감의 수집 레벨은 올라가기만 하고 내려갈 일은 없으므로
		-- 낮거나 같으면 종료
		--if collectLevel <= self.m_collectLevel then return end
		
		self:Set_Star(collectLevel)
		self:Set_NameTag(collectLevel)
		
		
		if collectLevel >= 4 then
			self:Set_PlatinumCard()
			return
		end
		
		self:Set_CardImage(collectLevel)
	end

	@ExecSpace("ClientOnly")
	method void Set_Star(integer collectLevel)
		-- 수집 레벨에 따라 별 표시 개수와 위치 설정
		for i=1, 3 do
			if i > collectLevel then
				self.starList.Children[i].Enable = false
				continue
			end
			
			self.starList.Children[i].Enable = true
			
			-- 0923 추가 -- 그리드 뷰 사용 시 엔티티 재활용이 되므로 머터리얼 초기화 필요
			self.starList.Children[i].SpriteGUIRendererComponent:ChangeMaterial("")
		end
		
		-- scrollLayout 사용하면 버그 --> 수동으로 위치 조정 (...)
		if collectLevel == 1 then
			self.starList.Children[1].UITransformComponent.anchoredPosition.x = 0
		elseif collectLevel == 2 then
			self.starList.Children[1].UITransformComponent.anchoredPosition.x = -13.5
			self.starList.Children[2].UITransformComponent.anchoredPosition.x = 13.5
		elseif collectLevel >= 3 then
			self.starList.Children[1].UITransformComponent.anchoredPosition.x = -27
			self.starList.Children[2].UITransformComponent.anchoredPosition.x = 0
			self.starList.Children[3].UITransformComponent.anchoredPosition.x = 27
		end
	end

	@ExecSpace("ClientOnly")
	method void Set_NameTag(integer collectLevel)
		-- 수집 여부에 따라 캐릭터 이름 또는 ??? 표시
		if collectLevel == 0 then
			self.t_name.Text = "???"
			--self.t_name.Entity.Parent.SpriteGUIRendererComponent.MaterialId = nil
			return
		end
		
		self.t_name.Text = _LocalizationService:GetText(self.charID.."_Name")
	end

	@ExecSpace("ClientOnly")
	method void Set_CardImage(integer collectLevel)
		-- 수집 레벨에 따라 카드 이미지 색상과 배경 매테리얼 설정
		if collectLevel == 0 then
			self.sp_RUID.Color = Color.black
			self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode("#253C5F")
			self.Entity.SpriteGUIRendererComponent.MaterialId = nil
		-- 임시로 넣은 머터리얼입니당
		else
			self.sp_RUID.Color = Color.white
			self.Entity.SpriteGUIRendererComponent.MaterialId = _UI_CollectionManager.Level_BG_Material[collectLevel]
		end
		
	end

	@ExecSpace("ClientOnly")
	method void Set_PlatinumCard()
		-- 카드 배경, 아웃라인 효과
		self.sp_RUID.Color = Color.white
		self.Entity.SpriteGUIRendererComponent.MaterialId = _UI_CollectionManager.Level_BG_Material[4]
		
		-- 네임태그 효과
		
		-- 별 효과
		for i=1, 3 do
			self.starList.Children[i].SpriteGUIRendererComponent.MaterialId = "material://a662a412-9e11-4249-b8ef-02515c716e8d"
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐릭터 카드 클릭 시 캐릭터 상세 정보 UI 표시
		_UI_CollectionManager.CharacterCollectionInfo:SetInfo(self.m_collectLevel, self.charID)
	end

	@EventSender("LocalPlayer")
	handler HandleCollectionUpdateEvent(CollectionUpdateEvent event)
		-- 컴렉션 데이터 업데이트 시 카드 재초기화
		--local season = event.season
		---@type table<string, integer>
		local CharacterUpdateList = event.CharacterUpdateList
		
		--if season ~= self.season then return end
		if CharacterUpdateList == nil then return end
		
		
		self:Initialize(self.charID, CharacterUpdateList[self.charID])
		--_UI_CollectionManager:CreateCharColList_NewGrid(season)
		
	end

end