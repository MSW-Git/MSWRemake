@Component
script CoachMoveComponent extends Component

	property number followDistance = 0.5

	property number followSpeed = 1.2

	property Vector3 Offset = Vector3(0.35,0.4,0)

	property string state = "create"

	property string coachID = "create"

	property string IdleRUID = ""

	property string LoveRUID = ""

	property string SadRUID = ""

	property string MoveRUID = ""

	property string ownerUserID = ""

	property number Velocity = 0

	property number DirectionTimer = 0

	property boolean CoolTime = false

	property number WaitingTimer = 0

	@ExecSpace("Server")
	method void Create(string id, integer coachType, Vector3 ownerPos, string ownerID, boolean masterEffectOn)
		-------------------------------------------------------------------------
		-- 코치 엔티티 클라에 생성하는 함수
		-------------------------------------------------------------------------
		
		local befCoachId = self.coachID
		
		self:Init(id,coachType,ownerPos,ownerID,masterEffectOn)
		
		local directionTime 
		-- 이미 생성되어있던 코치의 정보와 동일하다면 연출을 재생하지 않음 
		if ( befCoachId ~= id) then 	
			-- 코치 생성 연출 
		--	self:Direction(self.state)
			directionTime =_CoachService.DirectionTime_Short 
		else 
			directionTime =0
		end
		
		-- 1.2초 뒤 코치 움직임 
		_TimerService:SetTimerOnce(
			function() 
				self.state = "idle"
				self.Entity.SpriteRendererComponent.SpriteRUID = self.IdleRUID
				self:CoachSleepTimer(self.ownerUserID)
			end
			,directionTime
		)
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-----------------------------------------------------------------------------------
		--플레이어 따라다니기 
		-----------------------------------------------------------------------------------
		
		--이동 상태가 아니라면 위치 갱신하지 않음 
		if self.state == "create" then 
			return
		end
		
		-----------------------------------------------------------------------------------
		--param
		
		local player = _UserService:GetUserEntityByUserId(self.ownerUserID)
		if isvalid(player) == false then
			self.Entity.Enable = false
			return
		end
		
		
		local kinematic = player.KinematicbodyComponent:GetGroundPosition()
		local playerTransfom = Vector3( kinematic.x,kinematic.y,0)
		local targetPos = playerTransfom + self.Offset
		local coachPos = self.Entity.TransformComponent.Position
		local distanceToPlayer = Vector3.Distance(targetPos,coachPos)
		local directionVector = Vector3.Normalize(targetPos - coachPos) --플레이어 쪽으로 펫이 이동하는 벡터 계산
		
		-----------------------------------------------------------------------------------
		--코치 이미지 좌우반전 
		if directionVector.x < 0 then 
			self.Entity.SpriteRendererComponent.FlipX = false 
		else
			self.Entity.SpriteRendererComponent.FlipX = true 
		end
		-----------------------------------------------------------------------------------
		
		--펫과 플레이어의 거리가 가까우면 움직이지 않는다. 
		
		
		if ( distanceToPlayer < self.followDistance) then
			self.Velocity = 0
			if self.state == "idle" then 
				return 
			end
			
			self.Entity.SpriteRendererComponent.SpriteRUID = self.IdleRUID
			self.state = "idle"
			self.CoolTime = false
			self:CoachSleepTimer()
			return
		
		end
		
		-----------------------------------------------------------------------------------
		--코치 애님 move로 갱신
		
		if self.state ~="move" then 
			
			self.state = "move"
			self.Entity.SpriteRendererComponent.SpriteRUID = self.MoveRUID
			self.CoolTime = false
			self:CoachSleepTimer()
			
		end
		
		-----------------------------------------------------------------------------------
		--log("3",self.coachID,self.ownerUserID)
		self.Velocity =  math.min(2,self.Velocity + 0.01)
		local speed = ( self.followSpeed + self.Velocity ) * delta 
		
		self.Entity.TransformComponent:Translate(directionVector.x * speed  ,directionVector.y * speed  )
	end

	@ExecSpace("Multicast")
	method void Direction(string type)
		local effect = self.Entity:GetChildByName("Effect")
		-- 코치 동행 시작 연출 
		if type == "create" then 
			self.Entity.SpriteRendererComponent.SpriteRUID = self.LoveRUID
		
			local offset = Vector3(0.4,1.1,0)
			_EffectService:PlayEffect("6155383ea01d4f38828f6b0edb82f92d",self.Entity,self.Entity.TransformComponent.WorldPosition+offset,0,Vector3.one)
			
			self.Entity.Enable = true 
			
		-- 코치 동행 해제 연출 
		elseif type == "destroy" then 
			
			self.Entity.SpriteRendererComponent.SpriteRUID = self.SadRUID
			local repeatTime = 100
			local repeatCount = 0
		
			local transparent = function()
				self.Entity.SpriteRendererComponent.Color.a -= 0.025		
				repeatCount +=1 
				
				if repeatCount == 70 then 
					self.Entity.KinematicbodyComponent.EnableShadow = false --그림자 사라지는 속도가 느려서 미리 끔
					effect:SetEnable(false)
				end
				
				if repeatCount > repeatTime then 
					
					self.Entity.SpriteRendererComponent.Color.a = 0 
					self.Entity.SpriteRendererComponent.SpriteRUID = "" 
					_TimerService:ClearTimer(self.DirectionTimer)
				end
		
			end
			
		 	self.DirectionTimer = _TimerService:SetTimerRepeat(transparent,_CoachService.DirectionTime/repeatTime)
		 
		-- 마스터코치 이펙트 연출 
		--[[elseif type == "effectOn" then 
			local coachInfo = _CoachService:GetCoachInfo(self.coachID)
			effect.SpriteRendererComponent.SpriteRUID = _CoachService.MasterCoachRUID_Anim[coachInfo.Cost]
			effect.TransformComponent.Position = _CoachService.MasterCoachOffset[coachInfo.Cost]
			effect.TransformComponent.Scale = _CoachService.MasterCoachScale[coachInfo.Cost]
			effect.Enable = true]]--
		end
	end

	@ExecSpace("Multicast")
	method void Init(string id, integer coachType, Vector3 ownerPos, string ownerID, boolean masterEffectOn)
		-------------------------------------------------------------------------
		-- 코치 id 기준으로 엔티티 세팅 
		-------------------------------------------------------------------------
		
		self.coachID = id
		self.state = "idle"
		self.ownerUserID = ownerID
		
		local coachInfo = _CoachService:GetCoachInfo(id)
		
		self.IdleRUID = coachInfo.IdleRUID
		self.MoveRUID = coachInfo.MoveRUID
		self.LoveRUID = coachInfo.LoveRUID
		self.SadRUID = coachInfo.SadRUID
		
		-- 코치 리소스 변경
		--self.Entity.SpriteRendererComponent.SortingLayer = "Default"
		self.Entity.SpriteRendererComponent.Color.a = 1
		self.Entity.KinematicbodyComponent.EnableShadow = true
		self.Entity.SpriteRendererComponent.SpriteRUID = self.IdleRUID
		
		-- 내 코치가 다른 플레이어의 코치 보다 앞에 보이도록 처리 
		
		if "coach"..ownerID == self.Entity.Name then 
		--	self.Entity.SpriteRendererComponent.OrderInLayer = 2
		else
		--	self.Entity.SpriteRendererComponent.OrderInLayer = 1
		end
		
		-- 이펙트 설정 
		
		local effect = self.Entity:GetChildByName("Effect")
		effect.Enable = false
		
		--마스터 코치일 시 이펙트 활성화
		if coachType == 2 and masterEffectOn == true then 
			effect.SpriteRendererComponent.SpriteRUID = _CoachService.MasterCoachRUID_Anim[coachInfo.Cost]
			effect.TransformComponent.Position = _CoachService.MasterCoachOffset[coachInfo.Cost]
			effect.TransformComponent.Scale = _CoachService.MasterCoachScale[coachInfo.Cost]
			effect.Enable = true
		end
		
		-- 최초 스폰 위치
		self.Entity.TransformComponent.WorldPosition = ownerPos + self.Offset
		
		_TimerService:ClearTimer(self.DirectionTimer)
		self.Entity.Enable = true 
	end

	@ExecSpace("Client")
	method void CoachSleepTimer()
		--100초동안 코치와 아무 상호작용이 없다면 SleepRUID를 보여줍니다.
		if self.coachID == "" then return end
		if self.Entity.CurrentMap.Name ~= "Lobby" then return end
		if self.CoolTime then return end
		if self.state == "move" then _TimerService:ClearTimer(self.WaitingTimer) return end
		
		_TimerService:ClearTimer(self.WaitingTimer)
		
		local setsleep = function()
			self.Entity.SpriteRendererComponent.SpriteRUID = _CoachService:GetCoachInfo(self.coachID).SleepRUID
		end
		
		self.WaitingTimer=_TimerService:SetTimerOnce(setsleep, 100)
		
	end

	@ExecSpace("Client")
	method void Interaction()
		if self.coachID == "" then return end
		if self.CoolTime then return end
		if self.state == "move" then return end
		
		self.CoolTime = true
		--코치 인터렉션
		local ruid = ""
		
		while(_UtilLogic:IsNilorEmptyString(ruid)) do
			local num = _UtilLogic:RandomIntegerRange(1, 4)
			local coachinfo = _CoachService:GetCoachInfo(self.coachID)
			local table = {coachinfo.InteractionRUID_1, coachinfo.InteractionRUID_2, coachinfo.InteractionRUID_3, coachinfo.InteractionRUID_4}
			ruid = table[num]
		end
		
		self.Entity.SpriteRendererComponent.SpriteRUID = ruid
		
		local init = function()
			self.CoolTime = false
			self:CoachSleepTimer()
			self.Entity.SpriteRendererComponent.SpriteRUID = _CoachService:GetCoachInfo(self.coachID).IdleRUID
		end
		
		_TimerService:SetTimerOnce(init , 3)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: TouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters 
		local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		self:CoachSleepTimer()
		self:Interaction()
	end

end