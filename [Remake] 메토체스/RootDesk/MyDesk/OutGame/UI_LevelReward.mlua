@Component
script UI_LevelReward extends Component

	property string RewardID = ""

	@ExecSpace("Client")
	method void Update_RewardEntity(integer level, boolean Goal, string rewardID, integer amount)
		-- 레벨 보상 엔티티의 UI 요소들을 업데이트
		local reward_Bg = self.Entity.SpriteGUIRendererComponent
		local reward_Icon = self.Entity:GetChildByName("sp_Reward").SpriteGUIRendererComponent
		local t_level =self.Entity:GetChildByName("t_level")
		local t_amount = self.Entity:GetChildByName("t_amount")
		local complete = self.Entity:GetChildByName("sp_complete")
		
		self.RewardID = rewardID
		
		-- 정보에 맞게 초기화
		t_level.TextComponent.Text = tostring(level)
		
		-- 갯수 표시 끄기
		t_amount.Enable = false
		
		
		local iconResourceInfo = _UI_PlayerLevel:GetRewardIconInfo(rewardID)
		
			-- 랭크모드 아이콘 넣어주기
		if rewardID == "RankMode" then
			reward_Bg.ImageRUID = iconResourceInfo["BackgroundRUID"]
			reward_Icon.ImageRUID = iconResourceInfo["RUID"]
			
			self.Entity.UI_SimpleTooltipActivator.Title = _LocalizationService:GetTextFormat("Reward_ModeOpen_Title", _LocalizationService:GetText("GameMode_Rank"))
			self.Entity.UI_SimpleTooltipActivator.Desc = _LocalizationService:GetTextFormat("Reward_ModeOpen_Desc", _LocalizationService:GetText("GameMode_Rank")) 
			
		else
			-- 챌린지모드
			if _UtilLogic:Contains(rewardID, "Challenge") then
				-- 임시로..
				local grade = _UtilLogic:Split(rewardID, "Challenge")
				local lv = grade[2]
				
				-- 아이콘
				reward_Bg.ImageRUID = iconResourceInfo["BackgroundRUID"]
				reward_Icon.ImageRUID = iconResourceInfo["RUID"]
					
				self.Entity.UI_SimpleTooltipActivator.Title = _LocalizationService:GetTextFormat("Reward_ModeOpen_Title", _LocalizationService:GetText("GameMode_Challenge").." "..lv)
				self.Entity.UI_SimpleTooltipActivator.Desc = _LocalizationService:GetTextFormat("Reward_ModeOpen_Desc", _LocalizationService:GetText("GameMode_Challenge").." "..lv) 
				
			-- 마이너스 코치
			elseif _UtilLogic:Contains(rewardID, "COM") then
				local coachdata = _CoachService:GetCoachInfo(rewardID)
				
				reward_Bg.ImageRUID = "07d90a3597561504f90752a4137b57f2"
				reward_Icon.ImageRUID = iconResourceInfo["RUID"]
				
				self.Entity.UI_SimpleTooltipActivator.Title = coachdata.Name
				self.Entity.UI_SimpleTooltipActivator.Desc = coachdata.Desc
				
			-- 패자 부활권
			else
				reward_Bg.ImageRUID = iconResourceInfo["BackgroundRUID"]
				reward_Icon.ImageRUID = iconResourceInfo["RUID"]
				t_amount.Enable = true
				t_amount.TextComponent.Text = tostring(amount)
				
				self.Entity.UI_SimpleTooltipActivator.Title = "Repechage_Free"
				self.Entity.UI_SimpleTooltipActivator.Desc = "Repechage_Tooltip"
			end
		end
		
		reward_Icon.LocalScale = iconResourceInfo["LocalScale"]
		reward_Icon.LocalPosition = iconResourceInfo["LocalPosition"]
		
		-- 이미 획득한 것이면 complete 켜주기
		complete.Enable = Goal
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 레벨 보상 설명 텍스트를 초기화
		local ui_desc = _EntityService:GetEntityByPath("/ui/Lobby_HUD/Popup_LevelRewardList/UISprite/UIText")
		
		local desc = ""
		desc = _LocalizationService:GetTextFormat("LevelUpRewardDesc_1", 80).."\n".._LocalizationService:GetText("LevelUpRewardDesc_2")
		
		ui_desc.TextComponent.Text = desc
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스 호버 시 툴팁 위치를 조정
		_UI_PlayerLevel.tooltip_RewardInfo.UITransformComponent.Position.x = self.Entity.UITransformComponent.Position.x + 200
		if _UI_PlayerLevel.tooltip_RewardInfo.UITransformComponent.Position.x + _UI_PlayerLevel.tooltip_RewardInfo.UITransformComponent.RectSize.x / 2  > 1910 then
			_UI_PlayerLevel.tooltip_RewardInfo.UITransformComponent.Position.x = 1910 - (_UI_PlayerLevel.tooltip_RewardInfo.UITransformComponent.RectSize.x / 2)
		end
	end

end