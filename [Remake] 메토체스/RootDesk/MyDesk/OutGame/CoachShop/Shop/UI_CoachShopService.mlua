	@ExecSpace("ClientOnly")
	method void PreventDoubleClick(Entity ui)
		ui.ButtonComponent.Enable = false
		
		_TimerService:SetTimerOnce(function()
			
			ui.ButtonComponent.Enable = true	
			
		end,0.3)
	end

	@ExecSpace("Server")
	method void CheckHaveRoyalSyrup(string ID)
		-- 시럽 보유 여부 판단
		local plr = _UserService:GetUserEntityByUserId(senderUserId)
		
		local data = _CoachService:GetCoachInfo(ID)
		local price = _CoachShopDataLogic:Get_CoachPriceById("Coach", ID)
		local plrsyrup = plr.PlayerDataComponent.RoyalSyrup
		
		if plrsyrup < price[2] then 
			_UIToast:ShowMessageByLocalizingKey("CoachShop_NoRoyalSyrup", senderUserId)
			return	
		else
			_UI_CoachShopPopUp:PopupInitialize(ID, "Coach", senderUserId)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "cad7e2cd-4a61-4789-9980-9f771e814e4a")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:RefreshShopUI()
	end

end