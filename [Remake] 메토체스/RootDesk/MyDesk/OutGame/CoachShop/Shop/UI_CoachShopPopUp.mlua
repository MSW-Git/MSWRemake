@Logic
script UI_CoachShopPopUp extends Logic

	property Entity Popup = "97415356-462c-4f5c-ba49-f8dfa2b5d4cd"

	property TextComponent PopupTitle = "6cb1e606-ab9e-46af-bd82-0f6a66e514c1"

	property SpriteGUIRendererComponent sp_goodsRUID = "e58fe28f-4f01-44ce-89b1-ca877e181bc3"

	property TextComponent t_goodsName = "277cc68e-ed25-4133-824d-0c185cde0854"

	property TextComponent t_goodsInfo = "35e0c711-2c57-437e-a9d5-d21937154c43"

	property TextComponent t_CoolingOff = "91f48124-acf9-4a44-b166-3b7b5d87cb23"

	property TextComponent t_WorldCoinPay = "416b11f3-92f8-4bc3-a34f-a9de9485c6bf"

	property Entity bt_syrup = "1d9c19d9-07c9-4825-b2d2-fe44d9ddcf71"

	property TextComponent t_remnantSyrup = "b932afc7-3987-4921-89a4-1bb29f6317bd"

	property Entity bt_RoyalSyrup = "b2f11cb3-0ffe-48b5-98a3-6d45e069f74c"

	property TextComponent t_remnantRoyalSyrup = "49312d2a-f50e-4c68-917c-a100c9a115c9"

	property Entity ToolTipBtn = "b27c2d04-4de5-4f12-9a2e-3a5262da2ef5"

	property Entity MasterEffect = "34a126bf-9306-4141-ae1d-bcb29e56b3bf"

	property string CostFilterType = ""

	property integer Price_syrup = 0

	property integer Price_RoyalSyrup = 0

	property integer Price_WorldCoin = 0

	property string GoodsID = ""

	property string GoodsType = ""

	property string WorldShopID = "IE8AG57H8"

	@ExecSpace("Client")
	method void PopupInitialize(string ID, string type)
		-----------------------------------------------------------------
		-- func: 상점 팝업 UI(상품 상세 정보) 초기화 
		-----------------------------------------------------------------
		
		-- 굿즈 타입 구분
		self.GoodsID = ID
		self.GoodsType = type
		
		local data
		if self.GoodsType == "Gacha" then 
			data =  _CoachShopDataLogic:Get_Gacha(self.GoodsID)
		else
			data = _CoachService:GetCoachInfo(self.GoodsID)
			
		end
		
		-- 가격 데이터 가져옴
		local priceData = _CoachShopDataLogic:Get_CoachPriceById(self.GoodsType,self.GoodsID)
		self.Price_syrup = priceData[1]
		self.Price_RoyalSyrup = priceData[2]
		self.Price_WorldCoin = priceData[3]
		
		-----------------------------------------------------------------
		-- 타이틀
		
		local titleText = _LocalizationService:GetText("Buy")
		if self.GoodsType == "Gacha" then titleText = _LocalizationService:GetText("Gacha_CG00001_Name").." ".._LocalizationService:GetText("Buy")
		elseif self.GoodsType == "Coach" then titleText = _LocalizationService:GetText("Coach").." ".._LocalizationService:GetText("Buy")
		-- elseif self.GoodsType == "MasterCoach" then titleText = _LocalizationService:GetText("Master").." ".._LocalizationService:GetText("Coach").." ".._LocalizationService:GetText("Buy")
		end
		
		self.PopupTitle.Text = titleText 
		
		-----------------------------------------------------------------
		-- 굿즈 썸네일 RUID
		
		local resourceinfo = _LoadResourcesInfo:GetUILocalPositionScale(data.ProfileRUID)
		self.sp_goodsRUID.LocalPosition = resourceinfo["pos"]
		self.sp_goodsRUID.LocalScale = resourceinfo["scale"]
		self.sp_goodsRUID.ImageRUID = data.ProfileRUID
		
		-----------------------------------------------------------------
		-- 굿즈 마스터 이펙트 
		
		if self.GoodsType == "MasterCoach" then 
			--[[local cost = _CoachService:GetCoachInfo(self.GoodsID).Cost
			_UI_CoachShopService:MasterEffectRenderer(self.MasterEffect,cost)
			
			self.ToolTipBtn.Enable = true
			self.MasterEffect.Enable = true]]--
		else
			self.ToolTipBtn.Enable = false
			self.MasterEffect.Enable = false
		end
		
		-----------------------------------------------------------------
		-- 굿즈 이름
		
		if self.GoodsType == "MasterCoach" then
			--self.t_goodsName.Text = _LocalizationService:GetText("Master").." ".._LocalizationService:GetText("Coach_"..self.GoodsID.."_Name")
		else
			self.t_goodsName.Text = _LocalizationService:GetText(self.GoodsType.."_"..self.GoodsID.."_Name")
		end
		-----------------------------------------------------------------
		-- 굿즈 코스트
		local colorTable = _DataService:GetTable("GradeColor")
		local coachColor = Color.FromHexCode(colorTable:FindRow("Key", string.format("Coach_%d", data.Cost)):GetItem("Default"))
		self.sp_goodsRUID.Entity:GetChildByName("Cost").SpriteGUIRendererComponent.Color = coachColor
		self.sp_goodsRUID.Entity:GetChildByName("Cost").TextComponent.Text = tostring(data.Cost)
		
		-----------------------------------------------------------------
		-- 청약 철회 문구
		
		--self.t_CoolingOff.Text = _LocalizationService:GetText("CancellationDesc")
		
		-----------------------------------------------------------------
		-- 굿즈 설명
		
		self.t_goodsInfo.Text =  _LocalizationService:GetText(data.Desc)
		
		-----------------------------------------------------------------
		-- 페이먼트 (가격 수정 및 결제 방식 버튼)
		
		if self.GoodsType == "Gacha" then 
			self.t_WorldCoinPay.Entity.Enable = false 
			self.bt_syrup.Enable = true 
			self.bt_RoyalSyrup.Enable = false 
		else
			--self.t_WorldCoinPay.Entity.Enable = true 
			--self.bt_syrup.Enable = false 
			self.bt_RoyalSyrup.Enable = true 
		end 
		
		local curSyrup = _UserService.LocalPlayer.PlayerDataComponent.Syrup
		local curRoyalSyrup = _UserService.LocalPlayer.PlayerDataComponent.RoyalSyrup
		
		self.t_WorldCoinPay.Text = tostring(self.Price_WorldCoin)
		self.bt_syrup.TextComponent.Text = tostring(self.Price_syrup)
		self.bt_RoyalSyrup.TextComponent.Text = tostring(self.Price_RoyalSyrup)
		
		-----------------------------------------------------------------
		-- 구매 가능 여부 
		
		--가챠 상점일때 
		if self.GoodsType == "Gacha" then 
			local aftSyrup = curSyrup - self.Price_syrup
			if aftSyrup < 0 then -- 주황 시럽 구매 불가
				self.bt_syrup.TextComponent.FontColor =  Color.FromHexCode(_UI_CoachShopService.FontColor_noSyrup)
				self.t_remnantSyrup.Entity.Enable = false
				self.t_remnantRoyalSyrup.Enable = false -- 잔여 텍스트
			else
				self.bt_syrup.TextComponent.FontColor =  Color.FromHexCode(_UI_CoachShopService.FontColor_Price)
				-- 잔여 시럽 표시
				self.t_remnantSyrup.Text = _LocalizationService:GetText("RemainingAmount")..": "..aftSyrup
			end
			
		-- 코치 구매 상점일때 
		else
			
			local aftRoyalSyrup = curRoyalSyrup - self.Price_RoyalSyrup
			if aftRoyalSyrup < 0 then -- 로얄 시럽 구매 불가 
				self.bt_RoyalSyrup.TextComponent.FontColor =  Color.FromHexCode(_UI_CoachShopService.FontColor_noSyrup)
				self.t_remnantRoyalSyrup.Entity.Enable = false
				self.t_remnantRoyalSyrup.Enable = false -- 잔여 텍스트
				
			else
				self.t_remnantRoyalSyrup.Enable = true
				self.bt_RoyalSyrup.TextComponent.FontColor =  Color.FromHexCode(_UI_CoachShopService.FontColor_Price)	
				-- 잔여 시럽 표시
				self.t_remnantRoyalSyrup.Text = _LocalizationService:GetText("RemainingAmount")..": "..aftRoyalSyrup
			
			end
		end
		
		-----------------------------------------------------------------
		-- UI켜기
		self.Popup.Enable = true
		self.Popup:GetChildByName("Popup").Enable = true
	end

	@ExecSpace("ClientOnly")
	method void UIClose_Popup()
		-- 상점 팝업 UI 닫기 
		self.Popup.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnClick_Tooltip()
		---------------------------------------------------------------
		--func: 상품 정보 툴팁 버튼 클릭 
		---------------------------------------------------------------
		
		local tooltipEnable = function(bool)
			self.ToolTipBtn:GetChildByName("UIText").Enable = bool
		end
		
		--tooltipEnable(true)
			self.ToolTipBtn:GetChildByName("UIText").Enable = true
		
		-- n초 후 툴팁 내용 꺼짐 
		_TimerService:SetTimerOnce(function()
				self.ToolTipBtn:GetChildByName("UIText").Enable = false
		end,2)
	end

	@ExecSpace("Client")
	method void OnClick_PurchaseBtn(string type)
		if type == "WorldCoin" then 
			-- 월드코인 구매 버튼 클릭  
			 _WorldShopService:PromptPurchase(self.WorldShopID)	
		else
			-- 주황 시럽/로얄 시럽 구매 버튼 클릭 
			self:RequestPurchase(_UI_CoachShopList.NowPageCategory,self.GoodsID)
		end
	end

	@ExecSpace("Server")
	method void RequestPurchase(string category, string goodsId)
		local player = _UserService:GetUserEntityByUserId(senderUserId)
		
		
		player.CoachShopManager:Purchase_Coach(goodsId,category)
	end

	@ExecSpace("Client")
	method void Popup_CompletePurchaseInitailize(string ID)
		-- 구매 완료 팝업
		local completepopup = _EntityService:GetEntity("2b069d82-f314-4fc8-b5bf-c84445cc4474") -- /ui/Lobby_Shop/Panel/PopupPanel/Popup_CompletePurchase
		local goodsinfo = _EntityService:GetEntity("8037f441-9b1d-4cc3-8eb7-576f26d139c1") -- /ui/Lobby_Shop/Panel/PopupPanel/Popup_CompletePurchase/sp_goodsRUID
		
		local data = _CoachService:GetCoachInfo(ID)
		-----------------------------------------------------------------
		-- 썸네일
		local resourceinfo = _LoadResourcesInfo:GetUILocalPositionScale(data.ProfileRUID)
		goodsinfo.SpriteGUIRendererComponent.LocalPosition = resourceinfo["pos"]
		goodsinfo.SpriteGUIRendererComponent.LocalScale = resourceinfo["scale"]
		goodsinfo.SpriteGUIRendererComponent.ImageRUID = data.ProfileRUID
		-----------------------------------------------------------------
		-- 이름, 설명
		goodsinfo:GetChildByName("t_goodsName").TextComponent.Text = _LocalizationService:GetText(self.GoodsType.."_"..self.GoodsID.."_Name")
		goodsinfo:GetChildByName("t_goodsInfo").TextComponent.Text = data.Desc
		-----------------------------------------------------------------
		-- 코스트
		local colorTable = _DataService:GetTable("GradeColor")
		local coachColor = Color.FromHexCode(colorTable:FindRow("Key", string.format("Coach_%d", data.Cost)):GetItem("Default"))
		goodsinfo:GetChildByName("Cost").SpriteGUIRendererComponent.Color = coachColor
		goodsinfo:GetChildByName("Cost").TextComponent.Text = tostring(data.Cost)
		-----------------------------------------------------------------
		-- UI켜기
		self.Popup:GetChildByName("Popup_CompletePurchase").Enable = true
		self.Popup:GetChildByName("Popup").Enable = false
		
	end

	@EventSender("Entity", "ced6dd94-79c5-488a-b6e3-9f84f1fc0ab6")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 상점 팝업 UI 닫기
		self:UIClose_Popup()
	end

	@EventSender("Entity", "1d9c19d9-07c9-4825-b2d2-fe44d9ddcf71")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		
		-- 상점 팝업 UI 닫기 
		self:UIClose_Popup()
		
		-- 뽑기 요청  
		_GachaLogic:RequestPickCoach_1Syrup()
		
		-- 중복 클릭 방지 
		_UI_CoachShopService:PreventDoubleClick(event.Entity)
		
		
	end

	@EventSender("Entity", "416b11f3-92f8-4bc3-a34f-a9de9485c6bf")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 월드코인 구매 버튼 클릭 
		self:OnClick_PurchaseBtn("WorldCoin")
		
		-- 중복 클릭 방지 
		_UI_CoachShopService:PreventDoubleClick(event.Entity)
		
		
	end

	@EventSender("Entity", "b2f11cb3-0ffe-48b5-98a3-6d45e069f74c")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		
		-- 로얄 시럽 구매 버튼 클릭 
		self:OnClick_PurchaseBtn("RoyalSyrup")
		
		-- 중복 클릭 방지 
		_UI_CoachShopService:PreventDoubleClick(event.Entity)
		
		
	end

	@EventSender("Entity", "b27c2d04-4de5-4f12-9a2e-3a5262da2ef5")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 상품 정보 툴팁 버튼 클릭 
		self:OnClick_Tooltip()
		
		
	end

	@EventSender("Entity", "8f378758-f31b-47d6-8ae9-aa45a9c864e6")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		-- 팝업, 상점 닫기
		self:UIClose_Popup()
		self.Popup:GetChildByName("Popup_CompletePurchase").Enable = false
		
		local shopbtn =_EntityService:GetEntity("26cf3b61-dc03-48b3-9aab-0ef81efc7ec5") -- /ui/Lobby_Shop/Panel/shopBG/BT_Exit
		shopbtn:SendEvent(ButtonClickEvent(shopbtn))
		
		-- 코치 보관함으로 이동
		local coachbtn = _EntityService:GetEntity("3e7ce914-c634-4a56-812d-33c800737e59") -- /ui/Lobby_HUD/List_LeftMenu/Button_Coach
		coachbtn:SendEvent(ButtonClickEvent(coachbtn))
		
		-- 코치 보관함 인덱스 지정
		local data = _CoachService:GetCoachInfo(self.GoodsID)
		
		local coachtab = _EntityService:GetEntity("22fd2afe-2d08-47ff-864e-480fabdce528") -- /ui/Lobby_CoachInventory/Panel_CoachInventory/Tab_Cost
		
		if data.Cost <=5 then
			coachtab.TabComponent:OnTabButtonClicked(ButtonClickEvent(coachtab.Children[data.Cost+3]))
		elseif data.Cost >=7 then
			coachtab.TabComponent:OnTabButtonClicked(ButtonClickEvent(coachtab.Children[data.Cost+2]))
		end
		
		
	end

	@EventSender("Entity", "a6b77eed-ecd0-4f7d-9c1f-666cfffe9648")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		-- 팝업 닫기
		self:UIClose_Popup()
		self.Popup:GetChildByName("Popup_CompletePurchase").Enable = false
	end

end