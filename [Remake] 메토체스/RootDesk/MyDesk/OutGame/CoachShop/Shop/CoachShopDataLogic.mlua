@Logic
script CoachShopDataLogic extends Logic

	property table GoodsData_Coach = {}

	property table GoodsData_Gacha = {}

	property table CoachPrice = {}

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 상점 관련 데이터셋들을 로드하는 초기화 함수
		-----------------------------------------------------------
		-- GachaGoods(가챠 상품 목록) 데이터셋 읽어오기  
		
		local gachaData = _DataService:GetTable("GachaGoods")
		
		
		for _,row in pairs(gachaData:GetAllRow()) do
		
			local GoodsData = GachaGoods()
			GoodsData.id = row:GetItem("ID")
			GoodsData.Name = row:GetItem("Name")
			GoodsData.Desc = row:GetItem("Desc")
			GoodsData.Price = tonumber(row:GetItem("Price"))
			GoodsData.WorldCoin = tonumber(row:GetItem("WorldCoin"))
			
			GoodsData.ProfileRUID = row:GetItem("ProfileRUID")
		
			self.GoodsData_Gacha[GoodsData.id] = GoodsData
		end
		
		-----------------------------------------------------------
		-- CoachGoods(코치 상품 목록) 데이터셋 읽어오기  
		
		---@type MODUserDataSet
		local coachGoods = _DataService:GetTable("CoachGoods")
		
		for i=1, coachGoods:GetRowCount() do
			local row = coachGoods:GetRow(i)
			
			local GoodsData = CoachGoods()
			GoodsData.GoodsID = row:GetItem("GoodsID")
			
			self.GoodsData_Coach[GoodsData.GoodsID] = GoodsData
		end
		
		-----------------------------------------------------------
		-- CoachPrice(코치 가격) 데이터셋 읽어오기  
		
		local data = _DataService:GetTable("CoachPrice")
		
		
		for _,row in pairs(data:GetAllRow()) do
		
			local GoodsData = CoachPrice()
			GoodsData.Cost = tonumber(row:GetItem("Cost"))
			GoodsData.NormalPrice = tonumber(row:GetItem("NormalPrice"))
			GoodsData.MasterPrice = tonumber(row:GetItem("MasterPrice"))
			GoodsData.NormalWorldCoin = tonumber(row:GetItem("NormalWorldCoin"))
			GoodsData.MasterWorldCoin = tonumber(row:GetItem("MasterWorldCoin"))
			GoodsData.NormalDuplicate = tonumber(row:GetItem("NormalDuplicate"))
			GoodsData.MasterDuplicate = tonumber(row:GetItem("MasterDuplicate"))
			
			self.CoachPrice[GoodsData.Cost] = GoodsData
		end
		
		-----------------------------------------------------------
		--클라로 sync 
		
		--_TimerService:SetTimerOnce(function()
		--	self:DataSync(self.GoodsData_Gacha,self.GoodsData_Coach,self.CoachPrice)
		--	_UI_CoachShopList:Create_CoachShopList("Gacha")
		--end,1)
	end

	method GachaGoods Get_Gacha(string id)
		-- 가챠 상품 ID로 가챠 상품 정보를 조회하는 함수
		if not isvalid(self.GoodsData_Gacha[id]) then 
			return nil
		end
		
		return self.GoodsData_Gacha[id]
	end

	method CoachPrice Get_CoachPrice(integer cost)
		-- 코치 코스트로 가격 정보를 조회하는 함수
		if not isvalid(self.CoachPrice[cost]) then 
			return nil
		end
		
		return self.CoachPrice[cost]
	end

	method table Get_CoachPriceById(string goodsType, string goodsID)
		-- 상품 타입과 ID로 가격 정보를 배열 형태로 반환하는 함수
		if goodsType == "Gacha" then 
			local data = _CoachShopDataLogic:Get_Gacha(goodsID)
			return {data.Price,0,0}
			
		elseif goodsType == "Coach" then 
			local cost = _CoachService:GetCoachInfo(goodsID).Cost
			local data = _CoachShopDataLogic:Get_CoachPrice(cost)
		
			return {0,data.NormalPrice,data.NormalWorldCoin}
			
		else
			local cost = _CoachService:GetCoachInfo(goodsID).Cost
			local data = _CoachShopDataLogic:Get_CoachPrice(cost)
		
			return {0,data.MasterPrice,data.MasterWorldCoin}
		end
	end

	@ExecSpace("Client")
	method void DataSync(table GachaData, table coachData, table coachPrice)
		-- 서버에서 클라이언트로 상점 데이터를 동기화하는 함수
		self.GoodsData_Gacha = GachaData
		self.GoodsData_Coach = coachData
		self.CoachPrice = coachPrice
	end

	@ExecSpace("ServerOnly")
	@EventSender("Service", "UserService")
	handler HandleUserEnterEvent(UserEnterEvent event)
		-- 유저 입장 시 상점 데이터를 동기화하고 UI를 초기화하는 핸들러
		--------------- Native Event Sender Info ----------------
		-- Sender: UserService
		-- Space: Server
		---------------------------------------------------------
		
		-- Parameters
		local UserId = event.UserId
		---------------------------------------------------------
		self:DataSync(self.GoodsData_Gacha,self.GoodsData_Coach,self.CoachPrice,UserId)
		_UI_CoachShopList:Create_CoachShopList("Coach",UserId)
	end

end