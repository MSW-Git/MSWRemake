	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		
		-- 코스트 필터의 목록 UI , 버튼 이벤트 연결하기 
		for _,entity in pairs(self.Filter_CostList.Children) do 
			entity:ConnectEvent(ButtonClickEvent,function()
				
				
				-- 설정이 변경되지 않았다면 
				if self.FilterCostType == entity.Name then 
					self.Filter_CostList.Enable =false
					return
				end
					
				 
				self:OnClick_Filter(entity.Name,self.SortType) 
			end)
		end
		
		-- 정렬 목록 UI , 버튼 이벤트 연결하기 
		--for _,entity in pairs(self.SortList.Children) do 
		--    entity:ConnectEvent(ButtonClickEvent,
		--        
		--    function() 
		--            
		--        -- 설정이 변경되지 않았다면 
		--        if self.SortType == entity.Name then 
		--            --self.SortList.Enable =false
		--            return
		--        end
		--            
		--        self:OnClick_Filter(self.FilterCostType,entity.Name) 
		--            
		--    end)
		--end
		--
		self.Shop.Enable =false
	end

