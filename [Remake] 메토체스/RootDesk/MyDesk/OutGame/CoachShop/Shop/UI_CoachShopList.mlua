	@ExecSpace("ClientOnly")
	method table Sort(table coachList, string sortType)
		-- func: 코치 목록 id가 담긴 테이블을 코스트 오름차순/내림차순으로 정렬하는 함수
		--------------------------------------------------------------------------------
		--코스트 오름/내림차순
		table.sort(coachList, function(a, b)
			
			local costA = tonumber(_CoachService:GetCoachInfo(a).Cost)
			local costB = tonumber(_CoachService:GetCoachInfo(b).Cost)
			
			if sortType == "Cost_Descending" then 
				return costA > costB  -- a가 b보다 크면 앞에 오도록 설정 (내림차순)
			else
				return costA < costB
			end
		
		end)
		
		-- ID 뒷자리 오름차순
		local groupingtable = {{},{},{},{},{}}
		local index = 1
		for i = 1 , #coachList do
			if i == 1 then
				table.insert(groupingtable[index],coachList[1])
				
			else
				local a = _CoachService:GetCoachInfo(groupingtable[index][#groupingtable[index]]).Cost
				local b = _CoachService:GetCoachInfo(coachList[i]).Cost
				if a ~= b then
					index += 1
				end
				table.insert(groupingtable[index],coachList[i])
			end
		end
		
		for i = 1, #groupingtable do
			table.sort(groupingtable[i], function(a, b)
			
			local ID_A = tonumber(_UtilLogic:SubString(a, string.len(a)-1, 2))
			local ID_B = tonumber(_UtilLogic:SubString(b, string.len(b)-1, 2))
		
			return ID_A < ID_B   -- ID 오름차순
		end)
		end
		
		
		local target = {}
		for i = 1, #groupingtable do
			for j = 1, #groupingtable[i] do
				table.insert(target, groupingtable[i][j])
			end
		end
		
		return target
		
	end

	@ExecSpace("ClientOnly")
	method void OnClick_Filter(string costFilterType, string sortType)
		------------------------------------------------------------------------
		-- func: 필터 버튼 클릭 시 처리하는 함수 
		------------------------------------------------------------------------
		
		self.FilterCostType = costFilterType
		self.SortType = sortType 
		
		self.Filter_CostList.Enable =false
		self:Enable_SortList(false)
		
		self.Filter_CostText.TextComponent.Text = _LocalizationService:GetText(self.FilterCostType)
		--self.SortText.TextComponent.Text = _LocalizationService:GetText(sortType)
		
		self:RefreshGoods_Coach()
	end

	@ExecSpace("ClientOnly")
	method void OnClick_OwnCoachVisible()
		-- func: 코치 상점의 필터 버튼 클릭시 보유한 코치도 함께 보이도록 요청하는 함수 
		--------------------------------------------------------------------------------
		
		self.Check_Coach.Enable = not self.Check_Coach.Enable
		self.IsOwnCoachVisible = not self.IsOwnCoachVisible 
		
		self:OnClick_Filter(self.FilterCostType,self.SortType)
	end

