		------------------------------------------------------------------------
		
		-- 상점 카테고리 설정
		self.NowPageCategory = category
		
		-- 상점 카테고리 버튼 설정 
		self:InitCategoryBtn()
		
		-----------------------------------------------------------------------
		-- 그리드뷰 설정 
		self.GoodsArea.ItemEntity = self.CoachShop_GoodsArea.Children[1]
		
		-- 상점 카테고리에 따른 상품 UI 생성 
		if self.NowPageCategory == "Gacha" then 
			--self:RefreshGoods_Gacha()	
		else
			self:RefreshGoods_Coach()	
		end
	end

