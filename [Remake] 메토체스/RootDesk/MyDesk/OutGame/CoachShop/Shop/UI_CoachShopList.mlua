	@ExecSpace("ClientOnly")
	method void RefreshGoods_Coach()
		-----------------------------------------------------------------
		-- 코치 상점 품목 UI 그리기 
		-----------------------------------------------------------------
		
		--param 
		local coachManager = _UserService.LocalPlayer.CoachManager
		-- 필터링 진행
		local idTable = _CoachShopDataLogic.GoodsData_Coach
		-- _CoachShopDataLogic:GetItemsByType(self.NowPageCategory)
		------------------------------------------------------------------
		-- 유저가 설정한 필터 정보에 따라 보여질 상품 목록을 세팅합니다. 
		
		---@type table<string>
		local HasCoaches = {}
		
		for coachID,data in pairs(idTable) do
				
			-- 일반 코치 필터 
			if self.NowPageCategory == "Coach" then 
				if self.IsOwnCoachVisible == true and coachManager:GetHasType(coachID) > 0 then -- 보유하지 않은 코치만 보이도록 설정했는가?
					continue 
				end
				
			-- 마스터 코치 필터 
			--[[elseif self.NowPageCategory == "MasterCoach" then 
				if self.IsOwnMasterCoachVisible == true and coachManager:GetHasType(coachID) ~= 1 then -- 마스터 코치 구매 가능한가?  
					continue 
				end		]]--		
			end
		
			-- 유저가 설정한 코스트 필터와 상품에 보여질 코치의 코스트가 동일한가? 
			local coachData = _CoachService:GetCoachInfo(coachID)
			local cost = coachData.Cost
			if self.FilterCostType ~= "Total" and cost ~= tonumber(self.FilterCostType) then 
				continue
			end
				
			-- 마이너스 코치, 4코스트는 제외
			if _CoachService:GetCoachInfo(coachID).Cost > 0 and _CoachService:GetCoachInfo(coachID).Cost ~= 4 then
				table.insert(HasCoaches,coachID)
			end
		end
		
		-- 코스트 오름차순/내림차순 정렬 
		HasCoaches = self:Sort(HasCoaches,self.SortType)
		--self:Sort(HasCoaches,self.SortType)
		
		-----------------------------------------------------
		self.GoodsArea.TotalCount = #HasCoaches
		
		-- 그리드뷰 구성
		local function onRefresh(index, slot)
			index = index + 1
		
			---@type UI_Goods
			local goods = slot.UI_Goods
			--log(index,idTable)
			goods:InitializeGoods(HasCoaches[index], self.NowPageCategory, coachManager:GetHasType(HasCoaches[index]))
		end
		
		-----------------------------------------------------
		self.GoodsArea.OnRefresh = onRefresh
		self.GoodsArea:Refresh(true, true)
	end

	@ExecSpace("ClientOnly")
	method void RefreshGoods_Gacha()
		-----------------------------------------------------
		-- func: 상점 품목 UI 그리기 
		-----------------------------------------------------
		
		--[[local idTable =  _CoachShopDataLogic.GoodsData_Gacha
		
		
		self.GoodsArea.TotalCount =  #idTable+1 
		self.GoodsArea.ItemEntity = self.CoachShop_GoodsArea.Children[1]
		
		-- 그리드뷰 구성
		local function onRefresh(index, slot)
		
			if slot == self.GoodsArea.ItemEntity then 
				return
			end
			index = index + 1
		
			---@type UI_Goods
			local goods = slot.UI_Goods
		
			goods:InitializeGoods(table.keys(idTable)[index], self.NowPageCategory, 0)
		end
		
		self.GoodsArea.OnRefresh = onRefresh
		self.GoodsArea:Refresh(true, true)]]--
	end

