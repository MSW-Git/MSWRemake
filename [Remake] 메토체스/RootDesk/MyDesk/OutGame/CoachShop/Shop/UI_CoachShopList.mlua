			self:Enable_FilterCostBtn(true)
			self:Enable_SortBtn(true)
		
		--[[elseif self.NowPageCategory == "MasterCoach" then -- 마스터 코치 구매
			
			self.BT_MasterCoach.TextComponent.Text = _LocalizationService:GetText("Master").._LocalizationService:GetText("Coach")
