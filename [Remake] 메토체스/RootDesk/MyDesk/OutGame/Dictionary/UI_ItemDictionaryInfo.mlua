@Component
script UI_ItemDictionaryInfo extends Component

	property string nowItemID = ""

	property SpriteGUIRendererComponent sp_itemBG = "b6fab4b7-7f5c-463f-a66f-f01d0f9b9c19"

	property SpriteGUIRendererComponent sp_itemIcon = "941492ab-56dd-4689-a3c2-96bfccba918f"

	property TextComponent t_name = "c83d267f-a3b0-4c90-bb65-1a4c7c362888"

	property TextComponent t_guide = "4a54afdf-f4c3-4fdf-8cfb-021668903831"

	property TextComponent t_specialAbility = "00720835-cd40-4d8c-9302-91a4aea6754b"

	property Entity t_Status = "18e19576-deaf-4c9b-9bf5-d42e080741b2"

	property Entity UI_StatusEffect1_Name = "85b26e62-6cfe-4a5d-acf5-067cfdb9e13e"

	property Entity UI_StatusEffect1_Desc = "57e68e57-d5af-4f48-81d3-041f9c2cbe73"

	property Entity UI_StatusEffect2_Name = "753e9e6d-889e-4e8c-9171-f44e10f298c7"

	property Entity UI_StatusEffect2_Desc = "b6715bb0-d65e-4df8-b22a-0989b86e568d"

	property Entity UI_StatusEffect3_Name = "b735005e-01cb-46ae-a58c-f0e48caf1f26"

	property Entity UI_StatusEffect3_Desc = "2defe322-ff0b-46c5-a3d3-431dd7c640c4"

	property Entity UI_ItemExtraInfoTitle = "0719dd00-8bbc-4f93-8019-2e3c0b828dde"

	property Entity Recipe = "79c20ff2-890c-4136-a30c-f7216759b58e"

	property UI_Dictionary_ItemBT bt_materialIcon = "6faa2e37-b3af-4401-9e57-8b475f282736"

	property UI_Dictionary_ItemBT bt_materialIcon2 = "cf9a3042-6853-434f-a4ab-84a98d9235ba"

	property Entity Recipes = "4d43ba15-2a63-4c4d-a6bc-8a89b28e21e7"

	property Entity Box_ItemList = "82b5ca37-af64-45ce-a600-a4a38b772702"

	property Entity UI_DecoLine1 = "af5fafd9-3b10-465f-ab0f-56fda33f89cc"

	property Entity UI_DecoLine2 = "dd84531b-83f0-4b6b-885e-ba89b97582d4"

	property Entity UI_DecoLine3 = "90f88009-06fb-4980-a98d-14aec306b748"

	@ExecSpace("ClientOnly")
	method void OnInitialize()
		-- 아이템 정보 패널 초기화
		self.nowItemID = nil
	end

	@ExecSpace("ClientOnly")
	method void UpdateUI(string itemID)
		-- 아이템 정보 UI 전체 업데이트 및 타입별 확장 정보 표시
		if self.nowItemID == itemID then return end
		
		self.nowItemID = itemID
		
		---@type ItemStatusDictionaryData
		local data = _DictionaryDataManager.ItemDataList[itemID]
		------------------------------------------------------------------------------------------------------------
		-- 아이콘 및 배경
		self.sp_itemBG.ImageRUID = data.BackgroundRUID
		self.sp_itemIcon.ImageRUID = data.RUID
		self.sp_itemIcon.LocalScale = data.RUID_LocalScale
		self.sp_itemIcon.LocalPosition = data.RUID_LocalPos
		
		-- 이름
		self.t_name.Text = _LocalizationService:GetText("Item_"..itemID.."_Name")
		
		-- 가이드 입력 / 없을 시 빈 칸으로
		local guideText = data.Guide
		if _UtilLogic:IsNilorEmptyString(guideText) == true then
			self.t_guide.Entity.Enable = false
		else
			self.t_guide.Entity.Enable = true
			self.t_guide.Text = data.Guide
		end
		------------------------------------------------------------------------------------------------------------	
		-- 특수 효과
		if data.SpecialAbility == "" then
			self.t_specialAbility.Text = ""
			self.t_specialAbility.Entity.Enable = false
			self.UI_DecoLine1.Enable = false
		else
			self.t_specialAbility.Text = data.SpecialAbility
			self.t_specialAbility.Entity.Enable = true
			self.UI_DecoLine1.Enable = true
		end
		
		-- 스테이터스 갱신
		local statusText = self:GetItemStatusText(data)
		if _UtilLogic:IsNilorEmptyString(statusText) == false then
			self.t_Status.TextComponent.Text = statusText
			self.t_Status.Enable = true
			self.UI_DecoLine2.Enable = true
		else
			self.t_Status.Enable = false
			self.UI_DecoLine2.Enable = false
		end
		
		
		-- 상태이상 효과 여부 확인
		if _UtilLogic:IsNilorEmptyString(data.StatusEffect[1]) == false then
			local statusEffectID = data.StatusEffect[1]
			self.UI_StatusEffect1_Name.TextComponent.Text = _LocalizationService:GetText("StatusEffect_Name_"..statusEffectID)
			self.UI_StatusEffect1_Desc.TextComponent.Text = _LocalizationService:GetText("StatusEffect_Desc_"..statusEffectID)
			self.UI_StatusEffect1_Name.Enable = true
			self.UI_StatusEffect1_Desc.Enable = true
		else
			self.UI_StatusEffect1_Name.Enable = false
			self.UI_StatusEffect1_Desc.Enable = false
		end
		if _UtilLogic:IsNilorEmptyString(data.StatusEffect[2]) == false then
			local statusEffectID = data.StatusEffect[2]
			self.UI_StatusEffect2_Name.TextComponent.Text = _LocalizationService:GetText("StatusEffect_Name_"..statusEffectID)
			self.UI_StatusEffect2_Desc.TextComponent.Text = _LocalizationService:GetText("StatusEffect_Desc_"..statusEffectID)
			self.UI_StatusEffect2_Name.Enable = true
			self.UI_StatusEffect2_Desc.Enable = true
		else
			self.UI_StatusEffect2_Name.Enable = false
			self.UI_StatusEffect2_Desc.Enable = false
		end
		if _UtilLogic:IsNilorEmptyString(data.StatusEffect[3]) == false then
			local statusEffectID = data.StatusEffect[3]
			self.UI_StatusEffect3_Name.TextComponent.Text = _LocalizationService:GetText("StatusEffect_Name_"..statusEffectID)
			self.UI_StatusEffect3_Desc.TextComponent.Text = _LocalizationService:GetText("StatusEffect_Desc_"..statusEffectID)
			self.UI_StatusEffect3_Name.Enable = true
			self.UI_StatusEffect3_Desc.Enable = true
		else
			self.UI_StatusEffect3_Name.Enable = false
			self.UI_StatusEffect3_Desc.Enable = false
		end
		
		if #data.StatusEffect < 1 then
			self.UI_DecoLine3.Enable = false
		else
			self.UI_DecoLine3.Enable = true
		end
		
		-- 아이템 타입에 따라 확장 정보 표시
		if data.Type == "MaterialItem" then
			self:UpdateUI_Extra_Recipes(self.nowItemID)
			
			self.UI_ItemExtraInfoTitle.TextComponent.Text = "ItemCombinationTable"
			
			self.Recipes.Enable = true
			self.Recipe.Enable = false
			self.Box_ItemList.Enable = false
			
			self.Recipe.Parent.Enable = true
			
			-- 완성 아이템인 경우, 조합식을 표시합니다.
		elseif data.Type == "NormalItem" then
			self:UpdateUI_Extra_Recipe(self.nowItemID)
			
			self.UI_ItemExtraInfoTitle.TextComponent.Text = "MaterialInfo"
			
			self.Recipes.Enable = false
			self.Recipe.Enable = true
			self.Box_ItemList.Enable = false
			
			self.Recipe.Parent.Enable = true
			
			-- 박스 아이템인 경우, 획득 가능한 아이템 목록을 표시합니다.	
		elseif data.Type == "Box" then
			self:ItemList_Update()
			
			self.UI_ItemExtraInfoTitle.TextComponent.Text = "ObtainableItems"
			
			self.Recipes.Enable = false
			self.Recipe.Enable = false
			self.Box_ItemList.Enable = true
			
			self.Recipe.Parent.Enable = true
			
			-- 그 외의 경우에는 모두 끕니다.
		else
				-- 하나로 묶어놔서 parent 끄면 다 꺼짐
			self.Recipe.Parent.Enable = false
			self.UI_DecoLine3.Enable = false
			
				-- deco_line 엔티티 끄기
			if #data.StatusEffect < 1 then
				self.UI_DecoLine2.Enable = false
				
				if _UtilLogic:IsNilorEmptyString(statusText) == true then
					self.UI_DecoLine1.Enable = false
				end
			end
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method string GetItemStatusText(any data)
		-- 아이템 스탯 정보를 텍스트로 포맷팅하여 반환
		local statusTable = _DataService:GetTable("Status")
		local itemStatusTypes = _ItemStatusLogic:GetItemStatusTypeTable()
		
		---@type ItemStatusDictionaryData
		local itemData = data
		
		local statusText = ""
		
		for i=1, #itemStatusTypes do
			local statValue = itemData.Status[itemStatusTypes[i]]
			
			-- 값이 있는 경우 (=아이템을 통해 해당 스탯이 오른다면)
			if isvalid(statValue) == true and statValue ~= 0 then
				if statusText ~= "" then -- 빈 텍스트라면 줄넘김 x
					statusText = statusText.."\n"
				end
				
				local rowInStatusTable = statusTable:FindRow("Key", itemStatusTypes[i])
			
				local statName = _LocalizationService:GetText("Status_"..itemStatusTypes[i])
				local format = rowInStatusTable:GetItem("Format")
				local ItemStatusFormat = rowInStatusTable:GetItem("ItemStatusFormat")
				local colorCode = rowInStatusTable:GetItem("Color")
				
				statusText = statusText..string.format("<color=%s>%s %s</color>",colorCode, statName, string.format(ItemStatusFormat, tonumber(statValue)))
			end
		end
		
		return statusText
	end

	@ExecSpace("ClientOnly")
	method void UpdateUI_Extra_Recipes(string itemID)
		-- 재료 아이템 화면에서 / 이 재료 아이템으로 만들 수 있는 모든 레시피를 보여줍니다.
		
		-- 재료 아이템 아이디를 모두 받아옵니다.
		local materialList = _DictionaryDataManager:GetItemIDList(_DictionaryManager.NowShowingSeason, "MaterialItem")
		
		-- 현재 아이템 아이디와 재료 아이템 아이디를 순서대로 넣어가면서 Recipe1~8을 갱신해줍니다.
		for i=1, 8 do
			self.Recipes.Children[i]:GetChildByName("material_1").UI_Dictionary_ItemBT:UpdateIcon(materialList[i])
			
			local normalID = _ItemCombineService:GetNormalItemIDByMaterialItemIDs(itemID, materialList[i], nil)
			
			self.Recipes.Children[i]:GetChildByName("material2_1").UI_Dictionary_ItemBT:UpdateIcon(normalID)
			
			self.Recipes.Children[i]:GetChildByName("NormalItemName").TextComponent.Text = _LocalizationService:GetText("Item_"..normalID.."_Name")
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateUI_Extra_Recipe(string itemID)
		-- 완성 아이템 화면에서 / 이 아이템의 조합식을 보여줍니다.
		
		local materials = _ItemCombineService:GetMaterialItemIDsByNormalItemID(itemID)
		
		if materials == nil then
			log("재료 아이템이 없음")
			self.Recipe.Enable = false
			return
		end
		self.Recipe.Enable = true
		
		--[[local materialInfo =  _DictionaryDataManager:GetItemStatus_Row(materials[1])
		local materialInfo2 =  _DictionaryDataManager:GetItemStatus_Row(materials[2])]]
		
		self.bt_materialIcon:UpdateIcon(materials[1])
		self.bt_materialIcon2:UpdateIcon(materials[2])
	end

	@ExecSpace("ClientOnly")
	method void ItemList_Update()
		-- 박스 아이템의 획득 가능한 아이템 목록 UI 업데이트
		if self.nowItemID == "" then return end
		
		local list = self:SetItemList_intheBox(self.nowItemID)
		
		-- list 비어있으면 박스 아님
		if list == nil then
			return
		end
		
		for i =1, self.Box_ItemList.Children.Count do
			self.Box_ItemList.Children[i].Enable = false
		end
		
		
		for i =1, #list do
			self.Box_ItemList.Children[i].UI_Dictionary_ItemBT:UpdateIcon(list[i])
			self.Box_ItemList.Children[i].Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method table SetItemList_intheBox(string itemID)
		-- 해당 아이템이 '아이템 박스'인가?
		local itemTable = _DataService:GetTable("ItemStatus")
		local row = itemTable:FindRow("ItemID", itemID)
		if row:GetItem("Type") ~= "Box" then
			log_warning("box 타입 아이템이 아닙니다.")
			self.Box_ItemList.Parent.Enable = false
			return nil
		end
		
		self.Box_ItemList.Parent.Enable = true
		
		-- 미리 아이템 분류
		---@type table<string>
		local consumItem = {}
		---@type table<string>
		local materialItem = {}
		---@type table<string>
		local normalItem = {}
		for i=1, itemTable:GetRowCount() do
			if itemTable:GetCell(i, "Type") == "Consumable" and itemTable:GetCell(i, "Tags") ~= "Special" then
				table.insert(consumItem, itemTable:GetCell(i, "ItemID"))
			elseif itemTable:GetCell(i, "Type") == "MaterialItem" then table.insert(materialItem, itemTable:GetCell(i, "ItemID"))
			elseif itemTable:GetCell(i, "Type") == "NormalItem" then table.insert(normalItem, itemTable:GetCell(i, "ItemID")) end
		end
		
		-- 반환값
		---@type table
		local itemlist = {}
		
		
		-- 1. 재료 아이템 상자
		if itemID == "IB00001" then
			return materialItem
		-- 2. 공격형 재료 아이템 상자
		elseif itemID == "IB00002" then
			for i=1, #materialItem do
				local rowtemp = itemTable:FindRow("ItemID", materialItem[i])
				local tags = _UtilLogic:Split(rowtemp:GetItem("Tags"), ",")
				
				local hasTargetTag = false
				for j=1, #tags do
					if tags[j] == "Attacker" then
						hasTargetTag = true
					end
				end
				
				if hasTargetTag then table.insert(itemlist,materialItem[i]) end
			end
			
		-- 3. 방어형 재료 아이템 상자
		elseif itemID == "IB00003" then
			for i=1, #materialItem do
				local rowtemp = itemTable:FindRow("ItemID", materialItem[i])
				local tags = _UtilLogic:Split(rowtemp:GetItem("Tags"), ",")
				local hasTargetTag = false
				for j=1, #tags do
					if tags[j] == "Defender" then
						hasTargetTag = true
					end
				end
				
				if hasTargetTag then table.insert(itemlist,materialItem[i]) end
			end
		
		-- 12. 소모 아이템 상자
		elseif itemID == "IB00013" then
			return consumItem
			
		-- 완성 아이템 상자
		else
			local tag = row:GetItem("Tags")
			if tag == "" then self.Box_ItemList.Parent.Enable = false end
			
			for i=1, #materialItem do
				---@type string
				local normal = _ItemCombineService:GetNormalItemIDByMaterialItemIDs(tag, materialItem[i], nil)
				table.insert(itemlist, normal)
			end
			
		end
		return itemlist
	end

end