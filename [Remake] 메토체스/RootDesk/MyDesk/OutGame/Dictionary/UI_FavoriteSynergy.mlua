@Component
script UI_FavoriteSynergy extends Component

	property integer i_entityNumber = 0

	property TextComponent tooltip_SynergyInfo = "719b2655-3386-4aea-8010-7e3970daee05"

	property string synergyID = ""

	property UI_SynergyDictionaryInfo popup = "6c472ed3-eedb-44a2-a1ca-f1e886d15d95"

	property Entity UI_Icon = nil

	property Entity UI_Count = nil

	@ExecSpace("ClientOnly")
	method void Initialize()
		-- 즐겨찾기 시너지 UI 컴포넌트 초기화
		self.UI_Icon = self.Entity:GetChildByName("sp_SynergyIcon")
		self.UI_Count = self.Entity:GetChildByName("t_Count")
	end

	@ExecSpace("ClientOnly")
	method void UpdateFaveSynergy(string id, integer activeLevel, integer nowActiveMember)
		-- 즐겨찾기 시너지 UI 업데이트 (아이콘, 활성화 단계, 인원수)
		-- 즐겨찾기 캐릭터가 추가될 때, 캐릭터 조합에 따라 시너지를 업데이트합니다.
		-- id : 시너지 아이디
		-- activeLevel : 시너지 활성화 단계
		-- nowActvieMember : 배치된 캐릭터 
		------------------------------------------------------------------------------
		if isvalid(self.UI_Icon) == false then
			self:Initialize()
		end
		------------------------------------------------------------------------------
		self.synergyID = id
		local stepColor = {"#1d1d21", "#774e35", "#807c95", "#d28a3c", "#bf8f00", "#d7b6e5"}
		
		-- 표시할 시너지가 없는 경우
		if id == "NIL" then
			self.UI_Icon.Enable = false
			self.UI_Count.Enable = false
			self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode("#1c2b40") -- 컬러는 임시값입니당
			return
		end
		
		-- 있는 경우
		local data = _DictionaryDataManager.SynergyDataList[id]	
		
		self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode(stepColor[activeLevel + 1])
		
		if activeLevel == 0 then
			self.UI_Icon.SpriteGUIRendererComponent.Color = Color.FromHexCode("#464a52")
		else
			self.UI_Icon.SpriteGUIRendererComponent.Color = Color.FromHexCode("#1d1d21")
		end
		self.UI_Icon.SpriteGUIRendererComponent.ImageRUID = data.IconRUID
		self.UI_Icon.Enable = true
		
		self.UI_Count.TextComponent.Text = self:GetSynergyCountText(id, nowActiveMember)
		self.UI_Count.Enable = true
	end

	@ExecSpace("ClientOnly")
	method string GetSynergyCountText(string key, integer nowCount)
		-- 전직교관부터 판단
		if key == "S10024" then
			return nowCount.."/5"
		-- 전직교관이 아니면
		else
			local data = _DictionaryDataManager.SynergyDataList[key]
			
			-- 단일 시너지이면
			if data.NeedCount_step[3] ~= "-" then
				-- 숫자가 부족하면 1/n 으로, 충족되었으면 그냥 n으로 표기
		--[[		if nowCount == tonumber(row:GetItem("NeedCount_step3")) then
				return nowCount
				else]]
					return nowCount.."/"..data.NeedCount_step[3]
				--end
			end
			
			-- 활성화 단계 가져오기
			---@type table
			local step = {}
			
			for i=1, 5 do
				if data.NeedCount_step[i] ~= "-" then
					table.insert(step, tonumber(data.NeedCount_step[i]))
				end
			end
			
			-- 지금 숫자에 따라서 텍스트 바꿔주기
			local max = 0
			for i = 1, #step do
				if #step == i then
					max = step[i]
					break end
				if step[i] > nowCount then
					max = step[i]
					break
				elseif step[i] <= nowCount then
					max = step[i+1]
				end
			end
			
			return nowCount.."/"..max
		end
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스 호버 시 시너지 이름 툴팁 표시
		if self.synergyID == "" or self.synergyID == "NIL" then return end
		
		self.tooltip_SynergyInfo.Text = _LocalizationService:GetText(self.synergyID.."_Name")
		
		-- 위치 조정, 활성화
		self.tooltip_SynergyInfo.Entity.UITransformComponent.WorldPosition.x = self.Entity.UITransformComponent.WorldPosition.x
		self.tooltip_SynergyInfo.Entity.UITransformComponent.WorldPosition.y = self.Entity.UITransformComponent.WorldPosition.y + 40
		
		
		self.tooltip_SynergyInfo.Entity.Enable = true
		
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스 호버 해제 시 툴팁 숨김
		self.tooltip_SynergyInfo.Entity.Enable = false
	end

end