@Component
script UI_dictionary_RuneCard extends Component

	property SpriteGUIRendererComponent sp_image = nil

	property UI_RuneCardDictionaryInfo runeCardInfo = "e4e56ef5-c588-44cb-843a-a52a13e9c1dd"

	property string runeCardID = ""

	property Entity faveMark = nil

	@ExecSpace("ClientOnly")
	method void Initialize()
		-- 룬카드 버튼 UI 컴포넌트 초기화
		self.sp_image = self.Entity:GetChildByName("sp_image").SpriteGUIRendererComponent
		
		self.runeCardID = ""
		
		self.faveMark = self.Entity:GetChildByName("sp_FavoriteMark")
	end

	@ExecSpace("ClientOnly")
	method void UpdateCard(string id)
		-- 룬카드 이미지 및 배경색 업데이트, 즐겨찾기 상태 반영
		self:Initialize()
		self.runeCardID = id
		------------------------------------------------------------------------------
		-- 비어 있는 경우 = 빈 칸으로 표현
		if isvalid(id) == false or id == "" or id == "NIL" then
			self.Entity.SpriteGUIRendererComponent.Color = Color.FromHexCode("#324660")
			self.sp_image.ImageRUID = ""
			self.sp_image.Entity.Enable = false
			
			self.faveMark.Enable = false
			return
		end
		------------------------------------------------------------------------------
		self.sp_image.Entity.Enable = true
		
		
		local timer = 0
		local function getFnc()
			---@type RuneCardDictionaryData
			local runeData = _DictionaryDataManager.RuneDataList[id]
			if isvalid(runeData) then
				-- 등급에 따라 배경 색상 조정 (추후 ruid 변경으로 조절)
				self.Entity.SpriteGUIRendererComponent.Color = _UI_Color.RuneGrade[runeData.Grade] 
				------------------------------------------------------------------------------
				-- NPC 이미지 변경
				self.sp_image.ImageRUID = runeData.IconRUID
				self.sp_image.LocalScale = runeData.Icon_LocalScale
				self.sp_image.LocalPosition = runeData.Icon_LocalPos
				------------------------------------------------------------------------------
				-- 즐겨찾기 표시 여부
				self.faveMark.Enable = _DictionaryFavoriteListManager:IsSettedFave_Rune(id)
				_TimerService:ClearTimer(timer)
			else
				_TimerService:ClearTimer(timer)
			end
		end
		
		timer = _TimerService:SetTimerRepeat(getFnc, 0.5, 0)
		------------------------------------------------------------------------------
			
	end

	@EventSender("Logic", "DictionaryManager")
	handler HandleDictionaryFavoriteEvent(DictionaryFavoriteEvent event)
		-- 룬카드 즐겨찾기 변경 이벤트 수신 시 마크 상태 갱신
		-- Parameters
		local settedFaveRune = event.settedFaveRune
		---------------------------------------------------------
		self.faveMark = self.Entity:GetChildByName("sp_FavoriteMark")
		self.faveMark.Enable = _DictionaryFavoriteListManager:IsSettedFave_Rune(self.runeCardID)
		---------------------------------------------------------
	end

	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 마우스 클릭 시 룬카드 즐겨찾기 토글 처리
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------
		
		if TouchId == -1 then
			if self.runeCardID == nil or self.runeCardID == "" then return end
			_DictionaryManager:RuneCard_Favorite(self.runeCardID)
			return
		end
		
		if TouchId == -2 then
			if self.runeCardID == nil or self.runeCardID == "" then return end
			_DictionaryManager:RuneCard_Favorite(self.runeCardID)
		end
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스 호버 시 룬카드 정보 패널 표시 및 아웃라인 활성화
		if self.runeCardID == nil or self.runeCardID == "" then return end
		
		self.runeCardInfo:UpdateInfo(self.runeCardID)
		self.runeCardInfo.Entity.Enable = true
		self.Entity.SpriteGUIRendererComponent.Outline = true
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스 호버 해제 시 정보 패널 숨김 및 아웃라인 비활성화
		self.runeCardInfo.Entity.Enable = false
		self.Entity.SpriteGUIRendererComponent.Outline = false
	end

end