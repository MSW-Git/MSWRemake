@Component
script UI_dictionary_SynergyBT extends Component

	property string synergyID = ""

	property Entity charIconList = nil

	property SpriteGUIRendererComponent sp_SynergyIcon = nil

	property TextComponent t_synergyName = nil

	property UI_SynergyDictionaryInfo synergyInfo = "8d4f4962-1dde-4500-a966-31ae53746f76"

	@ExecSpace("ClientOnly")
	method void SynergyButtonInitialize(string id)
		-- 시너지 버튼 초기화 및 아이콘, 캐릭터 목록 설정
		self.synergyID = id
		
		self.charIconList = self.Entity:GetChildByName("bg_charList")
		local iconBg = self.Entity:GetChildByName("bg_SynergyIcon")
		self.sp_SynergyIcon = iconBg:GetChildByName("sp_synergyIcon").SpriteGUIRendererComponent
		self.t_synergyName = self.Entity:GetChildByName("t_SynergyName").TextComponent
		
		
		--local charlist = _DictionaryDataManager:GetList_Synergy(id)
		local data = _DictionaryDataManager.SynergyDataList[id]
		local charList_synergy = data.CharIDs
		---@type UserDataRow
		--local synergyRow = _DictionaryDataManager:GetSynergy_Row(id)
		
		---@type table<Entity>
		local iconList = self.charIconList.Children
		
		-- 캐릭터 리스트 갱신
		for i=1, #iconList, 1 do
			iconList[i].Enable = false
		end
		
		------------------------------------------------
		-- 지금은 컬러 조정 , 나중에 RUID로 변경
			-- 코스트 컬러
			local gradeColorTable = _DataService:GetTable("GradeColor")
			local gradeColor = {
				"252525", --임시로 0코스트 색상 넣어둠
				gradeColorTable:GetRow(1):GetItem("Default"),
				gradeColorTable:GetRow(2):GetItem("Default"),
				gradeColorTable:GetRow(3):GetItem("Default"),
				gradeColorTable:GetRow(4):GetItem("Default"),
				gradeColorTable:GetRow(5):GetItem("Default"),
			}
		------------------------------------------------
		
		for i=1, #charList_synergy, 1 do
		--[[	---@type UserDataRow
			local charRow = _DictionaryDataManager:GetCharacterInfo_Row(charList_synergy[i])]]
			local charData = _DictionaryDataManager.CharDataList(charList_synergy[i])
			local ruid = charData.IdleRUID
			local resourceInfo = _LoadResourcesInfo:GetUILocalPositionScale(ruid)
		
			iconList[i].Children[1].SpriteGUIRendererComponent.ImageRUID = ruid
			iconList[i].Children[1].SpriteGUIRendererComponent.LocalScale = resourceInfo["scale"]
			iconList[i].Children[1].SpriteGUIRendererComponent.LocalPosition = resourceInfo["pos"]
			iconList[i].Children[1].SpriteGUIRendererComponent.PlayRate = 0
			
			iconList[i].Enable = true
			
			iconList[i].SpriteGUIRendererComponent.Color = Color.FromHexCode(gradeColor[tonumber(charData.Cost)+1])
		end
		
		-- 시너지 아이콘 갱신
		self.sp_SynergyIcon.ImageRUID = data.IconRUID
		
		
		-- 시너지 명 갱신
		self.t_synergyName.Text = _LocalizationService:GetText(id.."_Name")
	end

	@ExecSpace("ClientOnly")
	method void FavoriteSynergy(string synergyID)
		-- 즐겨찾기 시너지 아이콘만 간단히 업데이트 (임시 구현)
		-- 임시로 써둔 코드!!
		
		-- 위 함수와 다르게 아이콘과 synergyID만 변경
		if synergyID == nil then
			-- 공란으로..
			self.synergyID = nil
			self.sp_SynergyIcon.ImageRUID = "324e791b9820ed84c8f4956978eae346"
			--self.faveMark.Enable = false
			return
		end
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 시너지 버튼 클릭 시 상세 정보 패널 표시
		self.synergyInfo:UpdateInfo(self.synergyID)
		--_DictionaryManager:SynergyDictionaryOpen(true)
		self.synergyInfo.Entity.Enable = true
	end

end