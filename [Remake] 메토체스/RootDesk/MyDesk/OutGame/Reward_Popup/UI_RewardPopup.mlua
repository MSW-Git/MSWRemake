@Component
script UI_RewardPopup extends Component

	property Entity Reward_original = "41fa3250-7658-4350-b447-f41b67c72619"

	property Entity RewardArea = "d5167868-5dd3-4cae-bbbd-33e80520a3ec"

	@ExecSpace("Client")
	method void Open_N_UpdateRewardList(SyncTable<string, integer> rewards)
		-----------------------------------------------------
		--func: 리워드 팝업을 업데이트 합니다.
		-----------------------------------------------------
		
		---@type integer
		local count = 2
		
		for rID, amount in pairs(rewards) do
			log(rID, amount)
			
			-- 이미 생성된 엔터티가 있을 때, 갱신
			if _EntityService:IsValid(self.RewardArea.Children[count]) then
				self.RewardArea.Children[count].UI_Reward_inPopup:UpdateReward(rID, amount)
				self.RewardArea.Children[count].Enable = true
			-- 없을 때, 생성
			else
				local newReplica = _SpawnService:SpawnByEntity(self.Reward_original, "Reward_Replica", Vector3(0,0,0), self.RewardArea)
				newReplica.UI_Reward_inPopup:UpdateReward(rID, amount)
				newReplica.Enable = true
			end
			
			
			count += 1
		end
		
		self.Entity.Enable = true
	end

	@EventSender("Entity", "8df457f8-c9a1-44d6-aa16-6725b0f5615c")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 보상 팝업 닫기 버튼 클릭 시 팝업 숨김 및 보상 아이템들 비활성화
		self.Entity.Enable = false
		
		for i=1, self.RewardArea.Children.Count do
			self.RewardArea.Children[i].Enable = false
		end
	end

end