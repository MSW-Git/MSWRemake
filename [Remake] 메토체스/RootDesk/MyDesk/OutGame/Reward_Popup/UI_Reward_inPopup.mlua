@Component
script UI_Reward_inPopup extends Component

	property string rewardID = ""

	property integer rewardAmount = 0

	property Entity ToolTip = "ea610db1-6f20-415b-a637-edea7d1f274e"

	@ExecSpace("ClientOnly")
	method void UpdateReward(string rID, integer amount)
		-- 보상 아이템의 ID와 수량을 설정하고 UI 업데이트
		self.rewardID = rID
		self.rewardAmount = amount
		
		-- 임시 배경
		self.Entity.SpriteGUIRendererComponent.ImageRUID = "775b9cb3b4f6419c823bd4d17e5625b2"
		
		-- 이미지
		self.Entity:GetChildByName("item_Reward").SpriteGUIRendererComponent.ImageRUID = _UI_AchievementService:ReturnAchieveRewardRUID(rID)
		self.Entity:GetChildByName("item_Reward").SpriteGUIRendererComponent.PlayRate = 0
		
		-- 갯수
		self.Entity:GetChildByName("t_amount").TextComponent.Text = tostring(self.rewardAmount)
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		---------------------------------------------------------------
		-- Func: tooltip 내용을 출력하는 함수입니다. 
		---------------------------------------------------------------
		
		-- 보상이 없는 버튼을 클릭했다면 툴팁을 출력하지 않습니다. 
		if _UtilLogic:IsNilorEmptyString(self.rewardID) then 
			return 
		end
		
		-- Parameters
		
		local keyHead = string.sub(self.rewardID,1,2)
		local charKeyHead = string.sub(self.rewardID,1,1)
		local rewardName 
		local rewardDesc
		---------------------------------------------------------------
		--툴팁 이름 및 설명 
		
		if keyHead == "CO" then --코치
		
			local coachInfo = _CoachService:GetCoachInfo(self.rewardID)
			rewardName = coachInfo.Name
			
			local nameKey = coachInfo.Name
			local coachEffect = coachInfo.Desc
				
			local achieveCoachDesc = _LocalizationService:GetText("Achievement_Coach_Desc")
		
			rewardDesc = string.format("%s%s",achieveCoachDesc,coachEffect)
			
		elseif charKeyHead == "C" then --변신
			local characterName = _LocalizationService:GetText(self.rewardID.."_Name")
			rewardName = characterName.." ".._LocalizationService:GetText("CharacterTransform")
			rewardDesc = _LocalizationService:GetTextFormat("Transform_Character_Desc",characterName)
			
		elseif keyHead =="NT" then --네임태그
		
			--로컬key 
			
			local nameKey = _DataService:GetTable("Title_NameTagDataset"):FindRow("NameTagID",self.rewardID):GetItem("Name")
			rewardName = _LocalizationService:GetText(nameKey)
			rewardDesc = _LocalizationService:GetText("NT_ToolTipDesc")
			
		elseif keyHead =="KW" then --키워드 
				
			local keywordKeyHead = string.sub(self.rewardID,1,3)
			
			--로컬key
			local nameKey = "툴팁 이름이 없습니다."
			
			if keywordKeyHead == "KWF" then -- 칭호 Front
		
				nameKey = _DataService:GetTable("Title_KeyWordFrontDataset"):FindRow("KeyWordID",self.rewardID):GetItem("Name")
		
			elseif keywordKeyHead == "KWB" then -- 칭호 Back
				
				nameKey = _DataService:GetTable("Title_KeyWordBackDataset"):FindRow("KeyWordID",self.rewardID):GetItem("Name")
		
			end
		
			rewardName = _LocalizationService:GetText(nameKey)
			rewardDesc = _LocalizationService:GetText("KW_ToolTipDesc")	
			
		elseif keyHead == "Sy" then -- 시럽
			rewardName = _LocalizationService:GetText(self.rewardID)
			rewardDesc = _LocalizationService:GetText(self.rewardID.."_Tooltip")
		else
			
			rewardName = "툴팁 이름이 없습니다."
			rewardDesc = "툴팁 설명이 없습니다"
		
		end
		
		
		-- 툴팁 팝업 위치 설정 
		local touchPos = self.Entity.UITransformComponent.WorldPosition
		
		self.ToolTip.UITransformComponent.WorldPosition = touchPos + Vector3(150,15,0)
		
		-- 툴팁 내용 설정 
		self.ToolTip:GetChildByName("UIText").TextComponent.Text = rewardName.."\n\n"..rewardDesc
		
		-- 툴팁 엔티티 켜기
		self.ToolTip.Enable = true 
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 툴팁 엔티티 켜기
		self.ToolTip.Enable = false
	end

end