@Logic
script CooldownType extends Logic

	property SyncTable<integer, number> CooldownDataTable

	property boolean IsInitialized = false

	property integer Type_CharacterShopLock = 1

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 쿨다운 데이터 테이블을 초기화
		self.IsInitialized = true
		
		self.CooldownDataTable[self.Type_CharacterShopLock] = 0.3
	end

end