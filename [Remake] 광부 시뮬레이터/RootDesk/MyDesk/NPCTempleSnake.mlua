@Component
script NPCTempleSnake extends Component

	@ExecSpace("Server")
	method void CheckRelicCollectionAcheivement(Entity player)
		-- 플레이어의 유물 도감 100% 달성 여부를 확인하고 신전 입장 권한을 부여
		if player.PlayerData.TownProgress[10] == true then
			return
		end
		
		-- 유물 도감 100% 보유 여부를 검사합니다.
		local relicSetTable = _DataService:GetTable("RelicSet")
		local isFullRegisted = true
		local registInfo = player.PlayerRelic.RegistrationInfo
		for i=1, relicSetTable:GetRowCount() do
		
			for j=1, 4 do
				local needIdx = relicSetTable:GetCell(i, 2*j)
				
				-- 등록 가능한 슬롯이라면 검사
				if needIdx ~= nil and needIdx ~= "" then
					-- 등록되지 않았다면
					if registInfo[(i-1)*4+j] == false then
						isFullRegisted = false 
						break
					end
				else
					break
				end
			end
			
			if isFullRegisted == false then
				break
			end
		end
		
		-- 모두 등록된 상태라면
		if isFullRegisted == true then
			player.PlayerData:ChangeTownProgress(10)
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_CanEnterTemple", player.OwnerId)
		else 
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_CannotEnterTemple", player.OwnerId)
			
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 신전 뱀 NPC 트리거에 들어왔을 때 유물 도감 달성도를 확인
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.PlayerData ~= nil then
			self:CheckRelicCollectionAcheivement(TriggerBodyEntity)
		end
	end

end