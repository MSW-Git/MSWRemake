@Component
script TrapGasLava extends Component

	property number time = 0

	property number Cooldown = 0

	property boolean canAttack = false

	property number Damage = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 2초간 가스 분출 후 2초 휴식을 반복하는 사이클 처리
		
		self.time = self.time + delta
		
		if self.time >= 0 and self.time <2 then
			self.canAttack = true
			self.Entity:GetChildByName("GasEffect"):SetEnable(true)
		elseif self.time >= 2 and self.time < 4 then
			self.canAttack = false
			self.Entity:GetChildByName("GasEffect"):SetEnable(false)
		elseif self.time >= 4 then
			self.time = 0
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 가스 용암에 닿았을 때 공격 가능 상태이면 대미지와 밀백 효과
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if self.canAttack == true then
			if TriggerBodyEntity == _UserService.LocalPlayer then
				TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(5, 2) * _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX)
				TriggerBodyEntity.PlayerIngameData:Hit(self.Damage)
				_SoundService:PlaySound("72f22238215748268ed891b4b30a2ce3", 1)
			end
		else 
			return
		end
	end

end