@Component
script TrapLava extends Component

	property SyncTable<number> timerTable

	property boolean IsProjectileSpawner = false

	@HideFromInspector
	property number SpawnTime = 0

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 용암 발사체인 경우 3초마다 용암 탄을 발사하도록 관리
		if self.IsProjectileSpawner then
			self. SpawnTime = self. SpawnTime + delta
			
			if self.SpawnTime > 3 then
				self.SpawnTime = 0
				
				self.Entity:GetChildByName("LavaProjectile").TrapLavaProjectile:MoveUp()
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 용암에 들어갔을 때 화상 스택을 초기에 적용하고 지속 데미지 타이머 시작
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			_UserService.LocalPlayer.PlayerStateAtStage:GetBurnStack(1, TriggerBodyEntity)
			-- _SoundService:PlaySound("2f2128d0ed70486fbf91d86ffb89a7b5", 0.5)
			
			local getBurnStack = function()
				TriggerBodyEntity.PlayerStateAtStage:GetBurnStack(1, TriggerBodyEntity)
			end
			
			for i=1, 6 do
				local timer = _TimerService:SetTimerOnce(getBurnStack, i)
				table.insert(self.timerTable, timer)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 용암에서 나갔을 때 실행 중인 모든 지속 데미지 타이머를 정지
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			for i=1, #self.timerTable do
				_TimerService:ClearTimer(self.timerTable[i])
			end
		end
	end

end