@Component
script TrapDirShooter extends Component

	@Sync
	@HideFromInspector
	@Description("OnUpdate에서 관리하는 변수로 건드리지 말 것.")
	property number Time = 0

	@Sync
	@HideFromInspector
	property number Angle = 0

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 일정 시간마다 4방향으로 회전하며 번개 투사체를 발사하는 함정 처리
		self.Time = self.Time + delta
		
		if self.Time > 5 then -- 발사 쿨타임 줄이기
			self.Time = 0
			
			-- 발사 이펙트
			local effectPos = Vector3(0, -0.25, 0)
			_EffectService:PlayEffectAttached("042c32ff1f934c5281b7d85a2d9d65be", self.Entity, effectPos, 0, Vector3.one)
			
			
			-- 수직으로 4개의 투사체 발사
			for i=1, 4 do
				local Projectile = _SpawnService:SpawnByModelId(
					"model://7aab6c33-203e-4d61-aa0c-cab8527eaf09",
					"ThunderProjectile",
					self.Entity.TransformComponent.WorldPosition,
					self.Entity.Parent)
				
				local angle = self.Angle + (90*i)
				if angle >= 360 then
					angle = angle - 360
				end
				Projectile.TrapProjectile:SetParameter(angle, 3, 2)
			end
			
			-- 각도 조절
			self.Angle = self.Angle + 45
			if self.Angle >=360 then
				self.Angle = self.Angle - 360
			end
			
		end
	end

end