@Component
script TrapChaseMobController extends InteractionComponent

	property boolean Signal = false

	property Entity Target = "c6a68f76-4b4b-498e-a8c4-39075c9b4deb"

	property Entity TargetUI = "b153252e-315c-4011-8019-347c9f9d896c"

	property Entity SignalButton = "9d5968f4-f091-4283-b814-20d224a92eac"

	@Sync
	property boolean isUsed = false

	property number Damage = 0

	property Entity TargetPlayer = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴트롤러 초기화 및 신호 버튼 UI 설정
		self:SetUsed(false)
		self.Signal = true
		self.SignalButton.SpriteGUIRendererComponent.Color = Color.blue
		self.SignalButton.TextComponent.Text = "베타 신호"
	end

	@ExecSpace("Server")
	method void SetUsed(boolean OnOff)
		-- 컴트롤러의 사용 상태를 서버에서 동기화
		self.isUsed = OnOff
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "9d5968f4-f091-4283-b814-20d224a92eac")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 신호 버튼 클릭으로 알파/베타 신호 전환
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.Signal == true then -- true는 파랑, red는 빨강
			self.Signal = false
			Entity.SpriteGUIRendererComponent.Color = Color.red
			Entity.TextComponent.Text = "알파 신호"
		else
			self.Signal = true
			Entity.SpriteGUIRendererComponent.Color = Color.blue
			Entity.TextComponent.Text = "베타 신호"
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "57a3195c-df7b-41f9-99e3-2292c7736b08")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 전송 버튼 클릭으로 로봇에게 신호 전송 및 UI 닫기
		if self.Target ~= nil then
			self.Target.TrapChaseMonster:Destroy(self.Signal, self.TargetPlayer)
			self.TargetUI:SetEnable(false)
			_UserService.LocalPlayer.MovementComponent.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 플레이어가 컴트롤러와 상호작용하여 제어 UI 열기
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		if self.isUsed == false then
			if self.TargetUI and self.TargetUI.Enable == false then
				self.TargetPlayer = InteractionEntity
				self.TargetUI:SetEnable(true)
				_UserService.LocalPlayer.MovementComponent.Enable = false
			end
		elseif self.isUsed == true then
			_UIToast:ShowMessage("재가동 대기 중입니다.")
		end
	end

end