@Component
script TrapIceFallSensor extends Component

	@Sync
	property number CoolTime = 5

	@Sync
	property number Timer = 5

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 타이머를 감소시키고 0에 도달하면 고드름 경고 모델을 생성
		self.Timer = self.Timer - delta
		if self.Timer <= 0 then
			self:SpawnCautionModel()
			self.Timer = self.CoolTime
		end
	end

	@ExecSpace("Client")
	method void SpawnCautionModel()
		-- 고드름 떨어지는 위역에 경고 모델을 생성하고 위치적 사운드 재생
		local Ice = _SpawnService:SpawnByModelId("model://355ef57c-69c6-475e-9f4e-71b2fd1333bd", "Ice", 
		Vector3(0, -5, 0), 
		self.Entity)
		
		local pos = Vector3(self.Entity.TransformComponent.Position.x, self.Entity.TransformComponent.Position.y, self.Entity.TransformComponent.Position.z)
		_SoundService:PlaySoundAtPos("0b2b1405d618430a9d43d2ac507db3d1", pos, _UserService.LocalPlayer, 1)																				
	end

end