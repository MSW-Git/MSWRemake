@Component
script TrapFireParabola extends Component

	property number damage = 0

	property string hitSoundId = ""

	property string hitEffectId = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 필터 효과와 사운드 ID를 초기화
		self.hitEffectId = "e876a618f67943f9a1fc13598eb701ab"
		self.hitSoundId = "2f2128d0ed70486fbf91d86ffb89a7b5"
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 화염 투사체에 닿았을 때 대미지와 효과 적용 후 투사체 파괴
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if TriggerBodyEntity == _UserService.LocalPlayer then
			_UserService.LocalPlayer.PlayerIngameData:Hit(self.damage)
				_SoundService:PlaySound(self.hitSoundId, 1)
			
			
			-- hit effect
			local hitPos = Vector3(TriggerBodyEntity.TransformComponent.WorldPosition.x,
				TriggerBodyEntity.TransformComponent.WorldPosition.y + 0.15,
				TriggerBodyEntity.TransformComponent.WorldPosition.z)
			_EffectService:PlayEffect(self.hitEffectId, self.Entity, hitPos, 0, Vector3.one)
			
			local callback = function()
				self.Entity:Destroy()
			end
			_TimerService:SetTimerOnce(callback, 0.5)
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleFootholdCollisionEvent(FootholdCollisionEvent event)
		-- 투사체가 바닥이나 다른 오브젝트에 쉦았을 때 즉시 파괴
		-- Parameters
		local FootholdNormal = event.FootholdNormal
		local ImpactDir = event.ImpactDir
		local ImpactForce = event.ImpactForce
		local ReflectDir = event.ReflectDir
		local Rigidbody = event.Rigidbody
		--------------------------------------------------------
		self.Entity:Destroy()
	end

end