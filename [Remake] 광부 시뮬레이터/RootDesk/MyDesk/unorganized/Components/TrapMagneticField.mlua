@Component
script TrapMagneticField extends Component

	property number damage = 0

	property string hitEffectId = ""

	property string hitSoundId = ""

	property number hitForce = 0

	property number hitCooldown = 0

	property number attackCooldown = 0

	property string AnimationClip = ""

	property boolean isTriggerd = false

	property boolean attackLock = false

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 자기장 트랩의 쿨다운 상태를 관리하고 범위/경보/공격 UI를 전환
		self.hitCooldown = self.hitCooldown - delta
		
		if self.hitCooldown > 6 then -- 범위 표시
			self.Entity:GetChildByName("Range"):SetEnable(true)
			self.Entity:GetChildByName("Signal"):SetEnable(false)
			self.Entity:GetChildByName("Attack"):SetEnable(false)
		elseif self.hitCooldown > 1.5 then -- 공격 5초전 사이렌 경보
			self.Entity:GetChildByName("Range"):SetEnable(false)
			self.Entity:GetChildByName("Signal"):SetEnable(true)
		elseif self.hitCooldown <= 0 then
			self.Entity:GetChildByName("Attack"):SetEnable(true)
			self.attackCooldown = self.attackCooldown - delta
			if self.attackLock == false then self:Attack() end
			if self.attackCooldown <= 0 then
				self.attackCooldown = 2
				self.hitCooldown = 15
				self.attackLock = false
			end
		end
	end

	@ExecSpace("Client")
	method void Attack()
		-- 자기장 내에 플레이어가 있을 때 전기 데미지와 넛백을 적용
		if self.isTriggerd == true then
			self.attackLock = true 
			wait(1.5)
			_UserService.LocalPlayer.PlayerStateAtStage:ElectricDamage(self.damage, _UserService.LocalPlayer)
			_UserService.LocalPlayer.RigidbodyComponent:AddForce(Vector2(self.hitForce*2, 0))
		else
			return
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 플레이어가 자기장 내에 머물러 있는 동안 트리거 상태 유지
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			self.isTriggerd = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 자기장 영역에서 나갔을 때 트리거 상태를 해제
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			self.isTriggerd = false
		end
	end

end