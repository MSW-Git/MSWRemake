@Component
script TrapMagnetFieldMaker extends Component

	property number damage = 0

	property string hitEffectId = ""

	property string hitSoundId = ""

	property number hitForce = 0

	@Sync
	@HideFromInspector
	property number ShockCoolDown = 0

	@Sync
	property number ShockCoolTime = 0

	@HideFromInspector
	property boolean isTriggerd = false

	@ExecSpace("Client")
	method void Attack()
		-- 자기장 공격을 실행하며 이팩트와 사운드 재생, 플레이어에게 데미지와 넷백 적용
		_EffectService:PlayEffect("003698afe94c48c0af40a16c126be607", self.Entity, self.Entity.TransformComponent.WorldPosition,
				0, 0.5*Vector3.one)
		
		if self.isTriggerd == true then
			_UserService.LocalPlayer.PlayerStateAtStage:ElectricDamage(self.damage, _UserService.LocalPlayer)
			_SoundService:PlaySound(self.hitSoundId, 1)
			_EffectService:PlayEffect(self.hitEffectId, self.Entity, _UserService.LocalPlayer.TransformComponent.WorldPosition,
				0, Vector3.one)
			_UserService.LocalPlayer.RigidbodyComponent:AddForce(Vector2(self.hitForce, 1.5))
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 쿨다운을 초기화하고 공격 시작
		self.ShockCoolDown = self.ShockCoolTime
		
		self:Start()
	end

	@ExecSpace("Server")
	method void Start()
		-- 쿨다운 타이머를 시작하고 공격 예고 및 실행을 반복 수행
		local coolDown = function()
			self.ShockCoolDown = self.ShockCoolDown - 1
			
			
			if self.ShockCoolDown <= 1 then
				self.Entity:GetChildByName("Range").Enable = true
			end
			
			if self.ShockCoolDown <= 0 then
				self.Entity:GetChildByName("Range").Enable = false
				self:Attack()
				self.ShockCoolDown = self.ShockCoolTime
			end
			
			self:Start()
		end
		
		_TimerService:SetTimerOnce(coolDown, 1)
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- 쿨다운 시간이 동기화될 때 카운트다운 텍스트 UI 업데이트
		if name == "ShockCoolDown" then
			self.Entity:GetChildByName("CountDown").TextComponent.Text = string.format("%d", self.ShockCoolDown)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 충돌 영역에서 나갔을 때 트리거 상태를 해제
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			self.isTriggerd = false
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 충돌 영역에 들어왔을 때 트리거 상태를 활성화
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			self.isTriggerd = true
		end
	end

end