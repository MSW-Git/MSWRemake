@Component
script TrapRotateBar extends Component

	property number RotatingSpeed = 60

	property number damage = 0

	property string hitEffectId = ""

	property string hitSoundId = ""

	property boolean isCooltime = true

	property number Cooltime = 10

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 회전 막대의 각도를 일정 속도로 왕복 회전시키는 업데이트 로직
		if self.Entity.TransformComponent.ZRotation < 180 then
			self.Entity.TransformComponent.ZRotation = 
			self.Entity.TransformComponent.ZRotation + delta * self.RotatingSpeed
			if self.Entity.TransformComponent.ZRotation <= 0 then
				self.RotatingSpeed = self.RotatingSpeed * -1
			end
		elseif self.Entity.TransformComponent.ZRotation >= 180 then
			self.Entity.TransformComponent.ZRotation = 179
			self.RotatingSpeed = self.RotatingSpeed * -1
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어에게 데미지와 화상 스택을 적용하고 사다리/로프 상태를 중단
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if self.isCooltime == true then
			if TriggerBodyEntity.TagComponent and
				TriggerBodyEntity.TagComponent.Tags[1] == "player" then	
				_SoundService:PlaySound(self.hitSoundId, 1)
				TriggerBodyEntity.PlayerIngameData:Hit(self.damage)
				if TriggerBodyEntity.PlayerStateAtStage.IgniteStack == 0 then
					TriggerBodyEntity.PlayerStateAtStage.IgniteStack = 1
				else
					TriggerBodyEntity.PlayerStateAtStage.IgniteStack += 1
				end
				self.isCooltime = false
				local callback = function()
					self.isCooltime = true
				end
				_TimerService:SetTimerOnce(callback, self.Cooltime)	
				if TriggerBodyEntity.StateComponent.CurrentStateName == "LADDER" 
					or  TriggerBodyEntity.StateComponent.CurrentStateName == "ROPE" then
						TriggerBodyEntity.StateComponent:ChangeState("IDLE")
				end
			end
		end
	end

end