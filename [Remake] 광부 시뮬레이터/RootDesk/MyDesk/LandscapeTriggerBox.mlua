@Component
script LandscapeTriggerBox extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 지형 트리거에 들어왔을 때 잠수 상태를 해제하고 중앙 공간 상태로 설정
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:Diving(false)
			_UserService.LocalPlayer.PlayerStateAtStage.playerInCenterSpaceInWater = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 지형 트리거를 벗어났을 때 잠수 상태로 설정하고 중앙 공간 상태를 해제
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:Diving(true)
			_UserService.LocalPlayer.PlayerStateAtStage.playerInCenterSpaceInWater = false
		end
		
	end

end