@Logic
script GemShopLogic extends Logic

	@ExecSpace("Server")
	method void BuyItem(number idx, Entity player)
		-- 젠 샵에서 아이템 구매 처리 (소모품, 추가 아이템, 특수 아이템)
		if idx > 0 then
			local consumableItemTable = _DataService:GetTable("ConsumableItems")
			local cost = tonumber(consumableItemTable:GetCell(idx, "Price"))
			local name = consumableItemTable:GetCell(idx, "Name")
			if player.PlayerStorage.currencyItems[2] < cost then
				log("가격 초과!")
				return
			end
			--
			player.PlayerStorage:UseCurrencyItems(2, cost)
			
			if idx < 3 then
				player.PlayerRelic:GetRelicBox(idx)
			else 
				player.PlayerStorage:AddConsumableItems(idx, 1)
			end
			
			_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_PurchasedItem", {name}, player.OwnerId)
		else 
			
			if idx == -1 then
				local cost = 3000
				if player.PlayerStorage.currencyItems[2] < cost then
					log("가격 초과!")
					return
				end
				
				player.PlayerStorage:UseCurrencyItems(2, cost)
				self:GetNewChair(player)
				_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_PurchasedItem", {"DailyReward_NewChair"}, player.OwnerId)
				
				
			elseif idx == -2 then
				local cost = 125
				if player.PlayerStorage.currencyItems[2] < cost then
					log("가격 초과!")
					return
				end
				
				player.PlayerStorage:UseCurrencyItems(2, cost)
				player.PlayerEmoticon.EmotToken = player.PlayerEmoticon.EmotToken + 1
				_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_PurchasedItem", {"CurrencyItemName_4"}, player.OwnerId)
				
			elseif idx == -3 then
				local cost = 1
				if player.PlayerData.PetEgg < cost then
					log("가격 초과!")
					return
				end
				
				player.PlayerData.PetEgg = player.PlayerData.PetEgg - 1
				player.PlayerStorage:AddCurrencyItems(7, 1500, true)
				_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_PurchasedItem", {"CurrencyItemName_7"}, player.OwnerId)
			end
			
		end
		
		-- 데이터 저장
		player.PlayerData:SaveData(1)
	end

	@ExecSpace("Server")
	method void GetNewChair(Entity player)
		-- 새로운 의자를 랜덤으로 획득하거나 모두 소유시 대신 유물 상자 지급
		local chairData = _DataService:GetTable("Chair")
		local targetTable = {}
		for i=1, chairData:GetRowCount() do
			if player.PlayerChair.haveItem[i] == false then
				table.insert(targetTable, i)
			end
		end
		
		if #targetTable == 0 then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_Daily_ReceivedHRRBoxBecauseHaveAllChairs", player.OwnerId)
			player.PlayerRelic:GetRelicBox(2)
			
		else 
			local randIdx = _UtilLogic:RandomIntegerRange(1, #targetTable)
			local targetIdx = targetTable[randIdx]
			
			local chairName = chairData:GetCell(targetIdx, 1)
			player.PlayerChair:AddItem(targetIdx)
			_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_Daily_ReceivedNewChair", {chairName}, player.OwnerId)
		end	
	end

end