@Component
script RelicGachaShopUI extends Component

	@ExecSpace("Client")
	method void RefreshUI()
		-- 렐릭 가차 상점 UI 정보 갱신 (가격 및 구매 버튼 상태)
		-- 구매 회수 표기
		local buyingCountText = _EntityService:GetEntityByPath("/ui/RelicGachaShopGroup/RelicGachaShop/Panel/BuyingCountPanel/CountText")
		buyingCountText.Enable = false
		
		--local buyingCount = _UserService.LocalPlayer.PlayerRelic.relicBoxBuyingCount + 1
		--[[
		local suffix = "th"
		if buyingCount == 1 then
			suffix = "st"
		elseif buyingCount == 2 then
			suffix = "nd"
		elseif buyingCount == 3 then
			suffix = "rd"
		end
		buyingCountText.TextComponent.Text = tostring(math.floor(buyingCount))..suffix
		]]--
		--buyingCountText.TextComponent.Text = _LocalizationService:GetTextFormat("RelicGachaShop_BuyingCountText", string.format("%d", buyingCount))
		
		-- 구매 금액 표기
		local priceText = _EntityService:GetEntityByPath("/ui/RelicGachaShopGroup/RelicGachaShop/Panel/Price")
		local price = 80000000000
		
		priceText.TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(price, _LocalizationService.CurrentLocaleId).." G"
		
		
		
		-- 구매 버튼 활성화
		local buyingButton = _EntityService:GetEntityByPath("/ui/RelicGachaShopGroup/RelicGachaShop/Panel/BuyButton")
		if _UserService.LocalPlayer.PlayerData.Money < price then
			buyingButton.ButtonComponent.Enable = false
		else
			buyingButton.ButtonComponent.Enable = true
		end
	end

	@EventSender("Entity", "a11e7e73-753f-4ef6-ac73-03734af97790")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 렐릭 가차 박스 구매 버튼 클릭 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerRelic:BuyRelicBox()
		
		Entity.ButtonComponent.Enable = false
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 눌렀을 때 렐릭 가차 상점 UI 닫기
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape then
			self.Entity.Enable = false
			_UserService.LocalPlayer.MovementComponent.Enable = true
		end
	end

end