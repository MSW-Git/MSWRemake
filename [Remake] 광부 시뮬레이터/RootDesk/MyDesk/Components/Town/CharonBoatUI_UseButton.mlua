@Component
script CharonBoatUI_UseButton extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 카론의 배 사용 버튼 클릭 처리 (환생 시간 단축 아이템)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		-- 버튼 일시 비활성화
		Entity.ButtonComponent.Enable = false
		local buttonEnable = function()
			Entity.ButtonComponent.Enable = true
		end
		_TimerService:SetTimerOnce(buttonEnable, 1.5)
		
		-- 팝업 닫기
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/Charon'sBoat").Enable = false
		_UserService.LocalPlayer.MovementComponent.Enable = true
		
		-- 적용!
		_UserService.LocalPlayer.PlayerData:UseCharonsBoat()
	end

end