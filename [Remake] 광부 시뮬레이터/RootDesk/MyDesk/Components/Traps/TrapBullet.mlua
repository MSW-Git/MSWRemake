@Component
script TrapBullet extends Component

	property number speed = 1

	property number damage = 0

	property string hitEffectId = ""

	property string hitSoundId = ""

	@HideFromInspector
	property number spawnedTime = 0

	property number surviveTime = 0

	property number poisonStack = 0

	property string type = ""

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 함정 총알이 일정 속도로 이동하고 생존 시간 초과시 제거
		self.Entity.TransformComponent:Translate(delta*self.speed, 0)
		
		self.spawnedTime = self.spawnedTime + delta
		
		if self.spawnedTime >= self.surviveTime then
			_EntityService:Destroy(self.Entity)
		end
	end

	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어와 충돌 시 눈덩이/일반 총알 타입에 따른 효과 처리
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "player" and self:IsClient() and TriggerBodyEntity == _UserService.LocalPlayer then
			
			-- hit sound
		
			if self.type == "snowBullet" then
				if TriggerBodyEntity.PlayerStateAtStage.onSnowMan then -- 만약 눈사람 상태라면 총알 무시
					return
				end
				TriggerBodyEntity.PlayerStateAtStage:GetSnownStack(1, TriggerBodyEntity)
			else
				TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(self.speed, 0)) -- 눈덩이가 아니여야만 날립니다.
			end
		
			_SoundService:PlaySound(self.hitSoundId, 1)
			
			
			-- hit effect
			local hitPos = Vector3(TriggerBodyEntity.TransformComponent.WorldPosition.x,
				TriggerBodyEntity.TransformComponent.WorldPosition.y + 0.15,
				TriggerBodyEntity.TransformComponent.WorldPosition.z)
			_EffectService:PlayEffect(self.hitEffectId, self.Entity, hitPos, 0, Vector3.one)
			
			-- give damage
			TriggerBodyEntity.PlayerIngameData:Hit(self.damage)
			-- TriggerBodyEntity.PlayerIngameData:Poisoned(self.poisonStack)
			
			-- change state 
			if TriggerBodyEntity.StateComponent.CurrentStateName == "LADDER" 
				or  TriggerBodyEntity.StateComponent.CurrentStateName == "ROPE" then
				TriggerBodyEntity.StateComponent:ChangeState("IDLE")
			end
			
			-- add force
			-- remove this entity
		
				_EntityService:Destroy(self.Entity)
		
		end
	end

end