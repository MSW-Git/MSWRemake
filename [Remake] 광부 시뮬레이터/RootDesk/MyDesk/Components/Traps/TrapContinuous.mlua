@Component
script TrapContinuous extends Component

	property number damage = 0

	property string hitEffectId = ""

	property string hitSoundId = ""

	property number hitForce = 0

	@HideFromInspector
	property boolean hitOn = false

	property number hitCooldown = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 지속 대미지 함정의 쿨다운 체크 및 타격 실행
		if self.hitOn == false then
			self.hitCooldown = 0
			return
		end
		self.hitCooldown = self.hitCooldown - delta
		
		if self.hitCooldown <= 0 then
			self.hitCooldown = 0.5
			self:Hit()
		end
	end

	@ExecSpace("Client")
	method void Hit()
		-- 플레이어에게 지속적으로 데미지, 사운드, 이팩트 적용
		log("hit")
		
		-- Parameters
		local TriggerBodyEntity = _UserService.LocalPlayer
		--------------------------------------------------------
		
		
		-- hit sound
		_SoundService:PlaySound(self.hitSoundId, 1)
		
		-- damage skin
		_DamageSkinService:Play(TriggerBodyEntity, "5ee3b84f8b494ef18ebb7572170dcff7", 0.01, 
			{self.damage}, DamageSkinTweenType.Default, false)
		
		-- hit effect
		local hitPos = Vector3(TriggerBodyEntity.TransformComponent.WorldPosition.x,
			TriggerBodyEntity.TransformComponent.WorldPosition.y + 0.15,
			TriggerBodyEntity.TransformComponent.WorldPosition.z)
		_EffectService:PlayEffect(self.hitEffectId, self.Entity, hitPos, 0, Vector3.one)
		
		-- give damage
		TriggerBodyEntity.PlayerIngameData:Hit(self.damage)
		
		-- change state 
		if TriggerBodyEntity.StateComponent.CurrentStateName == "LADDER" 
			or  TriggerBodyEntity.StateComponent.CurrentStateName == "ROPE" then
			TriggerBodyEntity.StateComponent:ChangeState("FALL")
		end
		
		-- cooldown
		self.hitCooldown = 0.5
	end

	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 지속 대미지 범위에 진입할 때 타격 시작
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "player" then
			self.hitOn = true
			log("hiton")
		end
	end

	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 지속 대미지 범위를 벗어날 때 타격 중지
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "player" then
			self.hitOn = false
			log("hitoff")
		end
	end

end