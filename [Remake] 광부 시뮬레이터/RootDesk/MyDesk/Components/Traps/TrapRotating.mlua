@Component
script TrapRotating extends Component

	property number RotatingSpeed = 0

	property boolean isClockwise = false

	property number time = 20

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 시계방향/반시계방향으로 회전하며 20초마다 방향을 바꿈
		if self.isClockwise == false then
			self.Entity.TransformComponent:Rotate(delta*self.RotatingSpeed)
		else
			self.Entity.TransformComponent:Rotate(delta*self.RotatingSpeed*-1)
		end
		
		self.time = self.time - delta
		if self.time <= 0 then
			self:ChangeClockwise()
			self.time = 20
		end
	end

	@ExecSpace("Client")
	method void ChangeClockwise()
		-- 시계방향과 반시계방향 회전을 전환
		if self.isClockwise == true then
			self.isClockwise = false
		else
			self.isClockwise = true
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 회전 방향 전환 타이머를 초기화
		self.time = 20
	end

end