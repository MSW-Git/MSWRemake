@Component
script DynamicFootholdManager extends InteractionComponent

	property Entity targetFootholdEntity = nil

	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 동적 발판과 상호작용 시 발판 활성화 및 사운드 재생
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		if self:IsServer() then
			return
		end
		--------------------------------------------------------
		local isEnabled = self.targetFootholdEntity.TweenLineComponent.Enable 
		
		if isEnabled == false then
			_UIToast:ShowMessage("발판을 작동시켰습니다.")
			self.targetFootholdEntity.TweenLineComponent.Enable = true
			_SoundService:PlaySound("0644f2c008cd428db1e42815b35bb206", 0.5)
		else 
			_UIToast:ShowMessage("이미 작동 중입니다.")
		end
	end

end