@Component
script TrapShowHitRange extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 트랩의 공격 범위를 시각적으로 표시하는 오브젝트들을 생성
		
		local startPos = self.Entity.TransformComponent.WorldPosition
		
		local destinationPos = self.Entity.TweenLineComponent.Positions[1]
		
		local showNum = 0
		local moveDir = "x"
		if math.abs(destinationPos.x) > 0 then
			showNum = math.floor(destinationPos.x)
			moveDir = "x"
		elseif math.abs(destinationPos.y) > 0 then
			showNum = math.floor(destinationPos.y)
			moveDir = "y"
		else 
			log("destPos is null")
			return
		end
		
		local updateidx = 1
		if showNum < 0 then
			updateidx = -1
		end 
		for i=0, showNum, updateidx do
			local spawnPos = Vector3(0, 0, 0)
			if moveDir == "y" then
				spawnPos = Vector3(startPos.x, startPos.y+i, startPos.z)
			else
				spawnPos = Vector3(startPos.x+i, startPos.y, startPos.z) 
			end
			
			local model = _SpawnService:SpawnByModelId(
				"model://38d2e83c-6bcf-4a8e-b56d-6fa4a8603d08",
				"bladeHitRange",
				spawnPos,
				self.Entity.Parent
				)
			
			model.SpriteRendererComponent.SortingLayer = "Default"
			model.SpriteRendererComponent.OrderInLayer = 2
		end
		
		self.Entity.SpriteRendererComponent.SortingLayer = "Default"
		self.Entity.SpriteRendererComponent.OrderInLayer = 3
	end

end