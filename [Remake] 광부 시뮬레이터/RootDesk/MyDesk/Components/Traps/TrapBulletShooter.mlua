@Component
script TrapBulletShooter extends Component

	@Sync
	@HideFromInspector
	property number ShootingCooldown = 0

	@Sync
	property number ShootingCooltime = 0

	property string bulletModelId = ""

	@Description("발사 각도를 오일러 표기법으로 나타냅니다. (1, 0)이 0도이고, 반시계 방향으로 각도를 올립니다.")
	property number ShootingAngle = 0

	property string ShootingEffectId = ""

	property number bulletDistance = 0

	property number bulletSpeed = 0

	@ExecSpace("ServerOnly")
	method void Fire()
		-- 투사체를 생성하고 설정된 각도로 발사하며 이펙트 재생
		-- 발사 이펙트
		_EffectService:PlayEffect(self.ShootingEffectId,
				self.Entity,
				self.Entity.TransformComponent.WorldPosition,
				0,
				Vector3.one)
		
		
		-- 엔티티 생성 및 각도 조절
		local Projectile = _SpawnService:SpawnByModelId(
			self.bulletModelId,
			"Projectile",
			self.Entity.TransformComponent.WorldPosition,
			self.Entity.Parent)
		
		local angle = self.ShootingAngle
		if angle >= 360 then
			angle = angle - 360
		end
		
		Projectile.TrapProjectile:SetParameter(angle, self.bulletDistance, self.bulletSpeed)
		Projectile.SpriteRendererComponent.SortingLayer = "Foreground"
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 함정 총알 발사기 초기화 시 쿨다운 설정 및 재귀 함수 시작
		self.ShootingCooldown = self.ShootingCooltime
		
		self:RecursiveFunc()
	end

	@ExecSpace("Server")
	method void RecursiveFunc()
		-- 일정 간격으로 쿨다운을 감소시키고 0이 되면 발사하는 재귀 함수
		local coolDown = function()
			self.ShootingCooldown = self.ShootingCooldown - 1
			
			if self.ShootingCooldown <= 0 then
				self:Fire()
				self.ShootingCooldown = self.ShootingCooltime
			end
			
			self:RecursiveFunc()
		end
		
		_TimerService:SetTimerOnce(coolDown, 1)
	end

end