@Component
script TrapGuardianBullet extends Component

	@Description("비행 속도 계수. 1이면 *1 만큼의 속도로, 3이면 *3만큼의 속도로 비행합니다.")
	@HideFromInspector
	property number speed = 0

	@Description("이 엔티티가 생성된 후로부터 lifetime 만큼의 시간이 지나면 자동으로 파괴됩니다.")
	@HideFromInspector
	property number lifeTime = 0

	@HideFromInspector
	@Description("이 엔티티가 생성된 후부터 흐른 시간")
	property number survivedTime = 0

	@HideFromInspector
	property number damage = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 플레이어를 추적하고 생존 시간 검사 후 제거
		self:ChasePlayer(delta)
		
		self.survivedTime = self.survivedTime + delta
		
		if self.survivedTime >= self.lifeTime then
			_EntityService:Destroy(self.Entity)
		end
	end

	@ExecSpace("Client")
	method void ChasePlayer(number delta)
		-- 플레이어 방향으로 이동하고 회전 업데이트
		local targetUser = _UserService.LocalPlayer
		local targetPos = Vector2(targetUser.TransformComponent.WorldPosition.x, targetUser.TransformComponent.WorldPosition.y)
		local startPos = Vector2(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y)
		
		local dist = targetPos - startPos
		local moveVector = Vector2.Normalize(dist)
		
		local angle = -Vector2.Angle(moveVector, Vector2(-1, 0))
		
		self.Entity.TransformComponent:Translate(moveVector.x * delta * self.speed, moveVector.y * delta * self.speed)
		self.Entity.TransformComponent.ZRotation = angle
		
	end

	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어와 충돌 시 감전 데미지, 이팩트, 사운드 처리 후 제거
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if self:IsServer() then
			return
		end
		
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			-- 데미지 처리
			TriggerBodyEntity.PlayerStateAtStage:ElectricDamage(self.damage, TriggerBodyEntity)
			-- 타격 이펙트
			_EffectService:PlayEffect("94d5246047cd41708117b398bbef14ec", self.Entity, self.Entity.TransformComponent.WorldPosition,
			0, Vector3.one, false)
			
			-- 타격 사운드
			_SoundService:PlaySound("5156e84e6ba74b76b1a87fdecde69df0", 0.75)
			
			-- 엔티티 제거
			_EntityService:Destroy(self.Entity) 
		end
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 범위에서 빠져나갔을 때 엔티티 제거
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.Name == "Range" and (self.Entity.Parent.Trap_ThunderPriest) then
			self.Entity:Destroy()
		end
	end

end