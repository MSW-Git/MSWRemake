@Component
script OutgameUIManager extends Component

	property boolean AutoEnableOnOutgame = false

	@EventSender("LocalPlayer")
	handler HandleLocalPlayerMapEnterEvent(LocalPlayerMapEnterEvent event)
		-- 맵 진입 시 아웃게임 UI 상태를 맵 타입에 따라 설정
		-- Parameters
		local EnteredMapType = event.EnteredMapType
		--------------------------------------------------------
		
		if EnteredMapType == "Mine" then
			self.Entity.Enable = false
		
		elseif EnteredMapType == "Town" and self.AutoEnableOnOutgame == true then
			self.Entity.Enable = true
			
			if (tostring(self.Entity.UITransformComponent.ActivePlatform) == "Mobile" and Environment:IsMobilePlatform() == false) or
				(tostring(self.Entity.UITransformComponent.ActivePlatform) == "PC" and Environment:IsPCPlatform() == false) then
				self.Entity.Enable = false
			else
				self.Entity.Enable = true
			end	
		end
		
		
		
	end

end