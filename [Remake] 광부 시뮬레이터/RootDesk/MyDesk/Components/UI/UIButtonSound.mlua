@Component
script UIButtonSound extends Component

	@Description("재생할 클릭 사운드 타입. (1=물풍선 소리) (2=얇은 클릭) (3=클릭)")
	@Delta(1)
	@MinValue(1)
	@MaxValue(3)
	property number SoundType = 1

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 사운드 타입에 따라 다른 소리를 재생
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.SoundType == 1 then
			_SoundService:PlaySound("7eda004ded944e459f1fbb16c7f0f3f4", 0.75)
		elseif self.SoundType == 2 then
			_SoundService:PlaySound("972843e759204d3e9ad84e7d3fa94f83", 0.75)
		elseif self.SoundType == 3 then
			_SoundService:PlaySound("de344b5f1bb444189d57dc52fca2bb14", 0.75)
		end
	end

end