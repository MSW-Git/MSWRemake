@Component
script WarningFlickeringUI extends Component

	@HideFromInspector
	property number time = 0

	property number minBrightness = 0

	property number maxBrightness = 0

	property number cycleTime = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 경고 UI의 사이클릭 깜뿡임 효과를 설정된 주기로 업데이트
		if self.Entity.Parent.Enable == true then
			self.time = self.time + delta
		end
		
		if self.time >= 0 and self.time < (self.cycleTime/2) then
			self.Entity.SpriteGUIRendererComponent.Color.a = (self.maxBrightness-self.minBrightness)/(self.cycleTime/2) * self.time + self.minBrightness
			
		elseif self.time <= self.cycleTime then
			self.Entity.SpriteGUIRendererComponent.Color.a = - (self.maxBrightness-self.minBrightness)/(self.cycleTime/2) * (self.time - self.cycleTime/2) + self.maxBrightness
		else 
			self.time = 0
		end
	end

end