@Component
script UIGuideAndButtonInteraction extends Component

	@ExecSpace("Client")
	method void PlayButtonClickDirection()
		-- 버튼 클릭 시 안내 텍스트와 버튼 아이콘에 애니메이션 효과 지연 재생
		local uitext = self.Entity.Parent:GetChildByName("UIText")
		local btn = self.Entity.Parent:GetChildByName("icon_key_E")
		
		local rate = 1.15
		local resizeEntity = function()
			rate = rate - 0.005
		
			uitext.UITransformComponent.Scale = Vector3(rate, rate, rate)
			btn.UITransformComponent.Scale = Vector3(rate, rate, rate)
		end 
		for i=1, 30 do
			_TimerService:SetTimerOnce(resizeEntity, i/120)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 인터랙션 버튼 클릭 이벤트 처리하여 다양한 오브젝트 상호작용 수행
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		-- click direction
		self:PlayButtonClickDirection()
		--------------------------------------------------------
		
		local ClickEvent = function()
			
			-- 마을 > 광산 포탈
			local portalToMine = self.Entity.Parent.Parent.PortalToMineInteraction
			if portalToMine ~= nil then
				portalToMine:EnterToMine()
			end
			
			-- 마을 > 마을 포탈
			local portalTownToTown = self.Entity.Parent.Parent.Portal_TownToTownInteraction
			if portalTownToTown ~= nil then
				portalTownToTown:OnInteractionEvent(_UserService.LocalPlayer)
			end
			
			-- 광산 > 광산 포탈
			local mineToMinePortal = self.Entity.Parent.Parent.PortalFromMineToMineInteraction
			if mineToMinePortal ~= nil then
				mineToMinePortal:OnInteractionEvent()
			end
			
			-- 광산 > 마을 포탈 (=귀환 로봇)
			local portalMineToTown = self.Entity.Parent.Parent.PortalToTownInteraction
			if portalMineToTown ~= nil then
				portalMineToTown:OnInteractionEvent()
			end
			
			-- NPC 이용
			local npcInteraction = self.Entity.Parent.Parent.NPCInteraction
			if npcInteraction ~= nil then
				npcInteraction:OnInteractionEvent()
			end
			
			-- 텔레포트 NPC 이용
			local portalNPCInteaction = self.Entity.Parent.Parent.TeleportNpcComponent
			if portalNPCInteaction ~= nil then
				portalNPCInteaction:OnInteractionEvent()
			end
			
			-- 광산3의 고드름 판매 NPC 이용
			local icicleNPCInteraction = self.Entity.Parent.Parent.IcicleSellNPCInteraction
			if icicleNPCInteraction ~= nil then
				icicleNPCInteraction:OnInteractionEvent()
			end
			
			-- 탐험 도구 상자
			local explorerBoxInteraction = self.Entity.Parent.Parent.ExplorerBoxInteraction
			if explorerBoxInteraction ~= nil then
				explorerBoxInteraction:OnInteractionEvent()
			end
				
			-- 횃불
			local lightInteraction = self.Entity.Parent.Parent.LightInteraction
			if lightInteraction ~= nil then
				lightInteraction:OnInteraction()
			end
			
			-- 광맥
			local miningTargetInteraction = self.Entity.Parent.Parent.MiningTargetObject
			if miningTargetInteraction ~= nil then
				miningTargetInteraction:OnInteractionEvent(_UserService.LocalPlayer, _UserService.LocalPlayer.PlayerIngameData.isIngame)
			end
			
			-- 광산5 - 소화기
			local trapControllerLava = self.Entity.Parent.Parent.TrapControllerLava
			if trapControllerLava ~= nil then
				trapControllerLava:OnInteractionEvent()
			end
				
		end
		
		_TimerService:SetTimerOnce(ClickEvent, 0.1)
		
		
	end

end