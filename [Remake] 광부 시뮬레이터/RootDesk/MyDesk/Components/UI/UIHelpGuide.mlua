@Component
script UIHelpGuide extends Component

	@ExecSpace("Client")
	method void ChangePage(number selectedPage)
		-- 도움말 가이드의 페이지를 변경하고 해당 버튼 상태 업데이트
		local guideImageList = _EntityService:GetEntity("f7c50a4c-9252-4d57-9d16-7c936cc2731a")
		for i=1, 6 do
			guideImageList:GetChildByName("Guide_"..tostring(i)).Enable = false
		end
		
		guideImageList:GetChildByName("Guide_"..tostring(selectedPage)).Enable = true
		
		
		-- open button 관리
		local btnList = _EntityService:GetEntity("32960e9d-7d69-45cf-a505-33d1f5f24ef0")
		for i=1, 6 do
			local btn = btnList:GetChildByName("GuideOpenButton_"..tostring(i))
			
			if i == selectedPage then
				btn.ButtonComponent.Enable = false
				btn.TextComponent.FontColor = Color.FromHexCode("#653122")
			else 
				btn.ButtonComponent.Enable = true
				btn.TextComponent.FontColor = Color.FromHexCode("#FFE398")
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 도움말 가이드 UI 초기화 및 로컬라이제이션 설정
		-- Localizing
		_EntityService:GetEntityByPath("/ui/HelpGuideGroup/HelpGuide/img_panel/panel_guide/Scroll_Layout/img_guide/Guide_1/Desc_3").TextComponent.Text = _LocalizationService:GetText("8001").." +1"
		
		-- Image Scaling
		_EntityService:GetEntityByPath("/ui/HelpGuideGroup/HelpGuide/img_panel/panel_guide/Scroll_Layout/img_guide/Guide_4/AchiImage").UITransformComponent.UIScale = Vector3(0.85, 0.85, 0.85)
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 이벤트 처리하여 도움말 창 닫기
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape then
			self.Entity.Enable = false
		end
	end

end