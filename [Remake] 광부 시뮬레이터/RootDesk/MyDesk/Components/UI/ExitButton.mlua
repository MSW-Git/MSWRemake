@Component
script ExitButton extends Component

	@Description("이 버튼을 눌렀을 때 Disable시킬(닫을) UI를 지정합니다. 아무것도 지정하지 않으면 자동으로 부모 엔티티를 Disable 시킵니다.")
	property Entity targetUI = nil

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 지정된 UI 또는 부모 UI를 비활성화하고 플레이어 움직임을 활성화
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.targetUI == nil then
			Entity.Parent:SetEnable(false)
		else
			self.targetUI.Enable = false 
		end
		
		_UserService.LocalPlayer.MovementComponent.Enable = true
	end

end