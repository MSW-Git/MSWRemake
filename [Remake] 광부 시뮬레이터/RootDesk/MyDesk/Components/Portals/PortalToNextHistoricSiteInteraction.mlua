@Component
script PortalToNextHistoricSiteInteraction extends InteractionComponent

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 다음 유적지로 이동하는 포털 인터랙션 (현재 주석 처리됨)
		--[[local PlayerCompo = _UserService.LocalPlayer.PlayerHistoricSite
		
		if PlayerCompo.OnHistoricSite == false then
			_UIToast:ShowMessage("이용하실 수 없습니다.")
		return end
		
		if PlayerCompo.MapList[1] == nil then 
			PlayerCompo:AddCurseStack(_UserService.LocalPlayer.PlayerHistoricSite.CurseStack * -1)
			PlayerCompo.MapList = {"HistoricSite_Mine1", "HistoricSite_Mine2", "Mine1_3", "Mine2_3", "Mine3_3", "Mine4_3", "Mine5_3", "Mine6_3", "Mine7_3", "Mine8_3"}
			_UIToast:ShowMessage("유적지 탐험을 모두 끝마쳤습니다.")
			_TeleportService:TeleportToEntity(_UserService.LocalPlayer, "/maps/HistoricSite_Town/SpawnLocation")
			PlayerCompo:SetOnHistoricSite(false)
			local CurseIcon = _EntityService:GetEntity("ac7447dd-8f8d-4212-a335-2a73146707d9")
			CurseIcon:SetEnable(false)
		return end
		
		local randIdx = _UtilLogic:RandomIntegerRange(1, #PlayerCompo.MapList)
		local destination = "/maps/"..PlayerCompo.MapList[randIdx].."/SpawnLocation"
		table.remove(PlayerCompo.MapList, randIdx)
		PlayerCompo:AddCurseStack(1)
		--다음 유적지의 유적지 포털 SetEnable 해주는 함수 (광산 작업하면서)
		_TeleportService:TeleportToEntityPath(_UserService.LocalPlayer, destination)]]
	end

end