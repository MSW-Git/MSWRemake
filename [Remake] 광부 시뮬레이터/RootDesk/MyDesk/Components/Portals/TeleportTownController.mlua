@Component
script TeleportTownController extends Component

	property Entity OpenBtn = "9d553af9-a3ee-43ff-8974-b8f6a9f953e6"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 텔레포트 타운 컨트롤러 초기화 및 UI 설정
		-- 로컬라이징
		local mainPanel = _EntityService:GetEntityByPath("/ui/TeleportGroup/TeleportSystem/MainPanel")
		for i=1, 9 do
			local townPanel = mainPanel:GetChildByName("TownPanel_"..tostring(i))
			local townName = townPanel:GetChildByName("TownName")
			townName.TextComponent.Text = tostring(math.floor(i))..". ".._LocalizationService:GetText(string.format("%d", 7200+i))
		end
		
		local entrancePopup = _EntityService:GetEntityByPath("/ui/TeleportGroup/EntranceTown")
		entrancePopup:GetChildByName("NoButton").TextComponent.Text = _LocalizationService:GetText("Close")
		entrancePopup:GetChildByName("YesButton").TextComponent.Text = _LocalizationService:GetText("Purchase")
		----------------------------------------------------------------------------------
		local Btn_Close = _EntityService:GetEntity("0923c594-65cb-43db-ad4b-187ee0ad8896")
		local callback = function()
			self.Entity:SetEnable(false)
			_UserService.LocalPlayer.MovementComponent.Enable = true
		end
		Btn_Close:ConnectEvent(ButtonClickEvent, callback)
		----------------------------------------------------------------------------------
		
		local callback2 = function()
			self:RenewUI()
		end
		self.OpenBtn:ConnectEvent(ButtonClickEvent, callback2)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- UI 갱신이 필요할 때 실행하는 업데이트 메소드
		if self._T.renewUI then
			self:RenewUI_Inner()
			self._T.renewUI = false
		end
	end

	@ExecSpace("Client")
	method void RenewUI()
		-- UI 갱신을 위한 플래그 설정
		self._T.renewUI = true
	end

	@ExecSpace("Client")
	method void RenewUI_Inner()
		-- 타운별 텔레포트 버튼 상태 갱신
		local panelList = _EntityService:GetEntity("ca7aabf4-86a0-4eee-9ef0-592d0fc74e4b")
		for i=1, 10 do
			local panel = panelList:GetChildByName("TownPanel_"..tostring(i))
			local goBtn = panel:GetChildByName("GoTown")
			
			if _UserService.LocalPlayer.PlayerData.TownAdmission[i] == true then
				goBtn.TextComponent.Text = _LocalizationService:GetText("TownTeleport_Go")
				goBtn.SpriteGUIRendererComponent.ImageRUID = "c8cb26245a8e48e5b3a22a34eb18e2c6"
				goBtn.TextComponent.FontColor = Color.FromHexCode("#653122")
			else 
				goBtn.TextComponent.Text = _LocalizationService:GetText("TownTeleport_unavailable")
				goBtn.SpriteGUIRendererComponent.ImageRUID = "651f621afbf14b19b2afd40aeb97af57"
				goBtn.TextComponent.FontColor = Color.FromHexCode("#434343")
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6f4c0989-e624-439f-9685-00d7b75c058f")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 첫 번째 타운(Town) 텔레포트 버튼 클릭 처리
		if _UserService.LocalPlayer.PlayerData.TownAdmission[1] == true then
			_TeleportService:TeleportToEntityPath(_UserService.LocalPlayer,"/maps/Town/SpawnPoint")
			self.Entity.Enable = false
		else
			_UIToast:ShowMessage(_LocalizationService:GetText("Message_BuyTownAdmission"))
		end
		
		self:RenewUI()
	end

