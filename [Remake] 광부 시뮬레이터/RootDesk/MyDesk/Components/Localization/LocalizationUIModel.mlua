@Component
script LocalizationUIModel extends Component

	property string key = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 모델 텍스트 지역화 초기화
		if self:IsClient() then
			self.key = self.Entity.Path
			self:Localize()
		end
	end

	@ExecSpace("ClientOnly")
	method void Localize()
		-- UI 모델의 텍스트를 지역화 데이터로 설정
		local data = _DataService:GetTable("UIModelTable")
		local keys = data:GetColumn(1)
		
		for i=1, #keys do
			if self.key == keys[i] then
				self.Entity.TextComponent.Text = _LocalizationService:GetText(data:GetCell(i, "Key_Text"))
				return
			end
		end
		
	end

end