@Component
script InventoryUISlotButton_RelicBox extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 인벤토리 유물박스 슬롯 버튼 클릭 이벤트
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, -1, -1))
		
		_EntityService:GetEntity("48667632-97d3-4ffa-a58a-50f9d188cc1e").InventoryUI:SetDetailInfoUI_RelicBox(idx)
	end

end