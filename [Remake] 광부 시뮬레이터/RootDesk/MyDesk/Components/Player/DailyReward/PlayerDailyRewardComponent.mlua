@Component
script PlayerDailyRewardComponent extends Component

	@HideFromInspector
	property number refreshtime = 0

	@HideFromInspector
	property number refreshtimeMAX = 1

	@Sync
	@HideFromInspector
	property number dailyProgress = 1

	@Sync
	@HideFromInspector
	property number lastRewardTime = 0

	property SyncTable<boolean> receivedReward

	method void OnBeginPlay()
		-- 데일리 보상 컴포넌트 초기화 및 테이블 설정
		self._T.tableList = {receivedReward = self.receivedReward}
		self._T.tableType = {receivedReward = "boolean"}
		
		self:ClearAllProperty()
	end

	@ExecSpace("ServerOnly")
	method void ClearAllProperty()
		-- 모든 데일리 보상 수령 상태를 초기화
		for i=1, 7 do
			self.receivedReward[i] = true
		end
	end

	@ExecSpace("Client")
	method void SetTableClient(string tableName, string strValue)
		-- 서버에서 전송된 테이블 데이터를 클라이언트에 동기화
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local tableValue = _UtilLogic:StringToTable(strValue)
		
		for index, value in ipairs(tableValue) do
			t[index] = value
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void SetTableElementClient(string tableName, number index, string value)
		-- 서버에서 전송된 특정 테이블 요소를 클라이언트에 동기화
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedValue = _ParsingLogic:ParseByType(value, self._T.tableType[tableName])
		t[index] = parsedValue
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ChangedTable(string name)
		-- 테이블 변경 시 관련 UI 갱신 처리
		if name == "receivedReward" then
			_EntityService:GetEntityByPath("/ui/DailyRewardGroup/DailyReward").DailyRewardUI:RefreshUI()
		end
	end

	@ExecSpace("Server")
	method void LoadedUserData(string dailyProgress, string lastRewardTime, string receivedRewardStr)
		-- 저장된 유저 데이터를 로드하여 데일리 보상 상태 복원
		--------------------------------------------------------------------------------------------------------
		-- 데일리보상 진척도
		if tonumber(dailyProgress) == nil  then
			self.dailyProgress = 1
		else 
			self.dailyProgress = tonumber(dailyProgress)
		end
		----------------------------------------------------
		-- 최근 접속일
		if tonumber(lastRewardTime) == nil then
			self.lastRewardTime = nil
		else 
			self.lastRewardTime = tonumber(lastRewardTime)
		end
		----------------------------------------------------
		-- 보상 수령 여부
		if receivedRewardStr == nil or receivedRewardStr == "" then
			for i=1, 7 do
				self.receivedReward[i] = false
			end
		else 
			local dataTable = _UtilLogic:StringToTable(receivedRewardStr)
			
			for i=1, 7 do
				self.receivedReward[i] = dataTable[i]
			end
		end
		--------------------------------------------------------------------------------------------------------
		-- 클라이언트와 테이블 동기화
		self:SetTableClient("receivedReward", _UtilLogic:TableToString(self.receivedReward), self.Entity.OwnerId)
		--------------------------------------------------------------------------------------------------------
		-- 진척도 갱신
		self:RefreshDailyRewardTime()
	end

	@ExecSpace("Server")
	method void RefreshDailyRewardTime()
		-- 현재 날짜 기준으로 데일리 보상 진척도 갱신
		------------------------------------------------------------------------------------------
		-- 현재시간 계산 : 연, 월, 일 정보를 가져와서 숫자로 변환
		local year = DateTime.UtcNow.Year
		local month = DateTime.UtcNow.Month
		local day = DateTime.UtcNow.Day
		
		local nowNum = 0
		
		-- 1. 연도에서부터 더하기
		nowNum = nowNum + (year-1)*365 --기본값
		local leapYearDays = math.floor((year-1)/4) - math.floor((year-1)/100) + math.floor((year-1)/400)
		nowNum = nowNum + leapYearDays
		
		-- 2. 월에서부터 더하기
		local monthDays = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
		if (year%4 == 0 and year%100) or year%400 == 0 then
			monthDays[2] = 29
		end
		for i=1, (month-1) do
			nowNum = nowNum + monthDays[i]
		end
		
		-- 3. 날에서부터 더하기
		nowNum = nowNum + day
		------------------------------------------------------------------------------------------
		-- 저장된 정보가 없다면 1일차로 한다.
		if self.lastRewardTime == nil then
			self.dailyProgress = 1
			self.lastRewardTime = nowNum
			return
		end
		
		
		local dailyGap = math.floor(nowNum - self.lastRewardTime)
		
		
		-- 하루 이상 차이라면 갱신
		if dailyGap >= 1 then
			if self.dailyProgress < 7 then
				self.dailyProgress = self.dailyProgress + 1
				
			-- 7일차 보상을 모두 수령한 뒤라면 리셋
			elseif self.dailyProgress >= 7 then
				self.dailyProgress = 1
				for i=1, 7 do
					self.receivedReward[i] = false
				end
		
			end
			
			self.lastRewardTime = nowNum
			
		-- 이미 갱신된 상태라면 아무것도 하지 않는다.
		elseif dailyGap == 0 then
			return
		end 
		------------------------------------------------------------------------------------------
		self:SetTableClient("receivedReward", _UtilLogic:TableToString(self.receivedReward), self.Entity.OwnerId)
	end

	@ExecSpace("Server")
	method void GiveReward(number day)
		-- 해당 날짜의 데일리 보상을 플레이어에게 지급
		-- 조건 검증1 : 진척도가 맞는지
		if day > self.dailyProgress then
			return
		end
		
		
		-- 조건 검증2 : 보상 수령 여부
		if self.receivedReward[day] == true then
			return
		end
		
		----------------------------------------
		self.receivedReward[day] = true
		self:SetTableElementClient("receivedReward", day, "true", self.Entity.OwnerId)
		----------------------------------------
		
		-- 보상을 주세요
		
		if day == 1 then
			self.Entity.PlayerStorage:AddConsumableItems(5, 3)
		elseif day == 3 then
			self.Entity.PlayerStorage:AddConsumableItems(10, 3)
		elseif day == 4 then
			self.Entity.PlayerStorage:AddConsumableItems(3, 2)
		elseif day == 6 then
			self.Entity.PlayerStorage:AddConsumableItems(4, 2)
			
		elseif day == 2 or day == 5 then
			self.Entity.PlayerStorage:AddCurrencyItems(2, 2000, true)
			--self.Entity.PlayerRelic:GetRelicBox(2)
			--_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_Daily_ReceivedHighRankRelicBox", self.Entity.OwnerId)
			
		elseif day == 7 then
			self.Entity.PlayerStorage:AddConsumableItems(11, 1)
			--[[
			local chairData = _DataService:GetTable("Chair")
			local targetTable = {}
			for i=1, chairData:GetRowCount() do
				if self.Entity.PlayerChair.haveItem[i] == false then
					table.insert(targetTable, i)
				end
			end
			
			if #targetTable == 0 then
				_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_Daily_ReceivedHRRBoxBecauseHaveAllChairs", self.Entity.OwnerId)
				self.Entity.PlayerRelic:GetRelicBox(2)
				
			else 
				local randIdx = _UtilLogic:RandomIntegerRange(1, #targetTable)
				local targetIdx = targetTable[randIdx]
				
				local chairName = chairData:GetCell(targetIdx, 1)
				self.Entity.PlayerChair:AddItem(targetIdx)
				_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_Daily_ReceivedNewChair", {chairName}, self.Entity.OwnerId)
			end	
			]]--
		end
		
		_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_GetDailyReward", self.Entity.OwnerId)
		
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- 동기화된 속성 변경 시 UI 갱신 처리
		if name == "dailyProgress" then
			_EntityService:GetEntityByPath("/ui/DailyRewardGroup/DailyReward").DailyRewardUI:RefreshUI()
		end 
	end

	method number DateToNumber(number year, number month, number day)
		-- 연월일을 숫자로 변환하여 날짜 계산에 사용
		-- 현재시간 계산 : 연, 월, 일 정보를 가져와서 숫자로 변환
		local nowNum = 0
		
		-- 1. 연도에서부터 더하기
		nowNum = nowNum + (year-1)*365 --기본값
		local leapYearDays = math.floor((year-1)/4) - math.floor((year-1)/100) + math.floor((year-1)/400)
		nowNum = nowNum + leapYearDays
		
		-- 2. 월에서부터 더하기
		local monthDays = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
		if (year%4 == 0 and year%100) or year%400 == 0 then
			monthDays[2] = 29
		end
		for i=1, (month-1) do
			nowNum = nowNum + monthDays[i]
		end
		
		-- 3. 날에서부터 더하기
		nowNum = nowNum + day
		
		log("입력값 = ", year, month, day)
		log("리턴값 = ", nowNum)
		
		return nowNum
	end

	@ExecSpace("Server")
	method void RefreshDailyRewardTimeOnCheat(number cheat)
		-- 치트 기능으로 날짜를 조작하여 데일리 보상 진척도 갱신
		
		------------------------------------------------------------------------------------------
		-- 현재시간 계산 : 연, 월, 일 정보를 가져와서 숫자로 변환
		local year = DateTime.UtcNow.Year
		local month = DateTime.UtcNow.Month
		local day = DateTime.UtcNow.Day
		
		local nowNum = 0
		
		-- 1. 연도에서부터 더하기
		nowNum = nowNum + (year-1)*365 --기본값
		local leapYearDays = math.floor((year-1)/4) - math.floor((year-1)/100) + math.floor((year-1)/400)
		nowNum = nowNum + leapYearDays
		
		-- 2. 월에서부터 더하기
		local monthDays = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
		if (year%4 == 0 and year%100) or year%400 == 0 then
			monthDays[2] = 29
		end
		for i=1, (month-1) do
			nowNum = nowNum + monthDays[i]
		end
		
		-- 3. 날에서부터 더하기
		nowNum = nowNum + day + cheat
		
		_UIToast:ShowMessage("출석치트("..tostring(cheat).."): 출석치트용 서버날짜는 "..string.format("%d년 %d월 %d일 입니다.", year, month, day+cheat))
		------------------------------------------------------------------------------------------
		-- 저장된 정보가 없다면 1일차로 한다.
		if self.lastRewardTime == nil then
			self.dailyProgress = 1
			self.lastRewardTime = nowNum
			return
		end
		
		
		local dailyGap = math.floor(nowNum - self.lastRewardTime)
		
		-- 하루 이상 차이라면 갱신
		if dailyGap >= 1 then
			if self.dailyProgress < 7 then
				self.dailyProgress = self.dailyProgress + 1
				
			-- 7일차 보상을 모두 수령한 뒤라면 리셋
			elseif self.dailyProgress >= 7 then
				self.dailyProgress = 1
				for i=1, 7 do
					self.receivedReward[i] = false
				end
		
			end
			
			self.lastRewardTime = nowNum
			
		-- 이미 갱신된 상태라면 아무것도 하지 않는다.
		elseif dailyGap == 0 then
			return
		end 
		------------------------------------------------------------------------------------------
		self:SetTableClient("receivedReward", _UtilLogic:TableToString(self.receivedReward), self.Entity.OwnerId)
		
	end

end