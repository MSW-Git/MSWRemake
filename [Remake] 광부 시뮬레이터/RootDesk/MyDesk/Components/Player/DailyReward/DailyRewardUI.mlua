@Component
script DailyRewardUI extends Component

	property EntityRef layoutTop = "f51d0241-37e3-41e7-8e5b-5a0c82e5aa0d"

	property EntityRef layoutBottom = "69c205df-f9b2-42eb-8f98-37910100f6eb"

	property EntityRef nextRewardTime = "c82a4c56-52e2-4c1c-8a87-96ca453bcdca"

	@ExecSpace("Client")
	method void RefreshUI()
		-- 데일리 보상 UI 전체 갱신 (진척도, 버튼 상태 등)
		local dailyProgress = _UserService.LocalPlayer.PlayerDailyRewardComponent.dailyProgress
		local receivedReward = _UserService.LocalPlayer.PlayerDailyRewardComponent.receivedReward
		
		for i=1, 7 do
			local slot = _EntityService:GetEntityByPath(self.layoutTop.Path.."/Slot_"..tostring(i)) 
			if i > 4 then 
				slot =  _EntityService:GetEntityByPath(self.layoutBottom.Path.."/Slot_"..tostring(i)) 
			end
			
			-- 갱신할 엔티티들을 불러옵니다.
			local receiveBtn = _EntityService:GetEntityByPath(slot.Path.."/ReceiveButton")
			local cover = _EntityService:GetEntityByPath(slot.Path.."/Cover")
			local cover_check = _EntityService:GetEntityByPath(cover.Path.."/CheckIcon")
			local dayNum = _EntityService:GetEntityByPath(slot.Path.."/DayNum")
			local itemName = _EntityService:GetEntityByPath(slot.Path.."/txt_item_name")
			
			-- 엔티티에 정보를 반영합니다.
			if i > dailyProgress then -- 달성 날짜 수 이후의 보상들이라면
				cover.Enable = false
				cover_check.Enable = false
				receiveBtn.Enable = false
				 dayNum.TextComponent.Text = _LocalizationService:GetTextFormat("DailyReward_Day", tostring(i)) --string.format(_LocalizationService:GetText("DailyReward_Day"),i)
				dayNum.TextComponent.FontColor = Color.FromHexCode("#9C6F44")
				
			elseif receivedReward[i] == true then -- 이미 보상을 수령한 상태라면
				cover.Enable = true
				cover_check.Enable = true
				receiveBtn.Enable = false
				dayNum.TextComponent.Text =_LocalizationService:GetText("DailyReward_AlreadyReceived")
				dayNum.TextComponent.FontColor = Color.FromHexCode("#FFCC00")
					
			else -- 그 외의 경우는 보상 수령 가능 상태
				cover.Enable = false
				receiveBtn.Enable = true
				dayNum.TextComponent.Text =_LocalizationService:GetText("DailyReward_Available")
				dayNum.TextComponent.FontColor = Color.FromHexCode("#532C0E")
			end
			
			
			local rewardName = {
				 _LocalizationService:GetText("ConsumableItemName_5").." ×3",
				_LocalizationService:GetText("CurrencyItemName_2").." ×2000",
				_LocalizationService:GetText("ConsumableItemName_10").." ×3",
				_LocalizationService:GetText("ConsumableItemName_3").." ×2",
				_LocalizationService:GetText("CurrencyItemName_2").." ×2000",
				_LocalizationService:GetText("ConsumableItemName_4").." ×2",
			}
			
			if i < 7 then
				itemName.TextComponent.Text = rewardName[i]
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 다음 보상까지 남은 시간 실시간 계산 및 표시
		if self.Entity.Enable == true then
			-- 남은 보상시간 체크
			local hour = DateTime.UtcNow.Hour
			local minute = DateTime.UtcNow.Minute
			local second = DateTime.UtcNow.Second
			
			local leftHour = 24 - hour - 1
			local leftMin = 60 - minute - 1
			local leftSec = 60 - second
			
			if leftSec >= 60 then
				leftSec = 0
				leftMin = leftMin + 1
			end
			
			if leftMin >= 60 then
				leftMin = 0
				leftHour = leftHour + 1
			end
			
			local leftTimeStr = string.format("%02d:%02d:%02d", leftHour, leftMin, leftSec)
			self.nextRewardTime.TextComponent.Text = leftTimeStr
		end
	end

	@EventSender("Entity", "119ad2a8-4e11-40b1-b294-8a002bde7957")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 보상 설명 패널 토글 버튼 클릭 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local descPanel = _EntityService:GetEntityByPath("/ui/DailyRewardGroup/DailyReward/Panel/panel_paper/DescPanel")
		
		if descPanel.Enable == true then
			descPanel.Enable = false
		else 
			descPanel.Enable = true
		end
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 데일리 보상 UI 닫기 처리
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape then
			self.Entity.Enable = false
		end
	end

end