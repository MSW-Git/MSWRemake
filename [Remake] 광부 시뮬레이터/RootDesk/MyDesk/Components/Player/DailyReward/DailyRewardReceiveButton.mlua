@Component
script DailyRewardReceiveButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 데일리 보상 수령 버튼 클릭 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Parent.Name, -1, -1))
		
		_UserService.LocalPlayer.PlayerDailyRewardComponent:GiveReward(idx)
		Entity.ButtonComponent.Enable = false
	end

end