@Component
script InfiniteQuestUI extends Component

	property boolean isFolded = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 무한 퀘스트 UI 초기화 및 기본 설정
		-- Localizing
		
		---------------------------------------------------------
		_EntityService:GetEntityByPath("/ui/IngameGroup/InfiniteQuest/Paper").Enable = false
		_EntityService:GetEntityByPath("/ui/IngameGroup/InfiniteQuest/GetNewQuestButton").Enable = true
		
		self.isFolded = true
	end

	@ExecSpace("Client")
	method void FoldUI()
		-- 무한 퀘스트 UI의 접기/펼치기 토글 처리
		local paperEntity = _EntityService:GetEntityByPath("/ui/IngameGroup/InfiniteQuest/Paper")
		
		-- 현재 상태에 따라 움직임 애니메이션을 재생합니다.
		if self.isFolded == false then
			paperEntity.Enable = false
			self.isFolded = true
		else 
			paperEntity.Enable = true 
			self.isFolded = false
		end
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- Tab키 입력으로 퀘스트 보상 수령 및 UI 접기 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if key == KeyboardKey.Tab then
			local playerInfQuest = _UserService.LocalPlayer.PlayerInfiniteQuest
		
			
			if playerInfQuest.isRewarded == false and playerInfQuest.currentScore >= playerInfQuest.goalScore then
				playerInfQuest:GetReward()
			elseif playerInfQuest.isRewarded == true and playerInfQuest.currentScore >= playerInfQuest.goalScore then
				return
			else 
				self:FoldUI()
			end
		end
	end

	@EventSender("Entity", "53bad064-de14-4dd2-8131-bf91aa60d372")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 새 퀘스트 시작 버튼 클릭 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		Entity.Enable = false
		
		_UserService.LocalPlayer.PlayerInfiniteQuest:GetNewQuest()
		
		_EntityService:GetEntityByPath("/ui/IngameGroup/InfiniteQuest/Paper").Enable = true
	end

end