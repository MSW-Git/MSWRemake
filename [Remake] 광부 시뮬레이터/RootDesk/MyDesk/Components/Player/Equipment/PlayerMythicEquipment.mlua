@Component
script PlayerMythicEquipment extends Component

	property SyncTable<number> EquipmentLevel

	property SyncTable<number> Equip1_Element

	property SyncTable<number> Equip2_Element

	property SyncTable<number> Equip3_Element

	property SyncTable<number> Equip4_Element

	@Sync
	property number PurchaseUnlockedLevel = 0

	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 테이블 리스트와 타입 정보를 설정하여 클라이언트 동기화 준비
		self._T.tableList = { 	EquipmentLevel = self.EquipmentLevel, 
							Equip1_Element = self.Equip1_Element, 
							Equip2_Element = self.Equip2_Element, 
							Equip3_Element = self.Equip3_Element, 
							Equip4_Element = self.Equip4_Element, 
		}
		
		self._T.tableType = { EquipmentLevel = "number", 
							Equip1_Element = "number", 
							Equip2_Element = "number",
							Equip3_Element = "number",
							Equip4_Element = "number"
		}
	end

	@ExecSpace("Client")
	method void SetTableClient(string tableName, string strValue)
		-- 서버에서 전달받은 테이블 데이터를 클라이언트 측에서 동기화하고 UI 갱신
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local tableValue = _UtilLogic:StringToTable(strValue)
		
		for index, value in ipairs(tableValue) do
			t[index] = value
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void SetTableElementClient(string tableName, number index, string value)
		-- 테이블의 특정 인덱스 요소를 클라이언트에서 업데이트하고 타입에 맞게 파싱
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedValue = _ParsingLogic:ParseByType(value, self._T.tableType[tableName])
		t[index] = parsedValue
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ClearTableClient(string tableName, string initValue, number tableCount)
		-- 클라이언트 측에서 테이블 전체를 초기값으로 클리어하고 UI 갱신
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedInitValue = _ParsingLogic:ParseByType(initValue, self._T.tableType[tableName])
		for index=1, tableCount do
			t[index] = parsedInitValue
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ChangedTable(string name)
		-- 테이블 데이터가 변경되었을 때 해당하는 UI 컴포넌트를 새로고침
		if name == "EquipmentLevel" then
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI:RefreshUI()
		end
	end

	@ExecSpace("Server")
	method void LoadedData(string levelStr, string eq1_element, string eq2_element, string eq3_element, string eq4_element, string PurchaseUnlockedLevel)
		-- 저장된 유저 데이터를 로드하여 신화 장비 레벨과 원소 정보를 복원하고 클라이언트에 동기화
		if levelStr == nil then
			for i=1, 4 do
				self.EquipmentLevel[i] = 0
			end
		else 
			local levelData = _UtilLogic:StringToTable(levelStr)
			
			for i=1, 4 do
				if levelData[i] == nil then
					self.EquipmentLevel[i] = 0
				else
					self.EquipmentLevel[i] = levelData[i]
				end
			end
		end
		----------------------------------------------------------------------
		if eq1_element == nil then
			for i=1, 8 do
				self.Equip1_Element[i] = 0
			end
		else 
			local elementData = _UtilLogic:StringToTable(eq1_element)
			
			for i=1, 8 do
				if elementData[i] == nil then
					self.Equip1_Element[i] = 0
				else
					self.Equip1_Element[i] = elementData[i]
				end
			end
		end
		----------------------------------------------------------------------
		if eq2_element == nil then
			for i=1, 8 do
				self.Equip2_Element[i] = 0
			end
		else 
			local elementData = _UtilLogic:StringToTable(eq2_element)
			
			for i=1, 8 do
				if elementData[i] == nil then
					self.Equip2_Element[i] = 0
				else
					self.Equip2_Element[i] = elementData[i]
				end
			end
		end
		----------------------------------------------------------------------
		if eq3_element == nil then
			for i=1, 8 do
				self.Equip3_Element[i] = 0
			end
		else 
			local elementData = _UtilLogic:StringToTable(eq3_element)
			
			for i=1, 8 do
				if elementData[i] == nil then
					self.Equip3_Element[i] = 0
				else
					self.Equip3_Element[i] = elementData[i]
				end
			end
		end
		----------------------------------------------------------------------
		if eq4_element == nil then
			for i=1, 8 do
				self.Equip4_Element[i] = 0
			end
		else 
			local elementData = _UtilLogic:StringToTable(eq4_element)
			
			for i=1, 8 do
				if elementData[i] == nil then
					self.Equip4_Element[i] = 0
				else
					self.Equip4_Element[i] = elementData[i]
				end
			end
		end
		----------------------------------------------------------------------
		if tonumber(PurchaseUnlockedLevel) == nil then
			self.PurchaseUnlockedLevel = 10
		else
			self.PurchaseUnlockedLevel = tonumber(PurchaseUnlockedLevel)
		end
		----------------------------------------------------------------------
		-- 클라 동기화
		self:SetTableClient("EquipmentLevel", _UtilLogic:TableToString(self.EquipmentLevel), self.Entity.OwnerId)
		self:SetTableClient("Equip1_Element", _UtilLogic:TableToString(self.Equip1_Element), self.Entity.OwnerId)
		self:SetTableClient("Equip2_Element", _UtilLogic:TableToString(self.Equip2_Element), self.Entity.OwnerId)
		self:SetTableClient("Equip3_Element", _UtilLogic:TableToString(self.Equip3_Element), self.Entity.OwnerId)
		self:SetTableClient("Equip4_Element", _UtilLogic:TableToString(self.Equip4_Element), self.Entity.OwnerId)
		----------------------------------------------------------------------
	end

	@ExecSpace("Server")
	method void PurchaseMythicEquipment(number equipIdx, number upgradeLevel)
		-- 지정된 신화 장비의 레벨을 업그레이드하고 비용 차감, 원소 획득 및 연출 재생
		local currentLevel = self.EquipmentLevel[equipIdx]
		local targetLevel = currentLevel + upgradeLevel
		
		local cost = 0
		for i=1, upgradeLevel do
			local currentTargetLevel = currentLevel + i
			local len = string.len(tostring(math.floor(100000000000 * currentTargetLevel)))
			local currentCost = 150000000000 * (1+0.6*(currentTargetLevel-1))
			
			cost = cost + currentCost
		end
		
		-- 공허 아이템 20 : 신화 장비 레벨업 비용 감소
		local applyVoidItem20 = function()
			local voidItemLv = self.Entity.PlayerVoidItem.haveItems[20]
			local voidItemTable = _DataService:GetTable("VoidItems")
			if voidItemLv > 0 then
				local initAbility = voidItemTable:GetCell(20, "InitAbility")
				local levelAbility = voidItemTable:GetCell(20, "AbilityPerLevel")
				local currentAbility = tonumber(initAbility) + tonumber(levelAbility) * voidItemLv
				
				cost = cost * (1 - currentAbility/100)
				
				_UIGetLog:PrintVoidItemLog(20, self.Entity.OwnerId)
			end
		end
		applyVoidItem20()
		
		
		-- 검증
		if self.Entity.PlayerData.Money < cost then
			log("비용 부족!")
			return
		end
		
		
		if targetLevel > self.PurchaseUnlockedLevel then
			log("한계보다 높은 레벨로 업그레이드하려고 했습니다!")
			return
		end
		
		------------------------------------------------------------------------
		
		-- 데이터 처리 & 클라 동기화
		self.Entity.PlayerData.Money = self.Entity.PlayerData.Money - cost
		self.EquipmentLevel[equipIdx] = self.EquipmentLevel[equipIdx] + upgradeLevel
		
		local beadsResultTable = { 0, 0, 0, 0, 0,	0, 0, 0}
		for i=1, upgradeLevel do
			local randomBeadsIdx = _UtilLogic:RandomIntegerRange(1, 8)
			beadsResultTable[randomBeadsIdx] = beadsResultTable[randomBeadsIdx] + 1
			if equipIdx == 1 then
				self.Equip1_Element[randomBeadsIdx] = self.Equip1_Element[randomBeadsIdx] + 1
			elseif equipIdx == 2 then
				self.Equip2_Element[randomBeadsIdx] = self.Equip2_Element[randomBeadsIdx] + 1
			elseif equipIdx == 3 then
				self.Equip3_Element[randomBeadsIdx] = self.Equip3_Element[randomBeadsIdx] + 1
			elseif equipIdx == 4 then
				self.Equip4_Element[randomBeadsIdx] = self.Equip4_Element[randomBeadsIdx] + 1
			end
		end
		
		
		if equipIdx == 1 then
			self:SetTableClient("Equip1_Element", _UtilLogic:TableToString(self.Equip1_Element), self.Entity.OwnerId)
		elseif equipIdx == 2 then
			self:SetTableClient("Equip2_Element", _UtilLogic:TableToString(self.Equip2_Element), self.Entity.OwnerId)
		elseif equipIdx == 3 then
			self:SetTableClient("Equip3_Element", _UtilLogic:TableToString(self.Equip3_Element), self.Entity.OwnerId)
		elseif equipIdx == 4 then
			self:SetTableClient("Equip4_Element", _UtilLogic:TableToString(self.Equip4_Element), self.Entity.OwnerId)
		end
		
		
		-- 능력치 적용
		self.Entity.PlayerData:ApplyPlayerStatus()
		
		-- 동기화
		self:SetTableElementClient("EquipmentLevel", equipIdx, tostring(self.EquipmentLevel[equipIdx]), self.Entity.OwnerId)
		
		-- 연출 재생 지시
		self:PlayPurchaseDirection(equipIdx, self.EquipmentLevel[equipIdx], _UtilLogic:TableToString(beadsResultTable), self.Entity.OwnerId)
		
		-- 업적 체크
		self.Entity.PlayerAchievementComponent:GetProgress(33, upgradeLevel)
		self.Entity.PlayerAchievementComponent:GetProgress(38, upgradeLevel)
		self.Entity.PlayerAchievementComponent:GetProgress(45, upgradeLevel)
		self.Entity.PlayerAchievementComponent:GetProgress(46, upgradeLevel)
		self.Entity.PlayerAchievementComponent:GetProgress(47, upgradeLevel)
		
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	@ExecSpace("Client")
	method void PlayPurchaseDirection(number equipIdx, number equipLevel, string beadsResultTable)
		-- 장비 구매 완료 후 클라이언트에서 업그레이드 연출을 재생
		_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI:PlayUpgradeDirection(equipIdx, equipLevel, _UtilLogic:StringToTable(beadsResultTable))
	end

	@ExecSpace("Server")
	method void RedistributionPowerOfGod(number equipIdx, string checkedTableStr)
		-- 선택된 신석을 랜덤하게 재분배하여 장비의 원소 구성을 변경하는 기능 수행
		local checkedTable = _UtilLogic:StringToTable(checkedTableStr)
		
		local targetTable = nil
		local tableName = ""
		if equipIdx == 1 then
			targetTable = self.Equip1_Element
			tableName = "Equip1_Element"
		elseif equipIdx == 2 then
			targetTable = self.Equip2_Element
			tableName = "Equip2_Element"
		elseif equipIdx == 3 then
			targetTable = self.Equip3_Element
			tableName = "Equip3_Element"
		elseif equipIdx == 4 then
			targetTable = self.Equip4_Element
			tableName = "Equip4_Element"
		end
		
		
		local beforeTable = {}
		for i=1, 8 do
			beforeTable[i] = targetTable[i]
		end
		
		
		-- 검증
		local cost = 20000000000 * (1+0.6*(self.EquipmentLevel[equipIdx]-1))
		if self.Entity.PlayerData.Money < cost then
			log("비용 부족!")
			return
		end
		-------------------------------------------------
		-- 처리
		self.Entity.PlayerData:UseMoney(cost)
		
		local removedIdxTable = {}
		local createdIdxTable = {}
		local countTable = {0, 0, 0, 0, 0, 0, 0, 0}
		
		for i=1, 8 do
			if checkedTable[i] == true then
				countTable[i] = targetTable[i]
			end
		end
		
		
		for i=1, 8 do
			for j=1, countTable[i] do
				table.insert(removedIdxTable, i)
				local randIdx = _UtilLogic:RandomIntegerRange(1, 8)
				table.insert(createdIdxTable, randIdx)
				
				targetTable[i] = targetTable[i] - 1
				targetTable[randIdx] = targetTable[randIdx] + 1
			end
		end
		
		-- 연출 재생
		local removedTableStr = _UtilLogic:TableToString(removedIdxTable)
		local createdTableStr = _UtilLogic:TableToString(createdIdxTable)
		local beforeTableStr = _UtilLogic:TableToString(beforeTable)
		self:PlayRedistributionDirection(removedTableStr, createdTableStr, beforeTableStr, self.Entity.OwnerId)
		
		-- 동기화
		local tableStr = ""
		if equipIdx == 1 then
			tableStr = _UtilLogic:TableToString(self.Equip1_Element)
		elseif equipIdx == 2 then
			tableStr = _UtilLogic:TableToString(self.Equip2_Element)
		elseif equipIdx == 3 then
			tableStr = _UtilLogic:TableToString(self.Equip3_Element)
		elseif equipIdx == 4 then
			tableStr = _UtilLogic:TableToString(self.Equip4_Element)
		end
		self:SetTableClient(tableName, tableStr ,self.Entity.OwnerId)
		
		-- 능력치 적용
		self.Entity.PlayerData:ApplyPlayerStatus()
		
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	@ExecSpace("Client")
	method void PlayRedistributionDirection(string removedTableStr, string createdTableStr, string beforeTableStr)
		-- 신석 재분배 연출을 클라이언트에서 재생하고 UI 버튼을 일시적으로 비활성화
		-- 일시적으로 버튼들을 비활성화합니다.
		local exitBtn = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/panel/Panel_right/Button_Exit")
		local checkBtnList = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/panel/Panel_right/CheckingButtonList")
		local redistributionBtn = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/panel/Panel_right/Button_Redistribution")
		exitBtn.Enable = false
		checkBtnList.Enable = false
		redistributionBtn.Enable = false
		---------------------------------------------------------------------------
		_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI.IsPlayingDirection = true
		
		-- 연출을 재생합니다.
		local removedTable = _UtilLogic:StringToTable(removedTableStr)
		local createdTable = _UtilLogic:StringToTable(createdTableStr)
		local beforeTable = _UtilLogic:StringToTable(beforeTableStr)
		
		local beadsList = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/panel/Panel_right/InfoList")
		local effect = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/panel/Panel_right/Effect")
		local ruidTable = {
			"02ddbb3e70ad4b478b620d6abf39a53e",
			"e1e8bcf265304122aaa3e35a162edb60",
			"085008f22cea45eea0f2a329df34cd7b",
			"afdfd440d48e4be1b1364a2a94a3ae8e",
			"9c9c2d503d1b4002a3e3576532da2587", -- 5
			"3f0fed655fc94390aa83e5ad3e8ef267",
			"54d433041333401eb2883e3761979eb5",
			"da265e4931b84fd9a10c29d5a63d5833",
		}
		
		local playEffect = function()
			local clonedEffect = effect:Clone("clonedEffect")
			
			clonedEffect:Destroy(0.4)
		end
		
		-- 1. 재분배하는 개수만큼 구슬 엔티티를 클론하고, 지정한 좌표로 이동시킵니다.
		local directionBeadEntity = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/panel/Panel_right/DirectionSprite/bead")
		
		local removeIdx = 0
		local angle = _UtilLogic:RandomIntegerRange(0, 360)
		local angleTick = 360/(#removedTable)
		local clonedEntities = {}
		local cloneBeadEntity = function()
			removeIdx = removeIdx + 1
			
			-- 클론
			local clonedEntity = directionBeadEntity:Clone("ClonedBead")
			clonedEntity.SpriteGUIRendererComponent.ImageRUID = ruidTable[removedTable[removeIdx]]
			clonedEntity:GetChildByName("Effect").Enable = false
			table.insert(clonedEntities, clonedEntity)
			
			-- 개수 차감
			beforeTable[removedTable[removeIdx]] = beforeTable[removedTable[removeIdx]] - 1
			beadsList:GetChildByName("List_"..tostring(math.floor(removedTable[removeIdx]))):GetChildByName("Amount").TextComponent.Text = string.format("%d", beforeTable[removedTable[removeIdx]])
			
			-- 좌표 계산
			angle = angle - angleTick
			local targetPos = Vector2(400*math.cos(math.rad(angle)), 400*math.sin(math.rad(angle)))
			local moveTick = targetPos/30
			
			-- 지정 좌표로 서서히 이동
			local moveEntity = function()
				clonedEntity.UITransformComponent.anchoredPosition = clonedEntity.UITransformComponent.anchoredPosition + moveTick
			end
			for j=1, 30 do
				_TimerService:SetTimerOnce(moveEntity, j/150)
			end
			
			_SoundService:PlaySound("0ff342cbcb97400ab224ce5f6ea083ae", 1)
		end
		for i=1, #removedTable do
			_TimerService:SetTimerOnce(cloneBeadEntity, 0.1*i)
			playEffect()
		end
		
		
		-- 2. 클론된 엔티티들을 결과에 맞춰 RUID를 변경합니다.
		local changeTargetIdx = 0
		
		local changeRUID = function()
			changeTargetIdx = changeTargetIdx + 1
			local targetEntity = clonedEntities[changeTargetIdx]
			local targetRUID = ruidTable[createdTable[changeTargetIdx]]
			targetEntity.SpriteGUIRendererComponent.ImageRUID = targetRUID
			
			_SoundService:PlaySound("0ff342cbcb97400ab224ce5f6ea083ae", 1)
			
			local clonedEffect = targetEntity:GetChildByName("Effect"):Clone("clonedEffect")
			clonedEffect:Destroy(0.4)
		end
		for i=1, #removedTable do
			_TimerService:SetTimerOnce(changeRUID, 0.1*#removedTable + 0.5)
		end
		
		
		-- 3. 클론된 엔티티들을 합쳐오면서 제거하고, 숫자를 변경시킵니다.
		local mergeTargetIdx = 0
		local merge = function()
			mergeTargetIdx = mergeTargetIdx + 1
			local targetEntity = clonedEntities[mergeTargetIdx]
			local distance = Vector2(0, 0) - targetEntity.UITransformComponent.anchoredPosition
			local moveTick = distance / 30
			
			local moveEntity = function()
				targetEntity.UITransformComponent.anchoredPosition = targetEntity.UITransformComponent.anchoredPosition + moveTick
			end
			for j=1, 30 do
				_TimerService:SetTimerOnce(moveEntity, j/150)
			end
			local createdIdx = createdTable[mergeTargetIdx]
			
			local setResultNumber = function()
				beforeTable[createdIdx] = beforeTable[createdIdx] + 1
				beadsList:GetChildByName("List_"..tostring(math.floor(createdIdx))):GetChildByName("Amount").TextComponent.Text = string.format("%d", beforeTable[createdIdx])
				_SoundService:PlaySound("0ff342cbcb97400ab224ce5f6ea083ae", 1)
			end
			_TimerService:SetTimerOnce(setResultNumber, 0.2)
		
			
			
			targetEntity:Destroy(31/150)
			_TimerService:SetTimerOnce(playEffect, 0.2)
			
		end
		for i=1, #removedTable do
			_TimerService:SetTimerOnce(merge, 0.1*#removedTable + 1 + 0.1*i)
		end
		
		
		-- 연출을 재생하는동안 엔티티들을 회전시킵니다.
		local rotation = 0
		local rotate = function()
			rotation = rotation + 1
			directionBeadEntity.Parent.UITransformComponent.ZRotation = rotation
		end
		for i=1, 6*#removedTable+30 do
			_TimerService:SetTimerOnce(rotate, i/30)
		end
		
		
		
		
		--
		--local idx = 0
		--local doDirection = function()
		--	idx = idx + 1
		--	beforeTable[removedTable[idx]] = beforeTable[removedTable[idx]] - 1
		--	beforeTable[createdTable[idx]] = beforeTable[createdTable[idx]] + 1
			
		--	self:RedistributionDirection_Inner(removedTable[idx], createdTable[idx], beforeTable[removedTable[idx]], beforeTable[createdTable[idx]])
		--end
		
		--for i=1, #removedTable do
		--	_TimerService:SetTimerOnce(doDirection, 0.4*i)
		--end
		
		
		
		---------------------------------------------------------------------------
		-- 버튼들을 다시 활성화하고, 패널을 새로고침합니다.
		local reActivateBtns = function()
			exitBtn.Enable = true
			checkBtnList.Enable = true
			redistributionBtn.Enable = true
			
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI:RefreshRedistributionInfoPanel()
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup").Enable = true
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI.IsPlayingDirection = false
		end
		_TimerService:SetTimerOnce(reActivateBtns, 0.2*#removedTable+1)
	end

	@ExecSpace("Client")
	method void RedistributionDirection_Inner(number removedIdx, number createdIdx, number afterRemoveAmount, number afterCreateAmount)
		-- 개별 신석의 재분배 애니메이션을 처리하는 내부 함수
		local beadsList = _EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop/RedistributionCheckPopup/Panel/InfoList")
		local removedEntity = beadsList:GetChildByName("List_"..tostring(math.floor(removedIdx))):GetChildByName("Amount")
		local createdEntity = beadsList:GetChildByName("List_"..tostring(math.floor(createdIdx))):GetChildByName("Amount")
		
		removedEntity.TextComponent.Text = string.format("%d", afterRemoveAmount)
		
		local setCreatedIdxInfo = function()
			createdEntity.TextComponent.Text = string.format("%d", afterCreateAmount)
			_SoundService:PlaySound("0ff342cbcb97400ab224ce5f6ea083ae", 1)
		end
		_TimerService:SetTimerOnce(setCreatedIdxInfo, 0.2)
	end

	@ExecSpace("Server")
	method void UnlockUpgradeLimit()
		-- 황금열쇠를 사용하여 신화 장비의 업그레이드 레벨 제한을 해제
		local currentLevelMax = self.PurchaseUnlockedLevel
		local nextMax = currentLevelMax + 5
		----------------------------------------------------------------------
		-- 검증
		local keysCost = 5
		if self.Entity.PlayerStorage.currencyItems[6] < keysCost then
			log("비용 부족!")
			return
		end
		----------------------------------------------------------------------
		-- 데이터 처리 
		self.Entity.PlayerStorage:UseCurrencyItems(6, keysCost)
		self.PurchaseUnlockedLevel = nextMax
		
		-- 연출 재생
		self:PlayUnlockDirection(nextMax, keysCost, self.Entity.OwnerId)
		
		-- 업적 : 레벨제한 올려보기
		self.Entity.PlayerAchievementComponent:GetProgress(39, 1)
		
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	@ExecSpace("Client")
	method void PlayUnlockDirection(number unlockedLevelMax, number usedKeyNum)
		-- 레벨 제한 해제 완료 후 클라이언트에서 해제 연출을 재생
		_EntityService:GetEntityByPath("/ui/EquipShopGroup/MythicEquipmentShop").MythicEquipmentShopUI:PlayUnlockDirection(unlockedLevelMax, usedKeyNum)
	end

	@ExecSpace("Server")
	method void ResetPropertiesByReborn()
		-- 환생 시 모든 신화 장비의 레벨과 원소 정보를 초기화하고 클라이언트에 동기화
		-- 장비 레벨 정보 리셋
		for i=1, 4 do
			self.EquipmentLevel[i] = 0
		end
		
		-- 신석 정보 리셋
		for i=1, 8 do
			self.Equip1_Element[i] = 0
			self.Equip2_Element[i] = 0
			self.Equip3_Element[i] = 0
			self.Equip4_Element[i] = 0
		end
		
		self:SetTableClient("EquipmentLevel", _UtilLogic:TableToString(self.EquipmentLevel), self.Entity.OwnerId)
		self:SetTableClient("Equip1_Element", _UtilLogic:TableToString(self.Equip1_Element), self.Entity.OwnerId)
		self:SetTableClient("Equip2_Element", _UtilLogic:TableToString(self.Equip2_Element), self.Entity.OwnerId)
		self:SetTableClient("Equip3_Element", _UtilLogic:TableToString(self.Equip3_Element), self.Entity.OwnerId)
		self:SetTableClient("Equip4_Element", _UtilLogic:TableToString(self.Equip4_Element), self.Entity.OwnerId)
	end

end