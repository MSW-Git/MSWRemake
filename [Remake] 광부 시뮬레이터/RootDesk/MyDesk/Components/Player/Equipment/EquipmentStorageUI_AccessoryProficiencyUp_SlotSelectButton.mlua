@Component
script EquipmentStorageUI_AccessoryProficiencyUp_SlotSelectButton extends Component

	property number itemIdx = 0

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 장신구 숙련도 업그레이드용 재료 선택 버튼 클릭 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage").EquipmentStorageUI:SelectAccessoryGradeupMaterial(self.itemIdx)
	end

end