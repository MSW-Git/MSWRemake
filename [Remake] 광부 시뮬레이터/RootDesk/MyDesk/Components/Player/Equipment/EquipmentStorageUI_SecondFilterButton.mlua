@Component
script EquipmentStorageUI_SecondFilterButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 장비 보관함 2차 필터 버튼 클릭 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 8, -1))
		
		_EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage").EquipmentStorageUI:SetSecondFilterIdx(idx)
	end

end