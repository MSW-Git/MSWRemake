@Component
script EquipmentStorageUI_MythicItemMouseHover extends Component

	@ExecSpace("Client")
	method void SetHoverUI(boolean enable)
		-- 신화 장비 아이템에 마우스 호버 시 툴팁 UI 표시 설정
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		local targetUI = _EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage/MythicDetailInfoPopup")
		targetUI.Enable = enable
		
		targetUI:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText("Mythic").." ".._LocalizationService:GetText("EquipType_"..tostring(idx))
		targetUI:GetChildByName("Level").TextComponent.Text = string.format("Lv. %d", _UserService.LocalPlayer.PlayerMythicEquipment.EquipmentLevel[idx])
		
		if idx == 4 then
			targetUI:GetChildByName("Ability_text").TextComponent.Text = _LocalizationService:GetText("800"..tostring(idx)).." +".._ThousandsSeparator:ConvertToMetricPrefixString(10000000, nil)
		else 
			targetUI:GetChildByName("Ability_text").TextComponent.Text = _LocalizationService:GetText("8005").." +".._ThousandsSeparator:ConvertToMetricPrefixString(10000000, nil)
		end
		
		if idx == 1 then
			targetUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "thumbnail://38345347650240b1af02fbe9d2e29920"
		elseif idx == 2 then
			targetUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "thumbnail://52a6839f290e431fbe29764bfbadae10"
		elseif idx == 3 then
			targetUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "067d97e8224f4e49bdcebc3dbd0570a2"
		elseif idx == 4 then
			targetUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "thumbnail://7967810b0e1a438ba6525116e537a0ba"
		end
	end

	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 신화 장비 아이템 버튼 상태 변경 시 호버 UI 표시 처리
		-- Parameters
		local state = tostring(event.state)
		--------------------------------------------------------
		if Environment:IsPCPlatform() then
			if state == "Hover" then
				self:SetHoverUI(true)
			else 
				self:SetHoverUI(false)
			end
			
		elseif Environment:IsMobilePlatform() then
			if state == "Pressed" then
				self:SetHoverUI(true)
			else 
				self:SetHoverUI(false)
			end
		end
	end

end