	end

	@ExecSpace("Server")
	method void Reborn()
		-- 조건 검증 
		if self.Entity.CurrentMapName ~= "Town9" and self.Entity.CurrentMapName ~= "Town10" then
			return
		end
		
		-- 조건 검증2 : 버튼 연타했을 때 실행하지 않도록
		if self.IsPlayingRebornDirection == true then
			log("조건검증2에 걸림")
			return
		end
		
		--[[
		-- 조건 검증3 : 열쇠 확인
		if self.TownProgress[9] == false then
			log("조건검증3에 걸림")
			return
		end
		]]--
		
		
		self.IsPlayingRebornDirection = true
		local initiating = function()
			self.IsPlayingRebornDirection = false
		end
		_TimerService:SetTimerOnce(initiating, 60)
		---------------------------------------
		self:PlayRebornDirection(self.Entity.OwnerId)
		------------------------------------------------------------------------------
		--log("reborn!")
		
		local GetRebornReward = function()
			self.Money = 0
			--------------------------------------------------------
			self:ClearAllProperty() -- 돈, 장비, 마을 정보 초기화
			--------------------------------------------------------
			self.Entity.PlayerBackpack:DiscardAllItem() -- 가방 비우기
			--------------------------------------------------------
			self:AddPetEgg() -- 펫 알 1개 획득
			--------------------------------------------------------
			self.RebornCount = self.RebornCount + 1 -- 환생 회수 카운트
			--------------------------------------------------------
			-- 환생코인 보상 : 신화장비 레벨에 비례 
			local rebirthCoinRewardAmount = 0
			for i=1, 4 do
				rebirthCoinRewardAmount = rebirthCoinRewardAmount + self.Entity.PlayerMythicEquipment.EquipmentLevel[i]
			end
			
			
			-- 공허 아이템 효과 적용 : 환생코인 보상 증가 
			local voidItemLv = self.Entity.PlayerVoidItem.haveItems[12]
			local voidItemTable = _DataService:GetTable("VoidItems")
			if voidItemLv > 0 then
				local initAbility = voidItemTable:GetCell(12, "InitAbility")
				local levelAbility = voidItemTable:GetCell(12, "AbilityPerLevel")
				local currentAbility = tonumber(initAbility) + tonumber(levelAbility) * voidItemLv
					
				rebirthCoinRewardAmount = math.floor(rebirthCoinRewardAmount * (1 + currentAbility/100))
				_UIGetLog:PrintVoidItemLog(12, self.Entity.OwnerId)
			end
			
			self.Entity.PlayerStorage:AddCurrencyItems(5, rebirthCoinRewardAmount, true)
			--------------------------------------------------------
			-- 신화 장비 리셋
			self.Entity.PlayerMythicEquipment:ResetPropertiesByReborn()
			--------------------------------------------------------
			-- 황금열쇠 보상
			local goldKeyRewardAmount = self.TempleRecord_Current - self.GoldKeyRewardedStage
			if goldKeyRewardAmount <= 0 then
				goldKeyRewardAmount = 0
			end
			
			self.Entity.PlayerStorage:AddCurrencyItems(6, goldKeyRewardAmount, true)
			
			-- 업적 - 황금열쇠 획득하기
			if goldKeyRewardAmount > 0 then
				self.Entity.PlayerAchievementComponent:GetProgress(34, 1)
			end
			--------------------------------------------------------
			-- 신전 도달 기록 리셋
			if self.GoldKeyRewardedStage < self.TempleRecord_Current then
				self.GoldKeyRewardedStage = self.TempleRecord_Current
			end
			self.TempleRecord_Current = 0
			--------------------------------------------------------
			-- 반복퀘스트 리셋
			self.Entity.PlayerInfiniteQuest:GetNewQuest()
			--------------------------------------------------------
			-- 마을1로 이동
			_TeleportService:TeleportToEntity(self.Entity, _EntityService:GetEntity("a13a0e3c-a396-4776-87a1-8642e8ccd1ac")) 
			
			-- 데이터 저장
			self:SaveData(1)
		end
		
		_TimerService:SetTimerOnce(GetRebornReward, 12)
		---------------------------------------
	end

	@ExecSpace("Client")
	method void PlayRebornDirection()
		-- 환생 연출 UI를 재생
		_EntityService:GetEntityByPath("/ui/Reborn/New_Reborn").RebornUI:PlayRebornDirection()
	end

	@ExecSpace("Client")
	method void SetTableClient(string tableName, string strValue)
		-- 서버에서 전달받은 테이블 데이터를 클라이언트에서 적용
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local tableValue = _UtilLogic:StringToTable(strValue)
		
		for index, value in ipairs(tableValue) do
			t[index] = value
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void SetTableElementClient(string tableName, number index, string value)
		-- 서버에서 전달받은 테이블의 특정 인덱스 값을 클라이언트에서 적용
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedValue = _ParsingLogic:ParseByType(value, self._T.tableType[tableName])
		t[index] = parsedValue
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ClearTableClient(string tableName, string initValue, number tableCount)
		-- 클라이언트에서 테이블을 초기값으로 모두 리셋
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedInitValue = _ParsingLogic:ParseByType(initValue, self._T.tableType[tableName])
		for index=1, tableCount do
			t[index] = parsedInitValue
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ChangedTable(string name)
		-- 테이블이 변경될 때 관련 UI와 상태를 새로고침
		if name == "haveEquipment" then
			--_EntityService:GetEntity("48667632-97d3-4ffa-a58a-50f9d188cc1e").InventoryUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop").EquipmentShopUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage").EquipmentStorageUI:RefreshUI()
			self:ApplyPlayerStatus()
		end
		
		if name == "equiped" then
			--_EntityService:GetEntity("48667632-97d3-4ffa-a58a-50f9d188cc1e").InventoryUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop").EquipmentShopUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage").EquipmentStorageUI:RefreshUI()
			self:ChangeEquipmentAvatarOnServer()
		end
		
		if name == "TownAdmission" then
			_EntityService:GetEntity("c2e43eac-471f-4851-9cd8-5a53c04fb484").TeleportTownController:RenewUI()
		end
	end

	@ExecSpace("ServerOnly")
	method void ClearAllProperty()
		-- 환생 시 모든 장비와 마을 진행도를 초기화 (마을1 제외)
		for i=1, 4 do
			self.equiped[i] = 0
		end
		
		self:ClearTableClient("equiped", "0", 4, self.Entity.OwnerId)
		
		for i=1, 160 do
			self.haveEquipment[i] = false
		end
		self:ClearTableClient("haveEquipment", "false", 160, self.Entity.OwnerId)
		
		self.TownAdmission[1] = true -- 마을 1은 항상 이동 가능하므로 예외 처리 필요
		self.TownProgress[1] = true -- for문을 1이 아닌 마을 2부터 돌리는 상황
		for i=2, self.maxTown do
			self.TownAdmission[i] = false
			self.TownProgress[i] = false
		end
		
		self:ClearTableClient("TownAdmission", "false", self.maxTown, self.Entity.OwnerId)
		self:ClearTableClient("TownProgress", "false", self.maxTown, self.Entity.OwnerId)
		self:SetTableElementClient("TownAdmission", 1, "true", self.Entity.OwnerId)
		self:SetTableElementClient("TownProgress", 1, "true", self.Entity.OwnerId)
		
	end

	@ExecSpace("ServerOnly")
	method void LoadedUserData()
		-- 데이터 로드 완료 후 클라이언트에 모든 테이블 데이터 동기화
		self:SetTableClient("equiped", _UtilLogic:TableToString(self.equiped), self.Entity.OwnerId)
		self:SetTableClient("haveEquipment", _UtilLogic:TableToString(self.haveEquipment), self.Entity.OwnerId)
		self:SetTableClient("TownAdmission", _UtilLogic:TableToString(self.TownAdmission), self.Entity.OwnerId)
		self:SetTableClient("TownProgress", _UtilLogic:TableToString(self.TownProgress), self.Entity.OwnerId)
	end

	@ExecSpace("ServerOnly")
	method void OnMapEnter(any enteredMap)
		-- 맵 입장시 유적 방문 기록 갱신 및 가이드 재생
		-- 유적 방문 기록
		if string.sub(enteredMap.Name, 1, 5) == "Mine9" then
			local currentHSStage = tonumber(string.sub(enteredMap.Name, -1, -1))
			
			if currentHSStage >= self.HistoricSiteRecord then
				self.HistoricSiteRecord = currentHSStage
			end
		end
		
		-- 유적지(마을) 방문시 가이드 재생
		if string.sub(enteredMap.Name, 1, 5) == "Town9" then
			_TutorialGuide:PlayGuide(10, self.Entity.OwnerId)
		end
		
		self:ApplyPlayerStatus()
	end

