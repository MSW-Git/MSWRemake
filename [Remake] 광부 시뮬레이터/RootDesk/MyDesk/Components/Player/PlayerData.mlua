	@ExecSpace("Server")
	method void PurchaseEquipmentBundle(number filterIdx, string checkedTableStr)
		-- 선택된 장비들을 한번에 번들 구매 처리
		local checkedList = _UtilLogic:StringToTable(checkedTableStr)
		local equipmentTable = _DataService:GetTable("Equipment")
		-------------------------------------------------------
		-- 조건검증 : 비용, 보유여부
		local totalCost = 0
		for i=1, 40 do
			if checkedList[i] == true then
				local idx = 40*(filterIdx-1) + i
		
				if self.haveEquipment[idx] == true then
					log("이미 보유중인 장비 인덱스가 번들구매에 포함되어 있습니다")
					return
				end
					
				local cost = equipmentTable:GetCell(i, 1)
				totalCost = totalCost + tonumber(cost)
			end
		end
		
		if totalCost > self.Money then
			log("비용 초과 오류입니다")
			return
		end
		
		if #checkedList < 1 then
			log("구매 수량이 0 입니다")
			return
		end
		-------------------------------------------------------
		-- 구매 처리
		for i=1, 40 do
			if checkedList[i] == true then
				local idx =  40*(filterIdx-1) + i 
				local cost = tonumber(equipmentTable:GetCell(i, 1))
				
				self.Money = self.Money - cost
				self.haveEquipment[idx] = true
			end	
		end
		
		--log("purchased successfully!")
		self:SetTableClient("haveEquipment", _UtilLogic:TableToString(self.haveEquipment), self.Entity.OwnerId)
		-------------------------------------------------------
		-- 연출 실행
		self:PlayDirection_EquipmentBundlePurchase(self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void PlayDirection_EquipmentBundlePurchase()
		-- 장비 번들 구매 완료 연출을 재생
		_EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop").EquipmentShopUI:PlayPurchaseBundleDirection()
	end

	@ExecSpace("Server")
	method void UseCharonsBoat()
		-- 카론의 배 사용 - 펫 알을 소모해 모든 마을과 장비를 해금하는 치트 기능
		------------------------------------------------------------------------------------------
		-- 검증
		------------------------------------------------------------------------------------------
		-- 현재 마을이 마을1이 아니면 이용 불가
		if self.Entity.CurrentMapName ~= "Town" then
			return
		end
		
		-- 건설하지 않았다면 이용 불가
		if self.Entity.PlayerConstruction.haveItems[2] < 2 then
			return
		end
		
		-- 펫 알이 없다면 이용 불가
		if self.PetEgg < 1 then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("/ui/PetShopGroup/PetShop/WarningPopup/Panel/Message", self.Entity.OwnerId)
			return
		end
		------------------------------------------------------------------------------------------
		------------------------------------------------------------------------------------------
		-- 진행시켜
		------------------------------------------------------------------------------------------
		-- 펫 알 소모
		self.PetEgg = self.PetEgg - 1
		
		-- 모든 마을 이동 권한 해금
		for i=1, 10 do
			self.TownAdmission[i] = true
			self.TownProgress[i] = true
		end
		
		-- 모든 장비 획득
		for i=1, 160 do
			self.haveEquipment[i] = true
		end
		
		-- 텔레포트
		_TeleportService:TeleportToEntityPath(self.Entity, "/maps/Town10/RoadArrow")
		------------------------------------------------------------------------------------------
		------------------------------------------------------------------------------------------
		-- 동기화
		------------------------------------------------------------------------------------------
		self:SetTableClient("TownAdmission", _UtilLogic:TableToString(self.TownAdmission), self.Entity.OwnerId)
		self:SetTableClient("TownProgress", _UtilLogic:TableToString(self.TownProgress), self.Entity.OwnerId)
		self:SetTableClient("haveEquipment", _UtilLogic:TableToString(self.haveEquipment), self.Entity.OwnerId)
		------------------------------------------------------------------------------------------
		------------------------------------------------------------------------------------------
	end

end