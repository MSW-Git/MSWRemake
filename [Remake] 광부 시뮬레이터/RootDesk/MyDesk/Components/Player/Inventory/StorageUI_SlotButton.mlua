@Component
script StorageUI_SlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 창고 슬롯 버튼 클릭 시 상세 정보 팝업 표시 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		local storageUIComponent = _EntityService:GetEntityByPath("/ui/InventoryGroup/Storage").StorageUI
		
		storageUIComponent:ShowDetailPopup(idx)
	end

end