	@EventSender("LocalPlayer")
	handler HandleLocalPlayerMapEnterEvent(LocalPlayerMapEnterEvent event)
		-- Parameters
		local EnteredMapType = event.EnteredMapType
		--------------------------------------------------------
		self:SetFilterIdx(1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5e24a5ec-ab44-48be-ab78-2abc5094f3a3")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx_row = math.floor(((self.showDetailIdx-1)%40)+1)
		local idx_col = math.floor(((self.showDetailIdx-1)/40)+1)
		
		if idx_row <= 0 or idx_col <= 0 then
			return
		end
		
		if self.filterIdx == 2 then
			_UserService.LocalPlayer.PlayerData:ChangeEquipment(idx_col, idx_row)
		elseif self.filterIdx == 3 then
			_UserService.LocalPlayer.PlayerChair:ChangeEquipedItem(self.showDetailIdx)
		elseif self.filterIdx == 4 then
			_UserService.LocalPlayer.PlayerPet:ChangeEquipedPet(self.showDetailIdx)
		end
		
		_UIToast:ShowMessage(_LocalizationService:GetText("Message_Equiped"))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "8b3f1245-43ec-474e-995f-08a71c232043")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.showDetailIdx >=1 and self.showDetailIdx <=4 then
			_UserService.LocalPlayer.PlayerData:ChangeEquipment(self.showDetailIdx, 0)
		
		elseif self.showDetailIdx == 5 then
			local message = _LocalizationService:GetText("Message_CannotUnequip")
			_UserService.LocalPlayer.PlayerChair:ChangeEquipedItem(0)
		
		elseif self.showDetailIdx == 6 then
			_UserService.LocalPlayer.PlayerPet:ChangeEquipedPet(0)
		end
		
		_UIToast:ShowMessage(_LocalizationService:GetText("Message_Unequiped"))
		
		
		-- detail Info 패널을 닫음
		_EntityService:GetEntity("8ac99920-813b-4ebe-a280-dc3d42b7a004"):SetEnable(false)
	end

	@EventSender("Entity", "62073ef5-28fb-4fb3-838a-be1b4d484c4d")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerRelic:OpenRelicBox(self.showDetailIdx)
		
		Entity.ButtonComponent.Enable = false
		local enableButton = function()
			if _UserService.LocalPlayer.PlayerRelic.havingRelicBoxNum[self.showDetailIdx] ~= nil and -- 뽑기하는 사이에 다른 슬롯(상자가 아닌 유물... 등)을 눌렀을 가능성 존재
				_UserService.LocalPlayer.PlayerRelic.havingRelicBoxNum[self.showDetailIdx] > 0 then
				Entity.ButtonComponent.Enable = true
			end
		end
		_TimerService:SetTimerOnce(enableButton, 1.5)
	end

end