@Component
script EquipmentStorageUI_NormalSlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 일반 장비 슬롯 버튼 클릭 시 상세 정보 표시 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage").EquipmentStorageUI:ShowNormalEquipmentDetailInfo(idx)
	end

end