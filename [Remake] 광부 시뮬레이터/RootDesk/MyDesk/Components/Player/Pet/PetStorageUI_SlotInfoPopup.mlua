@Component
script PetStorageUI_SlotInfoPopup extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 펫 정보 팝업 버튼 클릭 시 해당 슬롯의 상세 정보를 표시하도록 요청
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local slotIdx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/PetShopGroup/PetStorage").PetStorageUI:ShowDetailInfo(slotIdx)
	end

end