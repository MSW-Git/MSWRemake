@Component
script PlayerRelic extends Component

	property SyncTable<number> HavingDirtyItem

	property SyncTable<number> HavingPurifiedItem

	property SyncTable<boolean> RegistrationInfo

	property number ProbAcquiringBonusRelic = 0

	@Sync
	property number relicBoxBuyingCount = 0

	property SyncTable<number> havingRelicBoxNum

	method void OnBeginPlay()
		-- 플레이어 유물 시스템 초기화 및 테이블 설정
		self._T.tableList = {
			HavingDirtyItem = self.HavingDirtyItem, 
			HavingPurifiedItem = self.HavingPurifiedItem, 
			RegistrationInfo = self.RegistrationInfo, 
			havingRelicBoxNum = self.havingRelicBoxNum}
		
		self._T.tableType = {
			HavingDirtyItem = "number", 
			HavingPurifiedItem = "number", 
			RegistrationInfo = "boolean", 
			havingRelicBoxNum = "number"}
		
		self:ClearAllProperty()
	end

	@ExecSpace("ServerOnly")
	method void AddRelic(boolean isDirty, number idx)
		-- 플레이어에게 유물을 추가하고 보너스 확률 적용
		local amount = 1
		
		local randomValue = _UtilLogic:RandomDouble()
		if randomValue < self.ProbAcquiringBonusRelic then
			amount = 2
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_Gain1MoreRelic", self.Entity.OwnerId)
		end
		
		--local relicTable = _DataService:GetTable("Relic")
		--local relicName = relicTable:GetCell(idx, 1)
		
		if isDirty == true then
			self.HavingDirtyItem[idx] = self.HavingDirtyItem[idx] + amount
			self:SetTableElementClient("HavingDirtyItem", idx, tostring(self.HavingDirtyItem[idx]), self.Entity.OwnerId)	
			--_UIGetLog:AddLog("[유물] 정화되지 않은 "..relicName.."을(를) 획득했습니다!", Color.magenta, self.Entity.OwnerId)
		else 
			self.HavingPurifiedItem[idx] = self.HavingPurifiedItem[idx] + amount
			self:SetTableElementClient("HavingPurifiedItem", idx, tostring(self.HavingPurifiedItem[idx]), self.Entity.OwnerId)	
			--_UIGetLog:AddLog("[유물] "..relicName.."을(를) 획득했습니다!", Color.magenta, self.Entity.OwnerId)
		end
	end

	@ExecSpace("Server")
	method void Purifying()
		-- 더러운 유물을 정화하여 사용 가능한 유물로 변환
		local count = 0
		for i=1, _DataService:GetRowCount("Relic") do
			-- 게임 첫 시작시 에러 방지
			if self.HavingDirtyItem[i] == nil then
				return
			end
			
			if self.HavingDirtyItem[i] > 0 then
				self.HavingPurifiedItem[i] = self.HavingPurifiedItem[i] + self.HavingDirtyItem[i]
				count = count + self.HavingDirtyItem[i]
				self.HavingDirtyItem[i] = 0
				
				self:SetTableElementClient("HavingDirtyItem", i, tostring(self.HavingDirtyItem[i]), self.Entity.OwnerId)
				self:SetTableElementClient("HavingPurifiedItem", i, tostring(self.HavingPurifiedItem[i]), self.Entity.OwnerId)
			end
		end
		
		if count > 0 then
			_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Message_PurifiedInTown", {count}, self.Entity.OwnerId)
			_TutorialGuide:AddCondition(8, self.Entity.OwnerId)
			_UIAlarmMarker:SetEnableMarker("relic", true, self.Entity.OwnerId)
		end
	end

	@ExecSpace("Server")
	method void RegisterToBook(number slotIdx, string message)
		-- 유물을 유물북에 등록하고 필요한 재료를 소모
		local relicSetTable = _DataService:GetTable("RelicSet")
		--log("slotIdx = ", slotIdx)
		
		-- 조건 체크
		local rowIdx = math.floor((slotIdx-1)/4) + 1
		local columnIdx = math.floor((slotIdx-1)%4)+1
		
		local targetIdx = tonumber(relicSetTable:GetCell(rowIdx, columnIdx*2))
		local upgradeNum = tonumber(relicSetTable:GetCell(rowIdx, columnIdx*2 + 1))
		
		
		if self.HavingPurifiedItem[targetIdx] < upgradeNum then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_ThereIsNoRelicTryingRegist", self.Entity.OwnerId)
			return
		end
		
		
		-- 등록하면서 개수 소모
		self.HavingPurifiedItem[targetIdx] = self.HavingPurifiedItem[targetIdx] - upgradeNum
		self.RegistrationInfo[slotIdx] = true
		
		
		-- 클라이언트에 반영
		self:SetTableElementClient("HavingPurifiedItem", targetIdx, tostring(self.HavingPurifiedItem[targetIdx]), self.Entity.OwnerId)
		self:SetTableElementClient("RegistrationInfo", slotIdx, tostring(self.RegistrationInfo[slotIdx]), self.Entity.OwnerId)
		_UIToast:ShowMessage(message, self.Entity.OwnerId)
		
		
		-- 로그 출력
		for i=1, #self.RegistrationInfo do
			--log("registration[",i,"] = ", self.RegistrationInfo[i])
		end
	end

	@ExecSpace("Server")
	method void ClearDirtyItems()
		-- 사망했을 경우 실행하는 함수입니다.
		
		for i=1, #self.HavingDirtyItem do
			self.HavingDirtyItem[i] = 0
		end
		
		self:ClearTableClient("HavingDirtyItem", "0", #self.HavingDirtyItem, self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void SetTableClient(string tableName, string strValue)
		-- 서버에서 클라이언트로 테이블 전체 데이터 동기화
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local tableValue = _UtilLogic:StringToTable(strValue)
		
		for index, value in ipairs(tableValue) do
			t[index] = value
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void SetTableElementClient(string tableName, number index, string value)
		-- 서버에서 클라이언트로 테이블의 특정 요소만 동기화
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedValue = _ParsingLogic:ParseByType(value, self._T.tableType[tableName])
		t[index] = parsedValue
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ClearTableClient(string tableName, string initValue, number tableCount)
		-- 클라이언트에서 테이블을 초기값으로 모두 초기화
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedInitValue = _ParsingLogic:ParseByType(initValue, self._T.tableType[tableName])
		for index=1, tableCount do
			t[index] = parsedInitValue
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ChangedTable(string name)
		-- 테이블 변경 시 관련 UI들을 새로고침하여 화면 업데이트
		--_EntityService:GetEntity("71a64caf-bdc5-48a3-95f2-e3b201d90948").RelicBookUI:RefreshUI()
		if name == "RegistrationInfo" then
			_EntityService:GetEntity("71a64caf-bdc5-48a3-95f2-e3b201d90948").RelicBookUI:RefreshUI()
			_EntityService:GetEntity("71a64caf-bdc5-48a3-95f2-e3b201d90948").RelicBookUI:RefreshStatusUI()
			self.Entity.PlayerData:ApplyPlayerStatus()
			
		end
		
		
		if name == "HavingDirtyItem" or name == "HavingPurifiedItem" then
			_EntityService:GetEntityByPath("/ui/InventoryGroup/Storage").StorageUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/LegacySystemGroup/RelicBin").RelicBinUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/RelicMergeGroup/RelicMergeShop").RelicMergeShopUI:RefreshMainPanel()
		end
		
		if name == "havingRelicBoxNum" then
			_EntityService:GetEntityByPath("/ui/InventoryGroup/Storage").StorageUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/GemShopGroup/GemShop").GemShopUI:RefreshUI()
		end
	end

	@ExecSpace("ServerOnly")
	method void ClearAllProperty()
		-- 모든 유물 관련 속성을 초기값으로 리셋
		local relicTable = _DataService:GetTable("Relic")
		local relicSetTable = _DataService:GetTable("RelicSet")
		-------------------
		for i=1, relicTable:GetRowCount() do
			self.HavingDirtyItem[i] = 0
			self.HavingPurifiedItem[i] = 0
		end
		
		for i=1, relicSetTable:GetRowCount() do
			for j=1, 4 do
				self.RegistrationInfo[(i-1)*4+j] = false
			end
		end
		
		for i=1, 2 do
			self.havingRelicBoxNum[i] = 0
		end
		
		--self.relicBoxBuyingCount = 0
		
		for tableName, _ in ipairs(self._T.tableList) do
			self:ClearTableClient(tableName, tostring(_ParsingLogic:GetInitValueByType(self._T.tableType[tableName])), #self._T.tableType[tableName], self.Entity.OwnerId)
		end
	end

	@ExecSpace("ServerOnly")
	method void LoadedUserData(string havingPurifiedRelicStr, string registrationStr, string havingRelicBoxNumStr)
		-- 유물 보유 정보 갱신
		local relicCount = _DataService:GetRowCount("Relic")
		if isvalid(havingPurifiedRelicStr) == false then
			for i=1, relicCount do
				self.HavingPurifiedItem[i] = 0
			end
		else 
			local havingPurifiedRelic = _UtilLogic:StringToTable(havingPurifiedRelicStr)
			for i=1, relicCount do
				if havingPurifiedRelic[i] == nil then
					self.HavingPurifiedItem[i] = 0
				else 
					self.HavingPurifiedItem[i] = tonumber(havingPurifiedRelic[i])
				end
			end
		end
		----------------------------------
		-- 유물 등록 정보 갱신
		local relicSetCount = _DataService:GetRowCount("RelicSet")
		local registCount = relicSetCount * 4
		if isvalid(registrationStr) == false then
			for i=1, registCount do
				self.RegistrationInfo[i] = false
			end
		else
			local registration = _UtilLogic:StringToTable(registrationStr)
			for i=1, registCount do
				if registration[i] == nil or registration[i] == false then
					self.RegistrationInfo[i] = false
				elseif registration[i] == true then
					self.RegistrationInfo[i] = true
				else 
					log("알 수 없는 예외 : "..registration[i])
					self.RegistrationInfo[i] = false
				end
			end
		end
		----------------------------------
		-- 유물상자 보유정보 갱신
		if isvalid(havingRelicBoxNumStr) == false then
			for i=1, 2 do
				self.havingRelicBoxNum[i] = 0
			end
		else 
			local havingRelicBoxNumTable = _UtilLogic:StringToTable(havingRelicBoxNumStr)
			
			for i=1, 2 do
				if havingRelicBoxNumTable[i] == nil then
					self.havingRelicBoxNum[i] = 0
				else 
					self.havingRelicBoxNum[i] = havingRelicBoxNumTable[i]
				end
			end
		end
		----------------------------------
		self:SetTableClient("HavingPurifiedItem", _UtilLogic:TableToString(self.HavingPurifiedItem), self.Entity.OwnerId)
		self:SetTableClient("RegistrationInfo", _UtilLogic:TableToString(self.RegistrationInfo), self.Entity.OwnerId)
		self:SetTableClient("havingRelicBoxNum", _UtilLogic:TableToString(self.havingRelicBoxNum), self.Entity.OwnerId)
	end

	@ExecSpace("Server")
	method void SyncDirtyItem()
		-- 더러운 유물 데이터를 클라이언트와 동기화
		self:SetTableClient("HavingDirtyItem", _UtilLogic:TableToString(self.HavingDirtyItem), self.Entity.OwnerId)
	end

	@ExecSpace("ServerOnly")
	method void OnMapEnter(any enteredMap)
		-- 맵 진입 시 마을 지역에서 유물 자동 정화 수행
		if string.sub(enteredMap.Name, 1, 4) == "Town" then
			self:Purifying()
		end
	end

	@ExecSpace("Server")
	method void BuyRelicBox()
		-- 유물상자를 구매하여 인벤토리에 추가
		local price = 80000000000
		
		-- 조건 검증 1 : 보유 금액 
		if self.Entity.PlayerData.Money < price then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_NoEnoughMoney", self.Entity.OwnerId)
			return
		end
		------------------------------------------------------
		-- 구매 처리
		--self.relicBoxBuyingCount = self.relicBoxBuyingCount + 1
		self.havingRelicBoxNum[2] = self.havingRelicBoxNum[2] + 1
		self.Entity.PlayerData.Money = self.Entity.PlayerData.Money - price
		
		_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_BoughtRelicBox", self.Entity.OwnerId)
		------------------------------------------------------
		-- 테이블 관련 처리
		self:SetTableElementClient("havingRelicBoxNum", 2, tostring(self.havingRelicBoxNum[2]), self.Entity.OwnerId)
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- 속성 동기화 시 유물상자 공장 UI 업데이트
		if name == "relicBoxBuyingCount" then	
			local relicBoxGachaShopUI = _EntityService:GetEntityByPath("/ui/RelicGachaShopGroup/RelicGachaShop")
			relicBoxGachaShopUI.RelicGachaShopUI:RefreshUI()
		end
	end

	@ExecSpace("Server")
	method void OpenRelicBox(number boxIdx)
		-- 조건 검증
		if self.havingRelicBoxNum[boxIdx] < 1 then
			return
		end
		-----------------------------------
		-- 개수 차감
		self.havingRelicBoxNum[boxIdx] = self.havingRelicBoxNum[boxIdx] - 1
		-----------------------------------
		-- 확률표 가져오기
		local probTableDataSet = _DataService:GetTable("RelicBoxProbability")
		local probTable = {}
		for i=1, 4 do
			if i == 1 then
				table.insert(probTable, tonumber(probTableDataSet:GetCell(boxIdx, i+1)))
			else 
				table.insert(probTable, probTable[i-1]+tonumber(probTableDataSet:GetCell(boxIdx, i+1)))
			end
		end
		-----------------------------------
		-- 확률 적용
		local randomValue = _UtilLogic:RandomDouble()
		local targetGrade = 1
		for i=1, 4 do
			if randomValue <= probTable[i] then
				targetGrade = i
				break
			end
		end 
		
		local gradeText = {"Grade_2", "Grade_3", "Grade_4", "Grade_5"}
		
		
		
		-- 유물 선택 (등록 불가한 유물은 뜨지 않음)
		local relicTable = _DataService:GetTable("Relic")
		local targetRelicIdxTable = {}
		for i=1, relicTable:GetRowCount() do
			local grade = relicTable:GetCell(i, 4)
			if grade == gradeText[targetGrade] then
				if self:IsPossibleRegistToBook(i) == true then
					table.insert(targetRelicIdxTable, i)
				end
			end
		end
		
		-- 모든 유물이 등록된 상태면 아무거나
		if #targetRelicIdxTable == 0 then
			for i=1, relicTable:GetRowCount() do
				local grade = relicTable:GetCell(i, 4)
				if grade == gradeText[targetGrade] then
					table.insert(targetRelicIdxTable, i)
				end
			end
		end
		
		
		local randomTableIdx = _UtilLogic:RandomIntegerRange(1, #targetRelicIdxTable)
		local selectedRelicIdx = targetRelicIdxTable[randomTableIdx]
		
		-----------------------------------
		-- 데이터 반영
		--self:AddRelic(false, selectedRelicIdx)
		self.HavingPurifiedItem[selectedRelicIdx] = self.HavingPurifiedItem[selectedRelicIdx] + 1
		self:SetUI_RelicBoxOpenResult(selectedRelicIdx, boxIdx, self.Entity.OwnerId)
		-----------------------------------
		-- 클라이언트 테이블에 반영
		self:SetTableElementClient("havingRelicBoxNum", boxIdx, tostring(self.havingRelicBoxNum[boxIdx]), self.Entity.OwnerId)
		self:SetTableElementClient("HavingPurifiedItem", selectedRelicIdx, tostring(self.HavingPurifiedItem[selectedRelicIdx]), self.Entity.OwnerId)
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	@ExecSpace("Client")
	method void SetUI_RelicBoxOpenResult(number idx, number boxIdx)
		-- 유물상자 오픈 결과를 UI에 표시하고 팝업 설정
		local popup = _EntityService:GetEntityByPath("/ui/InventoryGroup/RelicBoxOpenResultPopup")
		----------------------------------------------------------------------
		----------------------------------------------------------------------
		-- 사운드를 재생합니다.
		_SoundService:PlaySound("f279f3cf146a49df860ab841d58a6b0d", 1)
		
		-- 변경할 엔티티를 불러옵니다.
		local panel = popup:GetChildByName("Panel")
		local nameUI = panel:GetChildByName("Name")
		local iconUI = panel:GetChildByName("Icon")
		local gradeUI = panel:GetChildByName("Grade")
		local FlavorTextUI = panel:GetChildByName("FlavorText")
		
		-- 반영할 정보를 불러옵니다.
		local relicTable = _DataService:GetTable("Relic")
		local name = relicTable:GetCell(idx, 1)
		local icon = relicTable:GetCell(idx, 2)
		local flavorText = relicTable:GetCell(idx, 3)
		local grade = relicTable:GetCell(idx, 4)
		
		-- 엔티티에 정보를 반영합니다.
		nameUI.TextComponent.Text = _LocalizationService:GetText(name)
		iconUI.SpriteGUIRendererComponent.ImageRUID = icon
		FlavorTextUI.TextComponent.Text = _LocalizationService:GetText(flavorText)
		gradeUI.TextComponent.Text = _LocalizationService:GetText(grade)
		
		local gradeTextColor = {	"#AFDC6E", "#4dd4EC", "#A66AFF", "#F64343" }
		local gradeNum = tonumber(string.sub(grade, -1, -1))
		gradeUI.TextComponent.FontColor = Color.FromHexCode(gradeTextColor[gradeNum-1])
		nameUI.TextComponent.FontColor = Color.FromHexCode(gradeTextColor[gradeNum-1])
		----------------------------------------------------------------------
		----------------------------------------------------------------------
		popup.Enable = true
	end

	@ExecSpace("Server")
	method void GetRelicBox(number idx)
		-- 지정된 인덱스의 유물상자를 인벤토리에 직접 추가
		self.Entity.PlayerRelic.havingRelicBoxNum[idx] = self.Entity.PlayerRelic.havingRelicBoxNum[idx] + 1
		
		self:SetTableElementClient("havingRelicBoxNum", idx, tostring(self.Entity.PlayerRelic.havingRelicBoxNum[idx]), self.Entity.OwnerId)
	end

	@ExecSpace("Server")
	method number Merge(SyncTable<number> materials)
		-- 보유량 검증
		local useTable = {}
		for i=1, 90 do
			useTable[i] = 0
		end
		for i=1, 4 do
			useTable[materials[i]] = useTable[materials[i]] + 1
		end
		for i=1, 90 do
			if (self.HavingPurifiedItem[i] - useTable[i]) < 0 then
				log("보유량 검증에서 캔슬")
				return
			end
		end
		
		-- 등급 검증 : 모든 재료의 등급이 일치하는지?
		local relicTable = _DataService:GetTable("Relic")
		local gradeTable = {}
		for i=1, 4 do
			table.insert(gradeTable, relicTable:GetCell(materials[i], 4))
		end
		
		for i=1, 3 do
			if gradeTable[i+1] ~= gradeTable[1] then
				log("등급 검증에서 캔슬")
				return 2 -- 등급 검증에서 캔슬됨
			end
		end
		--------------------------
		-- 재료 소모
		for i=1, 4 do
			self.HavingPurifiedItem[materials[i]] = self.HavingPurifiedItem[materials[i]] - 1
		end
		
		
		-- 결과 결정
		local targetGrade = "Grade_3"
		if gradeTable[1] == "Grade_3" then 
			targetGrade = "Grade_4"
		elseif gradeTable[1] == "Grade_4" or gradeTable[1] == "Grade_5" then
			targetGrade = "Grade_5"
		end
		
		-- 등록할 수 있는 유물만 획득합니다.
		local targetTable = {}
		for i=1, relicTable:GetRowCount() do
			local grade = relicTable:GetCell(i, 4)
			if grade == targetGrade then
				if self:IsPossibleRegistToBook(i) == true then
					table.insert(targetTable, i)
				end
			end
		end
		
		-- 등록할 수 있는 유물이 없다면(=모든 도감이 등록된 상태라면), 해당 등급의 무작위 아이템을 드롭합니다.
		if #targetTable == 0 then
			for i=1, relicTable:GetRowCount() do
				local grade = relicTable:GetCell(i, 4)
				if grade == targetGrade then
					table.insert(targetTable, i)
				end
			end
		end
		
		local randIdx = _UtilLogic:RandomIntegerRange(1, #targetTable)
		local resultItem = targetTable[randIdx]
		
		
		-- 개수 증가
		self.HavingPurifiedItem[resultItem] = self.HavingPurifiedItem[resultItem] + 1
		
		
		-- 팝업으로 보냄
		self:SetMergeResultPopup(resultItem, self.Entity.OwnerId)
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
		
		-- 클라와 데이터 동기화
		self:SetTableClient("HavingPurifiedItem", _UtilLogic:TableToString(self.HavingPurifiedItem), self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void SetMergeResultPopup(number relicIdx)
		-- 유물 합성 결과를 팝업 UI에 표시하고 등급에 따른 스타일 설정
		local relicTable = _DataService:GetTable("Relic")
		
		local resultPanel = _EntityService:GetEntityByPath("/ui/RelicMergeGroup/RelicMergeShop/ResultPanel")
		local resultPopup = resultPanel:GetChildByName("Popup")
		
		local nameUI = resultPopup:GetChildByName("Name")
		local iconbackUI = resultPopup:GetChildByName("IconBack")
		local iconUI = resultPopup:GetChildByName("icon")
		local flavorUI = resultPopup:GetChildByName("FlavorText") 
		local gradeUI = resultPopup:GetChildByName("Grade")
		
		
		local name = _LocalizationService:GetText(relicTable:GetCell(relicIdx, 1))
		local icon = relicTable:GetCell(relicIdx, 2)
		local flavorText = _LocalizationService:GetText(relicTable:GetCell(relicIdx, 3))
		local gradeText = _LocalizationService:GetText(relicTable:GetCell(relicIdx, 4))
		
		nameUI.TextComponent.Text = name
		iconUI.SpriteGUIRendererComponent.ImageRUID = icon
		flavorUI.TextComponent.Text = flavorText
		gradeUI.TextComponent.Text = gradeText 
		if relicTable:GetCell(relicIdx, 4) == "Grade_3" then
			iconbackUI.SpriteGUIRendererComponent.ImageRUID = "db5d4ddb2d3f4c659fcb160df0fb1cab"
			nameUI.TextComponent.FontColor = Color.FromHexCode("#4DD4EC")
			gradeUI.TextComponent.FontColor = Color.FromHexCode("#4DD4EC")
			
		elseif relicTable:GetCell(relicIdx, 4) == "Grade_4" then
			iconbackUI.SpriteGUIRendererComponent.ImageRUID = "23df4a65508f42afacec3fb533735e80"
			nameUI.TextComponent.FontColor = Color.FromHexCode("#A66AFF")
			gradeUI.TextComponent.FontColor = Color.FromHexCode("#A66AFF")
			
		elseif relicTable:GetCell(relicIdx, 4) == "Grade_5" then
			iconbackUI.SpriteGUIRendererComponent.ImageRUID = "3065e9c1bc364495bf1ce2abc2e78dcd"
			nameUI.TextComponent.FontColor = Color.FromHexCode("#F64343")
			gradeUI.TextComponent.FontColor = Color.FromHexCode("#F64343")
		end
	end

	@ExecSpace("Server")
	method void RecycleToLegacyCoin()
		-- 보유 중인 모든 유물을 등급별 점수로 환계하여 레거시 코인으로 전환
		local relicTable = _DataService:GetTable("Relic")
		
		-- 검증
		local havingRelicCount = {0, 0, 0, 0}
		for i=1, relicTable:GetRowCount() do
			local grade = tonumber(string.sub(relicTable:GetCell(i, "Grade"), 7, -1))
			local havingAmount = self.HavingPurifiedItem[i]
			
			havingRelicCount[grade-1] = havingRelicCount[grade-1] + havingAmount
		end
		
		local result = {0, 0, 0, 0}
		local totalAmount = 0
		for i=1, 4 do
			result[i] = havingRelicCount[i] * 4^(i-1)
			totalAmount = totalAmount + result[i]
		end
		
		if totalAmount == 0 then
			log("보상 개수가 0인데 재활용 시도함")
			return
		end
		-----------------------------------------------------------------------
		for i=1, relicTable:GetRowCount() do
			self.HavingPurifiedItem[i] = 0
		end
		
		self.Entity.PlayerStorage:AddCurrencyItems(7, totalAmount, true)
		
		-- 동기화
		self:SetTableClient("HavingPurifiedItem", _UtilLogic:TableToString(self.HavingPurifiedItem), self.Entity.OwnerId)
		
		-- 결과화면
		self:SetRecycleResultUI(totalAmount, self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void SetRecycleResultUI(number resultAmount)
		-- 유물 재활용 결과를 UI에 표시하고 팝업 활성화
		local resultPanel = _EntityService:GetEntityByPath("/ui/LegacySystemGroup/RelicBinResult")
		resultPanel.Enable = true
		
		_EntityService:GetEntityByPath("/ui/LegacySystemGroup/RelicBinResult/Popup/Amount").TextComponent.Text = "× ".._ThousandsSeparator:Separate(math.floor(resultAmount))
	end

	method boolean IsPossibleRegistToBook(number relicIdx)
		-- 지정된 유물이 유물북에 등록 가능한지 여부를 검사
		if relicIdx == nil or relicIdx < 1 or relicIdx > 90 then
			return false
		end
		
		-- 유물 도감에 등록 가능한지 여부를 확인, 가능한게 확인되면 즉시 true를 반환합니다.
		local relicSetTable = _DataService:GetTable("RelicSet")
		local registInfo = self.RegistrationInfo
		
		
		-- 모든 세트를 순회하면서 검사합니다
		for i=1, relicSetTable:GetRowCount() do
			-- 각 재료의 1~4번 재료가 현재 보려는 재료와 일치하는지 검사합니다.
			for j=1, 4 do
				local registMaterialIdx = tonumber(relicSetTable:GetCell(i, j*2))
				
				-- 일치할 경우, 해당 슬롯에 등록되었는지 여부를 확인합니다.
				if registMaterialIdx == relicIdx then
					local registedInfo = registInfo[(i-1)*4+j]
					if registedInfo == false then
						return true
					end
				end
			end
		end
		
		-- 등록 가능한 슬롯을 찾지 못했다면 false를 리턴합니다.
		return false
	end

	@ExecSpace("Server")
	method void AutoMerge(number grade)
		-- grade : 소모하는 재료의 등급. 일반(1), 고급(2), 희귀(3), 전설(4) 로 넘겨받음
		
		local relicTable = _DataService:GetTable("Relic")
		
		-- 등록 가능한 재료 수 및 결과 개수를 먼저 계산합니다.
		local havingRelic = self.HavingPurifiedItem
		local relicCount = {40, 17, 17, 16}
		local materialCount = {}
		local gradeMaterialCount = {0, 0, 0, 0}
		
		for i=1, relicTable:GetRowCount() do
			if self:IsPossibleRegistToBook(i) == false then
				materialCount[i] = havingRelic[i]
				
				if i <= relicCount[1] then
					gradeMaterialCount[1] = gradeMaterialCount[1] + materialCount[i]
					
				elseif i <= relicCount[1] + relicCount[2] then
					gradeMaterialCount[2] = gradeMaterialCount[2] + materialCount[i]
					
				elseif i <= relicCount[1] + relicCount[2] + relicCount[3] then
					gradeMaterialCount[3] = gradeMaterialCount[3] + materialCount[i]
					
				else
					gradeMaterialCount[4] = gradeMaterialCount[4] + materialCount[i]
				end
			else
				materialCount[i] = 0
			end
		end
		
		if gradeMaterialCount[grade] < 4 then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("LackOfAmount", self.Entity.OwnerId)
			return
		end
		------------------------------------------------------------------------
		-- 재료를 먼저 소모합니다.
		local relicIdx = {0, 40, 57, 74, 90}
		local useRelicAmount = gradeMaterialCount[grade] - gradeMaterialCount[grade]%4 -- 소모해야 하는 타겟 수량
		local usedRelicAmount = 0
		local newRelicAmount = 0
		for i=relicIdx[grade]+1, relicIdx[grade+1] do
			-- 목표 수량을 충족했다면 반복문 종료
			if usedRelicAmount == useRelicAmount then
				break
			end
			
			if materialCount[i] == 0 then
				-- 재료가 0개라면 아무것도 하지 않음
			elseif (usedRelicAmount + materialCount[i]) > useRelicAmount then
				local currentUsingAmount = useRelicAmount - usedRelicAmount
				self.HavingPurifiedItem[i] = self.HavingPurifiedItem[i] - currentUsingAmount
				usedRelicAmount = usedRelicAmount + currentUsingAmount
			else
				usedRelicAmount = usedRelicAmount + self.HavingPurifiedItem[i]
				self.HavingPurifiedItem[i] = 0
			end
		end
		------------------------------------------------------------------------
		-- 결과 풀을 먼저 결정합니다.
		local targetGrade = string.format("Grade_%d", grade+2)
		if targetGrade == "Grade_6" then targetGrade = "Grade_5" end 
		
		
		-- 등록할 수 있는 유물만 획득합니다.
		local targetTable = {}
		for i=1, relicTable:GetRowCount() do
			local gradeText = relicTable:GetCell(i, 4)
			if gradeText == targetGrade then
				if self:IsPossibleRegistToBook(i) == true then
					table.insert(targetTable, i)
				end
			end
		end
		
		-- 등록할 수 있는 유물이 없다면(=모든 도감이 등록된 상태라면), 해당 등급의 무작위 아이템을 드롭합니다.
		if #targetTable == 0 then
			for i=1, relicTable:GetRowCount() do
				local gradeText = relicTable:GetCell(i, 4)
				if gradeText == targetGrade then
					table.insert(targetTable, i)
				end
			end
		end
		------------------------------------------------------------------------
		-- 소모한 재료 개수에 맞춰 랜덤 획득합니다.
		newRelicAmount = usedRelicAmount/4
		local resultTable = {}
		for i=1, relicTable:GetRowCount() do
			resultTable[i] = 0
		end
		
		for i=1, newRelicAmount do
			local randIdx = _UtilLogic:RandomIntegerRange(1, #targetTable)
			local resultItem = targetTable[randIdx]
			self.HavingPurifiedItem[resultItem] = self.HavingPurifiedItem[resultItem] + 1
			resultTable[resultItem] = resultTable[resultItem] + 1
		end
		------------------------------------------------------------------------
		-- 데이터를 저장합니다.
		self.Entity.PlayerData:SaveData(1)
		------------------------------------------------------------------------
		-- 결과 UI를 쏩니다.
		self:SetAutoMergeResultUI(_UtilLogic:TableToString(resultTable), self.Entity.OwnerId)
		------------------------------------------------------------------------
		-- 클라이언트 동기화
		self:SetTableClient("HavingPurifiedItem", _UtilLogic:TableToString(self.HavingPurifiedItem), self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void SetAutoMergeResultUI(string resultTable)
		-- 자동 합성 결과를 유물 합성 상점 UI에 전달하여 결과 팝업 표시
		local relicMergeUI = _EntityService:GetEntityByPath("/ui/RelicMergeGroup/RelicMergeShop")
		relicMergeUI.RelicMergeShopUI:SetResultPopup(resultTable)
	end

end