@Component
script VoidItemStorageUI_SlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 공허 아이템 슬롯 버튼 클릭 시 해당 아이템의 상세 정보를 표시하도록 요청
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/VoidItemGroup/VoidItemStorage/VoidItemStorage_panel").VoidItemStorageUI:ShowSelectedItem(idx)
	end

end