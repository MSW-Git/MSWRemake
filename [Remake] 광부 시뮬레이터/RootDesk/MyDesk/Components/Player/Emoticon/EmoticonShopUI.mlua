@Component
script EmoticonShopUI extends Component

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- UI 갱신 요청 플래그 확인 및 처리
		if self._T.refreshUI then
			self:RefreshUI_Inner()
			self._T.refreshUI = false
		end
	end

	@ExecSpace("Client")
	method void RefreshUI()
		-- UI 갱신 플래그 설정
		self._T.refreshUI = true
	end

	@ExecSpace("Client")
	method void RefreshUI_Inner()
		-- 이모티콘 상점 UI 전체 갱신 (토큰, 버튼 상태)
		local emotTable = _DataService:GetTable("Emoticon")
		local emotNum = emotTable:GetRowCount()
		
		local haveFullPanel = _EntityService:GetEntity("24bc7e90-a6be-48c2-bb13-704307989428")
		local buyButton = _EntityService:GetEntity("4ce3b9b0-8e02-437f-9035-155d359259ef")
		
		local emotTokenNumUI = _EntityService:GetEntity("4d226aeb-2b9e-4e17-8f93-cd5ab1cbcc12")
		emotTokenNumUI.TextComponent.Text = string.format("%d", _UserService.LocalPlayer.PlayerEmoticon.EmotToken)
		
		local haveEmotData = _UserService.LocalPlayer.PlayerEmoticon.haveEmoticon
		for i=1, emotNum do
			if haveEmotData[i] == false then
				haveFullPanel.Enable = false
				
				if _UserService.LocalPlayer.PlayerEmoticon.EmotToken >= 1 then
					buyButton.ButtonComponent.Enable = true
				else 
					buyButton.ButtonComponent.Enable = false
				end
				
				return
			end
		end
		
		haveFullPanel.Enable = true
		buyButton.ButtonComponent.Enable = false
	end

	@ExecSpace("Client")
	method void SetGachaResultUI(number resultIdx)
		-- 가차 결과 UI 설정 및 표시
		local resultPanel = _EntityService:GetEntity("7cf50829-d526-442f-8ad2-c4e2b72bc7cc")
		
		local nameUI = resultPanel:GetChildByName("Name")
		local image = resultPanel:GetChildByName("EmotImage")
		
		local emotTable = _DataService:GetTable("Emoticon")
		local emotName = _LocalizationService:GetText(emotTable:GetCell(resultIdx, 1))
		local emotRUID = emotTable:GetCell(resultIdx, 2)
		local spriteLocalPosition = Vector2(tonumber(emotTable:GetCell(resultIdx, 3)), tonumber(emotTable:GetCell(resultIdx, 4)))
		
		nameUI.TextComponent.Text = emotName
		image.SpriteGUIRendererComponent.ImageRUID = emotRUID
		image.SpriteGUIRendererComponent.LocalPosition = spriteLocalPosition
		
		resultPanel.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 이모티콘 상점 UI 초기화
		
		
		-------------------------------------
		self:RefreshUI()
	end

	@EventSender("Entity", "4ce3b9b0-8e02-437f-9035-155d359259ef")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 이모티콘 구매 버튼 클릭 처리 (조건 검증 및 새 이모티콘 획득)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		-- 재화 체크
		if _UserService.LocalPlayer.PlayerEmoticon.EmotToken <= 0 then
			_UIToast:ShowMessage(_LocalizationService:GetText("Message_ThereAreNoEmotToken"))
			return
		end
		-------------------------------
		-- 전체 보유여부 체크
		local emotNum = _DataService:GetRowCount("Emoticon")
		local randomTargetTable = {}
		for i=1, emotNum do
			if _UserService.LocalPlayer.PlayerEmoticon.haveEmoticon[i] == false then
				table.insert(randomTargetTable, i)
			end
		end
		
		if #randomTargetTable <= 0 then
			_UIToast:ShowMessage(_LocalizationService:GetText("Message_AlreadyHaveAllEmot"))
			return
		end
		-------------------------------
		_UserService.LocalPlayer.PlayerEmoticon:GetNewEmot()
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 상점 UI 닫기 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if self.Entity.Enable == true and key == KeyboardKey.Escape then
			self.Entity.Enable = false
			self.Entity:GetChildByName("GachaResult").Enable = false
		end
	end

end