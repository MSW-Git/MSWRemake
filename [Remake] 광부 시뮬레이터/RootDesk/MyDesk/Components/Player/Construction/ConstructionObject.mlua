@Component
script ConstructionObject extends Component

	@Sync
	property number Idx = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 건설 오브젝트 초기화 및 표시 설정
		if self.Idx == 0 then
			log("idx is 0")
			return
		end
		
		self:SetNametagLocalization()
		self:RefreshEntityEnable()
	end

	@ExecSpace("Client")
	method void RefreshEntityEnable()
		-- 건설 레벨에 따른 오브젝트 활성화 상태 갱신
		--log("refresh!")
		
		local waitCount = 0
		while true do
			if _UserService.LocalPlayer.PlayerConstruction.haveItems[self.Idx] == nil then
				waitCount = waitCount + 1
				wait(1)  
				
				if waitCount > 8 then
					log("건설소 건물 못불러옴")
					return
				end
			else
				break
			end
		end
		
		
		
		if _UserService.LocalPlayer.PlayerConstruction.haveItems[self.Idx] > 1 then
			self.Entity.Enable = true
		else 
			--log("self.Idx = ", self.Idx ,", _UserService.LocalPlayer.PlayerConstruction.haveItems[self.Idx] = " ,  _UserService.LocalPlayer.PlayerConstruction.haveItems[self.Idx])
			self.Entity.Enable = false
			--log("enable false")
		end
	end

	@ExecSpace("Client")
	method void SetNametagLocalization()
		-- 건설 오브젝트의 이름 태그 다국어 설정
		local constructionTable = _DataService:GetTable("Construction")
		local key = constructionTable:GetCell(self.Idx, "Name")
		
		local tagEntity = self.Entity:GetChildByName("SubNameTag")
		if tagEntity ~= nil then
			tagEntity.NameTagComponent.Name = _LocalizationService:GetText(key)
		end
		
	end

	@EventSender("LocalPlayer")
	handler HandleLocalPlayerConstructed(LocalPlayerConstructed event)
		-- 플레이어 건설 완료 이벤트 수신 시 오브젝트 상태 갱신
		-- Parameters
		--------------------------------------------------------
		self:RefreshEntityEnable()
	end

end