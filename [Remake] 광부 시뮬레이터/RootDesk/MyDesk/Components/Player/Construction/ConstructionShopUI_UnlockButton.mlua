@Component
script ConstructionShopUI_UnlockButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 건설 시설 잠금 해제 버튼 클릭 시 확인 팝업 표시 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Parent.Parent.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop").ConstructionShopUI:SetUnlockCheckPopup(idx)
	end

end