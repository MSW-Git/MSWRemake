	method void CleanupIngamePropertiesOnServer()
		-- 서버에서 인게임 상태 정리 (현재 비어있음)
		
	end

	@ExecSpace("Server")
	method void SetChairBuffIdx(number idx)
		-- 의자 군중버프 인덱스 설정
		self.ChairBuffIdx = idx
	end

	@ExecSpace("Client")
	method string InitTempleTable()
		-- 신전 목록 초기화 및 최근 방문 신전을 제외한 랜덤 신전 선택
		self.EntranceTempleTable = {"Zeus_1", "Poseidon_2", "Apollon_3", "Athena_4", "Artemis_5", "Aphrodite_6", "Demeter_7"}
		local randIdx = _UtilLogic:RandomIntegerRange(1, #self.EntranceTempleTable)
		
		if self.latestTempleName == self.EntranceTempleTable[randIdx] then
			if randIdx == #self.EntranceTempleTable then
				randIdx = _UtilLogic:RandomIntegerRange(1, #self.EntranceTempleTable - 1) -- 7이면 1
			else
				randIdx = randIdx + 1 -- 1이면 2, 6이면 7
			end
			self.latestTempleName = self.EntranceTempleTable[randIdx]
			table.remove(self.EntranceTempleTable, randIdx)
			return self.latestTempleName
		else
			self.latestTempleName = self.EntranceTempleTable[randIdx]
			table.remove(self.EntranceTempleTable, randIdx)
			return self.latestTempleName
		end
		
	end

	@ExecSpace("Client")
	method string GetTempleTable()
		-- 남은 신전 목록에서 랜덤으로 선택하여 반환
		local randIdx = _UtilLogic:RandomIntegerRange(1, #self.EntranceTempleTable)
		self.latestTempleName = self.EntranceTempleTable[randIdx]
		table.remove(self.EntranceTempleTable, randIdx)
		
		
		return self.latestTempleName
		
	end

	@ExecSpace("Client")
	method void RecoverHP(number amount)
		-- HP를 지정된 양만큼 회복 (최대치 초과 방지)
		self.HP = self.HP + amount
		
		if self.HP > self.HPMax then
			self.HP = self.HPMax
		end
		
		self:SetHPandMPUI()
	end

	@ExecSpace("Server")
	method void AddCurrentTempleFloor(number amount, boolean reset, string id)
		-- 신전 에서 상위 층으로 나아갈 때 또는 층수 리셋 수행
		if self.Entity.PlayerComponent.UserId ~= id then
			return
		end
		
		if reset then
			self.TempleFloor_Current = 0
		else
			self.TempleFloor_Current = self.TempleFloor_Current + amount
			self:SetHPUseAmount(300000 + (self.Entity.PlayerIngameData.TempleFloor_Current - 1) * 120000)
		end
	end

	@ExecSpace("Server")
	method void resetPlayerSpeed(number speed, string id)
		-- 하데스 신전 등에서 플레이어 이동 속도 원복
		if self.Entity.PlayerComponent.UserId == id then
			self.Entity.MovementComponent.InputSpeed = speed
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 조명 오브젝트와 모닥불에 닿았을 때 빛 밝기/체력 회복 처리
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "light" then
			
			local playerPos = Vector2(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y)
			local lightPos = Vector2(TriggerBodyEntity.TransformComponent.WorldPosition.x, TriggerBodyEntity.TransformComponent.WorldPosition.y)
			local distance = math.abs(Vector2.Distance(playerPos, lightPos))
			
			local brightness = distance / (TriggerBodyEntity.TriggerComponent.BoxSize.x / 2)
			
			self.lightsBrightness[TriggerBodyEntity.Id] = brightness 
		end
		
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[2] == "bonfire" then
			self:SetNearBonfire(true)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "light" then
			self.lightsBrightness[TriggerBodyEntity.Id] = 1
		end
		
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[2] == "bonfire" then
			self:SetNearBonfire(false)
		end
	end

end