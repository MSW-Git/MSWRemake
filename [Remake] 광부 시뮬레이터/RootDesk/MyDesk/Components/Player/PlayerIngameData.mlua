	method void SetNearBonfire(boolean activate)
		-- 모닥불 근처 여부 설정 (모닥불 근처에서는 체력 회복)
		self.IsNearBonfire = activate
	end

	@ExecSpace("Client")
	method void UpdateDepthRecord()
		-- 현재 위치를 이용해 침탐 깊이를 계산하고 기록 업데이트
		local depthStandardEntity = _EntityService:GetEntity("f564182c-76f4-4ec3-8fd7-540a25a6577a")
		local depthBonus = 0
		
		local enteredMapName = self.Entity.Parent.Name
		 
		if enteredMapName == "Mine1_1" then
			depthBonus = 0
			depthStandardEntity = _EntityService:GetEntity("ae791836-3191-401b-9d32-df0750746712") -- 시작 지점의 포털
		
		elseif enteredMapName == "Mine1_2" then
			depthBonus = 42
			depthStandardEntity = _EntityService:GetEntity("b613f507-aa84-485d-85d0-0cf0d0947d38")
		
		elseif enteredMapName == "Mine1_3" then
			depthBonus = 42 + 34
			depthStandardEntity = _EntityService:GetEntity("60990d5d-ccdf-474c-a927-34d7feb0d407")
			
		elseif enteredMapName == "Mine2_1" then
			depthBonus = 42 + 34 + 35
			depthStandardEntity = _EntityService:GetEntity("aa2fc013-6d57-465a-a069-bd037f4c07e1")
		
		elseif enteredMapName == "Mine2_2" then
			depthBonus = 42 + 34 + 35 + 29
			depthStandardEntity = _EntityService:GetEntity("a10d77f8-9009-4a6c-839a-67d37550e714")
		
		elseif enteredMapName == "Mine2_3" then
			depthBonus = 42 + 34 + 35 + 29 + 38
			depthStandardEntity = _EntityService:GetEntity("aedbc317-aeb2-4c7b-9e6d-9194010ccabb")
		
		elseif enteredMapName == "Mine3_1" then
			depthBonus =  42 + 34 + 35 + 29 + 38 + 43
			depthStandardEntity = _EntityService:GetEntity("c05d3d5a-db89-4541-96e9-7625336bbfe1")
		
		elseif enteredMapName == "Mine3_2" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45
			depthStandardEntity = _EntityService:GetEntity("925478ca-4b59-475b-b64e-56cb0d92435e")
		
		elseif enteredMapName == "Mine3_3" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78
			depthStandardEntity = _EntityService:GetEntity("f5ee939c-297b-4b94-ac80-a56911561f4d")
		
		elseif enteredMapName == "Mine4_1" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42
			depthStandardEntity = _EntityService:GetEntity("cf6b03eb-e1b2-4192-ad85-fe7f097b5d7b")
		
		elseif enteredMapName == "Mine4_2" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42
			depthStandardEntity = _EntityService:GetEntity("39f173fe-51d9-4cab-8494-fb51b870136f")
		
		elseif enteredMapName == "Mine4_3" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26
			depthStandardEntity = _EntityService:GetEntity("9dd63efa-d13e-402c-885d-13dfe146cd49")
			
		elseif enteredMapName == "Mine5_1" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33
			depthStandardEntity = _EntityService:GetEntity("780f32ef-4e76-4303-abe4-5e97c22820e6")
		
		elseif enteredMapName == "Mine5_2" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24
			depthStandardEntity = _EntityService:GetEntity("4f63b1ff-a633-4cf6-b7e9-811dfe4616ed")
		
		elseif enteredMapName == "Mine5_3" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26
			depthStandardEntity = _EntityService:GetEntity("be8bca1a-51cf-4cba-a84b-80b2acb2eb64")
			
		elseif enteredMapName == "Mine6_1" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26 + 21
			depthStandardEntity = _EntityService:GetEntity("019dadcb-21bb-491a-8150-5f9bf8a02867")
		
		elseif enteredMapName == "Mine6_2" then
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26 + 21 + 35
			depthStandardEntity = _EntityService:GetEntity("c637b79b-d2ac-4ed7-9895-d923df544781")
		
		elseif enteredMapName == "Mine7_1" then -- 보너스 값 60
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26 + 21 + 35 + 37
			depthStandardEntity = _EntityService:GetEntity("dbf2bd20-497f-45b7-a672-4e939d0381dc")
			
		elseif enteredMapName == "Mine7_2" then -- 보너스 값 40
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26 + 21 + 35 + 37 + 50 
			depthStandardEntity = _EntityService:GetEntity("637e0ff5-4bd8-4967-8438-27915defd108")
		
		elseif enteredMapName == "Mine8_1" then -- 보너스 값 40
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26 + 21 + 35 + 37 + 50 + 32
			depthStandardEntity = _EntityService:GetEntity("d8162d29-386e-47f9-9b50-1860c43887ab")
		
		elseif enteredMapName == "Mine8_2" then -- 보너스 값 40
			depthBonus = 42 + 34 + 35 + 29 + 38 + 43 + 45 + 78 + 42 + 42 + 26 + 33 + 24 + 26 + 21 + 35 + 37 + 50 + 32 + 44
			depthStandardEntity = _EntityService:GetEntity("62d15726-fd9a-43ea-b0a7-53dc80bf9ff8")
		
		elseif enteredMapName == "Mine9_1" then -- 보너스 값 40
			depthBonus = 0
			depthStandardEntity = _EntityService:GetEntity("e025931b-6e8a-42c3-974f-034ea3f1a663")
		
		elseif enteredMapName == "Mine9_2" then -- 보너스 값 40
			depthBonus = 39
			depthStandardEntity = _EntityService:GetEntity("5d25cdf9-ce28-4d15-ae95-25f07304d025")
		
		elseif enteredMapName == "Mine9_3" then -- 보너스 값 40
			depthBonus = 39 + 34
			depthStandardEntity = _EntityService:GetEntity("4c4f23e2-69e4-4639-b89f-bbc10a79068d")
		
		elseif enteredMapName == "Mine9_4" then -- 보너스 값 40
			depthBonus = 39 + 34 + 43
			depthStandardEntity = _EntityService:GetEntity("6975676b-d567-4fb7-a202-83c5fb8b5d7f")
		
		elseif enteredMapName == "Mine9_5" then -- 보너스 값 40
			depthBonus = 39 + 34 + 43 + 33
			depthStandardEntity = _EntityService:GetEntity("fb224f26-7af0-43ae-8753-26d6cb38bd50")
			
		else 
			return
		end
		
		
		-- 기준 엔티티와 좌표 비교
		if depthStandardEntity == nil then
			return
		end
		
		self.depth = math.abs(self.Entity.TransformComponent.WorldPosition.y 
			- depthStandardEntity.TransformComponent.WorldPosition.y) + depthBonus
		
		-- 최고기록 갱신 (단일게임)
		if self.depth >= self.depthRecordOnetime then
			self.depthRecordOnetime = self.depth
		end
	end

	@ExecSpace("Client")
	method void UnprotectedHit(number damage)
		-- 보호막을 적용하지 않는 데미지일 경우 이 함수 사용 (중독 데미지 등)
		self.HP = self.HP - damage
		
		-- damage skin
		_DamageSkinService:Play(self.Entity, "5577a2fd5c25463a85683f7fc4b94ecb", 0.01, 
				{damage}, DamageSkinTweenType.Default, false)
	end

	@ExecSpace("Client")
	method void PopupMapEnteringUI(string enteredMapName, string tableName)
		-- 맵 입장시 맵 이름과 설명을 페이드 인/아웃 애니메이션과 함께 표시
		if self.Entity ~= _UserService.LocalPlayer then
			return
		end
		---------------------------------
		local dataIdx = 0
		if enteredMapName == "1_1" then
			dataIdx = 1 
		elseif enteredMapName == "2_1" then
			dataIdx = 5 
		elseif enteredMapName == "3_1" then
			dataIdx = 9 
		elseif enteredMapName == "4_1" then
			dataIdx = 13
		elseif enteredMapName == "5_1" then
			dataIdx = 17 
		elseif enteredMapName == "6_1" then
			dataIdx = 21 
		elseif enteredMapName == "7_1" then
			dataIdx = 25 
		elseif enteredMapName == "8_1" then
			dataIdx = 29
		elseif enteredMapName == "9_1" then
			dataIdx = 33
		elseif enteredMapName == "0_1" then
			dataIdx = 37 
			
		-- 아래서부턴 마을	
		elseif enteredMapName == "n" or enteredMapName == "1" then
			dataIdx = 1  
		elseif enteredMapName == "2" then
			dataIdx = 2  
		elseif enteredMapName == "3" then
			dataIdx = 3  
		elseif enteredMapName == "4" then
			dataIdx = 4  
		elseif enteredMapName == "5" then
			dataIdx = 5  
		elseif enteredMapName == "6" then
			dataIdx = 6  
		elseif enteredMapName == "7" then
			dataIdx = 7  
		elseif enteredMapName == "8" then
			dataIdx = 8  
		elseif enteredMapName == "9" then
			dataIdx = 9  
		elseif enteredMapName == "0" then
			dataIdx = 10  
		else 
			return
		end
		
		local dataTable = _DataService:GetTable(tableName)
		local mapName = dataTable:GetCell(dataIdx, 2)
		local desc = dataTable:GetCell(dataIdx, 4)
		---------------------------------
		local ui = _EntityService:GetEntity("8857739f-64d7-4e38-a37d-cba79172fb7d")
		local mapNameUI = ui:GetChildByName("Panel"):GetChildByName("MapName")
		local descUI = ui:GetChildByName("Panel"):GetChildByName("Desc")
		---------------------------------
		mapNameUI.TextComponent.Text = _LocalizationService:GetText(mapName)
		descUI.TextComponent.Text = _LocalizationService:GetText(desc)
		---------------------------------
		ui.Enable = true
		local alpha = 0
		
		local setColorUp = function()
			alpha = alpha + 1/30
		
			for i=1, #ui.Children do
				ui.Children[i].SpriteGUIRendererComponent.Color.a = alpha
			end
				
			mapNameUI.TextComponent.FontColor.a = alpha
			descUI.TextComponent.FontColor.a = alpha
		end
		
		for i=1, 30 do
			_TimerService:SetTimerOnce(setColorUp, i/30)
		end
		---------------------------------
		local alphaDown = 1
		local setColorDown = function()
			alphaDown = alphaDown - 1/30
		
			for i=1, #ui.Children do
				ui.Children[i].SpriteGUIRendererComponent.Color.a = alphaDown
			end
			
			mapNameUI.TextComponent.FontColor.a = alphaDown
			descUI.TextComponent.FontColor.a = alphaDown
		end
		
		for i=1, 30 do
			_TimerService:SetTimerOnce(setColorDown, i/30+2.5)
		end
		---------------------------------
		local disable = function()
			ui.Enable = false
		end
		
		_TimerService:SetTimerOnce(disable, 4)
		
		log("popup map entering")
	end

	@ExecSpace("Client")
	method void SetWarningUI(boolean enable)
		-- 체력이 25% 이하일 때 경고 UI 표시/비표시
		if _UserService.LocalPlayer ~= self.Entity then
			return
		end
		
		local warningUI = _EntityService:GetEntity("880adfef-9ed3-450e-98d6-ad15faf2338a")
		warningUI:SetEnable(enable)
	end

	@ExecSpace("Client")
	method void UseMP(number amount)
		-- 대쉬 등에서 MP 사용시 호출되는 함수
		self.MP = self.MP - amount*self.MPUseRate	
		
		if self.MP < 0 then
		 	self.MP = 0
		end
		
		self:SetHPandMPUI()
	end

	@ExecSpace("Client")
	method void GetProtector()
		-- 보호막 개수를 1개 증가
		self.protector = self.protector + 1
	end

	@ExecSpace("Server")
	method void SetHPUseAmount(number amount)
		-- 현재 광산/신전의 초당 HP 감소량 설정
		self.HPUseAmountPerSec = amount
		--log("현재 층"..self.TempleFloor_Current.."/".."현재 초당 데미지:"..self.HPUseAmountPerSec.."/".."현재 광맥 내구도:".. 700000000 + (self.TempleFloor_Current - 1) * 420000000 .."/".."현재 맵:"..self.Entity.CurrentMapName)
	end

