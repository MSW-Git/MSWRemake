@Component
script AccessoryMergeShopUI_SelectMaterialSlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 재료 슬롯 버튼 클릭 시 해당 재료를 선택하여 합성 창에 등록
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop").AccessoryMergeShopUI:RegistMaterial(idx)
	end

end