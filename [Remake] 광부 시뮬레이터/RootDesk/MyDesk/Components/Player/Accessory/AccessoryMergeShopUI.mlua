@Component
script AccessoryMergeShopUI extends Component

	property SyncTable<number> materialIdx

	property number waitForRegisterIdx = 0

	property number materialGrade = 0

	property boolean IsPlayingDirection = false

	@ExecSpace("Client")
	method void RefreshMainPanel()
		-- 메인 패널 새로고침 - 재료 슬롯, 결과 등급, 합성 버튼 상태 업데이트
		local panel = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/img_paper")
		local accessoryIconTable = _DataService:GetTable("AccessoryIcon")
		local accessoryInfoTable = _DataService:GetTable("AccessoryInfo")
		local accessorySetTable = _DataService:GetTable("AccessorySet")
		local gradeIconbackTable = _DataService:GetTable("GradeIconback")
		
		local mergeReady = true
		
		-- 재료 목록 갱신
		for i=1, 2 do
			local slot = panel:GetChildByName("Slot_"..tostring(i))
			local icon = slot:GetChildByName("Icon")
			local outline = slot:GetChildByName("Outline")
			
			if self.materialIdx[i] == nil or self.materialIdx[i] == 0 then
				outline.Enable = false 
				
				icon.SpriteGUIRendererComponent.ImageRUID = "e3abb89495df4120aadd707d758e2b78"
				icon.UITransformComponent.RectSize = Vector2(48, 48)
				icon.SpriteGUIRendererComponent.Color = Color.FromHexCode("#a37b58")
				icon.SpriteGUIRendererComponent.Color.a = 0.5
				mergeReady = false
			else 
				local itemKey = _UserService.LocalPlayer.PlayerAccessory.haveItems[self.materialIdx[i]]
				local itemData = _AccessoryLogic:GetAccessoryInfo(itemKey)
				
				outline.SpriteGUIRendererComponent.ImageRUID = gradeIconbackTable:GetCell(itemData[2], 1)
				outline.Enable = true
				
				icon.SpriteGUIRendererComponent.ImageRUID = accessoryIconTable:GetCell(itemData[1], "RUID_"..tostring(math.floor(itemData[3])))
				icon.UITransformComponent.RectSize = Vector2(100, 100)
				icon.SpriteGUIRendererComponent.Color = Color.white
				
				self.materialGrade = itemData[2]
			end
			
		end
		
		
		-- 결과 등급 갱신
		local resultGradeUI = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/img_paper/ResultGrade")
		if self.materialGrade == nil or self.materialGrade == 0 then
			resultGradeUI.TextComponent.Text = "?"
			resultGradeUI.SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
			resultGradeUI.TextComponent.FontColor = Color.white
		else 
			resultGradeUI.TextComponent.Text = _LocalizationService:GetText("Grade_"..tostring(math.floor(self.materialGrade+1)))
			resultGradeUI.TextComponent.FontColor = Color.FromHexCode(gradeIconbackTable:GetCell(self.materialGrade+1, "color"))
			
			if self.materialGrade == 1 then
				resultGradeUI.SpriteGUIRendererComponent.ImageRUID = "40d720566f8848a79a6cdfe33c2db8ee"
			elseif self.materialGrade == 2 then
				resultGradeUI.SpriteGUIRendererComponent.ImageRUID = "02df74a284c744ac8e7849ad0bfe7468"
			elseif self.materialGrade == 3 then
				resultGradeUI.SpriteGUIRendererComponent.ImageRUID = "5128857d733a4fa7bbdacf2da86d9a13"
			end
		end
		
		-- 합성 버튼 활성화 결정
		if mergeReady then
			_EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/MergeButton").ButtonComponent.Enable = true
		else 
			_EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/MergeButton").ButtonComponent.Enable = false	
		end
	end

	@ExecSpace("Client")
	method void ShowMaterialListPanel()
		-- 재료 선택 패널 표시 - 합성 가능한 아이템들의 리스트 생성
		local panel = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/SelectMaterial")
		
		local accessoryIconTable = _DataService:GetTable("AccessoryIcon")
		local accessoryInfoTable = _DataService:GetTable("AccessoryInfo")
		local accessorySetTable = _DataService:GetTable("AccessorySet")
		local gradeIconbackTable = _DataService:GetTable("GradeIconback")
		local abilityIconTable = _DataService:GetTable("AbilityIcon")
		
		-- 리스트를 갱신합니다.
		local list = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/SelectMaterial/Panel/List")
		local haveItems = _UserService.LocalPlayer.PlayerAccessory.haveItems
		for i=1, #haveItems do
			
			local slot = list:GetChildByName("Slot_"..tostring(i))
			if slot == nil then
				slot = list:GetChildByName("Slot"):Clone("Slot_"..tostring(i))
			end
			local iconback = slot:GetChildByName("Grade")
			local icon = iconback:GetChildByName("Icon")
			local setIcon = iconback:GetChildByName("Type")
			local ability = slot:GetChildByName("Ability")
			local abilityIcon = slot:GetChildByName("Icon_Ability")
			
			local itemCode = haveItems[i]
			local itemData = _AccessoryLogic:GetAccessoryInfo(itemCode)
			
			icon.SpriteGUIRendererComponent.ImageRUID = accessoryIconTable:GetCell(itemData[1], "RUID_"..tostring(math.floor(itemData[3])))
			setIcon.SpriteGUIRendererComponent.ImageRUID = accessorySetTable:GetCell(itemData[3], "SetRUID")
			iconback.SpriteGUIRendererComponent.ImageRUID = gradeIconbackTable:GetCell(itemData[2], 1)
			ability.TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(itemData[4], nil)
			abilityIcon.SpriteGUIRendererComponent.ImageRUID = abilityIconTable:GetCell(itemData[1], 2)
			
			if self.materialGrade == 0 or itemData[2] == self.materialGrade then
				if itemData[2] >= 4 then
					slot.Enable = false 
				else 
					slot.Enable = true
					
					-- 장착 여부에 따라 'IsEquiped' 엔티티 활성화
					local isEquiped = false
					for j=1, 3 do
						if i == _UserService.LocalPlayer.PlayerAccessory.equipedItemIdx[j] then
							slot:GetChildByName("IsEquiped").Enable = true
							isEquiped = true
						end
					end
					if isEquiped == false then
						slot:GetChildByName("IsEquiped").Enable = false
					end
					
					
					-- 선택 여부에 따라 'IsSelected' 엔티티 활성화
					if self.materialIdx[1] == i or self.materialIdx[2] == i then
						slot:GetChildByName("IsSelected").Enable = true
						slot.ButtonComponent.Enable = false
					else 
						slot:GetChildByName("IsSelected").Enable = false
						slot.ButtonComponent.Enable = true
					end
				end
		
			else 
				slot.Enable = false
			end
		end
		
		-- 필요없는 리스트는 제거합니다.
		local idx = #haveItems+1
		while true do
			local slot = list:GetChildByName("Slot_"..tostring(idx))
			if slot ~= nil then
				slot:Destroy()
				idx = idx + 1
			else
				break
			end
		end
		
		
		panel.Enable = true
	end

	@ExecSpace("Client")
	method void RegistMaterial(number idx)
		-- 재료를 대기중인 슬롯에 등록하고 메인 패널 업데이트
		self.materialIdx[self.waitForRegisterIdx] = idx
		self.waitForRegisterIdx = 0
		
		self:RefreshMainPanel()
		
		local MaterialListPanel = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/SelectMaterial")
		MaterialListPanel.Enable = false
		
		
	end

	@ExecSpace("Client")
	method void InitAllSetting()
		-- 모든 설정 초기화 - 재료 슬롯, 등급, 대기 인덱스 리셋
		self.materialIdx[1] = 0
		self.materialIdx[2] = 0
		self.materialGrade = 0
		self.waitForRegisterIdx = 0
	end

	@ExecSpace("Client")
	method void PlayDirection_Merge(string resultKey)
		-- 장신구 합성 연출 재생 - 이펙트, 사운드, 결과창 표시
		self.IsPlayingDirection = true 
		
		local paper = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/img_paper")
		
		-- 일부 버튼을 임시 제거합니다.
		local closeBtn = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/TitlePanel/ExitButton")
		local mergeBtn = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/Panel/MergeButton")
		closeBtn.Enable = false
		mergeBtn.Enable = false
		local btnEnable = function()
			closeBtn.Enable = true
			mergeBtn.Enable = true
		end
		_TimerService:SetTimerOnce(btnEnable, 3)
		
		
		
		-- 재료 슬롯에 이펙트를 재생하고, 아이콘을 비웁니다.
		for i=1, 2 do
			local slot = paper:GetChildByName("Slot_"..tostring(i))
			local SlotEffect = slot:GetChildByName("Effect")
			local icon = slot:GetChildByName("Icon")
				
			local cloneSlotEffect = function()
				local clonedEffect = SlotEffect:Clone("clonedEffect")
				icon.Enable = false
				_SoundService:PlaySound("c0d7360d9e0c4a4aa06555b51975a8ab", 0.5)
				
				clonedEffect:Destroy(1)
			end
			
			local iconEnable = function()
				icon.SpriteGUIRendererComponent.ImageRUID = "e3abb89495df4120aadd707d758e2b78"
				icon.UITransformComponent.RectSize = Vector2(48, 48)
				icon.SpriteGUIRendererComponent.Color = Color.FromHexCode("#a37b58")
				icon.SpriteGUIRendererComponent.Color.a = 0.5
				icon.Enable = true
			end
			
			_TimerService:SetTimerOnce(cloneSlotEffect, 0.25*i)
			_TimerService:SetTimerOnce(iconEnable, 3.0)
		end
		
		
		local resultPanel = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/ResultPanel")
		local resultPanelEffect = resultPanel:GetChildByName("Effect")
		local resultPopup = resultPanel:GetChildByName("Popup")
		
		resultPanel.SpriteGUIRendererComponent.Color.a = 0
		resultPanel.Enable = true
		resultPopup.Enable = false
		
		-- 결과창의 블랙패널 투명도를 0.5까지 서서히 높입니다.
		local alpha = 0
		local setPanelAlpha = function()
			alpha = alpha + 1/60
			resultPanel.SpriteGUIRendererComponent.Color.a = alpha
		end
		for i=1, 30 do
			_TimerService:SetTimerOnce(setPanelAlpha, i/30)
		end
		
		-- 책 이펙트를 재생합니다.
		local cloneResultEffect = function()
			local clonedEffect = resultPanelEffect:Clone("clonedEffect")
			_SoundService:PlaySound("4feadbd22c8f46e6b5ecf6b1e980c774", 0.5)
			
			clonedEffect:Destroy(2.5)
		end
		
		_TimerService:SetTimerOnce(cloneResultEffect, 1.5)
		
		
		-- 결과창 팝업이 뜹니다.
		local popupEnable = function()
			resultPopup.Enable = true
			self.IsPlayingDirection = false
		end
		_TimerService:SetTimerOnce(popupEnable, 2.5)
		
		------------------------------------------------------------------------------------------
		-- 결과창을 세팅합니다.
		local accessoryIconTable = _DataService:GetTable("AccessoryIcon")
		local accessorySetTable = _DataService:GetTable("AccessorySet")
		local accessoryInfoTable = _DataService:GetTable("AccessoryInfo")
		local gradeIconbackTable = _DataService:GetTable("GradeIconback")
		
		local itemData = _AccessoryLogic:GetAccessoryInfo(resultKey)
		local itemName = 
			_LocalizationService:GetText(accessoryInfoTable:GetCell(itemData[2],"name_grade")).." "
			.._LocalizationService:GetText(accessoryInfoTable:GetCell(itemData[3],"name_set")).." "
			.._LocalizationService:GetText(accessoryInfoTable:GetCell(itemData[1],"name_part"))
		local nameUI = resultPopup:GetChildByName("Name")
		nameUI.TextComponent.Text = itemName
		nameUI.TextComponent.FontColor = Color.FromHexCode(gradeIconbackTable:GetCell(itemData[2], "color"))
		
		local iconbackUI = resultPopup:GetChildByName("iconBack")
		iconbackUI.SpriteGUIRendererComponent.ImageRUID = gradeIconbackTable:GetCell(itemData[2], 1)
		
		local iconUI = resultPopup:GetChildByName("icon")
		iconUI.SpriteGUIRendererComponent.ImageRUID = accessoryIconTable:GetCell(itemData[1], "RUID_"..tostring(math.floor(itemData[3])))
		
		local gradeUI = resultPopup:GetChildByName("Grade")
		gradeUI.TextComponent.Text = _LocalizationService:GetText(string.format("Grade_%d", itemData[2]))
		gradeUI.TextComponent.FontColor = Color.FromHexCode(gradeIconbackTable:GetCell(itemData[2], "color"))
		
		local flavorTxtIdx = 15*(itemData[3]-1) + 3*(itemData[2]-1) + itemData[1]
		local flavorTextUI = resultPopup:GetChildByName("FlavorText")
		flavorTextUI.TextComponent.Text = _LocalizationService:GetText(accessoryInfoTable:GetCell(flavorTxtIdx,"flavorText"))
		
		local abilityUI = resultPopup:GetChildByName("Ability")
		abilityUI.TextComponent.Text = _LocalizationService:GetText(string.format("%d", 8000+itemData[1])).." +".._ThousandsSeparator:ConvertToMetricPrefixString(itemData[4], nil)
	end

	@EventSender("Entity", "b0c9f42b-7c0b-4c2c-b0bc-2e0d1afa2524")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 첫 번째 재료 슬롯 클릭 - 재료 선택 리스트를 열고 대기상태로 설정
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		self.waitForRegisterIdx = 1
		self:RefreshMainPanel()
		self:ShowMaterialListPanel()
		
	end

	@EventSender("Entity", "2b81d69c-3ea5-4c74-9a98-d45db5af228d")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 두 번째 재료 슬롯 클릭 - 재료 선택 리스트를 열고 대기상태로 설정
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		self.waitForRegisterIdx = 2
		self:RefreshMainPanel()
		self:ShowMaterialListPanel()
	end

	@EventSender("Entity", "68a1754b-a36c-450c-8b61-c73c7d804332")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 합성 버튼 클릭 - 재료 준비 확인 후 장신구 합성 실행
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.materialIdx[1] == nil or self.materialIdx[1] == 0 or self.materialIdx[2] == nil or self.materialIdx[2] == 0 then
			Entity.ButtonComponent.Enable = false
			return
		end
		
		_UserService.LocalPlayer.PlayerAccessory:MergeItems(_UtilLogic:TableToString(self.materialIdx))
	end

	@EventSender("Entity", "a83ff64a-9804-493e-a237-1f9da510afc5")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 리셋 버튼 클릭 - 모든 설정 초기화 후 메인 패널 새로고침
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		self:InitAllSetting()
		self:RefreshMainPanel()
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 재료 선택 패널 또는 샵 닫기
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		local selectMaterialPanel = _EntityService:GetEntityByPath("/ui/AccessoryMergeGroup/AccessoryMergeShop/SelectMaterial")
		
		if key == KeyboardKey.Escape and self.IsPlayingDirection == false then
			if selectMaterialPanel.Enable == true then
				selectMaterialPanel.Enable = false
				self.waitForRegisterIdx = 0
				self:RefreshMainPanel()
			else 
				self.Entity.Enable = false
				_UserService.LocalPlayer.MovementComponent.Enable = true
			end
		end
	end

end