@Component
script ChairBuffNova extends Component

	property EntityRef Owner = nil

	property number BuffIdx = 0

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 의자 버프 노바 시작 - 이팩트 재생 및 0.5초 후 자동 삭제
		local effectRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		
		_EffectService:PlayEffect(effectRUID,
			self.Entity,
			self.Entity.TransformComponent.WorldPosition,
			0,
			Vector3.one)
		
		local destroySelf = function()
			_EntityService:Destroy(self.Entity)
		end
		
		_TimerService:SetTimerOnce(destroySelf, 0.5)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 버프 노바에 닿으면 의자 버프 적용 (원 주인 제외)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.PlayerIngameData and TriggerBodyEntity ~= self.Owner then
			TriggerBodyEntity.PlayerIngameData:SetChairBuffIdx(self.BuffIdx)
			--log("Buff is Changed = ", self.BuffIdx)
		end
	end

end