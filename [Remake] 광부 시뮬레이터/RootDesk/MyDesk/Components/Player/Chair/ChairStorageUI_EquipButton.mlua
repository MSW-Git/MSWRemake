@Component
script ChairStorageUI_EquipButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 의자 장착 버튼 클릭 시 해당 의자로 장착 대상 변경
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local slotIdx = tonumber(string.sub(self.Entity.Parent.Name, 6, -1))
		
		_UserService.LocalPlayer.PlayerChair:ChangeEquipedItem(slotIdx)
	end

end