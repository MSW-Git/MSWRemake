@Component
script CollectionUI extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴렉션 UI 초기 설정 (아이템 슬롯 생성)
		local slot = _EntityService:GetEntity("cebbdd75-fd7e-4d87-8542-131a3e4bdb62")
		local itemTable = _DataService:GetTable("DropItem")
		
		for i=1, itemTable:GetRowCount() do
			slot:Clone("Slot_"..tostring(i))
		end
		
		
		self:RefreshDescUI()
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- UI 갱신 요청 플래그 확인 및 처리
		if self._T.refreshUI then
			self:RefreshUI_Inner()
			self._T.refreshUI = false
		end
	end

	@ExecSpace("Client")
	method void RefreshUI()
		-- UI 갱신 플래그 설정
		self._T.refreshUI = true
	end

	@ExecSpace("Client")
	method void RefreshUI_Inner()
		-- 컴렉션 UI 전체 갱신 (드롭 아이템 목록)
		local dropItemTable = _DataService:GetTable("DropItem")
		local playerCollection = _UserService.LocalPlayer.PlayerCollection
		
		for i=1, dropItemTable:GetRowCount() do
			local listEntityId = "6337ee0e-fa49-4fa1-a79c-55d4435f2de5"
		
			local listUI = _EntityService:GetEntity(listEntityId) 
			local slotUI = listUI:GetChildByName("Slot_"..tostring(i))
			
			
			-- 등급
			local grade = dropItemTable:GetCell(i, 3)
			
			-- 아이콘
			local iconUI = slotUI:GetChildByName("Icon")
			local iconRUID = dropItemTable:GetCell(i, 2)
			iconUI.SpriteGUIRendererComponent.ImageRUID = iconRUID
			if  playerCollection.dropItems[i] == nil then
			elseif playerCollection.dropItems[i] > 0 then
				iconUI.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
			elseif playerCollection.dropItems[i] == 0 or playerCollection.dropItems[i] == nil then
				iconUI.SpriteGUIRendererComponent.Color = Color(0, 0, 0, 0.4)
			end
		end
		
		
		self:RefreshDescUI()
	end

	@ExecSpace("Client")
	method void RefreshDescUI()
		-- 컴렉션 설명 패널 초기화
		local destPanel = _EntityService:GetEntity("c097178b-ca75-4104-906a-f52422fdf071")
		
		local nameUI = destPanel:GetChildByName("Name")
		local gradeUI = destPanel:GetChildByName("Grade")
		local descUI = destPanel:GetChildByName("Desc")
		local priceUI = destPanel:GetChildByName("Price")
		local statisticsUI = destPanel:GetChildByName("Statistics"):GetChildByName("Num")
		
		nameUI.TextComponent.Text = ""
		gradeUI.TextComponent.Text = ""descUI.TextComponent.Text = ""priceUI.TextComponent.Text = ""statisticsUI.TextComponent.Text = ""
	end

	@ExecSpace("Client")
	method void SetDescUI(number idx)
		-- 선택된 아이템의 상세 정보를 설명 패널에 표시
		local descPanel = _EntityService:GetEntity("c097178b-ca75-4104-906a-f52422fdf071")
		
		local nameUI = descPanel:GetChildByName("Name")
		local gradeUI = descPanel:GetChildByName("Grade")
		local descUI = descPanel:GetChildByName("Desc")
		local priceUI = descPanel:GetChildByName("Price")
		local iconUI = descPanel:GetChildByName("Icon_back"):GetChildByName("Icon")
		local statisticsUI = descPanel:GetChildByName("Statistics"):GetChildByName("Num")
		
		local itemData = _DataService:GetTable("DropItem")
		local iconRUID = itemData:GetCell(idx, 2)
		iconUI.SpriteGUIRendererComponent.ImageRUID = iconRUID
		
		if _UserService.LocalPlayer.PlayerCollection.dropItems[idx] <= 0 then
			self:RefreshDescUI()
			
			nameUI.TextComponent.Text = _LocalizationService:GetText("Unknown")
			gradeUI.TextComponent.Text = _LocalizationService:GetText("Unknown")
			gradeUI.TextComponent.FontColor = Color.FromHexCode("#2B130C")
			
			descUI.TextComponent.Text = _LocalizationService:GetText("Unknown")
		
			priceUI.TextComponent.Text = "???"
			
			iconUI.SpriteGUIRendererComponent.Color = Color(0, 0, 0, 0.4)
			statisticsUI.TextComponent.Text = "-"
		else 
			local grade = itemData:GetCell(idx, 3)
			
			local name = _LocalizationService:GetText(itemData:GetCell(idx, 1))
			local gradeLocalized = _LocalizationService:GetText(grade)
			local desc = _LocalizationService:GetText(itemData:GetCell(idx, 4))
			local price = itemData:GetCell(idx, 5)
			local statistics = _UserService.LocalPlayer.PlayerCollection.dropItems[idx]
			
			
			
			nameUI.TextComponent.Text = name -- 이름 텍스트
			gradeUI.TextComponent.Text = gradeLocalized -- 등급 텍스트
			
			if tostring(grade) == "Grade_1" then
				gradeUI.TextComponent.FontColor = Color.FromHexCode("#D8AD87")
				
			elseif tostring(grade) == "Grade_2" then		
				gradeUI.TextComponent.FontColor = Color.FromHexCode("#AFDC6E")
				
			elseif tostring(grade) == "Grade_3" then
				gradeUI.TextComponent.FontColor = Color.FromHexCode("#4DD4EC")
				
			elseif tostring(grade) == "Grade_4" then
				gradeUI.TextComponent.FontColor = Color.FromHexCode("#A66AFF")
				
			else -- 전설
				gradeUI.TextComponent.FontColor = Color.FromHexCode("#F64343")
			end
			
			descUI.TextComponent.Text = desc -- 설명 텍스트
			priceUI.TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(tonumber(price), nil) -- 가격 텍스트
			iconUI.SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
			statisticsUI.TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(statistics, nil) -- 누적 텍스트?
		end
		
		-- '업적 보기' 버튼
		local goToQuestBtn = descPanel:GetChildByName("Button_GoToQuest")
		goToQuestBtn.Enable = false
		goToQuestBtn.TextComponent.FontColor = Color.FromHexCode("#434343")
		
		
		descPanel:SetEnable(true)
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 컴렉션 UI 닫기 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if self.Entity.Enable == true and key == KeyboardKey.Escape then
			self.Entity.Enable = false
			self.Entity:GetChildByName("DescPanel").Enable = false
		end
	end

end