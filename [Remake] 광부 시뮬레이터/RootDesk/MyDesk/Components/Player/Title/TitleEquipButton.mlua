@Component
script TitleEquipButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 칭호 장착 버튼 클릭 시 해당 인덱스의 칭호를 장착하도록 요청
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Parent.Name, 6, -1))
		
		_EntityService:GetEntity("0040e4bf-eaeb-465d-8521-237b5a363e0e").TitleStorageUI:ChangeEquipedTitle(idx)
	end

end