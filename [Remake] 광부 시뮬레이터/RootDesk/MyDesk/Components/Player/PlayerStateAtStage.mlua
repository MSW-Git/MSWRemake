@Component
script PlayerStateAtStage extends Component

	property number StageNum = 0

	property number Poison_LeftTime = 0

	property number Poison_TickTime = 0

	property number HavingMaterialNum = 0

	property number ColdStack = 0

	property number ColdCoolTime = 0

	@Description("남은 감전 지속시간. 감전 상태라면 0 초과값을 갖고, 아니면 값을 0으로 한다.")
	property number Shocked_LeftTime = 0

	property number ShockedStack = 0

	property number IgniteCoolTime = 5

	@Description([[젖음(습기) 스택
]])
	property number IgniteShieldStack = 0

	property number IgniteStack = 0

	property number ExitedMode_LeftTime = 0

	@Sync
	property number ThirstyStack = 0

	property number ThirstyCoolTime = 0

	@Sync
	property number CurseStack = 0

	property number CurseCoolTime = 0

	@Description("8스테이지 밤인지를 나타냅니다. 밤에는 추위 스택이 쌓입니다.")
	property boolean IsNight = false

	property number airGauge = 0

	property number airGaugeDecreaseRate = 0

	property number airGaugeIncreaseRate = 0

	property EntityRef UI_Poison = "dbff2a82-36fc-434e-a2fa-01200e039438"

	property Entity UI_Cold = "f758c52e-a54f-464f-b4de-a9963038f9ec"

	property Entity UI_Day = "0ad73bff-7d3b-4fff-8957-953a882dad44"

	property Entity UI_Night = "8adb817b-2446-4f50-b02d-140497ee5736"

	property Entity UI_Shocked = "5cb1d58c-2768-4ffa-a24b-1c5b50329312"

	property Entity UI_Wet = "413af8e5-1c9b-4bd9-a306-c124bb41278e"

	property Entity UI_Burn = "c6973ae8-d6d9-4d25-97bf-44991f809504"

	property Entity UI_Exited = "91641ce6-9dfd-4d07-b9fd-a1c6c71415ad"

	property Entity UI_Thirsty = "93605192-49aa-4668-a65f-1a768b6049f9"

	property Entity UI_Curse = "ac7447dd-8f8d-4212-a335-2a73146707d9"

	property Entity UI_Enchanted = "9f6582bd-1a83-4b47-a1e0-f63e31120c0f"

	property Entity UI_Air = "14a024f5-1477-404a-922f-b0ee1c45d28d"

	property table RotationShield = {}

	property boolean beEnchanted = false

	property boolean onSnowMan = false

	property Entity snowMan = nil

	property number EnchantedTime = 0

	property number maxEnchantedTime = 0

	property boolean playerInWater = false

	property boolean playerInCenterSpaceInWater = false

	property number hadesOriginSpeed = 0

	@ExecSpace("ClientOnly")
	method void OnMapEnter(any enteredMap)
		-- 맵 입장 시 스테이지별 디버프 UI 설정 및 환경 초기화
		if self.Entity ~= _UserService.LocalPlayer then
			return
		end
		
		if string.sub(enteredMap.Name, 1, 4) == "Town" or string.sub(enteredMap.Name, 1, 17) == "HistoricSite_Town" then
			self.StageNum = 0
			
			local mineDefaultUI = _EntityService:GetEntity("719ec1e1-8be7-4d82-bae9-6ab3f79bc8c1")
			mineDefaultUI.Enable = false
			
			local mine9DefaultUI = _EntityService:GetEntity("fe0eb42b-30bc-4ef8-8c5e-31463483191e")
			mine9DefaultUI.Enable = false
			
			
		elseif string.sub(enteredMap.Name, 1, 4) == "Mine" then
			self.StageNum = tonumber(string.sub(enteredMap.Name, 5, 5)) 
			
			if self.StageNum < 9 then
				local hpUseAmountTable = _DataService:GetTable("HPUseAmountAtMine")
				local hpUseAmount = tonumber(hpUseAmountTable:GetCell(self.StageNum, 2))
				self.Entity.PlayerIngameData:SetHPUseAmount(hpUseAmount)
				
				local mineDefaultUI = _EntityService:GetEntity("719ec1e1-8be7-4d82-bae9-6ab3f79bc8c1")
				mineDefaultUI.TextComponent.Text = tostring(math.floor(self.StageNum))
				mineDefaultUI.Enable = true
				mineDefaultUI.UIMouseHover.Type3_Name = _LocalizationService:GetTextFormat("Debuff_Mine", string.format("%d", self.StageNum)) -- "광산의 힘%d"
				mineDefaultUI.UIMouseHover.Type3_Desc = 
				_LocalizationService:GetTextFormat("Debuff_Desc_Mine", hpUseAmountTable:GetCell(self.StageNum, 2) )
				--string.format("광산의 공기가 당신을 짓누릅니다. 체력이 초당 %d씩 감소합니다.", hpUseAmount)
			else 
				local hpUseAmountTable = _DataService:GetTable("HPUseAmountAtMine")
				local defaultHPUseAmount = tonumber(hpUseAmountTable:GetCell(self.StageNum, 2))
				
				local roomNum = tonumber(string.sub(enteredMap.Name, -1, -1)) -- 7에서 -1로 수정
				local roomHPUseAmount = defaultHPUseAmount * (1+  1.4 * (roomNum-1))
		
				
				local mine9DefaultUI = _EntityService:GetEntity("fe0eb42b-30bc-4ef8-8c5e-31463483191e")
				mine9DefaultUI.TextComponent.Text = tostring(math.floor(roomNum))
				mine9DefaultUI.Enable = true
				mine9DefaultUI.UIMouseHover.Type3_Name = _LocalizationService:GetTextFormat("Debuff_Ruins", string.format("%d", roomNum)) -- "유적의 힘%d"
				mine9DefaultUI.UIMouseHover.Type3_Desc = 
				_LocalizationService:GetTextFormat("Debuff_Desc_Ruins", string.format("%d",roomHPUseAmount), string.format("%d",defaultHPUseAmount), string.format("%d",(140*(roomNum-1))))
				--"초당 %d만큼 체력이 감소합니다. 유적 깊이에 따라 더 많이 감소합니다.\n(기본:%d, 깊이 비례 추가:%d%%)"			
				
				local finalHPUseAmount = roomHPUseAmount * (1 + 0.1*self.CurseStack)
				self.Entity.PlayerIngameData:SetHPUseAmount(finalHPUseAmount)
			end
			
			if self.Shocked_LeftTime > 0 then
				self._T.effectSerial = _EffectService:PlayEffectAttached("54f2920bb9d841cf8a882ea53aefed23", self.Entity, Vector3(0,0.5,0), 0, Vector3.one, true)
			end
		elseif string.sub(enteredMap.Name, 1, 4) == "Temp" then
			local blind = _EntityService:GetEntity("4980a1f7-46dd-4bdf-99e2-21466da5d2f4")
			
			if self.Entity.CurrentMapName == "Temple_Apollon_3" then
				blind.Visible = false
				local func = function()
					_UIToast:ShowMessage(_LocalizationService:GetText("Message_EnterApollonTemple"))
				end
				_TimerService:SetTimerOnce(func, 1.5)
			else
				blind.Visible = true
			end
		end
		
		local mateiralUI = _EntityService:GetEntity("406876ba-7427-4448-939d-28655b4a8b19")
		if self.StageNum == 3 then
			mateiralUI.Enable = true
			mateiralUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "d660bfd2e6d44b9182f048e730db5b5f"
			mateiralUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("Icicle") -- "고드름"
			mateiralUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("Desc_Icicle") -- "채광 시 일정 확률로 획득합니다. 출구의 고드름 상인에게 다가가면 자동으로 판매되어 골드를 얻을 수 있습니다." 
			mateiralUI.UIMouseHover.Type3_Icon = "d660bfd2e6d44b9182f048e730db5b5f"
			mateiralUI:GetChildByName("Amount").TextComponent.Text = string.format("%d", self.HavingMaterialNum)
			
		elseif self.StageNum == 6 then
			mateiralUI.Enable = true
			mateiralUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "e64e842795614536911e0df826d2c953"
			mateiralUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("Stardust") -- "별 조각"
			mateiralUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("Desc_Stardust") -- "채광 시 획득합니다. 10개를 모으면 '신난다!' 상태가 됩니다." 
			mateiralUI.UIMouseHover.Type3_Icon = "e64e842795614536911e0df826d2c953"
			mateiralUI:GetChildByName("Amount").TextComponent.Text = string.format("%d", self.HavingMaterialNum)
			
		elseif self.StageNum == 7 then
			mateiralUI.Enable = true
			mateiralUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "286fbd8ad97645818ef5269b67c144e6"
			mateiralUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("CloudPiece") -- "구름 조각"
			mateiralUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("Desc_CloudPiece") -- "채광 시 획득합니다. 10개를 모으면 보호막을 1개 얻습니다." 
			mateiralUI.UIMouseHover.Type3_Icon = "286fbd8ad97645818ef5269b67c144e6"
			mateiralUI:GetChildByName("Amount").TextComponent.Text = string.format("%d", self.HavingMaterialNum)
		
		elseif string.sub(enteredMap.Name, 1, 6) == "Temple" then
			mateiralUI.Enable = true
			mateiralUI:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "301b843fc7b64332bbc2347db41a623d"
			mateiralUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("GoldApple") 
			mateiralUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("Desc_GoldApple") 
			mateiralUI.UIMouseHover.Type3_Icon = "301b843fc7b64332bbc2347db41a623d"
			mateiralUI:GetChildByName("Amount").TextComponent.Text = string.format("%d", self.HavingMaterialNum)
		
		else 
			mateiralUI.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 플레이어의 상태이상과 환경적 디버프를 업데이트
		if self.Entity ~= _UserService.LocalPlayer then
			return
		end
		
		if _UserService.LocalPlayer.CurrentMapName == "Town10" then
			if self.Entity.CameraComponent.ConfineCameraArea == false then
				self.Entity.CameraComponent.ConfineCameraArea = true
				self.Entity.CameraComponent.ConfineCameraArea = false
				self.Entity.CameraComponent.ConfineCameraArea = true
			end
		else
			if self.Entity.CameraComponent.ConfineCameraArea == true then
				self.Entity.CameraComponent.ConfineCameraArea = false
				self.Entity.CameraComponent.ConfineCameraArea = true
				self.Entity.CameraComponent.ConfineCameraArea = false
			end
		end
		
		if self.Entity.CurrentMapName == "Temple_Hades_8" then
			if self.Entity.CurrentMap.TempleHadesManager.startGame and self.Entity.PlayerControllerComponent.LookDirectionX < 0 and not self.Entity.CurrentMap.TempleHadesManager.gameOver then
				--log("게임 오버")
				self.Entity.CurrentMap.TempleHadesManager.gameOver = true
				_UIToast:ShowMessage(_LocalizationService:GetText("Message_PlayerLookLeft"))
				self.Entity.PlayerIngameData.CompulsiveRigidbodyOff = true
				self.Entity.RigidbodyComponent.Enable = false
				self.Entity.MovementComponent.Enable = false
			end
		end
		
		if self.playerInWater then
			if not self.Entity.RigidbodyComponent:IsOnGround() and self.Entity.RigidbodyComponent.Gravity ~= 0.5 then
				self.Entity.RigidbodyComponent.Gravity = 0.5
			end
		end
		
		local ingameData = self.Entity.PlayerIngameData
		
		-- 중독
		local poisonUI = self.UI_Poison
		if self.Poison_LeftTime > 0 then
			self.Poison_TickTime = self.Poison_TickTime - delta
			self.Poison_LeftTime = self.Poison_LeftTime - delta
		
			poisonUI.Enable = true
			poisonUI.TextComponent.Text = string.format("%.1f", self.Poison_LeftTime)
			
			if self.Poison_TickTime <=0 then
				ingameData:UnprotectedHit(ingameData.HPMax * 0.01)
				self.Poison_TickTime = 1
			end
			
			--self.Entity:GetChildByName("AvatarRoot")
		else 
			poisonUI.Enable = false
			self.Poison_TickTime = 0
		end
		
		-----------------------------------
		
		-- 3. 8스테이지 추위
		if self.StageNum == 3 or (self.StageNum == 8 and self.IsNight == true) or (isvalid(self.Entity.CurrentMap.DemeterTempleManager) and 
			not self.Entity.CurrentMap.DemeterTempleManager.inSpring) then
			local coldUI = self.UI_Cold
			coldUI.TextComponent.Text = string.format("%d", self.ColdStack)
			coldUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Cold") 
			coldUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("StateDesc_Cold")
			coldUI.Enable = true
			local MiningGameUI = _EntityService:GetEntity("cf7e8298-08f2-4352-b1bc-6a21d7d3992f")
			if MiningGameUI.MiningGame.onMining == false and not self.onSnowMan and self.Entity.PlayerIngameData.isIngame then
				self.ColdCoolTime = self.ColdCoolTime + delta
				if self.ColdCoolTime >= 2 then
					self.ColdCoolTime = 0
					self.ColdStack = self.ColdStack + 1
		
					if self.ColdStack >= 10 then
						self:FreezePlayer()
						self.ColdStack = 0
					end
				end
			end
		else 
			if self.onSnowMan then
				self.onSnowMan = false
			end
			if isvalid(self.snowMan) then
				self.snowMan:Destroy()
				self.Entity.MovementComponent.Enable = true
				self.Entity.AvatarRendererComponent.Enable = true
			end
			self.UI_Cold.Enable = false
		end
		
		-----------------------------------
		
		-- 8스테이지 낮과 밤
		local dayUI = self.UI_Day
		local nightUI = self.UI_Night
		if self.StageNum == 8 then
			
			self.IsNight = self.Entity.CurrentMap.TrapDayOrNight.IsNight
			
			if self.IsNight == true then
				dayUI.Enable = false
				nightUI.Enable = true
			else 
				dayUI.Enable = true
				nightUI.Enable = false
				self.ColdStack = 0
			end
		else 
			dayUI.Enable = false
			nightUI.Enable = false
		end
		
		-----------------------------------
		
		-- 감전
		local shockedUI = self.UI_Shocked
		if self.Shocked_LeftTime > 0 then
			self.Shocked_LeftTime = self.Shocked_LeftTime - delta
			
			shockedUI.Enable = true
			shockedUI.TextComponent.Text = string.format("%d", self.Shocked_LeftTime)
			if string.sub(self.Entity.CurrentMapName, 1, 4) == "Mine" then
				shockedUI.TextComponent.FontSize = 26
				shockedUI:GetChildByName("damage").Enable = false
				shockedUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Shocked")
				shockedUI.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("Desc_ElectricShock", string.format("%d", self.Shocked_LeftTime))
			elseif string.sub(self.Entity.CurrentMapName, 1, 6) == "Temple" then
				shockedUI.TextComponent.FontSize = 20
				shockedUI:GetChildByName("damage").Enable = true
				shockedUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Shocked")
				shockedUI.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("Desc_ElectricShock_Temple", string.format("%d",self.ShockedStack + 1), string.format("%d", self.Shocked_LeftTime))
				-- string.format("감전 상태가 되는 피해를 입었습니다! 다음 피해를 {0}배로 받습니다. (남은 지속시간 : {0}초)", self.ShockedStack + 1, self.Shocked_LeftTime)
				shockedUI:GetChildByName("damage").TextComponent.Text = "x"..math.floor(self.ShockedStack + 1)
			end
		else 
			self.ShockedStack = 0
			if self.Entity.CostumeManagerComponent.CustomHairEquip ~= self._T.originHairRUID then
				self.Entity.CostumeManagerComponent.CustomHairEquip = self._T.originHairRUID
			end
			_EffectService:RemoveEffect(self._T.effectSerial)
			_TimerService:ClearTimer(self._T.electedEmotionTimer) 
			
			shockedUI.Enable = false
		end
		
		-- 바다에 빠지면 산소가 감소하는 코드
		if self.playerInWater then
			self.UI_Air.Enable = true
			if self.airGauge <= 0 then
				self.airGauge = 0
				self.Entity.PlayerIngameData:UseMP((self.Entity.PlayerIngameData.MPMax * 0.01) * delta)
				self._T.warningNoAirCount = self._T.warningNoAirCount + delta
				if self._T.warningNoAirCount > 5 then
					self._T.warningNoAirCount = 0
					_UIToast:ShowMessage(_LocalizationService:GetText("Message_NoAir"))
				end
			else
				self.airGauge = self.airGauge - delta * self.airGaugeDecreaseRate		
			end
			self.UI_Air.TextComponent.Text = tostring(math.floor(self.airGauge))
			self.UI_Air.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Air")
			self.UI_Air.UIMouseHover.Type3_Desc = _LocalizationService:GetText("StateDesc_Air")
			-- self.UI_Air.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("StateDesc_Air", math.floor(self.airGauge))
			-- 물에 빠져 공기가 소모되고 있습니다. (남은 산소 : {0}%)
		else
			if self.airGauge < 100 then
				self.airGauge = self.airGauge + self.airGaugeIncreaseRate * delta
				self.UI_Air.TextComponent.Text = tostring(math.floor(self.airGauge))
				self.UI_Air.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Air")
				self.UI_Air.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("StateDesc_Air_Recover") 
			--  self.UI_Air.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("StateDesc_Air_Recover", math.floor(self.airGauge))
			-- 산소를 회복하고 있습니다. (현재 산소 : {0}%)
			elseif self.airGauge >= 100 then
				self.airGauge = 100
				self.UI_Air.Enable = false
			end
		end
		
		if self.UI_Air.Enable then
			if self.airGauge < 20 then
				self.UI_Air.TextComponent.FontColor = Color.red
			else
				self.UI_Air.TextComponent.FontColor = self._T.originAirBuffSlotColor
			end
		end
		
			
		-- 젖음
		local wetUI = self.UI_Wet
		if self.IgniteShieldStack > 0 then
			wetUI.Enable = true
			wetUI.TextComponent.Text = string.format("%d", self.IgniteShieldStack)
		else 
			wetUI.Enable = false
		end
		
		local enchantedUI = self.UI_Enchanted
		if self.EnchantedTime > 0 then
			self.EnchantedTime = self.EnchantedTime - delta
			enchantedUI.Enable = true
			enchantedUI.TextComponent.Text = tostring(math.ceil(self.EnchantedTime))
			enchantedUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Enchanted")
			enchantedUI.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("StateDesc_Enchanted", math.ceil(self.EnchantedTime))
		else 
			self.EnchantedTime = 0
			if self.beEnchanted then
				self:Enchanted(false, self.Entity)
			end
			enchantedUI.Enable = false
			_TimerService:ClearTimer(self._T.enchantedEmotionTimer) -- 표정 타이머 해제
		end
		-----------------------------------
		
		-- 화상
		local burnUI = self.UI_Burn
		if self.IgniteStack > 0 then
			burnUI.Enable = true
			burnUI.TextComponent.Text = string.format("%d", self.IgniteStack)
			burnUI.UIMouseHover.Type3_Name = _LocalizationService:GetTextFormat("Burning", string.format("%d", self.IgniteStack)) -- "%d도 화상"
			
			local hpDecreaseRate = 3
			if self.IgniteStack == 1 then
				hpDecreaseRate = 3
			elseif self.IgniteStack == 2 then
				hpDecreaseRate = 7
			elseif self.IgniteStack == 3 then 
				hpDecreaseRate = 15
			end
			burnUI.UIMouseHover.Type3_Desc = _LocalizationService:GetTextFormat("Desc_Burning", string.format("%d", hpDecreaseRate)) -- "5초마다 최대 체력의 %d%%를 잃습니다. 물에 들어가면 제거됩니다."
		else 
			_TimerService:ClearTimer(self._T.burnEmotionTimer)
			burnUI.Enable = false
		end
		self.IgniteCoolTime = self.IgniteCoolTime + delta
		if self.IgniteCoolTime >= 5 then
			if self.IgniteStack == 1 then
				ingameData:UnprotectedHit(ingameData.HPMax*0.03)
			elseif self.IgniteStack == 2 then
				ingameData:UnprotectedHit(ingameData.HPMax*0.07)
			elseif self.IgniteStack == 3 then
				ingameData:UnprotectedHit(ingameData.HPMax*0.15)
			end
			
			self.IgniteCoolTime = 0
		end
		
		-----------------------------------
		
		-- 신난다!
		local exitedUI = self.UI_Exited
		if self.ExitedMode_LeftTime > 0 then
			if not isvalid(self.Entity.CurrentMap.DemeterTempleManager) then -- 데메테르 신전이 아니라면
				self.ExitedMode_LeftTime = self.ExitedMode_LeftTime - delta
				exitedUI.TextComponent.Text =tostring(math.floor(self.ExitedMode_LeftTime))
				exitedUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("StateDesc_Exiting")
			else -- 데메테르 신전이라면
				exitedUI.UIMouseHover.Type3_Desc = _LocalizationService:GetText("StateDesc_Exiting_Temple")
				exitedUI.TextComponent.Text = ""
			end
			exitedUI.UIMouseHover.Type3_Name = _LocalizationService:GetText("StateName_Exiting")
			exitedUI.Enable = true
		else 
			if isvalid(self.Entity:GetChildByName("ExitingEffect")) then
				self.Entity:GetChildByName("ExitingEffect"):Destroy()
			end
			exitedUI.Enable = false
		end
		
		-----------------------------------
		
		-- 목마름
		if self.StageNum == 8 then
			self.ThirstyCoolTime = self.ThirstyCoolTime + delta
			
			if self.ThirstyCoolTime >= 5 then
				if self.ThirstyStack < 10 then
					self:GetThirstyStack()
				end
				self.ThirstyCoolTime = 0
			end
		end
		
		local thirstyUI = self.UI_Thirsty
		if self.ThirstyStack > 0 then
			thirstyUI.Enable = true
			thirstyUI:GetChildByName("Amount").TextComponent.Text = string.format("%d", self.ThirstyStack)
		else 
			thirstyUI.Enable = false
		end
		
		-----------------------------------
		
		-- 유적 저주
		local curseUI = self.UI_Curse
		if self.StageNum == 9 then
			curseUI.Enable = true
			self.CurseCoolTime = self.CurseCoolTime + delta
			
			if self.CurseCoolTime >= 30 then
				self.CurseCoolTime = 0
				self:GetCurseStack()
				curseUI.TextComponent.Text = string.format("%d", self.CurseStack)
			end
		else 
			curseUI.Enable = false
		end
	end

	@ExecSpace("ServerOnly")
	method void GetMaterial(number amount)
		-- 개수 추가
		self.HavingMaterialNum = self.HavingMaterialNum + amount
		
		-- UI 세팅
		self:SetUI_HavingMaterialNum(self.HavingMaterialNum, self.Entity.OwnerId)
		--------------------------------
		
		-- 보유량에 따라 효과 발동
		local stageNum = tonumber(string.sub(self.Entity.CurrentMapName, 5, 5))
		
		-- 6스테이지 : 10개 보유시 '신난다!' 모드 발동
		if stageNum == 6 and self.HavingMaterialNum >= 10 then
			self:StartExitedMode(self.Entity.OwnerId)
			self:LoseMaterial(10, false)
		
		-- 7스테이지 : 10개 보유시 보호막 획득
		elseif stageNum == 7 and self.HavingMaterialNum >= 10 then
			self.Entity.PlayerIngameData:GetProtector()
			self:LoseMaterial(10, false)
		end
		
		--------------------------------
	end

	@ExecSpace("Server")
	method void SellAllMaterial()
		-- 보유 수량 체크 
		if self.HavingMaterialNum <= 0 then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_NoIcicleMaterial", self.Entity.OwnerId)
			-- _UIToast:ShowMessage("보유한 고드름이 없습니다.", self.Entity.OwnerId)
			return
		end
		
		-- 골드 획득
		local reward = 10 * self.HavingMaterialNum
		self.Entity.PlayerData:GetMoney(reward)
		
		-- 고드름 전부 제거
		self:LoseMaterial(self.HavingMaterialNum, true)
		
		_CustomLocalizationLogic:SendLocalizedFormattedToastMessageFromServer("Desc_SoldOut_Icicle", {reward}, self.Entity.OwnerId)
		-- "고드름을 판매하여 <color=yellow>%d</color> 골드를 획득했습니다!"
	end

	@ExecSpace("Server")
	method void LoseMaterial(number losingAmount, boolean IsInitiating)
		-- 보유 재료(고드름, 별 조각, 구름 조각, 황금 사과) 소모
		if IsInitiating then
			self.HavingMaterialNum = 0
		else
			self.HavingMaterialNum = self.HavingMaterialNum - losingAmount
			
			-- 0개 미만으로 내려가지 않도록 예외처리
			if self.HavingMaterialNum < 0 then
				self.HavingMaterialNum = 0
			end	
		end
		
		
		self:SetUI_HavingMaterialNum(self.HavingMaterialNum, self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void Poisoned(number time)
		-- 중독 상태로 만들고 지속시간 설정
		self.Poison_LeftTime = time
	end

	@ExecSpace("Client")
	method void FreezePlayer()
		-- 추위 스택 10개 달성 시 플레이어를 빙결시켜 2초간 이동 불가
		
		self.Entity.MovementComponent.Enable = false
			_SoundService:PlaySound("10890f3c5b7f44d48e9538fbe13211f2", 0.5)
		
			local effectPos = Vector3(0.45, 0, 0)
			_EffectService:PlayEffectAttached("223e1ac78340484f9a013d7eb81d9982", self.Entity, effectPos, 0, 0.5*Vector3.one)
		
		
		-- 빙결 해제 예약
		if isvalid(self.Entity.CurrentMap.DemeterTempleManager) then
			self:GetSnownStack(1, self.Entity)
		else
			_UIToast:ShowMessage(_LocalizationService:GetText("Debuff_Stack_Cold")) -- 얼어붙었습니다.
			local callback = function()
				self.Entity.MovementComponent.Enable = true
				self.ColdStack = 0
			end
			_TimerService:SetTimerOnce(callback, 2) -- 5초 동안 이동 금지
		end
	end

	@ExecSpace("Client")
	method void ElectricDamage(number Damage, Entity target)
		-- 감전 피해를 입을 때 스택에 따라 피해량 증가 및 외모 변경
		
		if _UserService.LocalPlayer.PlayerComponent.UserId ~= target.PlayerComponent.UserId then
			return
		end
		
		if target.PlayerIngameData.UsingElectricWarp then
			return
		end
		
		local shockEffectRUID = "54f2920bb9d841cf8a882ea53aefed23"
		local shockHairRUID = "a59086e54df1456885a8e44cbda3dedd"
		 
		local playEmotion = function()
			target.AvatarRendererComponent:PlayEmotion(EmotionalType.Pain, 1.5)
		end
		
		if self.Shocked_LeftTime > 0  then -- 감전 스택이 남아 있는 상태
			if string.sub(self.Entity.CurrentMapName, 1, 4) == "Mine" then
				target.PlayerIngameData:Hit(Damage * 2)
				self.Shocked_LeftTime = 0
		
			elseif string.sub(self.Entity.CurrentMapName, 1, 4) == "Temp" then
				_TimerService:ClearTimer(self._T.electedEmotionTimer)
				self._T.electedEmotionTimer = _TimerService:SetTimerRepeat(playEmotion, 1.5)
				self.Shocked_LeftTime = 30
				if self.ShockedStack + 1 <= 99 then 
					self.ShockedStack = self.ShockedStack + 1 
				end
				
				target.PlayerIngameData:Hit(Damage * (self.ShockedStack)) -- 2배의 데미지
			end
		else -- 감전 스택이 없는 상태에서 최초로 피해를 당한 것이다.
			target.CostumeManagerComponent.CustomHairEquip = shockHairRUID
			self._T.effectSerial = _EffectService:PlayEffectAttached(shockEffectRUID, self.Entity, Vector3(0,0.5,0), 0, Vector3.one, true)
			self.Shocked_LeftTime = 30
			_TimerService:ClearTimer(self._T.electedEmotionTimer)
			self._T.electedEmotionTimer = _TimerService:SetTimerRepeat(playEmotion, 1.5)
			if string.sub(self.Entity.CurrentMapName, 1, 4) == "Temp" then
				self.ShockedStack = 1
			end
			target.PlayerIngameData:Hit(Damage)
		end
		
	end

	@ExecSpace("Client")
	method void StartExitedMode()
		-- 6스테이지에서 별 조각 10개 획득시 '신난다!' 모드 활성으로 15초간 MP 소모 없이 대쉬 가능
		
		-- _UIToast:ShowMessage("신난다! 15초간 게임 없이 채광하고 마나없이 대쉬할 수 있습니다!")
		
		local coolTime = 15
		
		if isvalid(self.Entity.CurrentMap.DemeterTempleManager) then
			local effect = _SpawnService:SpawnByModelId("model://5b61c326-d4dd-45bf-8cb0-744d661bf660", "ExitingEffect", Vector3.zero, self.Entity)
			effect.SpriteRendererComponent.SortingLayer = "Foreground"
			_UIToast:ShowMessage(_LocalizationService:GetText("StateDesc_Exiting_Temple"))
		else
			-- 시작 이펙트
			_UIToast:ShowMessage(_LocalizationService:GetText("StateDesc_Exiting"))
			_EffectService:PlayEffectAttached("01d3431f34344bab92bed9e1c3a637c9", self.Entity, Vector3.zero,
					0, Vector3.one)
		
			-- 유지 이펙트
			local playEffect = function()
				_EffectService:PlayEffectAttached("0363d5b19d26454f81e1add4c0e09e9f", self.Entity, Vector3(0, 0.25, 0),
				0, 0.3*Vector3.one)
			end
			for i=1, 15 do
				_TimerService:SetTimerOnce(playEffect, i)
			end
			-- 유지 브금
			_SoundService:PlayBGM("87ad51b138dc433ab652facf35564a62", 1)
			local backToOriginalBGM = function()
				self.Entity.CurrentMap.SoundComponent:Play()
			end
			_TimerService:SetTimerOnce(backToOriginalBGM, 15)
		end
		self.ExitedMode_LeftTime = coolTime
		
		if not isvalid(self.Entity.CurrentMap.DemeterTempleManager) then -- 데메테르 신전이 아니라면
			self:StartExitedModeOnServer(coolTime) -- 쿨타임 없이 대쉬가능하게 해주는 구조
		end
	end

	@ExecSpace("Server")
	method void StartExitedModeOnServer(number Cooltime)
		-- 서버에서 '신난다!' 모드의 MP 소모량 0으로 설정 및 지속시간 후 원복
		self.Entity.PlayerIngameData.MPUseRate = 0
		local callback = function()
			self.Entity.PlayerIngameData.MPUseRate = 1
		end
		_TimerService:SetTimerOnce(callback, Cooltime)
	end

	@ExecSpace("Server")
	method void RemoveThirstyStack(boolean calledFromInitFunc)
		-- 8스테이지 물웅덩이에서 물를 마셔 목마름 스택 제거
		self.ThirstyStack = 0
		
		self.Entity.PlayerData:ApplyPlayerStatus()
		
		if calledFromInitFunc == false then
			_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("ThirstQuenching", self.Entity.OwnerId)
			-- _UIToast:ShowMessage("물을 마셔 갈증을 해소했습니다!",self.Entity.OwnerId)
		end
	end

	@ExecSpace("Client")
	method void GetBurnStack(number addedStackAmount, Entity target)
		-- 5스테이지 화상 스택 추가 - 단계별로 피해량 증가, 수분 스택으로 상쇄
		if _UserService.LocalPlayer.PlayerComponent.UserId ~= target.PlayerComponent.UserId then
			return
		end
		
		if string.sub(self.Entity.CurrentMapName, 1, 4) == "Town" then
			return
		end
		
		if self.IgniteShieldStack > 0 then
			self.IgniteShieldStack = self.IgniteShieldStack - 1
			_UIToast:ShowMessage(_LocalizationService:GetText("MoistureEvaporation"))
			-- _UIToast:ShowMessage("열기로 인해 수분이 증발하고 있습니다!")
			return
		end
		
		_EffectService:PlayEffectAttached("f6f0654090be449ca7ba8bd92fb578cb", target, Vector3.zero, 0 , Vector3(2,2,0))
		_SoundService:PlaySound("2f2128d0ed70486fbf91d86ffb89a7b5", 1)
		
		local changeEmotion = function()		
			target.AvatarRendererComponent:PlayEmotion(EmotionalType.Hot, 1.5)
		end
		
		-- 화상 이펙트
		if target:GetChildByName("burnEffect") == nil then
			local IgniteEffect = _SpawnService:SpawnByModelId(
			"model://a6370578-c4b8-4c1f-a8e4-1af39a645cdd", 
			"burnEffect", 
			Vector3(0, -0.35, 0), 
			target)
			self._T.burnEmotionTimer = _TimerService:SetTimerRepeat(changeEmotion, 1.5, 0)
		end
		
		-- 3도화상 이후는 없음
		if self.IgniteStack >= 3 then 
			return 
		end
		
		self.IgniteStack = self.IgniteStack + addedStackAmount
		_UIToast:ShowMessage(_LocalizationService:GetTextFormat("Debuff_Stack_Burning", string.format("%d", self.IgniteStack)))
		-- _UIToast:ShowMessage(string.format("앗 뜨거! %d도 화상 상태가 되었어요.", self.IgniteStack))
	end

	@ExecSpace("Client")
	method void GetWetStack(boolean getShield)
		-- 5스테이지에서 물에 닿았을 때 전체 화상 스택 제거 및 수분 보호막 추가
		-- 5스테이지가 아니면 젖음 스택 추가 X
		--[[ 
		if self.StageNum ~= 5 then 
			return 
		end 
		]]--
		------------------------------
		self.IgniteStack = 0
		
		_TimerService:ClearTimer(self._T.burnEmotionTimer)
		self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Hot, 0.1)
		
		local burnEffect = self.Entity:GetChildByName("burnEffect")
		
		if burnEffect ~= nil then
			burnEffect:Destroy()
		end
		
		if getShield and self.IgniteShieldStack < 3 then
			self.IgniteShieldStack = self.IgniteShieldStack + 1
		end
	end

	@ExecSpace("Client")
	method void GetCurseStack()
		-- 9스테이지(유적)에서 30초마다 저주 스택 추가 - 체력 소모량 10%씩 증가
		self.CurseStack = self.CurseStack + 1
		
		_UIToast:ShowMessage(_LocalizationService:GetText("Debuff_Stack_Ruins"))
		-- _UIToast:ShowMessage("유적의 저주를 받았습니다! 체력이 10% 더 빨리 감소합니다...")
		
		local hpUseAmountTable = _DataService:GetTable("HPUseAmountAtMine")
		local hpUseAmount = tonumber(hpUseAmountTable:GetCell(self.StageNum, 2))
		
		local roomNum = tonumber(string.sub(_UserService.LocalPlayer.CurrentMapName, 7, -1))
		hpUseAmount = hpUseAmount * (1 + 1.4*(roomNum-1))
		hpUseAmount = hpUseAmount * (1 + 0.1*self.CurseStack)
		
		self.Entity.PlayerIngameData:SetHPUseAmount(hpUseAmount)
	end

	@ExecSpace("Client")
	method void InitAllState(boolean inTemple)
		-- 모든 디버프와 상태이상을 초기화하고 관련 이펙트와 UI 제거
		
		self.Poison_LeftTime = 0
		
		self.ColdStack = 0
		self.ColdCoolTime = 0
		
		self.EnchantedTime = 0
		self:Enchanted(false, self.Entity)
		
		self.CurseStack = 0
		self.CurseCoolTime = 0
		
		if self.UI_Curse.TextComponent then
			self.UI_Curse.TextComponent.Text = "0"
		end
		
		self.ExitedMode_LeftTime = 0
		
		if not inTemple then
			self:LoseMaterial(self.HavingMaterialNum, true)
		end
		
		self.IgniteCoolTime = 0
		self.IgniteShieldStack = 0
		self.IgniteStack = 0
		
		local burnEffect = self.Entity:GetChildByName("burnEffect")
		if burnEffect ~= nil then
			burnEffect:Destroy()
		end
		
		self.Shocked_LeftTime = 0
		self.ShockedStack = 0
		self:RemoveThirstyStack(true)
		
		self:Diving(false)
		self.airGauge = 100
		
		self.Entity.RigidbodyComponent.WalkDrag = 0.5
		self.Entity.PlayerIngameData.CompulsiveRigidbodyOff = false
		self.Entity.PlayerIngameData.UsingElectricWarp = false
		if self.Entity.MovementComponent.Enable == false then
			self.Entity.MovementComponent.Enable = true
		end
		if self.Entity.RigidbodyComponent.Enable == false then
			self.Entity.RigidbodyComponent.Enable = true
		end
		if self.Entity.Visible == false then
			self.Entity.Visible = true
		end
		
		if self.Entity.CurrentMapName ~= "Temple_Apollon_3" then -- 아폴론 신전에서 visible을 꺼 주고 있기 때문에.. 다른 곳에선 다시 켜줘야 함
			local blind = _EntityService:GetEntity("4980a1f7-46dd-4bdf-99e2-21466da5d2f4") 
			blind.Visible = true
		end
	end

	@ExecSpace("Server")
	method void GetThirstyStack()
		-- 8스테이지에서 5초마다 목마름 스택 추가 - 이동속도 저하
		self.ThirstyStack = self.ThirstyStack + 1
		
		_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Debuff_Stack_Thirsty", self.Entity.OwnerId)
		-- _UIToast:ShowMessage("목이 말라 점점 느려집니다.", self.Entity.OwnerId)
		
		self.Entity.PlayerData:ApplyPlayerStatus()
	end

	@ExecSpace("Client")
	method void SetUI_HavingMaterialNum(number amount)
		-- 스테이지별 재료 보유량을 UI에 업데이트
		self.HavingMaterialNum = amount
		local materialUI = _EntityService:GetEntity("406876ba-7427-4448-939d-28655b4a8b19")
		materialUI:GetChildByName("Amount").TextComponent.Text = string.format("%d", amount)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 기본 설정값들을 설정
		if self.Entity ~= _UserService.LocalPlayer then
			return
		end
		
		
		self._T.originHairRUID = _UserService.LocalPlayer.CostumeManagerComponent.CustomHairEquip
		self._T.HitSquidDuration = 10
		self._T.HitBySquid = false -- 먹물에 맞았는 지(true = 맞음, false = 맞지 않음)
		self._T.originAirBuffSlotColor = self.UI_Air.TextComponent.FontColor
		self._T.warningNoAirCount = 0
		-- MapEnter에서 실행하도록 바꿔줘야 함
		-- self:InitRotationShield()
		
		
	end

	@ExecSpace("Client")
	method void HitBySquid()
		-- 5스테이지 오징어의 먹물에 맞았을 때 화면 효과와 통제 제약
		local inkSprite = _EntityService:GetEntityByPath("/ui/IngameGroup/Ink")
		
		
		if self._T.HitBySquid then -- 맞은 상태에서 다시 맞은 경우라면!
			_TimerService:ClearTimer(self._T.playFunc)
			inkSprite.SpriteGUIRendererComponent.Color.a = 0.5
		else
			inkSprite:SetEnable(true)
		end
		
		self._T.HitBySquid = true
		
		local iCount = 0
		
		local decreaseAlpha = function(number)
			iCount = iCount + 1
			if iCount == 50 then
				iCount = 0
				inkSprite:SetEnable(false)
				self._T.HitBySquid = false
				inkSprite.SpriteGUIRendererComponent.Color.a = 0.5
			end
			inkSprite.SpriteGUIRendererComponent.Color.a = inkSprite.SpriteGUIRendererComponent.Color.a - 0.01
		end
		
		local turnOff = function()
			for i = 1 , 50 do
				self._T.playFunc = _TimerService:SetTimerOnce(decreaseAlpha, (i*4) / 50)
			end
		end
		_TimerService:SetTimerOnce(turnOff, self._T.HitSquidDuration)
		
	end

	@ExecSpace("Client")
	method void GetRotationShield()
		-- 7스테이지 구름 조각 10개로 획득하는 회전 보호막 생성 (최대 6개)
		
		for i = 1 , 6 do
			if self.RotationShield[i] == false then
				self.RotationShield[i] = true
				local shield = _SpawnService:SpawnByModelId("model://7d0a8504-7fc6-47c1-a0ec-a3a5fe6b401f", "Shield", Vector3(0, 0, 0), _UserService.LocalPlayer)
				shield:Detach()
				shield.RotationShield.index = i
				if i == 1 then shield.RotationShield.angle = 0
				elseif i == 2 then shield.RotationShield.angle = 45
				elseif i == 3 then shield.RotationShield.angle = 90	
				elseif i == 4 then shield.RotationShield.angle = 135		
				elseif i == 5 then shield.RotationShield.angle = 180
				elseif i == 6 then shield.RotationShield.angle = 225
				end
				return
			end
		end
		-- 만약 모두가 True일 경우엔..
		_UIToast:ShowMessage("쉴드는 최대 6개까지 보유할 수 있습니다.")
	end

	@ExecSpace("Client")
	method void RemoveRotationShield(number index)
		-- 지정된 인덱스의 회전 보호막을 제거
		self.RotationShield[index] = false
	end

	@ExecSpace("Client")
	method void Enchanted(boolean play, Entity target)
		-- 6스테이지 아프로디테 매혹 효과 - 좌우 조작키 반전
		if self.Entity.PlayerComponent.UserId ~= target.PlayerComponent.UserId then
			return
		end
		
		local offEnchanted = function()
			self:Enchanted(false, target)
		end
		
		local playEmotion = function()
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Love, 1.5)
		end
		
		if play then -- 매혹켜기
			if self.beEnchanted then -- 매혹인 상태에서 다시 맞기
				_TimerService:ClearTimer(self._T.timer)
				_TimerService:ClearTimer(self._T.enchantedEmotionTimer)
				self._T.enchantedEmotionTimer = _TimerService:SetTimerRepeat(playEmotion, 1.5)
			else -- 매혹 최초로 맞기
				self.beEnchanted = true
				if not isvalid(target:GetChildByName("heartChat")) then
					local heartChat = _SpawnService:SpawnByModelId("model://240b85ac-6cbf-4ed8-845e-eafac7c83959", "heartChat", Vector3(0, 0.5, 0), target)
					heartChat.SpriteRendererComponent.SortingLayer = "Foreground"
				end
				target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.RightArrow)
				target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.LeftArrow)
				target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.A)
				target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.D)
		
				target.PlayerControllerComponent:SetActionKey(KeyboardKey.RightArrow, "MoveLeft")
				target.PlayerControllerComponent:SetActionKey(KeyboardKey.LeftArrow, "MoveRight")
				target.PlayerControllerComponent:SetActionKey(KeyboardKey.A, "MoveRight")
				target.PlayerControllerComponent:SetActionKey(KeyboardKey.D, "MoveLeft")
		
				_TimerService:ClearTimer(self._T.enchantedEmotionTimer)
				self._T.enchantedEmotionTimer = _TimerService:SetTimerRepeat(playEmotion, 1.5)
			end
			_EffectService:PlayEffectAttached("8954464adb284257b3371f908e9f6c5b", self.Entity.CurrentMap, Vector3(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y +0.2,0),0 ,Vector3(3,3,0))
			self._T.timer = _TimerService:SetTimerOnce(offEnchanted, self.maxEnchantedTime)
			self.EnchantedTime = self.maxEnchantedTime
			_SoundService:PlaySound("00d2f7479e3840688ef2d655ac54b63c", 1)
			_UIToast:ShowMessage(_LocalizationService:GetText("Message_Enchated"))
			
		else -- 매혹끄기
			_TimerService:ClearTimer(self._T.timer)
			self.beEnchanted = false
			
			if isvalid(target:GetChildByName("heartChat")) then
				target:GetChildByName("heartChat"):Destroy()
			end
			
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.RightArrow))
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.LeftArrow))
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.A))
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.D))
			
			target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.RightArrow)
			target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.LeftArrow)
			target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.A)
			target.PlayerControllerComponent:RemoveActionKey(KeyboardKey.D)
			
			target.PlayerControllerComponent:SetActionKey(KeyboardKey.RightArrow, "MoveRight")
			target.PlayerControllerComponent:SetActionKey(KeyboardKey.LeftArrow, "MoveLeft")
			target.PlayerControllerComponent:SetActionKey(KeyboardKey.A, "MoveLeft")
			target.PlayerControllerComponent:SetActionKey(KeyboardKey.D, "MoveRight")
		
			if isvalid(target:GetChildByName("keyArrow_L")) then
				target:GetChildByName("keyArrow_L"):Destroy()
			end
			if isvalid(target:GetChildByName("keyArrow_R")) then
				target:GetChildByName("keyArrow_R"):Destroy()
			end
			
		end
	end

	@ExecSpace("Client")
	method void GetSnownStack(number addedStackAmount, Entity target)
		-- 데메테르 신전에서 빙결시 눈사람이 되어 좌우 버튼 연타로 탈출
		if _UserService.LocalPlayer.PlayerComponent.UserId ~= target.PlayerComponent.UserId then 
			return
		end
		
		local MiningGameUI = _EntityService:GetEntity("cf7e8298-08f2-4352-b1bc-6a21d7d3992f")
		if self.onSnowMan or  MiningGameUI.MiningGame.onMining then -- 이미 눈사람이 있거나, 미니게임 진행중이라면 return 처리
			return
		end
		
		self.ColdStack = 0
		self.onSnowMan = true
		self._T.SnowManHP = _UtilLogic:RandomIntegerRange(4, 6)
		self._T.maxSnowManHP = self._T.SnowManHP
		self._T.PressL = false
		
		self.Entity.MovementComponent.Enable = false
		self.Entity.AvatarRendererComponent.Enable = false
		
		if self.Entity.StateComponent.CurrentStateName == "LADDER" or self.Entity.StateComponent.CurrentStateName == "ROPE" then
			self.Entity.StateComponent:ChangeState("FALL")
		end
		
		self.snowMan = _SpawnService:SpawnByModelId("model://b5b0ea17-aa60-46d0-8a1d-79328151b3d4", "SnowMan", Vector3.zero, target)
		self.snowMan.SnowMan.target = target
		self.snowMan.SpriteRendererComponent.SortingLayer = "Layer2"
		
		_UIToast:ShowMessage(_LocalizationService:GetText("Message_GetSnown")) -- 얼어붙어 눈사람이 되었습니다.
		
	end

	@ExecSpace("Client")
	method void Diving(boolean diving)
		-- 2스테이지 바다에 다이빙할 때 산소 게이지와 버블 생성
		
		self.airGaugeIncreaseRate = 15 -- 두 개는 시작할 때 능력치 기반으로 산정해야 함
		self.airGaugeDecreaseRate = 8
		
		local SpawnBubble = function()
			
			local spawnVector = Vector3(_UserService.LocalPlayer.TransformComponent.WorldPosition.x, _UserService.LocalPlayer.TransformComponent.WorldPosition.y + 0.15, 0)
		
			if self.playerInWater then
		
				local BubbleEntity = _SpawnService:SpawnByModelId("model://649ed171-bfcc-4044-ba2a-1841a1f8782e", "AirBubble", 
				self.Entity.TransformComponent.WorldPosition, self.Entity.CurrentMap)
		
				local destroyBubble = function()	
					if isvalid(BubbleEntity) then
						BubbleEntity:Destroy()
					end
				end
				_TimerService:SetTimerOnce(destroyBubble, 10)
				
				local moveRight = function()
					if isvalid(BubbleEntity) then
						BubbleEntity.TransformComponent:Translate(0.01, 0.01)
					end
				end
			
				local moveLeft = function()
					if isvalid(BubbleEntity) then
						BubbleEntity.TransformComponent:Translate(-0.01, 0.01)
					end
				end
		
				for i = 1, 100 do
					if i % 2 == 1 then
						_TimerService:SetTimerOnce(moveRight, (i*10) / 100) -- 5초 동안
					else 
						_TimerService:SetTimerOnce(moveLeft, (i*10) / 100)
					end
				end
			end	
		end
		
		if diving then
			_SoundService:PlaySound("10a95382eab94dc88fc54b90df247962", 0.5)
			self.Entity.PlayerStateAtStage.playerInWater = diving	
			self.Entity.AvatarRendererComponent.SortingLayer = "Layer2"
			self.Entity.AvatarRendererComponent.OrderInLayer = 1
			local nameTag = _SpawnService:SpawnByModelId("model://0f543aca-7a60-4839-98d5-a220bd308c4d", "nameTag", Vector3.zero, self.Entity)
			nameTag.NameTagComponent.NameTagRUID = self.Entity.NameTagComponent.NameTagRUID
			nameTag.NameTagComponent.Name = self.Entity.PlayerComponent.Nickname
			self.Entity.NameTagComponent.Enable = false
			local func = function()
				_TimerService:SetTimerOnce(SpawnBubble, 5)
			end
			self._T.bubbleSpawner = _TimerService:SetTimerRepeat(func, 10, 5)
		else
			self.Entity.PlayerStateAtStage.playerInWater = diving	
			self.Entity.AvatarRendererComponent.SortingLayer = "Player"
			self.Entity.AvatarRendererComponent.OrderInLayer = 3
			_TimerService:ClearTimer(self._T.bubbleSpawner)
		
			self.Entity.RigidbodyComponent.Gravity = 1
		
			if isvalid(self.Entity:GetChildByName("nameTag")) then
				self.Entity:GetChildByName("nameTag"):Destroy()
				self.Entity.NameTagComponent.Enable = true
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnMapLeave(Entity leftMap)
		-- 맵 퇴장시 신전별 설정 초기화
		if self.Entity ~= _UserService.LocalPlayer then
			return
		end
		
		if leftMap.Name == "Temple_Demeter_7" then
			_UserService.LocalPlayer.PlayerStateAtStage.ExitedMode_LeftTime = 0
			_UserService.LocalPlayer.RigidbodyComponent.WalkDrag = 0.5
			--log("플레이어가 데메테르 신전을 떠났습니다.")
			
		elseif leftMap.Name == "Temple_Hades_8" then
			-- log("플레이어가 하데스 신전을 떠났습니다.")
			self.Entity.PlayerIngameData:resetPlayerSpeed(self.hadesOriginSpeed, self.Entity.PlayerComponent.UserId)
			self.Entity.MovementComponent.Enable = true
			self.Entity.PlayerIngameData.CompulsiveRigidbodyOff = false
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyReleaseEvent(KeyReleaseEvent event)
		-- 매혹 상태에서 키 떼 때 화살표 이팩트 제거
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if key == KeyboardKey.LeftArrow or key == KeyboardKey.A then
			if isvalid(_UserService.LocalPlayer:GetChildByName("keyArrow_L")) then
				_UserService.LocalPlayer:GetChildByName("keyArrow_L"):Destroy()
			end
		elseif key == KeyboardKey.RightArrow or key == KeyboardKey.D then
			if isvalid(_UserService.LocalPlayer:GetChildByName("keyArrow_R")) then
				_UserService.LocalPlayer:GetChildByName("keyArrow_R"):Destroy()
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 매혹 상태나 눈사람 상태에서의 키 입력 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if self.beEnchanted then
			if key == KeyboardKey.RightArrow or key == KeyboardKey.D then
				local arrow = _SpawnService:SpawnByModelId("model://6e013cd4-c682-4713-b836-e344816c8f2c", "keyArrow_R", Vector3(0,1.3,0),_UserService.LocalPlayer)
				arrow.SpriteRendererComponent.SortingLayer = "Foreground"
			elseif key == KeyboardKey.LeftArrow or key == KeyboardKey.L then
				local arrow = _SpawnService:SpawnByModelId("model://093d8d4d-22d5-452a-bc8a-9fdc4174e5a3", "keyArrow_L", Vector3(0,1.3,0),_UserService.LocalPlayer)
				arrow.SpriteRendererComponent.SortingLayer = "Foreground"
			end
		end
		
		if self.onSnowMan and self._T.SnowManHP > 0 and isvalid(self.snowMan) then -- 눈사람 체력이 0이되면 작동하면 안됨
			if self._T.PressL then -- 다음에 L을 눌러야 하는 상황
				if key == KeyboardKey.LeftArrow or key == KeyboardKey.A then
					self._T.PressL = false
					self._T.SnowManHP = self._T.SnowManHP - 1
					self.snowMan.SpriteRendererComponent.FlipX = false
					_SoundService:PlaySound("b72e2a9fdf704601b0f61ed0e6363344", 1)
					_EffectService:PlayEffectAttached("0078562bf3e9485c92b32bd847f1186a", self.snowMan, Vector3.zero, 0, Vector3.one)
				end
			else -- 다음에 R을 눌러야 하는 상황
				if key == KeyboardKey.RightArrow or key == KeyboardKey.D then
					self._T.PressL = true
					self._T.SnowManHP = self._T.SnowManHP - 1
					self.snowMan.SpriteRendererComponent.FlipX = true
					_SoundService:PlaySound("b72e2a9fdf704601b0f61ed0e6363344", 1)
					_EffectService:PlayEffectAttached("0078562bf3e9485c92b32bd847f1186a", self.snowMan, Vector3.zero, 0, Vector3.one)
				end
			end
		
			self.snowMan:GetChildByName("GaugeBox"):GetChildByName("Gauge").SpriteGUIRendererComponent.FillAmount = self._T.SnowManHP / self._T.maxSnowManHP
		
			if self._T.SnowManHP == 0 then
				self.snowMan.SnowMan:destroy()
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleBodyActionStateChangeEvent(BodyActionStateChangeEvent event)
		-- 플레이어 액션 상태 변경에 따른 추가 처리
		-- Parameters
		local ActionState = event.ActionState
		local endFrameIndex = event.endFrameIndex
		local needResetAction = event.needResetAction
		local startFrameIndex = event.startFrameIndex
		--------------------------------------------------------
		
		if tostring(ActionState) == "Crouch" then
			_UserService.LocalPlayer.TriggerComponent.BoxSize.y = 0.35
		else
			_UserService.LocalPlayer.TriggerComponent.BoxSize.y = 0.7
		end
	end

end