@Logic
script AbilityIcon extends Logic

	method string GetAbilityIconRUID(string abilityName)
		-- 능력 이름을 기반으로 해당 능력 아이콘의 RUID를 반환
		local abilityIconTable = _DataService:GetTable("AbilityIcon")
		
		
		if string.sub(abilityName, 1, 9) == "채광력" then
			return abilityIconTable:GetCell(1, 2)
			
		elseif string.sub(abilityName, 1, 13) == "최대 체력" then
			return abilityIconTable:GetCell(2, 2)
			
		elseif string.sub(abilityName, 1, 6) == "가방" then
			return abilityIconTable:GetCell(3, 2)
			
		elseif string.sub(abilityName, 1, 12) == "이동속도" then
			return abilityIconTable:GetCell(4, 2)
			
		elseif string.sub(abilityName, 1, 13) == "최대 기력" then
			return abilityIconTable:GetCell(5, 2)
			
		elseif string.sub(abilityName, 1, 19) == "기력 회복속도" then
			return abilityIconTable:GetCell(6, 2)
			
		elseif string.sub(abilityName, 1, 23) == "기력 소모량 감소" then
			return abilityIconTable:GetCell(7, 2)
			
		elseif string.sub(abilityName, 1, 16) == "치명타 확률" then
			return abilityIconTable:GetCell(8, 2)
			
		elseif string.sub(abilityName, 1, 23) == "치명타 피해 비율" then
			return abilityIconTable:GetCell(9, 2)
			
		elseif string.sub(abilityName, 1, 6) == "행운" then
			return abilityIconTable:GetCell(10, 2)
		
		else
			log("실제 텍스트는 "..abilityName.."이고, 잘못된 값으로 sub 되었음")
		end
	end

	method string GetAbilityIconRUIDByIndex(number index)
		-- 인덱스를 기반으로 능력 아이콘의 RUID를 반환
		local abilityIconTable = _DataService:GetTable("AbilityIcon")
		
		return abilityIconTable:GetCell(index, 2)
	end

	method string GetAbilityNameByIndex(number index)
		-- 인덱스를 기반으로 능력 이름을 반환
		local abilityIconTable = _DataService:GetTable("AbilityIcon")
		
		return abilityIconTable:GetCell(index, 1)
	end

end