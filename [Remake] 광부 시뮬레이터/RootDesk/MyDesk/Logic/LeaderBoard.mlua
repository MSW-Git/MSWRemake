@Logic
script LeaderBoard extends Logic

	@Sync
	property SyncTable<string> nicknameTable

	@Sync
	property SyncTable<number> rpTable

	@Sync
	property SyncTable<string> ppsnTable

	property number updateTime = 600

	@ExecSpace("Server")
	method void SaveData(string playerId, number RP, string nickName)
		-- 플레이어의 랜킹 점수(RP)와 닉네임을 데이터베이스에 저장
		local db = _DataStorageService:GetSortableDataStorage("Ranking")
		
		local keyInfo = DataStorageKeyInfo(playerId, "v1", nickName)
		
		--[[
		local error1, record = db:GetByInfoAndWait(keyInfo)
		if error1 ~= 0 then
			return
		end
		]]--
		
		db:SetByInfoAndWait(keyInfo, math.tointeger(RP))
		
	end

	@ExecSpace("Server")
	method void LoadData()
		-- 서버에서 랜킹 데이터를 내림차순으로 로드하고 접속중인 유저들의 랜킹 업데이트
		local db = _DataStorageService:GetSortableDataStorage("Ranking")
		local error, record = db:GetSortedAndWait(SortDirection.Descending, 1, math.maxinteger)
		
		local loadedDataCount = 0
		
		table.clear(self.ppsnTable)
		table.clear(self.nicknameTable)
		table.clear(self.rpTable)
		
		while true do
			local data = record:GetCurrentPageDatas()
			
			if #data > 0 then
				
		
					
				for k, v in pairs(data) do
					table.insert(self.ppsnTable, v.KeyInfo.Key)
					table.insert(self.nicknameTable, v.KeyInfo.Tag)
					table.insert(self.rpTable, v.Value)
				end
		
				loadedDataCount = loadedDataCount + #data
				
				if record.IsLastPage == false and loadedDataCount < 1000 then
					record:MoveToNextPageAndWait()
				else 
					break
				end
			else 
				break
			end	
		end
		
		--[[
		local data = record:GetCurrentPageDatas()
		
		
		table.clear(self.ppsnTable)
		table.clear(self.nicknameTable)
		table.clear(self.rpTable)
		
		for k, v in pairs(data) do
			table.insert(self.ppsnTable, v.KeyInfo.Key)
			table.insert(self.nicknameTable, v.KeyInfo.Tag)
			table.insert(self.rpTable, v.Value)
		end
		]]--
		
		-- 접속중인 유저들의 랭킹을 갱신합니다.
		local users = _UserService.UserEntities.Values
		for i=1, #users do
			users[i].PlayerEmblem:GetRank()
		end
	end

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 매 시가 정각에 랜킹 데이터를 자동으로 업데이트
		local minute = DateTime.UtcNow.Minute
		local second = DateTime.UtcNow.Second
		
		if minute == 0 and second == 0 and self.updateTime >= 600 then
			self.updateTime = 0
			self:LoadData()
			log("정각 업데이트 실행")
		end
		
		
		
		self.updateTime = self.updateTime + delta
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 서버 시작 시 초기 랜킹 데이터 로드
		self:LoadData()
	end

end