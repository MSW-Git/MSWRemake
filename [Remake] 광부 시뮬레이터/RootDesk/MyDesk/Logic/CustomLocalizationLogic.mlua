@Logic
script CustomLocalizationLogic extends Logic

	property SyncTable<string> keys

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 클라이언트 시작 시 다국어 테이블 로드하고 UI 요소들에 다국어 텍스트 적용
		local localizingTable = _DataService:GetTable("LocalizationTable")
		local keys = localizingTable:GetColumn(1)
		for i=1, #keys do
			self.keys[i] = keys[i]
		end
		
		
		-- UI Localizing 적용
		for i=1, #keys do
			if string.len(keys[i]) >= 4 and string.sub(keys[i], 1, 4) == "/ui/" then
				
				local path = keys[i]
				--log("path = ", path)
				if path ~= nil and path ~= "" then
					local entity = _EntityService:GetEntityByPath(path)
					if entity ~= nil then
						local TextCompo = entity.TextComponent
						if TextCompo ~= nil then
							TextCompo.Text = _LocalizationService:GetText(path)
						end
					end
					
				end
			end
		end
		
		self:ApplyLocalizeOfCommonWordOnUI()
		
		
		--------------
		-- 예외처리
		_EntityService:GetEntityByPath("/ui/MineLoadingGroup/Loading/TipMessage").TextComponent.Text = _LocalizationService:GetText("4001")
	end

	@ExecSpace("Client")
	method void ApplyLocalizeOfCommonWordOnUI()
		-- 공통으로 사용되는 UI 요소들(버튼, 메시지 등)에 수동으로 다국어 적용
		-- 이모티콘 관련
		_EntityService:GetEntityByPath("/ui/EmoticonGroup/EmotShop/GachaResult/ExitButton").TextComponent.Text = _LocalizationService:GetText("OK")
		
		-- 펫 관련
		_EntityService:GetEntityByPath("/ui/PetShopGroup/PetShop/WarningPopup/Panel/ExitButton").TextComponent.Text = _LocalizationService:GetText("Close")
		_EntityService:GetEntityByPath("/ui/PetShopGroup/PetShop/GetNewPetPopup/ExitButton").TextComponent.Text = _LocalizationService:GetText("OK")
		
		-- 인게임 관련
		_EntityService:GetEntityByPath("/ui/PopupGroup/KeyBoxOpen/Panel/ExitButton").TextComponent.Text = _LocalizationService:GetText("OK")
		_EntityService:GetEntityByPath("/ui/PopupGroup/KeyBoxOpen/Panel/ExitButton").TextComponent.Text = _LocalizationService:GetText("OK")
		_EntityService:GetEntityByPath("/ui/IngameGroup/MiningPower/txt_mining_power").TextComponent.Text = _LocalizationService:GetText("8001")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/HP/Title").TextComponent.Text = _LocalizationService:GetText("HP")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/Stamina/Title").TextComponent.Text = _LocalizationService:GetText("MP")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/UIEmpty/HPDescPanel/Title").TextComponent.Text = _LocalizationService:GetText("HP")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/UIEmpty/MPDescPanel/Title").TextComponent.Text = _LocalizationService:GetText("MP")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/UIEmpty/PotionDesc/Title").TextComponent.Text = _LocalizationService:GetText("AdventureItem_Potion")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/UIEmpty/RopeDesc/Title").TextComponent.Text = _LocalizationService:GetText("AdventureItem_Rope")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/UIEmpty/TorchDesc/Title").TextComponent.Text = _LocalizationService:GetText("AdventureItem_Torch")
		_EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/UIEmpty/TrampolineDesc/Title").TextComponent.Text = _LocalizationService:GetText("AdventureItem_Trampoline")
		_EntityService:GetEntityByPath("/ui/MineLoadingGroup/Loading/Button_BeginAdventure").TextComponent.Text = _LocalizationService:GetText("BeginAdventure")
		_EntityService:GetEntityByPath("/ui/MineLoadingGroup/Loading/Button_BeginAdventure/txt_pc").TextComponent.Text = _LocalizationService:GetText("BeginAdventure").." (E)"
		_EntityService:GetEntityByPath("/ui/MineLoadingGroup/Loading/Button_BeginAdventure/txt_pc_1").TextComponent.Text = _LocalizationService:GetText("BeginAdventure")
		
		-- 각 UI 타이틀 번역
		_EntityService:GetEntityByPath("/ui/CollectionGroup/Collection/MainPanel/TitlePanel/Title").TextComponent.Text = _LocalizationService:GetText("SystemTitle_MineralCollection")
		_EntityService:GetEntityByPath("/ui/DailyRewardGroup/DailyReward/Panel/TitlePanel/Title").TextComponent.Text = _LocalizationService:GetText("SystemTitle_DailyReward")
		_EntityService:GetEntityByPath("/ui/HelpGuideGroup/HelpGuide/img_panel/title").TextComponent.Text = _LocalizationService:GetText("SystemTitle_HelpGuide")
		_EntityService:GetEntityByPath("/ui/AchievementGroup/AchievementPopUp/AchievementTitle/Text_Achievement_Title").TextComponent.Text = _LocalizationService:GetText("SystemTitle_Achievement")
		_EntityService:GetEntityByPath("/ui/RelicBookGroup/RelicBook/Panel/TitlePanel/Title").TextComponent.Text = _LocalizationService:GetText("SystemTitle_RelicCollection")
		_EntityService:GetEntityByPath("/ui/TeleportGroup/TeleportSystem/DescPanel/TitleText").TextComponent.Text = _LocalizationService:GetText("SystemTitle_TownTeleport")
		_EntityService:GetEntityByPath("/ui/TitleStorageGroup/TitleStorage/Panel/TitlePanel/Title").TextComponent.Text = _LocalizationService:GetText("SystemTitle_Title")
		
	end

	@ExecSpace("Client")
	method void SendLocalizedToastMessageFromServer(string messageKey)
		-- 서버에서 전달받은 메시지 키로 다국어 토스트 메시지를 표시
		_UIToast:ShowMessage(_LocalizationService:GetText(messageKey))
	end

	@ExecSpace("Client")
	method void SendLocalizedFormattedToastMessageFromServer(string messageKey, table table)
		-- 서버에서 전달받은 메시지 키와 인자들로 포매팅된 다국어 토스트 메시지를 표시
		for i=1, #table do
			if type(table[i]) == "string" then
				table[i] = _LocalizationService:GetText(table[i])
			elseif type(table[i]) == "number" then
				table[i] = string.format("%d", table[i])
			end
		end
		
		
		if #table == 1 then
			_UIToast:ShowMessage(_LocalizationService:GetTextFormat(messageKey, table[1]))
		elseif #table == 2 then
			_UIToast:ShowMessage(_LocalizationService:GetTextFormat(messageKey, table[1], table[2]))
		elseif #table == 3 then
			_UIToast:ShowMessage(_LocalizationService:GetTextFormat(messageKey, table[1], table[2], table[3]))
		end
	end

	@ExecSpace("Client")
	method void SetInstallationObjectsNametag(Entity targetEntity, string ownerNickname, string itemTypeKey)
		-- 설치물 엔티티에 소유자와 아이템 타입을 포함한 다국어 네임태그 설정
		targetEntity.NameTagComponent.Name = _LocalizationService:GetTextFormat("InstallationObjectNameTag", ownerNickname, _LocalizationService:GetText(itemTypeKey))
	end

end