@Component
script MenuUI extends Component

	property number CurrentShowingMenu = 0

	property Entity menuOpenBtn1 = "63d11aba-5d18-4978-b47c-fe488dfb9544"

	property Entity menuOpenBtn2 = "42497362-eef2-4b7f-b174-debeaba07bb3"

	property Entity menuOpenBtn3 = "73a093f7-bf93-442b-8858-d86c6c9fd32f"

	property Entity menu1 = "a6ef3f3e-de2f-4686-9486-b311e2b8ed03"

	property Entity menu2 = "e1c80021-0316-4467-a7e6-74dab0acd900"

	property Entity menu3 = "6055bb48-180b-49fc-8843-046e43841f15"

	property Entity exitButton = "55d0a792-5acb-4804-9511-c96e894ed1b4"

	@ExecSpace("Client")
	method void SetMenuUI()
		-- 현재 선택된 메뉴 상태에 따라 메뉴 버튼들과 메뉴 패널들의 활성화 상태를 설정
		if self.CurrentShowingMenu == 0 then
			self.menuOpenBtn1.ButtonComponent.Enable = true
			self.menuOpenBtn2.ButtonComponent.Enable = true
			self.menuOpenBtn3.ButtonComponent.Enable = true
			self.menu1.Enable = false
			self.menu2.Enable = false
			self.menu3.Enable = false
			self.exitButton.Enable = false
			
		elseif self.CurrentShowingMenu == 1 then
			self.menuOpenBtn1.ButtonComponent.Enable = false
			self.menuOpenBtn2.ButtonComponent.Enable = true
			self.menuOpenBtn3.ButtonComponent.Enable = true
			self.menu1.Enable = true
			self.menu2.Enable = false
			self.menu3.Enable = false
			self.exitButton.Enable = true
			
		elseif self.CurrentShowingMenu == 2 then
			self.menuOpenBtn1.ButtonComponent.Enable = true
			self.menuOpenBtn2.ButtonComponent.Enable = false
			self.menuOpenBtn3.ButtonComponent.Enable = true
			self.menu1.Enable = false
			self.menu2.Enable = true
			self.menu3.Enable = false
			self.exitButton.Enable = true
			
		elseif self.CurrentShowingMenu == 3 then
			self.menuOpenBtn1.ButtonComponent.Enable = true
			self.menuOpenBtn2.ButtonComponent.Enable = true
			self.menuOpenBtn3.ButtonComponent.Enable = false
			self.menu1.Enable = false
			self.menu2.Enable = false
			self.menu3.Enable = true
			self.exitButton.Enable = true
			
		end
	end

	@EventSender("Entity", "63d11aba-5d18-4978-b47c-fe488dfb9544")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 메뉴 1번 버튼 클릭 시 1번 메뉴를 표시
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 1
		self:SetMenuUI()
	end

	@EventSender("Entity", "42497362-eef2-4b7f-b174-debeaba07bb3")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 메뉴 2번 버튼 클릭 시 2번 메뉴를 표시
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 2
		self:SetMenuUI()
	end

	@EventSender("Entity", "73a093f7-bf93-442b-8858-d86c6c9fd32f")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 메뉴 3번 버튼 클릭 시 3번 메뉴를 표시
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 3
		self:SetMenuUI()
	end

	@EventSender("Entity", "55d0a792-5acb-4804-9511-c96e894ed1b4")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 종료 버튼 클릭 시 메뉴를 닫아 초기 상태로 변경
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 0
		self:SetMenuUI()
	end

	@EventSender("Entity", "c3151c73-e0e0-411e-9617-2bf98128f357")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 메뉴를 닫아 초기 상태로 변경
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 0
		self:SetMenuUI()
	end

	@EventSender("Entity", "6e977b1b-e9ad-4875-8178-c810d0ccee76")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 메뉴를 닫아 초기 상태로 변경
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 0
		self:SetMenuUI()
	end

	@EventSender("Entity", "2664a628-6dc9-4eaa-9431-ab7047707637")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 메뉴를 닫아 초기 상태로 변경
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		self.CurrentShowingMenu = 0
		self:SetMenuUI()
	end

	@EventSender("LocalPlayer")
	handler HandleLocalPlayerMapEnterEvent(LocalPlayerMapEnterEvent event)
		-- 플레이어가 마을 맵에 입장했을 때 메뉴를 초기 상태로 리셋
		-- Parameters
		local EnteredMapType = event.EnteredMapType
		---------------------------------------------------------
		if EnteredMapType == "Town" then
			self.CurrentShowingMenu = 0
			self:SetMenuUI()
		end
	end

end