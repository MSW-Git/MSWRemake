@Component
script AchievementItemUI extends Component

	property number index = 0

	property any data = nil

	property table ruidFromType = {}

	property table ruidFromReward = {}

	property AchievementUI achiUI = "1901b65b-b603-4390-ab20-4b2aeb3fb8b6"

	method void OnBeginPlay()
		-- UI 컴포넌트들의 참조를 초기화하고 설정
		self._T.typeImage = self.Entity:GetChildByName("Type_Image")
		self._T.ObjectiveText = self.Entity:GetChildByName("Objective_Text")
		self._T.Description = self.Entity:GetChildByName("Description_Text")
		self._T.ProgressGuage = self.Entity:GetChildByName("Progress_Ui"):GetChildByName("Progress_Gauge")
		self._T.ProgressText = self.Entity:GetChildByName("Progress_Ui"):GetChildByName("Progress_Text")
		self._T.RewardList = self.Entity:GetChildByName("Reward_List")
		self._T.RewardItemIamge = {}
		self._T.RewardItemAmount = {}
		for i=1, 3 do
			self._T.RewardItemIamge[i] = self._T.RewardList:GetChildByName("Item_"..tostring(i)):GetChildByName("Item_Image")
			self._T.RewardItemAmount[i] = self._T.RewardList:GetChildByName("Item_"..tostring(i)):GetChildByName("Item_Count")
		end
		
		
		self._T.ClaimButton = self.Entity:GetChildByName("Claim_Button")
		self._T.ItemHoverName = self.Entity:GetChildByName("ItemHoverName")
		self._T.CoverImage = self.Entity:GetChildByName("Cover_Image")
	end

	method void Refresh()
		-- 업적 데이터에 따라 UI 요소들을 갱신하고 상태에 맞는 버튼을 설정
		local achiTable = _DataService:GetTable("AchievementDataSet")
		
		self._T.typeImage.SpriteGUIRendererComponent.ImageRUID = self.achiUI.ruidFromType[self.data.type]
		
		-- self._T.ObjectiveText.TextComponent.Text = self.data.objective -- 업적 이름
		-- self._T.Description.TextComponent.Text = self.data.description -- 업적 설명
		
		self._T.ObjectiveText.TextComponent.Text = _LocalizationService:GetText(achiTable:GetCell(self.index+1, 2))
		self._T.Description.TextComponent.Text =  _LocalizationService:GetText(achiTable:GetCell(self.index+1, 3))
		
		self._T.ProgressGuage.SliderComponent.Value = self.data.progress / self.data.condition
		self._T.ProgressText.TextComponent.Text = _ThousandsSeparator:Separate(math.floor(self.data.progress)) .." / ".. _ThousandsSeparator:Separate(self.data.condition)
		
		self._T.RewardItemIamge[1].SpriteGUIRendererComponent.ImageRUID = self.achiUI.ruidFromReward[self.data.rewardName1]
		self._T.RewardItemIamge[1].UIMouseHover.Type2_PopupEntity = self._T.ItemHoverName
		self._T.RewardItemAmount[1].TextComponent.Text = self.data.rewardQuantity1
		--[[
		self._T.RewardItemIamge[2].SpriteGUIRendererComponent.ImageRUID = self.achiUI.ruidFromReward[self.data.rewardName2]
		self._T.RewardItemAmount[2].TextComponent.Text = self.data.rewardQuantity2
		self._T.RewardItemIamge[3].SpriteGUIRendererComponent.ImageRUID = self.achiUI.ruidFromReward[self.data.rewardName3]
		self._T.RewardItemAmount[3].TextComponent.Text = self.data.rewardQuantity3
		]]--
		
		-- 클리어한 상태인 경우 : 커버 씌우고, 받기 버튼 제거
		if self.data.isComplete == true then 
			self._T.ClaimButton.Enable = false
			self._T.CoverImage.Enable = true 
			
		elseif self.data.progress >= self.data.condition then
			self._T.ClaimButton.Enable = true
			self._T.ClaimButton.ButtonComponent.Enable = true
			self._T.ClaimButton.TextComponent.Text = _LocalizationService:GetText("GetRewarded")
			--self._T.ClaimButton.TextComponent.Text = "보상 받기"
			self._T.CoverImage.Enable = false 
			
		else
			self._T.ClaimButton.Enable = true
			self._T.ClaimButton.ButtonComponent.Enable = false
			self._T.ClaimButton.TextComponent.Text = _LocalizationService:GetText("Incomplete")
			--self._T.ClaimButton.TextComponent.Text = "미완료"
			self._T.CoverImage.Enable = false 
		end
		
		self._T.ClaimButton.AchievementRewardClaimButtonUI.idx = self.data.idx
		
		-- self._T.ItemHoverName.TextComponent.Text = self.data.rewardName1 -- 보상 호버 텍스트
		self._T.ItemHoverName.TextComponent.Text = _LocalizationService:GetText(achiTable:GetCell(self.index+1, 5))
		
		self._T.ItemHoverName.Enable = false
		
		
	end

	method void Clear()
		-- UI 요소들을 정리하고 초기화 (현재는 특별한 정리 작업 없음)
		
	end

end