@Component
script Trap_Arrow extends Component

	property number speed = 0

	property number Damage = 0

	property Vector2 dir = Vector2(0,0)

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 화살 트랩의 방향과 속도에 따라 이동
		self.Entity.TransformComponent:Translate(self.dir.x * delta * self.speed, self.dir.y * delta * self.speed)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어 충돌 시 밀어내기 및 화살 소멸 (현재 주석 처리됨)
		--[[ Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) then
				local dir = 0
			if self.Entity.SpriteRendererComponent.FlipX then
				dir = 1
			else
				dir = - 1
			end
			
			if TriggerBodyEntity.StateComponent.CurrentStateName == "LADDER" or TriggerBodyEntity.StateComponent.CurrentStateName == "ROPE" then
				TriggerBodyEntity.StateComponent:ChangeState("FALL")
			end
			TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(dir * 1, 1))
			
			_EntityService:Destroy(self.Entity)
		end
		]]--
		
	end

end