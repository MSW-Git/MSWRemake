@Component
script Trap_PillarManager extends Component

	property number Count = 0

	property number ChildrenType = 0

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 화염 기둥 가왕자 초기화 및 자동 공격 시작 설정
		local init = function()
			for i = 1 , #self.Entity.Children do
				if isvalid(self.Entity.Children[i].Trap_PillarOfFire) then
					self.Entity.Children[i].Trap_PillarOfFire.Damage = self.damage
				end
			end
		end
		_TimerService:SetTimerOnce(init, 4)
		
		local func = function()
			self:PlayAttack()
			self.Entity.SpriteRendererComponent.Color.a = 0
		end
		_TimerService:SetTimerOnce(func, 5)
	end

	@ExecSpace("Client")
	method void PlayAttack()
		-- 순차적으로 화염 기둥들의 공격 발동 제어
		self.Count = self.Count + 1
		
		for i = 1 , #self.Entity.Children do
			local target = self.Entity.Children[i]
			if target.Name == "Pillar_"..tostring(math.floor(self.Count)) then
				target.Trap_PillarOfFire:Attack()
			end
		end
		
		if self.Count == self.ChildrenType then
			self.Count = 0
		end
	end

end