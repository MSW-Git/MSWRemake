@Component
script Trap_Squid extends Component

	property number Cooltime = 0

	property string AttackRUID = ""

	property number bulletNum = 0

	property string bulletId = ""

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스퀼드 트랩 초기화 및 공격 타이머 설정
		local playLightning = function()
			self:ReadyShot(true)
		end
		
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		
		_TimerService:SetTimerRepeat(playLightning, self.Cooltime, 10)
	end

	@ExecSpace("Client")
	method void ReadyShot(boolean Switch)
		-- 공격 준비 상태에 따라 스퀼드 색상 변경 애니메이션 실행
		local updateRGB = function()
			if Switch then
				self.Entity.SpriteRendererComponent.Color.g = self.Entity.SpriteRendererComponent.Color.g - 1/255
				self.Entity.SpriteRendererComponent.Color.b = self.Entity.SpriteRendererComponent.Color.b - 1/255
			else
				self.Entity.SpriteRendererComponent.Color.g = self.Entity.SpriteRendererComponent.Color.g + 1/255
				self.Entity.SpriteRendererComponent.Color.b = self.Entity.SpriteRendererComponent.Color.b + 1/255
			end
		end
		
		for i = 1 , 255 do
			_TimerService:SetTimerOnce(updateRGB, (i * 3)/255)
			if Switch and i == 255 then
				self.Entity.SpriteRendererComponent.SpriteRUID = self.AttackRUID
			end
		end
	end

	@ExecSpace("Client")
	method void ShotInk()
		-- 묵물을 360도 전방위로 사격하여 데미지 전달
		self.Entity.SpriteRendererComponent.SpriteRUID = self.AttackRUID
		
		for i = 1 , self.bulletNum do
			local bullet = _SpawnService:SpawnByModelId(self.bulletId, "bullet", self.Entity:GetChildByName("SpawnPoint").TransformComponent.WorldPosition, self.Entity.CurrentMap)
			bullet.Trap_InkBullet.damage = self.damage
			bullet.SpriteRendererComponent.SortingLayer = "Foreground"
			bullet.Trap_InkBullet.dirVec = Vector2(math.cos(math.pi * 2 * i / self.bulletNum), math.sin(math.pi * 2 * i / self.bulletNum)) -- math.pi * 2 = 360
		end
		
		--[[
		local spawnDir = 1
		
		if not self.Entity.SpriteRendererComponent.FlipX then
			spawnDir = -1
		end
		
		local bullet = _SpawnService:SpawnByModelId("model://8f680b32-6c78-43c9-96e4-b23b9532101b", "Bullet", Vector3(0.5 * spawnDir, 0.05, 0), self.Entity)
		
		local angle = math.random(1, 75)
		local shotStr = math.random(3, 10)
		local dir = Vector2(1, 0)
		
		
		local radianAngle = angle * 3.141592 / 180
		local shootVector = Vector2(math.cos(radianAngle), math.sin(radianAngle))
		
		if not self.Entity.SpriteRendererComponent.FlipX then -- 왼쪽
			shootVector.x = - shootVector.x
		end
		
		bullet.RigidbodyComponent:AddForce(shootVector * shotStr)
		]]--
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEmbededSpriteAnimPlayerChangeFrameEvent(EmbededSpriteAnimPlayerChangeFrameEvent event)
		-- 스퀼드 애니메이션 프레임 변경 시 공격 타이밍 제어
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.Entity.SpriteRendererComponent.SpriteRUID == self.AttackRUID then
			-- AttackRUID's totalFrame is 6..
			if FrameIndex == 4 then
				self:ShotInk()
				self:ReadyShot(false)
				self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			end
		end
	end

end