@Component
script Trap_HeartBullet extends Component

	property Vector2 dirVec = Vector2(0,0)

	property boolean reverse = false

	property number lifetime = 0

	property number damage = 0

	property string hitEffectId = ""

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 하트 총알의 이동 - 전진 후 역방향으로 빠르게 되돌아감
		if not self.reverse then
			self.Entity.TransformComponent:Translate(self.dirVec.x * delta, self.dirVec.y * delta)
		else
			self.Entity.TransformComponent:Translate(-self.dirVec.x * 3.5 * delta, -self.dirVec.y * delta * 3.5)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 하트 총알 생성 시 생명주기 절반 지점에서 역방향 전환 타이머 설정
		local reverse = function()
			self.reverse = true
		end
		_TimerService:SetTimerOnce(reverse, self.lifetime / 2)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 스폰포인트 도달 시 소멸, 플레이어 충돌 시 마법 효과 및 데미지 적용
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if self.reverse and TriggerBodyEntity.Name == "SpawnPoint"then
			_EntityService:Destroy(self.Entity)
		elseif isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:Enchanted(true, TriggerBodyEntity)
			TriggerBodyEntity.PlayerIngameData:Hit(self.damage)
			_EntityService:Destroy(self.Entity)
			_EffectService:PlayEffectAttached(self.hitEffectId, TriggerBodyEntity.CurrentMap, TriggerBodyEntity.TransformComponent.WorldPosition, 0 , Vector3.one, false)
		end
	end

end