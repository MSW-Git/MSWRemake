@Component
script GoldApple extends Component

	property number speed = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 골드 애플이 타겟 위치를 향해 지정된 속도로 이동
		local targetPos = Vector2(_EntityService:GetEntityByPath("/maps/Temple_Aphrodite_6/InteractionObject"):GetChildByName("targetPos").TransformComponent.WorldPosition.x, 
			_EntityService:GetEntityByPath("/maps/Temple_Aphrodite_6/InteractionObject"):GetChildByName("targetPos").TransformComponent.WorldPosition.y)
		local applePos = Vector2(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y)
		local dist = targetPos - applePos
		local moveVector = Vector2.Normalize(dist)
		self.Entity.TransformComponent:Translate(moveVector.x * delta * self.speed, moveVector.y * delta * self.speed)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 골드 애플 생성 시 3초 후 자동으로 제거되도록 타이머 설정
		local destroy = function()
			self.Entity:Destroy()
		end
		_TimerService:SetTimerOnce(destroy, 3)
	end

end