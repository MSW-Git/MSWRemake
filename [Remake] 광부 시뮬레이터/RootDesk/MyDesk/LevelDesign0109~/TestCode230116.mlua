@Component
script TestCode230116 extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 플레이어 좌우 이동 키 반전 설정 (테스트용)
		self.Entity.PlayerControllerComponent:RemoveActionKey(KeyboardKey.RightArrow)
		self.Entity.PlayerControllerComponent:RemoveActionKey(KeyboardKey.LeftArrow)
		
		self.Entity.PlayerControllerComponent:RemoveActionKey(KeyboardKey.A)
		self.Entity.PlayerControllerComponent:RemoveActionKey(KeyboardKey.D)
		
		
		self.Entity.PlayerControllerComponent:SetActionKey(KeyboardKey.RightArrow, "MoveLeft")
		self.Entity.PlayerControllerComponent:SetActionKey(KeyboardKey.LeftArrow, "MoveRight")
		
		self.Entity.PlayerControllerComponent:SetActionKey(KeyboardKey.A, "MoveLeft")
		self.Entity.PlayerControllerComponent:SetActionKey(KeyboardKey.D, "MoveRight")
		
		
	end

end