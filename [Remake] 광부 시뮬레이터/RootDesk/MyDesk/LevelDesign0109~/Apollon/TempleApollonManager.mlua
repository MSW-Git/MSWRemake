@Component
script TempleApollonManager extends Component

	property string modelId = "model://58f86b47-c7cd-4f47-90e6-92dea0116191"

	property number spawnSecondWorshipTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 아폴론 신전 관리자 초기화, 지정된 시간에 숭배 오브젝트 생성
		local spawn = function()
			_SpawnService:SpawnByModelId(self.modelId, "worship", self.Entity:GetChildByName("Sun"):GetChildByName("SpawnPoint").TransformComponent.WorldPosition, self.Entity)
		end
		_TimerService:SetTimerOnce(spawn, 0)
		_TimerService:SetTimerOnce(spawn, self.spawnSecondWorshipTime)
		_TimerService:SetTimerOnce(spawn, self.spawnSecondWorshipTime*2)
		log("이거 실행안되는거죠?")
	end

end