@Component
script Item_RotationShield extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) then
			TriggerBodyEntity.PlayerStateAtStage:GetRotationShield()
			self.Entity.Enable = false
		end
		
	end

end