@Component
script CloudLightningTriggerCheck extends Component

	property boolean selected = false

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 플레이어가 번개 공격 영역에 있고 공격 선택 상태일 때 전기 데미지 실행
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and self.Entity.Parent.Trap_ThunderCloud.OnAttack and self.selected then
			self.Entity.Parent.Trap_ThunderCloud.OnAttack = false
			TriggerBodyEntity.PlayerStateAtStage:ElectricDamage(30, TriggerBodyEntity)
			_EffectService:PlayEffect("94d5246047cd41708117b398bbef14ec", self.Entity, self.Entity.TransformComponent.WorldPosition,0, Vector3.one, false)
			_SoundService:PlaySound("5156e84e6ba74b76b1a87fdecde69df0", 0.75)
		end
	end

end