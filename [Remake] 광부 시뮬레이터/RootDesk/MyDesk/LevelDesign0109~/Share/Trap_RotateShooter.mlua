@Component
script Trap_RotateShooter extends Component

	property string bulletId = "model://b363de78-b925-42aa-8022-9d68524ffcb3"

	property number cooltime = 0

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("Client")
	method void Shooter()
		-- 사방으로 회전하며 탄알을 발사하는 함정 시스템을 실행
		
		local playShot = function()
		
		local r = self.Entity:GetChildByName("spawnPoint"):GetChildByName("pos_R").TransformComponent.WorldPosition
		local l = self.Entity:GetChildByName("spawnPoint"):GetChildByName("pos_L").TransformComponent.WorldPosition
		local t = self.Entity:GetChildByName("spawnPoint"):GetChildByName("pos_T").TransformComponent.WorldPosition
		local b = self.Entity:GetChildByName("spawnPoint"):GetChildByName("pos_B").TransformComponent.WorldPosition
		local o = self.Entity:GetChildByName("spawnPoint"):GetChildByName("pos_Origin").TransformComponent.WorldPosition
		self.Entity.SpriteRendererComponent.Color = Color.red
		
		for i = 1 , 4 do
			local bullet 
			= _SpawnService:SpawnByModelId(self.bulletId, "bullet", Vector3(o.x, o.y, 0), self.Entity.CurrentMap)
			bullet.sampleBullet.damage = self.damage
			bullet.SpriteRendererComponent.SortingLayer = "Foreground"
			if i == 1 then
				bullet.sampleBullet.dist = Vector2(r.x - o.x, r.y - o.y)
			elseif i == 2 then
				bullet.sampleBullet.dist = Vector2(l.x - o.x, l.y - o.y)
			elseif i == 3 then
				bullet.sampleBullet.dist = Vector2(t.x - o.x, t.y - o.y)
			elseif i == 4 then
				bullet.sampleBullet.dist = Vector2(b.x - o.x, b.y - o.y)
			end
			local destroy = function()
				if isvalid(bullet) then
					bullet:Destroy()
				end
			end
			_TimerService:SetTimerOnce(destroy, 5)
		end
			self.Entity.SpriteRendererComponent.Color = self._T.originColor
		end
		
		_TimerService:SetTimerOnce(playShot, 1.5)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 탄알 발사 지점을 지속적으로 회전시켜 다양한 방향으로 공격
		self.Entity:GetChildByName("spawnPoint").TransformComponent.WorldZRotation = self.Entity:GetChildByName("spawnPoint").TransformComponent.WorldZRotation + 5 * delta
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 초기화 시 원래 색상을 저장하고 설정된 쿨타임으로 반복 발사 시작
		local shoot = function()
			self:Shooter()
		end
		_TimerService:SetTimerRepeat(shoot, self.cooltime , self.cooltime)
		self._T.originColor = self.Entity.SpriteRendererComponent.Color 
	end

end