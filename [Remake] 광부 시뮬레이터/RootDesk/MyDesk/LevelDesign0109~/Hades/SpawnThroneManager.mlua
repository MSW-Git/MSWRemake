@Component
script SpawnThroneManager extends Component

	property number spawnNum = 0

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("Client")
	method void SpawnRandomMiningTarget(EntityRef enteredPlayer)
		-- 지정된 수만큼의 랜덤 왕좌 함정을 활성화하고 데미지 설정
		if enteredPlayer ~= _UserService.LocalPlayer then
			return
		end
		
		local childrenNum = #self.Entity.Children
		
		
		if self.spawnNum > childrenNum then
			return
		end
		
		local childIndexTable = {}
		for i=1, childrenNum do
			local child = self.Entity.Children[i]
			child:SetEnable(false, false, false)
			table.insert(childIndexTable, i)
		end
		
		
		for i=1, self.spawnNum do
			local randIdx = _UtilLogic:RandomIntegerRange(1, #childIndexTable)
			local childIdx = childIndexTable[randIdx]
			-- local child = self.Entity.Children[i]
			local child = self.Entity.Children[childIdx]
			child:SetEnable(true, false, false)
			if isvalid(child.Trap_Hades_Throne) then
				child.Trap_Hades_Throne.damage = self.damage
			end
			-- child.MiningTargetObject.Enable = true
			table.remove(childIndexTable, randIdx)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 초기화 시 로컬 플레이어를 대상으로 왕좌 함정을 랜덤 생성
		self:SpawnRandomMiningTarget(_UserService.LocalPlayer)
	end

end