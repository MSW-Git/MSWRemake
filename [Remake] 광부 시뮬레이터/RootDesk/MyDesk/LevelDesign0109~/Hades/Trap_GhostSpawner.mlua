@Component
script Trap_GhostSpawner extends Component

	property string spawnModelId = "model://deca4e69-bb39-4859-a79e-0d63e6a2a7fb"

	property string spawnEffectRUID = "885947126e8e474cbd2f05c0f8947c2e"

	property number cooltime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 하데스 게임 시작 시 설정된 쿨타임에 따라 유령을 반복 생성
		local spawnGhost = function()
			if self.Entity.CurrentMap.TempleHadesManager.startGame then
				_EffectService:PlayEffectAttached(self.spawnEffectRUID, self.Entity, Vector3(0,-0.9,0), 0,Vector3.one)
				_SpawnService:SpawnByModelId(self.spawnModelId, "ghost", Vector3(0, -0.6,0), self.Entity)
			end
		end
		_TimerService:SetTimerRepeat(spawnGhost, self.cooltime, self.cooltime)
		
	end

end