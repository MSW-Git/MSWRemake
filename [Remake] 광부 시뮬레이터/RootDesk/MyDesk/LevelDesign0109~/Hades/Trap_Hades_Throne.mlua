@Component
script Trap_Hades_Throne extends Component

	property boolean hitted = false

	property number damage = 0

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 하데스 왕좌에 닿으면 게임 오버 상태로 전환하고 성공 이팩트 실행
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity ~= _UserService.LocalPlayer then
			return
		end
		
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and isvalid(self.Entity.CurrentMap.TempleHadesManager) and not self.hitted then
			self.hitted = true
			_EffectService:PlayEffectAttached("54633f504fb34a028bb1e11df7a1c352", TriggerBodyEntity, Vector3.zero, 0 , Vector3.one)
			TriggerBodyEntity.RigidbodyComponent.Enable = false
			TriggerBodyEntity.MovementComponent.Enable = false
			self.Entity.CurrentMap.TempleHadesManager.gameOver = true
		end
	end

end