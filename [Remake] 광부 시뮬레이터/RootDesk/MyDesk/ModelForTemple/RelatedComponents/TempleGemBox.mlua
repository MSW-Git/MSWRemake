@Component
script TempleGemBox extends InteractionComponent

	@Sync
	property Entity guideImage = nil

	@Sync
	property number coolDown = 0

	method void OnBeginPlay()
		-- 서버 시작 시 상호작용 가능한 가이드 이미지를 초기화
		if self:IsServer() then
			local guideImage = self.Entity:GetChildByName("GuideImage")
			self.guideImage = guideImage
		end
	end

	@ExecSpace("Client")
	method void OnInteractionEvent()
		-- 하데스의 보물상자 상호작용 시 사운드 재생과 서버 로직 호출 및 UI 표시
		-- 사운드
		_SoundService:PlaySound("c3881663d79a48c684124132bfaabb7b", 0.7)
		
		
		-- 건설8 : 지하신전에서 하데스의 보물상자를 발견할 수 있습니다. 상호작용하면 젬을 얻습니다.
		local constuctionLv = _UserService.LocalPlayer.PlayerConstruction.haveItems[8] 
		if constuctionLv > 1 then
			self:OnInteractionEventOnServer(_UserService.LocalPlayer)
		end
		
		
		-- 결과에 대한 UI
		-- _UIToast:ShowMessage(_LocalizationService:GetText("하데스의 보물상자에서 젬을 얻었습니다."))
		 _UIToast:ShowMessage(_LocalizationService:GetText("Message_UseGemBox"))
		
		-- 엔티티 제거
		self.Entity.Enable = false
	end

	@ExecSpace("Server")
	method void OnInteractionEventOnServer(Entity player)
		-- 서버에서 보물상자 상호작용 처리: 쿨다운 체크 후 건설 레벨에 따른 젠 지급
		-- 검증
		if self.coolDown > 0 then
			return
		end
		------------------------------------------------------------
		self.coolDown = 3
		local setDownCool = function()
			self.coolDown = 0
		end
		_TimerService:SetTimerOnce(setDownCool, 3)
		
		local constuctionLv = player.PlayerConstruction.haveItems[8] 
		local amount = _UtilLogic:RandomIntegerRange(10, 15) * constuctionLv
		player.PlayerStorage:AddCurrencyItems(2, amount, true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 엔티티 상호작용 이벤트 핸들러: OnInteractionEvent 메소드 호출
		self:OnInteractionEvent()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 상호작용 영역 진입 시 E키 가이드 UI를 생성하고 표시
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			local spawnPos = Vector3(0, 0.5, 0)
			local guideUI = _SpawnService:SpawnByModelId("model://85ad2718-739a-4bf9-aee4-f439cda53303", "Guide_Key", spawnPos, self.Entity)
			guideUI:GetChildByName("UIText").TextComponent.Text = _LocalizationService:GetText("Use")
			
			guideUI:GetChildByName("icon_key_E").UITransformComponent.WorldPosition.x = guideUI:GetChildByName("icon_key_E").UITransformComponent.WorldPosition.x + 0.2
			guideUI:GetChildByName("UIText").UITransformComponent.RectSize = Vector2(420, 100)
		
			if InteractionEntity ~= _UserService.LocalPlayer then
				guideUI.Enable = false
			else 
				guideUI.Enable = true
			end
		else
			guideKeyWorldUI.Enable = true
		end
		
		self.guideImage.Enable = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-- 상호작용 영역 떠날 때 E키 가이드 UI를 비활성화하고 기본 가이드 이미지 표시
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			log("가이드 키가 없습니다.")
			return
		end
		
		guideKeyWorldUI.Enable = false
		self.guideImage.Enable = true
	end

end