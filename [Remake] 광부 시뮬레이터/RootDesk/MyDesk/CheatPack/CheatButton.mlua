@Component
script CheatButton extends Component

	property string cheatType = ""

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 치트 버튼 클릭 시 해당하는 치트 타입을 서버에서 실행
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.cheatType == "templePortalCheatOn" then
			local templeIdx = _EntityService:GetEntityByPath("/ui/CheatGroup/Model_CheatGroup/list/cheatList_TemplePortal/Input_Level").TextComponent.Text
			_CheatManager:UseCheatOnServer(_UserService.LocalPlayer, self.cheatType.."_"..templeIdx)
			
			
		else 
			_CheatManager:UseCheatOnServer(_UserService.LocalPlayer, self.cheatType)
		end
	end

end