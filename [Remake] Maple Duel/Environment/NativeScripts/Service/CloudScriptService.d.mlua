---@sealed
---@description "This is the superclass of all Services. Provides basic functions of Service."
@Service
script CloudScriptService extends Service

	---@sealed
	@ExecSpace("ServerOnly")
	method table InvokeAndWait(string scriptName, string functionName, table param, boolean isDebug) end

	---@sealed
	@ExecSpace("ServerOnly")
	method void InvokeAsync(string scriptName, string functionName, table param, boolean isDebug, func<table> callbackFunction) end

end