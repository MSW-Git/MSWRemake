@Component
script Map extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property SpriteGUIRendererComponent fade = nil

	property Entity blockEntity = nil

	property SoundComponent sound = nil

	property BackgroundComponent background = nil

	property TileMapComponent centerlineTileMap = nil

	property TileMapComponent borderTileMap = nil

	property Input input = nil

	@Sync
	property Duel duel = nil

	@Sync
	property Tutorial tutorial = nil

	property boolean isWaiting = true

	property boolean isLoaded = false

	property string mode = nil

	property string theme = nil

	method table GetProperties()
		-- 맵의 속성들을 테이블로 반환
		local propertyTable = {
			mode = self.mode,
			theme = self.theme,
			duel = self.duel,
			tutorial = self.tutorial,
		}
		
		return propertyTable
	end

	method void SetProperties(table propertyTable)
		-- 속성 테이블을 받아서 맵의 속성들을 설정
		for propertyName, propertyValue in pairs(propertyTable) do
			self[propertyName] = propertyValue
		end
	end

	@ExecSpace("Client")
	method void SetPropertiesInClient(table propertyTable)
		-- 클라이언트에서 속성들을 설정
		self:SetProperties(propertyTable)
	end

	@ExecSpace("ServerOnly")
	method void SyncProperties(string userId)
		-- 서버에서 특정 사용자에게 속성들을 동기화
		self:SetPropertiesInClient(self:GetProperties(), userId)
	end

	@ExecSpace("Client")
	method void OnSyncProperties()
		-- 속성 동기화 완료 후 맵 장식 적용
		self:Decorate()
	end

	@ExecSpace("ServerOnly")
	method void Sync(string userId)
		-- 서버에서 클라이언트로 맵 정보 동기화
		_TimerService:SetTimerOnce(function()
			while self.isWaiting do
				wait(0.01)
			end
			
			local userEntity = _UserService:GetUserEntityByUserId(userId)
			if not isvalid(userEntity) then
				return
			end
			userEntity.Character.isSynced = true
			
			self:SyncProperties(userId)
			
			if isvalid(self.duel) then
				self.duel:Sync(userId)
			end
			
			if isvalid(self.tutorial) then
				self.tutorial:Sync(userId)
			end
			
			for _, userEntity in pairs(_UserService:GetUsersByMapComponent(self.Entity.CurrentMap.MapComponent)) do
				userEntity.Character:Sync(userId)
			end
			
			self:OnSyncProperties(userId)
			
		end, 0)
	end

	@ExecSpace("ClientOnly")
	method void Decorate()
		-- 테마에 따른 맵 장식 및 배경음악 설정
		if _UtilLogic:IsNilorEmptyString(self.theme) then
			return
		end
		
		local bgm
		local background
		local tileMap
		local playerBackground
		
		if self.theme == "LithHarbor" then
			bgm = "d479098207e2405a8dfdaff121b04ebc"
			background = "1b971347d33e47c98d0c5d2df9260b7a"
			tileMap = "48afa7d90aa24fadae9c52f30977342e"
			playerBackground = "5ccf05c1568541b8b35648a0a0d0f23c"
		elseif self.theme == "Perion" then
			bgm = "f555b438ab2a41b0a714ccc6dbe720df"
			background = "9ba480b0b65e433a9797e2b30125bcb7"
			tileMap = "e80a4b6e22d34348837d2ecf30e7cf74"
			playerBackground = "3a26d5efdc6b4582851ad3291e791d56"
		elseif self.theme == "Ellinia" then
			bgm = "d004b763ed7a421c95a6a3204be532b7"
			background = "60741c3333334297b9f211939e02a4fc"
			tileMap = "d6a94bc26c8f43e2a7abfabfae0c4fc4"
			playerBackground = "dfd17b9cea354b91902457969ae40613"
		elseif self.theme == "Henesys" then 
			bgm = "3926b48759d246dc8464a876ff7fa5ce"
			background = "0cd3c88074bc4ed2ad86334a1c4f74af"
			tileMap = "9dfea3808bbd49a5877d8624df21b1c7"
			playerBackground = "b085f8b747424e60b74223d5e0b21cda"
		elseif self.theme == "KerningCity" then 
			bgm = "bbbf2616f2064d658f4d53af5faf9d3e"
			background = "ab82b15e100f40a4b5c43897eaa03471"
			tileMap = "2667829326dd46de80ef26f6bb7f26ae"
			playerBackground = "c30e434ff66d40c4b220d41e5706cb69"
		elseif self.theme == "Nautilus" then
			bgm = "ab3383f554f64622b56e2f6e41b5a917"
			background = "8570a4f9835e4919b459b411cfd99e1b"
			tileMap = "cd545c73cfcc4342aa4f6b1b17da0857"
			playerBackground = "f3767ee57aae493eb6232e96641ad8b5"
		elseif self.theme == "Orbis" then
			bgm = "02301b8112894626a78f8d517aada78a"
			background = "8e19209b863044af8401cb4cc7c9db34"
			tileMap = "c88359e9d1f540dcb2ffb9cd45693db8"
			playerBackground = "e8d93e68f1904a019f010724fb99de13"
		elseif self.theme == "Ludibrium" then
			bgm = "2a898d7dbe4c422189e42897708eba4b"
			background = "4a34b17d15e744e697a60ca129e8020b"
			tileMap = "737c5997e79e4a7d810e083f325ae824"
			playerBackground = "aa0117d10977414b851f46fa57d98b4c"
		end
		
		self.sound.AudioClipRUID = bgm
		self.sound:Play()
		self.background.ScrollRate = 0
		self.background:ChangeBackgroundByTemplateRUID(background)
		self.borderTileMap.TileSetRUID = tileMap
		self.centerlineTileMap.TileSetRUID = tileMap
		if isvalid(self.duel) then
			for _, player in ipairs(self.duel.playerArray) do
				player.backgroundEntity.SpriteRendererComponent.SpriteRUID = playerBackground
			end
		end
		
		local name = self.theme .. "Decoration"
		local entity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName(name), name, Vector3.zero, self.Entity.CurrentMap)
		
		local ruidArray = {bgm, background, tileMap}
		---@type table
		local rendererArray = entity:GetChildComponentsByTypeName("SpriteRendererComponent", true)
		for i, renderer in ipairs(rendererArray) do
			table.insert(ruidArray, renderer.SpriteRUID)
		end
		
		_ResourceService:PreloadAsync(ruidArray, function()
			self.isLoaded = true
			
			_TweenLogic:PlayTween(1, 0, 1, EaseType.Linear, function(t)
				self.fade.Color.a = t
			end)
			_TimerService:SetTimerOnce(function()
				self.fade.RaycastTarget = false
				self.blockEntity.Enable = false
			end, 1)
		end)
	end

	method void GetFriendsServerAttribute()
		-- 친구 목록 조회를 위한 서버 속성 메서드
		
	end

	@ExecSpace("ServerOnly")
	method void GetFriends(Character character, table userIdArray)
		-- 친구 목록 정보 조회 및 반환
		if not isvalid(character) then
			return
		end
		
		if _Server:IsRequesting() then
			if character ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local resultCode, memory = _WorldInstanceService:GetSharedMemory("User")
		if resultCode ~= SharedMemoryResultCode.OK then
			log(resultCode)
			return
		end
		
		local friendTable = {}
		local resultTable = memory:BatchGetVariableAndWait(userIdArray)
		for userId, result in pairs(resultTable) do
			local friend
			if result.Code == SharedMemoryResultCode.OK then
				if character.friendTable[userId] == nil then
					friend = {}
				else
					friend = _MSON:FastStringToAny(result.Info.Value)
					
					if friend.nickname ~= character.friendTable[userId].nickname then
						character.friendTable[userId].nickname = friend.nickname
					end
				end
			elseif result.Code == SharedMemoryResultCode.NotFound then
				friend = {}
			else
				log(result.Code)
				return
			end
			
			friendTable[userId] = friend
		end
		
		local friendArray = {}
		for i, userId in ipairs(userIdArray) do
			friendArray[i] = friendTable[userId]
		end
		
		self:GetFriendsInSender(userIdArray, friendArray, character.Entity.Name)
	end

	@ExecSpace("Client")
	method void GetFriendsInSender(table userIdArray, table friendArray)
		-- 클라이언트에서 친구 정보를 업데이트하고 이벤트 발송
		local character = _UserService.LocalPlayer.Character
		for i, friend in ipairs(friendArray) do
			local userId = userIdArray[i]
			if not _Table:IsEmpty(friend) and friend.nickname ~= character.friendTable[userId].nickname then
				character.friendTable[userId].nickname = friend.nickname
			end
		end
		
		self.Entity:SendEvent(_Event:GetFriends(userIdArray, friendArray))
	end

	method void FollowServerAttribute()
		-- 친구 따라가기 기능을 위한 서버 속성 메서드
		
	end

	@ExecSpace("ServerOnly")
	method void Follow(Character character, string userId, table friend)
		-- 친구 따라가기 기능 처리
		if not isvalid(character) then
			return
		end
		
		if character.friendTable[userId] == nil then
			return
		end
		
		if character.isMatching then
			return
		end
		
		if _Server:IsRequesting() then
			if character ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local location = friend.location
		local mode = location.mode
		if mode == "Lobby" then
			local channel = location.channel
			if channel.key == _WorldInstanceService.WorldInstanceId then
				if _RoomService:IsInstanceRoom() then
					if Environment:IsPublishedPlay() then
						_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, location.channel.key, "", function(result) end)
					else
						_RoomService:MoveUserToStaticRoom(character.Entity.Name)
					end
				else
					return
				end
			else
				_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, location.channel.key, "", function(result) end)
			end
		elseif mode == "RankedMatch" then
			if location.worldInstanceKey == _WorldInstanceService.WorldInstanceId then
				return
			end
			_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, location.worldInstanceKey, "", function(result) end)
		elseif mode == "FriendlyMatch" then
			local room = location.room
			local channel = room.channel
			if channel.key == _WorldInstanceService.WorldInstanceId then
				if _RoomService:IsInstanceRoom() then
					if room.key ~= _RoomService.RoomKey then
						_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, channel.key, _MSON:FastAnyToString(friend), function(result) end)
					else
						return
					end
				else
					_RoomService:GetOrCreateInstanceRoom(room.key)
					_RoomService:MoveUserToInstanceRoom(room.key, character.Entity.Name)
				end
			else
				_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, channel.key, _MSON:FastAnyToString(friend), function(result) end)
			end
		elseif mode == "Practice" then	
			local room = location.room
			local channel = room.channel
			if channel.key == _WorldInstanceService.WorldInstanceId then
				if _RoomService:IsInstanceRoom() then
					if room.key ~= _RoomService.RoomKey then
						_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, channel.key, _MSON:FastAnyToString(friend), function(result) end)
					else
						return
					end
				else
					_RoomService:GetOrCreateInstanceRoom(room.key)
					_RoomService:MoveUserToInstanceRoom(room.key, character.Entity.Name)
				end
			else
				_TeleportService:WarpUserToWorldInstanceAsync(character.Entity.Name, channel.key, _MSON:FastAnyToString(friend), function(result) end)
			end
		end
	end

end