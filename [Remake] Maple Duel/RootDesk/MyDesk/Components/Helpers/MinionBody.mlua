@Component
script MinionBody extends UnitBody

	property Minion object = nil

	property Entity atkEntity = nil

	property Integer atkInteger = nil

	property Entity minionEntity = nil

	property Entity barrierEntity = nil

	property Entity venomEntity = nil

	property Entity freezeEntity = nil

	property Entity stunEntity = nil

	property Entity scareEntity = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 미니언 몸체 초기화 및 상태 이펙트 엔티티 생성
		__base:OnBeginPlay()
		
		_ResourceService:PreloadAsync(self.minionEntity.StateAnimationComponent.ActionSheet.Values, nil)
		
		self.barrierEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Barrier"), "Barrier", Vector3(0, 0.14, -0.041), self.Entity)
		self.venomEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Venom"), "Venom", Vector3(0, 0, -0.042), self.Entity)
		self.freezeEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Freeze"), "Freeze", Vector3(0, 0.45, -0.043), self.Entity)
		self.stunEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Stun"), "Stun", Vector3(0, 0.45, -0.044), self.Entity)
		self.scareEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Scare"), "Scare", Vector3(0, 0.45, -0.045), self.Entity)
	end

end