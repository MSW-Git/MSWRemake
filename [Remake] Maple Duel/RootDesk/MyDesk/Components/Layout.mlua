@Component
script Layout extends Component

	property table transformTable = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 자식 엔티티들의 Transform 컴포넌트를 테이블에 저장
		for _, entity in ipairs(self.Entity.Children) do
			self.transformTable[entity.Name] = entity.TransformComponent
		end
	end

	@ExecSpace("ClientOnly")
	method TransformComponent GetTransform(string name)
		-- 이름으로 Transform 컴포넌트를 검색하여 반환
		return self.transformTable[name]
	end

end