	method void GetFriendlyMatchRoomsInSender(table roomArray)
		self.Entity:SendEvent(_Event:GetFriendlyMatchRooms(roomArray))
	end

	method void BeginMatchingServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void BeginMatching(Character character)
		if not isvalid(character) then
			return
		end
		
		if not Environment:IsPublishedPlay() or character.isMatching or not character:IsAbleToMatch() then
			return
		end
		
		if _Server:IsRequesting() then
			if character ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local resultCode
		local leaderBoardInfo = _Matching:GetOrCreateLeaderBoard()
		if leaderBoardInfo == nil then
			return
		end
		
		resultCode = _MatchmakingService:RequestMatchingAndWait(leaderBoardInfo.Id, "RankedMatch", character.Entity.PlayerComponent.ProfileCode, "", function(matchInfo)
			if matchInfo.ResultCode == MatchmakingResultCode.Ok then
				if isvalid(character) and character.isMatching then
					_MatchmakingService:WarpMatchUser(character.Entity.PlayerComponent.ProfileCode)
				end
			else
				self:CancelMatching(character)
			end
		end)
		if resultCode ~= MatchmakingResultCode.Ok then
			return
		end
		
		self:BeginMatchingInSender(character.Entity.Name)
		character.isMatching = true
	end

	@ExecSpace("Client")
	method void BeginMatchingInSender()
		local character = _UserService.LocalPlayer.Character
		character.isMatching = true
		
		self.uiManager.LobbyModule:Close()
		self.uiManager.NoticeModule:Hide()
		self.uiManager.RewardModule:Hide()
		self.uiManager.EventModule:Hide()
		self.uiManager.RankedMatchModule:SetMatching(true)
	end

	method void CancelMatchingServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void CancelMatching(Character character)
		if not isvalid(character) then
			return
		end
		
		if not Environment:IsPublishedPlay() or not character.isMatching then
			return
		end
		
		if _Server:IsRequesting() then
			if character ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local resultCode = _MatchmakingService:CancelMatchingAndWait(character.Entity.PlayerComponent.ProfileCode)
		if resultCode == MatchmakingResultCode.AlreadyMatched then
			return
		end
		
		self:CancelMatchingInSender(tostring(resultCode) , character.Entity.Name)
		character.isMatching = false
	end

	@ExecSpace("Client")
	method void CancelMatchingInSender(string resultCode)
		resultCode = MatchmakingResultCode.CastFrom(resultCode)
		
		local character = _UserService.LocalPlayer.Character
		character.isMatching = false
		
		if resultCode == MatchmakingResultCode.NotMatching then
			self.uiManager.PopupModule:Open("MatchingNotFound", true, nil, nil)
		end
		self.uiManager.LobbyModule:Open()
		self.uiManager.NoticeModule:Show()
		self.uiManager.RewardModule:Show()
		self.uiManager.EventModule:Show()
		self.uiManager.RankedMatchModule:SetMatching(false)
	end

	@ExecSpace("ServerOnly")
	method void Initialize(boolean isRankedMatch)
		if not _UtilLogic:IsNilorEmptyString(self.mode) then
			return
		end
		
		self.mode = isRankedMatch and "RankedMatch" or "Lobby"
		if self.mode == "Lobby" then
			self.theme = "LithHarbor"
			self:UpdateChannels()
		elseif self.mode == "RankedMatch" then
			self.theme = _Table:GetRandomElement({"Perion", "Ellinia", "Henesys", "KerningCity"})
			self.duel = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Duel"), "Duel", Vector3.zero, self.Entity).Duel
			self.isWaiting = false
			
			_TimerService:SetTimerOnce(function()
				if self.duel.isDueling or self.isEndMatch then
					return
				end
				
				local playerCount = 0
				local winner
				for _, player in ipairs(self.duel.playerArray) do
					if isvalid(player.character) then
						playerCount += 1
						winner = player
					end
				end
				if playerCount == 1 then
					self.duel:EndMatch(winner)
					winner:Tardy()
				end
			end, 50)
		end
	end

	@ExecSpace("ServerOnly")
	method table UpdateMatchResult(string winnerUserId)
		if not Environment:IsPublishedPlay() then
			return
		end
		
		local resultCode
		local leaderBoardInfo = _Matching:GetOrCreateLeaderBoard()
		if leaderBoardInfo == nil then
			return
		end
		
		if _Table:IsEmpty(self.matchUserInfos) then
			return
		end
		
		local resultTable = {}
		for i = 1, 2 do
			local profileCode = self.matchUserInfos[i].ProfileCode
			local userId = _UserService:GetUserByProfileCode(profileCode).UserId
			resultTable[userId] = {}
		end
		
		local rankInfo
		for i = 1, 2 do
			local profileCode = self.matchUserInfos[i].ProfileCode
			local userId = _UserService:GetUserByProfileCode(profileCode).UserId
			resultCode, rankInfo = _MatchmakingService:GetRankInfoAndWait(leaderBoardInfo.Id, "1", profileCode)
			local befMmr = resultCode == LeaderboardResultCode.Ok and rankInfo.Score or 1500
			resultTable[userId].befMmr = befMmr
		end
		
		local matchResultInfo
		if not _UtilLogic:IsNilorEmptyString(winnerUserId) then
			local winnerProfileCode = _UserService.Users[winnerUserId].ProfileCode
			resultCode, matchResultInfo = _MatchmakingService:UpdateMatchResultAndWait(leaderBoardInfo.Id, self.matchUserInfos[1].ProfileCode, self.matchUserInfos[2].ProfileCode, winnerProfileCode)
			if resultCode ~= MatchmakingResultCode.Ok then
				log(resultCode)
				return
			end
		end
		
		local sortableDataStorage = _DataStorageService:GetSortableDataStorage("Ranking")
		for i = 1, 2 do
			local profileCode = self.matchUserInfos[i].ProfileCode
			local userId = _UserService:GetUserByProfileCode(profileCode).UserId
			local userDataStorage = _DataStorageService:GetUserDataStorage(userId)
			local result = resultTable[userId]
			
			local befMmr = result.befMmr
			local afterMmr
			if matchResultInfo == nil then
				afterMmr = befMmr
			else
				if profileCode == matchResultInfo.Home.ProfileCode then
					afterMmr = matchResultInfo.Home.Score
				else
					afterMmr = matchResultInfo.Away.Score
				end
			end
			
			local value
			resultCode, value = userDataStorage:GetAndWait("rankPoint")
			if not (resultCode == 0 or resultCode == 1000002) then
				log(resultCode)
				continue
			end
			
			local befRankPoint = value and _MSON:FastStringToAny(value) or 500
			local targetRankPoint = 2 * (afterMmr - 1500) + 1500
			local bonus = math.floor((targetRankPoint - befRankPoint) / 40)
			local delta
			if _UtilLogic:IsNilorEmptyString(winnerUserId) then
				delta = 0
			elseif winnerUserId == userId then
				delta = math.max(math.min(20 + bonus, 40), 10)
			else
				delta = math.min(math.max(-20 + bonus, -40), -10)
			end
			local afterRankPoint = math.max(befRankPoint + delta, 500)
			userDataStorage:SetAndWait("rankPoint", _MSON:FastAnyToString(afterRankPoint))
			
			result.rankPoint = afterRankPoint - befRankPoint
			result.befRankPoint = befRankPoint
			result.afterRankPoint = afterRankPoint
			result.mmr = afterMmr - befMmr
			result.afterMmr = afterMmr
			
			local userEntity = _UserService:GetUserEntityByUserId(userId)
			if not isvalid(userEntity) then
				continue
			end
			local character = userEntity.Character
			local ranking = 0
			local sortedPages
			resultCode, sortedPages = sortableDataStorage:GetSortedAndWait(SortDirection.Descending, 0, 100000)
			if resultCode ~= 0 then
				log(resultCode)
				return
			end
			
			local count = 1
			while true do
			    local datas = sortedPages:GetCurrentPageDatas()
			    for _, data in pairs(datas) do
					if self.Entity.Name == data.KeyInfo.Key then
						ranking = count
						break
					end
					count += 1
					if count > 1 then
						break
					end
			    end
				if count > 1 or ranking > 0 then
					break
				end
				
			    if sortedPages.IsLastPage == true then
			        break
			    end
			    
			    sortedPages:MoveToNextPageAndWait()
			end
			character:SetRankInServer(afterRankPoint, ranking)
			
			sortableDataStorage:SetByInfoAndWait(DataStorageKeyInfo(userId, "", character.nickname), afterRankPoint)
		end
		
		return resultTable
	end

	method void ReturnToLobbyServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void ReturnToLobby(Character character)
		if not isvalid(character) then
			return
		end
		
		if _Server:IsRequesting() then
			if character ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		_TeleportService:WarpUserToWorldAsync(character.Entity.Name, Environment.WorldId, "", function() end)
	end

end