	@ExecSpace("ServerOnly")
	method void IncreaseSpecialEventAttendanceCount()
		local key = self.temp.specialEventAttendanceCountKey
		
		local dateTime = _DateTime:KtcNow()
		local days = _DateTime:KtcNowDays()
		if dateTime < DateTime(2025, 6, 11) then
			if self.temp.specialEventAttendanceCountkey ~= days then
				self.temp.specialEventAttendanceCountkey = days
				self.temp.specialEventAttendanceCount = (self.temp.specialEventAttendanceCount or 0) + 1
			end
		end
		
		self:IncreaseSpecialEventAttendanceCountInOwner(self.temp.specialEventAttendanceCount, self.temp.specialEventAttendanceCountkey, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void IncreaseSpecialEventAttendanceCountInOwner(integer specialEventAttendanceCount, integer specialEventAttendanceCountKey)
		self.temp.specialEventAttendanceCount = specialEventAttendanceCount
		self.temp.specialEventAttendanceCountKey = specialEventAttendanceCountKey
		
	end

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		if not self:IsUser() or not self.isLoaded then
			return
		end
		
		local dateTime = _DateTime:KtcNow()
		if dateTime ~= nil and self.dateTime ~= nil and self.dateTime.Day + 1 == dateTime.Day then
			self:IncreaseSpecialEventAttendanceCount()
		end
		
		self.dateTime = dateTime
	end

	method void ReceiveCardPacksBySpecialEventServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void ReceiveCardPacksBySpecialEvent(integer index)
		if not self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local success = false
		local dateTime = _DateTime:KtcNow()
		if dateTime < DateTime(2025, 6, 11) then
			if self.temp.specialEventReceiveTable == nil then
				self.temp.specialEventReceiveTable = {}
			end
			if not self.temp.specialEventReceiveTable[string.format("Day%d", index)] then
				self.temp.specialEventReceiveTable[string.format("Day%d", index)] = true
				
				success = true
			end
		end
		
		local cardPackName
		local count
		if index == 1 then
			cardPackName = "ClassicEpic"
			count = 5
		elseif index == 2 then
			cardPackName = "NautilusEpic"
			count = 5
		elseif index == 3 then
			cardPackName = "ClassicUnique"
			count = 5
		elseif index == 4 then
			cardPackName = "NautilusUnique"
			count = 5
		elseif index == 5 then
			cardPackName = "ClassicLegendary"
			count = 10
		elseif index == 6 then
			cardPackName = "NautilusEpic"
			count = 10
		elseif index == 7 then
			cardPackName = "ClassicEpic"
			count = 10
		elseif index == 8 then
			cardPackName = "NautilusUnique"
			count = 5
		elseif index == 9 then
			cardPackName = "ClassicUnique"
			count = 10
		elseif index == 10 then
			cardPackName = "NautilusLegendary"
			count = 10
		end
		
		local infos
		if success then
			infos = {}
			for i = 1, count do
				local infoArray = self.cardPackManager:GetInfos(cardPackName)
				self:GainCards(infoArray, "OpenCardPack")
				table.insert(infos, infoArray)
			end
			
			self.cardPackData = {
				name = cardPackName,
				infos = infos,
				index = 1,
			}
		end
		
		if self:IsUser() then
			self:ReceiveCardPacksBySpecialEventInOwner(cardPackName, count, index, success, infos, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void ReceiveCardPacksBySpecialEventInOwner(string cardPackName, integer count, integer index, boolean success, table infos)
		if not success then
			return
		end
		
		if self.temp.specialEventReceiveTable == nil then
			self.temp.specialEventReceiveTable = {}
		end
		self.temp.specialEventReceiveTable[string.format("Day%d", index)] = true
		for _, infoArray in ipairs(infos) do
			self:GainCards(infoArray, nil)
		end
		self.uiManager.CardPackModule:Open(cardPackName, count)
		self.uiManager.EventModule:ReceiveCardPacksBySpecialEvent(index)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: TouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		
		if not _UserService.LocalPlayer.Character.isLoaded or _Server:IsRequesting() then
			return
		end
		
		_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
		
		if self:IsOwner() then
			self.uiManager.EmoteModule:Open()
		else
			self.uiManager.InteractionModule:Open(self)
		end
		
	end

	@EventSender("Service", "UserService")
	handler HandleUserLeaveEvent(UserLeaveEvent event)
		--------------- Native Event Sender Info ----------------
		-- Sender: UserService
		-- Space: Server
		---------------------------------------------------------
		
		-- Parameters
		-- local ProfileCode = event.ProfileCode
		local UserId = event.UserId
		---------------------------------------------------------
		
		if self.Entity.Name ~= UserId then
			return
		end
		
		local home = self.Entity.CurrentMap.Home
		if isvalid(home) then
			home:CancelMatching(self)
		end
		
		local duel = self.Entity.CurrentMap.Map.duel
		if isvalid(duel) and duel.isDueling and isvalid(self.player) then
			local winner = self.player.opponent
			duel.commandManager:RunCommand("EndDuel", {winner}, {})
		end
		
		if isvalid(self.player) then
			duel:ClearBeginDuelTimer()
			self.player.character = nil
			self.player.isReady = false
			self.player.isServing = true
		end
		
		if self.Entity.Name == UserId and self.isLoaded then
			self.lastWorldExitDate = _DateTime:KtcNow():ToFormattedString("yyyy-MM-dd HH:mm:ss")
			
			local userDataStorage = _DataStorageService:GetUserDataStorage(self.Entity.Name)
			userDataStorage:BatchSetAndWait({
				temp = _MSON:FastAnyToString(self.temp),
				meso = _MSON:FastAnyToString(self.meso),
				dailyRankedWinMeso = _MSON:FastAnyToString(self.dailyRankedWinMeso),
				dailyRankedWinMesoKey = _MSON:FastAnyToString(self.dailyRankedWinMesoKey),
				dailyPlayMeso = _MSON:FastAnyToString(self.dailyPlayMeso),
				dailyPlayMesoKey = _MSON:FastAnyToString(self.dailyPlayMesoKey),
				dailyRankedPlayCount = _MSON:FastAnyToString(self.dailyRankedPlayCount),
				dailyRankedPlayCountKey = _MSON:FastAnyToString(self.dailyRankedPlayCountKey),
				cardTable = _MSON:FastAnyToString(self.cardTable),
				newCardTable = _MSON:FastAnyToString(self.newCardTable),
				cardBackTable = _MSON:FastAnyToString(self.cardBackTable),
				newCardBackTable = _MSON:FastAnyToString(self.newCardBackTable),
				cardBack = _MSON:FastAnyToString(self.cardBack),
				deckArray = _MSON:FastAnyToString(self.deckArray),
				deckIndex = _MSON:FastAnyToString(self.deckIndex),
				friendTable = _MSON:FastAnyToString(self.friendTable),
				topRankPoint = _MSON:FastAnyToString(self.topRankPoint),
				finishedTutorial = _MSON:FastAnyToString(self.finishedTutorial),
				
				profileCode = _MSON:FastAnyToString(self.profileCode),
				nickname = _MSON:FastAnyToString(self.nickname),
				firstWorldEnterDate = _MSON:FastAnyToString(self.firstWorldEnterDate),
				lastWorldEnterDate = _MSON:FastAnyToString(self.lastWorldEnterDate),
				lastWorldExitDate = _MSON:FastAnyToString(self.lastWorldExitDate),
			})
			
			local resultCode, memory = _WorldInstanceService:GetSharedMemory("User")
			if resultCode ~= SharedMemoryResultCode.OK then
				log(resultCode)
				return
			end
			
			memory:DeleteVariableAndWait(UserId)
		end
	end

end