	method void DeleteDeckServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void DeleteDeck()
		if not self.isLoaded then
			return
		end
		
		if _Table:IsEmpty(self:GetDeck()) then
			return
		end
		
		if isvalid(self.player) or self.isMatching then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		table.remove(self.deckArray, self.deckIndex)
		self.deckIndex = math.min(self.deckIndex, #self.deckArray)
		
		if self:IsUser() then
			self:DeleteDeckInOwner(self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void DeleteDeckInOwner()
		table.remove(self.deckArray, self.deckIndex)
		self.deckIndex = math.min(self.deckIndex, #self.deckArray)
		self.Entity:SendEvent(DeleteDeck())
		self.Entity:SendEvent(SetDeckIndex())
	end

	method void SetDeckIndexServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void SetDeckIndex(integer deckIndex)
		if not self.isLoaded then
			return
		end
		
		if #self.deckArray == 0 then
			if deckIndex ~= 1 then
				return
			end
		elseif deckIndex <= 0 or #self.deckArray < deckIndex then
			return
		end
		
		if isvalid(self.player) or self.isMatching then
			return
		end
		
		if self.deckIndex == deckIndex then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		self.deckIndex = deckIndex
		
		if self:IsUser() then
			self:SetDeckIndexInOwner(deckIndex, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetDeckIndexInOwner(integer deckIndex)
		self.deckIndex = deckIndex
		self.Entity:SendEvent(SetDeckIndex())
	end

