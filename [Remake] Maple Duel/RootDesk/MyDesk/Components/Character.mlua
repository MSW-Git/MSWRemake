		self:SetRankInServer(rankPoint, ranking)
		
		self:SetRankInClient(rankPoint, ranking)
	end

	@ExecSpace("ServerOnly")
	method void SetRankInServer(integer rankPoint, integer ranking)
		self.rankPoint = rankPoint
		self.ranking = ranking
	end

	@ExecSpace("Client")
