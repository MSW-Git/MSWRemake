@Component
script Character extends Component

	property BotManager botManager = "383a452f-0ea6-43ba-a738-725a001906a9"

	property CardManager cardManager = "aa80dcbc-1e88-4f95-9e8e-f3e3b9749e7d"

	property CardBackManager cardBackManager = "d31aa203-b026-4ad8-b8d3-1d8cea99398c"

	property CardPackManager cardPackManager = "fe274865-e1d4-4ece-a185-40d5bf7865e3"

	property DeckManager deckManager = "e920267e-c338-457c-af06-67081552ceca"

	property EmoteManager emoteManager = "0102c2b9-1758-453a-a6c6-6b7fa04d88d1"

	property RankManager rankManager = "84709e8b-278d-431c-bc06-a7fe8874ca23"

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Player player = nil

	property NameTagComponent classTag = nil

	property integer maxDeckCount = 10

	property boolean isMatching = false

	property boolean isLoaded = false

	property table temp = nil

	property integer meso = nil

	@TargetUserSync
	property integer dailyRankedWinMeso = nil

	@TargetUserSync
	property integer dailyRankedWinMesoKey = nil

	@TargetUserSync
	property integer dailyPlayMeso = nil

	@TargetUserSync
	property integer dailyPlayMesoKey = nil

	@TargetUserSync
	property integer dailyRankedPlayCount = 0

	@TargetUserSync
	property integer dailyRankedPlayCountKey = 0

	property table cardTable = nil

	property table newCardTable = {}

	property table cardBackTable = {}

	property table newCardBackTable = {}

	property string cardBack = nil

	property table deckArray = nil

	property integer deckIndex = nil

	property table friendTable = nil

	property table friendRequestArray = {}

	property table unfriendArray = {}

	property integer rankPoint = nil

	property integer ranking = nil

	property integer topRankPoint = nil

	property boolean finishedTutorial = nil

	property string profileCode = ""

	property string nickname = ""

	property string firstWorldEnterDate = ""

	property string lastWorldEnterDate = ""

	property string lastWorldExitDate = ""

	property string banStartDate = ""

	property string banEndDate = ""

	property string banReason = ""

	property boolean isMatchUser = nil

	property boolean isMatchUserWaiting = true

	property table cardPackData = nil

	property table emoteArray = {}

	property Entity emoteEntity = nil

	property any emoteTweener = nil

	property integer emoteTimer = 0

	property integer emoteSortTimer = 0

	property boolean isSynced = false

	property any dateTime = nil

	method void OnMapEnter(Entity enteredMap)
		if self:IsServer() and self:IsUser() then
			local home = enteredMap.Home
			if isvalid(home) then
				if Environment:IsPublishedPlay() then
					
					while _UserService.Users[self.Entity.Name] == nil do
						wait(0.1)
					end
					
		            local profileCode = _UserService.Users[self.Entity.Name].ProfileCode
					
					if _Table:IsEmpty(home.matchUserInfos) then
						local resultCode, matchUserInfos = _MatchmakingService:GetMatchUserInfosAndWait(profileCode)
						self.isMatchUserWaiting = false
						if resultCode == MatchmakingResultCode.Ok then
							self.isMatchUser = true
							home.matchUserInfos = matchUserInfos
						elseif resultCode == MatchmakingResultCode.NotMatched then
							self.isMatchUser = false
						else
							_UIToast:ShowMessage(tostring(resultCode), 50)
							self.isMatchUser = false
							return
						end
					else
						self.isMatchUserWaiting = false
						self.isMatchUser = false
						for i = 1, 2 do
							if home.matchUserInfos[i].ProfileCode == profileCode then
								self.isMatchUser = true
							end
						end
					end
				else
					self.isMatchUserWaiting = false
					self.isMatchUser = false
				end
				
				home:Initialize(self.isMatchUser)
			else
				self.isMatchUserWaiting = false
				self.isMatchUser = false
			end
			
			enteredMap.Map:Sync(self.Entity.Name)
		end
	end

	method void OnBeginPlay()
		if self:IsServer() then
			if not self:IsUser() then
				self:Load(nil)
			end
		else
			self:SpawnClassTag()
			self:SpawnEmoteEffect()
			if self:IsOwner() then
				_Server:Request(self, "Load", {_LocalizationService.CurrentLocaleId})
			end
		end
	end

	method table GetProperties()
		local propertyTable = {
			rankPoint = self.rankPoint,
			ranking = self.ranking,
			isMatchUser = self.isMatchUser,
		}
		
		return propertyTable
	end

	method void SetProperties(table propertyTable)
		for propertyName, propertyValue in pairs(propertyTable) do
			self[propertyName] = propertyValue
		end
	end

	@ExecSpace("Client")
	method void SetPropertiesInClient(table propertyTable)
		self:SetProperties(propertyTable)
	end

	@ExecSpace("ServerOnly")
	method void SyncProperties(string userId)
		self:SetPropertiesInClient(self:GetProperties(), userId)
	end

	@ExecSpace("Client")
	method void OnSyncProperties()
		self:SetNameTag()
	end

	@ExecSpace("ServerOnly")
	method void Sync(string userId)
		self:SyncProperties(userId)
		self:OnSyncProperties(userId)
	end

	@ExecSpace("ServerOnly")
	method void Clear(string localeId)
		self:SetTemp({})
		self:SetMeso(0)
		self.dailyRankedWinMesoKey = 0
		self:SetDailyRankedWinMeso(0)
		self.dailyPlayMesoKey = 0
		self:SetDailyPlayMeso(0)
		self:SetCards(self.cardManager:GetStarterCollection())
		self:SetCardBacks(self.cardBackManager:GetStarterCardBacks())
		self:SetCardBack("OrangeMushroom")
		self:SetDecks({
			self.deckManager:GetWarriorStarterDeck(localeId),
			self.deckManager:GetMagicianStarterDeck(localeId),
			self.deckManager:GetBowmanStarterDeck(localeId),
			self.deckManager:GetThiefStarterDeck(localeId),
			self.deckManager:GetPirateStarterDeck(localeId)
		})
		self:SetDeckIndex(1)
		self:SetFriends({})
		self:SetRank(500, 0)
		self:SetTopRankPoint(500)
	end

	method void LoadServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void Load(string localeId)
		if self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		if not self:IsUser() then
			self.isLoaded = true
			
			local data = self.botManager:GetData(self.Entity.Bot.name)
			self.cardBack = data.cardBack
			self.deckArray = data.deckArray
			self.deckIndex = data.deckIndex
			
			return
		end
		
		local warpRecord = _TeleportService:GetWarpRecord(self.Entity.Name)
		if warpRecord ~= nil and not _UtilLogic:IsNilorEmptyString(warpRecord.Data) and not _RoomService:IsInstanceRoom() then
			local friend = _MSON:FastStringToAny(warpRecord.Data)
			local room = friend.location.room
			if _RoomService.InstanceRooms[room.key] then
				_RoomService:MoveUserToInstanceRoom(room.key, self.Entity.Name)
				
				return
			end
		end
		
		while not self.isSynced do
			wait(0.01)
		end
		local sortableDataStorage = _DataStorageService:GetSortableDataStorage("Ranking")
		if sortableDataStorage == nil then
			return
		end
		
		local userDataStorage = _DataStorageService:GetUserDataStorage(self.Entity.Name)
		if userDataStorage == nil then
			return
		end
		local keys = {
			"temp", 
			"meso", 
			"dailyRankedWinMeso", 
			"dailyRankedWinMesoKey", 
			"dailyPlayMeso", 
			"dailyPlayMesoKey", 
			"dailyRankedPlayCount",
			"dailyRankedPlayCountKey",
			"cardTable",
			"newCardTable",
			"cardBackTable",
			"newCardBackTable",
			"cardBack", 
			"deckArray", 
			"deckIndex", 
			"friendTable",
			"unfriendArray",
			"rankPoint",
			"topRankPoint",
			"finishedTutorial",
			
			"profileCode",
			"nickName",
			"firstWorldEnterDate",
			"lastWorldEnterDate",
			"lastWorldExitDate",
			"banStartDate",
			"banEndDate",
			"banReason"
		}
		userDataStorage:BatchGetAsync(keys, function(resultCode, keys, pages)
			if resultCode ~= 0 then
				log(resultCode)
				return
			end
			
			local isFirstWorldEnter
			
			local temp
			local meso
			local dailyRankedWinMeso
			local dailyRankedWinMesoKey
			local dailyPlayMeso
			local dailyPlayMesoKey
			local dailyRankedPlayCount
			local dailyRankedPlayCountKey
			local cardTable
			local newCardTable
			local cardBackTable
			local newCardBackTable
			local cardBack
			local deckArray
			local deckIndex
			local friendTable
			local unfriendArray
			local rankPoint
			local ranking
			local topRankPoint
			local finishedTutorial
			
			local profileCode
			local nickname
			local firstWorldEnterDate
			local lastWorldEnterDate
			local lastWorldExitDate
			local banStartDate
			local banEndDate
			local banReason
			
			ranking = 0
			if Environment:IsPublishedPlay() then
				local sortedPages
				resultCode, sortedPages = sortableDataStorage:GetSortedAndWait(SortDirection.Descending, 0, 100000)
				if resultCode ~= 0 then
					log(resultCode)
					return
				end
				
				local count = 1
				while true do
				    local datas = sortedPages:GetCurrentPageDatas()
				    for _, data in pairs(datas) do
						local userId = data.KeyInfo.Key
						if self.Entity.Name == userId then
							ranking = count
							break
						end
						count += 1
						if count > 1 then
							break
						end
				    end
					if count > 1 or ranking > 0 then
						break
					end
					
				    if sortedPages.IsLastPage == true then
				        break
				    end
				    
				    sortedPages:MoveToNextPageAndWait()
				end
			end
			
			while true do
				local datas = pages:GetCurrentPageDatas()
				for _, data in pairs(datas) do
					local key = data.KeyInfo.Key
					local str = data.Value
					local value = str and _MSON:FastStringToAny(str)
					
					if key == "temp" then
						temp = value or {}
					elseif key == "meso" then
						meso = value or 0
					elseif key == "dailyRankedWinMeso" then
						dailyRankedWinMeso = value or 0
					elseif key == "dailyRankedWinMesoKey" then
						dailyRankedWinMesoKey = value or 0
					elseif key == "dailyPlayMeso" then
						dailyPlayMeso = value or 0
					elseif key == "dailyPlayMesoKey" then
						dailyPlayMesoKey = value or 0
					elseif key == "dailyRankedPlayCount" then
						dailyRankedPlayCount = value or 0
					elseif key == "dailyRankedPlayCountKey" then
						dailyRankedPlayCountKey = value or 0
					elseif key == "cardTable" then
						cardTable = value or self.cardManager:GetStarterCollection()
					elseif key == "newCardTable" then
						newCardTable = value or _Table:DeepCopy(cardTable)
					elseif key == "cardBackTable" then
						cardBackTable = value or self.cardBackManager:GetStarterCardBacks()
					elseif key == "newCardBackTable" then
						newCardBackTable = value or _Table:DeepCopy(cardBackTable)
					elseif key == "cardBack" then
						cardBack = value or "OrangeMushroom"
					elseif key == "deckArray" then
						deckArray = value or {
							self.deckManager:GetWarriorStarterDeck(localeId),
							self.deckManager:GetMagicianStarterDeck(localeId),
							self.deckManager:GetBowmanStarterDeck(localeId),
							self.deckManager:GetThiefStarterDeck(localeId),
							self.deckManager:GetPirateStarterDeck(localeId)
						}
					elseif key == "deckIndex" then
						deckIndex = value or 1
					elseif key == "friendTable" then
						friendTable = value or {}
					elseif key == "unfriendArray" then
						unfriendArray = value or {}
					elseif key == "rankPoint" then
						rankPoint = value or 500
					elseif key == "topRankPoint" then
						topRankPoint = value or 500
					elseif key == "finishedTutorial" then
						finishedTutorial = value or false
					elseif key == "profileCode" then
						profileCode = _UserService.Users[self.Entity.Name].ProfileCode 
					elseif key == "nickName" then
						nickname = _UserService.Users[self.Entity.Name].Nickname
					elseif key == "firstWorldEnterDate" then
						firstWorldEnterDate = value or _DateTime:KtcNow():ToFormattedString("yyyy-MM-dd HH:mm:ss")
					elseif key == "lastWorldEnterDate" then
						lastWorldEnterDate = _DateTime:KtcNow():ToFormattedString("yyyy-MM-dd HH:mm:ss")
					elseif key == "lastWorldExitDate" then
						lastWorldExitDate = value
					elseif key == "banStartDate" then
						banStartDate = value
					elseif key == "banEndDate" then
						banEndDate = value
					elseif key == "banReason" then
						banReason = value
					end
				end
				
				if pages.IsLastPage == true then
					break
				end
				
				local loadResultCode = pages:LoadNextPageAndWait()
				if loadResultCode ~= 0 then
					break
				end
				
				pages:MoveToNextPageAndWait()
			end
			
			self:SetBanned(banStartDate, banEndDate, banReason)
			if self:IsBanned() then
				return
			end
			
			self.isLoaded = true
			self:SetLoadedInOwner(self.Entity.Name)
			
			self:SetTemp(temp)
			self:SetMeso(meso)
			self.dailyRankedWinMesoKey = dailyRankedWinMesoKey
			self:SetDailyRankedWinMeso(dailyRankedWinMeso)
			self.dailyPlayMesoKey = dailyPlayMesoKey
			self:SetDailyPlayMeso(dailyPlayMeso)
			self.dailyRankedPlayCountKey = dailyRankedPlayCountKey
			self:SetDailyRankedPlayCount(dailyRankedPlayCount)
			self:SetCards(cardTable)
			self:SetNewCards(newCardTable)
			self:SetCardBacks(cardBackTable)
			self:SetNewCardBacks(newCardBackTable)
			self:SetCardBack(cardBack)
			self:SetDecks(deckArray)
			self:SetDeckIndex(deckIndex)
			self.unfriendArray = unfriendArray
			self:SetFriends(friendTable)
			self:SetTopRankPoint(topRankPoint)
			self:SetRank(rankPoint, ranking)
			self:SetEmotes({"PinkBeanMelong", "PinkBeanLove", "PinkBeanEat", "PinkBeanSleep", "PinkBeanCry", "PinkBeanStunned"})
			self.finishedTutorial = finishedTutorial
			
			self.profileCode = profileCode
			self.nickname = nickname
			self.firstWorldEnterDate = firstWorldEnterDate
			self.lastWorldEnterDate = lastWorldEnterDate
			self.lastWorldExitDate = lastWorldExitDate
		
			self:RankedMatchReady()
			
			if not self.isMatchUser then
				self.Entity.RigidbodyComponent.Enable = true
				self.Entity.RigidbodyComponent:SetWorldPosition(Vector2(_UtilLogic:RandomDouble() * 10 - 5, 4))
			end
			
			local memory
			resultCode, memory = _WorldInstanceService:GetSharedMemory("User")
			if resultCode ~= SharedMemoryResultCode.OK then
				log(resultCode)
				return
			end
		
			local location
			local map = self.Entity.CurrentMap.Map
			local mode = map.mode
			if mode == "Lobby" then
				local home = self.Entity.CurrentMap.Home
				location = {
					mode = mode,
					channel = home.channel
				}
			elseif mode == "RankedMatch" then
				location = {
					mode = mode,
					worldInstanceKey = _WorldInstanceService.WorldInstanceId
				}
			elseif mode == "FriendlyMatch" then
				local room = self.Entity.CurrentMap.Room
				location = {
					mode = mode,
					room = room.room
				}
			elseif mode == "Practice" then
				local room = self.Entity.CurrentMap.Room
				location = {
					mode = mode,
					room = room.room
				}
			elseif mode == "Tutorial" then
				local room = self.Entity.CurrentMap.Room
				location = {
					mode = mode,
					room = room.room
				}
			end
			
			memory:SetVariableAndWait(self.Entity.Name, _MSON:AnyToString({
				profileCode = self.profileCode,
				nickname = self.nickname,
				majorRank = self:GetMajorRank(),
				location = location,
			}))
			
			if mode == "Lobby" and not self.finishedTutorial then
				local home = self.Entity.CurrentMap.Home
				
				home:BeginTutorial(self)
			end
		end)
	end

	@ExecSpace("Client")
	method void SetLoadedInOwner()
		self.isLoaded = true
	end

	@ExecSpace("ServerOnly")
	method void RankedMatchReady()
		while self.isMatchUserWaiting do
			wait(0.01)
		end
		
		if self.isMatchUser then
			local duel = self.Entity.CurrentMap.Map.duel
			for _, player in ipairs(duel.playerArray) do
				if player.isReady then
					continue
				end
				
				player:Ready(self)
				break
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SpawnClassTag()
		self.classTag = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("ClassTag"), 
			"ClassTag", Vector3.zero, self.Entity).NameTagComponent
		self.classTag.Entity.Enable = false
	end

	@ExecSpace("ServerOnly")
	method void SetTemp(table temp)
		self.temp = temp
		
		local dateTime = _DateTime:KtcNow()
		local days = _DateTime:KtcNowDays()
		
		if dateTime < DateTime(2024, 12, 13) then
			if temp.openEventCardPackCountKey == nil then
				temp.openEventCardPackCountKey = _DateTime:KtcNowDays()
				temp.openEventCardPackCount = 3
			end
		elseif DateTime(2024, 12, 13) <= dateTime and dateTime < DateTime(2024, 12, 20) then
			if temp.openEventCardPackCountKey == nil or temp.openEventCardPackCountKey < (DateTime(2024, 12, 13) - DateTime.MinValue).Days then
				temp.openEventCardPackCountKey = _DateTime:KtcNowDays()
				temp.openEventCardPackCount = 3
			end
		elseif DateTime(2024, 12, 20) <= dateTime and dateTime < DateTime(2024, 12, 27) then
			if temp.openEventCardPackCountKey == nil or temp.openEventCardPackCountKey < (DateTime(2024, 12, 20) - DateTime.MinValue).Days then
				temp.openEventCardPackCountKey = _DateTime:KtcNowDays()
				temp.openEventCardPackCount = 2
			end
		else
			temp.openEventCardPackCount = nil
			temp.openEventCardPackCountKey = nil
		end
		
		if dateTime < DateTime(2025, 6, 11) then
			if temp.specialEventAttendanceCountkey ~= days then
				temp.showedEvent = nil
				
				temp.specialEventAttendanceCountkey = days
				temp.specialEventAttendanceCount = (temp.specialEventAttendanceCount or 0) + 1
			end
		end
		
		if self:IsUser() then
			self:SetTempInOwner(temp, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetTempInOwner(table temp)
		self.temp = temp
		
		self.Entity:SendEvent(SetOpenEventCardPackCount())
	end

	method integer GetOpenEventCardPackCount()
		local key = self.temp.openEventCardPackCountKey
		if key == nil then
			return 0
		end
		
		local dateTime = _DateTime:KtcNow()
		
		if DateTime(2024, 12, 27) <= dateTime then
			return 0
		elseif key < (DateTime(2024, 12, 20) - DateTime.MinValue).Days and DateTime(2024, 12, 20) <= dateTime and dateTime < DateTime(2024, 12, 27) then
			return 2
		elseif key < (DateTime(2024, 12, 13) - DateTime.MinValue).Days and DateTime(2024, 12, 13) <= dateTime and dateTime < DateTime(2024, 12, 20) then
			return 3
		else
			return self.temp.openEventCardPackCount
		end
	end

	@ExecSpace("ServerOnly")
	method void DecreaseOpenEventCardPackCount()
		local key = self.temp.openEventCardPackCountKey
		if key == nil then
			return
		end
		
		local dateTime = _DateTime:KtcNow()
		local days = _DateTime:KtcNowDays()
		if DateTime(2024, 12, 27) <= dateTime then
			self.temp.openEventCardPackCount = nil
			self.temp.openEventCardPackCountKey = nil
		elseif key < (DateTime(2024, 12, 20) - DateTime.MinValue).Days and DateTime(2024, 12, 20) <= dateTime and dateTime < DateTime(2024, 12, 27) then
			self.temp.openEventCardPackCount = 1
			self.temp.openEventCardPackCountKey = days
		elseif key < (DateTime(2024, 12, 13) - DateTime.MinValue).Days and DateTime(2024, 12, 13) <= dateTime and dateTime < DateTime(2024, 12, 20) then
			self.temp.openEventCardPackCount = 2
			self.temp.openEventCardPackCountKey = days
		else
			self.temp.openEventCardPackCount -= 1
			self.temp.openEventCardPackCountKey = days
		end
		
		self:DecreaseOpenEventCardPackCountInOwner(self.temp.openEventCardPackCount, self.temp.openEventCardPackCountKey, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void DecreaseOpenEventCardPackCountInOwner(integer openEventCardPackCount, integer openEventCardPackCountKey)
		self.temp.openEventCardPackCount = openEventCardPackCount
		self.temp.openEventCardPackCountKey = openEventCardPackCountKey
		
		self.Entity:SendEvent(SetOpenEventCardPackCount())
	end

	@ExecSpace("ServerOnly")
	method void SetMeso(integer meso)
		self.meso = math.max(0, meso)
		
		if self:IsUser() then
			self:SetMesoInOwner(meso, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetMesoInOwner(integer meso)
		self.meso = meso
		
		self.Entity:SendEvent(SetMeso())
	end

	@ExecSpace("ServerOnly")
	method void AddMeso(integer delta, string source)
		self:AddMesoInServer(delta, source)
		
		if self:IsUser() then
			self:AddMesoInOwner(delta, self.Entity.Name)
		end
	end

	@ExecSpace("ServerOnly")
	method void AddMesoInServer(integer delta, string source)
		local meso = math.max(0, self.meso + delta)
		
		local befAsset = self.meso
		local afterAsset = meso
		local asset = math.abs(afterAsset - befAsset)
		
		self.meso = meso
	end

	@ExecSpace("Client")
	method void AddMesoInOwner(integer delta)
		self.meso = math.max(0, self.meso + delta)
		
		self.Entity:SendEvent(SetMeso())
	end

	method integer GetDailyRankedWinMeso()
		local days = _DateTime:KtcNowDays()
		if days == self.dailyRankedWinMesoKey then
			return self.dailyRankedWinMeso
		else
			return 0
		end
	end

	@ExecSpace("ServerOnly")
	method void SetDailyRankedWinMeso(integer dailyRankedWinMeso)
		local days = _DateTime:KtcNowDays()
		if days == self.dailyRankedWinMesoKey then
			self.dailyRankedWinMeso = dailyRankedWinMeso
		else
			self.dailyRankedWinMeso = 0
			self.dailyRankedWinMesoKey = days
		end
	end

	@ExecSpace("ServerOnly")
	method void AddDailyRankedWinMeso(integer delta)
		local days = _DateTime:KtcNowDays()
		if days == self.dailyRankedWinMesoKey then
			self.dailyRankedWinMeso += delta
		else
			self.dailyRankedWinMeso = delta
			self.dailyRankedWinMesoKey = days
		end
	end

	method integer GetDailyPlayMeso()
		local days = _DateTime:KtcNowDays()
		if days == self.dailyPlayMesoKey then
			return self.dailyPlayMeso
		else
			return 0
		end
	end

	@ExecSpace("ServerOnly")
	method void SetDailyPlayMeso(integer dailyPlayMeso)
		local days = _DateTime:KtcNowDays()
		if days == self.dailyPlayMesoKey then
			self.dailyPlayMeso = dailyPlayMeso
		else
			self.dailyPlayMeso = 0
			self.dailyPlayMesoKey = days
		end
	end

	@ExecSpace("ServerOnly")
	method void AddDailyPlayMeso(integer delta)
		local days = _DateTime:KtcNowDays()
		if days == self.dailyPlayMesoKey then
			self.dailyPlayMeso += delta
		else
			self.dailyPlayMeso = delta
			self.dailyPlayMesoKey = days
		end
	end

	method integer GetDailyRankedPlayCount()
		local days = _DateTime:KtcNowDays()
		if days == self.dailyRankedPlayCountKey then
			return self.dailyRankedPlayCount
		else
			return 0
		end
	end

	@ExecSpace("ServerOnly")
	method void SetDailyRankedPlayCount(integer dailyRankedPlayCount)
		local days = _DateTime:KtcNowDays()
		if days == self.dailyRankedPlayCountKey then
			self.dailyRankedPlayCount = dailyRankedPlayCount
		else
			self.dailyRankedPlayCount = 0
			self.dailyRankedPlayCountKey = days
		end
	end

	@ExecSpace("ServerOnly")
	method void IncreaseDailyRankedPlayCount()
		local days = _DateTime:KtcNowDays()
		if days == self.dailyRankedPlayCountKey then
			self.dailyRankedPlayCount += 1
		else
			self.dailyRankedPlayCount = 1
			self.dailyRankedPlayCountKey = days
		end
	end

	method integer GetCardCount(table info)
		local name = info.name
		local variant = info.variant
		local quality = info.quality
		
		if self.cardTable ~= nil and self.cardTable[name] ~= nil and self.cardTable[name][variant] ~= nil and self.cardTable[name][variant][quality] ~= nil then
			return self.cardTable[name][variant][quality]
		else
			return 0
		end
	end

	@ExecSpace("ServerOnly")
	method void SetCards(table cardTable)
		self.cardTable = cardTable
		
		if self:IsUser() then
			self:SetCardsInOwner(cardTable, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetCardsInOwner(table cardTable)
		self.cardTable = cardTable
	end

	method void GainCards(table infoArray, string source)
		for _, info in ipairs(infoArray) do
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			self.cardTable[name] = self.cardTable[name] or {}
			self.cardTable[name][variant] = self.cardTable[name][variant] or {}
			self.cardTable[name][variant][quality] = self.cardTable[name][variant][quality] or 0
			
			if source ~= "BuyCard" then
				self.newCardTable[name] = self.newCardTable[name] or {}
				self.newCardTable[name][variant] = self.newCardTable[name][variant] or {}
				self.newCardTable[name][variant][quality] = self.newCardTable[name][variant][quality] or 0
			end
			
			local befItemCount = self.cardTable[name][variant][quality]
			local afterItemCount = befItemCount + 1
			self.cardTable[name][variant][quality] += 1
			if source ~= "BuyCard" then
				self.newCardTable[name][variant][quality] += 1
			end
			
		end
	end

	method void LoseCards(table infoArray, string source)
		for _, info in ipairs(infoArray) do
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			local count = self.cardTable[name][variant][quality]
			local befItemCount = count
			local afterItemCount = count - 1
			self.cardTable[name][variant][quality] = count > 1 and count - 1 or nil
			local t2 = self.cardTable[name][variant]
			if _Table:IsEmpty(t2) then
				self.cardTable[name][variant] = nil
			end
			local t1 = self.cardTable[name]
			if _Table:IsEmpty(t1) then
				self.cardTable[name] = nil
			end
			
		end
	end

	method void BuySingleCardPackServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method boolean BuySingleCardPack(string cardPackName)
		if not self.isLoaded then
			return false
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return false
			end
		end
		
		_Server.sender = nil
		
		local befAsset
		local afterAsset
		local success = false
		local currency = self.cardPackManager:GetCurrency(cardPackName)  
		local price = self.cardPackManager:GetSinglePrice(cardPackName)
		if currency == "Meso" then
			if self.meso >= price then
				befAsset = self.meso
				self:AddMeso(-price, "BuyCardPack")
				afterAsset = self.meso
				
				success = true
			end
		elseif currency == "WorldCoin" then
			success = true
		end
		
		local infoArray
		if success then
			local productType = "SingleCardPack"
			local productId = cardPackName .. productType
			
			infoArray = self.cardPackManager:GetInfos(cardPackName)
			self:GainCards(infoArray, "OpenCardPack")
			
			self.cardPackData = {
				name = cardPackName,
				infos = {infoArray},
				index = 1,
			}
		end
		
		if self:IsUser() then
			self:BuySingleCardPackInOwner(cardPackName, success, infoArray, self.Entity.Name)
		end
		
		return success
	end

	@ExecSpace("Client")
	method void BuySingleCardPackInOwner(string cardPackName, boolean success, table infoArray)
		if not success then
			self.uiManager.PopupModule:Open("NotEnoughMeso", true, nil, nil)
			
			return
		end
		
		self:GainCards(infoArray, nil)
		self.uiManager.CardPackModule:Open(cardPackName, 1)
	end

	method void BuySingleCardPackByOpenEventServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void BuySingleCardPackByOpenEvent(string cardPackName)
		if not self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local success = false
		local dateTime = _DateTime:KtcNow()
		local openEventCardPackCount = self:GetOpenEventCardPackCount()
		if ((cardPackName == "ClassicUnique" and dateTime < DateTime(2024, 12, 20)) or
			(cardPackName == "ClassicLegendary" and DateTime(2024, 12, 20) <= dateTime and dateTime < DateTime(2024, 12, 27))) and openEventCardPackCount > 0 then
			self:DecreaseOpenEventCardPackCount()
			
			success = true
		end
		
		local infoArray
		if success then
			local productType = "SingleCardPack"
			local productId = cardPackName .. productType
			
			infoArray = self.cardPackManager:GetInfos(cardPackName)
			self:GainCards(infoArray, "OpenCardPack")
			
			self.cardPackData = {
				name = cardPackName,
				infos = {infoArray},
				index = 1,
			}
		end
		
		if self:IsUser() then
			self:BuySingleCardPackByOpenEventInOwner(cardPackName, success, infoArray, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void BuySingleCardPackByOpenEventInOwner(string cardPackName, boolean success, table infoArray)
		if not success then
			self.uiManager.PopupModule:Open("NotEventPeriod", true, nil, nil)
			
			return
		end
		
		self:GainCards(infoArray, nil)
		self.uiManager.CardPackModule:Open(cardPackName, 1)
	end

	method void BuyMultipleCardPacksServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method boolean BuyMultipleCardPacks(string cardPackName)
		if not self.isLoaded then
			return false
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return false
			end
		end
		
		_Server.sender = nil
		
		local befAsset
		local afterAsset
		local success = false
		local currency = self.cardPackManager:GetCurrency(cardPackName)  
		local price = self.cardPackManager:GetMultiplePrice(cardPackName)
		if currency == "Meso" then
			if self.meso >= price then
				befAsset = self.meso
				self:AddMeso(-price, "BuyCardPack")
				afterAsset = self.meso
				
				success = true
			end
		elseif currency == "WorldCoin" then
			success = true
		end
		
		local infos
		if success then
			local productType = "MultipleCardPack"
			local productId = cardPackName .. productType
			
			infos = {}
			for i = 1, 5 do
				local infoArray = self.cardPackManager:GetInfos(cardPackName)
				self:GainCards(infoArray, "OpenCardPack")
				table.insert(infos, infoArray)
			end
			
			self.cardPackData = {
				name = cardPackName,
				infos = infos,
				index = 1,
			}
		end
		
		if self:IsUser() then
			self:BuyMultipleCardPacksInOwner(cardPackName, success, infos, self.Entity.Name)
		end
		
		return success
	end

	@ExecSpace("Client")
	method void BuyMultipleCardPacksInOwner(string cardPackName, boolean success, table infos)
		local currency = self.cardPackManager:GetCurrency(cardPackName)  
		local price = self.cardPackManager:GetMultiplePrice(cardPackName)
		
		if not success then
			if currency == "Meso" then
				self.uiManager.PopupModule:Open("NotEnoughMeso", true, nil, nil)
			end
			
			return
		end
		
		for _, infoArray in ipairs(infos) do
			self:GainCards(infoArray, nil)
		end
		self.uiManager.CardPackModule:Open(cardPackName, 5)
	end

