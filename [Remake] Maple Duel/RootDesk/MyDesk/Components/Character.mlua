		if self:IsOwner() then
			self.Entity:SendEvent(SetRank())
		end
	end

	method void BuyCardServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void BuyCard(table info)
		if not self.isLoaded then
			return
		end
		
		if not (self.cardManager:GetRarity(info.name) == "Normal" and info.quality == "Gold" and self:GetCardCount(info) < 2) then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local befAsset
		local afterAsset
		local success = false
		local price = 100000
		if self.meso >= price then
			befAsset = self.meso
			self:AddMeso(-price, "BuyCard")
			afterAsset = self.meso
			
			success = true
		end
		
		if success then
			local productType = "Card"
			local productId = string.format("%s%s%s%s", info.name, info.variant, info.quality, productType)
			
			self:GainCards({info}, "BuyCard")
		end
		
		if self:IsUser() then
			self:BuyCardInOwner(info, success, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void BuyCardInOwner(table info, boolean success)
		if not success then
			self.uiManager.PopupModule:Open("NotEnoughMeso", true, nil, nil)
			
			return
		end
		
		self.uiManager.PopupModule:Open("SuccessBuyCard", true, nil, nil)
		self:GainCards({info}, "BuyCard")
		self.Entity:SendEvent(_Event:BuyCard(info))
	end

	method void SellCardServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void SellCard(table info)
		if not self.isLoaded then
			return
		end
		
		if self:GetCardCount(info) <= 2 then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local price = self.cardManager:GetSellPrice(self.cardManager:GetRarity(info.name))
		self:AddMeso(price, "SellCard")
		
		self:LoseCards({info}, "SellCard")
		
		if self:IsUser() then
			self:SellCardInOwner(info, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SellCardInOwner(table info)
		self.uiManager.PopupModule:Open("SuccessSellCard", true, nil, nil)
		self:LoseCards({info}, nil)
		self.Entity:SendEvent(_Event:SellCard(info))
	end

	method boolean IsUser()
		return self.Entity.Model.Name == "DefaultPlayer"
	end

	method boolean IsOwner()
		return self.Entity == _UserService.LocalPlayer
	end

	method boolean IsAlly()
		return self:IsClient() and _UserService.LocalPlayer.Character:IsAllyWith(self)
	end

	method boolean IsAllyWith(Character character)
		if isvalid(self.player) and self.player.opponent.character == character then
			return false
		end
		
		return self == character or self:IsFriendWith(character)
	end

	method boolean IsFriendWith(Character character)
		return self:IsUser() and self.friendTable[character.Entity.Name] ~= nil
	end

	method boolean IsAbleToMatch()
		return self.isLoaded and not _UtilLogic:IsNilorEmptyString(self.cardBack) and not _Table:IsEmpty(self:GetDeck()) and self.deckManager:IsDeckComplete(self:GetDeck())
	end

	method boolean IsAbleToReady()
		if self.Entity.CurrentMap.Map.mode == "Tutorial" then
			return self.isLoaded
		else
			return self.isLoaded and not _UtilLogic:IsNilorEmptyString(self.cardBack) and not _Table:IsEmpty(self:GetDeck()) and self.deckManager:IsDeckComplete(self:GetDeck())
		end
	end

	method table GetDeck()
		local tutorial = self.Entity.CurrentMap.Map.tutorial
		if isvalid(tutorial) then
			if self:IsUser() then
				if tutorial.duelId == 1 then
					return self.deckManager:GetTutorialPlayerDeck_1()
				elseif tutorial.duelId == 2 then
					return self.deckManager:GetTutorialPlayerDeck_2()
				end
			else
				if tutorial.duelId == 1 then
					return self.deckManager:GetTutorialBotDeck_1()
				elseif tutorial.duelId == 2 then
					return self.deckManager:GetTutorialBotDeck_2()
				end
			end
		else
			return self.deckArray[self.deckIndex]
		end
	end

	method string GetMajorRank()
		return self.rankManager:GetMajorRank(self.rankPoint, self.ranking)
	end

	method integer GetMinorRank()
		return self.rankManager:GetMinorRank(self.rankPoint)
	end

	@ExecSpace("ClientOnly")
	method string GetRankName()
		return self.rankManager:GetRankName(self.rankPoint, self.ranking)
	end

	@ExecSpace("ClientOnly")
	method string GetRankPoint()
		return self.rankManager:GetRankPoint(self.rankPoint)
	end

	@ExecSpace("ClientOnly")
	method void SetNameTag()
		if self.rankPoint == nil or self.ranking == nil then
			return
		end
		
		local resource = self.resourceManager:GetResource("NameTag")
		local majorRank = self:GetMajorRank()
		self.Entity.NameTagComponent.NameTagRUID = resource[majorRank]
	end

	method void OpenCardPackServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void OpenCardPack(string cardPackName)
		if not self.isLoaded then
			return
		end
		
		if _Table:IsEmpty(self.cardPackData) then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local name = self.cardPackData.name
		local infos = self.cardPackData.infos
		local index = self.cardPackData.index
		
		local infoArray = infos[index]
		self.cardPackData.index += 1
		if self.cardPackData.index > #infos then
			self.cardPackData = nil
		end
		
		self:OpenCardPackInClient(name, infoArray)
	end

	@ExecSpace("Client")
	method void OpenCardPackInClient(string cardPackName, table infoArray)
		if self:IsOwner() then
			self.uiManager.CardPackModule:OpenCardPack(infoArray)
		end
		
		self.cardPackManager:OpenCardPack(self, cardPackName, infoArray)
	end

	@ExecSpace("ServerOnly")
	method void SetFriends(table friendTable)
		for _, userId in ipairs(self.unfriendArray) do
			friendTable[userId] = nil
		end
		
		local userDataStorage = _DataStorageService:GetUserDataStorage(self.Entity.Name)
		if userDataStorage ~= nil then
			while true do
				local resultCode, value = userDataStorage:GetAndWait("unfriendArray")
				if resultCode == 0 then
					if value == nil then
						userDataStorage:SetAndWait("unfriendArray", "{}")
						break
					else
						local unfriendArray = _MSON:FastStringToAny(value)
						for _, userId in ipairs(self.unfriendArray) do
							_Table:Remove(unfriendArray, userId)
						end
						resultCode, value = userDataStorage:UpdateAndWait("unfriendArray", value, _MSON:FastAnyToString(unfriendArray))
						if resultCode == 0 then
							break
						elseif resultCode == 2000000 then
							continue
						else
							log(resultCode)
							break
						end
					end
				else
					log(resultCode)
					break
				end
			end
		end
		
		self.friendTable = friendTable
		
		if self:IsUser() then
			self:SetFriendsInOwner(friendTable, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetFriendsInOwner(table friendTable)
		self.friendTable = friendTable
		
		local duel = self.Entity.CurrentMap.Map.duel
		if isvalid(duel) and duel.isDueling then
			for _, player in ipairs(duel.playerArray) do
				player:ShowFriendRequestButton()
			end
		end
	end

	method void SendFriendRequestServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void SendFriendRequest(Character other)
		if not self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local result
		if not isvalid(other) or not other.isLoaded then
			result = "UserNotFound"
		elseif _Table:Contains(other.friendRequestArray, self) then
			result = "Pending"
		elseif self:IsFriendWith(other) then
			result = "FriendAlready"
		else
			result = "Success"
		end
		
		if result == "Success" then
			table.insert(other.friendRequestArray, self)
			self:SendFriendRequestInOther(other.Entity.Name)
		end
		
		self:SendFriendRequestInOwner(result, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void SendFriendRequestInOther()
		local other = _UserService.LocalPlayer.Character
		
		if #other.friendRequestArray == 0 then
			self.uiManager.SocialModule:ShowPopup(self)
		end
		table.insert(other.friendRequestArray, self)
	end

	@ExecSpace("Client")
	method void SendFriendRequestInOwner(string result)
		self.uiManager.PopupModule:Open("SendFriendRequest" .. result, true, nil, nil)
		self.uiManager.InteractionModule:Close()
	end

	method void RefuseFriendRequestServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void RefuseFriendRequest(Character sender)
		if not self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		_Table:Remove(self.friendRequestArray, sender)
		for i = #self.friendRequestArray, 1, -1 do
			if not isvalid(self.friendRequestArray[i]) then
				table.remove(self.friendRequestArray, i)
			end
		end
		
		self:RefuseFriendRequestInOwner(sender, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void RefuseFriendRequestInOwner(Character sender)
		_Table:Remove(self.friendRequestArray, sender)
		for i = #self.friendRequestArray, 1, -1 do
			if not isvalid(self.friendRequestArray[i]) then
				table.remove(self.friendRequestArray, i)
			end
		end
		
		if isvalid(self.friendRequestArray[1]) then
			self.uiManager.SocialModule:ShowPopup(self.friendRequestArray[1])
		else
			self.uiManager.SocialModule:HidePopup()
		end
	end

	method void AcceptFriendRequestServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void AcceptFriendRequest(Character sender)
		if not self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		_Table:Remove(self.friendRequestArray, sender)
		for i = #self.friendRequestArray, 1, -1 do
			if not isvalid(self.friendRequestArray[i]) then
				table.remove(self.friendRequestArray, i)
			end
		end
		
		local result
		if not isvalid(sender) or not sender.isLoaded then
			result = "UserNotFound"
		elseif self:IsFriendWith(sender) then
			result = "FriendAlready"
		else
			result = "Success"
		end
		
		if result == "Success" then
			self.friendTable[sender.Entity.Name] = {profileCode = sender.profileCode, nickname = sender.nickname}
			sender.friendTable[self.Entity.Name] = {profileCode = self.profileCode, nickname = self.nickname}
			self:AcceptFriendRequestInSender(sender.Entity.Name)
			
			if isvalid(self.player) and not isvalid(sender.player) and self.player.duel.isDueling then
				self.player.commandManager:SetWatching(sender, self.player)
			end
			if isvalid(sender.player) and not isvalid(self.player) and sender.player.duel.isDueling then
				sender.player.commandManager:SetWatching(self, sender.player)
			end
		end
		self:AcceptFriendRequestInOwner(sender, result, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void AcceptFriendRequestInOwner(Character sender, string result)
		_Table:Remove(self.friendRequestArray, sender)
		for i = #self.friendRequestArray, 1, -1 do
			if not isvalid(self.friendRequestArray[i]) then
				table.remove(self.friendRequestArray, i)
			end
		end
		
		if isvalid(self.friendRequestArray[1]) then
			self.uiManager.SocialModule:ShowPopup(self.friendRequestArray[1])
		else
			self.uiManager.SocialModule:HidePopup()
		end
		
		if result == "Success" then
			local user = _UserService.Users[sender.Entity.Name]
			self.friendTable[sender.Entity.Name] = {profileCode = user.ProfileCode, nickname = user.Nickname}
		else
			self.uiManager.PopupModule:Open("AcceptFriendRequest" .. result, true, nil, nil)
		end
	end

	@ExecSpace("Client")
	method void AcceptFriendRequestInSender()
		local sender = _UserService.LocalPlayer.Character
		local user = _UserService.Users[self.Entity.Name]
		sender.friendTable[self.Entity.Name] = {profileCode = user.ProfileCode, nickname = user.Nickname}
	end

	method void UnfriendServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void Unfriend(string userId)
		if not self.isLoaded then
			return
		end
		
		if not self.friendTable[userId] then
			self:UnfriendInOwner(userId, self.Entity.Name)
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local userEntity = _UserService:GetUserEntityByUserId(userId)
		if isvalid(userEntity) and userEntity.Character.isLoaded then
			local other = userEntity.Character
			self.friendTable[userId] = nil
			other.friendTable[self.Entity.Name] = nil
			
			if isvalid(self.player) and not isvalid(other.player) and self.player.duel.isDueling then
				self.player.commandManager:SetWatching(other, self.player)
			end
			if isvalid(other.player) and not isvalid(self.player) and other.player.duel.isDueling then
				other.player.commandManager:SetWatching(self, other.player)
			end
			
			self:UnfriendInOther(userId)
		else
			self.friendTable[userId] = nil
			
			local userDataStorage = _DataStorageService:GetUserDataStorage(userId)
			if userDataStorage ~= nil then
				while true do
					local resultCode, value = userDataStorage:GetAndWait("unfriendArray")
					if resultCode == 0 then
						if value == nil then
							userDataStorage:SetAndWait("unfriendArray", "{}")
							break
						else
							local unfriendArray = _MSON:FastStringToAny(value)
							table.insert(unfriendArray, self.Entity.Name)
							resultCode, value = userDataStorage:UpdateAndWait("unfriendArray", value, _MSON:FastAnyToString(unfriendArray))
							if resultCode == 0 then
								break
							elseif resultCode == 2000000 then
								continue
							else
								log(resultCode)
								break
							end
						end
					else
						log(resultCode)
						break
					end
				end
			end
		end
		
		self:UnfriendInOwner(userId, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void UnfriendInOther()
		local other = _UserService.LocalPlayer.Character
		other.friendTable[self.Entity.Name] = nil
		
		other.Entity:SendEvent(_Event:Unfriend(self.Entity.Name))
	end

	@ExecSpace("Client")
	method void UnfriendInOwner(string userId)
		self.friendTable[userId] = nil
		
		self.uiManager.InteractionModule:Close()
		
		self.Entity:SendEvent(_Event:Unfriend(userId))
	end

	method integer GetFriendCount()
		return _Table:GetSize(self.friendTable)
	end

	method boolean IsBanned()
		if _UtilLogic:IsNilorEmptyString(self.banStartDate) or _UtilLogic:IsNilorEmptyString(self.banEndDate) then
			return false
		end
		
		return DateTime(self.banStartDate) <= _DateTime:KtcNow() and _DateTime:KtcNow() <= DateTime(self.banEndDate)
	end

	@ExecSpace("ServerOnly")
	method void SetBanned(string banStartDate, string banEndDate, string banReason)
		self.banStartDate = banStartDate
		self.banEndDate = banEndDate
		self.banReason = banReason
		
		if self:IsUser() then
			self:SetBannedInOwner(banStartDate, banEndDate, banReason, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetBannedInOwner(string banStartDate, string banEndDate, string banReason)
		self.banStartDate = banStartDate
		self.banEndDate = banEndDate
		self.banReason = banReason
		
		if self:IsBanned() then
		
			self.uiManager.PopupModule:ShowBanMessage(banStartDate, banEndDate, banReason)
		end
	end

