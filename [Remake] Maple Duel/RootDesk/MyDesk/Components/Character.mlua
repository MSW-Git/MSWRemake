	@ExecSpace("Client")
	method void PlayEmoteInClient(string emote)
		if self:IsOwner() then
			self.uiManager.EmoteModule:Close()
		end
		
		self.Entity.AvatarRendererComponent:PlayEmotion(self.emoteManager:GetEmotionalType(emote), 3)
		
		local spriteRenderer = self.emoteEntity.SpriteRendererComponent
		spriteRenderer.SpriteRUID = ""
		spriteRenderer.SpriteRUID = self.resourceManager:GetResource("Emote")[emote]
		local transform = self.emoteEntity.TransformComponent
		transform.Position.x = 0
		transform.Position.y = 0
		transform.Position.z = 0
		transform.Scale.x = 0
		transform.Scale.y = 0
		
		if self.emoteTweener then
			self.emoteTweener:Destroy()
		end
		_TimerService:ClearTimer(self.emoteSortTimer)
		_TimerService:ClearTimer(self.emoteTimer)
		self.emoteTweener = _Tween:MoveAndScaleTo(self.emoteEntity, Vector2(0, 0.75), 2 * Vector2.one, 0.125, EaseType.Linear, EaseType.Linear, false)
		self.emoteSortTimer = _TimerService:SetTimerRepeat(function()
			spriteRenderer.SortingLayer = self.Entity.AvatarRendererComponent.SortingLayer
			spriteRenderer.OrderInLayer = 5
		end, 0.01)
		self.emoteTimer = _TimerService:SetTimerOnce(function()
			self.emoteTweener:Destroy()
			_TimerService:ClearTimer(self.emoteSortTimer)
			self.emoteTweener = _Tween:ScaleTo(self.emoteEntity, Vector2.zero, 0.125, EaseType.Linear)
		end, 2.875)
	end

	@ExecSpace("ClientOnly")
	method void SpawnEmoteEffect()
		self.emoteEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Effect"), "Effect", Vector3(100, 100, 0), self.Entity)
	end

