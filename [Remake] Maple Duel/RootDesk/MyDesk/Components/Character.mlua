	@ExecSpace("ServerOnly")
	method void SetDecks(table deckArray)
		for _, deck in ipairs(deckArray) do
			if deck.cardTable ~= nil then
				for name, t1 in pairs(deck.cardTable) do
					for variant, t2 in pairs(t1) do
						for quality, count in pairs(t2) do
							local ownCount = self:GetCardCount({name = name, variant = variant, quality = quality})
							if ownCount <= count then
								t2[quality] = ownCount
							end
						end
					end
				end
			end
		end
		
		self.deckArray = deckArray
		
		if self:IsUser() then
			self:SetDecksInOwner(deckArray, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void SetDecksInOwner(table deckArray)
		self.deckArray = deckArray
	end

	method void CreateDeckServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void CreateDeck(string class, string localeId)
		if not self.isLoaded then
			return
		end
		
		if not (class == "Warrior" or class == "Magician" or class == "Bowman" or class == "Thief" or class == "Pirate") then
			return
		end
		
		if #self.deckArray >= self.maxDeckCount then
			return
		end
		
		if isvalid(self.player) or self.isMatching then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		local deck = self.deckManager:GetNewDeck(class, localeId)
		table.insert(self.deckArray, deck)
		self.deckIndex = #self.deckArray
		
		if self:IsUser() then
			self:CreateDeckInOwner(deck, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void CreateDeckInOwner(table deck)
		table.insert(self.deckArray, deck)
		self.deckIndex = #self.deckArray
		self.Entity:SendEvent(CreateDeck())
		self.Entity:SendEvent(SetDeckIndex())
	end

	method void FinishDeckServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void FinishDeck(table deck)
		if not self.isLoaded then
			return
		end
		
		if _Table:IsEmpty(self:GetDeck()) then
			return
		end
		
		if not self.deckManager:IsDeckValid(deck) then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		if deck.cardTable ~= nil then
			for name, t1 in pairs(deck.cardTable) do
				for variant, t2 in pairs(t1) do
					for quality, count in pairs(t2) do
						if self:GetCardCount({name = name, variant = variant, quality = quality}) < count then
							return
						end
					end
				end
			end
		end
		
		if isvalid(self.player) or self.isMatching then
			return
		end
		
		self.deckArray[self.deckIndex] = deck
		
		if self:IsUser() then
			self:FinishDeckInOwner(deck, self.Entity.Name)
		end
	end

	@ExecSpace("Client")
	method void FinishDeckInOwner(table deck)
		self.deckArray[self.deckIndex] = deck
		self.Entity:SendEvent(FinishDeck())
	end

