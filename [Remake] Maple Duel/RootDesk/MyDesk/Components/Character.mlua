	method boolean IsNewCard(table info)
		local name = info.name
		local variant = info.variant
		local quality = info.quality
		
		if self.newCardTable ~= nil and self.newCardTable[name] ~= nil and self.newCardTable[name][variant] ~= nil and self.newCardTable[name][variant][quality] then
			return true
		else
			return false
		end
	end

	method void RemoveNewCardsServerAttribute()
		
	end

	@ExecSpace("ServerOnly")
	method void RemoveNewCards(table infoArray)
		if not self.isLoaded then
			return
		end
		
		if _Server:IsRequesting() then
			if self ~= _Server.sender then
				return
			end
		end
		
		_Server.sender = nil
		
		for _, info in ipairs(infoArray) do
			if not self:IsNewCard(info) then
				continue
			end
			
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			local count = self.newCardTable[name][variant][quality]
			if count ~= nil then
				self.newCardTable[name][variant][quality] = nil
			end
			local t2 = self.newCardTable[name][variant]
			if _Table:IsEmpty(t2) then
				self.newCardTable[name][variant] = nil
			end
			local t1 = self.newCardTable[name]
			if _Table:IsEmpty(t1) then
				self.newCardTable[name] = nil
			end
		end
		
		self:RemoveNewCardsInOwner(infoArray, self.Entity.Name)
	end

	@ExecSpace("Client")
	method void RemoveNewCardsInOwner(table infoArray)
		for _, info in ipairs(infoArray) do
			if not self:IsNewCard(info) then
				continue
			end
			
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			local count = self.newCardTable[name][variant][quality]
			if count ~= nil then
				self.newCardTable[name][variant][quality] = nil
			end
			local t2 = self.newCardTable[name][variant]
			if _Table:IsEmpty(t2) then
				self.newCardTable[name][variant] = nil
			end
			local t1 = self.newCardTable[name]
			if _Table:IsEmpty(t1) then
				self.newCardTable[name] = nil
			end
		end
	end

