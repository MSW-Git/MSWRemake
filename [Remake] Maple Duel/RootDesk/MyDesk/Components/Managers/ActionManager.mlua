		local position = receiver:GetOffsettedPosition(unit, 1.5 * Vector2.right, false)
		_Tween:MoveTo(receiver.actor.Entity, position, 0.25, EaseType.CubicEaseOut, true)
		receiver:LookAt(unit)
		
		wait(0.25)
		
		receiver:Animate("Skill2")
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		wait(1.43)
		
		_Effect:PlayHitEffectAttached(resource.hitAnimation_2, unit, Vector3.zero, receiver, nil)
		
		_TimerService:SetTimerOnce(function()
				_Tween:MoveTo(receiver.actor.Entity, Vector2.zero, 0.5, EaseType.CubicEaseOut, false)
				receiver:LookNothing()
			end, 1.43)
	end

