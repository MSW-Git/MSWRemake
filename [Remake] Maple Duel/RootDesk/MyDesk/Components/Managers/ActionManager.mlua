	@ExecSpace("ClientOnly")
	method void PreCoreClownMonkey(Unit unit)
		local receiver = self.triggerManager.receiver
		local resource = self.resourceManager:GetResource("ClownMonkey")
		
		local ballAnimationArray = {resource.ballAnimation_1, resource.ballAnimation_2, resource.ballAnimation_3}
		local hitAnimationArray = {resource.hitAnimation_1, resource.hitAnimation_2, resource.hitAnimation_3}
		local hitSoundArray = {resource.hitSound_1, resource.hitSound_2, resource.hitSound_3}
		local randomIndex = _UtilLogic:RandomIntegerRange(1, 3)
		
		local fromPosition = receiver:GetLookAtPosition(Vector2(0.18, 0.27), true)
		local toPosition = unit:GetActorPosition()
		_Effect:ThrowEffect(ballAnimationArray[randomIndex], fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
		
		wait(0.5)
		
		_Effect:PlayHitEffectAttached(hitAnimationArray[randomIndex], unit, Vector3.zero, receiver, nil)
		_SoundService:PlaySound(hitSoundArray[randomIndex], 1)
	end

