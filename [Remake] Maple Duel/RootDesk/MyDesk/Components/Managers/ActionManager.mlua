	@ExecSpace("ClientOnly")
	method void PreCoreStirge(Unit unit, Minion attacker)
		local receiver = self.triggerManager.receiver
		local resource = self.resourceManager:GetResource("Stirge")
		
		local offset = receiver.actor.Entity.TransformComponent.Position:ToVector2()
		_Tween:Lerp(receiver.actor.Entity, receiver.anchorEntity, unit.actor.Entity, 0, 1, 0.3, EaseType.CubicEaseIn, offset, nil)
		
		wait(0.2)
		
		_SoundService:PlaySound(resource.skillSound_1, 0.5)
		
		wait(0.1)
		
		_Effect:PlayHitEffect(resource.hitAnimation_1, unit, Vector3.zero, receiver, nil)
		_Tween:Lerp(receiver.actor.Entity, receiver.anchorEntity, unit.actor.Entity, 1, 0, 0.5, EaseType.CubicEaseOut, offset, nil)
	end

	@ExecSpace("ClientOnly")
	method void PreCoreStrafe(Minion minion, Card attacker)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("Strafe")
		
		player:PlaceFront()
		player:Animate("Shoot1")
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, 0.001 * Vector3.back, nil)
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.5)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_2, player, Vector3.zero, {FadeOut = true})
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		local count = 4
		local interval = 0.075
		local gapY = 0.2
		_TimerService:SetTimerOnce(function()
				for i = 1, count do
					local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
					local toPosition = player:GetOffsettedPosition(minion, Vector2(0, gapY * (0.5 * count + 0.5 - i)), false)
					_Effect:ThrowEffect(resource.ballAnimation_1, fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
				
					wait(interval)
				end
			end, 0)
		
		wait(0.5)
		
		_TimerService:SetTimerOnce(function()
				for i = 1, count do
					_Effect:PlayHitEffect(resource.hitAnimation_1, minion, Vector3(0, gapY * (0.5 * count + 0.5 - i), -0.001 * i), player, nil)
				
					wait(interval)
				end
			end, 0)
		_TimerService:SetTimerOnce(function()
				for i = 2, count do
					wait(interval)
				
					_SoundService:PlaySound(self.resourceManager:GetResource(minion.name).damageSound, 1)
				end
			end, 0)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.75)
	end

