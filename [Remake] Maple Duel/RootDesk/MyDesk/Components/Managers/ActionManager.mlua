	method number GetProcessDelay(string actionName)
		-- 액션 이름에 따른 처리 지연 시간 반환
		return self.processDelayTable[actionName] or 0
	end

	method number GetCoreDelay(string actionName)
		-- 액션 이름에 따른 핵심 지연 시간 반환
		return self.coreDelayTable[actionName] or 0
	end

	@ExecSpace("ClientOnly")
	method void PlayPreProcessAction(string actionName)
		-- 액션 전처리 단계 실행
		_Util:Call(self, "PreProcess" .. actionName, {})
	end

	@ExecSpace("ClientOnly")
	method void PlayPostProcessAction(string actionName)
		-- 액션 후처리 단계 실행
		_Util:Call(self, "PostProcess" .. actionName, {})
	end

	@ExecSpace("ClientOnly")
	method void PlayPreCoreAction(string actionName, Object object, table args)
		-- 액션 핵심 전처리 단계 실행
		_Util:Call(self, "PreCore" .. actionName, {object, _Table:Unpack(args)})
	end

	@ExecSpace("ClientOnly")
	method void PlayPostCoreAction(string actionName, Object object, table args)
		-- 액션 핵심 후처리 단계 실행
		_Util:Call(self, "PostCore" .. actionName, {object, _Table:Unpack(args)})
	end

	method string GetSummonActionName(string name)
		-- 소환 액션 이름을 생성하고 해당 메서드 존재 여부에 따라 기본값 반환
		local actionName = "Summon" .. name
		return self[actionName] == nil and "Summon" or actionName
	end

	@ExecSpace("ClientOnly")
	method void PlaySummonAction(Minion minion)
		-- 미니언 소환 액션을 실행
		_Util:Call(self, self:GetSummonActionName(minion.name), {minion})
	end

	@ExecSpace("ClientOnly")
	method table SummonCoroutine(Minion minion)
		-- 미니언 소환 액션을 코루틴으로 실행하여 제어 가능한 태스크 반환
		return _Util:RunCoroutine(self, self:GetSummonActionName(minion.name), {minion})
	end

	@ExecSpace("ClientOnly")
	method void Summon(Minion minion)
		-- 기본 소환 애니메이션과 사운드 효과 재생
		local resource = self.resourceManager:GetResource("Summon")
		
		local transform = minion.actor.Entity.TransformComponent
		transform.Position = Vector3.zero
		transform.Scale.x = 0
		transform.Scale.y = 0
		minion:PlaceFront()
		_Tween:MoveAndScaleTo(minion.actor.Entity, Vector2(0, 0.8), 1.25 * Vector2.one, 0.375, EaseType.CubicEaseOut, EaseType.CubicEaseOut, false)
		_SoundService:StopSound(resource.sound)
		_SoundService:PlaySound(resource.sound, 1)
		_TimerService:SetTimerOnce(function()
				_Tween:MoveAndScaleTo(minion.actor.Entity, Vector2.zero, Vector2.one, 0.375, EaseType.CubicEaseIn, EaseType.CubicEaseIn, false)
			end, 0.375)
		_TimerService:SetTimerOnce(function()
				_Effect:PlayEffect(resource.animation, Vector3.zero, minion.actor.Entity, _Effect:GetUnitLayerOptions(nil))
			end, 0.4)
		
		
		wait(0.75)
		
		minion:PlaceBack()
	end

	@ExecSpace("ClientOnly")
	method void PreProcessAirStrike()
		-- 에어 스트라이크 스킬 전처리 (플레이어 애니메이션 및 이펙트)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("AirStrike")
		
		player:Animate("AirStrike")
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, Vector3.zero, nil)
		
		wait(0.6)
		
		_Effect:PlayEffect(resource.skillAnimation_2, Vector3(0, -2, 900), nil, _Effect:GetUnitLayerOptions(nil))
		_Effect:PlayEffect(resource.skillAnimation_3, Vector3(0, -2, 899.999), nil, _Effect:GetUnitLayerOptions(nil))
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(1.8)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessAirStrike()
		-- 에어 스트라이크 스킬 후처리 대기
		wait(1.56)
	end

	@ExecSpace("ClientOnly")
	method void PreCoreAirStrike(Minion minion)
		-- 에어 스트라이크 피해 적용 전 히트 이펙트 재생
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("AirStrike")
		
		_Effect:PlayHitEffectAttached(resource.hitAnimation_1, minion, Vector3.zero, player, nil)
		_SoundService:PlaySound(resource.hitSound_1, 1)
	end

	@ExecSpace("ClientOnly")
	method void PreProcessArmorCrash()
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("ArmorCrash")
		
		player:Animate("Alert")
		_Effect:PlaySkillEffect(resource.skillAnimation_1, player, Vector3.zero, nil)
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.64)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
			end, 0.88)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessArmorCrash()
		-- 아머 크래시 스킬 후처리 대기
		wait(0.88)
	end

	@ExecSpace("ClientOnly")
	method void PreCoreArmorCrash(Minion minion)
		-- 아머 크래시 피해 적용 전 히트 이펙트 재생
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("ArmorCrash")
		
		_Effect:PlayHitEffectAttached(resource.hitAnimation_1, minion, Vector3.zero, player, nil)
		
		wait(0.56)
	end

	method void PreCoreArrowBlow(Minion minion, Card attacker)
		-- 애로우 블로우 스킬 실행 (플레이어 애니메이션과 투사체 발사)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("ArrowBlow")
		
		player:PlaceFront()
		player:Animate("Shoot2")
		
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.5)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, Vector3.zero, {FadeOut = true})
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
		local toPosition = minion:GetActorPosition()
		_Effect:ThrowEffect(resource.ballAnimation_1, fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
		
		wait(0.5)
		
		_Effect:PlayHitEffectAttached(resource.hitAnimation_1, minion, Vector3.zero, player, nil)
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.75)
	end

	@ExecSpace("ClientOnly")
	method void PreProcessArrowBomb()
		-- 애로우 밤 스킬 전처리 (플레이어 애니메이션과 투사체 발사)
		local player = self.triggerManager.receiver.player
		local minion = self.triggerManager.args[1]
		local resource = self.resourceManager:GetResource("ArrowBomb")
		
		player:PlaceFront()
		player:Animate("Shoot1")
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.5)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, Vector3.zero, {FadeOut = true})
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
		local toPosition = minion:GetActorPosition()
		_Effect:ThrowEffect(resource.ballAnimation_1, fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
		
		wait(0.5)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.75)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessArrowBomb()
		wait(0)
	end

	method void PreCoreArrowBomb(Minion minion, Card attacker)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("ArrowBomb")
		 
		_Effect:PlayHitEffect(_Table:GetRandomElement({resource.hitAnimation_1, resource.hitAnimation_2}), minion, Vector3.zero, player, nil)
		_SoundService:PlaySound(resource.hitSound_1, 1)
	end

	@ExecSpace("ClientOnly")
	method void PreProcessArrowRain()
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("ArrowRain")
		
		player:PlaceFront()
		
		local playerPosition = player.opponent.field.Entity.TransformComponent.WorldPosition:ToVector2() + 0.5 * Vector2.up
		_Tween:MoveTo(player.actor.Entity, playerPosition, 0.25, EaseType.CubicEaseOut, true)
		
		wait(0.25)
		
		player:Animate("Shoot1")
		_SoundService:PlaySound(resource.skillSound_1, 1)
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, 0.001 * Vector3.back, nil)
		
		wait(0.5)
		
		_SoundService:PlaySound(resource.skillSound_2, 1)
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_2, player, Vector3.zero, {FadeOut = true})
		
		wait(0.28)
		
		local zPosition = 900
		local direction = player:GetLookAtDirection()
		_TimerService:SetTimerOnce(function()
				for i = 1, 20 do
					for j = 1, 7 do
						local fromPosition = Vector2(playerPosition.x + _UtilLogic:RandomDouble() * 6 - 3 - direction * 0.85, playerPosition.y + 1 + _UtilLogic:RandomDouble())
						local toPosition = fromPosition + Vector2(direction * 0.85, -2.3)
						_Effect:MoveEffect(resource.extraAnimation_1, fromPosition, toPosition, zPosition, 0.2, EaseType.Linear, _Effect:GetUnitLayerOptions({Alpha = 0.75, FlipX = direction > 0}))
						zPosition -= 0.001
					end
				
					wait(0.05)
				end
			end, 0)
		
		_TimerService:SetTimerOnce(function()
				_Tween:MoveTo(player.actor.Entity, Vector2.zero, 0.75, EaseType.CubicEaseOut, false)
			
				wait(0.75)
			
				player:Animate("Idle")
				player:PlaceBack()
			end, 1.5)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessArrowRain()
		wait(2.25)
	end

	@ExecSpace("ClientOnly")
	method void PreCoreArrowRain(Minion minion)
		local receiver = self.triggerManager.receiver
		local resource = self.resourceManager:GetResource("ArrowRain")
		
		_Effect:PlayHitEffectAttached(resource.hitAnimation_1, minion, Vector3.zero, receiver, nil)
		_SoundService:PlaySound(resource.hitSound_1, 1)
	end

	@ExecSpace("ClientOnly")
	method void PreCoreAssaulter(Minion minion)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("Assaulter")
		
		player:PlaceFront()
		
		local beginPosition = player:GetOffsettedPosition(minion, 1.75 * Vector2.right, false)
		_Tween:MoveTo(player.actor.Entity, beginPosition, 0.25, EaseType.CubicEaseOut, true)
		
		wait(0.25)
		
		local endPosition = player:GetOffsettedPosition(minion, 1.75 * Vector2.left, false)
		player:Animate("Assaulter")
		_Effect:PlaySkillEffect(resource.skillAnimation_1, player, Vector3.zero, nil)
		_Tween:MoveTo(player.actor.Entity, endPosition, 0.05, EaseType.CubicEaseIn, true)
		
		wait(0.05)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_2, player, Vector3.zero, nil)
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_3, player, 0.001 * Vector3.back, nil)
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.6)
		
		_Effect:PlayHitEffect(resource.hitAnimation_1, minion, Vector3.zero, player, nil)
		
		_TimerService:SetTimerOnce(function()
				_Tween:MoveTo(player.actor.Entity, Vector2.zero, 0.5, EaseType.CubicEaseOut, false)
			
				wait(0.5)
			
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.25)
	end

	@ExecSpace("ClientOnly")
	method void PreProcessAthenaPierce()
		wait(0)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessAthenaPierce()
		wait(1)
	end

	@ExecSpace("ClientOnly")
	method void PreProcessAvenger()
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("Avenger")
		
		player:PlaceFront()
		
		local playerPosition = player:GetOffsettedPositionFromPoint(player.opponent.field.Entity.TransformComponent.WorldPosition:ToVector2(), Vector2(4.2, 0), false)
		_Tween:MoveTo(player.actor.Entity, playerPosition, 0.25, EaseType.CubicEaseOut, true)
		
		wait(0.25)
		
		player:Animate("Avenger")
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, Vector3.zero, nil)
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.72)
		
		local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
		local toPosition = player:GetLookAtPosition(Vector2(8, 0), true)
		local angle = -player:GetLookAtDirection() * 720
		_Effect:MoveAndSpinEffect(resource.ballAnimation_1, fromPosition, toPosition, 0, angle, 0.75, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		wait(0.6)
		
		_TimerService:SetTimerOnce(function()
				_Tween:MoveTo(player.actor.Entity, Vector2.zero, 0.75, EaseType.CubicEaseOut, false)
			
				wait(0.75)
			
				player:Animate("Idle")
				player:PlaceBack()
			end, 0)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessAvenger()
