	@ExecSpace("ClientOnly")
	method void PreProcessShockwave()
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("Shockwave")
		
		player:PlaceFront()
		
		local playerPosition = player.opponent.field.Entity.TransformComponent.WorldPosition:ToVector2() + 0.5 * Vector2.up
		_Tween:MoveTo(player.actor.Entity, playerPosition, 0.25, EaseType.CubicEaseOut, true)
		
		wait(0.25)
		
		player:Animate("Assaulter")
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(1.44)
		
		local effectPosition = Vector3(0, 0, 900)
		effectPosition.y = player.opponent.field.Entity.TransformComponent.WorldPosition.y - 0.5
		_TimerService:SetTimerOnce(function()
				for i = 1, 10 do
					for j = 1, 3 do
						effectPosition.x = playerPosition.x + _UtilLogic:RandomDouble() * 8 - 4
						_Effect:PlayEffect(resource.extraAnimation_1, effectPosition, nil, _Effect:GetUnitLayerOptions(nil))
						effectPosition.z -= 0.001
					end
					wait(0.1)
				end
			end, 0)
		
		wait(1)
		
		_TimerService:SetTimerOnce(function()
				_Tween:MoveTo(player.actor.Entity, Vector2.zero, 0.75, EaseType.CubicEaseOut, false)
			
				wait(0.75)
			
				player:Animate("Idle")
				player:PlaceBack()
			end, 1)
	end

