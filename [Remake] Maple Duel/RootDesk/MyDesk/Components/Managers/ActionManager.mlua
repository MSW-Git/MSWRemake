	@ExecSpace("ClientOnly")
	method void PreCoreFireBoar(Minion minion, Minion attacker)
		local receiver = self.triggerManager.receiver
		local resource = self.resourceManager:GetResource("FireBoar")
		
		local offset = receiver.actor.Entity.TransformComponent.Position:ToVector2()
		_Tween:Lerp(receiver.actor.Entity, receiver.anchorEntity, minion.actor.Entity, 0, 1, 0.3, EaseType.CubicEaseIn, offset, nil)
		
		wait(0.2)
		
		_SoundService:PlaySound(resource.skillSound_1, 0.5)
		
		wait(0.1)
		
		_Effect:PlayHitEffect(resource.hitAnimation_1, minion, Vector3.zero, receiver, nil)
		_Tween:Lerp(receiver.actor.Entity, receiver.anchorEntity, minion.actor.Entity, 1, 0, 0.5, EaseType.CubicEaseOut, offset, nil)
	end

