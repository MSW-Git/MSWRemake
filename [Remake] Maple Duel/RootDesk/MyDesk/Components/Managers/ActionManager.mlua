	@ExecSpace("ClientOnly")
	method void PreProcessIceShot()
		local player = self.triggerManager.receiver.player
		local minion = self.triggerManager.args[1]
		local resource = self.resourceManager:GetResource("IceShot")
		
		player:PlaceFront()
		player:Animate("Shoot2")
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, 0.001 * Vector3.back, nil)
		_Effect:PlaySkillEffect(resource.skillAnimation_2, player, Vector3(0, 0.28, -0.002), {FadeOut = true, ScaleOut = true})
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.5)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_3, player, Vector3.zero, {FadeOut = true})
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
		local toPosition = minion:GetActorPosition()
		_Effect:ThrowEffect(resource.ballAnimation_1, fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
		
		wait(0.5)
		
		local position = minion.actor.Entity.TransformComponent.WorldPosition:ToVector2()
		local animationArray = {resource.extraAnimation_1, resource.extraAnimation_2, resource.extraAnimation_3}
		local zPosition = 900
		_TimerService:SetTimerOnce(function()
				for i = 1, 10 do
					for j = 1, 3 do
						fromPosition = Vector2(position.x + _UtilLogic:RandomDouble() * 4 - 1.3, position.y + 0.75 + _UtilLogic:RandomDouble())
						toPosition = fromPosition + Vector2(-1.4, -1.75)
						_Effect:MoveEffect(_Table:GetRandomElement(animationArray), fromPosition, toPosition, zPosition, 0.6, EaseType.Linear, _Effect:GetUnitLayerOptions({Alpha = 0.75}))
						zPosition -= 0.001
					end
				
					wait(0.05)
				end
			end, 0)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.75)
	end

