	@ExecSpace("ClientOnly")
	method void PreCoreDoubleShot(Unit unit, Card attacker)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("DoubleShot")
		
		player:PlaceFront()
		player:Animate("Shoot1")
		
		wait(0.5)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, Vector3.zero, {FadeOut = true})
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		local count = 2
		local interval = 0.075
		local gapY = 0.2
		_TimerService:SetTimerOnce(function()
				for i = 1, count do
					local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
					local toPosition = player:GetOffsettedPosition(unit, Vector2(0, gapY * (0.5 * count + 0.5 - i)), false)
					_Effect:ThrowEffect(resource.ballAnimation_1, fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
				
					wait(interval)
				end
			end, 0)
		
		wait(0.5)
		
		_TimerService:SetTimerOnce(function()
				for i = 1, count do
					_Effect:PlayHitEffect(resource.hitAnimation_1, unit, Vector3(0, gapY * (0.5 * count + 0.5 - i), -0.001 * i), player, nil)
				
					wait(interval)
				end
			end, 0)
		_TimerService:SetTimerOnce(function()
				for i = 2, count do
					wait(interval)
				
					_SoundService:PlaySound(self.resourceManager:GetResource(unit.name).damageSound, 1)
				end
			end, 0)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.75)
	end

