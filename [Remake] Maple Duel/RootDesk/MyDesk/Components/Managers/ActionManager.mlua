	@ExecSpace("ClientOnly")
	method void PreCoreCorkscrewBlow(Minion minion)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("CorkscrewBlow")
		
		player:PlaceFront()
		player:LookLeft()
		local beginPosition = minion.actor.Entity.TransformComponent.WorldPosition:ToVector2() + 1.25 * Vector2.right
		_Tween:MoveTo(player.actor.Entity, beginPosition, 0.25, EaseType.CubicEaseOut, true)
		
		wait(0.25)
		
		player:Animate("Alert")
		_Effect:PlaySkillEffect(resource.skillAnimation_1, player, Vector3.zero, nil)
		
		wait(0.96)
		
		local endPosition = minion.actor.Entity.TransformComponent.WorldPosition:ToVector2() + 0.75 * Vector2.left
		player:Animate("CorkscrewBlow")
		_Tween:MoveTo(player.actor.Entity, endPosition, 0.05, EaseType.CubicEaseIn, true)
		
		wait(0.05)
		
		_Effect:PlaySkillEffect(resource.skillAnimation_2, player, Vector3.zero, nil)
		_Effect:PlayHitEffect(resource.hitAnimation_1, minion, Vector3.zero, player, nil)
		_SoundService:PlaySound(resource.hitSound_1, 1)
		
		_Tween:MoveTo(minion.actor.Entity, 2.5 * Vector2.left, 0.1, EaseType.CubicEaseIn, false)
	end

	@ExecSpace("ClientOnly")
	method void PostCoreCorkscrewBlow(Minion minion)
		local player = self.triggerManager.receiver.player
		
		wait(1)
		
		_Tween:MoveTo(player.actor.Entity, Vector2.zero, 0.5, EaseType.CubicEaseOut, false)
		_Tween:MoveTo(minion.actor.Entity, Vector2.zero, 0.5, EaseType.QuintEaseOut, false)
		
		_TimerService:SetTimerOnce(function()
			player:Animate("Idle")
			player:LookNothing()
			player:PlaceBack()
		end, 0.5)
	end

