	@ExecSpace("ClientOnly")
	method void PreCoreSnatch(Minion minion)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("Snatch")
		
		player:PlaceFront()
		player:LookLeft()
		local beginPosition = minion.actor.Entity.TransformComponent.WorldPosition:ToVector2() + 4.2 * Vector2.right
		_Tween:MoveTo(player.actor.Entity, beginPosition, 0.25, EaseType.CubicEaseOut, true)
		
		wait(0.25)
		
		player:Animate("SwingT2")
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, Vector3.zero, nil)
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.54)
		
		_Effect:PlayHitEffect(resource.hitAnimation_1, minion, Vector3.zero, player, nil)
		_SoundService:PlaySound(resource.hitSound_1, 1)
		minion:PlaceFront()
		_Tween:MoveTo(minion.actor.Entity, 3 * Vector2.right, 0.2, EaseType.Linear, false)
	end

	@ExecSpace("ClientOnly")
	method void PostCoreSnatch(Minion minion)
		local player = self.triggerManager.receiver.player
		
		wait(0.7)
		
		minion:PlaceBack()
		_Tween:MoveTo(player.actor.Entity, Vector2.zero, 0.5, EaseType.CubicEaseOut, false)
		_Tween:MoveTo(minion.actor.Entity, Vector2.zero, 0.5, EaseType.QuintEaseOut, false)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:LookNothing()
				player:PlaceBack()
			end, 0.5)
	end

