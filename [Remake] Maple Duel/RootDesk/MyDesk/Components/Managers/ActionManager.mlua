	method void PreCoreDrain(Unit unit, Card attacker)
		local player = self.triggerManager.receiver.player
		local resource = self.resourceManager:GetResource("Drain")
		
		player:PlaceFront()
		player:Animate("SwingO1")
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_1, player, 0.001 * Vector3.back, nil)
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.45)
		
		_Effect:PlaySkillEffectAttached(resource.skillAnimation_2, player, Vector3.zero, {FadeOut = true})
		_SoundService:PlaySound(resource.skillSound_2, 1)
		
		local fromPosition = player:GetLookAtPosition(Vector2(0.28, 0), true)
		local toPosition = unit:GetActorPosition()
		local ballAnimation
		if attacker.variant == "Default" then
			ballAnimation = resource.ballAnimation_1
		elseif attacker.variant == "SteelyThrowingKnives" then
			ballAnimation = resource.ballAnimation_2
		end
		_Effect:ThrowEffect(ballAnimation, fromPosition, toPosition, 0, 0.5, EaseType.Linear, _Effect:GetUnitLayerOptions(nil))
		
		wait(0.5)
		
		_Effect:PlayHitEffect(resource.hitAnimation_1, unit, Vector3.zero, player, nil)
		
		_TimerService:SetTimerOnce(function()
				player:Animate("Idle")
				player:PlaceBack()
			end, 0.75)
	end

