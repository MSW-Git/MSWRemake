	@ExecSpace("ClientOnly")
	method void PreProcessChiefGraySummon()
		local receiver = self.triggerManager.receiver
		local resource = self.resourceManager:GetResource("ChiefGray")
		
		receiver:Animate("Skill2")
		_SoundService:PlaySound(resource.skillSound_1, 1)
		
		wait(0.6)
		
		local fieldPosition = receiver.player.opponent.field.Entity.TransformComponent.WorldPosition:ToVector2()
		local animationArray = {resource.extraAnimation_1, resource.extraAnimation_2, resource.extraAnimation_3}
		local zPosition = 900
		_TimerService:SetTimerOnce(function()
				for i = 1, 10 do
					for j = 1, 7 do
						local fromPosition = Vector2(fieldPosition.x + _UtilLogic:RandomDouble() * 6 - 2.25, fieldPosition.y + 0.8 + _UtilLogic:RandomDouble())
						local toPosition = fromPosition - Vector2(1.5, 1.8)
						_Effect:MoveEffect(_Table:GetRandomElement(animationArray), fromPosition, toPosition, zPosition, 0.6, EaseType.Linear, _Effect:GetUnitLayerOptions({Alpha = 0.75}))
						zPosition -= 0.001
					end
				
					wait(0.05)
				end
			end, 0)
	end

	@ExecSpace("ClientOnly")
	method void PostProcessChiefGraySummon()
		wait(1)
	end

