@Component
script TargetManager extends Component

	property Duel duel = nil

	property TaskManager taskManager = nil

	method boolean GetCardRequiresTarget(Card card)
		-- 카드 이름에 해당하는 타겟팅 메소드가 존재하는지 확인
		return self[card.name] ~= nil
	end

	@ExecSpace("ServerOnly")
	method table GetCardTargetables(Card card)
		-- 서버에서 카드가 타겟할 수 있는 대상 목록을 계산하여 반환
		local targetableArray = _Util:Call(self, card.name, {card})
		if targetableArray then
			local ret = {}
			for _, targetable in ipairs(targetableArray) do
				if targetable:IsTargetable(card.player) then
					table.insert(ret, targetable)
				end
			end
			return ret
		else
			return {}
		end
	end

	method table ArrowBlow(Card card)
		-- 애로우블로우 스킬의 타겟: 필드의 모든 미니언
		return self.duel:GetMinions(nil)
	end

	method table ArrowBomb(Card card)
		-- 애로우밤 스킬의 타겟: 필드의 모든 미니언
		return self.duel:GetMinions(nil)
	end

	method table Assaulter(Card card)
		-- 어썰터 스킬의 타겟: 필드의 모든 미니언
		return self.duel:GetMinions(nil)
	end

	method table Brandish(Card card)
		-- 브랜디시 스킬의 타겟: 모든 유닛 (플레이어 포함)
		return self.duel:GetUnits()
	end

	method table CorkscrewBlow(Card card)
		-- 코크스크류블로우 스킬의 타겟: 필드의 모든 미니언
		return self.duel:GetMinions(nil)
	end

	method table Disorder(Card card)
		-- 디스오더 스킬의 타겟: 자신의 필드에 있는 미니언들
		return card.player.field:GetMinions(nil)
	end

	method table Doom(Card card)
		-- 둠 스킬의 타겟: 필드의 모든 미니언
		return self.duel:GetMinions(nil)
	end

	method table DoubleShot(Card card)
		-- 더블샷 스킬의 타겟: 모든 유닛 (플레이어 포함)
		return self.duel:GetUnits()
	end

	method table DragonBlood(Card card)
		-- 드래곤블러드 스킬의 타겟: 모든 유닛 (플레이어 포함)
		return self.duel:GetUnits()
	end

	method table Drain(Card card)
		-- 드레인 스킬의 타겟: 모든 유닛 (플레이어 포함)
		return self.duel:GetUnits()
	end

	method table EnergyOrb(Card card)
		-- 에너지오브 스킬의 타겟: 모든 유닛 (플레이어 포함)
		return self.duel:GetUnits()
	end

	method table FinalAttack(Card card)
		return self.duel:GetMinions(self.taskManager.damagedSelector)
	end

	method table FireArrow(Card card)
		return self.duel:GetUnits()
	end

	method table Flamethrower(Card card)
		return self.duel:GetMinions(nil)
	end

	method table HolyShield(Card card)
		return self.duel:GetMinions(nil)
	end

	method table IceShot(Card card)
		return self.duel:GetMinions(nil)
	end

	method table IceSplitter(Card card)
		return self.duel:GetMinions(nil)
	end

	method table IronArrow(Card card)
		return self.duel:GetMinions(nil)
	end

	method table LuckySeven(Card card)
		return self.duel:GetMinions(nil)
	end

	method table NinjaStorm(Card card)
		return self.duel:GetMinions(nil)
	end

	method table PowerKnockBack(Card card)
		return self.duel:GetMinions(nil)
	end

	method table PowerStrike(Card card)
		return self.duel:GetMinions(nil)
	end

	method table Rush(Card card)
		return card.player.opponent:GetUnits()
	end

	method table Sacrifice(Card card)
		return card.player.field:GetMinions(nil)
	end

	method table Snatch(Card card)
		return self.duel:GetMinions(nil)
	end

	method table Snipe(Card card)
		return self.duel:GetMinions(nil)
	end

	method table SomersaultKick(Card card)
		return self.duel:GetMinions(nil)
	end

	method table Steal(Card card)
		return card.player.opponent.field:GetMinions(nil)
	end

	method table Strafe(Card card)
		return self.duel:GetMinions(nil)
	end

	method table Threaten(Card card)
		return self.duel:GetMinions(nil)
	end

	method table ThunderSpear(Card card)
		return self.duel:GetMinions(nil)
	end

end