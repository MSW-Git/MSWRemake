		local sound = self.dataSet:FindRow("name", name):GetItem("skillSound_3")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

	method string GetHitSound_1(string name)
		local sound = self.dataSet:FindRow("name", name):GetItem("hitSound_1")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

	method string GetHitSound_2(string name)
		local sound = self.dataSet:FindRow("name", name):GetItem("hitSound_2")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

