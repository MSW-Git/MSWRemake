		local animation = self.dataSet:FindRow("name", name):GetItem("skillAnimation_2")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetSkillAnimation_3(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("skillAnimation_3")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetBallAnimation_1(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("ballAnimation_1")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetBallAnimation_2(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("ballAnimation_2")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetBallAnimation_3(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("ballAnimation_3")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetHitAnimation_1(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("hitAnimation_1")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetHitAnimation_2(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("hitAnimation_2")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetHitAnimation_3(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("hitAnimation_3")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetExtraAnimation_1(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("extraAnimation_1")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetExtraAnimation_2(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("extraAnimation_2")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetExtraAnimation_3(string name)
		local animation = self.dataSet:FindRow("name", name):GetItem("extraAnimation_3")
		return not _UtilLogic:IsNilorEmptyString(animation) and animation or nil
	end

	method string GetSkillSound_1(string name)
		local sound = self.dataSet:FindRow("name", name):GetItem("skillSound_1")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

	method string GetSkillSound_2(string name)
		local sound = self.dataSet:FindRow("name", name):GetItem("skillSound_2")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

