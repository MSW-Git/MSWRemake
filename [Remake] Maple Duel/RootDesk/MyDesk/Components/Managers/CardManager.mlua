		local sound = self.dataSet:FindRow("name", name):GetItem("extraSound_3")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

	method table GetAllCardNames()
		return self.allCardNameArray
	end

	method table GetCardNames()
		return self.cardNameArray
	end

	method table GetMinionNames()
		return self.minionNameArray
	end

	method table GetSkillNames()
		return self.skillNameArray
	end

	method table GetCardNamesByTag(string tag)
		return self.tagCardNameTable[tag]
	end

	method table GetMinionNamesByTag(string tag)
		return self.tagMinionNameTable[tag]
	end

	method table GetSkillNamesByTag(string tag)
		return self.tagSkillNameTable[tag]
	end

	method table GetCardNamesByCost(integer cost)
		return self.costCardNameTable[cost]
	end

	method table GetMinionNamesByCost(integer cost)
		return self.costMinionNameTable[cost]
	end

	method table GetSkillNamesByCost(integer cost)
		return self.costSkillNameTable[cost]
	end

	method table GetCardNamesByClass(string class)
		return self.classCardNameTable[class]
	end

	method table GetMinionNamesByClass(string class)
		return self.classMinionNameTable[class]
	end

	method table GetSkillNamesByClass(string class)
		return self.classSkillNameTable[class]
	end

	method table GetInfosByClass(string class)
		return self.classInfoTable[class]
	end

	method table GetCompleteCollection()
		local cardTable = {}
		for _, info in ipairs(self.infoArray) do
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			cardTable[name] = cardTable[name] or {}
			cardTable[name][variant] = cardTable[name][variant] or {}
			cardTable[name][variant][quality] = 2
		end
		
		return cardTable
	end

	method table GetRandomCollection()
		local cardTable = {}
		for _, info in ipairs(_Table:GetRandomElements(self.infoArray, 100)) do
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			cardTable[name] = cardTable[name] or {}
			cardTable[name][variant] = cardTable[name][variant] or {}
			cardTable[name][variant][quality] = _UtilLogic:RandomIntegerRange(1, 3)
		end
		
		return cardTable
	end

	method table GetStarterCollection()
		local cardTable = {}
		for _, name in ipairs(self.cardNameArray) do
			if self:GetRarity(name) == "Normal" then
				cardTable[name] = {
					Default = {
						Silver = 2,
					}
				}
			end
		end
		
		return cardTable
	end

	method table GetInfos()
		return self.infoArray
	end

	method table ToInfoArray(table cardTable)
		local infoArray = {}
		for _, info in ipairs(self.infoArray) do
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			if cardTable == nil or cardTable[name] == nil or cardTable[name][variant] == nil or cardTable[name][variant][quality] == nil then
				continue
			end
			
			local count = cardTable[name][variant][quality]
			for i = 1, count do
				table.insert(infoArray, {name = name, variant = variant, quality = quality})
			end
		end
		
		return infoArray
	end

	method table ToCardTable(table infoArray)
		local cardTable = {}
		for _, info in ipairs(infoArray) do
			local name = info.name
			local variant = info.variant
			local quality = info.quality
			
			cardTable[name] = cardTable[name] or {}
			cardTable[name][variant] = cardTable[name][variant] or {}
			cardTable[name][variant][quality] = cardTable[name][variant][quality] or 0
			cardTable[name][variant][quality] += 1
		end
		
		return cardTable
	end

	method table GetCardNamesByThemeAndRarity(string theme, string rarity)
		return self.themeRarityTable[theme][rarity]
	end

	method integer GetSellPrice(string rarity)
		if rarity == "Rare" then
			return 100
		elseif rarity == "Epic" then
			return 200
		elseif rarity == "Unique" then
			return 500
		elseif rarity == "Legendary" then
			return 1000
		end
	end

end