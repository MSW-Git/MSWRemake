		local sound = self.dataSet:FindRow("name", name):GetItem("hitSound_3")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

	method string GetExtraSound_1(string name)
		local sound = self.dataSet:FindRow("name", name):GetItem("extraSound_1")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

	method string GetExtraSound_2(string name)
		local sound = self.dataSet:FindRow("name", name):GetItem("extraSound_2")
		return not _UtilLogic:IsNilorEmptyString(sound) and sound or nil
	end

