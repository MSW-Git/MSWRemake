@Component
script MainCamera extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 메인 카메라 설정 및 화면 비율에 맞는 줌 적용
		local cameraComponent = self.Entity.CameraComponent
		
		_CameraService.TransitionBlendTime = 0
		_CameraService.TransitionBlendType = CameraBlendType.Cut
		_CameraService:SwitchCameraTo(cameraComponent)
		
		cameraComponent.ZoomRatio = _Screen:GetZoomRatio()
	end

end