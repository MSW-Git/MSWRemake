@Component
script Integer extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property number positionGapX = 1.25

	property string sortingLayer = ""

	property integer orderInLayer = 0

	property Vector2 digitScale = Vector2(0,0)

	property integer integer = nil

	property table digitEntityArray = {}

	property integer digitsCount = 0

	@ExecSpace("ClientOnly")
	method void SetInteger(integer integer)
		-- 정수 값을 설정하고 숫자 스프라이트로 표시
		if self.integer == integer then
			return
		end
		
		self.integer = integer
		local digitArray = self:GetDigits(integer)
		self:PlaceDigits(digitArray)
	end

	@ExecSpace("ClientOnly")
	method void SetPositiveInteger(integer integer)
		-- 양수 값을 설정하고 + 기호와 함께 표시
		if self.integer == integer then
			return
		end
		
		self.integer = integer
		local digitArray = self:GetDigits(integer)
		table.insert(digitArray, 12)
		self:PlaceDigits(digitArray)
	end

	@ExecSpace("ClientOnly")
	method void Clear()
		-- 모든 숫자 스프라이트를 제거하고 초기화
		self.integer = nil
		self.digitsCount = 0
		for _, entity in ipairs(self.digitEntityArray) do
			entity.SpriteRendererComponent.Color = Color.white
			entity.SpriteRendererComponent.SpriteRUID = ""
			entity.Visible = false
			entity:Destroy()
		end
		table.clear(self.digitEntityArray)
	end

	@ExecSpace("ClientOnly")
	method void SetColor(Color color)
		-- 모든 숫자 스프라이트의 색상을 변경
		for _, entity in ipairs(self.digitEntityArray) do
			entity.SpriteRendererComponent.Color = color
		end
	end

	@ExecSpace("ClientOnly")
	method void SetAlpha(number alpha)
		-- 모든 숫자 스프라이트의 투명도를 변경
		for _, entity in ipairs(self.digitEntityArray) do
			entity.SpriteRendererComponent.Color.a = alpha
		end
	end

	@ExecSpace("ClientOnly")
	method table GetDigits(integer integer)
		-- 정수를 개별 자릿수로 분리하여 배열로 반환
		local isNegative = false
		local digitArray = {}
		if integer == 0 then
			table.insert(digitArray, 1)
		elseif integer < 0 then
			isNegative = true
		end
		integer = math.abs(integer)
		while integer > 0 do
			table.insert(digitArray, math.fmod(integer, 10) + 1)
			integer = math.floor(integer * 0.1)
		end
		if isNegative then
			table.insert(digitArray, 11)
		end
		
		return digitArray
	end

	@ExecSpace("ClientOnly")
	method void PlaceDigits(table digitArray)
		-- 숫자 스프라이트들을 화면에 배치하고 표시
		local count = #digitArray
		local positionGapX = self.positionGapX * self.digitScale.x
		local positionX = positionGapX * (count - 1) * 0.5
		local digitSpriteArray = self.resourceManager:GetResource("Digit")
		for i = 1, count do
			if not self.digitEntityArray[i] then
				self.digitEntityArray[i] 
					= _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Digit"), "Digit", Vector3.zero, self.Entity)
			end
			local transform = self.digitEntityArray[i].TransformComponent
			transform.Position = Vector3(positionX, 0, i * -0.001)
			transform.Scale.x = self.digitScale.x
			transform.Scale.y = self.digitScale.y
			positionX = positionX - positionGapX
			local spriteRenderer = self.digitEntityArray[i].SpriteRendererComponent
			spriteRenderer.SortingLayer = self.sortingLayer
			spriteRenderer.OrderInLayer = self.orderInLayer
			spriteRenderer.SpriteRUID = digitSpriteArray[digitArray[i]]
			self.digitEntityArray[i].Visible = true
		end
		for i = count + 1, #self.digitEntityArray do 
			self.digitEntityArray[i].Visible = false
		end
		
		self.digitsCount = count
	end

end