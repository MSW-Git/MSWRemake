@Component
script GuideModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property ButtonComponent guideButton = nil

	property Entity fadeEntity = nil

	property Entity panelEntity = nil

	property ButtonComponent xButton = nil

	property ButtonComponent controlButton = nil

	property ButtonComponent howButton = nil

	property ControlMenu controlMenu = nil

	property HowMenu howMenu = nil

	property boolean isOpen = false

	property string mode = ""

	property any panelTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 가이드 모듈 초기화 시 가이드, X, 컨트롤, How 버튼 이벤트들을 연결
		self.guideButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self:Open()
		end)
		
		self.xButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			self:Close()
		end)
		
		self.controlButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self:SetMode("Control")
		end)
		
		self.howButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self:SetMode("How")
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 가이드 모듈을 열고 컨트롤 모드로 설정
		self.isOpen = true
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = true
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.panelEntity, Vector2.one, 0.175, EaseType.Linear)
		
		self:SetMode("Control")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 가이드 모듈을 닫고 모든 메뉴를 숨김
		self.isOpen = false
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = false
		
		self.controlMenu:Close()
		self.howMenu:Close()
		
		local panelTransform = self.panelEntity.TransformComponent
		panelTransform.Scale.x = 0
		panelTransform.Scale.y = 0
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		
		self.mode = ""
	end

	@ExecSpace("ClientOnly")
	method void SetMode(string mode)
		-- 가이드 모드를 설정하고 컨트롤 또는 How 모드에 따라 UI를 전환
		if self.mode == mode then
			return
		end
		self.mode = mode
		
		local resource = self.resourceManager:GetResource("GuideModule")
		if self.mode == "Control" then
			self.controlButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			self.howButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			self.controlMenu:Open()
			self.howMenu:Close()
		elseif self.mode == "How" then
			self.controlButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			self.howButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			self.controlMenu:Close()
			self.howMenu:Open()
		end
	end

	@ExecSpace("ClientOnly")
	method void SetGuideButtonEnable(boolean enable)
		-- 가이드 버튼의 활성화 상태를 설정
		self.guideButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void SetPanelButtonsEnable(boolean enable)
		-- 패널 내 모든 버튼들의 활성화 상태를 설정
		self.xButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.controlButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.howButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		
		self.controlMenu:SetButtonsEnable(enable)
		self.howMenu:SetButtonsEnable(enable)
	end

end