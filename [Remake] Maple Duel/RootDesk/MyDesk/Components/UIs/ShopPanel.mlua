@Component
script ShopPanel extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property Entity fadeEntity = nil

	property BuyPanel buyPanel = nil

	property ButtonComponent cardPackButton = nil

	property Entity cardPackContentEntity = nil

	property ButtonComponent classicButton = nil

	property ButtonComponent nautilusButton = nil

	property ButtonComponent normalEpicButton = nil

	property ButtonComponent normalUniqueButton = nil

	property ButtonComponent normalLegendaryButton = nil

	property ButtonComponent goldEpicButton = nil

	property ButtonComponent goldUniqueButton = nil

	property ButtonComponent goldLegendaryButton = nil

	property SpriteRendererComponent normalEpicImage = nil

	property SpriteRendererComponent normalUniqueImage = nil

	property SpriteRendererComponent normalLegendaryImage = nil

	property SpriteRendererComponent goldEpicImage = nil

	property SpriteRendererComponent goldUniqueImage = nil

	property SpriteRendererComponent goldLegendaryImage = nil

	property string leftTabMode = ""

	property string topTabMode = ""

	property string theme = ""

	property any panelTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 상점 패널 초기화 및 이벤트 연결
		self.cardPackButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:SetLeftTabMode("CardPack")
		end)
		
		self.classicButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:SetTopTabMode("Classic")
		end)
		
		self.nautilusButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:SetTopTabMode("Nautilus")
		end)
		
		self.normalEpicButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "Epic")
		end)
		
		self.normalEpicImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "Epic")
		end)
		
		self.normalUniqueButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "Unique")
		end)
		
		self.normalUniqueImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "Unique")
		end)
		
		self.normalLegendaryButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "Legendary")
		end)
		
		self.normalLegendaryImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "Legendary")
		end)
		
		self.goldEpicButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "GoldEpic")
		end)
		
		self.goldEpicImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "GoldEpic")
		end)
		
		self.goldUniqueButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "GoldUnique")
		end)
		
		self.goldUniqueImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "GoldUnique")
		end)
		
		self.goldLegendaryButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "GoldLegendary")
		end)
		
		self.goldLegendaryImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.buyPanel:Open(self.theme .. "GoldLegendary")
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 상점 패널 열기
		self.fadeEntity.Enable = true
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.Entity, Vector2.one, 0.175, EaseType.Linear)
		
		self:SetLeftTabMode("CardPack")
		self:SetTopTabMode("Classic")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 상점 패널 닫기
		self.fadeEntity.Enable = false
		
		local transform = self.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		
		self.leftTabMode = ""
		self.topTabMode = ""
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 상점 패널 버튼들의 활성화 상태 설정
		self.cardPackButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.classicButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.nautilusButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.normalEpicButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.normalUniqueButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.normalLegendaryButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.goldEpicButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.goldUniqueButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.goldLegendaryButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void SetLeftTabMode(string leftTabMode)
		-- 왼쪽 탭 모드 설정
		if self.leftTabMode == leftTabMode then
			return
		end
		self.leftTabMode = leftTabMode
		
		local resource = self.resourceManager:GetResource("ShopModule")
		if leftTabMode == "CardPack" then
			self.cardPackContentEntity.Enable = true
			
			self.cardPackButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.leftTabSelectedMode
		end
	end

	@ExecSpace("ClientOnly")
	method void SetTopTabMode(string topTabMode)
		-- 상단 탭 모드 설정
		if self.topTabMode == topTabMode then
			return
		end
		self.topTabMode = topTabMode
		
		local resource = self.resourceManager:GetResource("ShopModule")
		local cardPackResource = self.resourceManager:GetResource("CardPack")
		if topTabMode == "Classic" then
			self.classicButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.topTabSelectedMode
			self.nautilusButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.topTabUnselectedMode
			
			self.theme = "Classic"
		elseif topTabMode == "Nautilus" then
			self.classicButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.topTabUnselectedMode
			self.nautilusButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.topTabSelectedMode
			
			self.theme = "Nautilus"
		end
		
		self.normalEpicImage.SpriteRUID = cardPackResource[self.theme .. "Epic"]
		self.normalUniqueImage.SpriteRUID = cardPackResource[self.theme .. "Unique"]
		self.normalLegendaryImage.SpriteRUID = cardPackResource[self.theme .. "Legendary"]
		self.goldEpicImage.SpriteRUID = cardPackResource[self.theme .. "GoldEpic"]
		self.goldUniqueImage.SpriteRUID = cardPackResource[self.theme .. "GoldUnique"]
		self.goldLegendaryImage.SpriteRUID = cardPackResource[self.theme .. "GoldLegendary"]
	end

end