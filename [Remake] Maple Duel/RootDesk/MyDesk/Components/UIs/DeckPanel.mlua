@Component
script DeckPanel extends Component

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity warriorDeckEntity = nil

	property Entity magicianDeckEntity = nil

	property Entity bowmanDeckEntity = nil

	property Entity thiefDeckEntity = nil

	property Entity pirateDeckEntity = nil

	property DeckMenu deckMenu = nil

	property any panelTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 덱 패널 초기화 시 덱 메뉴를 생성하고 각 직업별 덱 생성 터치 이벤트를 연결
		self.deckMenu = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("DeckMenu"), "DeckMenu", Vector3(0, 1.65, 0), self.Entity).DeckMenu
		
		local character = _UserService.LocalPlayer.Character
		self.warriorDeckEntity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			if #character.deckArray >= character.maxDeckCount then
				self.uiManager.PopupModule:Open(_LocalizationService:GetText("MaxDeckCount"), true, nil, nil)
			else
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckCreateDeck", _LocalizationService:GetText("Warrior")), false, function()
					_Server:Request(character, "CreateDeck", {"Warrior", _LocalizationService.CurrentLocaleId})
				end, nil)
			end
		end)
		self.magicianDeckEntity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			if #character.deckArray >= character.maxDeckCount then
				self.uiManager.PopupModule:Open(_LocalizationService:GetText("MaxDeckCount"), true, nil, nil)
			else
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckCreateDeck", _LocalizationService:GetText("Magician")), false, function()
					_Server:Request(character, "CreateDeck", {"Magician", _LocalizationService.CurrentLocaleId})
				end, nil)
			end
		end)
		self.bowmanDeckEntity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			if #character.deckArray >= character.maxDeckCount then
				self.uiManager.PopupModule:Open(_LocalizationService:GetText("MaxDeckCount"), true, nil, nil)
			else
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckCreateDeck", _LocalizationService:GetText("Bowman")), false, function()
					_Server:Request(character, "CreateDeck", {"Bowman", _LocalizationService.CurrentLocaleId})
				end, nil)
			end
		end)
		self.thiefDeckEntity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			if #character.deckArray >= character.maxDeckCount then
				self.uiManager.PopupModule:Open(_LocalizationService:GetText("MaxDeckCount"), true, nil, nil)
			else
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckCreateDeck", _LocalizationService:GetText("Thief")), false, function()
					_Server:Request(character, "CreateDeck", {"Thief", _LocalizationService.CurrentLocaleId})
				end, nil)
			end
		end)
		self.pirateDeckEntity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			if #character.deckArray >= character.maxDeckCount then
				self.uiManager.PopupModule:Open(_LocalizationService:GetText("MaxDeckCount"), true, nil, nil)
			else
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckCreateDeck", _LocalizationService:GetText("Pirate")), false, function()
					_Server:Request(character, "CreateDeck", {"Pirate", _LocalizationService.CurrentLocaleId})
				end, nil)
			end
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 덱 패널을 열고 화면에 표시하는 애니메이션을 실행
		local transform = self.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.Entity, Vector2.one, 0.175, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 덱 패널을 닫고 화면에서 숨김
		local transform = self.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 덱 패널의 버튼들의 활성화 상태를 설정 (현재 구현 없음)
		
	end

end