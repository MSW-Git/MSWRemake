@Component
script CardModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity fadeEntity = nil

	property CardPanel cardPanel = nil

	property DeckPanel deckPanel = nil

	property DeckEditPanel deckEditPanel = nil

	property ButtonComponent xButton = nil

	property boolean isOpen = false

	property boolean isDeckEditMode = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 카드 모듈 초기화 시 X버튼 이벤트와 덱 관련 이벤트들을 연결
		local character = _UserService.LocalPlayer.Character
		
		self.xButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			if self.isDeckEditMode then
				if self.deckEditPanel.isDirty then
					self.uiManager.PopupModule:Open("DoubleCheckSaveDeck", false, function() self.deckEditPanel:RequestSaveDeck() end, function() self:Close() end)
				else
					_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
					
					self:Close()
				end
			else
				_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
				
				self:Close()
			end
		end)
		
		character.Entity:ConnectEvent(CreateDeck, function()
			self:SetMode(true)
		end)
		
		character.Entity:ConnectEvent(FinishDeck, function()
			self:SetMode(false)
		end)
		
		character.Entity:ConnectEvent(SaveDeck, function()
			self:Close()
		end)
		
		character.Entity:ConnectEvent(DeleteDeck, function()
			self:SetMode(false)
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open(boolean isDeckEditMode)
		-- 카드 모듈을 열고 덱 편집 모드 여부에 따라 UI를 설정
		self.isOpen = true
		self.uiManager:UpdateButtons()
		self.uiManager:UpdatePlayerController()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = true
		
		self.cardPanel:Open()
		self:SetMode(isDeckEditMode)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 카드 모듈을 닫고 모든 패널들을 초기화
		self.isOpen = false
		self.uiManager:UpdateButtons()
		self.uiManager:UpdatePlayerController()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = false
		
		self.isDeckEditMode = false
		self.cardPanel:Close()
		self.deckPanel:Close()
		self.deckEditPanel:Close()
	end

	@ExecSpace("ClientOnly")
	method void SetMode(boolean isDeckEditMode)
		-- 덱 편집 모드 설정에 따라 적절한 패널을 표시하고 카드 패널 모드를 변경
		self.isDeckEditMode = isDeckEditMode
		
		if isDeckEditMode then
			self.deckPanel:Close()
			self.deckEditPanel:Open()
		else
			self.deckPanel:Open()
			self.deckEditPanel:Close()
		end
		
		self.cardPanel:SetMode(isDeckEditMode)
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 카드 모듈의 모든 패널과 버튼들의 활성화 상태를 설정
		self.cardPanel:SetButtonsEnable(enable)
		self.deckPanel:SetButtonsEnable(enable)
		self.deckEditPanel:SetButtonsEnable(enable)
		
		self.xButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

end