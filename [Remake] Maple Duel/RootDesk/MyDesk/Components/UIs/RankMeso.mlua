@Component
script RankMeso extends Component

	property TextComponent titleText = nil

	property TextComponent deltaText = nil

	@ExecSpace("ClientOnly")
	method void Initialize(integer delta)
		-- 랭크 메소 보상 정보 초기화
		local character = _UserService.LocalPlayer.Character
		self.titleText.Text = character:GetRankName() .. " !"
		local colorTable = {
			Iron = Color.FromHexCode("#BA7E06"), 
			Bronze = Color.FromHexCode("#FEA537"),
			Silver = Color.FromHexCode("#BFBFBF"), 
			Gold = Color.FromHexCode("#FFD400"), 
			Platinum = Color.FromHexCode("#03FFAF"), 
			Master = Color.FromHexCode("#D95AFF"), 
			Legend = Color.FromHexCode("#FF3E3E"), 
		}
		self.titleText.FontColor = colorTable[character:GetMajorRank()]
		
		self.deltaText.Text = string.format("+%d", delta)
	end

end