@Component
script RewardSlot extends Component

	property RankManager rankManager = "84709e8b-278d-431c-bc06-a7fe8874ca23"

	property TextComponent titleText = nil

	property TextComponent progressText = nil

	property TextComponent mesoText = nil

	property Entity fadeEntity = nil

	property Entity checkEntity = nil

	property string type = ""

	property integer limit = 0

	property integer meso = 0

	@ExecSpace("ClientOnly")
	method void SetDailyReward()
		-- 일일 보상 정보 설정
		self.fadeEntity.Enable = false
		self.checkEntity.Enable = false
		
		local character = _UserService.LocalPlayer.Character
		
		if self.type == "RankedPlay" then
			local count = character:GetDailyRankedPlayCount()
			if count >= self.limit then
				self.fadeEntity.Enable = true
				self.checkEntity.Enable = true
			end
			
			self.titleText.Text = _LocalizationService:GetTextFormat("RankedPlayReward", self.limit)
			self.progressText.Text = string.format("%d/%d", math.min(count, self.limit), self.limit)
			self.mesoText.Text = tostring(self.meso)
		elseif self.type == "RankedWin" then
			local count = character:GetDailyRankedWinMeso()
			if count >= self.limit then
				self.fadeEntity.Enable = true
				self.checkEntity.Enable = true
			end
			
			self.titleText.Text = _LocalizationService:GetText("RankedWinReward")
			self.progressText.Text = string.format("%d/%d", math.min(count, self.limit), self.limit)
		elseif self.type == "Play" then
			local count = character:GetDailyPlayMeso()
			if count >= self.limit then
				self.fadeEntity.Enable = true
				self.checkEntity.Enable = true
			end
			
			self.titleText.Text = _LocalizationService:GetText("PlayReward")
			self.progressText.Text = string.format("%d/%d", math.min(count, self.limit), self.limit)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetRankReward(integer rankPoint, integer meso)
		-- 랭크 달성 보상 정보 설정
		self.fadeEntity.Enable = false
		self.checkEntity.Enable = false
		
		local character = _UserService.LocalPlayer.Character
		
		if character.topRankPoint >= rankPoint then
			self.fadeEntity.Enable = true
			self.checkEntity.Enable = true
		end
		
		local colorTable = {
			Iron = "#ba7e06", 
			Bronze = "#fea537",
			Silver = "#bfbfbf", 
			Gold = "#ffd400", 
			Platinum = "#03ffaf", 
			Master = "#d95aff", 
			Legend = "#ff3e3e", 
		}
		self.titleText.Text = _LocalizationService:GetTextFormat("Achieve", colorTable[self.rankManager:GetMajorRank(rankPoint, 0)], self.rankManager:GetRankName(rankPoint, 0))
		
		self.mesoText.Text = tostring(meso)
	end

end