@Component
script BuyPanel extends Component

	property CardPackManager cardPackManager = "fe274865-e1d4-4ece-a185-40d5bf7865e3"

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity fadeEntity = nil

	property ButtonComponent xButton = nil

	property ButtonComponent singleButton = nil

	property ButtonComponent multipleButton = nil

	property TextComponent cardPackNameText = nil

	property TextComponent cardPackInfoText = nil

	property Entity cardPackEntity = nil

	property Entity cardPackSingleEntity = nil

	property Entity cardPackMultipleEntity = nil

	property Entity buyEntity = nil

	property ButtonComponent buyButton = nil

	property SpriteRendererComponent buyIcon = nil

	property TextComponent buyText = nil

	property ButtonComponent probabilityInfoButton = nil

	property any panelTweener = nil

	property boolean isOpen = false

	property string cardPackName = ""

	property string mode = ""

	property any buyTweener = nil

	property any cardPackTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 구매 패널 초기화 시 버튼 이벤트들을 연결하고 카드팩 구매 및 확률 정보 처리
		self.xButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			self:Close()
		end)
		
		self.singleButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:ShowCardPack(self.cardPackName, "Single")
		end)
		
		self.multipleButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:ShowCardPack(self.cardPackName, "Multiple")
		end)
		
		local character = _UserService.LocalPlayer.Character
		
		self.buyButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			local currency = self.cardPackManager:GetCurrency(self.cardPackName)
			
			if self.mode == "Single" then
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckBuySingleCardPack" .. currency, _LocalizationService:GetText(self.cardPackName)), false, function()
					if self.uiManager.CardPackModule.isOpen then
						return
					end
					
					if currency == "Meso" then
						_Server:Request(character, "BuySingleCardPack", {self.cardPackName})
					elseif currency == "WorldCoin" then
						_Shop:PromptSinglePurchase(self.cardPackName)
					end
				end, nil)
			elseif self.mode == "Multiple" then
				self.uiManager.PopupModule:Open(_LocalizationService:GetTextFormat("DoubleCheckBuyMultipleCardPacks" .. currency, _LocalizationService:GetText(self.cardPackName)), false, function()
					if self.uiManager.CardPackModule.isOpen then
						return
					end
					
					if currency == "Meso" then
						_Server:Request(character, "BuyMultipleCardPacks", {self.cardPackName})
					elseif currency == "WorldCoin" then
						_Shop:PromptMultiplePurchase(self.cardPackName)
					end
				end, nil)
			end
			if currency == "WorldCoin" then
				self.uiManager.PopupModule.refundInfoButton.Entity.SpriteGUIRendererComponent.RaycastTarget = true
			end
		end)
		
		self.probabilityInfoButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open(string cardPackName)
		-- 구매 패널을 열고 지정된 카드팩의 정보를 표시
		self.isOpen = true
		self.uiManager:UpdateButtons()
		
		self.fadeEntity.Enable = true
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.Entity, Vector2.one, 0.175, EaseType.Linear)
		
		self:ShowCardPack(cardPackName, "Single")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 구매 패널을 닫고 화면에서 숨김
		self.isOpen = false
		self.uiManager:UpdateButtons()
		
		self.fadeEntity.Enable = false
		
		local transform = self.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 구매 패널의 모든 버튼들의 활성화 상태를 설정
		self.xButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.singleButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.multipleButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.buyButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.probabilityInfoButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void ShowCardPack(string cardPackName, string mode)
		-- 지정된 카드팩과 모드에 따라 UI를 업데이트하고 가격 정보를 표시
		self.cardPackName = cardPackName
		self.mode = mode
		
		local buyTransform = self.buyEntity.TransformComponent
		buyTransform.Scale.x = 0
		buyTransform.Scale.y = 0
		if self.buyTweener then
			self.buyTweener:Destroy()
		end
		self.buyTweener = _Tween:ScaleTo(self.buyEntity, Vector2.one, 0.125, EaseType.Linear)
		
		local cardPackTransform = self.cardPackEntity.TransformComponent
		cardPackTransform.Scale.x = 0
		cardPackTransform.Scale.y = 0
		if self.cardPackTweener then
			self.cardPackTweener:Destroy()
		end
		self.cardPackTweener = _Tween:ScaleTo(self.cardPackEntity, Vector2.one, 0.125, EaseType.Linear)
		
		local resource = self.resourceManager:GetResource("ShopModule")
		local currency = self.cardPackManager:GetCurrency(cardPackName)
		local price
		local count
		if self.mode == "Single" then
			self.singleButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.leftTabSelectedMode
			self.multipleButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.leftTabUnselectedMode
			
			price = self.cardPackManager:GetSinglePrice(cardPackName)
			count = 1
			self.cardPackSingleEntity.Enable = true
			self.cardPackMultipleEntity.Enable = false
		elseif self.mode == "Multiple" then
			self.singleButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.leftTabUnselectedMode
			self.multipleButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.leftTabSelectedMode
			
			price = self.cardPackManager:GetMultiplePrice(cardPackName)
			count = 5
			self.cardPackSingleEntity.Enable = false
			self.cardPackMultipleEntity.Enable = true
		end
		self.cardPackNameText.Text = _LocalizationService:GetText(cardPackName) 
		self.cardPackInfoText.Text = _LocalizationService:GetText(cardPackName .. "Info")
		
		local icon = self.resourceManager:GetResource("ShopModule")[currency]
		self.buyIcon.SpriteRUID = icon
		self.buyText.Text = string.format("%d (%d %s)", price, count, _LocalizationService:GetText("P"))
		
		---@type table
		local rendererArray = self.cardPackEntity:GetChildComponentsByTypeName("SpriteRendererComponent", true)
		for _, renderer in ipairs(rendererArray) do
			renderer.SpriteRUID = self.resourceManager:GetResource("CardPack")[cardPackName]
		end
	end

end