@Component
script PlayerModule extends Component

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity menuEntity = nil

	property ButtonComponent surrenderButton = nil

	property boolean isOpen = false

	property any menuTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 플레이어 모듈 초기화 시 항복 버튼 클릭 이벤트를 연결하고 듀얼 종료 처리
		self.surrenderButton.Entity:ConnectEvent(ButtonClickEvent, function()
			self.uiManager.PopupModule:Open("DoubleCheckSurrender", false, function()
				local player =_UserService.LocalPlayer.Character.player
				if isvalid(player) then
					local commandManager = player.commandManager
					commandManager:RunCommand("EndDuel", {player.opponent}, {})
				end
			end, nil)
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 플레이어 메뉴를 열고 화면에 표시하는 애니메이션을 실행
		self.isOpen = true
		self.uiManager:UpdateButtons()
		
		if self.menuTweener then
			self.menuTweener:Destroy()
		end
		self.menuTweener = _Tween:ScaleTo(self.menuEntity, Vector2.one, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 플레이어 메뉴를 닫고 화면에서 숨김
		self.isOpen = false
		self.uiManager:UpdateButtons()
		
		local menulTransform = self.menuEntity.TransformComponent
		menulTransform.Scale.x = 0
		menulTransform.Scale.y = 0
		if self.menuTweener then
			self.menuTweener:Destroy()
		end
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 플레이어 모듈의 버튼들의 활성화 상태를 설정
		self.surrenderButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

end