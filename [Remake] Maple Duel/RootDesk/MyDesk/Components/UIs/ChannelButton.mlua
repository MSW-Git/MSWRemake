@Component
script ChannelButton extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property ButtonComponent button = nil

	property SpriteGUIRendererComponent icon = nil

	property TextComponent channelNameText = nil

	property table channel = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 채널 버튼 초기화 시 스케일을 0으로 설정하고 클릭 이벤트를 연결
		local transform = self.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		
		self.button.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			if self.channel.key ~= _WorldInstanceService.WorldInstanceId and self.channel.currentUserCount < self.channel.maxUserCount then
				_Server:Request(self.Entity.CurrentMap.Home, "EnterChannel", {_UserService.LocalPlayer.Character, self.channel})
			end
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetChannel(table channel)
		-- 채널 정보를 설정하고 현재 채널 상태에 따라 UI 표시를 업데이트
		self.channel = channel
		self.channelNameText.Text = string.format("%s %d", _LocalizationService:GetText("Channel"), channel.id)
		
		local resource = self.resourceManager:GetResource("ChannelButton")
		local image
		if channel.key == _WorldInstanceService.WorldInstanceId then
			image = resource.thisChannel
			self.button.Transition = TransitionType.None
		else
			image = resource.otherChannel
			self.button.Transition = TransitionType.SpriteSwap
		end
		self.button.Entity.SpriteGUIRendererComponent.ImageRUID = image
		
		local icon
		if channel.currentUserCount == channel.maxUserCount then
			icon = resource.redCircleIcon
		elseif channel.currentUserCount >= channel.maxUserCount * 0.75 then
			icon = resource.orangeCircleIcon
		else
			icon = resource.greenCircleIcon
		end
		self.icon.ImageRUID = icon
	end

end