@Component
script EventModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity fadeEntity = nil

	property Entity panelEntity = nil

	property ButtonComponent xButton = nil

	property Entity eventButtonEntity = nil

	property ButtonComponent eventButton = nil

	property ButtonComponent specialEventButton = nil

	property ButtonComponent hotTimeEventButton = nil

	property ButtonComponent originalWorldEventButton = nil

	property Entity specialEventContentEntity = nil

	property Entity hotTimeEventContentEntity = nil

	property Entity originalWorldEventContentEntity = nil

	property TextComponent specialEventEndTimeText = nil

	property TextComponent specialEventUpdateTimeText = nil

	property ButtonComponent noticeButton = nil

	property boolean isOpen = false

	property string mode = ""

	property any panelTweener = nil

	property any tweener = nil

	property integer specialEventTimer = 0

	property table attendanceSlotArray = {}

	property boolean isSpecialEventPeriod = false

	property boolean isOriginalWorldEventWinner = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 이벤트 모듈 초기화 시 출석 슬롯들과 버튼 이벤트들을 연결하고 이벤트 타이머를 설정
		local character = _UserService.LocalPlayer.Character
		
		self.attendanceSlotArray = self.Entity:GetChildComponentsByTypeName("AttendanceSlot", true)
		for i, attendanceSlot in ipairs(self.attendanceSlotArray) do
			attendanceSlot.receiveButton.Entity:ConnectEvent(ButtonClickEvent, function()
				if _Server:IsRequesting() then
					return
				end
				
				_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
				
				_Server:Request(character, "ReceiveCardPacksBySpecialEvent", {i})
			end)
		end
		
		self.eventButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if character.isMatching or isvalid(character.player) then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self:Open()
		end)
		
		self.xButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			self:Close()
		end)
		
		self.specialEventButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:SetMode("SpecialEvent")
		end)
		
		self.hotTimeEventButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:SetMode("HotTimeEvent")
		end)
		
		self.originalWorldEventButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			self:SetMode("OriginalWorldEvent")
		end)
		
		self.noticeButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.uiManager.PopupModule:Open(_LocalizationService:GetText("SpecialEventNotice"), true, nil, nil)
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 이벤트 모듈을 열고 이벤트 기간에 따라 적절한 모드를 설정
		self.isOpen = true
		self.isSpecialEventPeriod = _DateTime:KtcNow() < DateTime(2025, 6, 11)
		self.uiManager:UpdateButtons()
		self.uiManager:UpdatePlayerController()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = true
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.panelEntity, Vector2.one, 0.175, EaseType.Linear)
		
		if _LocalizationService.CurrentLocaleId ~= "ko" or not self.isOriginalWorldEventWinner then
			local resource = self.resourceManager:GetResource("EventModule")
			self.originalWorldEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.disabledMode
			self.originalWorldEventButton.Entity.Parent:GetChildByName("Text").Enable = false
		end
		
		if self.isSpecialEventPeriod then
			self:SetMode("SpecialEvent")
		else
			self.specialEventButton.Entity.Parent.TransformComponent.Position.y = -1.13
			self.hotTimeEventButton.Entity.Parent.TransformComponent.Position.y = 0.03
			self.originalWorldEventButton.Entity.Parent.TransformComponent.Position.y = -0.555
			
			local resource = self.resourceManager:GetResource("EventModule")
			self.specialEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.disabledMode
			self.specialEventButton.Entity.Parent:GetChildByName("Text").Enable = false
			self:SetMode("HotTimeEvent")
		end
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 이벤트 모듈을 닫고 타이머를 정리
		self.isOpen = false
		self.uiManager:UpdateButtons()
		self.uiManager:UpdatePlayerController()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = false
		
		local panelTransform = self.panelEntity.TransformComponent
		panelTransform.Scale.x = 0
		panelTransform.Scale.y = 0
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		
		self.mode = ""
		_TimerService:ClearTimer(self.specialEventTimer)
	end

	@ExecSpace("ClientOnly")
	method void SetEventButtonEnable(boolean enable)
		-- 이벤트 버튼의 활성화 상태를 설정
		self.eventButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void SetPanelButtonsEnable(boolean enable)
		-- 패널 내 모든 버튼들과 출석 슬롯들의 활성화 상태를 설정
		self.xButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.specialEventButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable and self.isSpecialEventPeriod
		self.hotTimeEventButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.originalWorldEventButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable and _LocalizationService.CurrentLocaleId == "ko" and self.isOriginalWorldEventWinner
		self.noticeButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		
		local character = _UserService.LocalPlayer.Character
		for i, attendanceSlot in ipairs(self.attendanceSlotArray) do
			local slotEnable = enable and (not (character.temp.specialEventReceiveTable ~= nil and character.temp.specialEventReceiveTable[string.format("Day%d", i)])) and ( character.temp.specialEventAttendanceCount ~= nil and i <= character.temp.specialEventAttendanceCount)	attendanceSlot.receiveButton.Enable = slotEnable
			attendanceSlot.receiveButton.Entity.SpriteGUIRendererComponent.RaycastTarget = slotEnable
			
			if slotEnable then
				attendanceSlot.receiveButtonText.FontColor = Color.white
			else
				attendanceSlot.receiveButtonText.FontColor = Color.FromHexCode("#a0a0a0")
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Show()
		-- 이벤트 버튼을 화면에 표시
		if self.tweener then
			self.tweener:Destroy()
		end
		self.tweener = _Tween:ScaleTo(self.eventButtonEntity, Vector2.one, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void Hide()
		-- 이벤트 버튼을 화면에서 숨김
		if self.tweener then
			self.tweener:Destroy()
		end
		self.tweener = _Tween:ScaleTo(self.eventButtonEntity, Vector2.zero, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void SetMode(string mode)
		-- 이벤트 모드를 설정하고 특별 이벤트, 핫타임, 원작 월드 이벤트 모드에 따라 UI를 전환
		if self.mode == mode then
			return
		end
		self.mode = mode
		
		_TimerService:ClearTimer(self.specialEventTimer)
		
		local resource = self.resourceManager:GetResource("EventModule")
		if mode == "SpecialEvent" then
			self.specialEventContentEntity.Enable = true
			self.hotTimeEventContentEntity.Enable = false
			self.originalWorldEventContentEntity.Enable = false
			
			self.specialEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			self.hotTimeEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			if self.isOriginalWorldEventWinner and _LocalizationService.CurrentLocaleId == "ko" then
				self.originalWorldEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			end
			
			self.specialEventTimer = _TimerService:SetTimerRepeat(function()
				local timeSpan = _DateTime:KtcNow() < DateTime(2025, 6, 11) and DateTime(2025, 6, 11) - _DateTime:KtcNow() or TimeSpan.Zero
				self.specialEventEndTimeText.Text = _LocalizationService:GetTextFormat("SpecialEventEndTime", timeSpan.Days, timeSpan:ToFormattedString("hh':'mm':'ss"))
				self.specialEventUpdateTimeText.Text = _LocalizationService:GetTextFormat("SpecialEventUpdateTime", timeSpan:ToFormattedString("hh':'mm':'ss"))
			end, 0.01)
			
			local character = _UserService.LocalPlayer.Character
			for i, attendanceSlot in ipairs(self.attendanceSlotArray) do
				if character.temp.specialEventReceiveTable ~= nil and character.temp.specialEventReceiveTable[string.format("Day%d", i)] then
					attendanceSlot.fadeEntity.Enable = true
					attendanceSlot.checkEntity.Enable = true
				end
			end
		elseif mode == "HotTimeEvent" then
			self.specialEventContentEntity.Enable = false
			self.hotTimeEventContentEntity.Enable = true
			self.originalWorldEventContentEntity.Enable = false
			
			if self.isSpecialEventPeriod then
				self.specialEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			end
			self.hotTimeEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			if self.isOriginalWorldEventWinner and _LocalizationService.CurrentLocaleId == "ko" then
				self.originalWorldEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			end
		elseif mode == "OriginalWorldEvent" then
			self.specialEventContentEntity.Enable = false
			self.hotTimeEventContentEntity.Enable = false
			self.originalWorldEventContentEntity.Enable = true
			
			if self.isSpecialEventPeriod then
				self.specialEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			end
			self.hotTimeEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			if self.isOriginalWorldEventWinner and _LocalizationService.CurrentLocaleId == "ko" then
				self.originalWorldEventButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void ReceiveCardPacksBySpecialEvent(integer index)
		-- 특별 이벤트 출석 보상을 수령하고 UI를 업데이트
		local attendanceSlot = self.attendanceSlotArray[index]
		attendanceSlot.fadeEntity.Enable = true
		attendanceSlot.checkEntity.Enable = true
	end

end