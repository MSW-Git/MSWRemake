@Component
script RoomButton extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property ButtonComponent button = nil

	property SpriteGUIRendererComponent image = nil

	property TextComponent roomNameText = nil

	property TextComponent userCountText = nil

	property table room = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 룸 버튼 초기화 및 클릭 이벤트 연결
		local transform = self.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		
		self.button.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			_Server:Request(self.Entity.CurrentMap.Home, "EnterFriendlyMatchRoom", {_UserService.LocalPlayer.Character, self.room})
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetRoom(table room)
		-- 룸 정보 설정 및 UI 업데이트
		self.room = room
		self.roomNameText.Text = string.format("%s %d-%d", _LocalizationService:GetText("Room"), room.channel.id, room.id) 
		self.userCountText.Text = string.format("%d %s", room.userCount, _LocalizationService:GetText("Player"))
		
		local resource = self.resourceManager:GetResource("RoomButton")
		self.image.ImageRUID = resource[room.theme]
	end

end