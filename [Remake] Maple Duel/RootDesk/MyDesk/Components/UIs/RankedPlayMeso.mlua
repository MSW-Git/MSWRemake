@Component
script RankedPlayMeso extends Component

	property TextComponent titleText = nil

	property TextComponent deltaText = nil

	@ExecSpace("ClientOnly")
	method void Initialize(integer delta, integer count)
		-- 랭크 플레이 메소 보상 정보 초기화
		self.titleText.Text = _LocalizationService:GetTextFormat("RankedPlay", count)
		self.deltaText.Text = string.format("+%d", delta)
	end

end