@Logic
script Queue extends Logic

	method void Initialize(table queue)
		-- 큐 자료구조를 초기화
		queue.size = 0
		queue.beginIndex = 1
		queue.endIndex = 0
		queue.data = {}
	end

	method void Push(table queue, any value)
		-- 큐의 끝에 요소를 추가
		queue.size = queue.size + 1
		queue.endIndex = queue.endIndex + 1
		queue.data[queue.endIndex] = value
	end

	method any Pop(table queue)
		-- 큐의 첫 번째 요소를 제거하고 반환
		if queue.beginIndex > queue.endIndex then
			return nil
		end
		
		queue.size = queue.size - 1
		local value = queue.data[queue.beginIndex]
		queue.data[queue.beginIndex] = nil
		queue.beginIndex = queue.beginIndex + 1
		return value
	end

	method any Back(table queue)
		-- 큐의 마지막 요소를 반환 (제거하지 않음)
		return queue.data[queue.endIndex]
	end

	method any Front(table queue)
		-- 큐의 첫 번째 요소를 반환 (제거하지 않음)
		return queue.data[queue.beginIndex]
	end

end