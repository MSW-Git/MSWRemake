@Logic
script Math extends Logic

	method number Atan2(number y, number x)
		-- 2차원 좌표계에서 원점으로부터의 각도를 라디안으로 계산
		if x > 0 then
			return math.atan(y / x)
		elseif y >= 0 and x < 0 then
			return math.atan(y / x) + math.pi
		elseif y < 0 and x < 0 then
			return math.atan(y / x) - math.pi
		elseif y > 0 and x == 0 then
			return math.pi / 2
		elseif y < 0 and x == 0 then
			return -math.pi / 2
		else
			return 0
		end
		
	end

end