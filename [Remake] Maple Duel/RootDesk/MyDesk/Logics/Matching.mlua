@Logic
script Matching extends Logic

	@ExecSpace("ServerOnly")
	method any GetOrCreateLeaderBoard()
		if not Environment:IsPublishedPlay() then
			return
		end
		
		local resultCode
		local leaderBoardInfos
		local leaderBoardInfo
		resultCode, leaderBoardInfos = _MatchmakingService:GetLeaderboardInfosAndWait()
		if resultCode ~= LeaderboardResultCode.Ok then
			log(resultCode)
			return
		end
		
		if _Table:IsEmpty(leaderBoardInfos) then
			resultCode, leaderBoardInfo = _MatchmakingService:CreateLeaderboardAndWait("RankedMatch", LeaderboardScoringStrategy.Last, LeaderboardRatingStrategy.Elo, LeaderboardRankingStrategy.FirstHigh, nil)
		else
			leaderBoardInfo = leaderBoardInfos[1]
		end
		
		return leaderBoardInfo
	end

end