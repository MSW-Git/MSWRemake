            }
          ],
          "Code": "local grade_RandNumber = _UtilLogic:RandomIntegerRange(1, 100)\n\nlocal rewardMonster_Grade = \"\"\n\nlocal gradeUp_Percent = math.floor(curGradeUP_Percent)\nlocal gradeDown_Percent = math.floor(curGradeDown_Percent)\n\nif grade_RandNumber <= gradeUp_Percent then\n\trewardMonster_Grade = nextGrade -- 성공\nelse\n\tlocal grade_Down_RandNumber = _UtilLogic:RandomIntegerRange(1, 100)\n\t\t\t\n\tif grade_Down_RandNumber <= gradeDown_Percent then\n\t\t-- 등급 하락\n\t\tif curGrade == _MonsterService.Grade_1_Name then\n\t\t\trewardMonster_Grade = _MonsterService.Grade_0_Name \n\t\t\t\n\t\telseif curGrade == _MonsterService.Grade_2_Name then\n\t\t\trewardMonster_Grade = _MonsterService.Grade_1_Name\n\t\t\t\n\t\telseif curGrade == _MonsterService.Grade_3_Name then\n\t\t\trewardMonster_Grade = _MonsterService.Grade_2_Name\n\t\t\t\n\t\telseif curGrade == _MonsterService.Grade_4_Name then\n\t\t\trewardMonster_Grade = _MonsterService.Grade_3_Name \n\t\t\t\n\t\telseif curGrade == _MonsterService.Grade_5_Name then\n\t\t\trewardMonster_Grade = _MonsterService.Grade_4_Name\n\t\tend\n\t\t\n\telse\n\t\trewardMonster_Grade = curGrade -- 등급 유지\n\tend\nend\n\n\n-- 최고 등급 간의 조합이라면 등급 상승률 / 등급 하락율을 모두 0%로 표시\nif unmatchedFusion then\n\tgradeUp_Percent = 0\n\tgradeDown_Percent = 100\t\nend\n\nself.GradeUpText.TextComponent.Text = tostring(gradeUp_Percent)..\"%\"\nself.GradeDownText.TextComponent.Text = tostring(gradeDown_Percent)..\"%\"\n\nreturn rewardMonster_Grade",
