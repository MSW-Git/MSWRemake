              "Name": "arg1"
            }
          ],
          "Code": "local table_example = {}\n\nfor i = 1, #arg1 do\n\ttable.insert(table_example, arg1[i])\nend\n \nreturn table_example",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "ShallowCopy"
        }
      ],
      "EntityEventHandlers": [
        {
          "Name": "HandleButtonStateChangeEvent",
          "EventName": "ButtonStateChangeEvent",
          "ParameterName": "event",
          "Target": "self",
          "Code": "-- Parameters\nlocal state = event.state\n--------------------------------------------------------\n\nif tostring(state) == \"Clicked\" then\n\tself:OnClick()\nend",
