            }
          ],
          "Code": "--------------------------------------------------------------------------\n-- 자원 기본 생산량과 생산량 증가 비율 \n--------------------------------------------------------------------------\nlocal origin_GoldQuantity = _MonsterService.Origin_GoldQuantity_Starting\nlocal origin_GoldQuantity_Ratio = _MonsterService.Origin_GoldQuantity_Ratio\n\nlocal monsterGeneration = monGeneration_arg - 1\nlocal monsterLv = monLv_arg - 1\nlocal PercentByClass = 0\n\n--------------------------------------------------------------------------\n-- 몬스터 등급에 따른 '숨렙'을 가져옵니다.\n--------------------------------------------------------------------------\nif monGrade_arg == _MonsterService.Grade_0_Name then -- 없음 (0)\n\tPercentByClass = _MonsterService.Grade_0_Hide_Class \n\t\nelseif monGrade_arg == _MonsterService.Grade_1_Name then -- 일반 (0)\n\tPercentByClass = _MonsterService.Grade_1_Hide_Class \n\t\nelseif monGrade_arg == _MonsterService.Grade_2_Name then -- 고급 (5)\n\tPercentByClass = _MonsterService.Grade_2_Hide_Class\n\t \nelseif monGrade_arg == _MonsterService.Grade_3_Name then -- 희귀 (10)\n\tPercentByClass = _MonsterService.Grade_3_Hide_Class \n\t\nelseif monGrade_arg == _MonsterService.Grade_4_Name then -- 전설 (15)\n\tPercentByClass = _MonsterService.Grade_4_Hide_Class\n\t \nelseif monGrade_arg == _MonsterService.Grade_5_Name then -- 유일 (20)\n\tPercentByClass = _MonsterService.Grade_5_Hide_Class \nend\n\n\nlocal base_Quantity = origin_GoldQuantity\nlocal base_Quantity_By_Class = 0\n---------------------------------------------------------------------------\n-- '숨렙'과 '세대 보너스'를 적용합니다.\n---------------------------------------------------------------------------\nfor i = 1, monsterGeneration do\n\tbase_Quantity = base_Quantity * _MonsterService.Origin_GoldQuantity_Multiple_By_Generation\nend\n---------------------------------------------------------------------------\n\nself.base_Gold_Quantity_Only_Generation = base_Quantity\n\nbase_Quantity_By_Class = base_Quantity * (PercentByClass * 0.01)\nbase_Quantity = base_Quantity + base_Quantity_By_Class\n\n---------------------------------------------------------------------------\n-- 골드 생산량 공식을 적용합니다.\n---------------------------------------------------------------------------\nlocal monLv_Quantity = base_Quantity * (monsterLv * origin_GoldQuantity_Ratio * 0.01)\n\nlocal resultValue = base_Quantity + monLv_Quantity\n\n\nself.base_Gold_Quantity = resultValue\n\nself.Skill_GoldQuantity = resultValue * (self.Skill_Gold_QuantityBuff * 0.01) \n\nreturn (resultValue + self.Skill_GoldQuantity)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Get_Money_By_Type"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "type"
            }
          ],
          "Code": "if type == \"basic\" then\n\tself.UI_Basic_Info.Enable = true\n\tself.UI_Detail_Info.Enable = false\n\tself.UI_Basic_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode(\"#7072c9\")\n\tself.UI_Detail_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode(\"#5a5a7d\")\n\t\nelseif type == \"detail\" then\n\tself.UI_Basic_Info.Enable = false\n\tself.UI_Detail_Info.Enable = true\n\tself.UI_Basic_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode(\"#5a5a7d\")\n\tself.UI_Detail_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode(\"#7072c9\")\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "SwitchCategory"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "filter"
            }
          ],
          "Code": "if filter == \"Monster\" then\n\tself.UI_Normal.Enable = true\n\tself.UI_Lab.Enable = false\n\t\n\tself:RefreshItem()\n\tself:SwitchCategory(\"basic\")\n\tself:RefreshCategoryButtons(filter)\n\n\t\nelseif filter == \"Lab\" then\n\tself.UI_Normal.Enable = false\n\tself.UI_Lab.Enable = true\n\t\n\tself:RefreshLaboratory_Info()\n\tself:RefreshCategoryButtons(filter)\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "SwitchContents"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 연구 UI를 Refresh합니다. -----------------\n\nlocal player = _UserService.LocalPlayer\n\nif #player.PlayerData.Minventory_Id == 0 then\n\treturn\nend\n\n-- 해당 몬스터 아이템을 강조 표시 합니다. ----------------------------------\nself:HightLightItem()\n\nlocal generation = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"generation\"))\n\nlocal dataSetName_Grade = \"LabDataSet_Grade\"\nlocal dataSetName_Personality = \"LabDataSet_Personality\"\nlocal dataSetName_Skill = \"LabDataSet_Skill\"\nlocal dataSetName_Script = \"LabDataSet_Script\"\n\nlocal lab_Text_Info = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Lab_Grade_Info/Text_Grade_Info\")\nlocal ui_Grade = _EntityService:GetEntityByPath(self.UI_Lab.Path..\"/UI_Board/UI_Grade\")\nlocal ui_Grade_Text_Info = _EntityService:GetEntityByPath(ui_Grade.Path..\"/Text_Info\")\nlocal ui_Grade_Text_Percent = _EntityService:GetEntityByPath(ui_Grade.Path..\"/Text_Percent\")\nlocal ui_Grade_Image_Money = _EntityService:GetEntityByPath(ui_Grade.Path..\"/Image_Money\")\nlocal ui_Grade_Text_Money = _EntityService:GetEntityByPath(ui_Grade.Path..\"/Text_Money\") \nlocal ui_Grade_Button_Upgrade = _EntityService:GetEntityByPath(ui_Grade.Path..\"/Button_Upgrade\") \n \nlocal ui_Personality = _EntityService:GetEntityByPath(self.UI_Lab.Path..\"/UI_Board/UI_Personality\")\nlocal ui_Personality_Text_Info = _EntityService:GetEntityByPath(ui_Personality.Path..\"/Text_Info\")\nlocal ui_Personality_Image_Money = _EntityService:GetEntityByPath(ui_Personality.Path..\"/Image_Money\")\nlocal ui_Personality_Text_Money = _EntityService:GetEntityByPath(ui_Personality.Path..\"/Text_Money\") \nlocal ui_Personality_Button_Upgrade = _EntityService:GetEntityByPath(ui_Personality.Path..\"/Button_Upgrade\") \n \nlocal ui_Skill = _EntityService:GetEntityByPath(self.UI_Lab.Path..\"/UI_Board/UI_Skill\")\nlocal ui_Skill_Text_Info = _EntityService:GetEntityByPath(ui_Skill.Path..\"/Text_Info\")\nlocal ui_Skill_Image_Money = _EntityService:GetEntityByPath(ui_Skill.Path..\"/Image_Money\")\nlocal ui_Skill_Text_Money = _EntityService:GetEntityByPath(ui_Skill.Path..\"/Text_Money\") \nlocal ui_Skill_Button_Upgrade = _EntityService:GetEntityByPath(ui_Skill.Path..\"/Button_Upgrade\") \n\nlocal ui_Lock_Grade = _EntityService:GetEntityByPath(ui_Grade.Path..\"/UI_Lock\")\nlocal ui_Lock_Personality = _EntityService:GetEntityByPath(ui_Personality.Path..\"/UI_Lock\")\nlocal ui_Lock_Skill = _EntityService:GetEntityByPath(ui_Skill.Path..\"/UI_Lock\")\n\n--=====================================\n-- 등급 연구 경고 메세지 갱신\n--=====================================\nlocal grade_1_Text = \"<color=\".._MonsterService.Grade_1_Color..\">\".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_1_Name)..\"</color>\"\nlocal grade_2_Text = \"<color=\".._MonsterService.Grade_2_Color..\">\".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_2_Name)..\"</color>\"\nlocal grade_3_Text = \"<color=\".._MonsterService.Grade_3_Color..\">\".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_3_Name)..\"</color>\"\nlocal grade_4_Text = \"<color=\".._MonsterService.Grade_4_Color..\">\".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_4_Name)..\"</color>\"\nlocal grade_5_Text = \"<color=\".._MonsterService.Grade_5_Color..\">\".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_5_Name)..\"</color>\"\n\nlocal info1_Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_lab_info_1\", grade_1_Text, grade_2_Text, grade_3_Text, grade_4_Text, grade_5_Text)\nlocal info2_Text = _LocalizationService.LocalTranslator:GetText(\"UI_lab_info_2\")\nlab_Text_Info.TextComponent.Text = \"- \"..info1_Text..\"\\n\\n- \"..info2_Text\n\n--=====================================\n-- 등급 UI 갱신\n--=====================================\nlocal grade = player.PlayerData.Minventory_Grade[self.ShowMonsterIDX]\nlocal grade_HexCode = \"\"\nlocal grade_Number = 0 \nif grade == _MonsterService.Grade_0_Name then\n\tgrade_HexCode = _MonsterService.Grade_0_Color\n\nelseif grade == _MonsterService.Grade_1_Name then\n\tgrade_HexCode = _MonsterService.Grade_1_Color\n\tgrade_Number = 1\nelseif grade == _MonsterService.Grade_2_Name then\n\tgrade_HexCode = _MonsterService.Grade_2_Color\n\tgrade_Number = 2\nelseif grade == _MonsterService.Grade_3_Name then\n\tgrade_HexCode = _MonsterService.Grade_3_Color\n\tgrade_Number = 3\nelseif grade == _MonsterService.Grade_4_Name then\n\tgrade_HexCode = _MonsterService.Grade_4_Color\n\tgrade_Number = 4\nelseif grade == _MonsterService.Grade_5_Name then\n\tgrade_HexCode = _MonsterService.Grade_5_Color\n\tgrade_Number = 5\nend\n\nlocal grade_ID = tonumber(_DataService:GetCell(dataSetName_Grade, generation, \"ID\"))\nlocal grade_Quantity = tonumber(_DataService:GetCell(dataSetName_Grade, generation, \"Quantity\"))\nlocal grade_Percent = 0\n\nif grade_Number == 5 or generation == 1 then -- 5세대는 연구 불가\n\tui_Grade_Text_Percent.Enable = false\nelse\n\tgrade_Percent = tonumber(_DataService:GetCell(\"LabDataSet_Grade_Percent\", grade_Number + 1, \"percent\"))\n\tui_Grade_Text_Percent.Enable = true\nend\n\n\nui_Grade_Text_Percent.TextComponent.Text =  _LocalizationService.LocalTranslator:GetTextFormat(\"UI_lab_percent\", grade_Percent)\nui_Grade_Text_Info.TextComponent.Text = \"<color=\"..grade_HexCode..\">\".._LocalizationService.LocalTranslator:GetText(player.PlayerData.Minventory_Grade[self.ShowMonsterIDX])..\"</color>\"\nui_Grade_Text_Money.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(grade_Quantity)\nui_Grade_Image_Money.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", grade_ID - 20000, \"ruid\")\n\nlocal grade_isPossible = false\n\nif grade_ID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= grade_Quantity then\n\t\tgrade_isPossible = true\n\tend\t\nelseif grade_ID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= grade_Quantity then\n\t\tgrade_isPossible = true\n\tend\nelseif grade_ID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= grade_Quantity then\n\t\tgrade_isPossible = true\n\tend\nend\n\nui_Grade_Text_Money.TextComponent.FontColor = grade_isPossible and Color(1, 1, 1, 0.8) or Color(193/255, 117/255, 117/255, 0.8)\n\nui_Lock_Grade.Enable = not (generation >= 3)\n\nif grade ~= _MonsterService.Grade_5_Name and grade_isPossible and generation >= 3 then\n\tui_Grade_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_lab_enable\")\n\tui_Grade_Button_Upgrade.ButtonComponent.Enable = true\n\tui_Grade_Button_Upgrade.TextComponent.FontColor.a = 1\nelse\n\tui_Grade_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_lab_disable\")\n\tui_Grade_Button_Upgrade.ButtonComponent.Enable = false\n\tui_Grade_Button_Upgrade.TextComponent.FontColor.a = 0.5\n\tplayer.PlayerData.IsHold_Gauge_Grade = false\nend\n\n--=====================================\n-- 성격 UI 갱신\n--=====================================\nlocal personality = player.PlayerData.Minventory_Personality[self.ShowMonsterIDX]\nlocal personality_Name = ''\n\nif personality == 0 then\n\tpersonality_Name = _MonsterService.Personality_0_Name\n\t\nelseif personality == 1 then\n\tpersonality_Name = _MonsterService.Personality_1_Name\n\t\nelseif personality == 2 then\n\tpersonality_Name = _MonsterService.Personality_2_Name\n\t\nelseif personality == 3 then\n\tpersonality_Name = _MonsterService.Personality_3_Name\n\t\nelseif personality == 4 then\n\tpersonality_Name = _MonsterService.Personality_4_Name\n\t\nelseif personality == 5 then\n\tpersonality_Name = _MonsterService.Personality_5_Name\n\t\nelseif personality == 6 then\n\tpersonality_Name = _MonsterService.Personality_6_Name\nend\n\nlocal personality_ID = tonumber(_DataService:GetCell(dataSetName_Personality, generation, \"ID\"))\nlocal personality_Quantity = tonumber(_DataService:GetCell(dataSetName_Personality, generation, \"Quantity\"))\n\nui_Personality_Text_Info.TextComponent.Text = personality_Name\nui_Personality_Text_Money.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(personality_Quantity)\nui_Personality_Image_Money.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", personality_ID - 20000, \"ruid\")\n\nlocal personality_isPossible = false\n\nif personality_ID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= personality_Quantity then\n\t\tpersonality_isPossible = true\n\tend\t\nelseif personality_ID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= personality_Quantity then\n\t\tpersonality_isPossible = true\n\tend\nelseif personality_ID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= personality_Quantity then\n\t\tpersonality_isPossible = true\n\tend\nend\n\nui_Personality_Text_Money.TextComponent.FontColor = personality_isPossible and Color(1, 1, 1, 0.8) or Color(193/255, 117/255, 117/255, 0.8)\n\nui_Lock_Personality.Enable = not (generation >= 3)\n\nif personality_isPossible and generation >= 3 then\n\tui_Personality_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_lab_enable\")\n\tui_Personality_Button_Upgrade.ButtonComponent.Enable = true\n\tui_Personality_Button_Upgrade.TextComponent.FontColor.a = 1\nelse\n\tui_Personality_Button_Upgrade.TextComponent.Text =  _LocalizationService.LocalTranslator:GetText(\"UI_lab_disable\")\n\tui_Personality_Button_Upgrade.ButtonComponent.Enable = false\n\tui_Personality_Button_Upgrade.TextComponent.FontColor.a = 0.5\n\tplayer.PlayerData.IsHold_Gauge_Personality = false\nend\n\n--=====================================\n-- 스킬 UI 갱신\n--=====================================\nlocal skill = player.PlayerData.Minventory_Skill_Id[self.ShowMonsterIDX]\nlocal skill_Name = ''\nlocal translatedGrade = _LocalizationService.LocalTranslator:GetText(grade)\nif skill == 0 then\n\tskill_Name = _LocalizationService.LocalTranslator:GetText(\"Stat_skill_none\")\n\t\nelseif skill == 1 then\n\tskill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_1_Name)..\"<color=\"..grade_HexCode..\"> [\"..translatedGrade..\"]</color>\"\n\t\nelseif skill == 2 then\n\tskill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_2_Name)..\"<color=\"..grade_HexCode..\"> [\"..translatedGrade..\"]</color>\"\n\t\nelseif skill == 3 then\n\tskill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_3_Name)..\"<color=\"..grade_HexCode..\"> [\"..translatedGrade..\"]</color>\"\n\t\nelseif skill == 4 then\n\tskill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_4_Name)..\"<color=\"..grade_HexCode..\"> [\"..translatedGrade..\"]</color>\"\n\t\nelseif skill == 5 then\n\tskill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_5_Name)..\"<color=\"..grade_HexCode..\"> [\"..translatedGrade..\"]</color>\"\nend\n\nlocal skill_ID = tonumber(_DataService:GetCell(dataSetName_Skill, generation, \"ID\"))\nlocal skill_Quantity = tonumber(_DataService:GetCell(dataSetName_Skill, generation, \"Quantity\"))\n\nui_Skill_Text_Info.TextComponent.Text = skill_Name\nui_Skill_Text_Money.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(skill_Quantity)\nui_Skill_Image_Money.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", skill_ID - 20000, \"ruid\")\n\nlocal skill_isPossible = false\n\nif skill_ID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= skill_Quantity then\n\t\tskill_isPossible = true\n\tend\t\nelseif skill_ID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= skill_Quantity then\n\t\tskill_isPossible = true\n\tend\nelseif skill_ID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= skill_Quantity then\n\t\tskill_isPossible = true\n\tend\nend\n\nui_Skill_Text_Money.TextComponent.FontColor = skill_isPossible and Color(1, 1, 1, 0.8) or Color(193/255, 117/255, 117/255, 0.8)\n\nui_Lock_Skill.Enable = not (generation >= 5)\nif skill_isPossible and generation >= 5 then\n\tui_Skill_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_lab_enable\")\n\tui_Skill_Button_Upgrade.ButtonComponent.Enable = true\n\tui_Skill_Button_Upgrade.TextComponent.FontColor.a = 1\nelse\n\tui_Skill_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_lab_disable\")\n\tui_Skill_Button_Upgrade.ButtonComponent.Enable = false\n\tui_Skill_Button_Upgrade.TextComponent.FontColor.a = 0.5\n\tplayer.PlayerData.IsHold_Gauge_Skill = false\nend",
          "Scope": 2,
          "ExecSpace": 2,
