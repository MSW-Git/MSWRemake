          "Code": "local list_Children = self.List.Children\nlocal player = _UserService.LocalPlayer\n\nlocal isFind_FirstMonster = false\n\nfor i = 2, #list_Children do\n\tlocal idx = list_Children[i].MonsteryItem.Idx\n\n\tlist_Children[i].Enable = player.PlayerData.Minventory_Summoned[idx] \n\t\n\tif not isFind_FirstMonster then\n\t\tif list_Children[i].Enable then\n\t\t\tself.ShowMonsterIDX = idx\n\t\t\tself:RefreshShowMonsterInfo()\n\t\t\tisFind_FirstMonster = true\n\t\tend\n\tend\nend\n\n-- =================================================\n-- 최상단 몬스터를 보여줍니다.\n-- =================================================\n\nif not isFind_FirstMonster then\n\tself.UI_ShowUI_MonsterProfile.Enable = false\n\tself.UI_ShowUI_Contents.Enable = false\nelse\n\tself.UI_ShowUI_MonsterProfile.Enable = true\n\tself.UI_ShowUI_Contents.Enable = true\nend",
