      ],
      "Methods": [
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "self:SwitchContents(\"Monster\")",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Open"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "self.ShowMonsterIDX = 1\nself.Text_Progress_Lab.Text = \"\"\nself.UI_Lock.Enable = true",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Close"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local player = _UserService.LocalPlayer\nlocal list_Children = self.List.Children\n\n-- Item을 생성합니다. --------------------------------------\nfor x = #list_Children, #player.PlayerData.Minventory_Id do\n\tlocal clonedItem = self.Item:Clone(\"item\"..tostring(x))\n\nend\n\nlist_Children = self.List.Children\n\nfor i = 2, #self.List.Children do\n\tif list_Children[i].MonsteryItem.Idx == 0 then\n\t\tlist_Children[i].MonsteryItem.Idx = i - 1\n\tend\nend\n\n\n-- 보유한 몬스터가 있을 때만 UI를 갱신합니다. --------------\nif #player.PlayerData.Minventory_Id > 0 then\n\t\t\n\tself.UI_ShowUI_MonsterProfile.Enable = true\n\tself.UI_ShowUI_Contents.Enable = true\n\t\n\t-- 몬스터의 정보를 보여줍니다. ----------\n\tself:RefreshShowMonsterInfo()\n\t-----------------------------------------\nelse\n\tself.UI_ShowUI_MonsterProfile.Enable = false\n\tself.UI_ShowUI_Contents.Enable = false\nend\n\nself:Set_Filter(self.Cur_Filter)\n\nif self.UI_Lock.Enable then\n\tself.UI_Lock.Enable = false\nend\n",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshItem"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local player = _UserService.LocalPlayer\n\nif #player.PlayerData.Minventory_Id == 0 then\n\treturn\nend\n\nlocal dataSetName = \"MonsterDataSet_Base\"\n\nlocal Normal_UI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Normal\")\n\n-- 해당 IDX에 몬스터 정보가 없을 경우 --------------------------------------\nif not isvalid(player.PlayerData.Minventory_Id[self.ShowMonsterIDX]) then\n\tlog(\"Monster IDX Error.\")\n\tself.ShowMonsterIDX = 1\n\treturn\nend\n\n-- 해당 몬스터 아이템을 강조 표시 합니다. ----------------------------------\nself:HightLightItem()\n\n\nlocal monsterGrade = player.PlayerData.Minventory_Grade[self.ShowMonsterIDX]\nlocal monsterPersonality = player.PlayerData.Minventory_Personality[self.ShowMonsterIDX]\nlocal monsterSkill = player.PlayerData.Minventory_Skill_Id[self.ShowMonsterIDX]\nlocal monsterGeneration = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"generation\"))\nlocal monsterLevel = player.PlayerData.Minventory_Level[self.ShowMonsterIDX]\n\n-- 몬스터 등급 / 스킬 공식을 가져옵니다. ----------------------------------\nself:Give_Stat_ByGrade(monsterGrade)\nself:Give_Stat_BySkill(player, monsterSkill, self.ShowMonsterIDX)\nself.Gold_Quantity = self:Get_Money_By_Type(monsterLevel, monsterGrade, monsterGeneration)\n\n-- 몬스터의 정보를 표시합니다. ---------------------------------------------\nlocal monsterName = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"name\"))\nlocal monsterName_Text = monsterName\n\n-- 몬스터의 세대를 표시합니다. ---------------------------------------------\nlocal generationText = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_generation\", monsterGeneration)\nlocal monsterGenerationText = \"<color=#adf7ff>\"..generationText..\"</color>\"\n\n-- 몬스터의 등급을 표시합니다. ---------------------------------------------\n\nlocal monsterGrade_Color = \"\"\n\nif monsterGrade == _MonsterService.Grade_0_Name then\n\tmonsterGrade_Color = _MonsterService.Grade_0_Color\n\t\nelseif monsterGrade == _MonsterService.Grade_1_Name then\n\tmonsterGrade_Color = _MonsterService.Grade_1_Color\n\t\nelseif monsterGrade == _MonsterService.Grade_2_Name then\n\tmonsterGrade_Color = _MonsterService.Grade_2_Color\n\t\nelseif monsterGrade == _MonsterService.Grade_3_Name then\n\tmonsterGrade_Color = _MonsterService.Grade_3_Color\n\t\nelseif monsterGrade == _MonsterService.Grade_4_Name then\n\tmonsterGrade_Color = _MonsterService.Grade_4_Color\n\t\nelseif monsterGrade == _MonsterService.Grade_5_Name then\n\tmonsterGrade_Color = _MonsterService.Grade_5_Color\nend\n\nlocal monsterGradeName = _LocalizationService.LocalTranslator:GetText(monsterGrade)\nlocal monsterGradeText = \"<color=\"..monsterGrade_Color..\">\"..monsterGradeName..\"</color>\"\n\n-- 몬스터의 레벨을 표시합니다. ---------------------------------------------\nlocal monsterLevelText = \"<color=#adf7ff>Lv.\"..tostring(math.floor(monsterLevel))..\"</color>\"\n\nlocal text_Name = _EntityService:GetEntity(\"d9b6165a-8331-420a-87ff-45440c082dbf\") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Name\nlocal text_Generation = _EntityService:GetEntity(\"c4eaf16a-71f1-46e2-87e5-af21b92d3c94\") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Generation\nlocal text_Grade = _EntityService:GetEntity(\"971d514f-bfa2-4557-9b66-106bd7da3309\") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Grade\nlocal text_Level = _EntityService:GetEntity(\"be999df5-f1bb-4dc0-91b2-65eea90873e6\") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Level\n\ntext_Name.TextComponent.Text = monsterName_Text\ntext_Generation.TextComponent.Text = monsterGenerationText\ntext_Grade.TextComponent.Text = monsterGradeText\ntext_Level.TextComponent.Text = monsterLevelText\n\n-- 만렙이면 MAX 이미지를 표시합니다. ---------------------------------------\nself.Image_ShowUI_LevelMax.ButtonComponent.Enable = (monsterLevel >= _MonsterService.MonsterMaxLevel) \n\n-- Exp 게이지를 표시합니다. -----------------------------------------------\nlocal exp = player.PlayerData.Minventory_Exp[self.ShowMonsterIDX]\nlocal mexp = player.PlayerData.Minventory_Mexp[self.ShowMonsterIDX]\n\nif player.PlayerData.Minventory_Level[self.ShowMonsterIDX] >= _MonsterService.MonsterMaxLevel then\n\tself.Gauge_ShowUI_Level.Value = 0\nelse\n\tself.Gauge_ShowUI_Level.Value = exp/mexp\nend\n\n\n-- 몬스터의 이미지를 표시합니다. ------------------------------------------\nself.ShowUI_Monster.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"ruid\")\n\n\n-- 몬스터의 Scale을 반영합니다. -------------------------------------------\n\nlocal mon_x = tonumber(_DataService:GetCell(\"MonsterDataSet_UI\", player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"Thumbnail_x\"))\nlocal mon_y = tonumber(_DataService:GetCell(\"MonsterDataSet_UI\", player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"Thumbnail_y\"))\n\nself.ShowUI_Monster.SpriteGUIRendererComponent.LocalScale = Vector2(mon_x, mon_y)\n\nself.ShowUI_Monster.SpriteGUIRendererComponent.EndFrameIndex = 0\n\n\nif not Normal_UI.Enable then\n\treturn\nend\n\n-- 몬스터의 성격을 표시합니다. ---------------------------------------------\n\nlocal personalityName = \"\"\n\nif monsterPersonality == 0 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_0_Name)\n\t\nelseif monsterPersonality == 1 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_1_Name)\n\t\nelseif monsterPersonality == 2 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_2_Name)\n\t\nelseif monsterPersonality == 3 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_3_Name)\n\t\nelseif monsterPersonality == 4 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_4_Name)\n\t\nelseif monsterPersonality == 5 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_5_Name)\n\t\nelseif monsterPersonality == 6 then\n\tpersonalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_6_Name)\nend \n\nself.Text_Personality.TextComponent.Text = personalityName\n\n-- 몬스터의 스킬을 표시합니다. ---------------------------------------------\n\nlocal monsterSkillName = \"\"\nlocal monsterSkillInfo = \"\"\nlocal monsterSkillRUID = \"\"\nlocal monsterSkill_Grade = _LocalizationService.LocalTranslator:GetText(player.PlayerData.Minventory_Grade[self.ShowMonsterIDX])\n\nif monsterSkill == 0 then\n\tmonsterSkillName = _LocalizationService.LocalTranslator:GetText(\"Stat_skill_none\")\n\tmonsterSkillInfo = _LocalizationService.LocalTranslator:GetText(\"Stat_skill_none_info\")\n\tmonsterSkillRUID = \"9020e3c8b9f346b09d244b01cfe30a59\"\n\t\nelseif monsterSkill == 1 then\n\tmonsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_1_Name)\n\tmonsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_1_Info, math.floor(self.Skill_Berry_Chance_Buff))\n\tmonsterSkillRUID = _MonsterService.Skill_1_RUID\n\t\nelseif monsterSkill == 2 then\n\tmonsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_2_Name)\n\tmonsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_2_Info, math.floor(self.Skill_Berry_Quantity_Buff))\n\tmonsterSkillRUID = _MonsterService.Skill_2_RUID\n\t\nelseif monsterSkill == 3 then\n\tmonsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_3_Name)\n\tmonsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_3_Info, math.floor(self.Skill_Ruby_Chance_Buff))\n\tmonsterSkillRUID = _MonsterService.Skill_3_RUID\n\t\nelseif monsterSkill == 4 then\n\tmonsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_4_Name)\n\tmonsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_4_Info, math.floor(self.Skill_Ruby_Quantity_Buff))\n\tmonsterSkillRUID = _MonsterService.Skill_4_RUID\n\t\nelseif monsterSkill == 5 then\n\tmonsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_5_Name)\n\tmonsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_5_Info, math.floor(self.Skill_Gold_QuantityBuff))\n\tmonsterSkillRUID = _MonsterService.Skill_5_RUID\nend\n\nif monsterSkill ~= 0 then \n\tself.Text_Skill.TextComponent.Text = monsterSkillName..\" [\"..monsterSkill_Grade..\"]\"\n\tself.Text_Skill_Info.TextComponent.Text = monsterSkillInfo\nelse\n\tself.Text_Skill.TextComponent.Text = monsterSkillName\n\tself.Text_Skill_Info.TextComponent.Text = monsterSkillInfo\nend\n\nself.Text_Skill_Icon.SpriteGUIRendererComponent.ImageRUID = monsterSkillRUID\n\n-- 해당 몬스터가 '마스코트' 상태인지 확인합니다. ---------------------------\nif player.PlayerData.MInventory_MascotPet_Id == self.ShowMonsterIDX then\n\tself.Button_ShowUI_SetMascot.TextComponent.FontColor = Color.FromHexCode(\"#d88080\")\nelse\n\tself.Button_ShowUI_SetMascot.TextComponent.FontColor = Color(0, 0, 0, 0.2)\nend\n\n-- 소환 상태에 따라 버튼 상태를 다르게 설정합니다. -------------------------\n\n-- 농장에서만 버튼이 활성화되게 합니다.\nself.Button_ShowUI_Summon.Enable = (player.CurrentMapName == \"farm\") \nself.Button_ShowUI_Release.Enable = (self.Cur_Filter == \"Recent_Get\") \nself.Image_Title.Enable = (player.CurrentMapName == \"farm\")\n \nif player.PlayerData.Minventory_Summoned[self.ShowMonsterIDX] then\n\tlocal bringBackText = _LocalizationService.LocalTranslator:GetText(\"UI_bringBack\")\n\tself.Button_ShowUI_Summon.TextComponent.Text = bringBackText\n\tself.Button_ShowUI_Summon.SpriteGUIRendererComponent.Color = Color(147/255, 54/255, 77/255, 1)\nelse\n\tlocal summonText = _LocalizationService.LocalTranslator:GetText(\"UI_summon\")\n\tself.Button_ShowUI_Summon.TextComponent.Text = summonText\n\tself.Button_ShowUI_Summon.SpriteGUIRendererComponent.Color = Color(132/255, 136/255, 51/255, 1)\nend\n\n\n\n-- 골드 확률 공식 ----------------------------------------------------------------------------------\nlocal monsterGoldText_Percent = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_percent\", math.floor(_MonsterService.Origin_Gold_Chance))\n\n-- 생산품 확률 공식 --------------------------------------------------------------------------------\nlocal origin_Item_Chance = _MonsterService.Origin_Item_Chance \nlocal grade_Item_Chance = _MonsterService.Origin_Item_Chance * (self.Grade_Item_Chance_Buff * 0.01)\nlocal monsterItemText_Percent = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_percent\", math.ceil(origin_Item_Chance + grade_Item_Chance)) \n----------------------------------------------------------------------------------------------------\n\n\n-- 베리 확률 공식 ----------------------------------------------------------------------------------\nlocal origin_Berry_Chance = _MonsterService.Origin_Berry_Chance -- 10 \nlocal skill_Berry_Chance = _MonsterService.Origin_Berry_Chance * (self.Skill_Berry_Chance_Buff * 0.01)\nlocal monsterBerryText_Percent = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_percent\", math.ceil(origin_Berry_Chance + skill_Berry_Chance))\n----------------------------------------------------------------------------------------------------\n\n\n-- 루비 생산 확률 공식 -----------------------------------------------------------------------------\nlocal origin_Ruby_Chance = _MonsterService.Origin_Ruby_Chance \nlocal skill_Ruby_Chance = _MonsterService.Origin_Ruby_Chance * (self.Skill_Ruby_Chance_Buff * 0.01)\nlocal monsterRubyText_Percent =  _LocalizationService.LocalTranslator:GetTextFormat(\"UI_percent\", math.ceil(origin_Ruby_Chance + skill_Ruby_Chance))\n----------------------------------------------------------------------------------------------------\n\n-- 텍스트 반영 ------------------------------------------------------\nself.Text_Gold_Percent.TextComponent.Text = monsterGoldText_Percent\nself.Text_Item_Percent.TextComponent.Text = monsterItemText_Percent\nself.Text_Berry_Percent.TextComponent.Text = monsterBerryText_Percent\nself.Text_Ruby_Percent.TextComponent.Text = monsterRubyText_Percent\n---------------------------------------------------------------------\n\n-- 생산품 이미지 반영 -----------------------------------------------\nlocal item_ID = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], \"product\"))\nself.Image_MonsterItem.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", item_ID - 20000, \"ruid\")\nself.Image_Item_Detail.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", item_ID - 20000, \"ruid\") \n---------------------------------------------------------------------\n\n\nlocal monsterRubyQuantity = math.ceil(self.base_Gold_Quantity / (_MonsterService.Origin_ExpQuantity_Ruby * 0.1)) \n\nlocal monsterberryQuantity = math.ceil(self.base_Gold_Quantity / (_MonsterService.Origin_ExpQuantity_Berry * 0.1))\n\nlocal berrySkillQuantity =  math.ceil((monsterberryQuantity * self.Skill_Berry_Quantity_Buff * 0.01))\n\nlocal berryQuantity = monsterberryQuantity + berrySkillQuantity\n\nlocal rubySkillQuantity = math.ceil((monsterRubyQuantity * self.Skill_Ruby_Quantity_Buff * 0.01))\nlocal rubyQuantity = monsterRubyQuantity + rubySkillQuantity\n\n-- 몬스터의 생산량 반영 ---------------------------------------------\nself.Text_Gold_Quantity.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(self.Gold_Quantity)\nself.Text_Item_Quantity.TextComponent.Text = \"x 1\"\nself.Text_Berry_Quantity.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(berryQuantity)\nself.Text_Ruby_Quantity.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(rubyQuantity)\n---------------------------------------------------------------------\n\nself.UI_Berry.Enable = (monsterGeneration >= 2)\nself.UI_Detail_Berry.Enable = (monsterGeneration >= 2)\n\nself.UI_Ruby.Enable = (monsterGeneration >= 3)\nself.UI_Detail_Ruby.Enable = (monsterGeneration >= 3)\n\n\n---------------------------------------------------------------------\n-- 세부 정보를 갱신합니다.\n---------------------------------------------------------------------\n\nself.Text_ProductTime.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_speedForProducing\", math.floor(_MonsterService.Origin_Product_Time))\n\n-- 골드 --\nself.Text_Gold_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalQuantity\", _SystemService:ThousandsSeparator(self.base_Gold_Quantity))\nself.Text_Gold_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusQuantity\", _SystemService:ThousandsSeparator(self.Gold_Quantity - self.base_Gold_Quantity))\n\n-- 아이템 --\nself.Text_Item_Quantity_Detail.TextComponent.Text =  _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalQuantity\", \"1\")\nself.Text_Item_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalPercent\", math.floor(_MonsterService.Origin_Item_Chance))\nself.Text_Item_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusQuantity\", \"0\")\nself.Text_Item_Bonus_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusPercent\", math.floor(self.Grade_Item_Chance_Buff))\n\n-- 베리 --\nlocal base_berry = self.base_Gold_Quantity_Only_Generation / (_MonsterService.Origin_ExpQuantity_Berry * 0.1)\nself.Text_Berry_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalQuantity\", _SystemService:ThousandsSeparator(base_berry))\nself.Text_Berry_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusQuantity\", _SystemService:ThousandsSeparator(berryQuantity - base_berry))\n\nself.Text_Berry_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalPercent\", math.floor(origin_Berry_Chance))\nself.Text_Berry_Bonus_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusPercent\", math.floor(self.Skill_Berry_Chance_Buff))\n\n\n-- 루비 --\nlocal base_ruby = self.base_Gold_Quantity_Only_Generation / (_MonsterService.Origin_ExpQuantity_Ruby * 0.1)\nself.Text_Ruby_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalQuantity\", _SystemService:ThousandsSeparator(base_ruby))\nself.Text_Ruby_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusQuantity\", _SystemService:ThousandsSeparator(rubyQuantity - base_ruby))\n\nself.Text_Ruby_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productNormalPercent\", math.floor(origin_Ruby_Chance))\nself.Text_Ruby_Bonus_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_productBonusPercent\", math.floor(self.Skill_Ruby_Chance_Buff))",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshShowMonsterInfo"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local list_Children = self.List.Children\n\nfor i = 2, #list_Children do\n\tlist_Children[i].MonsteryItem:RefreshInfo()\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "HightLightItem"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "grade"
            }
          ],
          "Code": "local monsterGrade_To_Number = 0\n\nif grade == _MonsterService.Grade_0_Name then\n\tmonsterGrade_To_Number = 0\n\t\nelseif grade == _MonsterService.Grade_1_Name then\n\tmonsterGrade_To_Number = 1\n\nelseif grade == _MonsterService.Grade_2_Name then\n\tmonsterGrade_To_Number = 2\n\t\nelseif grade == _MonsterService.Grade_3_Name then\n\tmonsterGrade_To_Number = 3\n\t\nelseif grade == _MonsterService.Grade_4_Name then\n\tmonsterGrade_To_Number = 4\n\t\nelseif grade == _MonsterService.Grade_5_Name then\n\tmonsterGrade_To_Number = 5\nend\n\nself.Grade_Gold_Item_Quantity_Buff = tonumber(_DataService:GetCell(\"MonsterDataSet_Grade_Passive\", monsterGrade_To_Number + 1, \"gold_Item_QuantityBuff\"))\nself.Grade_Item_Chance_Buff = tonumber(_DataService:GetCell(\"MonsterDataSet_Grade_Passive\", monsterGrade_To_Number + 1, \"itemChanceBuff\"))\n",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Give_Stat_ByGrade"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "skill_ID"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            }
          ],
          "Code": "if skill_ID == 0 then\n\tself.Skill_Gold_QuantityBuff = 0\n\tself.Skill_Berry_Chance_Buff = 0\n\tself.Skill_Berry_Quantity_Buff = 0 \n\tself.Skill_Ruby_Chance_Buff = 0\n\tself.Skill_Ruby_Quantity_Buff = 0\n\treturn\nend\n\nlocal effectValue = 1\nif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_1_Name then\n\teffectValue = _MonsterService.Skill_Grade_1_Effect\n\t\nelseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_2_Name then \n\teffectValue = _MonsterService.Skill_Grade_2_Effect\n\t\nelseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_3_Name then \n\teffectValue = _MonsterService.Skill_Grade_3_Effect\n\t\nelseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_4_Name then \n\teffectValue = _MonsterService.Skill_Grade_4_Effect\n\t\nelseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_5_Name then \n\teffectValue = _MonsterService.Skill_Grade_5_Effect\nend\n\nself.Skill_Gold_QuantityBuff = tonumber(_DataService:GetCell(\"MonsterDataSet_Skill_Passive\", skill_ID, \"goldQuantityBuff\")) * effectValue\nself.Skill_Berry_Chance_Buff = tonumber(_DataService:GetCell(\"MonsterDataSet_Skill_Passive\", skill_ID, \"berryChanceBuff\")) * effectValue \nself.Skill_Berry_Quantity_Buff = tonumber(_DataService:GetCell(\"MonsterDataSet_Skill_Passive\", skill_ID, \"berryQuantityBuff\"))  * effectValue\nself.Skill_Ruby_Chance_Buff = tonumber(_DataService:GetCell(\"MonsterDataSet_Skill_Passive\", skill_ID, \"rubyChanceBuff\")) * effectValue\nself.Skill_Ruby_Quantity_Buff = tonumber(_DataService:GetCell(\"MonsterDataSet_Skill_Passive\", skill_ID, \"rubyQuantityBuff\")) * effectValue",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Give_Stat_BySkill"
        },
        {
          "Return": {
            "Type": "number",
