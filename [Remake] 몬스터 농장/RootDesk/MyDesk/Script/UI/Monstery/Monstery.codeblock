            }
          ],
          "Code": "local button_Monster = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Buttons/Button_Monster\")\nlocal button_Monster_Inner = _EntityService:GetEntityByPath(button_Monster.Path..\"/Button\")\n\nlocal button_Lab = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Buttons/Button_Lab\") \nlocal button_Lab_Inner = _EntityService:GetEntityByPath(button_Lab.Path..\"/Button\")\n\nbutton_Monster.ButtonComponent.Enable = not (filter == \"Monster\")\nbutton_Monster_Inner.ButtonComponent.Enable = not (filter == \"Monster\")\nbutton_Monster_Inner.TextComponent.FontColor = (filter == \"Monster\") and Color(227/255, 227/255, 227/255, 1) or Color(159/255, 167/255, 173/255, 1) \n\nbutton_Lab.ButtonComponent.Enable = not (filter == \"Lab\")\nbutton_Lab_Inner.ButtonComponent.Enable = not (filter == \"Lab\")\nbutton_Lab_Inner.TextComponent.FontColor = (filter == \"Lab\") and Color(227/255, 227/255, 227/255, 1) or Color(159/255, 167/255, 173/255, 1) ",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshCategoryButtons"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "if self.List_Filter.Enable then\n\treturn\nend\n\nself.Image_Filter_Block_Background.Enable = true\nself.List_Filter.Enable = true",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Open_FilterUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "self.Image_Filter_Block_Background.Enable = false\nself.List_Filter.Enable = false",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Close_FilterUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "Filter"
            }
          ],
          "Code": "-- Filter Item을 클릭했을 때, 필터를 적용합니다. ----------------------\n\nlocal list_Children = self.List_Filter.Children\n\n-- 선택된 상태인 Filter Item만 강조 표시합니다. -----------------------\nfor i = 1, #list_Children do\n\tlocal item_Filter = list_Children[i].Monstery_Filter_Monster.Type\n\tif item_Filter == Filter then\n\t\tlist_Children[i].ButtonComponent.Enable = false\n\t\t\n\t\t-- 현재 설정된 필터를 텍스트 UI에 반영합니다. ----------------\n\t\tself.Text_Cur_Filtering.Text = list_Children[i].TextComponent.Text\n\n\telse\n\t\tlist_Children[i].ButtonComponent.Enable = true\n\t\t\n\n\tend\nend\n\n-- 필터링을 적용하고 갱신합니다. --------------------------------------\n\n\n-- 세대 오름차 순 정렬\nif Filter == \"Generation_Up\" then\n\tself:Filtering_Monster_By_Generation(Filter, true)\n-- 세대 내림차 순 정렬\t\nelseif Filter == \"Generation_Down\" then\n\tself:Filtering_Monster_By_Generation(Filter, false)\n-- 등급 오름차 순 정렬\nelseif Filter == \"Grade_Up\" then\n\tself:Filtering_Monster_By_Grade(Filter, true)\n-- 등급 내림차 순 정렬\nelseif Filter == \"Grade_Down\" then\n\tself:Filtering_Monster_By_Grade(Filter, false)\n-- 소환한 몬스터만 보여주기\nelseif Filter == \"Summoned_Monster\" then\n\tself:Filtering_Monster_By_Summoned(Filter)\n-- 대기 중인 몬스터만 보여주기\nelseif Filter == \"Waiting_Monster\" then\n\tself:Filtering_Monster_By_Waiting(Filter)\n-- 최근에 획득한 순으로 정렬\nelseif Filter == \"Recent_Get\" then\n\tself:Filtering_Monster_By_Recent_Get(Filter)\nend\n\nself.Cur_Filter = Filter\n\nself.Button_ShowUI_Release.Enable = (self.Cur_Filter == \"Recent_Get\") ",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Set_Filter"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "filter"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
