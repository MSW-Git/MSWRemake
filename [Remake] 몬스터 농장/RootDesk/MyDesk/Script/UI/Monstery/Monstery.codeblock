            }
          ],
          "Code": "-- ==================================================\n-- status == true, 내림차 순 정렬\n-- status == false, 오름차 순 정렬\n-- ==================================================\nlocal player = _UserService.LocalPlayer\n\nlocal list_Children = self.List.Children\n\nlocal monsterIDX = {}\nlocal sortPoint = {}\n\n-- 등급 정렬을 위해 사전에 테이블을 생성합니다. -----\nfor i = 2, #list_Children do\n\t\n\tlocal itemIDX = list_Children[i].MonsteryItem.Idx \n\tlocal itemGrade = player.PlayerData.Minventory_Grade[itemIDX]\n\t\n\tif itemGrade == _MonsterService.Grade_0_Name then\n\t\titemGrade = 0\n\telseif itemGrade == _MonsterService.Grade_1_Name then\n\t\titemGrade = 1\n\telseif itemGrade == _MonsterService.Grade_2_Name then\n\t\titemGrade = 2\n\telseif itemGrade == _MonsterService.Grade_3_Name then\n\t\titemGrade = 3\n\telseif itemGrade == _MonsterService.Grade_4_Name then\n\t\titemGrade = 4\n\telseif itemGrade == _MonsterService.Grade_5_Name then\n\t\titemGrade = 5\n\telse\n\t\titemGrade = 0\n\tend\n\t\n\ttable.insert(monsterIDX, itemIDX)\n\ttable.insert(sortPoint, itemGrade)\nend\n------------------------------------------------------\n\n\n-- 내림차 순 등급 정렬 -------------------------------\nif status then\n\tfor i = 1, #monsterIDX do\n\t\tfor x = 1, #monsterIDX - 1 do\n\t\t\tif sortPoint[x] < sortPoint[x+1] then\n\t\t\t\tmonsterIDX[x], monsterIDX[x+1] = monsterIDX[x+1], monsterIDX[x]\n\t\t\t\tsortPoint[x], sortPoint[x+1] = sortPoint[x+1], sortPoint[x]\n\t\t\tend\n\t\tend\n\tend\n\t\n-- 오름차 순 등급 정렬 ------------------------------\nelse\n\tfor i = 1, #monsterIDX do\n\t\tfor x = 1, #monsterIDX - 1 do\n\t\t\tif sortPoint[x] > sortPoint[x+1] then\n\t\t\t\tmonsterIDX[x], monsterIDX[x+1] = monsterIDX[x+1], monsterIDX[x]\n\t\t\t\tsortPoint[x], sortPoint[x+1] = sortPoint[x+1], sortPoint[x]\n\t\t\tend\n\t\tend\n\tend\nend\n\nfor i = 2, #list_Children do\n\tlist_Children[i].Enable = true\n\tlist_Children[i].MonsteryItem.Idx = monsterIDX[i-1]\n\tlist_Children[i].MonsteryItem:RefreshInfo()\nend\n\n-- =================================================\n-- 최상단 몬스터를 보여줍니다.\n-- =================================================\nif #list_Children >= 2 and isvalid(list_Children[2]) then\n\t\n\tif filter ~= self.Cur_Filter then\n\t\tself.ShowMonsterIDX = list_Children[2].MonsteryItem.Idx\n\t\tself:RefreshShowMonsterInfo()\n\tend\n\tself.UI_ShowUI_MonsterProfile.Enable = true\n\tself.UI_ShowUI_Contents.Enable = true\nend",
