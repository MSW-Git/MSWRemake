          "DefaultValue": "70802395-fa9a-4ae0-9b4c-be7450a48ccb",
          "SyncDirection": 0,
          "Attributes": [],
          "Name": "Text_Prev_Capacity"
        },
        {
          "Type": "Component",
          "DefaultValue": "e0cb2589-a927-415d-a0e6-72c13d1361d0:SpriteGUIRendererComponent",
