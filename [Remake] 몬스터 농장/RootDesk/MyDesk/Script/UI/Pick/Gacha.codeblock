          "Code": "-- 기존 설정 값 초기화 ----------------\nself.Text_GetItemCount.TextComponent.Text = ''\nself.Text_GetItemName.TextComponent.Text = ''\nself.Text_GetItemType.TextComponent.Text = ''\nself.Image_GetItemImage.SpriteGUIRendererComponent.ImageRUID = \"3e9d52ed52d64794bbd6f72bab8ee3d9\" \nself.Text_GetItemType.SpriteGUIRendererComponent.Color = Color(0, 0, 0 , 0)\n\nself.OpenItem.Enable = false\nself.Text_GetItemName.Enable = false\nself.Button_Close.Enable = false\n\nself.Destination_Type = \"\"\nself.Progress = 0\n\nwait(1)\nself.Text_Info.Enable = true",
