            }
          ],
          "Code": "_LevelUpService:Open(lv)",
          "Scope": 2,
          "ExecSpace": 6,
          "Attributes": [],
          "Name": "OpenLvUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "name"
            },
            {
              "Type": "any",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "value"
            }
          ],
          "Code": "local player = _UserService.LocalPlayer\nif player ~= self.Entity then\n\treturn\nend\n\nif name == \"IsLoaded\" then\n\twait(1)\n\tlocal loadingUI = _EntityService:GetEntityByPath(\"/ui/LoadingGroup\")\n\tloadingUI.Enable = not value\n\treturn\nend\n\nif self.Entity.CurrentMapName == \"farm\" and self.Owner then\n\n-- 플레이어의 인벤토리 수량 갱신 ----------------------------------------------\nif name == \"Heart\" then\n\tlocal text_Like = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Player_Stat/Text_Like\") \n\ttext_Like.TextComponent.Text = _SystemService:ThousandsSeparator(value)\n\t\t\nelseif name == \"Inventory_Quantity\" then -- Table\n\tself.Inventory_Sync = true\n\t\nelseif name == \"Inventory_Type\" then\n\tself.Inventory_Sync = true\n\nelseif name == \"Inventory_Name\" then\n\tself.Inventory_Sync = true\n\t\t\nelseif name == \"Hinventory_Level\" then\n\tself.Helper_Sync = true\n\t\t\nelseif name == \"Hinventory_Summoned\" then\n\tself.Helper_Sync = true\n\t\t\n\t-- MyCon의 이미지를 갱신합니다. --\nelseif name == \"EquippedMyConID\" then \n\tlocal playerLogo = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Player_Stat/UI_Player_Logo/Image_Icon\")\n\tplayerLogo.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"MyConDataSet\", value, \"ruid\")\n\t\nelseif name == \"Minventory_Id\" then\n\tself.Monster_ID_Sync = true\n\t\t\nelseif name == \"Minventory_Grade\" then\n\tself.Monster_Sync = true\n\t\t\nelseif name == \"Minventory_Exp\" then\n\tself.Monster_Sync = true\n\t\nelseif name == \"Minventory_Mexp\" then\n\tself.Monster_Sync = true\n\t\nelseif name == \"Minventory_Level\" then\n\tself.Monster_Sync = true\n\t\t\nelseif name == \"MInventory_MascotPet_Id\" then\n\tself.Monster_Sync = true\n\t\t\nelseif name == \"Minventory_Personality\" then\n\tself.Monster_Sync = true\n\t\t\nelseif name == \"Minventory_Skill_Id\" then\n\tself.Monster_Sync = true\n\t\t\nelseif name == \"IsAutoPlaceOnStore\" then\n\n\tlocal auto_Place_Button = _EntityService:GetEntityByPath(\"/ui/StoreGroup/Image_Board/Image_Board_Buy/UI_ItemInfo/UI_Bottom_Bar/Auto_Place_Button\")\n\t\n\tif value then\n\t\tauto_Place_Button.SpriteGUIRendererComponent.Color = Color(135/255, 131/255, 78/255, 1)\n\t\tauto_Place_Button.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_autoPlaceOn\")\n\t\t\t\n\t\tauto_Place_Button.TextComponent.FontColor.a = 1\n\telse\n\t\tauto_Place_Button.SpriteGUIRendererComponent.Color = Color(70/255, 70/255, 70/255, 1)\n\t\tauto_Place_Button.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(\"UI_autoPlaceOff\")\n\t\tauto_Place_Button.TextComponent.FontColor.a = 0.3\n\tend\n\n\t\t\nelseif name == \"CurPotGauge\" then\n\n\tlocal cookGroup = _EntityService:GetEntityByPath(\"/ui/CookGroup\")\n\n\tif cookGroup.Enable then\n\t\t_CookService:RefreshPotUI(false)\t\t\n\tend \n\t\t\nelseif name == \"IsCooked\" then\n\tlocal cookGroup = _EntityService:GetEntityByPath(\"/ui/CookGroup\")\n\n\tif cookGroup.Enable then\n\t\t_CookService:RefreshButtons()\n\t\t_CookService:RefreshItems()\n\tend \n\t\t\nelseif name == \"CurPotTimer\" then\t\n\tlocal cookGroup = _EntityService:GetEntityByPath(\"/ui/CookGroup\")\n\t\t\n\tif cookGroup.Enable then\n\t\t_CookService:RefreshTimer(value)\n\tend\n\t\t\nelseif name == \"CurPotLevel\" or name == \"CurKitchenTool_Level\" or name == \"CurSuit_Level\" or name == \"CurRecipe_Level\" then\n\tlocal upgradeGroup = _EntityService:GetEntityByPath(\"/ui/CookGroup/Upgrade_Background\")\n\n\tif upgradeGroup.Enable then\n\t\t_CookService:RefreshTools()\n\t\t_CookService:Refresh_UpgradeUI()\t\n\tend\n\t\t\t\n-- 플레이어가 소환한 몬스터 수 갱신 -------------------------------------------\nelseif name == \"MaxSummon\" then\n\t\t\n\t-- UI 반영 ---------------\n\tlocal summon_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_SummonedMonster\")\n\tlocal summon_UI_MonsterWindow = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/Text_Summoned_Monster\")\n\t\n\tlocal playerSummoned = _PlayerService:Check_Monster_Summoned(player)\n\tif playerSummoned >= value then -- 최대 소환량에 도달한 상태라면\n\t\tsummon_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\n\t\tsummon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\n\telse\n\t\tsummon_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\t\n\t\tsummon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\t\n\tend\n\t\n\tsummon_UI.TextComponent.Text = tostring(math.floor(playerSummoned)).. \" / \"..tostring(math.floor(self.MaxSummon))\n\tsummon_UI_MonsterWindow.TextComponent.Text = tostring(math.floor(playerSummoned)).. \" / \"..tostring(math.floor(self.MaxSummon))\n\n\t\t\nelseif name == \"Minventory_Summoned\" then\n\tself.Monster_Summon_Sync = true\n\t\n-- 플레이어의 레벨 반영 -------------------------------------------------------\nelseif name == \"Level\" then\t\n\tlocal DefaultUI_Level = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Player_Stat/UI_Player_Logo/Text_Level\")\n\tDefaultUI_Level.TextComponent.Text = tostring(math.floor(value))\n\n\t-- 닉네임 반영 --\n\tlocal nickName = _SystemService:StringTrimmer(self.Entity.PlayerComponent.Nickname, 24)\n\tlocal nickName_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Player_Stat/Text_PlayerName\")\n\tnickName_UI.TextComponent.Text = nickName\n\n\tself:UnLock_Contents_ByLevel(player)\n\t\n-- 플레이어의 재화 반영 -------------------------------------------------------\nelseif name == \"Gold\" then\n\n   \tlocal newString = _SystemService:ThousandsSeparator(value)\n\n\tlocal DefaultUI_Gold = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Gold\")\n\tDefaultUI_Gold.TextComponent.Text = newString\n\t\n\tlocal StoreUI = _EntityService:GetEntityByPath(\"/ui/StoreGroup\")\n\tif StoreUI.Enable then\n\t\tStoreUI.Store:RefreshInfo()\n\tend\n\t\n\tlocal StoreGroup_Gold = _EntityService:GetEntityByPath(\"/ui/StoreGroup/Image_Board/UI_StateBar/Text_Coin\")\n\tStoreGroup_Gold.TextComponent.Text = newString\n\t\n\tlocal KioskGroup_Gold = _EntityService:GetEntityByPath(\"/ui/KioskGroup/Image_Board/UI_StateBar/Text_Coin\")\n\tKioskGroup_Gold.TextComponent.Text = newString\n\t\n\tlocal FusionGroup_Gold = _EntityService:GetEntityByPath(\"/ui/MonsterFusionGroup/UI_set_fusion/UI_StateBar/Text_Coin\")\n\tFusionGroup_Gold.TextComponent.Text = newString\n\t\n\tlocal UI_Gold_Effect_White = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Gold/Effect_white\")\n\tUI_Gold_Effect_White.EffectUI:whiteEffect()\n\t\t\n\tlocal cookUpgrade_Gold = _EntityService:GetEntityByPath(\"/ui/CookGroup/Upgrade_Background/Image_Background/Upgrade_Title/UI_StateBar/Text_Coin\")\n\tcookUpgrade_Gold.TextComponent.Text = newString\n\t\t\n\tlocal MonsterUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup\")\n\tlocal LabUI = _EntityService:GetEntityByPath(MonsterUI.Path..\"/UI_Monster_Left/UI_Lab\")\n\t\n\tif LabUI.Enable then\n\t\tMonsterUI.Monstery:RefreshLaboratory_Info()\n\tend\n\t\t\n-- 플레이어의 루비 반영 -------------------------------------------------------\nelseif name == \"Ruby\" then\n\t\n   \tlocal newString = _SystemService:ThousandsSeparator(value)\n\n\tlocal DefaultUI_Ruby = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Ruby\")\n\tDefaultUI_Ruby.TextComponent.Text = newString\n\t\t\n\tlocal UI_Ruby_Effect_White = _EntityService:GetEntityByPath(DefaultUI_Ruby.Path..\"/Effect_white\")\n\tUI_Ruby_Effect_White.EffectUI:whiteEffect()\n\t\t\n\tlocal MonsterUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup\")\n\tlocal LabUI = _EntityService:GetEntityByPath(MonsterUI.Path..\"/UI_Monster_Left/UI_Lab\")\n\t\n\tlocal Store_Ruby = _EntityService:GetEntityByPath(\"/ui/StoreGroup/Image_Board/UI_StateBar_Ruby/Text_Ruby\")\n\tStore_Ruby.TextComponent.Text = newString\n\t\t\n\tif LabUI.Enable then\n\t\tMonsterUI.Monstery:RefreshLaboratory_Info()\n\tend\n\t\t\nelseif name == \"Berry\" then\n\t\n   \tlocal newString = _SystemService:ThousandsSeparator(value)\n\n\tlocal DefaultUI_Berry = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Berry\")\n\tDefaultUI_Berry.TextComponent.Text = newString\n\t\t\n\tlocal UI_Berry_Effect_White = _EntityService:GetEntityByPath(DefaultUI_Berry.Path..\"/Effect_white\")\n\tUI_Berry_Effect_White.EffectUI:whiteEffect()\n\n\tlocal MonsterUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup\")\n\tlocal LabUI = _EntityService:GetEntityByPath(MonsterUI.Path..\"/UI_Monster_Left/UI_Lab\")\n\t\n\tif LabUI.Enable then\n\t\tMonsterUI.Monstery:RefreshLaboratory_Info()\n\tend\n\t\t\n-- 플레이어의 인벤토리 최대 보유량 반영 ---------------------------------------\nelseif name == \"MaxCapacity\" then\n\t\n\tlocal prev_capacity = _EntityService:GetEntityByPath(\"/ui/KioskGroup/Upgrade_Background/UI_Upgrade/Center_Bar/Text_Prev_Upgrade\")\n\tlocal next_capacity = _EntityService:GetEntityByPath(\"/ui/KioskGroup/Upgrade_Background/UI_Upgrade/Center_Bar/Text_Next_Upgrade\") \n\t\n\tprev_capacity.TextComponent.Text = tostring(math.floor(value))\n\tnext_capacity.TextComponent.Text = tostring(math.floor(value + 8))\n\n\n\t-- UI 반영 ---------------\n\tlocal capacity_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Inv_Capacity\") \n\tlocal capacity_UI_InvWindow = _EntityService:GetEntityByPath(\"/ui/KioskGroup/UI_StateBar_Capacity\")\n\t\n\tlocal playerCapacity = _PlayerService:Check_Inventory(self.Entity)\n\tif playerCapacity >= self.MaxCapacity then -- 최대 수용랑에 도달한 상태라면\n\t\tcapacity_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\n\t\tcapacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\n\telse\n\t\tcapacity_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\t\n\t\tcapacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\n\tend\n\n\tcapacity_UI.TextComponent.Text = tostring(math.floor(playerCapacity))..\" / \"..tostring(math.floor(self.MaxCapacity))\n\tcapacity_UI_InvWindow.TextComponent.Text = tostring(math.floor(playerCapacity))..\" / \"..tostring(math.floor(self.MaxCapacity))\n\t\n\n\t\t\n-- 플레이어의 '조합하기 기능' 해제 반영 ---------------------------------------\nelseif name == \"Finventory_Unlock\" then\n\tself.Fusion_Sync = true\n\t\nelseif name == \"Finventory_Slot_Unlock\" then\n\tself.Fusion_Sync = true\n\t\t\n\t\t\nelseif name == \"Finventory_Remaining_Time\" then\n\tself.Fusion_Sync = true\n\t\t\nelseif name == \"Finventory_Reward_Monster_Id\" then\n\tself.Fusion_Sync = true\n\t\t\n-- 플레이어의 최대 아이템 보유량이 변경되었다면 -------------------------------\nelseif name == \"MaxCapacity_Upgrade_Level\" then\n\tlocal kioskUI = _EntityService:GetEntityByPath(\"/ui/KioskGroup\")\n\tkioskUI.Kiosk:RefreshUpgradeUI(player)\n\tlocal Capacity = 0\n\t\n\tfor i = 1, #self.Inventory_Quantity do\n\t\tCapacity = Capacity + self.Inventory_Quantity[i]\n\tend\n\t\n\t-- UI 반영 ---------------\n\tlocal capacity_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Inv_Capacity\") \n\tlocal capacity_UI_InvWindow = _EntityService:GetEntityByPath(\"/ui/KioskGroup/UI_StateBar_Capacity\")\n\n\tcapacity_UI.TextComponent.Text = tostring(math.floor(Capacity))..\" / \"..tostring(math.floor(self.MaxCapacity))\n\tcapacity_UI_InvWindow.TextComponent.Text = tostring(math.floor(Capacity))..\" / \"..tostring(math.floor(self.MaxCapacity))\n\t\t\n\t\t\n-- 첫 농장 진입시 닉네임을 UI에 반영합니다. ----------------------------------\nelseif name == \"NickName\" then\n\tlocal nickName = _SystemService:StringTrimmer(value, 24)\n\tlocal nickName_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Player_Stat/Text_PlayerName\")\n\tnickName_UI.TextComponent.Text = nickName\nend\n\t\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "OnSyncProperty"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "-- Entity의 Layer를 갱신합니다. ---------------------------------------------------------------------------\nself.Entity.AvatarRendererComponent.OrderInLayer = -(self.Entity.TransformComponent.Position.y * 200) + 800",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "LayerSettingInFarm"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- GuestUI를 농장 주인의 정보에 맞게 갱신합니다. ---------------------------------------------------------------\nlocal guestUI = _EntityService:GetEntityByPath(\"/ui/GuestGroup\")\nlocal textOwnerName = _EntityService:GetEntityByPath(guestUI.Path..\"/UI_Player_Stat/Text_PlayerName\")\nlocal textOwnerLike = _EntityService:GetEntityByPath(guestUI.Path..\"/UI_Player_Stat/Text_Like\")\nlocal textOwnerLevel = _EntityService:GetEntityByPath(guestUI.Path..\"/UI_Player_Stat/UI_Player_Logo/Text_Level\")\nlocal playerLogo = _EntityService:GetEntityByPath(guestUI.Path..\"/UI_Player_Stat/UI_Player_Logo/Image_Icon\")\n\nlocal owner = _EntityService:GetEntity(self.Entity.CurrentMap.MapInfo.MapOwnerEntityID)\n\nlocal nickName = _SystemService:StringTrimmer(owner.PlayerComponent.Nickname, 24)\ntextOwnerName.TextComponent.Text = nickName\ntextOwnerLike.TextComponent.Text = _SystemService:ThousandsSeparator(owner.PlayerData.Heart)\ntextOwnerLevel.TextComponent.Text = tostring(math.floor(owner.PlayerData.Level))\n\nplayerLogo.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"MyConDataSet\", owner.PlayerData.EquippedMyConID, \"ruid\")\n----------------------------------------------------------------------------------------------------------------",
          "Scope": 2,
          "ExecSpace": 6,
          "Attributes": [],
          "Name": "RefreshGuestUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 가장 가까운 플레이어와 거래할 수 있게 UI를 띄웁니다. ---------------------\n\nlocal players = _UserService.UserEntities.Values\n\nlocal playerPos = self.Entity.TransformComponent.Position\n\n---@type Entity\nlocal nearestPlayer = nil\n\n-- 맵에 혼자 있다면 Return합니다. -------------------------------------------\nif #players == 1 then\n\tlocal tradeUI = _EntityService:GetEntityByPath(\"/ui/LobbyGroup/UI_Trade\")\n\ttradeUI.Enable = false\n\treturn\n\t\n-- 맵에 둘 이상 있다면 가장 가까운 플레이어를 찾습니다. ---------------------\nelseif #players >= 2 then\n\tif players[1] == self.Entity then\n\t\tnearestPlayer = players[2]\n\telse\n\t\tnearestPlayer = players[1]\n\tend\nend\n\n\nlocal nearestPlayerGap = math.abs(playerPos.x - nearestPlayer.TransformComponent.Position.x) + math.abs(playerPos.y - nearestPlayer.TransformComponent.Position.y)\n\n-- 가장 가까운 플레이어를 찾습니다. -----------------------------------------\nfor i = 1, #players do\n\t\n\tif players[i] == self.Entity or not isvalid(players[i]) then\n\t\t-- 자기 자신일 경우를 제외시킵니다. \n\telse\n\t\tlocal xGap = math.abs(playerPos.x - players[i].TransformComponent.Position.x)\n\t\tlocal yGap = math.abs(playerPos.y - players[i].TransformComponent.Position.y)\n\t\t\n\t\tif nearestPlayerGap > xGap + yGap then\n\t\t\tnearestPlayerGap = xGap + yGap\n\t\t\tnearestPlayer = players[i]\n\t\tend\n\tend\nend\n\n\nlocal range = 1.5\nlocal tradeUI = _EntityService:GetEntityByPath(\"/ui/LobbyGroup/UI_Trade\")\n\n-- 최소 범위 내에 있을 때만 상호작용이 가능하게 합니다. -----------------------------\nif nearestPlayerGap >= range then\n\ttradeUI.Enable = false\n\tself.InteractedPlayer = nil\nelse\n\ttradeUI.Enable = true\n\tlocal nickName = _SystemService:StringTrimmer(nearestPlayer.PlayerComponent.Nickname, 24)\n\tlocal nameText = _EntityService:GetEntityByPath(tradeUI.Path..\"/Text_Name\")\n\tnameText.TextComponent.Text = nickName\n\t\n\t-- 해당 플레이어가 상호작용 중이라면 '교환' 버튼을 비활성화합니다. --------------\n\t\n\tlocal button_Trade = _EntityService:GetEntityByPath(\"/ui/LobbyGroup/UI_Trade/UI_Trade/Button_Trade\")\n\n\tbutton_Trade.ButtonComponent.Enable = not isvalid(nearestPlayer.PlayerTradeComponent.TraderID)\n\t\n\t-- 가장 가까운 엔티티와 상호작용 행동을 할 수 있게 설정합니다. --\n\tself.InteractedPlayer = nearestPlayer\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "ShowTradeUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "self.Entity.CameraComponent:SetZoomTo(65, 0)",
          "Scope": 2,
          "ExecSpace": 6,
          "Attributes": [],
          "Name": "CameraZoom"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "mapName"
            }
          ],
          "Code": "if mapName == \"farm\" then\n\t\t\n\t-- 카메라 설정 ----------------------------------------------\n\tself.Entity.CameraComponent.ConfineCameraArea = true\n\tself.Entity.CameraComponent.LeftBottom = Vector2(-10.3, -3.5)\n\tself.Entity.CameraComponent.RightTop = Vector2(9.8, 8.3)\n\t-------------------------------------------------------------\n\t\n\t-- 이동속도 --------------------------------\n\tself.Entity.MovementComponent.InputSpeed = 3\n\t\n\nelseif mapName == \"lobby\" then\n\t-- 카메라 설정 ----------------------------------------------\n\tself.Entity.CameraComponent.ConfineCameraArea = true\n\tself.Entity.CameraComponent.LeftBottom = Vector2(-28.9, -9.8)\n\tself.Entity.CameraComponent.RightTop = Vector2(-3.2, 7.3)\n\t-------------------------------------------------------------\n\t\n\t-- 이동속도 --------------------------------\n\tself.Entity.MovementComponent.InputSpeed = 3\n\n\t\nelse\n\t-- 카메라 설정 ----------------------------------------------\n\tself.Entity.CameraComponent.ConfineCameraArea = false\n\t------------------------------------------------------------\n\n\t-- 이동속도 --------------------------------\n\tself.Entity.MovementComponent.InputSpeed = 1\nend",
          "Scope": 2,
          "ExecSpace": 6,
          "Attributes": [],
          "Name": "CameraSetting"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- Inventory UI에 반영 ---\nlocal playerCapacity = _PlayerService:Check_Inventory(self.Entity)\n\n-- UI 반영 ---------------\nlocal capacity_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_Inv_Capacity\") \nlocal capacity_UI_InvWindow = _EntityService:GetEntityByPath(\"/ui/KioskGroup/UI_StateBar_Capacity\")\n\t\nif playerCapacity >= self.MaxCapacity then -- 최대 수용랑에 도달한 상태라면\n\tcapacity_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\n\tcapacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\nelse\n\tcapacity_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\t\n\tcapacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\nend\n\ncapacity_UI.TextComponent.Text = tostring(math.floor(playerCapacity))..\" / \"..tostring(math.floor(self.MaxCapacity))\ncapacity_UI_InvWindow.TextComponent.Text = tostring(math.floor(playerCapacity))..\" / \"..tostring(math.floor(self.MaxCapacity))\n\t\n\n-- 상점 refresh --\nlocal StoreUI = _EntityService:GetEntityByPath(\"/ui/StoreGroup\")\nif StoreUI.Enable then\n\tStoreUI.Store:RefreshInfo()\nend\n\n-- 요리 refresh --\nlocal cookUI = _EntityService:GetEntityByPath(\"/ui/CookGroup\")\nif cookUI.Enable then\n\t_CookService:RefreshItems()\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Sync_Inventory"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- Monster UI에 반영 ---\nlocal monsteryUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup\")\nif monsteryUI.Enable then\n\tmonsteryUI.Monstery:RefreshItem()\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Sync_Monster_By_ID"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- Monster UI에 반영 ---\nlocal monsteryUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup\")\nif monsteryUI.Enable then\n\tmonsteryUI.Monstery:RefreshShowMonsterInfo()\n\t\n\tlocal LabUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Lab\")\n\n\tif LabUI.Enable then\n\t\tmonsteryUI.Monstery:RefreshLaboratory_Info()\n\tend\nelse\n\treturn\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Sync_Monster_By_Info"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local Summoned = 0\n\t\nfor i = 1, #self.Minventory_Summoned do\n\tif self.Minventory_Summoned[i] then\n\t\tSummoned = Summoned + 1\n\tend\nend\n\t\n\n-- UI 반영 ---------------\nlocal summon_UI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Stat/UI_SummonedMonster\")\nlocal summon_UI_MonsterWindow = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/Text_Summoned_Monster\")\n\t\nif Summoned >= self.MaxSummon then -- 최대 소환량에 도달한 상태라면\n\tsummon_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\n\tsummon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)\nelse\n\tsummon_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\t\n\tsummon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)\t\nend\n\t\nsummon_UI.TextComponent.Text = tostring(math.floor(Summoned)).. \" / \"..tostring(math.floor(self.MaxSummon))\nsummon_UI_MonsterWindow.TextComponent.Text = tostring(math.floor(Summoned)).. \" / \"..tostring(math.floor(self.MaxSummon))\n\n\n-- Monster UI에 반영 ---\nlocal monsteryUI = _EntityService:GetEntityByPath(\"/ui/MonsterGroup\")\n\nif monsteryUI.Enable then\n\tmonsteryUI.Monstery:RefreshItem()\n\tmonsteryUI.Monstery:RefreshShowMonsterInfo()\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Sync_Monster_By_Summon"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local fusionUI = _EntityService:GetEntityByPath(\"/ui/MonsterFusionGroup\")\n\t\nif fusionUI.Enable then\n\tfusionUI.Fusion:RefreshAllOngoingList()\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Sync_Fusion"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local StoreUI = _EntityService:GetEntityByPath(\"/ui/StoreGroup\")\nif StoreUI.Enable then\n\tStoreUI.Store:RefreshHelperList()\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Sync_Helepr"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "-- 플레이어의 레벨에 따라 기능을 잠금해제 합니다. ------\nlocal level = player.PlayerData.Level\n\nlocal fusion_Lock = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Buttons/Button_Fusion/Image_lock\")\nlocal cook_Lock = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Buttons/Button_Cook/Image_lock\")\n\nfusion_Lock.Enable = not (level >= 3)\ncook_Lock.Enable = not (level >= 4)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "UnLock_Contents_ByLevel"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": null,
          "Code": "-- 랜덤 주기로 저장합니다. ----------------------------------------\nself.FarmEventTimer = _UtilLogic:RandomIntegerRange(240, 480) \n\nif self.Entity.Enable then\n\tlocal function_Layer = function() self:LayerSettingInFarm(self.Entity) end\n\t_TimerService:SetTimerRepeat(function_Layer, 1, 1)\nend",
          "Scope": 2,
