      "Methods": [
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "any",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "enteredMap"
            }
          ],
          "Code": "-- 플레이어가 위치한 장소가 Lobby 라면 --------------------------------------------------------\nif self.Entity.CurrentMapName ~= \"farm\" then\n\n\tself.Entity.PlayerMove.Enable = false\n\n\tif self.IsLoaded then\n\t\t_MascotService:DeleteMascotMonster(self.MascotPet)\n\t\t_MascotService:CreateMascotMonster(self.Entity)\n\tend\n\t\n-- 플레이어가 위치한 장소가 farm 이라면 -------------------------------------------------------\n\t\n\t\n\n\t\nelseif self.Entity.CurrentMapName == \"farm\" then\n\t\n\tlocal farm = self.Entity.CurrentMap\n\n\tif #farm.MapInfo.MapOwnerName <= 1 then\n\t\t\n\t\tfarm.MapInfo.MapOwnerName = self.Entity.Name\n\t\tfarm.MapInfo.MapOwnerEntityID = self.Entity.Id\n\tend\n\n\t\n\twait(0.5)\n\n\t-- 해당 농장의 owner라면 -----------------------------------------------------------------\n\tself.Owner = (farm.MapInfo.MapOwnerName == self.Entity.Name)\n\tself.Entity.PlayerMove.Enable = self.Owner\n\n\t\n\t-- 농장의 주인이라면 ----------------------------------------------------------------------\n\tif self.Owner then\n\t\tlocal camera = _EntityService:GetEntityByPath(\"/maps/farm/Camera\")\n\t\t_CameraService:SwitchCameraTo(camera.CameraComponent, self.Entity.Name)\n\t\t\n\t\tself.Entity.CameraComponent.Enable = false\n\t\tself.Entity.PlayerControllerComponent.Enable = false\n\n\t\tlocal balloonUI = _EntityService:GetEntityByPath(\"/maps/farm/UI_Balloon\") \n\t\tlocal balloon = balloonUI:Clone(\"UI_Balloon\")\n\t\tballoon:AttachTo(self.Entity)\n\t\tballoon.TransformComponent.Position = Vector3(0, 1, 0)\n\t\tballoon.Enable = false\n\t\t\n\t\tself.Entity:AddComponent(\"OwnerEntity\")\n\t\t\n\t\tself.NickName = self.Entity.PlayerComponent.Nickname\n\t\t\n\n\t-- 농장의 방문객이라면 --------------------------------------------------------------------\n\t\t\n\telse\n\n\t\t\n\t\t-- GuestUI를 갱신합니다. --\n\t\tself:RefreshGuestUI()\t\n\t\t\n\t\t-- 농장의 플레이어들에게 알림 메세지를 보냅니다. --\n\t\t_LocalizationToastService:VisitFarm(self.Entity.PlayerComponent.Nickname)\n\t\tself.Entity.PlayerControllerComponent.Enable = true\n\tend\n\t\n\nend\n",
          "Scope": 2,
          "ExecSpace": 1,
          "Attributes": [],
          "Name": "OnMapEnter"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "any",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "leftMap"
            }
          ],
          "Code": "-- 농장을 떠날 때 토스트 메세지를 띄웁니다.\nif leftMap.Name == \"farm\" then\n\tif self.Owner then\n\t\t\n\telse\n\t\t_LocalizationToastService:LeaveFarm(self.Entity.PlayerComponent.Nickname)\n\tend\nend",
          "Scope": 2,
          "ExecSpace": 1,
          "Attributes": [],
          "Name": "OnMapLeave"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "delta"
            }
          ],
          "Code": "local player = _UserService.LocalPlayer\n\n-- 주인이 아닐 경우 -----------------------------------------------\nif player ~= self.Entity then\n\treturn\nend\n\nif self.Owner then\n\n\tif self.IsHold_Gauge_Grade then\n\t\tself.Gauge_Grade_Temp = self.Gauge_Grade_Temp + delta\n\t\tself.Gauge_Lab_Grade.Value = self.Gauge_Grade_Temp * 2\n\t\t\n\t\tif self.Gauge_Lab_Grade.Value >= self.Gauge_Lab_Grade.MaxValue then\n\t\t\tlocal button_Grade = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Board/UI_Grade/Button_Upgrade\")\n\t\t\tbutton_Grade.Monstery_Button_Upgrade:OnClick()\n\t\t\tself.Gauge_Grade_Temp = 0\n\t\t\tself.Gauge_Lab_Grade.Value = 0\n\t\t\tself.IsHold_Gauge_Grade = false\n\t\tend\n\tend\n\t\n\tif self.IsHold_Gauge_Personality then\n\n\t\tself.Gauge_Personality_Temp = self.Gauge_Personality_Temp + delta\n\t\tself.Gauge_Lab_Personality.Value = self.Gauge_Personality_Temp * 2\n\t\t\n\t\tif self.Gauge_Lab_Personality.Value >= self.Gauge_Lab_Personality.MaxValue then\n\t\t\tlocal button_Personality = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Board/UI_Personality/Button_Upgrade\")\n\t\t\tbutton_Personality.Monstery_Button_Upgrade:OnClick()\n\t\t\tself.Gauge_Personality_Temp = 0\n\t\t\tself.Gauge_Lab_Personality.Value = 0\n\t\t\tself.IsHold_Gauge_Personality = false\n\t\tend\n\tend\n\t\n\tif self.IsHold_Gauge_Skill then\n\n\t\tself.Gauge_Skill_Temp = self.Gauge_Skill_Temp + delta\n\t\tself.Gauge_Lab_Skill.Value = self.Gauge_Skill_Temp * 2\n\t\tif self.Gauge_Lab_Skill.Value >= self.Gauge_Lab_Skill.MaxValue then\n\t\t\tlocal button_Skill = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Board/UI_Skill/Button_Upgrade\")\n\t\t\tbutton_Skill.Monstery_Button_Upgrade:OnClick()\n\t\t\tself.Gauge_Skill_Temp = 0\n\t\t\tself.Gauge_Lab_Skill.Value = 0\n\t\t\tself.IsHold_Gauge_Skill = false\n\t\tend\n\tend\n\t\nend\n\nif self.Inventory_Sync then\n\tself:Sync_Inventory()\n\tself.Inventory_Sync = false\nend\n\nif self.Monster_Sync then\n\tself:Sync_Monster_By_Info()\n\tself.Monster_Sync = false\nend\n\nif self.Fusion_Sync then\n\tself:Sync_Fusion()\n\tself.Fusion_Sync = false\nend\n\nif self.Helper_Sync then\n\tself:Sync_Helepr()\n\tself.Helper_Sync = false\nend\n\nif self.Monster_ID_Sync then\n\tself:Sync_Monster_By_ID()\n\tself.Monster_ID_Sync = false\nend\n\nif self.Monster_Summon_Sync then\n\tself:Sync_Monster_By_Summon()\n\tself.Monster_Summon_Sync = false\nend\n\nif self.Entity.PlayerSubData.NormalQuests_Sync then\n\tself.Entity.PlayerSubData:Sync_NormalQuest()\n\tself.Entity.PlayerSubData.NormalQuests_Sync = false\nend\n\nif self.Entity.PlayerSubData.WaitingQuests_Sync then\n\tself.Entity.PlayerSubData:Sync_WaitingQuest()\n\tself.Entity.PlayerSubData.WaitingQuests_Sync = false\nend\n\nif self.Entity.PlayerSubData.DoneQuests_Sync then\n\tself.Entity.PlayerSubData:Sync_DoneQuest()\n\tself.Entity.PlayerSubData.DoneQuests_Sync = false\nend\n\nif self.Entity.PlayerSubData.DailyGiveHeartList_Sync then\n\tself.Entity.PlayerSubData:Sync_DailyGiveHeartList()\n\tself.Entity.PlayerSubData.DailyGiveHeartList_Sync = false\nend\n\nif self.Entity.PlayerSubData.AchievementComplete_Sync then\n\tself.Entity.PlayerSubData:Sync_Achievement()\n\tself.Entity.PlayerSubData.AchievementComplete_Sync = false\nend\n\n\n--- 최적화 --------------------------------------------------------\nif self.RefreshTime >= self.RefreshTimeMAX then\n\tself.RefreshTime = 0\nelse\n\tself.RefreshTime = self.RefreshTime + delta\n\treturn\nend\n\n-- ================================================================\n-- Transfer 오류가 날 시, 대기 후 추방합니다. \n-- ================================================================\nif self.IsTransferring then\n\t\n\tlocal gachaUI = _EntityService:GetEntity(\"0e991b2e-5775-43ef-bcf1-419582467183\") -- /ui/GachaGroup\n\tif not gachaUI.Enable then\n\t\tself.TransferKick_Timer = self.TransferKick_Timer + self.RefreshTimeMAX\n\tend\n\tif self.TransferKick_Timer >= self.TransferKick_TimerMAX then\n\t\tlocal yes = function() _MapService:MoveToLobbyFromFarm(player) end\n\t\t\n\t\tif self.Entity.CurrentMapName == \"farm\" then\n\t\t\t_UIPopup:Open(_LocalizationService.LocalTranslator:GetText(\"Popup_failToConnect\"), yes, nil, nil)\n\t\telse\n\t\t\t_UserService:KickUser(player.PlayerComponent.UserId, KickReason.ETC)\n\t\tend\n\t\t\n\t\tself.TransferKick_Timer = 0\n\tend\n\t\nelse\n\tself.TransferKick_Timer = 0\nend\n\t\n-- 싱크 로직을 실행합니다. ----------------------------------------\nif self.Owner then\n\tself:AlwaysSyncData(self.IsPossibleWalk)\n\t_QuestService:QuestCompleteNotify() -- 퀘스트 진행도를 실시간으로 받아옵니다.\nend\n\n-- 이벤트 타이머를 실행합니다. ------------------------------------\nif self.Owner then\n\tif self.FarmEventTimer > 0 then\n\t\tif self.FarmEventUITimer <= 0 then\n\t\t\tself.FarmEventTimer = self.FarmEventTimer - self.RefreshTimeMAX\n\t\tend\n\telse\n\t\tself.FarmEventTimer = _UtilLogic:RandomIntegerRange(240, 480)\n\t\tself.FarmEventUITimer = 60\n\t\t_EventService:Open()\n\tend \n\t\n\tlocal eventNotification = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/Event_Notification\")\n\tlocal eventUI = _EntityService:GetEntityByPath(\"/ui/FarmEventGroup\")\n\n\teventNotification.Visible = not self.IsPossibleWalk\n\t\n\tif self.FarmEventUITimer > 0 then\n\t\tif not eventUI.Enable then\n\t\t\tself.FarmEventUITimer = self.FarmEventUITimer - self.RefreshTimeMAX\n\t\tend\n\telse\n\t\tlocal eventPoint = _EntityService:GetEntityByPath(\"/maps/farm/Event_Point\")\n\t\t\n\t\tif eventPoint.Enable then\n\t\t\teventPoint.Enable = false\n\t\tend\n\t\t\n\t\tif eventNotification.Enable then\n\t\t\teventNotification.Enable = false\n\t\tend\n\t\t\n\tend\n\nend\n\n-- 플레이어의 상태(owner,guest)에 따라 다르게 UI를 표시합니다. ----\n\nif self.Owner then\n\tself:ChangeStatusByRole(\"owner\")\nelse\n\tself:ChangeStatusByRole(\"guest\")\nend\n\nself:CameraSetting(self.Entity.CurrentMapName)\nif self.Entity.CurrentMapName ~= \"farm\" then\n\tif self.Entity.CurrentMapName == \"lobby\" then\n\t\t--self:CameraZoom()\n\tend\n\tself:ShowTradeUI()\nend\n\n",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "OnUpdate"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "role"
            }
          ],
          "Code": "if self.Entity.CurrentMapName == \"farm\" then\n\tif string.len(self.Entity.CurrentMap.MapInfo.MapOwnerName) <= 1 then\n\t\treturn\n\tend\nelse\n\treturn\nend\n\n-- 해당 플레이어 엔티티의 OrderInLayer를 갱신합니다. -------------\n\nlocal defaultUI = _EntityService:GetEntityByPath(\"/ui/DefaultGroup\")\nlocal guestUI = _EntityService:GetEntityByPath(\"/ui/GuestGroup\")\nlocal LobbyGroup = _EntityService:GetEntityByPath(\"/ui/LobbyGroup\")\n\nlocal stat_UI = _EntityService:GetEntityByPath(defaultUI.Path..\"/UI_Stat\")\nlocal player_Stat_UI = _EntityService:GetEntityByPath(defaultUI.Path..\"/UI_Player_Stat\") \nlocal buttons_UI = _EntityService:GetEntityByPath(defaultUI.Path..\"/UI_Buttons\")\nlocal left_UI = _EntityService:GetEntityByPath(defaultUI.Path..\"/Left_Buttons\")\nlocal joyStick = _EntityService:GetEntityByPath(defaultUI.Path..\"/JoyStick\")\nlocal jumpButton = _EntityService:GetEntityByPath(defaultUI.Path..\"/JumpButton\")\n \n-- 해당 플레이어가 농장의 소유주라면 ------------------------------\nif role == \"owner\" then\n\t\n\tif isvalid(self.Entity.OwnerEntity) then\n\t\tself.Entity.OwnerEntity.Enable = false\n\tend\n\n\tif self.IsPossibleWalk then -- '투어 모드'라면\n\t\tstat_UI.Visible = false\n\t\tbuttons_UI.Visible = false\n\t\tleft_UI.Visible = false\n\t\t\n\t\tplayer_Stat_UI.UITransformComponent.AlignmentOption = AlignmentType.BottomCenter\n\t\tplayer_Stat_UI.UITransformComponent.anchoredPosition.x = 0\n\t\t\n\t\tif isvalid(self.Entity.OwnerEntity) then\n\t\t\tself.Entity.OwnerEntity.Enable = false\n\t\tend\n\t\t\t\n\t\tlocal camera = _EntityService:GetEntityByPath(\"/maps/farm/Camera\")\n\t\tif camera.CameraComponent.Enable then\n\t\t\tcamera.CameraComponent.Enable = false\t\n\t\t\tself.Entity.CameraComponent.Enable = true\n\t\t\t\n\t\t\t_CameraService:SwitchCameraTo(self.Entity.CameraComponent)\n\t\tend\n\t\t\n\t\tself.Entity.StateComponent.Enable = true\n\t\tself.Entity.PlayerControllerComponent.Enable = true\n\t\t\n\t\tif Environment:IsMobilePlatform() then\n\t\t\tjoyStick.Enable = true\n\t\t\tjumpButton.Enable = true\n\t\tend\n\t\t\n\telse -- '관리모드'라면\n\t\tstat_UI.Visible = true\n\t\tbuttons_UI.Visible = true\n\t\tleft_UI.Visible = true\n\t\t\n\t\tplayer_Stat_UI.UITransformComponent.AlignmentOption = AlignmentType.BottomLeft\n\t\tplayer_Stat_UI.UITransformComponent.anchoredPosition.x = 360\n\t\t\n\t\tif isvalid(self.Entity.OwnerEntity) then\n\t\t\tself.Entity.OwnerEntity.Enable = true\n\t\tend\n\n\t\tif self.Entity.CameraComponent.Enable then\n\t\t\tlocal camera = _EntityService:GetEntityByPath(\"/maps/farm/Camera\")\n\t\t\t\n\t\t\tif camera.CameraComponent.Enable then\n\t\t\t\t_CameraService:SwitchCameraTo(camera.CameraComponent)\n\t\t\tend\n\t\t\t\n\t\t\tself.Entity.CameraComponent.Enable = false\n\t\t\tcamera.CameraComponent.Enable = true\n\t\tend\n\t\t\n\t\tself.Entity.PlayerControllerComponent.Enable = false\n\t\t\n\t\tif Environment:IsMobilePlatform() then\n\t\t\tjoyStick.Enable = false\n\t\t\tjumpButton.Enable = false\n\t\tend\n\tend\n\t\n\t-- UI 숨기기 모드라면\n\tif self.IsHideUI then\n\t\tdefaultUI.Enable = false\n\telse\n\t\tdefaultUI.Enable = true\n\tend\n\t\n\tguestUI.Enable = false\n\n\t\n-- 해당 플레이어가 농장의 방문자라면 ------------------------------\nelseif role == \"guest\" then\n\tdefaultUI.Enable = false\n\tguestUI.Enable = true\n\t\n\tself.Entity.PlayerControllerComponent.Enable = true\nend\n\nLobbyGroup.Enable = false",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "ChangeStatusByRole"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "isPossibleWalk"
            }
          ],
          "Code": "-- 시간 체크 로직 ------------------------------\nlocal curTime = DateTime.UtcNow\nlocal diffTimeMs = 0\nlocal isFail = false\n\nif not isvalid(self._T.lastRequestedTime) then\n\tself._T.lastRequestedTime = DateTime.UtcNow\n\tdiffTimeMs = 1000\nelse\n\tdiffTimeMs = curTime.Elapsed - self._T.lastRequestedTime.Elapsed\nend\n\n-- 너무 빠른 속도로 재호출되었다면 -------------\nif diffTimeMs < 1000 then\n\tisFail = true\nend\n\t\nif not isFail then\n\t\n\t-- 주기적인 저장 로직 ------------------------------------------------------------------------------\n\tself.Interval_SaveTimer = self.Interval_SaveTimer + 1\n\t\n\tif self.Interval_SaveTimer >= self.Interval_SaveMaxTimer then\n\t\tself.Interval_SaveTimer = 0\n\t\tself.Interval_SaveMaxTimer = _UtilLogic:RandomIntegerRange(240,360)\n\t\tself.Entity.Save_System:Save(true)\n\tend\n\n\t\n\t-- 몬스터 조합 처리 로직 ---------------------------------------------------------------------------\n\tlocal finishedFusionFlag = false\n\t\n\t\tfor i = 1, self.Finventory_Slot_Quantity do\n\t\t\t\n\t\t\tif self.Finventory_Slot_Unlock[i] then -- 해당 슬롯을 오픈한 상태라면 ---------------\n\t\t\t\t\n\t\t\t\tif self.Finventory_Remaining_Time[i] > 0 then -- 남은 시간이 있다면 -------------\n\t\t\t\t\tself.Finventory_Remaining_Time[i] = self.Finventory_Remaining_Time[i] - 1\n\t\t\t\t\t\t\n\t\t\t\t\t-- 최초 한 번만 Toast Message를 띄우기 위함 -----------\n\t\t\t\t\tif self.Finventory_Remaining_Time[i] <= 0 then\n\t\t\t\t\t\n\t\t\t\t\t\t_LocalizationToastService:ShowMessage(\"Popup_completeFusion\", self.Entity.Name)\n\t\t\t\t\tend\n\t\t\t\t\t\n\t\t\t\telse -- 남은 시간이 없다면 ------------------------------------------------------\n\t\t\t\t\tif isvalid(self.Finventory_First_Grade[i]) and isvalid(self.Finventory_Second_Grade[i]) then\n\t\t\t\t\t\tif string.len(self.Finventory_First_Grade[i]) >= 2 and string.len(self.Finventory_Second_Grade[i]) >= 2 then\n\t\t\t\t\t\t\tfinishedFusionFlag = true\n\t\t\t\t\t\tend\n\t\t\t\t\tend\n\t\t\t\tend\n\t\t\tend\n\t\t\t\n\t\tend\n\t\n\t-- 조합 완료된 몬스터가 1개 이상이면 노티를 띄움\n\tif finishedFusionFlag then\n\t\tself.Entity.PlayerSubData.Noti_Fusion = 1 \n\telse\n\t\tself.Entity.PlayerSubData.Noti_Fusion = 0\n\tend\n\t-----------------------------------------------------------------------------------------------------\n\t\n\t\n\t-- 요리 중이면 타이머를 실행합니다. -----------------------------------------------------------------\n\tlocal kitchenTool_Generation = self.CurKitchenTool_Level\n\tlocal kitchenTool_Buff = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", kitchenTool_Generation, \"ReduceTimeBuff\")) * 0.01 \n\tlocal cookMaxTimer = _CookService.Origin_CookMaxTimer - math.floor(_CookService.Origin_CookMaxTimer * kitchenTool_Buff)\n\t\n\tif self.IsCooked then\n\t\tif self.CurPotTimer < cookMaxTimer then\n\t\t\tself.CurPotTimer = self.CurPotTimer + 1\n\t\t\t\n\t\t\tif self.CurPotTimer >= cookMaxTimer then\n\t\t\t\t_LocalizationToastService:ShowMessage(\"Popup_completeCook\", self.Entity.Name)\n\t\t\tend\n\t\t\t\n\t\t\tself.Entity.PlayerSubData.Noti_Cook = 0\n\t\telse\n\t\t\tself.Entity.PlayerSubData.Noti_Cook = 1\n\t\tend\n\telse\n\t\tself.Entity.PlayerSubData.Noti_Cook = 0\n\tend\n\t\n\t\n\t-- 플레이어 엔티티 줍기 로직 ------------------------------------------------------------------------\n\tif not isPossibleWalk then\n\t\tif not self.IsFindItem then\n\t\t\tif self.ItemTimer > 0 then\n\t\t\t\tself.ItemTimer = self.ItemTimer - 1\n\t\t\telse\n\t\t\t\t-- 플레이어 엔티티에 반영 ---------------------------------\n\t\t\t\tself.Entity.OwnerEntity:FindSettingItem(self.Entity.Name)\n\t\t\t\t\n\t\t\t\tself.IsFindItem = true\n\t\t\t\tself.ItemTimer = _UtilLogic:RandomIntegerRange(15, 30)\n\t\t\t\t\n\t\t\t\t-- 일감 ---------------------------------------------------\t\t\n\t\t\t\tif _QuestService:CheckHaveQuest(self.Entity, 6) then -- 아이템 발견 10회 [일감]\n\t\t\t\t\tself.Entity.PlayerSubData.FindItemCount = self.Entity.PlayerSubData.FindItemCount + 1\n\t\t\t\tend\n\t\t\t\t\n\t\t\tend\n\t\tend\n\tend\nend\n\nself._T.lastRequestedTime = DateTime.UtcNow",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "AlwaysSyncData"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
