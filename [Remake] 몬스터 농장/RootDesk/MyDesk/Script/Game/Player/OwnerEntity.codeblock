          "Name": "FindEmotion"
        },
        {
          "Type": "Component",
          "DefaultValue": "cf0fe12f-db97-4a6d-b975-ebdff5e64181:MapInfo",
          "SyncDirection": 0,
          "Attributes": [],
          "Name": "MapInfo"
        },
        {
          "Type": "number",
          "DefaultValue": "0",
          "SyncDirection": 0,
          "Attributes": [],
          "Name": "LayerRefreshTime"
        },
        {
