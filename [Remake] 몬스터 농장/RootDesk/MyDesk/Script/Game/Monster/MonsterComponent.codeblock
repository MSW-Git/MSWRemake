            }
          ],
          "Code": "-- 몬스터의 ID를 인벤토리에서 찾아서 갱신합니다. ---------------------------\nlocal MinventoryId = player.PlayerData.Minventory_Entity[self.MonsterIDX]\n\nif not isvalid(MinventoryId) or self.Entity.Id ~= MinventoryId then\n\tfor i = 1, #player.PlayerData.Minventory_Id do\n\t\tif self.Entity.Id == player.PlayerData.Minventory_Entity[i] then\n\t\t\tself.MonsterIDX = i\n\t\t\tbreak\n\t\tend\n\tend\nend\n\n\n-- 이 몬스터가 딸기 / 루비를 생산하는 몬스터인지 설정합니다. ---------------\nlocal monGeneration = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[self.MonsterIDX], \"generation\"))\n\nif self.Generation ~= monGeneration then\n\tif monGeneration >= 2 then\n\t\tself.IsPossibleBerry = true\n\telse\n\t\tself.IsPossibleBerry = false\n\tend\n\t\n\tif monGeneration >= 3 then\n\t\tself.IsPossibleRuby = true\n\telse\n\t\tself.IsPossibleRuby = false\n\tend\n\tself.Generation = monGeneration\nend\n\n\n-- 몬스터의 등급에 따라 스케일을 갱신합니다. --------------------------------\nif self.Grade ~= player.PlayerData.Minventory_Grade[self.MonsterIDX] then\n\tself:EntityScaleSetting(player.PlayerData.Minventory_Grade[self.MonsterIDX])\n\tself:Give_Stat_ByGrade(player, player.PlayerData.Minventory_Grade[self.MonsterIDX])\n\tself.Grade = player.PlayerData.Minventory_Grade[self.MonsterIDX] \nend\n\nif self.Skill_ID ~= player.PlayerData.Minventory_Skill_Id[self.MonsterIDX] then\n\tself:Give_Stat_BySkill(player, player.PlayerData.Minventory_Skill_Id[self.MonsterIDX], self.MonsterIDX)\n\tself.Skill_ID = player.PlayerData.Minventory_Skill_Id[self.MonsterIDX]  \nend\n\n-- 몬스터 생산량 적용 --\nlocal level = player.PlayerData.Minventory_Level[self.MonsterIDX]\nlocal grade = player.PlayerData.Minventory_Grade[self.MonsterIDX]\n\nif not isvalid(level) or not isvalid(grade) then\n\treturn\nend\nself.Gold_Quantity = self:Get_Money_By_Type(level, grade, monGeneration)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "EntityMonsterInfoSetting"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 해당 몬스터가 도우미 추적 상태인지 확인합니다. --------------------------\n\nlocal helpers = _EntityService:GetEntitiesByTag(\"Helper\")\n\nfor i =1, #helpers do\n\tif helpers[i].HelperEntity.TargetEntity == self.Entity then\n\t\tself.IsHelperTarget = true\n\t\t\n\t\t-- 제자리에 멈춰있게 설정 --\n\t\tself.MoveTimer = 0\n\t\tself.isReachedDestination = true\n\t\t----------------------------\n\t\treturn\n\tend\nend\n\nself.IsHelperTarget = false",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "CheckIsHelperMonster"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "isOutOfRange"
            },
            {
              "Type": "Vector2",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "targetPos"
            },
            {
              "Type": "Vector3",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "myPos"
            }
          ],
          "Code": "if not isOutOfRange then -- 농장 안이라면 --------------------\n\tself.Entity.TransformComponent.WorldPosition = Vector3(targetPos.x, targetPos.y, 0)\n\t\nelse -- 농장 밖으로 나간 상태라면 ----------------------------\n\tlocal target_x = self.Entity.TransformComponent.Position.x\n\tlocal target_y = self.Entity.TransformComponent.Position.y\n\t\t\t\n\t\n\tif myPos.x <= _PlayerService.Range_X.x then\n\t\ttarget_x = _PlayerService.Range_X.x\n\n\telseif myPos.x >= _PlayerService.Range_X.y then\n\t\ttarget_x = _PlayerService.Range_X.y\n\tend\n\t\t\t\n\tif myPos.y <= _PlayerService.Range_Y.x then\n\t\ttarget_y = _PlayerService.Range_Y.x\n\t\t\n\telseif myPos.y >= _PlayerService.Range_Y.y then\n\t\ttarget_y = _PlayerService.Range_Y.y\n\n\tend\n\t\t\t\n\tself.Entity.TransformComponent.WorldPosition = Vector3(target_x, target_y, 0)\n\nend\n\nself:EntityLayerSetting()",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "EntityDragDrop"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "isPossibleRuby"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "isPossibleBerry"
            }
          ],
          "Code": "-- 골드 외에 부산물 획득 여부를 확인합니다. -------------\nif not isvalid(player.PlayerData.Minventory_Id[idx]) then\n\treturn\nend\n\nlocal rubyChancePercent = 0\nlocal berryChancePercent = 0\nlocal itemChancePercent = 0\n\nif isPossibleRuby then\n\t\n\tlocal skillBonus = 0\n\t\n\tif player.PlayerData.Minventory_Skill_Id[idx] == 3 then\n\t\tif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_1_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_1_Effect\n\t\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_2_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_2_Effect\n\t\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_3_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_3_Effect\n\t\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_4_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_4_Effect\n\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_5_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_5_Effect\n\t\tend\n\tend\n\n\t----------------------------------------------------------------------------------------------------\n\t-- 루비 생산 확률 공식 --\n\tlocal origin_Ruby_Chance = _MonsterService.Origin_Ruby_Chance \n\tlocal skill_Ruby_Chance = _MonsterService.Origin_Ruby_Chance * (self.Skill_Ruby_Chance_Buff * (skillBonus * 0.01))\n\t\n\trubyChancePercent = origin_Ruby_Chance + skill_Ruby_Chance\n\t----------------------------------------------------------------------------------------------------\n\t\nend\n\nif isPossibleBerry then\n\t\n\tlocal skillBonus = 0\n\t\n\tif player.PlayerData.Minventory_Skill_Id[idx] == 1 then\n\t\tif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_1_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_1_Effect\n\t\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_2_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_2_Effect\n\t\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_3_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_3_Effect\n\t\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_4_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_4_Effect\n\t\t\n\t\telseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_5_Name then\n\t\t\tskillBonus = _MonsterService.Skill_Grade_5_Effect\n\t\tend\n\tend\n\n\t----------------------------------------------------------------------------------------------------\n\t-- 베리 생산 확률 공식 --\n\tlocal origin_Berry_Chance = _MonsterService.Origin_Berry_Chance -- 20 \n\tlocal skill_Berry_Chance = _MonsterService.Origin_Berry_Chance * (self.Skill_Berry_Chance_Buff * (skillBonus * 0.01))\n\tberryChancePercent = origin_Berry_Chance + skill_Berry_Chance\n\n\t----------------------------------------------------------------------------------------------------\n\t\nend\n\n----------------------------------------------------------------------------------------------------\n-- 생산품 확률 공식 --\nlocal origin_Item_Chance = _MonsterService.Origin_Item_Chance \nlocal grade_Item_Chance = _MonsterService.Origin_Item_Chance * (self.Grade_Item_Chance_Buff * 0.01)\nitemChancePercent = origin_Item_Chance + grade_Item_Chance\n----------------------------------------------------------------------------------------------------\n\nlocal ruby_Rand_Number = _UtilLogic:RandomIntegerRange(1, 100)\nlocal berry_Rand_Number = _UtilLogic:RandomIntegerRange(1, 100)\nlocal item_Rand_Number = _UtilLogic:RandomIntegerRange(1, 100)\nlocal ingredient_Rand_Number = _UtilLogic:RandomIntegerRange(1, 100)\n\nif ruby_Rand_Number <= rubyChancePercent then -- 루비 당첨\n\ttable.insert(self.ProductsToGet, \"ruby\")\nend\n\nif berry_Rand_Number <= berryChancePercent then -- 베리 당첨\n\ttable.insert(self.ProductsToGet, \"berry\")\nend\n\nif item_Rand_Number <= itemChancePercent then -- 부산물 당첨\n\ttable.insert(self.ProductsToGet, \"item\")\nend\n\nif ingredient_Rand_Number <= _MonsterService.Origin_Ingredient_Chance then -- 요리 재료 당첨\n\ttable.insert(self.ProductsToGet, \"ingredient\")\n\t\n\tlocal monsterGeneration = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"generation\"))\n\t\n\t-- 해당 몬스터 세대에 해당하는 요리 재료를 무작위로 하나 리턴합니다. ---------------------------\n\tlocal ingredientTable = {}\n\tlocal dataSetName = \"CookDataSet_Ingredient_By_Generation\"\n\t\n\tfor i = 1, _DataService:GetRowCount(dataSetName) do\n\t\tlocal itemGeneration = tonumber(_DataService:GetCell(dataSetName, i, \"generation\"))\n\t\t\n\t\tif itemGeneration == monsterGeneration then\n\t\t\ttable.insert(ingredientTable, tonumber(_DataService:GetCell(dataSetName, i, \"itemID\")))\n\t\tend\n\t\t\n\t\tif itemGeneration > monsterGeneration then\n\t\t\tbreak\n\t\tend\n\n\tend\n\t\n\tlocal randNumber = _UtilLogic:RandomIntegerRange(1, #ingredientTable)\n\tself.Temp_Getting_Ingredient_ID = ingredientTable[randNumber]\nend\n-- 획득한 아이템 이미지를 띄웁니다. --\nlocal Ui_Mark = _EntityService:GetEntityByPath(self.Entity.Path..\"/UI_Balloon/UI_Mark\")\nlocal Ui_Item = _EntityService:GetEntityByPath(self.Entity.Path..\"/UI_Balloon/UI_Item\")\n\nif #self.ProductsToGet > 1 then -- 여러 부산물을 동시 획득했다면\n\tself.Entity.MonsterComponent.IsFinished = true\n\tUi_Item.SpriteRendererComponent.SpriteRUID = \"a31c2f185efa42b892e9f2078b2e3617\"\n\tUi_Mark.SpriteRendererComponent.SpriteRUID = _MonsterService.Miracle_Balloon_RUID\n\t\t\nelseif #self.ProductsToGet == 1 then\n\tself.Entity.MonsterComponent.IsFinished = true\n\t\n\tif self.ProductsToGet[1] == \"item\" then\n\t\tlocal itemID = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"product\")) - 20000\n\t\tUi_Item.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(\"ItemDataSet_Base\", itemID, \"ruid\")\n\t\tUi_Mark.SpriteRendererComponent.SpriteRUID = \"48abe6cf3f764877a5f57d93972069d6\" \n\t\t\n\telseif self.ProductsToGet[1] == \"ruby\" then\n\t\tUi_Item.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(\"ItemDataSet_Base\", _PlayerService.Ruby_ID - 20000, \"ruid\")\n\t\tUi_Mark.SpriteRendererComponent.SpriteRUID = _MonsterService.Money_Balloon_RUID\n\t\t\n\telseif self.ProductsToGet[1] == \"berry\" then\n\t\tUi_Item.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(\"ItemDataSet_Base\", _PlayerService.Berry_ID - 20000, \"ruid\")\t\n\tUi_Mark.SpriteRendererComponent.SpriteRUID = _MonsterService.Money_Balloon_RUID\n\t\t\n\telseif self.ProductsToGet[1] == \"ingredient\" then\n\t\tUi_Item.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(\"ItemDataSet_Base\", self.Temp_Getting_Ingredient_ID - 20000, \"ruid\")\n\t\tUi_Mark.SpriteRendererComponent.SpriteRUID = _MonsterService.Ingredient_Balloon_RUID\n\t\t\n\tend\n\nelseif #self.ProductsToGet == 0 then\n\tplayer.PlayerData.Minventory_Time[idx] = 0 \nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "SetProduct"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
