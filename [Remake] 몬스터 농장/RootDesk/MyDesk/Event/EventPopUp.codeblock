        {
          "Type": "Entity",
          "DefaultValue": "f295ddbe-b85b-480b-a213-507ba4d5f44c",
          "SyncDirection": 0,
          "Attributes": [],
          "Name": "UI_Event"
        },
        {
          "Type": "Component",
          "DefaultValue": "7edd0e5a-4a3d-412e-85d7-21a9f24d5668:UITransformComponent",
