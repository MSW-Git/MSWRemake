              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "itemID"
            }
          ],
          "Code": "-- 요리 아이템의 이름을 보여줍니다. -----------\nlocal player = _UserService.LocalPlayer\nlocal itemDataSet = _DataService:GetTable(\"ItemDataSet_Base\")\n_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText(itemDataSet:GetCell(itemID - 20000, \"name\")))",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "ShowItemName"
        }
