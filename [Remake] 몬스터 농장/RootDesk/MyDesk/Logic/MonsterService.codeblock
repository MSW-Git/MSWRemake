              "SyncDirection": 0,
              "Attributes": [],
              "Name": "prev"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "next"
            }
          ],
          "Code": "----------------------------------------------------------------------------------------------------\nif not isvalid(type) or not isvalid(idx) or not isvalid(prev) or not isvalid(next) then\n\treturn\nend\n\n\nlocal player = _UserService.LocalPlayer\nlocal monsterName = \"<color=#aaf5f4>\".._LocalizationService.LocalTranslator:GetText(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"name\"))..\"</color>\"\nlocal text_Progress = _EntityService:GetEntityByPath(\"/ui/MonsterGroup/UI_Monster_Left/UI_Lab/Text_Progress\")\n\nlocal dataSetName = \"LabDataSet_Script\"\nlocal dataSet_Length = _DataService:GetRowCount(dataSetName)\nlocal randIDX = _UtilLogic:RandomIntegerRange(1, dataSet_Length)\n\n-- 플레이버 텍스트를 생성합니다. -------------------------------------------------------------------\nlocal selectedText = \"-  \".._LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell(dataSetName, randIDX, \"script\"), monsterName)..\"\\n\"\n\nif type == \"Grade\" then\n\tlocal prevColor = \"\"\n\tlocal nextColor = \"\"\n\t\n\tif prev == 0 then\n\t\tprev = self.Grade_0_Name\n\t\tprevColor = self.Grade_0_Color\n\telseif prev == 1 then\n\t\tprev = self.Grade_1_Name\n\t\tprevColor = self.Grade_1_Color\n\telseif prev == 2 then\n\t\tprev = self.Grade_2_Name\n\t\tprevColor = self.Grade_2_Color\n\telseif prev == 3 then\n\t\tprev = self.Grade_3_Name\n\t\tprevColor = self.Grade_3_Color\n\telseif prev == 4 then\n\t\tprev = self.Grade_4_Name\n\t\tprevColor = self.Grade_4_Color\n\telseif prev == 5 then\n\t\tprev = self.Grade_5_Name\n\t\tprevColor = self.Grade_5_Color\n\tend\n\t\n\tif next== 0 then\n\t\tnext = self.Grade_0_Name\n\t\tnextColor = self.Grade_0_Color\n\telseif next == 1 then\n\t\tnext = self.Grade_1_Name\n\t\tnextColor = self.Grade_1_Color\n\telseif next == 2 then\n\t\tnext = self.Grade_2_Name\n\t\tnextColor = self.Grade_2_Color\n\telseif next == 3 then\n\t\tnext = self.Grade_3_Name\n\t\tnextColor = self.Grade_3_Color\n\telseif next == 4 then\n\t\tnext = self.Grade_4_Name\n\t\tnextColor = self.Grade_4_Color\n\telseif next == 5 then\n\t\tnext = self.Grade_5_Name\n\t\tnextColor = self.Grade_5_Color\n\tend\n\t\n\tlocal curGrade = next\n\tprev = \"<color=\"..prevColor..\">'\".._LocalizationService.LocalTranslator:GetText(prev)..\"'</color>\"\n\tnext = \"<color=\"..nextColor..\">'\".._LocalizationService.LocalTranslator:GetText(next)..\"'</color>\"\n\t\n\tif success then\n\t\tlocal result = \"-  \".._LocalizationService.LocalTranslator:GetTextFormat(\"Lab_gradeUp\", monsterName, prev, next)\n\t\ttext_Progress.TextComponent.Text = selectedText..result\n\telse\n\t\tif curGrade ~= self.Grade_0_Name then\n\t\t\tlocal result = \"-  \".._LocalizationService.LocalTranslator:GetTextFormat(\"Lab_gradeDown\", monsterName, prev, next)\n\t\t\ttext_Progress.TextComponent.Text = selectedText..result\n\t\telse\n\t\t\tlocal result = \"-  \".._LocalizationService.LocalTranslator:GetText(\"Lab_gradeNone\")\n\t\t\ttext_Progress.TextComponent.Text = selectedText..result\n\t\tend\n\tend\n\t\nelseif type == \"Personality\" then\n\tlocal prevColor = \"\"\n\tlocal nextColor = \"\"\n\tif prev == 0 then\n\t\tprev = self.Personality_0_Name\n\t\tprevColor = self.Personality_0_Color\n\telseif prev == 1 then\n\t\tprev = self.Personality_1_Name\n\t\tprevColor = self.Personality_1_Color\n\telseif prev == 2 then\n\t\tprev = self.Personality_2_Name\n\t\tprevColor = self.Personality_2_Color\n\telseif prev == 3 then\n\t\tprev = self.Personality_3_Name\n\t\tprevColor = self.Personality_3_Color\n\telseif prev == 4 then\n\t\tprev = self.Personality_4_Name\n\t\tprevColor = self.Personality_4_Color\n\telseif prev == 5 then\n\t\tprev = self.Personality_5_Name\n\t\tprevColor = self.Personality_5_Color\n\telseif prev == 6 then\n\t\tprev = self.Personality_6_Name\n\t\tprevColor = self.Personality_6_Color\n\tend\n\t\n\tif next== 0 then\n\t\tnext = self.Personality_0_Name\n\t\tnextColor = self.Personality_0_Color\n\telseif next == 1 then\n\t\tnext = self.Personality_1_Name\n\t\tnextColor = self.Personality_1_Color\n\telseif next == 2 then\n\t\tnext = self.Personality_2_Name\n\t\tnextColor = self.Personality_2_Color\n\telseif next == 3 then\n\t\tnext = self.Personality_3_Name\n\t\tnextColor = self.Personality_3_Color\n\telseif next == 4 then\n\t\tnext = self.Personality_4_Name\n\t\tnextColor = self.Personality_4_Color\n\telseif next == 5 then\n\t\tnext = self.Personality_5_Name\n\t\tnextColor = self.Personality_5_Color\n\telseif next == 6 then\n\t\tnext = self.Personality_6_Name\n\t\tnextColor = self.Personality_6_Color\n\tend\n\t\n\tprev = \"<color=\"..prevColor..\">'\".._LocalizationService.LocalTranslator:GetText(prev)..\"'</color>\"\n\tnext = \"<color=\"..nextColor..\">'\".._LocalizationService.LocalTranslator:GetText(next)..\"'</color>\"\n\t\n\tlocal result = \"-  \".._LocalizationService.LocalTranslator:GetTextFormat(\"Lab_personalityChange\", monsterName, prev, next)\n\ttext_Progress.TextComponent.Text = selectedText..result\n\t\nelseif type == \"Skill\" then\n\t\n\tlocal prevColor = \"\"\n\tlocal nextColor = \"\"\n\n\tif prev == 1 then\n\t\tprev = self.Skill_1_Name\n\telseif prev == 2 then\n\t\tprev = self.Skill_2_Name\n\telseif prev == 3 then\n\t\tprev = self.Skill_3_Name\n\telseif prev == 4 then\n\t\tprev = self.Skill_4_Name\n\telseif prev == 5 then\n\t\tprev = self.Skill_5_Name\n\tend\n\t\n\tif next == 1 then\n\t\tnext = self.Skill_1_Name\n\telseif next == 2 then\n\t\tnext = self.Skill_2_Name\n\telseif next == 3 then\n\t\tnext = self.Skill_3_Name\n\telseif next == 4 then\n\t\tnext = self.Skill_4_Name\n\telseif next == 5 then\n\t\tnext = self.Skill_5_Name\n\tend\n\t\n\tprev = \"<color=#aaf5f4>'\".._LocalizationService.LocalTranslator:GetText(prev)..\"'</color>\"\n\tnext = \"<color=#aaf5f4>'\".._LocalizationService.LocalTranslator:GetText(next)..\"'</color>\"\n\t\n\tlocal result = \"-  \".._LocalizationService.LocalTranslator:GetTextFormat(\"Lab_skillChange\", monsterName, prev, next)\n\ttext_Progress.TextComponent.Text = selectedText..result\nend",
