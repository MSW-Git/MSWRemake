            }
          ],
          "Code": "local generation = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"generation\"))\n\nlocal dataSetName_Personality = \"LabDataSet_Personality\"\n\nlocal quantity = tonumber(_DataService:GetCell(dataSetName_Personality, generation, \"Quantity\"))\nlocal itemID = tonumber(_DataService:GetCell(dataSetName_Personality, generation, \"ID\"))\n\n-- 재화 소모 --------------------------------\nif itemID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= quantity then\n\t\t_PlayerService:GetGold(player, -quantity)\n\t\t_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -quantity, nil, nil, nil, player.Name)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\n\t\nelseif itemID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= quantity then\n\t\t_PlayerService:GetBerry(player, -quantity)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\n\t\nelseif itemID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= quantity then\n\t\t_PlayerService:GetRuby(player, 1, -quantity)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\nend\n\n-- 성격의 종류는 여섯 가지입니다. -----------\nlocal personality_Table = {1, 2, 3, 4, 5, 6}\n\n\n-- 동일한 성격으로 바뀌지 않게 합니다. ------\ntable.remove(personality_Table, player.PlayerData.Minventory_Personality[idx])\n\n\n-- 현재 성격, 바뀔 성격을 받아옵니다. -------\nlocal randNumber = _UtilLogic:RandomIntegerRange(1, #personality_Table)\nlocal curPersonality = player.PlayerData.Minventory_Personality[idx]\nlocal nextPersonality = personality_Table[randNumber] \n\n\n-- 성격을 바꿉니다. -------------------------\nplayer.PlayerData.Minventory_Personality[idx] = nextPersonality\n\n\n-- 플레이버 텍스트를 띄웁니다. --------------\nself:Refresh_Lab_Progress_Text(\"Personality\", idx, true, curPersonality, nextPersonality, player.Name)\n\n\n-- 통신을 끝냅니다. ================\n_TransferService:Transfer(\"out\")\n--==================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "Change_MonsterPersonality"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "type"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "success"
            },
            {
              "Type": "number",
