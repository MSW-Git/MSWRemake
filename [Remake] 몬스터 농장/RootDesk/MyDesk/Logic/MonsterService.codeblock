      "Methods": [
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": null,
          "Code": "local eventDataSet = _DataService:GetTable(\"EventDataSet\")\n\nfor i = 1, eventDataSet:GetRowCount() do\n\tlocal tt = eventDataSet:GetCell(i, \"EventType\")\n\tif isvalid(tt) and tt ~= \"\" and tt ~= \" \" then\n\t\ttable.insert(self.Event, i)\n\tend\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "OnBeginPlay"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "firstOpenSummon"
            },
            {
              "Type": "Vector3",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "savedPosition"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "invSummon"
            }
          ],
          "Code": "-- 몬스터 더미에 데이터 넣기 --\nlocal dataSetName = \"MonsterDataSet_Base\"\nlocal uiDataSetName = \"MonsterDataSet_UI\"\nlocal itemDataSetName = \"ItemDataSet_Base\"\n\t\nlocal monsterItemID = 0\nlocal dummy_monster = _EntityService:GetEntityByPath(\"/maps/farm/dummy_monster\")\nlocal monster = dummy_monster\n\n-- 플레이어가 선택한 펫을 필드 위에 소환 --\n\nif firstOpenSummon then\n\tmonster = dummy_monster:Clone(\"monster\"..tostring(player.PlayerData.MonsterIDX))\n\tmonster.TransformComponent.Position = savedPosition\nelse\n\tif not player.PlayerData.Minventory_Summoned[idx] then\n\t\tmonster = dummy_monster:Clone(\"monster\"..tostring(player.PlayerData.MonsterIDX))\n\t\tlocal randPos = Vector3(math.random(-280,200) / 100, math.random(100, 260) / 100, 0)\n\t\t\n\t\tmonster.TransformComponent.Position = randPos\n\n\t\tplayer.PlayerData.Minventory_Summoned[idx] = true\n\telse\n\t\tif isvalid(invSummon) and invSummon then\n\t\t\t-- 통신 종료 ================================\n\t\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t\t-- ==========================================\n\t\tend\n\t\treturn\n\tend\nend\n\t\t\nplayer.PlayerData.MonsterIDX = player.PlayerData.MonsterIDX + 1\n\n\nmonster.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[idx], \"ruid\")\nmonsterItemID = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[idx], \"product\")) - 20000\n\nlocal item_ballon = _EntityService:GetEntityByPath(monster.Path..\"/UI_Balloon\")\nlocal shadow = _EntityService:GetEntityByPath(monster.Path..\"/shadow\")\nlocal body = _EntityService:GetEntityByPath(monster.Path..\"/body\")\n\t\t\nlocal item_x = 0\nlocal item_y = tonumber(_DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"item_ui_y\"))\nlocal shadow_x = 0\nlocal shadow_y = 0.01\nlocal shadow_xscale = tonumber(_DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"shadow_x_scale\"))\nlocal shadow_yscale = tonumber(_DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"shadow_y_scale\")) \n\t\t\t\t\nmonster.MonsterComponent.GapYPos = item_y\nmonster.MonsterComponent.IdleMotion = _DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"idle_ruid\")\nbody.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"idle_ruid\")\n\t\t\nmonster.SpriteRendererComponent.SpriteRUID = _DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"idle_ruid\")\nmonster.MonsterComponent.WalkMotion = _DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[idx], \"walk_ruid\")\nmonster.ChatBalloonComponent.Offset = -14 + (item_y * 10)\nitem_ballon.TransformComponent.Position = Vector3(item_x, item_y, 0)\nshadow.TransformComponent.Position = Vector3(shadow_x, shadow_y, 0)\nshadow.TransformComponent.Scale = Vector3(shadow_xscale, shadow_yscale, 1)\n\n\t\n-- 몬스터의 좌표 저장을 위함 --\nplayer.PlayerData.Minventory_Entity[idx] = monster.Id \nplayer.PlayerData.Minventory_Time[idx] = math.random(1, self.Origin_Product_Time - 1)\nmonster.MonsterComponent.OwnerId = player.Name\nmonster.MonsterComponent.CurTargetY_Pos = monster.TransformComponent.Position.y\n\nif isvalid(invSummon) then\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", player.Name)\n\t-- ==========================================\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "SummonMonster"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "for i = 1, #player.PlayerData.Minventory_Id do\n\tif player.PlayerData.Minventory_Summoned[i] then\n\t\tlocal randX = math.random(_PlayerService.Range_X.x * 100, _PlayerService.Range_X.y * 100) * 0.01\n\t\tlocal randY = math.random(_PlayerService.Range_Y.x * 100, _PlayerService.Range_Y.y * 100) * 0.01\n\t\tself:SummonMonster(player, i, true, Vector3(randX, randY,0), nil)\n\tend\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "SummonMonsterByLoad"
        },
