          ],
          "Code": "-- sort한 테이블을 서버에다 저장 --\nfor i = 1, #exp do\n\tplayer.PlayerData.Minventory_Exp[i] = exp[i]\n\tplayer.PlayerData.Minventory_Mexp[i] = mexp[i]\n\tplayer.PlayerData.Minventory_Grade[i] = grade[i]\n\tplayer.PlayerData.Minventory_Level[i] = lv[i]\n\tplayer.PlayerData.Minventory_Time[i] = time[i]\n\tplayer.PlayerData.Minventory_Id[i] = id[i]\n\tplayer.PlayerData.Minventory_Entity[i] = ent[i]\n\tplayer.PlayerData.Minventory_Summoned[i] = summoned[i]\n\tplayer.PlayerData.Minventory_UniqueID[i] = uniqueID[i]\n\tplayer.PlayerData.Minventory_Personality[i] = personality[i]\n\tplayer.PlayerData.Minventory_Skill_Id[i] = skill_id[i]\nend\n\t\n-- 마스코트를 재부여 합니다. -----------------------\nfor x = 1, #player.PlayerData.Minventory_UniqueID do\n\tif player.PlayerData.Minventory_UniqueID[x] == mascotMonster_UniqueID then\n\t\t\t_MascotService:SetMascot(player, x, false, false)\n\t\tbreak\n\tend\nend\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "RefreshMonsterTable"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "itemID"
            }
          ],
          "Code": "-- 필드 위에 소환된 몬스터에게만 요리를 먹입니다. ------------------\nlocal cookPoint =  tonumber(_DataService:GetCell(\"ItemDataSet_Base\", itemID - 20000, \"point\"))\nlocal summonedMonsters_IDX = {}\n\n\n-- 소환된 몬스터로만 테이블을 만듭니다. -----------------------------------\nfor i = 1, #player.PlayerData.Minventory_Id do\n\tif player.PlayerData.Minventory_Summoned[i] then\n\t\ttable.insert(summonedMonsters_IDX, i)\n\tend\nend\n\n-- 소환된 몬스터에게만 경험치를 제공합니다. -------------------------------\nfor i =1, #summonedMonsters_IDX do\n\tlocal monster_EXP = player.PlayerData.Minventory_Exp[summonedMonsters_IDX[i]]\n\tlocal monster_MEXP = player.PlayerData.Minventory_Mexp[summonedMonsters_IDX[i]]\n\t\n\tif isvalid(monster_EXP) then\n\t\tplayer.PlayerData.Minventory_Exp[summonedMonsters_IDX[i]] = monster_EXP + cookPoint\n\t\t\n\t\tmonster_EXP = player.PlayerData.Minventory_Exp[summonedMonsters_IDX[i]] \n\t\t\n\t\t-- 경험치가 최대 경험치를 넘었다면 레벨업 함수를 실행합니다. -----\n\t\tif monster_EXP >= monster_MEXP then\n\t\t\t_MonsterService:LevelUpMonster(player, summonedMonsters_IDX[i])\n\t\tend\n\tend\nend\n\n_LocalizationToastService:ShowMessage(\"Popup_feedMonster\", player.Name)\n\n--서브 퀘스트: 몬스터에게 요리 먹이기 -------------------------------\nplayer.PlayerSubData.GetFeedCount = player.PlayerSubData.GetFeedCount + 1 \n\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "FeedMonster"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "i"
            }
          ],
          "Code": "\n-------------------------------------------------------------\n-- *** 레벨업 시 최대 경험치 증가량 공식 ***\n-------------------------------------------------------------\nlocal monster_Generation = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[i], \"generation\"))\nlocal MEXP = self.Origin_Monster_Mexp * (self.Origin_Monster_Mexp_Up_Multiple ^ (monster_Generation - 1))\n\nlocal plusMEXP = MEXP * (self.Origin_Monster_Mexp_Up_Ratio * 0.01)\n\n-- 여러 번 레벨 업 할 경우 한번만 스킬 이펙트를 적용 --------\nlocal levelUp = false\n\n-- 만렙이 아니라면 ------------------------------------------\nif player.PlayerData.Minventory_Level[i] < self.MonsterMaxLevel and player.PlayerData.Minventory_Exp[i] >= player.PlayerData.Minventory_Mexp[i] then\n\tplayer.PlayerData.Minventory_Exp[i] = math.abs(player.PlayerData.Minventory_Exp[i] - player.PlayerData.Minventory_Mexp[i])\n\tplayer.PlayerData.Minventory_Mexp[i] = player.PlayerData.Minventory_Mexp[i] + plusMEXP\n\tplayer.PlayerData.Minventory_Level[i] = player.PlayerData.Minventory_Level[i] + 1\n\tlevelUp = true\nend\n\n-- 재 레벨업을 한다면 ---------------------------------------\nif  player.PlayerData.Minventory_Level[i] < self.MonsterMaxLevel and player.PlayerData.Minventory_Exp[i] >= player.PlayerData.Minventory_Mexp[i] then\n\tlevelUp = false\n\tself:LevelUpMonster(player, i)\nend\n\n-- 소환된 상태일 경우에만 이펙트 소환 -----------------------\nif levelUp then\n\tif player.PlayerData.Minventory_Summoned[i] then\n\t\t_SoundService:PlaySound(\"549a743c68494fe1854ef6d60acb6950\", 0.75, player.Name)\n\t\t_EffectService:PlayEffectAttached(\"17faf2101c2b4b8581fd3ede1a1b898b\", _EntityService:GetEntity(player.PlayerData.Minventory_Entity[i]), Vector3(0, 0, 0), 0, Vector3(1, 1, 1), false)\n\tend\nend\n",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "LevelUpMonster"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "num"
            }
          ],
          "Code": "-- 몬스터 소환 수를 늘립니다.\nplayer.PlayerData.MaxSummon = player.PlayerData.MaxSummon + num",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "SummonSpaceUp"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            }
          ],
          "Code": "local generation = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"generation\"))\n\nlocal dataSetName_Skill = \"LabDataSet_Skill\"\n\nlocal quantity = tonumber(_DataService:GetCell(dataSetName_Skill, generation, \"Quantity\"))\nlocal itemID = tonumber(_DataService:GetCell(dataSetName_Skill, generation, \"ID\"))\n\n\n--===============================================================\n-- 몬스터의 스킬을 무작위로 변경합니다.\n--===============================================================\n\n\n-- 재화 소모 ----------------------------------------------------\nif itemID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= quantity then\n\t\t_PlayerService:GetGold(player, -quantity)\n\t\t_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -quantity, nil, nil, nil, player.Name)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\n\t\nelseif itemID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= quantity then\n\t\t_PlayerService:GetBerry(player, -quantity)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\n\t\nelseif itemID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= quantity then\n\t\t_PlayerService:GetRuby(player, 1, -quantity)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\nend\n-----------------------------------------------------------------\n\n--매안 퀘스트:17 연구소 스킬 시도-----------------------------------------------------------------\nplayer.PlayerSubData.GetLabSkillCount = player.PlayerSubData.GetLabSkillCount + 1\n\n\n\n-- 스킬의 종류는 다섯 개 입니다. --------------------------------\nlocal skill_Table = {1, 2, 3, 4, 5}\n\n\n-- 현재 스킬을 빼서 동일한 스킬이 나오지 않게 합니다. -----------\ntable.remove(skill_Table, player.PlayerData.Minventory_Skill_Id[idx])\n\nlocal randNumber = _UtilLogic:RandomIntegerRange(1, #skill_Table)\n\n\n-- 현재 스킬, 바뀔 스킬 정보를 받아옵니다. ----------------------\nlocal curSkillNumber = player.PlayerData.Minventory_Skill_Id[idx] \nlocal nextSkillNumber = skill_Table[randNumber]\n\nplayer.PlayerData.Minventory_Skill_Id[idx] = nextSkillNumber\n\n-- 서브 퀘스트 조건: 스킬 획득하기 - 루비 생산 확률 스킬  --------------------------------\nif nextSkillNumber == 3 then \n\t\n\tif _QuestService:CheckHaveQuest(player,26) then \n\t\tplayer.PlayerSubData.GetSkillChange = player.PlayerSubData.GetSkillChange + 1 \n\tend\n\t\nend\n\n-- 플레이버 텍스트를 갱신합니다. --------------------------------\nself:Refresh_Lab_Progress_Text(\"Skill\", idx, true, curSkillNumber, nextSkillNumber, player.Name)\n\n\n-- 통신을 끝냅니다. ================\n_TransferService:Transfer(\"out\")\n--==================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "Change_MonsterSkill"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            }
          ],
          "Code": "local generation = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"generation\"))\n\nlocal dataSetName_Grade = \"LabDataSet_Grade\"\n\nlocal quantity = tonumber(_DataService:GetCell(dataSetName_Grade, generation, \"Quantity\"))\nlocal itemID = tonumber(_DataService:GetCell(dataSetName_Grade, generation, \"ID\"))\n\n-- 재화 소모 --------------------------------\nif itemID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= quantity then\n\t\t_PlayerService:GetGold(player, -quantity)\n\t\t_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -quantity, nil, nil, nil, player.Name)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\n\t\nelseif itemID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= quantity then\n\t\t_PlayerService:GetBerry(player, -quantity)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\n\t\nelseif itemID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= quantity then\n\t\t_PlayerService:GetRuby(player, 1, -quantity)\n\telse\n\t\t-- 통신을 끝냅니다. ================\n\t\t_TransferService:Transfer(\"out\")\n\t\t--==================================\n\t\treturn\n\tend\nend\n\n\nlocal dataSetName = \"LabDataSet_Grade_Percent\" \nlocal grade = player.PlayerData.Minventory_Grade[idx] \nlocal gradeNumber = 0\n\n-- 몬스터의 등급을 번호로 바꿉니다. -------------\nif grade == self.Grade_0_Name then\n\tgradeNumber = 0\n\t\nelseif grade == self.Grade_1_Name then\n\tgradeNumber = 1\n\t\nelseif grade == self.Grade_2_Name then\n\tgradeNumber = 2\n\t\nelseif grade == self.Grade_3_Name then\n\tgradeNumber = 3\n\t\nelseif grade == self.Grade_4_Name then\n\tgradeNumber = 4\n\t\nelseif grade == self.Grade_5_Name then\n\tgradeNumber = 5\nend\n\n-- 성공 확률을 의미합니다. ----------------------\nlocal origin_Percent = _UtilLogic:RandomIntegerRange(1, 100)\nlocal grade_Percent = 0\n\nlocal curGradeNumber = gradeNumber\n\n-- 마지막 등급일 때는 등급을 변경할 수 없습니다.-\nif gradeNumber <= 4 then\n\tgrade_Percent = tonumber(_DataService:GetCell(dataSetName, gradeNumber + 1, \"percent\"))\nelse\n\t-- 통신을 끝냅니다. ================\n\t_TransferService:Transfer(\"out\")\n\t--==================================\n\treturn\nend\n\n\n\n-- 플레이버 텍스트를 띄웁니다. -----------------\nif grade_Percent >= origin_Percent then -- 성공\n\tgradeNumber = gradeNumber + 1\n\tself:Refresh_Lab_Progress_Text(\"Grade\", idx, true, curGradeNumber, curGradeNumber + 1, player.Name)\nelse -- 실패\n\t\n\tgradeNumber = gradeNumber - 1\n\t\n\t-- 일반에서 등급 하락이 없게 예외처리 ------\n\tif gradeNumber == 0 then\n\t\tgradeNumber = 1\n\tend\n\t\n\tself:Refresh_Lab_Progress_Text(\"Grade\", idx, false, curGradeNumber, curGradeNumber - 1, player.Name)\nend\n\n\n\n--메인 퀘스트 15:유일 등급 획득 -----------------\nif player.PlayerSubData.MainQuest == 15 then\n\tif gradeNumber > 4 then \n\tplayer.PlayerSubData.GetGrade5Monster = player.PlayerSubData.GetGrade5Monster + 1\n\tend\nend\n\n-- 서브 퀘스트 : 등급 변경 시도 -----------------\n\n\tplayer.PlayerSubData.GetGradeChange = player.PlayerSubData.GetGradeChange + 1\n\n\n-- 등급 상승 ------------------------------------\nif gradeNumber == 0 then\n\tplayer.PlayerData.Minventory_Grade[idx]  = self.Grade_0_Name\n\t\nelseif gradeNumber == 1 then\n\tplayer.PlayerData.Minventory_Grade[idx]  = self.Grade_1_Name\n\t\nelseif gradeNumber == 2 then\n\tplayer.PlayerData.Minventory_Grade[idx]  = self.Grade_2_Name\n\t\nelseif gradeNumber == 3 then\n\tplayer.PlayerData.Minventory_Grade[idx]  = self.Grade_3_Name\n\t\nelseif gradeNumber == 4 then\n\tplayer.PlayerData.Minventory_Grade[idx]  = self.Grade_4_Name\n\t\nelseif gradeNumber == 5 then\n\tplayer.PlayerData.Minventory_Grade[idx]  = self.Grade_5_Name\nend\n\n-- 통신을 끝냅니다. ================\n_TransferService:Transfer(\"out\")\n--==================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "Change_MonsterGrade"
        },
