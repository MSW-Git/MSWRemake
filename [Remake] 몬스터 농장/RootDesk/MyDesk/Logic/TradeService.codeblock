          "Code": "local partnerList_Children = self.PartnerSlotList.Children\nlocal playerList_Children = self.PlayerSlotList.Children\n\nfor i = 1, #partnerList_Children do\n\tlocal openUI = _EntityService:GetEntityByPath(partnerList_Children[i].Path..\"/UI_Open\")\n\tlocal closeUI = _EntityService:GetEntityByPath(partnerList_Children[i].Path..\"/UI_Close\")\n\t\n\topenUI.Enable = false\n\tcloseUI.Enable = true\nend\n\nfor i = 1, #playerList_Children do\n\tlocal openUI = _EntityService:GetEntityByPath(playerList_Children[i].Path..\"/UI_Open\")\n\tlocal closeUI = _EntityService:GetEntityByPath(playerList_Children[i].Path..\"/UI_Close\")\n\t\n\topenUI.Enable = false\n\tcloseUI.Enable = true\nend",
