            "Name": null
          },
          "Arguments": null,
          "Code": "-- 생성된 Caption Item을 모두 Delete합니다. -----------\nlocal monsterList_Children = self.MonsterList.Children\n\nfor i = 2, #monsterList_Children do\n\tmonsterList_Children[i]:Destroy()\nend\n",
          "Scope": 2,
          "ExecSpace": 6,
          "Attributes": [],
          "Name": "DeleteListItems"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "slot"
            }
          ],
          "Code": "local player = _UserService.LocalPlayer\nlocal slot_Children = self.PlayerSlotList.Children \n\nlocal closeUI = _EntityService:GetEntityByPath(slot_Children[slot].Path..\"/UI_Close\")\nlocal openUI = _EntityService:GetEntityByPath(slot_Children[slot].Path..\"/UI_Open\")\n\t\t\n\nif idx == 0 then -- 빈 슬롯이라면\n\tcloseUI.Enable = true\n\topenUI.Enable = false\n\t\nelse -- 몬스터라면\n\tcloseUI.Enable = false\n\topenUI.Enable = true\n\n\tlocal itemImage = _EntityService:GetEntityByPath(openUI.Path..\"/UI_Mask/Image_Monster\")\n\tlocal gradeImage = _EntityService:GetEntityByPath(openUI.Path..\"/UI_Grade\")\n\tlocal levelText = _EntityService:GetEntityByPath(openUI.Path..\"/UI_Grade/UI_Level\")\n\tlocal text_Generation = _EntityService:GetEntityByPath(openUI.Path..\"/UI_Generation\")\n\t\t\n\t-- Monster의 Level을 가져옵니다. --------------------------\n\titemImage.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"MonsterDataSet_Base\", player.PlayerData.Minventory_Id[idx], \"ruid\")\n\tlevelText.TextComponent.Text = \"Lv.\"..tostring(math.floor(player.PlayerData.Minventory_Level[idx]))\t\n\t\t\t\n\t-- Monster의 Scale을 가져옵니다. --------------------------\n\tlocal mon_x = tonumber(_DataService:GetCell(\"MonsterDataSet_UI\", player.PlayerData.Minventory_Id[idx], \"Thumbnail_x\"))\n\tlocal mon_y = tonumber(_DataService:GetCell(\"MonsterDataSet_UI\", player.PlayerData.Minventory_Id[idx], \"Thumbnail_y\"))\n\t\t\t\n\titemImage.SpriteGUIRendererComponent.EndFrameIndex = 0\n\titemImage.SpriteGUIRendererComponent.LocalScale = Vector2(mon_x, mon_y)\n\t\t\t\n\t-- 등급 반영 ----------------------------------------------\n\tlocal grade = player.PlayerData.Minventory_Grade[idx]\n\t\n\tif grade == _MonsterService.Grade_0_Name then\n\t\tgradeImage.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)\n\t\n\telseif grade == _MonsterService.Grade_1_Name then\n\t\tgradeImage.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)\n\t\n\telseif grade == _MonsterService.Grade_2_Name then\n\t\tgradeImage.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)\n\t\n\telseif grade == _MonsterService.Grade_3_Name then\n\t\tgradeImage.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)\n\t\n\telseif grade == _MonsterService.Grade_4_Name then\n\t\tgradeImage.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)\n\t\t\n\telseif grade == _MonsterService.Grade_5_Name then\n\t\tgradeImage.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)\n\tend\n\t\t\n\t-- Monster의 세대를 반영합니다. ---------------------------\n\tlocal MonsterGeneration = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\",  player.PlayerData.Minventory_Id[idx], \"generation\"))\n\t\n\tif MonsterGeneration == 1 then\n\t\ttext_Generation.TextComponent.Text = \"★<color=#c8c8c8>★★★★</color>\"\n\t\t\n\telseif MonsterGeneration == 2 then\n\t\ttext_Generation.TextComponent.Text = \"★★<color=#c8c8c8>★★★</color>\"\n\t\t\n\telseif MonsterGeneration == 3 then\n\t\ttext_Generation.TextComponent.Text = \"★★★<color=#c8c8c8>★★</color>\"\n\t\t\n\telseif MonsterGeneration == 4 then\n\t\ttext_Generation.TextComponent.Text = \"★★★★<color=#c8c8c8>★</color>\"\n\t\t\n\telseif MonsterGeneration == 5 then\n\t\ttext_Generation.TextComponent.Text = \"★★★★★\"\n\tend\nend",
          "Scope": 2,
