              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "destination"
            }
          ],
          "Code": "local player = _UserService.LocalPlayer\n\n-- 확정 뽑기 ---------------------------------------------------------------------\n\nif self.IsOpen then -- 이미 켜진 팝업이 있을 때 리턴시킴\n\treturn\nend\n\n-- 기본 설정 ---------------------------------------------------------------------\nplayer.PlayerMove.Type =\"UI\"\nself.IsOpen = true\nself.PopupGroup.Enable = true\n\n-- 가챠 UI가 닫힌 후, 어떤 UI를 열지 선택합니다. ---------------------------------\nif isvalid(destination) then\n\tself.PopupGroup.Gacha.Destination_Type = destination\t\nend\n----------------------------------------------------------------------------------\n\nself.PopupGroup.Gacha:OpenByNormalItem(itemId, itemType, itemRUID, etc1, etc2)\n\n-- 애니메이션 ----\nself:StartTween(true)\n\n-- 사운드 재생 ---\n_SoundService:PlaySound(\"0cae201e10d5468ead5e6ecd1cd747e9\", 1)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "DecisionOpen"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "self:StartTween(false)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Close"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "open"
            }
          ],
          "Code": "local canvasGroup = self.PopupGroup.CanvasGroupComponent \nif open == true then\n\tcanvasGroup.GroupAlpha = 0\nend\nself.IsTweenPlaying = true\nlocal time = 0\n\n\nlocal preTime = _UtilLogic.ElapsedSeconds\n\nlocal tween = function()\n\t\n\tlocal delta = _UtilLogic.ElapsedSeconds - preTime\n\ttime = time + delta\n\tlocal timeValue = time\t\n\tpreTime = _UtilLogic.ElapsedSeconds\n\n\tif time >= self.Duration then\n\t\ttimeValue = self.Duration\n\t\tif open == false then\n\t\t\tself.PopupGroup.Enable = false\n\t\t\tself.IsOpen = false\n\t\tend\n\t\tself.IsTweenPlaying = false\n\t\t_TimerService:ClearTimer(self.TweenEventId)\n\n\tend\n\tif open == false then\n\t\ttimeValue = self.Duration - timeValue\n\tend\n\tlocal tweenValue = _MODTweenLogic.Ease(EaseType.SineEaseIn,self.From,\n\tself.To - self.From,timeValue,self.Duration)\n\tcanvasGroup.GroupAlpha = timeValue / self.Duration\nend\nself.TweenEventId = _TimerService:SetTimerRepeat(tween,1/60)\t",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "StartTween"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
