              "Name": "itemRUID"
            }
          ],
          "Code": "local player = _UserService.LocalPlayer\n\n-- 가차 뽑기 ------------------------------------------\n\nif self.IsOpen then -- 이미 켜진 팝업이 있을 때 리턴시킴\n\treturn\nend\n\n-- 기본 설정 -----\nplayer.PlayerMove.Type =\"UI\"\nself.IsOpen = true\nself.PopupGroup.Enable = true\nself.PopupGroup.Gacha:OpenByRandomItem(itemId, itemRUID)\n\n-- 애니메이션 ----\nself:StartTween(true)\n\n-- 사운드 재생 ---\n_SoundService:PlaySound(\"0cae201e10d5468ead5e6ecd1cd747e9\", 1)",
          "Scope": 2,
