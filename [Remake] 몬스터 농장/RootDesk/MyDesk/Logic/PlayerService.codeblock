            }
          ],
          "Code": "if player.PlayerSubData.GetMonsterReward[id] then\n\treturn\nend\n\nplayer.PlayerSubData.GetMonsterReward[id] = true\n\nlocal generation = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", id, \"generation\"))\n\nself:GetHeart_By_Content(player, generation)\n\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
