            },
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "category"
            }
          ],
          "Code": "local totalHeart = 0\n\nif category == \"Normal\" then\n\t-- 컬렉션 보상 일괄 회수 ----------------------------------------\n\tfor i = 1, #args do\n\t\tif not player.PlayerSubData.GetFusionMonReward[args[i]] then\n\t\t\tplayer.PlayerSubData.GetFusionMonReward[args[i]] = true\n\t\t\t\n\t\t\tlocal rewardMonster = tonumber(_DataService:GetCell(\"MonsterDataSet_Fusion\", args[i], \"reward\"))\n\t\t\ttotalHeart =\ttotalHeart + tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", rewardMonster, \"generation\"))\n\t\tend \n\tend\n\t\nelseif category == \"Secret\" then\n\t-- 컬렉션 보상 일괄 회수 ----------------------------------------\n\tfor i = 1, #args do\n\t\tif not player.PlayerSubData.GetFusionMonReward_Secret[args[i]] then\n\t\t\tplayer.PlayerSubData.GetFusionMonReward_Secret[args[i]] = true\n\t\t\t\n\t\t\tlocal rewardMonster = tonumber(_DataService:GetCell(\"MonsterDataSet_RandFusion_Base\", args[i], \"id\"))\n\t\t\ttotalHeart =\ttotalHeart + tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", rewardMonster, \"generation\"))\n\t\tend \n\tend\nend\n\nself:GetHeart_By_Content(player, totalHeart)\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
