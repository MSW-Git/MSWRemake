            "Name": null
          },
          "Arguments": [],
          "Code": "local maxMonster  = \"\\n\\n<color=#8084b4>\".._LocalizationService:GetTextFormat(\"Popup_maxMonster\", math.floor(_PlayerService.MaxHaveMonster))..\"</color>\"\n_UIPopup:Open(_LocalizationService.LocalTranslator:GetText(\"Popup_alert_Trade\")..maxMonster, nil, nil, nil)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "MonsterSpaceFullAlertByTrade"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "eventID"
            }
          ],
          "Code": "-- 이벤트를 통해 재화를 얻습니다. ------------------------------\nlocal rewardDataSetName = \"EventDataSet_Reward\"\n\nlocal rewardRatio = _DataService:GetCell(\"EventDataSet\", eventID, \"reward_Ratio\")\nlocal rewardQuantity = _DataService:GetCell(rewardDataSetName, player.PlayerData.Level, \"reward_Quantity\")\n\nif not isvalid(rewardRatio) or rewardRatio == '' or rewardRatio == ' ' then\n\treturn\nend\n\nif not isvalid(rewardQuantity) then\n\treturn\nend\n\nrewardQuantity = tonumber(rewardQuantity) * (rewardRatio * 0.01)\n\n-- 재화를 얻습니다. -------------------------------------\nplayer.PlayerData.Gold = player.PlayerData.Gold + rewardQuantity\n\nif player.PlayerData.Gold < 0 then\n\tplayer.PlayerData.Gold = 0 \nend\n\n\n_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, rewardQuantity, nil, nil, nil, player.Name)\n",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetGoldByEvent"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "local maxLevel = _DataService:GetRowCount(\"ItemDataSet_CapaUpCost\")\n\nlocal capacityLevel = player.PlayerData.MaxCapacity_Upgrade_Level\n\n-- 창고를 최대 레벨까지 확장했다면 더 이상 레벨 업 못하게 합니다. --------\nif capacityLevel > maxLevel then\n\t_LocalizationToastService:ShowMessage(\"Popup_imPossibleToExpand\", player.Name)\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", player.Name)\n\t-- ==========================================\n\treturn\nend\n\n\n-- 금액을 제대로 받아오지 못했다면 리턴합니다. ---------------------------\nlocal cost = tonumber(_DataService:GetCell(\"ItemDataSet_CapaUpCost\", capacityLevel, \"cost\"))\n\nif not isvalid(cost) then\n\t_LocalizationToastService:ShowMessage(\"Popup_faitToExpandCapacity\", player.Name)\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", player.Name)\n\t-- ==========================================\n\treturn\nend\n\nif player.PlayerData.Gold < cost then\n\t_LocalizationToastService:ShowMessage(\"Popup_lackOfGold\", player.Name)\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", player.Name)\n\t-- ==========================================\n\treturn\nend\n\n\n-- 재화를 뻅니다. --------------------------------------------------------\nplayer.PlayerData.Gold = player.PlayerData.Gold - cost\n_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -cost, nil, nil, nil, player.Name)\n\n\n\n-- 창고 최대 보유량을 늘립니다 -------------------------------------------\nplayer.PlayerData.MaxCapacity = tonumber(_DataService:GetCell(\"ItemDataSet_CapaUpCost\", capacityLevel, \"maxCapacity\"))\nplayer.PlayerData.MaxCapacity_Upgrade_Level = capacityLevel + 1\n\n_GetPopupService:ShowMessage(player, nil, 9, \"GetPopup_capacity\", true, \"34f706c703cc44a39ae631384accc136\", player.Name)\n\n\n-- 이펙트 재생 -----------------------------------------------------------\n_LocalizationToastService:ShowMessage(\"Popup_capacityUp\", player.Name)\n_SoundService:PlaySound(\"74222ba4b41d48dd97175fd691124a67\", 0.75, player.Name)\n\t\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================\n",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "CapacityUP"
        },
        {
          "Return": {
            "Type": "number",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "local capacity = 0\n\nfor i = 1, #player.PlayerData.Inventory_Quantity do\n\tcapacity = capacity + player.PlayerData.Inventory_Quantity[i]\nend\n\nreturn capacity",
          "Scope": 2,
          "ExecSpace": 0,
          "Attributes": [],
          "Name": "Check_Inventory"
        },
        {
          "Return": {
            "Type": "number",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "local summoned = 0\nlocal playerData = player.PlayerData \n\nfor i = 1, #playerData.Minventory_Id do\n\tif playerData.Minventory_Summoned[i] then\n\t\tsummoned = summoned + 1\n\tend\nend\n\nreturn summoned",
          "Scope": 2,
          "ExecSpace": 0,
          "Attributes": [],
          "Name": "Check_Monster_Summoned"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "player.PlayerData.IsAutoPlaceOnStore = not player.PlayerData.IsAutoPlaceOnStore\n\nif player.PlayerData.IsAutoPlaceOnStore then\n\t_LocalizationToastService:ShowMessage(\"Popup_enableAutoPlace\", player.Name)\nelse\n\t_LocalizationToastService:ShowMessage(\"Popup_disableAutoPlace\", player.Name)\nend\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "Set_Auto_Place_Status"
        }
      ],
      "EntityEventHandlers": [],
      "worldCoreVersion": "26.3.0.0",
      "worldStudioVersion": "0.1.0.0",
      "useService": 0
    }
  }
}