              "Name": "id"
            },
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "type"
            }
          ],
          "Code": "if type == \"Secret\" then\n\tif player.PlayerSubData.GetFusionMonReward_Secret[id] then\n\t\treturn\n\tend\n\t\nelseif type == \"Normal\" then\n\tif player.PlayerSubData.GetFusionMonReward[id] then\n\t\treturn\n\tend\nend\n\n\nlocal monster_ID = 0\nlocal generation = 0\n\nif type == \"Secret\" then\n\tmonster_ID = tonumber(_DataService:GetCell(\"MonsterDataSet_RandFusion_Base\", id, \"id\"))\n\tplayer.PlayerSubData.GetFusionMonReward_Secret[id] = true\n\t\nelseif type == \"Normal\" then\n\tmonster_ID = tonumber(_DataService:GetCell(\"MonsterDataSet_Fusion\", id, \"reward\"))\n\tplayer.PlayerSubData.GetFusionMonReward[id] = true\nend\n\ngeneration = tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", monster_ID, \"generation\"))\n\n\nself:GetHeart_By_Content(player, generation)\n\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetFusionCollectionReward"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
