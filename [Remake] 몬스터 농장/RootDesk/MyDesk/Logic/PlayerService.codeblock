              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "id"
            }
          ],
          "Code": "local isSecretMonster = _DataService:GetCell(\"MonsterDataSet_Base\", id, \"isSecret\")\n\nlocal monsterIDX = 0\nlocal randFusion_DataSet = _DataService:GetTable(\"MonsterDataSet_RandFusion_Base\")\nlocal normalFusion_DataSet =  _DataService:GetTable(\"MonsterDataSet_Fusion\") \n\n\nif isSecretMonster == \"TRUE\" then\n\tlocal length = randFusion_DataSet:GetRowCount()\n\tfor i = 1, length do\n\t\tlocal targetID = tonumber(randFusion_DataSet:GetCell(i, \"id\"))\n\t\tif id == targetID then\n\t\t\tmonsterIDX = i\n\t\t\tbreak\n\t\tend\n\tend\nelse\n\tlocal length = normalFusion_DataSet:GetRowCount()\n\n\tfor i = 1, length do\n\t\tlocal targetID = tonumber(normalFusion_DataSet:GetCell(i, \"reward\"))\n\n\t\tif id == targetID then\n\t\t\tmonsterIDX = i\n\t\t\tbreak\n\t\tend\n\tend\nend\t\t\n\n\nif isSecretMonster == \"TRUE\" then\n\tif player.PlayerSubData.GetFusionMonList_Secret[monsterIDX] then\n\t\treturn\n\tend\nelse\n\tif player.PlayerSubData.GetFusionMonList[monsterIDX] then\n\t\treturn\n\tend\nend\t\t\n\n-- 해당 조합 컬렉션을 해금하고 해금한 날짜를 기록합니다. -----------\n\nlocal utcTime = _SystemService:UTCtimeToTable(_UtilLogic:GetUTCNow())\n\t\t\nif utcTime[2] < 10 then\n\tutcTime[2] = \"0\"..tostring(utcTime[2])\nend\n\t\t\nif utcTime[3] < 10 then\n\tutcTime[3] = \"0\"..tostring(utcTime[3])\nend\n\nif isSecretMonster == \"TRUE\" then\n\tplayer.PlayerSubData.GetFusionMonList_Secret[monsterIDX] = true\n\tplayer.PlayerSubData.GetFusionMonDate_Secret[monsterIDX] = tostring(utcTime[1])..\" / \"..utcTime[2]..\" / \"..utcTime[3]\nelse\n\tplayer.PlayerSubData.GetFusionMonList[monsterIDX] = true\n\tplayer.PlayerSubData.GetFusionMonDate[monsterIDX] = tostring(utcTime[1])..\" / \"..utcTime[2]..\" / \"..utcTime[3]\n\nend\t\t\n\n_GetPopupService:ShowMessage(player, nil, nil, \"GetPopup_collection\", true, \"67c54ca3c79b4df380ba78e16b8c3c26\", player.Name)\n\t\t\nif not player.PlayerSubData.IsCollectionComplete then\n\t_SubDataService:SetCollectionBlink(player, true)\nend\n\t",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetFusionCollection"
        },
