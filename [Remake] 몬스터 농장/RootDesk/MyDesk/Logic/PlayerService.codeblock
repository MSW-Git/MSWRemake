          },
          "Arguments": [],
          "Code": "local player = _UserService.LocalPlayer\nlocal button_Tour = _EntityService:GetEntityByPath(\"/ui/DefaultGroup/UI_Player_Stat/Button_Tour\")\n\n-- 투어 모드가 켜져있다면 끄고, 꺼져있다면 킵니다.\nplayer.PlayerData.IsPossibleWalk = not player.PlayerData.IsPossibleWalk\n\nif player.PlayerData.IsPossibleWalk then\n\t_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText(\"Popup_goodToTakeARest\"))\n\tplayer.OwnerEntity:IsClick()\n\t\nelse\n\t_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText(\"Popup_getBackToWork\"))\n\n\tlocal camera = _EntityService:GetEntityByPath(\"/maps/farm/Camera\") \n\tif isvalid(camera) then\n\t\tcamera.TransformComponent.Position = player.TransformComponent.Position\n\tend\n\t\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "SetWalkPossible"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
