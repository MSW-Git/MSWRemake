              "Name": "player"
            }
          ],
          "Code": "-- 이미 만렙에 도달했다면 ----------------------\nif player.PlayerData.Level >= self.MaxLevel then\n\t_UIPopup:Open(_LocalizationService.LocalTranslator:GetText(\"Popup_failToLevelUp\"), nil, nil, nil)\n\treturn\nend\n\n\nlocal dataSetName = \"FarmLevelDataSet\"\n\nlocal cost = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Level, \"cost\"))\nlocal curMaxSummon = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Level, \"maxSummon\"))\nlocal nextMaxSummon = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Level + 1, \"maxSummon\"))\n\nlocal costText = _LocalizationService.LocalTranslator:GetText(\"Popup_levelUpCost\")..\" <color=#929aff>\".._SystemService:ThousandsSeparator(cost)..\"</color> <color=#d7d0a5>G</color>\"\n\nlocal maxSummonText = \"\\n\\n\".._LocalizationService.LocalTranslator:GetText(\"Popup_maxMonsterCountUp\")..\"  <color=#929aff>\"..tostring(curMaxSummon)..\" -> \"..tostring(nextMaxSummon)..\"</color>\"\n\nlocal yes = function()\n\t-- 통신 시작 ================================\n\t_TransferService:Transfer(\"in\")\n\t-- ==========================================\n\tself:LevelUP_Yes(player)\nend\n\nlocal no = function() \nend\n\n\t\n_UIPopup:Open(_LocalizationService.LocalTranslator:GetText(\"Popup_alert_LevelUp\")..\"\\n\"..costText..maxSummonText, yes, no, nil)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "LevelUP"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "local dataSetName = \"FarmLevelDataSet\"\nlocal cost = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Level, \"cost\"))\nlocal nextMaxSummon = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Level + 1, \"maxSummon\"))\n\nif player.PlayerData.Gold >= cost then\n\t_LevelUpService:Open(player.PlayerData.Level, player.Name)\n\t_PlayerService:GetGold(player, -cost) -- 돈을 뺍니다.\n\t_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -cost, nil, nil, nil, player.Name)\n\t\t\t\n\tplayer.PlayerData.Level = player.PlayerData.Level + 1\n\tplayer.PlayerData.MaxSummon = nextMaxSummon\nelse\n\t_LocalizationToastService:ShowMessage(\"Popup_lackOfGold\", player.Name)\nend\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\")\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "LevelUP_Yes"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "type"
            }
          ],
          "Code": "local imageRUID = \"\"\nlocal maxLevel = 5\n\nlocal ingredient_ID = 0\nlocal ingredient_Quantity = 0\n\n-- 해당 장비의 가격을 계산합니다. ----------------------------------------------------------------------\nif type == \"솥\" then\n\tif player.PlayerData.CurPotLevel >= maxLevel then\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\tend\n\t\n\tingredient_ID = tonumber(_DataService:GetCell(\"CookDataSet_Pot\", player.PlayerData.CurPotLevel, \"required_ItemID\"))\n\tingredient_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_Pot\", player.PlayerData.CurPotLevel, \"required_Quantity\"))\n\t\nelseif type == \"요리도구\" then\n\tif player.PlayerData.CurKitchenTool_Level >= maxLevel then\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\tend\n\tingredient_ID = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", player.PlayerData.CurKitchenTool_Level, \"required_ItemID\"))\n\tingredient_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", player.PlayerData.CurKitchenTool_Level, \"required_Quantity\"))\n\t\nelseif type == \"요리복장\" then\n\tif player.PlayerData.CurSuit_Level >= maxLevel then\t\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\tend\n\tingredient_ID = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", player.PlayerData.CurSuit_Level, \"required_ItemID\"))\n\tingredient_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", player.PlayerData.CurSuit_Level, \"required_Quantity\"))\n\t\nelseif type == \"레시피\" then\n\tif player.PlayerData.CurRecipe_Level >= maxLevel then\t\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\tend\n\tingredient_ID = tonumber(_DataService:GetCell(\"CookDataSet_Recipe\", player.PlayerData.CurRecipe_Level, \"required_ItemID\"))\n\tingredient_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_Recipe\", player.PlayerData.CurRecipe_Level, \"required_Quantity\"))\nend\n\n-- 재화 계산 ---------------------------------------------------\nif ingredient_ID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold < ingredient_Quantity then\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\telse\n\t\t_PlayerService:GetGold(player, -ingredient_Quantity)\n\tend\nelseif ingredient_ID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry < ingredient_Quantity then\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\telse\n\t\t_PlayerService:GetBerry(player, -ingredient_Quantity)\n\tend\nelseif ingredient_ID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby < ingredient_Quantity then\n\t\t-- 통신합니다. ================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t--=============================\n\t\treturn\n\telse\n\t\t_PlayerService:GetRuby(player, -ingredient_Quantity, 1)\n\tend\nend\n\n-- 장비를 업그레이드 합니다. --------------------------------------------------------------\nif type == \"솥\" then\n\n\tplayer.PlayerData.CurPotLevel = player.PlayerData.CurPotLevel + 1\n\timageRUID = _DataService:GetCell(\"CookDataSet_Pot\", player.PlayerData.CurPotLevel, \"ruid\")\n\t\nelseif type == \"요리도구\" then\n\n\tplayer.PlayerData.CurKitchenTool_Level = player.PlayerData.CurKitchenTool_Level + 1\n\timageRUID = _DataService:GetCell(\"CookDataSet_KitchenTool\", player.PlayerData.CurKitchenTool_Level, \"ruid\")\n\t\nelseif type == \"요리복장\" then\n\t\n\tplayer.PlayerData.CurSuit_Level = player.PlayerData.CurSuit_Level + 1\n\timageRUID = _DataService:GetCell(\"CookDataSet_Suit\", player.PlayerData.CurSuit_Level, \"ruid\")\n\t\nelseif type == \"레시피\" then\n\n\tplayer.PlayerData.CurRecipe_Level = player.PlayerData.CurRecipe_Level + 1\n\timageRUID = _DataService:GetCell(\"CookDataSet_Recipe\", player.PlayerData.CurRecipe_Level, \"ruid\")\nend\n\n--퀘스트 조건: 요리 도구 강화 -----------------------------------------------------------------\nplayer.PlayerSubData.GetCookingEquipment = player.PlayerSubData.GetCookingEquipment + 1\n\n\n-- 획득 메시지를 띄웁니다. -----------------------------------------------------------------\n_GetPopupService:ShowMessage(player, nil, nil, \"GetPopup_upgrade\", true, imageRUID, player.Name)\n\n\n-- 효과음을 재생합니다. --------------------------------------------------------------------\n_SoundService:PlaySound(\"16336dee681d482abd442d887736ac4d\", 0.75, player.Name)\n\n-- 통신합니다. ================\n_TransferService:Transfer(\"out\", player.Name)\n--=============================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetCookItem"
        },
