          ],
          "Code": "-- 재화를 얻습니다. -------------------------------------\nplayer.PlayerData.Gold = player.PlayerData.Gold + value\n\nif player.PlayerData.Gold < 0 then\n\tplayer.PlayerData.Gold = 0 \nend",
          "Scope": 2,
          "ExecSpace": 1,
          "Attributes": [],
          "Name": "GetGold"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "value"
            }
          ],
          "Code": "-- 베리를 얻습니다. -------------------------------------\nplayer.PlayerData.Berry = player.PlayerData.Berry + value\n\nif value > 0 then \nplayer.PlayerSubData.GetBerryCount = player.PlayerSubData.GetBerryCount + value --퀘스트 조건 \n\nend\n\nif player.PlayerData.Berry < 0 then\n\tplayer.PlayerData.Berry = 0\nend\n\n_GetPopupService:ShowMessage(player, self.Berry_ID, value, nil, nil, nil, player.Name)",
          "Scope": 2,
          "ExecSpace": 1,
          "Attributes": [],
          "Name": "GetBerry"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "count"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "valuePerItem"
            }
          ],
          "Code": "player.PlayerData.Ruby = player.PlayerData.Ruby + (valuePerItem * count)\n\nplayer.PlayerSubData.GetRubyCount = player.PlayerSubData.GetRubyCount + (valuePerItem * count) -- 퀘스트 조건 \n\n\n_GetPopupService:ShowMessage(player, self.Ruby_ID, valuePerItem * count, nil, nil, nil, player.Name)\n\nif player.PlayerData.Ruby < 0 then\n\tplayer.PlayerData.Ruby = 0\nend",
          "Scope": 2,
          "ExecSpace": 1,
          "Attributes": [],
          "Name": "GetRuby"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "giver"
            },
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "receiver"
            }
          ],
          "Code": "local giverName = giver.PlayerComponent.Nickname\nlocal receiverName = receiver.PlayerComponent.Nickname\n\n\nif not isvalid(giver) then\n\treturn\nend\n\nif not isvalid(receiver) then\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", giver.Name)\n\t-- ==========================================\n\treturn\nend\n\nif not giver.PlayerData.IsLoaded then\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", giver.Name)\n\t-- ==========================================\n\treturn\nend\n\nif not receiver.PlayerData.IsLoaded then\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", giver.Name)\n\t-- ==========================================\n\treturn\nend\n\n-- 오늘 Receiver에게 이미 인기도를 준 상태인지 확인합니다. --------------------------\nlocal isExist = false\n\nfor i = 1, #giver.PlayerSubData.DailyGiveHeartList do\n\tif giver.PlayerSubData.DailyGiveHeartList[i] == receiver.Name then\n\t\tisExist = true\n\t\tbreak\n\tend\nend\n\n-- 오늘 이미 Receiver에게 인기도를 준 상태라면 --------------------------------------\nif isExist then\n\t_LocalizationToastService:FailToRaiseHeart(receiverName, giver.Name)\n\t-- 통신 종료 ================================\n\t_TransferService:Transfer(\"out\", giver.Name)\n\t-- ==========================================\n\treturn\nend\n\n-- 인기도 Toast Message를 띄웁니다. -------------------------------------------------\n_LocalizationToastService:RaiseHeartMutual(giverName, receiverName, receiver.Name)\n_LocalizationToastService:RaiseHeart(receiverName, giver.Name)\n\n\n-- Receiver의 인기도를 올립니다. ----------------------------------------------------\nreceiver.PlayerData.Heart = receiver.PlayerData.Heart + 1\n\n\n----------------------------------------------\n-- 랭킹을 저장합니다.\n----------------------------------------------\n_SaveLoadService:Save_Rank(receiver, true)\n\n\n-- 서브 퀘스트 조건: 인기도 3개 주기 ----------------------------------------------------\ngiver.PlayerSubData.GetPopularityCount = giver.PlayerSubData.GetPopularityCount + 1 \n\n-- Receiver의 오늘 인기도 목록에 해당 플레이어의 이름을 넣습니다. -------------------\ntable.insert(giver.PlayerSubData.DailyGiveHeartList, receiver.Name)\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", giver.Name)\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetHeart"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "id"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "quantity"
            },
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "forceStack"
            }
          ],
          "Code": "local playerCapacity = self:Check_Inventory(player)\n\nif (playerCapacity + quantity <= player.PlayerData.MaxCapacity) or forceStack then -- 아이템을 얻을 수 있는 상태라면\n\t\n\tplayer.PlayerSubData.Noti_Inv = 1\n\n\t-- 해당 아이템의 최대 보유 갯수를 받아옵니다. ---------------------------------------------------------------\n\tlocal maxQuantity = tonumber(_DataService:GetCell(\"ItemDataSet_Base\", (id - 20000), \"max_quantity\"))\n\t-- 아이템의 type\n\tlocal type = _DataService:GetCell(\"ItemDataSet_Base\", (id - 20000), \"type\")\n\n\t--서브 퀘스트: 식재료 얻기 ----------------------------------------------------------------------\n\tif type ==\"식재료\" then\n\t\tplayer.PlayerSubData.GetIngredient = player.PlayerSubData.GetIngredient + 1\n\tend\n\t\n\n\n\n\t-- 인벤토리에서 해당 아이템이 있나 확인합니다. ----------------------------------------------------------------\n\tfor i = 1, #player.PlayerData.Inventory_Name do\n\t\t\n\t\t-- 인벤토리에 아이템이 존재하고 최대 스택 수량까지 스택되지 않았다면 --------------------------------------\n\t\tif player.PlayerData.Inventory_Name[i] == id and player.PlayerData.Inventory_Quantity[i] ~= maxQuantity then \n\t\n\t\t\tlocal number = player.PlayerData.Inventory_Quantity[i] + quantity -- 더한 값\n\t\n\t\t\tif number > maxQuantity then -- 더한 값이 최대 스택 수량을 넘었다면 재귀함수로 넘겨 다시 더합니다. ---\n\t\t\t\tlocal current_number = number - maxQuantity -- 최대 스택 수량까지 남은 개수\n\t\t\t\t\n\t\t\t\tplayer.PlayerData.Inventory_Quantity[i] = maxQuantity -- 아이템을 얻습니다.\n\t\t\t\tself:GetItem(player, id, current_number, forceStack)\n\t\n\t\t\telse -- 더할 값이 최대 스택 수량을 넘기지 않았다면 ---------------------------------------------------\n\t\t\t\tplayer.PlayerData.Inventory_Quantity[i] = number -- 아이템을 얻습니다\n\t\t\tend\n\t\t\t\n\t\t\treturn\n\t\tend\n\tend\n\t\n\t-- 플레이어의 인벤토리에 해당 아이템이 없을 경우 ----------------------------------------------------------------------\n\ttable.insert(player.PlayerData.Inventory_Name, id)\n\ttable.insert(player.PlayerData.Inventory_Quantity, quantity)\n\ttable.insert(player.PlayerData.Inventory_Type, type)\n\n\n\n\n\t\n\treturn\n\t\nelse -- 적재가 불가능할 경우\n\t_PlayerService:SpaceFullAlert(player.Name)\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetItem"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "id"
            },
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "grade"
            }
          ],
          "Code": "local playerState = player.PlayerData\n\nlocal dataSetName = \"MonsterDataSet_Base\"\nlocal dataSet_Length = _DataService:GetRowCount(dataSetName)\n\n-- 마스코트 인덱스를 1 올립니다. -------------------------------------------------------------------\nif player.PlayerData.MInventory_MascotPet_Id ~= 0 then\n\tplayer.PlayerData.MInventory_MascotPet_Id = player.PlayerData.MInventory_MascotPet_Id + 1\nend\n\n-- Monster Table Generate --------------------------------------------------------------------------\t\ntable.insert(playerState.Minventory_Id, 1, id)\ntable.insert(playerState.Minventory_Exp, 1, 0) \ntable.insert(playerState.Minventory_Time, 1, 0) \ntable.insert(playerState.Minventory_Level, 1, 1)\ntable.insert(playerState.Minventory_Entity, 1, \" \")\ntable.insert(playerState.Minventory_Summoned, 1, false)\ntable.insert(playerState.Minventory_UniqueID, 1, tostring(id)..tostring(player.PlayerData.MonsterIDX)..\"_a\")\n\n-- 세대를 기준으A로 다른 데이터를 넣습니다. ---------------------------------------------------------\nlocal monster_Generation = tonumber(_DataService:GetCell(dataSetName, id, \"generation\")) \n\n-- 세대에 따라 다른 몬스터 최대 경험치 공식을 적용합니다. ------------------------------------------\nlocal MEXP = _MonsterService.Origin_Monster_Mexp * (_MonsterService.Origin_Monster_Mexp_Up_Multiple ^ (monster_Generation - 1))\n\ntable.insert(playerState.Minventory_Mexp, 1, MEXP)\n-- '1세대'\nif monster_Generation == 1 then\n\ttable.insert(playerState.Minventory_Personality, 1, 0)\n\t\n\ttable.insert(playerState.Minventory_Grade, 1, grade)\n\t\n\ttable.insert(playerState.Minventory_Skill_Id, 1, 0)\n\n\t\n-- '2세대'\nelseif monster_Generation == 2 then\n\ttable.insert(playerState.Minventory_Personality, 1, 0)\n\t\n\ttable.insert(playerState.Minventory_Grade, 1, grade)\n\t\n\ttable.insert(playerState.Minventory_Skill_Id, 1, 0)\n\n\n-- '3세대'\nelseif monster_Generation == 3 then\n\ttable.insert(playerState.Minventory_Personality, 1, _UtilLogic:RandomIntegerRange(1, 6))\n\t\n\ttable.insert(playerState.Minventory_Grade, 1, grade)\n\t\n\ttable.insert(playerState.Minventory_Skill_Id, 1, 0)\n\n-- '4세대'\nelseif monster_Generation == 4 then\n\ttable.insert(playerState.Minventory_Personality, 1, _UtilLogic:RandomIntegerRange(1, 6))\n\t\n\ttable.insert(playerState.Minventory_Grade, 1, grade)\n\t\n\ttable.insert(playerState.Minventory_Skill_Id, 1, 0)\n\n\t\n\n-- '5세대'\nelseif monster_Generation == 5 then\n\ttable.insert(playerState.Minventory_Personality, 1, _UtilLogic:RandomIntegerRange(1, 6))\n\n\ttable.insert(playerState.Minventory_Grade, 1, grade)\n\t\n\ttable.insert(playerState.Minventory_Skill_Id, 1, _UtilLogic:RandomIntegerRange(1, 5))\n\n\nend\n\n\nplayer.PlayerData.MonsterIDX = player.PlayerData.MonsterIDX + 1\nplayer.PlayerSubData.Noti_MInv = 1 -- 몬스터 노티를 띄움\n\n\n---------------------------------------------------------------------------------------------------\n-- ★★ 콘텐츠 관련 ★★\n---------------------------------------------------------------------------------------------------\n\n\n---------------------------------------------------------------------------\n-- 도감 \n---------------------------------------------------------------------------\n-- 획득한 적 없는 몬스터라면 '도감'에 추가합니다.\nlocal find = false\nif player.PlayerSubData.GetMonsterList[id] then\n\tfind = true\nend\n\n\nif not find then\n\tplayer.PlayerSubData.GetMonsterList[id] = true\n\t\n\t-- 해당 몬스터가 '비밀 몬스터'인지 확인하고, 맞다면 획득 날짜를 반환합니다.\n\tlocal isRandomMonster = false\n\tlocal isSecret = _DataService:GetCell(dataSetName, id, \"isSecret\")\n\t\n\tif isvalid(isSecret) and isSecret == \"true\" then\n\t\tisRandomMonster = true\n\tend\n\t\n\tif isRandomMonster then\n\t\tlocal utcTime = _SystemService:UTCtimeToTable(_UtilLogic:GetUTCNow())\n\t\t\n\t\tif utcTime[2] < 10 then\n\t\t\tutcTime[2] = \"0\"..tostring(utcTime[2])\n\t\tend\n\t\t\n\t\tif utcTime[3] < 10 then\n\t\t\tutcTime[3] = \"0\"..tostring(utcTime[3])\n\t\tend\n\t\t\n\t\tplayer.PlayerSubData.GetFusionMonDate[id] = tostring(utcTime[1])..\" / \"..utcTime[2]..\" / \"..utcTime[3]\n\tend\n\t----------------------------------------------------------------------------\n\t\n\tif player.CurrentMapName == \"farm\" then\n\t\t_GetPopupService:ShowMessage(player, nil, nil, \"GetPopup_book\", true, \"94118d2548724dbd8e06503d23df7ff7\", player.Name)\n\t\t\n\t\tif not player.PlayerSubData.IsBookComplete then\n\t\t\t_SubDataService:SetBookBlink(player, true)\n\t\tend\n\t\t\n\tend\nend\n\n----------------------------------------------------------------------------\n-- 일감 \n----------------------------------------------------------------------------\n-- 몬스터 얻기 \t\nif _QuestService:CheckHaveQuest(player, 8) then -- 일반 몬스터 1회 얻기 [일감]\n\tplayer.PlayerSubData.GetNormalMonCount = player.PlayerSubData.GetNormalMonCount + 1\nend\t",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetMonster"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            },
            {
              "Type": "string",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "Popup_buyHelper"
            }
          ],
          "Code": "-- 도우미를 얻을 때, 기본적으로 코스튬을 같이 제공해줍니다. ----\nlocal dataSetName = \"HelperDataSet\"\n\nlocal curLevel = player.PlayerData.Hinventory_Level[idx]\n\nlocal ing_ID = tonumber(_DataService:GetCell(\"ItemDataSet_Store_Helper\", idx, \"ing_\"..tostring(math.floor(curLevel))..\"_ID\"))\nlocal ing_Quantity = tonumber(_DataService:GetCell(\"ItemDataSet_Store_Helper\", idx, \"ing_\"..tostring(math.floor(curLevel))..\"_Quantity\"))\n\n-- 최대 레벨 이상으로 레벨 업 한 상태라면 ------------\nif curLevel >= 3 then\n\t-- 통신 종료 ====================================\n\t_TransferService:Transfer(\"out\", player.Name)\n\t-- ==============================================\n\treturn\nend\n\n-- 플레이어의 재화가 충분한지 확인\nif ing_ID == _PlayerService.Gold_ID then\n\tif player.PlayerData.Gold >= ing_Quantity then\n\t\tself:GetGold(player, -ing_Quantity)\n\t\t_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -ing_Quantity, nil, nil, nil, player.Name)\n\telse\n\t\t-- 통신 종료 ================================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t-- ==========================================\n\t\treturn\n\tend\nelseif ing_ID == _PlayerService.Berry_ID then\n\tif player.PlayerData.Berry >= ing_Quantity then\n\t\tself:GetBerry(player, -ing_Quantity)\n\telse\n\t\t-- 통신 종료 ================================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t-- ==========================================\n\t\treturn\n\tend\nelseif ing_ID == _PlayerService.Ruby_ID then\n\tif player.PlayerData.Ruby >= ing_Quantity then\n\t\tself:GetRuby(player, 1, -ing_Quantity)\n\telse\n\t\t-- 통신 종료 ================================\n\t\t_TransferService:Transfer(\"out\", player.Name)\n\t\t-- ==========================================\n\t\treturn\n\tend\nend\n\n--퀘스트 조건: 일꾼 구매 \nif player.PlayerData.Hinventory_Level[idx] == 0 then\n\tplayer.PlayerSubData.GetHelperCount = player.PlayerSubData.GetHelperCount +1\nend\n-- 퀘스트 조건: 일꾼 업그레이드 \nif player.PlayerData.Hinventory_Level[idx] >= 1 then\n\tplayer.PlayerSubData.GetHelperUpgrade = player.PlayerSubData.GetHelperUpgrade +1\nend\n\t\nplayer.PlayerData.Hinventory_Level[idx] = player.PlayerData.Hinventory_Level[idx] + 1\n\n-- 일꾼 소환 --------------------------------\n_HelperService:SummonHelper(player, idx, true)\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetHelper"
        },
        {
          "Return": {
