          "Arguments": [],
          "Code": "local maxMonster  = \"\\n\\n<color=#8084b4>\".._LocalizationService:GetTextFormat(\"Popup_maxMonster\", math.floor(_PlayerService.MaxHaveMonster))..\"</color>\"\n_UIPopup:Open(_LocalizationService.LocalTranslator:GetText(\"Popup_alert_FullMonster\")..maxMonster, nil, nil, nil)",
