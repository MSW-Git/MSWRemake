            },
            {
              "Type": "array",
              "DefaultValue": "number",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "args"
            }
          ],
          "Code": "-- 몬스터 도감 보상 일괄 회수 --------------------------------\nlocal totalHeart = 0\nfor i = 1, #args do\n\tif not player.PlayerSubData.GetMonsterReward[args[i]] then\n\t\tplayer.PlayerSubData.GetMonsterReward[args[i]] = true\n\t\ttotalHeart =\ttotalHeart + tonumber(_DataService:GetCell(\"MonsterDataSet_Base\", args[i], \"generation\"))\n\tend \nend\n\nself:GetHeart_By_Content(player, totalHeart)\n\n-- 통신 종료 ================================\n_TransferService:Transfer(\"out\", player.Name)\n-- ==========================================",
          "Scope": 2,
