              "Name": "value"
            }
          ],
          "Code": "player.PlayerData.Heart = player.PlayerData.Heart + value\n\n----------------------------------------------\n-- 랭킹을 저장합니다.\n----------------------------------------------\n_SaveLoadService:Save_Rank(player, true)\n\n_GetPopupService:ShowMessage(player, nil, math.floor(value), \"GetPopup_heart\", true, \"777deddade3a44c79c2e7fcdaa2e3919\", player.Name)",
