      "Language": 1,
      "Name": "GetPopupService",
      "Type": 5,
      "Source": 0,
      "Target": null,
      "Properties": [
        {
          "Type": "Entity",
          "DefaultValue": "8e83d587-613b-4533-a896-e55fe2817dc7",
          "SyncDirection": 0,
          "Attributes": [],
