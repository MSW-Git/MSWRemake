          },
          "Arguments": null,
          "Code": "local player = _UserService.LocalPlayer\n\n-- 경로 --------------------------------------------------------------------------------------------------------\nlocal item_Pot = _EntityService:GetEntityByPath(\"/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_Pot\")\nlocal item_Suit = _EntityService:GetEntityByPath(\"/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_Suit\")\nlocal item_KitchenTool = _EntityService:GetEntityByPath(\"/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_KitchenTool\")\nlocal item_Recipe = _EntityService:GetEntityByPath(\"/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_Recipe\")\n\n\n-- 플레이어의 요리 장비 정보 -----------------------------------------------------------------------------------\nlocal curPot_Level = player.PlayerData.CurPotLevel\nlocal curSuit_Level = player.PlayerData.CurSuit_Level\nlocal curKitchenTool_Level = player.PlayerData.CurKitchenTool_Level\nlocal curRecipe_Level = player.PlayerData.CurRecipe_Level\n\n-- 플레이어의 장비 버프 가산치 ---------------------------------------------------------------------------------\nlocal curPot_Value = tonumber(_DataService:GetCell(\"CookDataSet_Pot\", curPot_Level, \"maxQuantity\"))\nlocal curSuit_Value = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", curSuit_Level, \"ReduceGaugeBuff\"))\nlocal curKitchenTool_Value = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", curKitchenTool_Level, \"ReduceTimeBuff\"))\nlocal curRecipe_Value = tonumber(_DataService:GetCell(\"CookDataSet_Recipe\", curRecipe_Level, \"UpgradeValueBuff\"))\n\n-- 제목, 설명 초기화 -------------------------------------------------------------------------------------------\nlocal curPot_Image = _DataService:GetCell(\"CookDataSet_Pot\", curPot_Level, \"ruid\")\nlocal curPot_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(\"CookDataSet_Pot\", curPot_Level, \"name\"))\n\nlocal unlockText = _LocalizationService.LocalTranslator:GetText(\"Cook_unlock\")\nlocal maxGaugeText = _LocalizationService.LocalTranslator:GetText(\"Cook_maxGauge\")\nlocal potDescription = unlockText..\" : \".._DataService:GetCell(\"CookDataSet_Pot\", curPot_Level, \"description\")..\"\\n\"..maxGaugeText..\" : \"..tostring(curPot_Value)..\"%\"\nlocal curPot_Description = potDescription\n\nlocal curPot_Upgrade_Item_ID = tonumber(_DataService:GetCell(\"CookDataSet_Pot\", curPot_Level, \"required_ItemID\")) - 20000\nlocal curPot_Upgrade_Item_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_Pot\", curPot_Level , \"required_Quantity\"))\n\nlocal curSuit_Image = _DataService:GetCell(\"CookDataSet_Suit\", curSuit_Level, \"ruid\")\nlocal curSuit_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(\"CookDataSet_Suit\", curSuit_Level, \"name\"))\nlocal curSuit_Description = _LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell(\"CookDataSet_Suit\", curSuit_Level, \"description\"), curSuit_Value)\n\nlocal curSuit_Upgrade_Item_ID = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", curSuit_Level, \"required_ItemID\")) - 20000\nlocal curSuit_Upgrade_Item_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", curSuit_Level, \"required_Quantity\"))\n\nlocal curKitchenTool_Image = _DataService:GetCell(\"CookDataSet_KitchenTool\", curKitchenTool_Level, \"ruid\")\nlocal curKitchenTool_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(\"CookDataSet_KitchenTool\", curKitchenTool_Level, \"name\"))\nlocal curKitchenTool_Description = _LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell(\"CookDataSet_KitchenTool\", curKitchenTool_Level, \"description\"), curKitchenTool_Value)\n\nlocal curKitchenTool_Upgrade_Item_ID = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", curKitchenTool_Level, \"required_ItemID\")) - 20000\nlocal curKitchenTool_Upgrade_Item_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", curKitchenTool_Level, \"required_Quantity\"))\n\nlocal curRecipe_Image = _DataService:GetCell(\"CookDataSet_Recipe\", curRecipe_Level, \"ruid\")\nlocal curRecipe_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(\"CookDataSet_Recipe\", curRecipe_Level, \"name\"))\nlocal curRecipe_Description = _LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell(\"CookDataSet_Recipe\", curRecipe_Level, \"description\"), curRecipe_Value)\nlocal curRecipe_Upgrade_Item_ID = tonumber(_DataService:GetCell(\"CookDataSet_Recipe\", curRecipe_Level, \"required_ItemID\")) - 20000\nlocal curRecipe_Upgrade_Item_Quantity = tonumber(_DataService:GetCell(\"CookDataSet_Recipe\", curRecipe_Level, \"required_Quantity\"))\n\nself:Refresh_UpgradeUI_Item(item_Pot, curPot_Image, curPot_Title, curPot_Description, curPot_Upgrade_Item_ID, curPot_Upgrade_Item_Quantity, curPot_Level)\n\nself:Refresh_UpgradeUI_Item(item_Suit, curSuit_Image, curSuit_Title, curSuit_Description, curSuit_Upgrade_Item_ID, curSuit_Upgrade_Item_Quantity, curSuit_Level)\n\nself:Refresh_UpgradeUI_Item(item_KitchenTool, curKitchenTool_Image, curKitchenTool_Title, curKitchenTool_Description, curKitchenTool_Upgrade_Item_ID, curKitchenTool_Upgrade_Item_Quantity, curKitchenTool_Level)\n\nself:Refresh_UpgradeUI_Item(item_Recipe, curRecipe_Image, curRecipe_Title, curRecipe_Description, curRecipe_Upgrade_Item_ID, curRecipe_Upgrade_Item_Quantity, curRecipe_Level)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Refresh_UpgradeUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": "nil",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "item"
            },
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "ruid"
            },
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "title"
            },
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "description"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "itemID"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "itemQuantity"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "level"
            }
          ],
          "Code": "local player = _UserService.LocalPlayer\n\n-- 이미지 경로 -----------------------------------------------------------------------------------------------\nlocal image_Ingredient = _EntityService:GetEntityByPath(item.Path..\"/UI_Bottom/Image_Ingredient\")\nlocal image_Item = _EntityService:GetEntityByPath(item.Path..\"/UI_Top/Image_Item\")\n\n-- 텍스트 경로 -----------------------------------------------------------------------------------------------\nlocal text_Money = _EntityService:GetEntityByPath(item.Path..\"/UI_Bottom/Text_Money\")\nlocal text_Title = _EntityService:GetEntityByPath(item.Path..\"/UI_Top/Text_Title\")\nlocal text_Description = _EntityService:GetEntityByPath(item.Path..\"/UI_Top/Text_Description\")\nlocal text_Generation = _EntityService:GetEntityByPath(item.Path..\"/UI_Top/Text_Generation\")\n\n-- 버튼 경로 -------------------------------------------------------------------------------------------------\nlocal button_Condition = _EntityService:GetEntityByPath(item.Path..\"/UI_Bottom\")\nlocal button_Upgrade = _EntityService:GetEntityByPath(item.Path..\"/Button_Upgrade\") \n\nimage_Item.SpriteGUIRendererComponent.ImageRUID = ruid\n\ntext_Title.TextComponent.Text = title\ntext_Description.TextComponent.Text = description\n\nif level == 1 then\n\ttext_Generation.TextComponent.Text = \"<color=#ffe471>★</color>★★★★\"\n\t\nelseif level == 2 then\n\ttext_Generation.TextComponent.Text = \"<color=#ffe471>★★</color>★★★\"\n\t\nelseif level == 3 then\n\ttext_Generation.TextComponent.Text = \"<color=#ffe471>★★★</color>★★\"\n\t\nelseif level == 4 then\n\ttext_Generation.TextComponent.Text = \"<color=#ffe471>★★★★</color>★\"\n\t\nelseif level == 5 then\n\ttext_Generation.TextComponent.Text = \"<color=#ffe471>★★★★★</color>\"\n\t\nend\n\n-- 해당 장비를 만렙까지 올렸다면 -----------------------------------------------------------------------------\nif  itemID == 0 or itemQuantity == 0 then\n\tbutton_Condition.SpriteGUIRendererComponent.Color = Color.FromHexCode(\"#444683\")\n\tbutton_Upgrade.Enable = false\n\timage_Ingredient.Enable = false\n\ttext_Money.Enable = false\nelse\n\tbutton_Upgrade.Enable = true\n\timage_Ingredient.Enable = true\n\ttext_Money.Enable = true\n\ttext_Money.TextComponent.Text = \"x \".._SystemService:ThousandsSeparator(itemQuantity)\nend\n\nlocal levelUpText = _LocalizationService.LocalTranslator:GetText(\"UI_levelUP\")\nlocal lackOfGoldText = _LocalizationService.LocalTranslator:GetText(\"UI_lackOfGold\")\n\n\nif itemID ~= 0 and itemQuantity ~= 0 then\n\t\n\timage_Ingredient.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", itemID, \"ruid\")\n\t\n\tif itemID == _PlayerService.Gold_ID - 20000 then\n\t\tbutton_Condition.SpriteGUIRendererComponent.Color = player.PlayerData.Gold >= itemQuantity and Color.FromHexCode(\"#8683b1\") or Color.FromHexCode(\"#a25757\") \n\t\timage_Ingredient.SpriteGUIRendererComponent.Color.a = player.PlayerData.Gold >= itemQuantity and 1 or 0.4\n\t\ttext_Money.TextComponent.FontColor.a = player.PlayerData.Gold >= itemQuantity and 1 or 0.4 \n\t\tbutton_Upgrade.ButtonComponent.Enable = player.PlayerData.Gold >= itemQuantity\n\t\t\n\t\tbutton_Upgrade.SpriteGUIRendererComponent.ImageRUID = player.PlayerData.Gold >= itemQuantity and \"b598cf22e48a4e4bb7a3c47cb719f679\" or \"92a7f54bc19c4447be0b4b6c60dfc6ff\"\n\t\tbutton_Upgrade.ButtonComponent.Enable = player.PlayerData.Gold >= itemQuantity \n\t\t\n\t\tbutton_Upgrade.TextComponent.Text = player.PlayerData.Gold >= itemQuantity and levelUpText or lackOfGoldText\n\t\tbutton_Upgrade.TextComponent.FontColor.a = player.PlayerData.Gold >= itemQuantity and 1 or 0.4 \n\t\t\n\telseif itemID == _PlayerService.Berry_ID - 20000 then\n\t\tbutton_Condition.SpriteGUIRendererComponent.Color = player.PlayerData.Berry >= itemQuantity and Color.FromHexCode(\"#8683b1\") or Color.FromHexCode(\"#a25757\") \n\t\timage_Ingredient.SpriteGUIRendererComponent.Color.a = player.PlayerData.Berry >= itemQuantity and 1 or 0.4\n\t\ttext_Money.TextComponent.FontColor.a = player.PlayerData.Berry >= itemQuantity and 1 or 0.4\n\t\t\n\t\tbutton_Upgrade.SpriteGUIRendererComponent.ImageRUID = player.PlayerData.Berry >= itemQuantity and \"b598cf22e48a4e4bb7a3c47cb719f679\" or \"92a7f54bc19c4447be0b4b6c60dfc6ff\"\n\t\tbutton_Upgrade.ButtonComponent.Enable = player.PlayerData.Berry >= itemQuantity \n\t\n\t\tbutton_Upgrade.TextComponent.Text = player.PlayerData.Gold >= itemQuantity and levelUpText or lackOfGoldText\n\t\tbutton_Upgrade.TextComponent.FontColor.a = player.PlayerData.Berry >= itemQuantity and 1 or 0.4\n\t\t\n\telseif itemID == _PlayerService.Ruby_ID - 20000 then\n\t\tbutton_Condition.SpriteGUIRendererComponent.Color = player.PlayerData.Ruby >= itemQuantity and Color.FromHexCode(\"#8683b1\") or Color.FromHexCode(\"#a25757\") \n\t\timage_Ingredient.SpriteGUIRendererComponent.Color.a = player.PlayerData.Ruby >= itemQuantity and 1 or 0.4\n\t\ttext_Money.TextComponent.FontColor.a = player.PlayerData.Ruby >= itemQuantity and 1 or 0.4\n\t\t\n\t\tbutton_Upgrade.SpriteGUIRendererComponent.ImageRUID = player.PlayerData.Ruby >= itemQuantity and \"b598cf22e48a4e4bb7a3c47cb719f679\" or \"92a7f54bc19c4447be0b4b6c60dfc6ff\"\n\t\tbutton_Upgrade.ButtonComponent.Enable = player.PlayerData.Ruby >= itemQuantity \n\t\t\n\t\tbutton_Upgrade.TextComponent.Text = player.PlayerData.Gold >= itemQuantity and levelUpText or lackOfGoldText\n\t\tbutton_Upgrade.TextComponent.FontColor.a = player.PlayerData.Ruby >= itemQuantity and 1 or 0.4\n\tend\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Refresh_UpgradeUI_Item"
        }
      ],
