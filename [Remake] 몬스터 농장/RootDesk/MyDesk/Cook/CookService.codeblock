      "Methods": [
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 요리 UI를 엽니다. ------------------------------------------------------\nlocal player = _UserService.LocalPlayer\nplayer.PlayerMove.Type =\"UI\"\n\n\nif player.PlayerData.IsCooked then\n\tself.Text_Timer.Enable = true\n\tself.UI_Gauge.Enable = false\nelse\n\tself.Text_Timer.Enable = false\n\tself.UI_Gauge.Enable = true\nend\n\nself.CookUI.Enable = true\n\n\n-- 요리 아이템을 생성합니다. ----------------------------------------------\nself:CreateCookItems()\n\n-- 설정된 필터대로 카테고리를 적용합니다. ---------------------------------\nself:ChangeCategory(self.Filter)\n\n-- 요리 UI를 갱신합니다. --------------------------------------------------\nself:RefreshPotUI(true)\n\n-- 장비 UI를 갱신합니다. --------------------------------------------------\nself:RefreshTools()\n\n-- 타이머 UI를 갱신합니다. ------------------------------------------------\n_CookService:RefreshTimer(player.PlayerData.CurPotTimer)\n\n-- 효과음 재생 ------------------------------------------------------------\n_SoundService:PlaySound(\"3060a8c8180a423faacb3f8d29200b85\", 1)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Open"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "self.UI_Lock.Enable = true\n\nif self.CookUI.Enable then\n\tlocal player = _UserService.LocalPlayer\n\tplayer.PlayerMove.Type =\"none\"\n\n\tself.CookUI.Enable = false\nend",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "Close"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local player = _UserService.LocalPlayer\n\nlocal list_Children = self.List.Children\nlocal list_owner_Children = self.List_Owner_Cook.Children\n\n-- 식재료 아이템만 인벤토리에서 가져옵니다. ------------------------------\nlocal dataSetName = \"ItemDataSet_Base\" \n\n\n-- 기존 식재료 테이블을 초기화합니다. ------------------------------------\ntable.clear(self.IngredientTable)\n\nlocal cook_ItemTable = {}\n\n-- 식재료 아이템만 테이블에 담습니다. ------------------------------------\nfor i = 1, #player.PlayerData.Inventory_Type do\n\tlocal itemType = player.PlayerData.Inventory_Type[i] \n\tif isvalid(itemType) and itemType == \"식재료\" then\n\t\ttable.insert(self.IngredientTable, i)\n\t\n\telseif isvalid(itemType) and itemType == \"요리\" then\n\t\ttable.insert(cook_ItemTable, i)\n\tend\nend\n\n-- 재료 아이템의 종류만큼 Item을 생성합니다. -----------------------------\nfor x = #list_Children, #self.IngredientTable do\n\tlocal newItem = self.Item:Clone(\"Item_\"..tostring(x))\nend\n\nlist_Children = self.List.Children\n\n\n-- 요리 아이템의 종류만큼 Item을 생성합니다. -----------------------------\nfor x = #list_owner_Children, #cook_ItemTable do\n\tlocal newItem = self.Item_Owner_Cook:Clone(\"Item_\"..tostring(x))\nend\n\nlist_owner_Children = self.List_Owner_Cook.Children\n\n\nif self.Filter == \"Ingredient\" then\n\t-- 재료 아이템의 정보를 갱신합니다. ----------------------------------\n\tfor i = 2, #list_Children do\n\t\tlist_Children[i].Cook_Item.Idx = self.IngredientTable[i-1]\n\t\tlist_Children[i].Cook_Item:RefreshInfo()\n\tend\n\t\nelseif self.Filter == \"Cook\" then\n\t-- 요리 아이템의 정보를 갱신합니다. ----------------------------------\n\tfor i = 2, #list_owner_Children do\n\t\tlist_owner_Children[i].Cook_Owner_Item.Idx = cook_ItemTable[i-1]\n\t\tlist_owner_Children[i].Cook_Owner_Item:RefreshInfo()\n\tend\nend\n\n\nif self.UI_Lock.Enable then\n\tself.UI_Lock.Enable = false\nend\n\nself:RefreshButtons()",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshItems"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "idx"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "recipe_Level_Buff"
            }
          ],
          "Code": "-- 솥에 재료를 넣습니다. ------------------\n_PlayerService:DestroyItem(player, idx, 1)\n\nlocal itemGeneration = tonumber(_DataService:GetCell(\"ItemDataSet_Base\", idx - 20000, \"generation\"))\nlocal itemGrade = _DataService:GetCell(\"ItemDataSet_Base\", idx - 20000, \"etc\")\n\nlocal originValue = tonumber(_DataService:GetCell(\"CookDataSet_Ingredient_Value\", itemGeneration, \"value\"))\n\nlocal gradePoint = 0\n\n-- 등급에 따른 가산 비율을 적용합니다. ----\nif itemGrade == \"A\" then\n\tgradePoint = self.A_Grade_Point\n\t \nelseif itemGrade == \"B\" then\n\tgradePoint = self.B_Grade_Point \n\t\nelseif itemGrade == \"C\" then\n\tgradePoint = self.C_Grade_Point\nend\n\nlocal totalPoint = ((originValue * gradePoint) + ((originValue * gradePoint) * recipe_Level_Buff))\n\nplayer.PlayerData.CurPotGauge = player.PlayerData.CurPotGauge + totalPoint\n\n_SoundService:PlaySound(\"029be48569da47e99012b93a23f1b64d\", 1, player.Name)\n\n-- 통신합니다. ================\n_TransferService:Transfer(\"out\")\n--=============================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "PutIngredient"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "array",
              "DefaultValue": "number",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "ingredients_IDX"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "potMaxGauge"
            },
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "recipe_Level_Buff"
            }
          ],
          "Code": "-- 재료를 자동 채우기 합니다. -----------------------------------------------------------------------\nlocal totalGauge = 0\n\nlocal ingredient_ID_Table = {}\nlocal ingredient_Quantity_Table = {}\nlocal ingredient_Subtraction_Table = {}\n\n-- 식재료 아이템의 수량을 담는 테이블과 감산할 수량을 담는 테이블을 생성합니다. ---------------------\nfor i = 1, #ingredients_IDX do\n\ttable.insert(ingredient_Quantity_Table, player.PlayerData.Inventory_Quantity[ingredients_IDX[i]])\n\ttable.insert(ingredient_Subtraction_Table, 0)\nend\n\n-- 식재료 테이블을 세대를 기준으로 정렬합니다. ------------------------------------------------------\nfor i = 1, #ingredients_IDX do\n\tfor x = 1, #ingredients_IDX - 1 do\n\t\tlocal curGeneration = tonumber(_DataService:GetCell(\"ItemDataSet_Base\", player.PlayerData.Inventory_Name[ingredients_IDX[x]] - 20000, \"generation\"))\n\t\tlocal nextGeneration = tonumber(_DataService:GetCell(\"ItemDataSet_Base\", player.PlayerData.Inventory_Name[ingredients_IDX[x+1]] - 20000, \"generation\"))\n\t\t\n\t\tif curGeneration > nextGeneration then\n\t\t\tingredients_IDX[x], ingredients_IDX[x+1] = ingredients_IDX[x+1], ingredients_IDX[x]\n\t\t\tingredient_Quantity_Table[x], ingredient_Quantity_Table[x+1] = ingredient_Quantity_Table[x+1], ingredient_Quantity_Table[x] \n\t\tend\n\tend\nend\n\n--  플레이어가 보유한 식재료의 ID 값만 담는 테이블을 생성합니다. ------------------------------------\nfor i = 1, #ingredients_IDX do\n\ttable.insert(ingredient_ID_Table, player.PlayerData.Inventory_Name[ingredients_IDX[i]])\nend\n\n-- PotGauge에 가산할 총량입니다. --------------------------------------------------------------------\nlocal totalValue = 0\n\n-- 재료 테이블을 순회하며 점수 계산 + 감산할 개수를 계산합니다. -------------------------------------\nfor i = 1, #ingredients_IDX do\n\tlocal itemGeneration = tonumber(_DataService:GetCell(\"ItemDataSet_Base\", player.PlayerData.Inventory_Name[ingredients_IDX[i]] - 20000, \"generation\"))\n\tlocal originValue = tonumber(_DataService:GetCell(\"CookDataSet_Ingredient_Value\", itemGeneration, \"value\"))\n\tlocal itemGrade = _DataService:GetCell(\"ItemDataSet_Base\", player.PlayerData.Inventory_Name[ingredients_IDX[i]] - 20000, \"etc\")\n\tlocal gradePoint = 0\n\n\t-- 등급에 따른 가산 비율을 적용합니다. ----\n\tif itemGrade == \"A\" then\n\t\tgradePoint = self.A_Grade_Point\n\t\t \n\telseif itemGrade == \"B\" then\n\t\tgradePoint = self.B_Grade_Point \n\t\t\n\telseif itemGrade == \"C\" then\n\t\tgradePoint = self.C_Grade_Point\n\tend\n\n\tfor x = 1, ingredient_Quantity_Table[i] do\n\t\tlocal totalPoint = ((originValue * gradePoint) + ((originValue * gradePoint) * recipe_Level_Buff))\n\t\ttotalValue = totalValue + totalPoint\n\t\tingredient_Subtraction_Table[i] = ingredient_Subtraction_Table[i] + 1\n\t\t\n\t\tif player.PlayerData.CurPotGauge + totalValue >= potMaxGauge then\n\t\t\tbreak\n\t\tend\n\tend\n\t\n\tif player.PlayerData.CurPotGauge + totalValue >= potMaxGauge then\n\t\tbreak\n\tend\nend\n\n-- PotGauge에 TotalValue를 가산합니다. --------------------------------------------------------------\nplayer.PlayerData.CurPotGauge = player.PlayerData.CurPotGauge + totalValue\n\n-- 사용한 식재료를 소모합니다. ---------------------------------------------------------------------- \nfor i = 1, #ingredient_ID_Table do\n\t\n\tif ingredient_Subtraction_Table[i] >= 1 then\n\t\t_PlayerService:DestroyItem(player, ingredient_ID_Table[i], ingredient_Subtraction_Table[i])\n\tend\nend\n\n_SoundService:PlaySound(\"029be48569da47e99012b93a23f1b64d\", 1, player.Name)\n\n-- 통신합니다. ================\n_TransferService:Transfer(\"out\")\n--=============================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "PutAutoIngredient"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "boolean",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "isCalledByOpenFunction"
            }
          ],
          "Code": "-- 요리 UI를 갱신합니다. ---------------------------------------------------\n\nlocal player = _UserService.LocalPlayer\n\nlocal curPotLevel = player.PlayerData.CurPotLevel\nlocal curPotGauge = player.PlayerData.CurPotGauge\n\nlocal cookGauge = _EntityService:GetEntityByPath(self.UI_Gauge.Path..\"/UI_Gauge_Body\")\n\n-- 플레이어가 장착하고 있는 항아리의 맥스 게이지를 가져옵니다.\nself.CurPotMaxGauge = tonumber(_DataService:GetCell(\"CookDataSet_Pot\", curPotLevel, \"maxQuantity\"))\n\t\t\t\nlocal potPercent = (curPotGauge * 100) / self.CurPotMaxGauge\n\t\t\ncookGauge.SliderComponent.Value = potPercent * 0.01\n\n\nlocal kitchenSuit_Generation = player.PlayerData.CurSuit_Level\nlocal kitchenSuit_Buff = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", kitchenSuit_Generation, \"ReduceGaugeBuff\")) * 0.01 \n\nlocal minimumQuantity = tonumber(_DataService:GetCell(\"CookDataSet_Base\", 1, \"condition\"))\nlocal requiredQuantity = minimumQuantity - math.floor(minimumQuantity * kitchenSuit_Buff)\n\n-- 요리를 할 수 있는 정도의 게이지를 올렸다면 -----------------------------\nif curPotGauge >= requiredQuantity then\n\tcookGauge.SliderComponent.FillRectColor = Color.FromHexCode(\"#675fff\")\nelse\n\tcookGauge.SliderComponent.FillRectColor = Color.FromHexCode(\"#dadada\")\nend\n\n-- UI에 반영합니다. -------------------------------------------------------\nif potPercent > 100 then\n\tpotPercent = 100\nend\n\nif curPotGauge > self.CurPotMaxGauge then\n\tcurPotGauge = self.CurPotMaxGauge\nend\n\nself.CookUI_Text.TextComponent.Text = \"<color=#fffff>\"..tostring(math.floor(curPotGauge))..\" / \"..tostring(math.floor(self.CurPotMaxGauge))..\"</color> (\"..tostring(math.floor(potPercent))..\"%)\"\n\t\t\t\nif not isCalledByOpenFunction then\n\tcookGauge.Cook_BlinkButton:whiteEffect(cookGauge.SliderComponent.FillRectColor)\nend\n\n-- UI를 갱신합니다. -------------------------------------------------------\nself:RefreshCookUI()\nself:RefreshButtons()",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshPotUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "local player = _UserService.LocalPlayer\n\n-- '일괄 넣기' 버튼 Refresh ------------------------------------------------------------\n\nif player.PlayerData.CurPotGauge >= self.CurPotMaxGauge or #self.List.Children == 1 or self.Filter == \"Cook\" then\n\tself.Button_Put.ButtonComponent.Enable = false\n\tself.Button_Put.TextComponent.FontColor.a = 0.3\n\t\nelse\n\tif not player.PlayerData.IsCooked then\n\t\tself.Button_Put.ButtonComponent.Enable = true\n\t\tself.Button_Put.TextComponent.FontColor.a = 1\n\tend\nend\n\n-- '만들기' 버튼 Refresh ------------------------------------------------------------\n\nlocal kitchenSuit_Generation = player.PlayerData.CurSuit_Level\nlocal kitchenSuit_Buff = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", kitchenSuit_Generation, \"ReduceGaugeBuff\")) * 0.01 \n\nlocal minimumQuantity = tonumber(_DataService:GetCell(\"CookDataSet_Base\", 1, \"condition\"))\nlocal requiredQuantity = minimumQuantity - math.floor(minimumQuantity * kitchenSuit_Buff)\n\n-- 최소 필요 게이지 이상이라면 ------------------------------------------------------\nif not player.PlayerData.IsCooked then\n\tif player.PlayerData.CurPotGauge == 0 then\n\t\tself.Button_Cook.ButtonComponent.Enable = false\n\t\tself.Button_Cook.TextComponent.FontColor.a = 0.3\n\t\tself.Button_Ready.Enable = false\n\t\t\n\telseif player.PlayerData.CurPotGauge >= requiredQuantity then\n\t\tself.Button_Cook.ButtonComponent.Enable = true\n\t\tself.Button_Cook.TextComponent.FontColor.a = 1\n\t\tself.Button_Ready.Enable = false\n\t\t\n\telseif player.PlayerData.CurPotGauge >= 1 then\n\t\tself.Button_Cook.ButtonComponent.Enable = true\n\t\tself.Button_Cook.TextComponent.FontColor.a = 1\n\t\tself.Button_Ready.Enable = true\n\tend\n\nelse\n\t-- 최소 필요 게이지를 도달하지 못했다면 ---------------------------------------------\n\tself.Button_Cook.ButtonComponent.Enable = false\n\tself.Button_Ready.Enable = false\n\tself.Button_Cook.TextComponent.FontColor.a = 0.3\nend\n\n-- 게이지, 요리 회수 버튼 Refresh ---------------------------------------------------\nlocal cookGauge = _EntityService:GetEntityByPath(self.CookUI.Path..\"/CookPopUp/UI_Left/UI_Gauge\")\nlocal cookTimer = _EntityService:GetEntityByPath(self.CookUI.Path..\"/CookPopUp/UI_Left/UI_Timer\")\n\n\t\t\t\ncookGauge.Enable = not player.PlayerData.IsCooked\ncookTimer.Enable = player.PlayerData.IsCooked\n",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshButtons"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "-- 플레이어를 요리 상태로 변경합니다. -------\nplayer.PlayerData.IsCooked = true\n\n-- 통신합니다. ================\n_TransferService:Transfer(\"out\", player.Name)\n--=============================",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "DoCook"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "-- 소요 시간이 끝나고 요리를 얻습니다. ------\nplayer.PlayerData.CurPotTimer = 0\nplayer.PlayerData.CurPotGauge = 0\nplayer.PlayerData.IsCooked = false\n\nplayer.PlayerSubData.GetCookCount = player.PlayerSubData.GetCookCount + 1\n\nself:GiveReward(player.Name)\n",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "GetCook"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 가챠 창을 엽니다. --------------------------------------------------------------\nlocal player = _UserService.LocalPlayer\nlocal player_Progress = self.Player_CookProgress\nlocal dataSetName = \"CookDataSet_Base\"\n\n-- 예외 처리 ----------------------------------------------------------------------\nlocal gap = 1 \n\nif player_Progress < self.Origin_CookQuantity then\n\tgap = 1\nelse\n\tgap = player_Progress - 3\nend\n-----------------------------------------------------------------------------------\n\n\n-- 플레이어가 획득하게 될 요리 아이템들을 테이블에 넣습니다. ----------------------\nlocal item_Table = {}\nfor i = gap, player_Progress do\n\ttable.insert(item_Table, tonumber(_DataService:GetCell(dataSetName, i, \"id\")))\nend\n-----------------------------------------------------------------------------------\n\n-- 테이블에 담은 요리 아이템 중 하나를 랜덤으로 획득하게 합니다. ------------------\nlocal randNumber = 0\n-----------------------------------------------------------------------------------\n\nlocal randValue = _UtilLogic:RandomIntegerRange(0, 100)\n\t\n-- 획득 공식을 적용합니다. --------------------------------------------------------\nif #item_Table == 1 then\n\t\n\t-- 100% 확률로 당첨\n\trandNumber = 1\n\t\nelseif #item_Table == 2 then\n\n\t-- 75%의 확률로 ID 1, 25% 확률로 ID 2인 아이템 당첨\n\tif randValue > 75 then\n\t\trandNumber = 1\n\telse\n\t\trandNumber = 2\n\tend\n\t\t\nelseif #item_Table == 3 then\n\n\t-- 50%의 확률로 ID 1, 25% 확률로 ID 2, 25% 확률로 ID 3인 아이템 당첨\n\tif randValue > 50 then\n\t\trandNumber = 1\n\telseif randValue > 25 then\n\t\trandNumber = 2\n\telse\n\t\trandNumber = 3\n\tend\n\t\nelseif #item_Table == 4 then\n\n\t-- 25%의 확률로 ID 1, 25% 확률로 ID 2, 25% 확률로 ID 3, 25% 확률로 ID 4인 아이템 당첨\n\tif randValue > 75 then\n\t\trandNumber = 1\n\telseif randValue > 50 then\n\t\trandNumber = 2\n\telseif randValue > 25 then\n\t\trandNumber = 3\n\telse\n\t\trandNumber = 4\n\tend\t\nend\n\n-- 퀘스트:12 요리 등급 이상 시도,16 등급 이상  ----------------------------------------------\nlocal rewardItem_ID = item_Table[randNumber] -- 20033\nlocal rewardItem_Rank = tonumber(_DataService:GetCell(\"ItemDataSet_Base\", rewardItem_ID - 20000, \"etc\"))\n\nif _QuestService:CheckHaveQuest(player,17) then \n\tif rewardItem_Rank >= 8 then\n\t_SubDataService:playerCookCountUp(player,17)\n\tend\nend\nif _QuestService:CheckHaveQuest(player,19) then \n\tif rewardItem_Rank >= 12 then\n\t_SubDataService:playerCookCountUp(player,19)\n\tend\nend\nif _QuestService:CheckHaveQuest(player,23) then \n\tif rewardItem_Rank >= 16 then\n\t_SubDataService:playerCookCountUp(player,23)\n\tend\nend\n\n----------------------------------------------\n\n_GachaService:DecisionOpen(rewardItem_ID, \"아이템\", \"730834f3a80f42a696bdaaf1a177be60\", 1, nil, \"Cook\")\n\nself.Player_CookProgress = 0\nself.Player_Cur_Background_Level = 0\n\nself:Close()",
          "Scope": 2,
          "ExecSpace": 6,
          "Attributes": [],
          "Name": "GiveReward"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "value"
            }
          ],
          "Code": "-- 예외 처리 -----------------------------------------------------\nif not isvalid(value) then\n\tvalue = 0\nend\n\nlocal player = _UserService.LocalPlayer\n\n\n-- 요리가 완료되면 버튼을 활성화합니다. --------------------------\nlocal kitchenTool_Generation = player.PlayerData.CurKitchenTool_Level\nlocal kitchenTool_Buff = tonumber(_DataService:GetCell(\"CookDataSet_KitchenTool\", kitchenTool_Generation, \"ReduceTimeBuff\")) * 0.01 \nlocal cookMaxTimer = _CookService.Origin_CookMaxTimer - math.floor(_CookService.Origin_CookMaxTimer * kitchenTool_Buff)\n\n-- 요리 텍스트에 남은 시간을 반영합니다. -------------------------\nself.Text_Timer.TextComponent.Text = self:RemainingTimeCalculator(cookMaxTimer, value)\n\n\n-- 타이머가 채워지지 않았다면 '요리 완성' 버튼을 비활성화합니다. -\nself.Text_Timer.ButtonComponent.Enable = (cookMaxTimer - value <= 0)",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshTimer"
        },
        {
          "Return": {
            "Type": "string",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "number",
              "DefaultValue": "0",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "maxTimer"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "timer"
            }
          ],
          "Code": "local time = maxTimer - timer\n\n-- 요리 완료까지 남은 시간을 계산해서 return합니다. ---------------\nlocal hour = 0\nlocal minute = 0 \nlocal second = 0\nlocal time_text = ''\n\nif time < 0 then\n\ttime = 0\nelse\n\thour = math.floor(time / 3600)\n\ttime = time - hour * 3600\n\t\n\tminute = math.floor(time / 60)\n\ttime = time - minute * 60\n\t\n\tsecond = time\nend\n \n\nif hour >= 1 then\n\ttime_text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_fusion_RemainingTime_Full\", math.floor(hour), math.floor(minute), math.floor(second))\n\t\nelseif minute >= 1 then\n\ttime_text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_fusion_RemainingTime_Short\", math.floor(minute), math.floor(second))\n\t\nelseif second <= 0 then\n\ttime_text = _LocalizationService.LocalTranslator:GetText(\"Cook_getCook\")\nelse\n\ttime_text = _LocalizationService.LocalTranslator:GetTextFormat(\"UI_fusion_RemainingTime_VeryShort\", math.floor(second))\n\nend\n\nreturn time_text",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RemainingTimeCalculator"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": null,
          "Code": "local player = _UserService.LocalPlayer\n\nlocal list_Children = self.List_Cook.Children\n\nlocal dataSetName = \"CookDataSet_Base\" \n\n-- 요리 아이템들을 List 하위에 생성합니다. --------------\nfor i = #list_Children, _DataService:GetRowCount(dataSetName) do\n\tlocal newItem = self.Item_Cook:Clone(\"Item_\"..tostring(i))\n\tlocal newItem_ID = tonumber(_DataService:GetCell(dataSetName, i, \"id\"))\n\tnewItem.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(\"ItemDataSet_Base\", (newItem_ID - 20000), \"ruid\")\nend\n\nself:RefreshCookUI()",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "CreateCookItems"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": null,
          "Code": "local player = _UserService.LocalPlayer\n\nlocal dataSetName = \"CookDataSet_Base\"\nlocal length = _DataService:GetRowCount(dataSetName)\n\n-- 요리의 최대 세대는 5입니다. --------------------------\nlocal maxGeneration = math.floor(length / self.Origin_CookQuantity) -- 5\n---------------------------------------------------------\n\n-- 배경 Target Position과 조건을 가져옵니다. ------------\nif #self.Background_Target_X_Position == 0 then\n\t\n\tfor i = 1, length do\n\t\tlocal background_X = _DataService:GetCell(dataSetName, i, \"background_X\")\n\t\t\n\t\ttable.insert(self.Cook_Conditions, tonumber(_DataService:GetCell(dataSetName, i, \"condition\")))\n\n\t\tif isvalid(background_X) then\n\t\t\ttable.insert(self.Background_Target_X_Position, tonumber(background_X))\n\t\tend\n\tend\nend\n\n\nlocal kitchenSuit_Generation = player.PlayerData.CurSuit_Level\nlocal kitchenSuit_Buff = tonumber(_DataService:GetCell(\"CookDataSet_Suit\", kitchenSuit_Generation, \"ReduceGaugeBuff\")) * 0.01 \n\n-- 플레이어의 게이지에 해당하는 진행도를 가져옵니다. (최적화 겸용) -\nfor i = self.Player_CookProgress + 1, #self.Cook_Conditions do\n\t\n\tlocal minimumQuantity = self.Cook_Conditions[i]\n\tlocal requiredQuantity = self.Cook_Conditions[i] - math.floor(self.Cook_Conditions[i] * kitchenSuit_Buff)\n\t\n\tif player.PlayerData.CurPotGauge >= requiredQuantity then\n\t\tself.Player_CookProgress = i \n\t\tself.Player_Cur_Background_Level = tonumber(_DataService:GetCell(dataSetName, i, \"backgroundID\"))\n\telse\n\t\tbreak\n\tend\nend\n\n\n\n-- 배경 이동 --\nlocal cur_Background_Gap = 0\n\nif self.Player_Cur_Background_Level >= 1 then\n\tcur_Background_Gap = self.Background_Target_X_Position[self.Player_Cur_Background_Level]\nend\n\nlocal prev_Background_Gap = 0 \n\nif self.Player_Cur_Background_Level >= 1 then\n\tprev_Background_Gap = self.Player_Cur_Background_Level == 1 and 0 or self.Background_Target_X_Position[self.Player_Cur_Background_Level - 1] \nend\n\nlocal background_Pos_Gap =  (cur_Background_Gap - prev_Background_Gap) / self.Origin_CookQuantity\n\nlocal cur_Cook_Index_InGroup = self.Player_CookProgress % self.Origin_CookQuantity\n\nif self.Player_CookProgress ~= 0 and cur_Cook_Index_InGroup == 0 then\n\tcur_Cook_Index_InGroup = self.Origin_CookQuantity\nend\n\nlocal prevPos = self.Image_Background.UITransformComponent.WorldPosition\nself.Image_Background.TweenLineComponent.Positions[1] = Vector2(prev_Background_Gap + (background_Pos_Gap * cur_Cook_Index_InGroup), 0)\n\nself.Image_Background.UITransformComponent.WorldPosition = prevPos\nself.Image_Background.TweenLineComponent:RestartFromCurrentPosition()\n\n\n-- 아이템 이동 --\nlocal maxPosition = -2600\nlocal list_Children = self.List_Cook.Children\nlocal list_Length = #list_Children\nlocal posGap = maxPosition / (list_Length - 1)\n\nlocal prevItem_Pos = self.List_Cook.UITransformComponent.WorldPosition\nself.List_Cook.TweenLineComponent.Positions[1] = Vector2(self.Player_CookProgress * posGap, 0)\n\nself.List_Cook.UITransformComponent.WorldPosition = prevItem_Pos \nself.List_Cook.TweenLineComponent:RestartFromCurrentPosition()",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "RefreshCookUI"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "filter"
            }
          ],
          "Code": "-- 식재료 / 요리 카테고리를 변경합니다.\n\nself.Filter = filter\n\nif self.Filter == \"Ingredient\" then\n\tself.List.Enable = true\n\tself.List_Owner_Cook.Enable = false\n\t\n\tself.Button_Category_Cook_Inner.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1) \n\tself.Button_Category_Ingredient_Inner.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1) \n\t\n\tself.Button_Category_Cook_Inner.ButtonComponent.Enable = true\n\tself.Button_Category_Cook.ButtonComponent.Enable = true\n\t\n\tself.Button_Category_Ingredient_Inner.ButtonComponent.Enable = false\n\tself.Button_Category_Ingredient.ButtonComponent.Enable = false\n\t\nelseif self.Filter == \"Cook\" then\n\tself.List.Enable = false\n\tself.List_Owner_Cook.Enable = true\n\t\n\tself.Button_Category_Cook_Inner.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1)  \n\tself.Button_Category_Ingredient_Inner.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1) \n\t\n\tself.Button_Category_Cook_Inner.ButtonComponent.Enable = false\n\tself.Button_Category_Cook.ButtonComponent.Enable = false\n\t\n\tself.Button_Category_Ingredient_Inner.ButtonComponent.Enable = true\n\tself.Button_Category_Ingredient.ButtonComponent.Enable = true\nend\n\n-- 효과음을 재생합니다. -----------------------------------------\n_SoundService:PlaySound(\"01368b4822a340c2a93ec088bdd81c07\", 0.45)\n\nself:RefreshButtons()\nself:RefreshItems()",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "ChangeCategory"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": null,
          "Code": "-- 플레이어가 착용한 장비를 UI에 갱신합니다. -------------------\nlocal player = _UserService.LocalPlayer \n\n-- 플레이어의 현재 장비 레벨을 받아옵니다. ---------------------\nlocal potLevel = player.PlayerData.CurPotLevel\nlocal kitchenTool_Level = player.PlayerData.CurKitchenTool_Level\nlocal recipe_Level = player.PlayerData.CurRecipe_Level\nlocal suit_Level = player.PlayerData.CurSuit_Level\n\n-- 장비 데이터셋을 가져옵니다. ---------------------------------\nlocal pot_DataSetName = \"CookDataSet_Pot\"\nlocal tool_DataSetName = \"CookDataSet_KitchenTool\"\nlocal recipe_DataSetName = \"CookDataSet_Recipe\"\nlocal suit_DataSetName = \"CookDataSet_Suit\"\n\nself.Image_Pot.ImageRUID = _DataService:GetCell(pot_DataSetName, potLevel, \"ruid\")\n\nself.Text_PotName.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(pot_DataSetName, potLevel, \"name\"))\n\nself.Image_KitchenTool.ImageRUID = _DataService:GetCell(tool_DataSetName, kitchenTool_Level, \"ruid\")\nself.Image_Recipe.ImageRUID = _DataService:GetCell(recipe_DataSetName, recipe_Level, \"ruid\")\nself.Image_Suit.ImageRUID = _DataService:GetCell(suit_DataSetName, suit_Level, \"ruid\")\n\n-- 장비 세대를 표시해줍니다. -----------------------------------\n\n-- 솥 --\nif potLevel == 1 then\n\tself.Text_Pot_Generation.Text = \"★<color=#6b6b6b>★★★★</color>\"\nelseif potLevel == 2 then\n\tself.Text_Pot_Generation.Text = \"★★<color=#6b6b6b>★★★</color>\"\nelseif potLevel == 3 then\n\tself.Text_Pot_Generation.Text = \"★★★<color=#6b6b6b>★★</color>\"\nelseif potLevel == 4 then\n\tself.Text_Pot_Generation.Text = \"★★★★<color=#6b6b6b>★</color>\"\nelseif potLevel == 5 then\n\tself.Text_Pot_Generation.Text = \"★★★★★\"\nend\n\n-- 도구 --\nif kitchenTool_Level == 1 then\n\tself.Text_Tool_Generation.Text = \"★<color=#6b6b6b>★★★★</color>\"\nelseif kitchenTool_Level == 2 then\n\tself.Text_Tool_Generation.Text = \"★★<color=#6b6b6b>★★★</color>\"\nelseif kitchenTool_Level == 3 then\n\tself.Text_Tool_Generation.Text = \"★★★<color=#6b6b6b>★★</color>\"\nelseif kitchenTool_Level == 4 then\n\tself.Text_Tool_Generation.Text = \"★★★★<color=#6b6b6b>★</color>\"\nelseif kitchenTool_Level == 5 then\n\tself.Text_Tool_Generation.Text = \"★★★★★\"\nend\n\n-- 복장 --\nif suit_Level == 1 then\n\tself.Text_Suit_Generation.Text = \"★<color=#6b6b6b>★★★★</color>\"\nelseif suit_Level == 2 then\n\tself.Text_Suit_Generation.Text = \"★★<color=#6b6b6b>★★★</color>\"\nelseif suit_Level == 3 then\n\tself.Text_Suit_Generation.Text = \"★★★<color=#6b6b6b>★★</color>\"\nelseif suit_Level == 4 then\n\tself.Text_Suit_Generation.Text = \"★★★★<color=#6b6b6b>★</color>\"\nelseif suit_Level == 5 then\n\tself.Text_Suit_Generation.Text = \"★★★★★\"\nend\n\n-- 레시피 --\nif recipe_Level == 1 then\n\tself.Text_Recipe_Generation.Text = \"★<color=#6b6b6b>★★★★</color>\"\nelseif recipe_Level == 2 then\n\tself.Text_Recipe_Generation.Text = \"★★<color=#6b6b6b>★★★</color>\"\nelseif recipe_Level == 3 then\n\tself.Text_Recipe_Generation.Text = \"★★★<color=#6b6b6b>★★</color>\"\nelseif recipe_Level == 4 then\n\tself.Text_Recipe_Generation.Text = \"★★★★<color=#6b6b6b>★</color>\"\nelseif recipe_Level == 5 then\n\tself.Text_Recipe_Generation.Text = \"★★★★★\"\nend",
