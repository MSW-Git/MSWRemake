        },
        {
          "Type": "string",
          "DefaultValue": "\"2f7700012b7e49399595932f9ef8e1ac\"",
          "SyncDirection": 3,
          "Attributes": [],
          "Name": "Walk_RUID"
        },
        {
          "Type": "string",
          "DefaultValue": "\"\"",
          "SyncDirection": 3,
          "Attributes": [],
