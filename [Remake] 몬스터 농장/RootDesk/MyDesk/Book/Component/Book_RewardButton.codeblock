            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 통신합니다. ================\n_TransferService:Transfer(\"in\")\n--=============================\n\n-- reward 보상을 획득합니다. -----------------------------\nlocal player = _UserService.LocalPlayer\n\nlocal category = _BookService.Category\n\nif category == \"Monster\" then\n\t_PlayerService:GetMonsterBookReward(player, self.Id)\nend\n\nself.Entity.Enable = false",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "OnClick"
        }
      ],
      "EntityEventHandlers": [
        {
          "Name": "HandleButtonClickEvent",
          "EventName": "ButtonClickEvent",
          "Target": "self",
          "Code": "--===========================================\n-- 서버 지연 대응 로직\n--===========================================\nlocal player = _UserService.LocalPlayer\n\nif player.PlayerData.IsTransferring then\n\treturn\nend\n--===========================================\n\nself:OnClick()",
          "Scope": 2,
          "ExecSpace": 2
        }
      ]
    }
