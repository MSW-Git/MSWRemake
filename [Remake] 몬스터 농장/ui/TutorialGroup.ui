                "a": 0.72
              },
              "DropShadowDistance": 32.0,
              "Font": 0,
              "FontColor": {
                "r": 0.74833566,
                "g": 0.733325958,
                "b": 0.9003906,
                "a": 1.0
              },
              "FontSize": 33,
              "MaxSize": 40,
              "MinSize": 10,
              "OutlineColor": {
                "r": 0.7,
                "g": 0.7,
                "b": 0.7,
                "a": 1.0
              },
              "OutlineDistance": {
                "x": 1.0,
                "y": -1.0
              },
              "OutlineWidth": 1.0,
              "Overflow": 0,
              "OverrideSorting": false,
              "Padding": {
                "left": 0,
                "right": 0,
                "top": 0,
                "bottom": 0
              },
              "SizeFit": false,
              "Text": "- 어느 날, 몬스터가 마법의 힘으로 아이템을 만든다는 사실을 알게 되었다.\n- <color=#fff389>\"그래.. 몬스터는 돈이 된다!\" </color>\n- 부자가 되고 싶은 당신, 저금한 돈과 함께 영혼까지 끌어모아 결국은 몬스터 농장을 차리고야 만다.",
              "UseOutLine": false,
              "Enable": true
