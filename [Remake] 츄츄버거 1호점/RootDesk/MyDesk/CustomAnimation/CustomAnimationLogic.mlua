@Logic
script CustomAnimationLogic extends Logic

	property table clipData = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 초기화 작업 수행
	end

	method number InterpolateKeyframes(table keyframes, number time)
		-- 키프레임 데이터를 기반으로 주어진 시간의 보간된 값을 계산
		return _TweenCurveLogic:GetTweenValue(time,keyframes)
	end

	method void ApplyAnimation(table animationData, number currentTime, any callback)
		-- 애니메이션 데이터를 현재 시간에 맞게 적용
		for _, curve in ipairs(animationData.curves) do
		        local propertyName = curve.propertyName
		        local keyframes = curve.keyframes
				local path = curve.path
		        local interpolatedValue = self:InterpolateKeyframes(keyframes, currentTime)
		        if interpolatedValue then    
					callback(path,propertyName,interpolatedValue)
		    	end
		end
	end

	method table GetClip(string animation, string clip)
		-- 애니메이션 클립 데이터를 가져오거나 캐시에서 로드
		if self.clipData[animation] == nil then
			self.clipData[animation] = {}
		end
		
		if self.clipData[animation][clip] == nil then
			local data = _DataService:GetTable(animation)
			if data ~= nil then
				for i = 1, data:GetRowCount() do
					local clipName = data:GetCell(i,"clip")
					if clipName == clip then
						local json = _HttpService:JSONDecode(data:GetCell(i,"data"))
						self.clipData[animation][clip] = json
						break
					end
				end
			end
		end
		return self.clipData[animation][clip]
	end

end