@Struct
script StoreRankingRewardData

	property integer Index = 0

	property integer Ranking = 0

	property integer Score = 0

	property SyncTable<string, integer> Rewards

	property integer ReexamCost = 0

	method void Load(any dataRow)
		-- CSV 데이터 행에서 랭킹 보상 정보를 로드하는 함수
		---@type UserDataRow
		local row = dataRow
		
		self.Index = tonumber(row:GetItem("Index"))
		self.Ranking = tonumber(row:GetItem("Ranking"))
		self.Score = tonumber(row:GetItem("Score"))
		self.ReexamCost = tonumber(row:GetItem("ReexamCost"))
		
		for i = 1, 3 do
			local reward = row:GetItem("Reward"..i)
			
			local rewardData = _UtilLogic:Split(reward, ",")
			local itemId = rewardData[1]
			local itemCount = tonumber(rewardData[2])
			
			if self.Rewards[itemId] == nil then
				self.Rewards[itemId] = 0
			end
			self.Rewards[itemId] = itemCount
		end
	end

	method table GetAdjustedReward(integer ranking, integer stageId)
		-- 플레이어의 정확한 랭킹에 따라 조정된 보상을 계산하여 반환하는 함수
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		
		local adjustedCount = function(index, userRk, itemId)
			local currentData = stageData:GetStageRankingData(index)
		
			local exData = stageData:GetStageRankingData(index+1)
			if exData == nil then
				exData = currentData
			end
			
			local nextData = stageData:GetStageRankingData(index-1)
			if nextData == nil then
				nextData = currentData
			end
			
			local exCount = exData.Rewards[itemId]
		
			local nowCount = currentData.Rewards[itemId]
		
				
			local gap = math.abs(nextData.Ranking - currentData.Ranking)
			local currentPos = math.abs( userRk - currentData.Ranking)
			
			local percent = 0
			if gap ~= currentPos then
				percent = math.floor( ( (gap - currentPos)/gap  + 0.005)  * 10)/10
			end
		
			local result = math.floor(exCount + nowCount * ( 1 - percent ))
			
			return result
		end
		
		local getMaxCount = function(index, userRk, itemId)
			local currentData = stageData:GetStageRankingData(index)
		
			local nowCount = currentData.Rewards[itemId]
			return nowCount 
		end
		
		local rewardTable = {}
		
		if ranking == 1 then 
			
			for itemId, count in pairs(self.Rewards) do
				count = math.floor(getMaxCount(self.Index, ranking, itemId))
				rewardTable[itemId] = count
			end
			
		elseif ranking == 10000 then 
			
			for itemId, count in pairs(self.Rewards) do
				if itemId == "G0001" or itemId == "G0005" then
					count = ( getMaxCount(self.Index, ranking, itemId) ) * 0.1
		        end
				rewardTable[itemId] = math.floor(count)
			end
			
		else
				
			for itemId, count in pairs(self.Rewards) do
				if itemId == "G0001" or itemId == "G0005" then
					count = adjustedCount(self.Index, ranking, itemId)
				end
				rewardTable[itemId] = count
			end
		end
		
		return rewardTable
	end

end