@Component
script TrainingChar extends Component

	property string TCharId = ""

	property Vector2 OriginPos = Vector2(0,0)

	property Entity EnteredSpot = nil

	property string CharState = ""

	property integer TCharOrder = 0

	property Entity TruckParent = "dbe4260d-bae0-4358-953e-3d8a747ccb0d"

	property Entity MapParent = "b15c9917-b71a-4237-8cb1-06d9a7c2c2d9"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 캐릭터를 초기화하는 함수
		self.OriginPos = self.Entity.UITransformComponent.anchoredPosition
		self._T.emotionBalloon = self.Entity:GetChildByName("EmotionBalloon")
		self._T.emotionBalloon.Enable = false
		self._T.emotionBalloon:GetChildByName("BackLight").Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnEnterSpot(Entity spot)
		-- 스팟에 입장할 때 처리하는 함수
		if isvalid(self.EnteredSpot) then
			self.EnteredSpot.SpotComponent:ClearEnteredTChar()
		end
		
		self.EnteredSpot = spot
		
		if isvalid(self.EnteredSpot) then
			self.Entity:AttachTo(self.EnteredSpot)
			self.Entity.UITransformComponent.anchoredPosition = Vector2(0, 160)
			local player = _UserService.LocalPlayer
			player.PlayerTrainingManager:SendChuChu(self.Entity, self.EnteredSpot.SpotComponent.SpotKey)
		else
			self:GotoOriginPos()
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void Emotion(string emotion)
		-- 캐릭터의 감정 표현을 설정하는 함수
		local img1 = _EntityService:GetEntityByPath("/ui/TrainingGroup/PlacePanel/Foothold/Foot/Truck/CharImage".._StringUtilLogic:NumToString(self.TCharOrder))
		local img2 = _EntityService:GetEntityByPath("/ui/TrainingGroup/PlacePanel/Foothold_HotPlace/Foot/Truck/CharImage".._StringUtilLogic:NumToString(self.TCharOrder))
		 
		_TrialLogic:PlayUIEmployeeAnim(self.Entity, self.TCharId, emotion, true, _UserService.LocalPlayer)
		_TrialLogic:PlayUIEmployeeAnim(img1, self.TCharId, emotion, true, _UserService.LocalPlayer)
		_TrialLogic:PlayUIEmployeeAnim(img2, self.TCharId, emotion, true, _UserService.LocalPlayer)
	end

	@ExecSpace("ClientOnly")
	method void FindHint(table hintItemIds)
		-- 힌트를 찾는 처리를 하는 함수
		self.CharState = "FindHint"
		self:Emotion("Love")
		
		local hint = _EntityService:GetEntityByPath("/ui/TrainingGroup/Hint")
		local hintNum = #hintItemIds
		local player = _UserService.LocalPlayer
		
		for i = 1, hintNum do
			local newHint = _SpawnService:SpawnByEntity(hint, "newHint", Vector3.zero, self.Entity)
			newHint:AttachTo(hint.Parent)
			local hintItemId = hintItemIds[i]
			newHint.SpriteGUIRendererComponent.ImageRUID =  _HintItemDataSetLogic:ReturnIconRuidById(hintItemId)
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_FindItemHint"], 1)
			_UIEntityService:PlayMoveBounceTween(newHint, true, 30, 0.3, false, 1)
			
			_TimerService:SetTimerOnce(function() 
				self.EnteredSpot.SpotComponent:AddHintIcon(hintItemId)
				newHint:Destroy()
				
				_TimerService:SetTimerOnce(function() 
					player.PlayerTrainingManager:SwitchNextChuchu()
					self:Init()
				end, 0.5)
			end, 0.5)
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void FindPaperHint()
		-- 종이 힌트를 찾는 처리를 하는 함수
		local hint = _EntityService:GetEntityByPath("/ui/TrainingGroup/Hint")
		local enteredSpotPos = self.EnteredSpot.UITransformComponent.anchoredPosition:ToVector3()
		local newHint = _SpawnService:SpawnByEntity(hint, "newBox", Vector3.zero, self.Entity)
		newHint:AttachTo(hint.Parent)
		newHint.SpriteGUIRendererComponent.ImageRUID =  _IconRuidEnum.PaperHintIcon 
		newHint.Enable = true
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_FindPaperHint"], 1)
		_UIEntityService:PlayMoveBounceTween(newHint, true, 30, 0.3, false, 1)
		_TimerService:SetTimerOnce(function() 
			newHint:Destroy()
			
		end, 1)
	end

	@ExecSpace("ClientOnly")
	method void GotoOriginPos()
		-- 원래 위치로 이동하는 함수
		self.Entity:AttachTo(self.TruckParent)
		self.Entity.UITransformComponent.anchoredPosition = self.OriginPos
		self:Emotion("Stand")
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 캐릭터를 초기화하는 함수
		self:GotoOriginPos()
		
		self.CharState = "Ready"
		if isvalid(self.EnteredSpot) then
			self.EnteredSpot.SpotComponent:ClearEnteredTChar()
		end
		
		self.EnteredSpot = nil
		
	end

	@ExecSpace("ClientOnly")
	method void SetCharId(string empId)
		-- 캐릭터 ID를 설정하는 함수
		self.TCharId = empId
		self.TCharOrder = tonumber(_UtilLogic:TrimStart(self.Entity.Name, "Char00"))
		
		self:Emotion("Stand")
		self:Init()
	end

end