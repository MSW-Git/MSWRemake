@Struct
script AutoTrainingSlotData

	property string State = ""

	property string ChuchuId = ""

	property integer SlotNum = 0

	property integer ResultMoney = 0

	property table RewardBoxes = {}

	property table Skill1Info = {}

	property table Skill2Info = {}

	property integer RemainDay = 0

	property integer IsOpen = 0

	property integer Reputation = 0

	property integer ResultClover = 0

	property table ResultCloverInfoList = {}

	method void FindSlotNumFromId()
		-- ID로부터 슬롯 번호를 찾는 함수
		
	end

	method void FindSlotNumFromEntity()
		-- 엔티티로부터 슬롯 번호를 찾는 함수
		
	end

	method table ConvertToTable()
		-- 슬롯 데이터를 테이블 형태로 변환하는 함수
		local result = {}
		
		result["State"] = self.State
		result["ChuchuId"] = self.ChuchuId
		result["SlotNum"] = self.SlotNum
		result["RemainDay"] = self.RemainDay
		result["IsOpen"] = self.IsOpen
		
		result["ResultMoney"] = self.ResultMoney
		result["ResultClover"] = self.ResultClover
		result["Reputation"] = self.Reputation
		result["RewardBoxes"] = _UtilLogic:TableToString(self.RewardBoxes)
		
		result["Skill1Info"] = _UtilLogic:TableToString(self.Skill1Info)
		result["Skill2Info"] = _UtilLogic:TableToString(self.Skill2Info)
		
		return result
	end

	method void SetFromTable(table data)
		-- 테이블 데이터로부터 슬롯 정보를 설정하는 함수
		self.State = data["State"]
		
		self.ChuchuId = data["ChuchuId"]
		self.SlotNum = tonumber(data["SlotNum"])
		
		self.RemainDay = tonumber(data["RemainDay"])
		self.IsOpen = tonumber(data["IsOpen"])
		
		self.ResultMoney = tonumber(data["ResultMoney"])
		self.ResultClover = tonumber(data["ResultClover"])
		self.Reputation = tonumber(data["Reputation"])
		self.RewardBoxes = _UtilLogic:StringToTable(data["RewardBoxes"])
		
		self.Skill1Info = _UtilLogic:StringToTable(data["Skill1Info"])
		self.Skill2Info = _UtilLogic:StringToTable(data["Skill2Info"])
	end

	method table DefaultDataTable()
		-- 기본 데이터 테이블을 생성하는 함수
		local result = {}
		
		result["State"] = _AutoTrainingUIStateEnum.Default
		result["ChuchuId"] = ""
		result["SlotNum"] = 0
		result["RemainDay"] = 0
		result["IsOpen"] = 0
		
		result["ResultMoney"] = 0
		result["ResultClover"] = 0
		result["Reputation"] = 0
		result["RewardBoxes"] = ""
		
		result["Skill1Info"] = ""
		result["Skill2Info"] = ""
		
		return result
	end

end