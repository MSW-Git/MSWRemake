@Struct
script TrainingExpRewardData

	property integer StageId = 0

	property integer ManagementLevel = 0

	property string TrainingExpCookItemId = ""

	property string TrainingExpServingItemId = ""

	property integer TrainingExpItemCount = 0

	property string AutoTrainingExpCookItemId = ""

	property string AutoTrainingExpServingItemId = ""

	property integer AutoTrainingItemCount = 0

	method TrainingExpRewardData SetData(any row)
		-- 데이터 행에서 훈련 경험치 보상 데이터를 설정하는 함수
		---@type UserDataRow
		local dataRow = row
		self.StageId = tonumber(dataRow:GetItem("StageId"))
		self.ManagementLevel = tonumber(dataRow:GetItem("ManagementLevel")) + 1 
		
		self.TrainingExpCookItemId = dataRow:GetItem("TrainingExpCookItemId")
		self.TrainingExpServingItemId =  dataRow:GetItem("TrainingExpServingItemId")
		self.TrainingExpItemCount = tonumber(dataRow:GetItem("TrainingExpItemCount"))
		
		self.AutoTrainingExpCookItemId =  dataRow:GetItem("AutoTrainingExpCookItemId")
		self.AutoTrainingExpServingItemId =  dataRow:GetItem("AutoTrainingExpServingItemId")
		self.AutoTrainingItemCount = tonumber(dataRow:GetItem("AutoTrainingItemCount"))
		
		return self
	end

end