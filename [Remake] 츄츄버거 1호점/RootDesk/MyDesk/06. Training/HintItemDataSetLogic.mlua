@Logic
script HintItemDataSetLogic extends Logic

	property table HintItemData = {}

	property integer CategoryCount = 11

	@Sync
	property number Colorcount = 0

	method void OnBeginPlay()
		-- 게임 시작 시 데이터셋을 로드하는 함수
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- 힌트 아이템 데이터셋을 로드하는 함수
		table.clear(self.HintItemData)
		local itemDataSet = _DataService:GetTable("HintItemDataSet")
		for i = 1, itemDataSet:GetRowCount() do
			local itemData = HintItemData() 
			itemData:Load(itemDataSet, i)
			
			if self.HintItemData[itemData.Id] ~= nil then
				break
			end
		
			self.HintItemData[itemData.Id] = itemData
		end
	end

	method HintItemData GetHintItemData(string id)
		-- ID로 힌트 아이템 데이터를 가져오는 함수
		if self.HintItemData == nil then
			return nil
		end
		
		return self.HintItemData[id]
	end

	method table ReturnItemListByColor(string color)
		-- 특정 색상의 아이템 목록을 반환하는 함수
		local itemList = {}
		
		local itemDataSet = _DataService:GetTable("HintItemDataSet")
		for i = 1, itemDataSet:GetRowCount() do
			local row = itemDataSet:GetRow(i)
			local rowColor = row:GetItem("Color")
			if rowColor == color then
				table.insert(itemList, row:GetItem("Id")) 
				if itemList >= self.CategoryCount then 
					break
				end
			end
		end
		
		return itemList
	end

	method string ReturnItemIdByCategoryAndColor(string category, string color)
		-- 카테고리와 색상으로 아이템 ID를 반환하는 함수
		local itemId = ""
		local colorList = self:ReturnRowByColor(color)
		for i = 1, #colorList do
			local row = colorList[i]
			local rowCategory = row:GetItem("CategoryKey")  
			if rowCategory == category then
				itemId = row:GetItem("Id")
				break
			end
		end
		
		return itemId
	end

	method any ReturnRowByColor(string color)
		-- 특정 색상의 데이터 행을 반환하는 함수
		local itemList = {}
		
		local itemDataSet = _DataService:GetTable("HintItemDataSet")
		for i = 1, itemDataSet:GetRowCount() do
			local row = itemDataSet:GetRow(i)
			if row:GetItem("Color") == color then
				table.insert(itemList, row) 
				if #itemList >= self.CategoryCount then 
					break
				end
			end
		end
		
		return itemList
	end

	method table ReturnRandomPlaceItems(table hintCategoryList, table hintColorList)
		-- 랜덤 장소 아이템들을 반환하는 함수
		local placeItems = {}
		local dataSet = _DataService:GetTable("RandomPlaceDataSet")
		local color1Items = {}
		local randomIndexes = {}
		local rand = _StringUtilLogic:ShuffleStringTable({"1","2","3","4"})
		table.insert(randomIndexes, rand[1])
		table.insert(randomIndexes, rand[2])
			
		local rand2 = _StringUtilLogic:ShuffleStringTable({"5","6","7","8"})
		table.insert(randomIndexes, rand2[1])
		table.insert(randomIndexes, rand2[2])
		table.insert(randomIndexes, rand2[3])
			
		local rand3 = _StringUtilLogic:ShuffleStringTable({"9","10","11","12"})
		table.insert(randomIndexes, rand3[1])
		table.insert(randomIndexes, rand3[2])
		
		for _, row in pairs(dataSet:GetAllRow()) do
			local id = row:GetItem("Id")
			local color = tonumber(row:GetItem("Color"))
			local category1 = tonumber(row:GetItem("Category1"))
			local category2 = tonumber(row:GetItem("Category2"))
			local category3 = tonumber(row:GetItem("Category3"))
			
			for i = 1, #randomIndexes do
				if id == randomIndexes[i] then
					local item1= _HintItemDataSetLogic:ReturnItemIdByCategoryAndColor(hintCategoryList[category1], hintColorList[color])
					local item2= _HintItemDataSetLogic:ReturnItemIdByCategoryAndColor(hintCategoryList[category2], hintColorList[color])
					local item3= _HintItemDataSetLogic:ReturnItemIdByCategoryAndColor(hintCategoryList[category3], hintColorList[color])
					local items = {item1, item2, item3}
					table.insert(placeItems, items)
				end
			end
		end
		
		return placeItems
	end

	method string ReturnIconRuidById(string id)
		-- ID로 아이콘 RUID를 반환하는 함수
		if _UtilLogic:IsNilorEmptyString(id) then
		end
		local itemDataSet = _DataService:GetTable("HintItemDataSet")
		local ruid = itemDataSet:FindRow("Id", id):GetItem("IconRuid")
		
		return ruid
	end

	method string ReturnItemName(string id)
		-- ID로 아이템 이름을 반환하는 함수
		if _UtilLogic:IsNilorEmptyString(id) then
		end
		
		---@type HintItemData
		local data = self.HintItemData[id]
		local category = _LocalizationService:GetText("CategoryKey_"..data.Category)
		local color = _LocalizationService:GetText("ColorKey_"..data.Color)
		local name = color.." "..category
		return name
	end

end