@Component
script UICustomChatHolder extends Component

	property Entity OnOpen = "298da51f-f1c2-4c03-a8a1-acc68b26113d"

	property Entity OnFold = "153fa90b-bb80-4cb2-b6dc-390e5784492c"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 초기화 시 채팅창을 숨김 상태로 설정
		self:ToggleCustomChat(false)
	end

	@ExecSpace("ClientOnly")
	method void ToggleCustomChat(boolean enable)
		-- 채팅창의 펼치기/접기 상태를 전환
		
		self.OnFold.Enable = not enable
		self.OnOpen.Enable = enable
		
	end

	@EventSender("Entity", "43dc37d0-654a-4a9e-9bed-fac21201a2b6")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 채팅창 열기 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:ToggleCustomChat(true)
	end

	@EventSender("Entity", "2368bbc8-36e6-46ff-87db-e890f1f0cf9c")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 채팅창 닫기 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:ToggleCustomChat(false)
	end

end