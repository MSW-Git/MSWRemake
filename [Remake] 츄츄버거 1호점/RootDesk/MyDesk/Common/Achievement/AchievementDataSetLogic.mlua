@Logic
script AchievementDataSetLogic extends Logic

	property table AchiTypeData = {}

	property table AchiIdData = {}

	method void OnBeginPlay()
		-- 게임 시작 시 업적 데이터셋을 로드
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- CSV 파일에서 업적 타입 및 ID 데이터를 로드하여 테이블에 저장
		table.clear(self.AchiTypeData)
		local achiTypeDataSet = _DataService:GetTable("AchievementTypeData")
		for i = 1, achiTypeDataSet:GetRowCount() do
			local achiTypeData = AchievementTypeData()
			achiTypeData:Load(achiTypeDataSet, i)
			
			if self.AchiTypeData[achiTypeData.Type] ~= nil then
				break
			end
		
			self.AchiTypeData[achiTypeData.Type] = achiTypeData
		end
		
		table.clear(self.AchiIdData)
		local achiIdDataSet = _DataService:GetTable("AchievementIdData")
		for i = 1, achiIdDataSet:GetRowCount() do
			local achiIdData = AchievementIdData()
			achiIdData:Load(achiIdDataSet, i)
			
			if self.AchiIdData[achiIdData.Id] ~= nil then
				break
			end
		
			self.AchiIdData[achiIdData.Id] = achiIdData
		end
	end

	method AchievementTypeData GetAchievementTypeData(integer achiType)
		-- 업적 타입 ID로 해당 업적 타입 데이터 반환
		return self.AchiTypeData[achiType]
	end

	method AchievementIdData GetAchievementIdData(integer achiId)
		-- 업적 ID로 해당 업적 ID 데이터 반환
		return self.AchiIdData[achiId]
	end

end