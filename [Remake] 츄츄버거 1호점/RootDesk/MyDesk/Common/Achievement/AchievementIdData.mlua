@Struct
script AchievementIdData

	property integer Type = 0

	property integer Id = 0

	property integer TypeValue = 0

	property string RewardType = ""

	property integer RewardAmount = 0

	property string ConditionType = ""

	property string ConditionValue = ""

	method void Load(any dataTable, integer index)
		-- CSV 데이터테이블에서 업적 ID 데이터를 로드하여 속성에 저장
		---@type MODUserDataSet
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		self.Type = tonumber(rowData:GetItem("Type"))
		self.Id = tonumber(rowData:GetItem("Id"))
		self.TypeValue = tonumber(rowData:GetItem("TypeValue"))
		self.RewardType = rowData:GetItem("RewardType")
		self.RewardAmount = tonumber(rowData:GetItem("RewardAmount"))
		
		local condition = _UtilLogic:Split(rowData:GetItem("Condition"), ",")
		self.ConditionType = condition[1]
		self.ConditionValue = condition[2]
	end

end