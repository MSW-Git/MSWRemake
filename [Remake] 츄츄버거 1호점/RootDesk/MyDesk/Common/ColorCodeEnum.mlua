@Logic
script ColorCodeEnum extends Logic

	property string DefaultBrownFont = "#a0710d"

	property string LightBrownOutline = "#d98a1a"

	property string YellowFont = "#FFE92C"

	property string GreenFont = "#5d953f"

	property string OrangeFont = "#dd6822"

	property string RedFont = "#FA5246"

	property string DarkBrownOutline = "#863205"

	property string WhiteFont = "#ffffff"

	property string BrownOutline = "#79551b"

	property string BrownFont = "#918169"

	property string LightGreenFont = "#9de339"

	property string DarkGreenOutline = "#385b06"

	property string YellowBrownFont = "#93640a"

	property string RedOutline = "#800c04"

	property string CheckOutMesoFont = "#ffe23f"

	property string CheckOutMesoOutline = "402605"

	property string GainTipFont = "#ff5c8a"

	property string GainTipOutline = "520621"

	property string LightRedOutline = "#990c0c"

	property SyncTable<string, Color> ColorList

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 색상 코드 테이블을 초기화
		
		self.ColorList["#72634b"] = Color.FromHexCode("#72634b")
		self.ColorList["#fa5246"] = Color.FromHexCode("#fa5246")
		self.ColorList["#5f6f16"] = Color.FromHexCode("#5f6f16")
		self.ColorList["#a17407"] = Color.FromHexCode("#a17407")
		self.ColorList["#FFE84E"] = Color.FromHexCode("#FFE84E")
		self.ColorList["#814514"] = Color.FromHexCode("#814514")
		self.ColorList["#ffffff"] = Color.FromHexCode("#ffffff")
	end

	@ExecSpace("ClientOnly")
	method Color GetColor(string hexCode)
		-- 헥스 코드로 색상 객체를 반환하고 캐시에 저장
		if self.ColorList[hexCode] == nil then
			self.ColorList[hexCode] = Color.FromHexCode(hexCode)
		end
		
		if self.ColorList[hexCode] == nil then
			return self:GetColor("#ffffff")
		end
		
		return self.ColorList[hexCode]
	end

end