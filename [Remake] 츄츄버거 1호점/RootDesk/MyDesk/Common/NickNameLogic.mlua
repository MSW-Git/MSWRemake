@Logic
script NickNameLogic extends Logic

	property integer CharLimit = 16

	method string IsValid(string text, boolean isUnlock)
		-- 닉네임 텍스트가 유효한지 검증하고 결과 메시지를 반환
		if self:IsWhitespaceOnly(text) then
			return "JobNickName_MinCharLimit"
		end
		
		local len = 0
		for _, codepoint in utf8.codes(text) do
			local v = self:CodePointToLen(codepoint)
			if v == 0 then
				return "JobNickName_InvalidCharacter"
			end
			
			len += v
		end
		
		if isUnlock then
			return "Success"
		end
		
		if len == 0 then
			return "JobNickName_MinCharLimit"
		end
		
		if len > self.CharLimit then
			return "JobNickName_ExceedCharLimit"
		end
		
		return "Success"
	end

	method integer CodePointToLen(integer codepoint)
		-- 유니코드 코드포인트를 문자 길이로 변환
		if not codepoint then
			return 0
		end
		
		if codepoint >= 0x0030 and codepoint <= 0x0039 then
			return 1	
		elseif codepoint >= 0x0041 and codepoint <= 0x005A then
			return 1	
		elseif codepoint >= 0x0061 and codepoint <= 0x007A then
			return 1	
		elseif self:IsWhitespaceCodepoint(codepoint) then
			return 0	
		elseif codepoint >= 0x1100 and codepoint <= 0x11FF then
			return 2	
		elseif codepoint >= 0x3131 and codepoint <= 0x3182 then
			return 2	
		elseif codepoint >= 0xAC00 and codepoint <= 0xD7AF then
			return 2	
		end
		
		return 0
	end

	method boolean IsWhitespaceOnly(string text)
		-- 텍스트가 공백 문자로만 구성되어 있는지 확인
		if _UtilLogic:IsNilorEmptyString(text) then
			return true
		end
		
		for _, codepoint in utf8.codes(text) do
			if not self:IsWhitespaceCodepoint(codepoint) then
				return false
			end
		end
		
		return true
	end

	method boolean IsWhitespaceCodepoint(integer codepoint)
		-- 코드포인트가 공백 문자인지 확인
		if codepoint == 0x0020 or codepoint == 0x00A0 or codepoint == 0x200B or codepoint == 0x202F or codepoint == 0x3000 then
			return true
		elseif codepoint >= 0x2000 and codepoint <= 0x2003 then
			return true
		end
		
		return false
	end

	@EventSender("Entity", "60e26afd-cee8-46b2-8b85-9caa8ff74d41")
	handler HandleTextInputEndEditEditorEvent(TextInputEndEditEditorEvent event)
		-- 텍스트 입력 완료 에디터 이벤트 처리
		
	end

end