@Logic
script ResourceManager extends Logic

	property SyncTable<string, string> SFXTable

	method void OnBeginPlay()
		-- 게임 시작 시 SFX 테이블을 로드하고 리소스를 프리로드
		local sfxDataSet = _DataService:GetTable("SFXTable")
		local sfxTable = {}
		for i=1,sfxDataSet:GetRowCount() do
			local id = sfxDataSet:GetCell(i,"Name")
			local ruid = sfxDataSet:GetCell(i,"Ruid")
			
			if ruid ~= "" then
				self.SFXTable[id] = ruid
				table.insert(sfxTable,ruid)
			end
		end
		
		if #sfxTable > 0 then
			_ResourceService:PreloadAsync(sfxTable, function() end)
		end
	end

	method void ChangeMaterial(Entity entity, string materialId, integer duration)
		-- 엔티티의 머터리얼을 변경하고 지정된 시간 후 원래대로 복원
		entity.SpriteGUIRendererComponent:ChangeMaterial(materialId)
		_TimerService:SetTimerOnce(function() 
			entity.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial) 
		end, duration)
	end

end