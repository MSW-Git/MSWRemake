@Component
script UIUpgradePanel extends Component

	property Entity UpgradeList = "7483e56e-9a53-4e26-aca9-d814f6c3bf41"

	property integer SelecteTab = 0

	property Entity TabBar = "78df6dd5-60ac-49b4-ac34-ac98908e4089"

	property SyncTable<integer, Entity> Tabs

	property Entity UpgradeDetail = "6c75e43c-07d7-4da0-9102-86f9bc353140"

	property integer NowSelected = 0

	property SyncTable<integer, Entity> listSlotEntities

	property Entity UpgradeTitle = "457aaefb-bf0a-43eb-8071-49e2bd3132a4"

	property Entity GuideBtn = "9ec44fd2-c052-4e9c-b3ec-d9623d30b6e7"

	property any guideHandler = nil

	property boolean exMoneyBarEnable = false

	property boolean exUIChatExpand = false

	property Entity NoList = "0537b1f8-a073-466f-bdfe-fdd614029735"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 업그레이드 패널 초기화 및 탭 버튼 이벤트 연결
		for i, entity in pairs(self.TabBar.Children) do
			local index = tonumber(entity.Name)
			
			self.Tabs[tonumber(entity.Name)] = entity
			entity:GetChildByName("UITextDesc").TextComponent.Text = self:ReturnTabName(index)
			entity:GetChildByName("UISpriteSelect"):GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = self:ReturnTabIconRUID(index)
			
			entity:ConnectEvent(ButtonClickEvent, function()
				if _UIGroupManager:IsEnableOpenPopUp() == false then
					return
				end
				
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				self:SetSelectTab(index, nil)
			end)
		end
		
		self:Close()
	end

	@ExecSpace("ClientOnly")
	method void Open(integer upgradeId)
		-- 업그레이드 패널을 열고 특정 업그레이드를 선택
		if self.Entity.Enable then
			return
		end
		
		_UIGroupManager:EnableUpgradeGroup(true)
		self.Entity:SetEnable(true)
		_MainMenuRedDotManager:EnableUpgradeRedDot(false)
		
		local tab = 0
		if upgradeId ~= nil then
			local upgradeData = _UpgradeDataSetLogic:GetData(upgradeId)
			tab = upgradeData.Tab
		end
		
		
		self:SetSelectTab(tab, upgradeId)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 업그레이드 패널을 닫기
		self.Entity:SetEnable(false)
		_UIGroupManager:EnableUpgradeGroup(false)
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer tabId, integer upgradeId)
		-- 선택된 탭의 업그레이드 목록을 갱신
		for i = 1, #self.UpgradeList.Children do
			self.UpgradeList.Children[i].Enable = false
		end
		table.clear(self.listSlotEntities)
		
		for i, entity in pairs(self.Tabs) do
			self:SetTabRedDot(i)
		end
		
		local tabDatas = _UpgradeDataSetLogic:ReturnTabDatas(tabId, _UserService.LocalPlayer)
		local index = 0
		if #tabDatas > 0 then
			index = 1
		end
		
		if isvalid(upgradeId) then
			for i = 1, #tabDatas do
				if upgradeId == tabDatas[i] then
					index = i
					break
				end
			end
		end
		
		if self.NowSelected == 0 then
			self.NowSelected = tabDatas[index]
		end
		
		self.NoList.Enable = #tabDatas == 0
		for i = 1, #tabDatas do
			local typeId = tabDatas[i]
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_UpgradeListSlot", i, self.UpgradeList)
			
			entity.UIUpgradeListSlot:Refresh(typeId, typeId == self.NowSelected)	
			self.listSlotEntities[typeId] = entity
		end
		
		self.UpgradeDetail.UIUpgradeDetail:Refresh(self.NowSelected)
	end

	@ExecSpace("ClientOnly")
	method void SetSelectTab(integer selectTab, integer upgradeId)
		-- 선택된 탭을 설정하고 UI를 갱신
		self.SelecteTab = selectTab
		self.NowSelected = 0
		self:Refresh(selectTab, upgradeId)
		self:OnSelectTab(selectTab)
		self.UpgradeTitle.TextComponent.Text = self:ReturnTabName(selectTab)
	end

	@ExecSpace("ClientOnly")
	method void OnSelectTab(integer selectTab)
		-- 탭 선택 시 UI 스타일을 변경하고 가이드 버튼 설정
		self:SetGuidePageBtn(selectTab)
		self:ResetScroll()
		
		for i, entity in pairs(self.Tabs) do
			
			if i == selectTab then 
				entity:GetChildByName("UISpriteSelect").SpriteGUIRendererComponent.ImageRUID = "c126e98243bf4c7cbfa7bcbb278b0f60"
				local uiTextDesc = entity:GetChildByName("UITextDesc")
				uiTextDesc.TextComponent.FontColor = Color.white
				uiTextDesc.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#985F05")
				uiTextDesc.TextComponent.UseOutLine = true
				local uiSpriteIcon = entity:GetChildByName("UISpriteSelect"):GetChildByName("Icon")
				uiSpriteIcon.SpriteGUIRendererComponent.Color.a = 1
				
			else
				entity:GetChildByName("UISpriteSelect").SpriteGUIRendererComponent.ImageRUID = "6cc87742434e42e3b3a988e83142db83"
				local uiTextDesc = entity:GetChildByName("UITextDesc")
				uiTextDesc.TextComponent.FontColor = _ColorCodeEnum:GetColor("#BB9A59")
				uiTextDesc.TextComponent.UseOutLine = false
				local uiSpriteIcon = entity:GetChildByName("UISpriteSelect"):GetChildByName("Icon")
				uiSpriteIcon.SpriteGUIRendererComponent.Color.a = 0.5
				
			end
		end
	end

	method string ReturnTabName(integer index)
		-- 탭 인덱스에 해당하는 로컬라이즈된 탭 이름을 반환
		return _GetLocalizationTextLogic:GetText("UpgradeTabTitle"..index)
	end

	@ExecSpace("ClientOnly")
	method void OnSelectSlot(integer selectId)
		-- 업그레이드 슬롯을 선택하고 세부 정보를 갱신
		self.NowSelected = selectId
		
		for id, entity in pairs(self.listSlotEntities) do
			if id == selectId then
				entity.UIUpgradeListSlot:Refresh(id, true)
			else
				entity.UIUpgradeListSlot:Refresh(id, false)
			end
		end
		
		self.UpgradeDetail.UIUpgradeDetail:Refresh(selectId)
	end

	method string ReturnTabIconRUID(integer index)
		-- 탭 인덱스에 해당하는 아이콘 RUID를 반환
		if index == 1 then 
			return "7b51d1c13753409b81588c50ebffbb75"
		elseif index == 2 then 
			return "18d06cd0327a4877ab8ed6058d55d5e5"
		elseif index == 3 then 
			return "0d32289149c744c0b09c875fa9afa07f"
		elseif index == 4 then 
			return "5c6a284c715e454686aca1f927c98f3b"
		elseif index == 5 then 
			return "de34bc8137594ad393dd8c74f64f3472"
		elseif index == 0 then 
			return "1fd8204147594755916e29ebf832945e"
		end
	end

	@ExecSpace("ClientOnly")
	method void SetGuidePageBtn(integer selectTab)
		-- 선택된 탭에 따라 가이드 페이지 버튼을 설정
		self.GuideBtn:DisconnectEvent(ButtonClickEvent, self.guideHandler)
		local guidePage = _UpgradeDataSetLogic:ReturnGuidePageIdByTabIndex(selectTab)
		self.GuideBtn.Enable = guidePage ~= nil
		
		if guidePage ~= nil then
			self.guideHandler = _GuidePageManager:SetGuidePageButton(guidePage, self.GuideBtn)
		else
			self.guideHandler = nil
		end
	end

	@ExecSpace("ClientOnly")
	method void SetTabRedDot(integer tabId)
		-- 탭에 업그레이드 가능한 항목이 있을 때 빨간 점 표시
		local player = _UserService.LocalPlayer
		local tabDatas = _UpgradeDataSetLogic:ReturnTabDatas(tabId, player)
		
		local isRedDot = false
		for i = 1, #tabDatas do
			local typeId = tabDatas[i]
			local typeData = _UpgradeDataSetLogic:GetData(typeId)
			
			local currentLevel = player.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(typeId)
			local nextLevel = currentLevel + 1
			if nextLevel > typeData:GetMaxLevel(player) then
				continue
			end
			
			local nextLevelData = _UpgradeDataSetLogic:GetLevelData(typeId, nextLevel)
			local isConditionSatisfied = _UpgradeDataSetLogic:IsConditionSatisfied(nextLevelData, player)
			if isConditionSatisfied and player.PlayerInventory.Money >= nextLevelData:GetUpgradeCost(player) then 
				isRedDot = true
				break
			end
		end
		
		self.Tabs[tabId]:GetChildByName("UISpriteSelect"):GetChildByName("RedDot").Enable = isRedDot
	end

	@ExecSpace("ClientOnly")
	method void ResetScroll()
		-- 선택된 업그레이드 항목으로 스크롤 위치를 초기화
		local tabDatas = _UpgradeDataSetLogic:ReturnTabDatas(self.SelecteTab, _UserService.LocalPlayer)
		local index = 0
		if #tabDatas > 0 then
			index = 1
		end
		
		if isvalid(self.NowSelected) then
			for i = 1, #tabDatas do
				if self.NowSelected == tabDatas[i] then
					index = i
					break
				end
			end
		end
		
		self.UpgradeList.ScrollLayoutGroupComponent:SetScrollPositionByItemIndex(index-1)
	end

	@EventSender("Entity", "ac1f7d08-e82a-4f35-a5df-97d79f33e977")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 업그레이드 패널을 닫기
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("Entity", "c23978a3-ef8c-4f46-9328-906d857dc3d5")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 업그레이드 패널 열기 버튼 클릭 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open(nil)
	end

end