@Component
script UISubscriptionProgressSlot extends Component

	property SpriteGUIRendererComponent Icon = nil

	property TextComponent ProgressText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화
		self.Icon = self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		self.ProgressText = self.Entity:GetChildByName("ProgressText").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh(string itemId, integer leftCount)
		-- 구독 아이템의 진행 상태를 UI에 표시
		self.ProgressText.Entity.Enable = true
		self.Icon:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		self.Entity.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		
		local itemData = _ItemDataSetLogic:GetItemData(itemId)
		self.Icon.ImageRUID = itemData.IconRUID
		self.ProgressText.Text = tostring(leftCount)
	end

	@ExecSpace("ClientOnly")
	method void Disable(string itemId)
		-- 구독 서비스가 만료되었을 때 비활성화 표시
		self.Icon:ChangeMaterial(_IconRuidEnum.GrayScaleMaterial)
		self.Entity.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.GrayScaleMaterial)
		self.ProgressText.Entity.Enable = false
		
		local itemData = _ItemDataSetLogic:GetItemData(itemId)
		self.Icon.ImageRUID = itemData.IconRUID
	end

end