@Struct
script UpgradeLevelData

	property integer TypeId = 0

	property integer Level = 0

	property integer Value = 0

	property integer Cost = 0

	property string ConditionType = ""

	property string ConditionValue = ""

	property any HelpData = nil

	method void Load(any rowData, integer typeId)
		-- CSV 행 데이터에서 업그레이드 레벨 정보를 로드
		self.TypeId = typeId
		
		self.Level = tonumber(rowData:GetItem("Level"))
		self.Value = tonumber(rowData:GetItem("Value"))
		self.Cost = tonumber(rowData:GetItem("Cost"))
		
		self.ConditionType = rowData:GetItem("ConditionType")
		self.ConditionValue = rowData:GetItem("ConditionValue")
		
		
		local helpDataSet = _DataService:GetTable("UpgradeHelpData")
		for i = 1, helpDataSet:GetRowCount() do
			local row = helpDataSet:GetRow(i)
			
			local id = tonumber(row:GetItem("Id"))
			if id ~= typeId then
				continue
			end
			
			local level = row:GetItem("Level")
			if _UtilLogic:IsNilorEmptyString(level) then
				local helpData = UpgradeHelpData()
				helpData:Load(row)
				
				if self.HelpData == nil then
					self.HelpData = helpData
				end
				break
			else
				if tonumber(level) == self.Level then
					local helpData = UpgradeHelpData()
					helpData:Load(row)
					
					if self.HelpData == nil then
						self.HelpData = helpData
					end
					break
				end
			end
			
		end
		
	end

	method UpgradeHelpData GetHelpData()
		-- 업그레이드 도움말 데이터를 반환
		return self.HelpData
	end

	method integer GetUpgradeCost(Entity player)
		-- 플레이어의 스테이지와 전략 효과를 반영한 업그레이드 비용 계산
		local cost = self.Cost
		
		local stageData = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage)
		if self.TypeId == _UpgradeTypeEnum.GrillLevel then
			cost = stageData.UpgradeGrillLevelCost[self.Level]
		elseif self.TypeId == _UpgradeTypeEnum.CounterLevel then
			cost = stageData.UpgradeCounterLevelCost[self.Level]	
		end
		
		if cost == nil then 
			return nil
		end
		
		local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage).UpgradeCostRate
		local strategyEffect = _StrategyEnum:GetPlayerStrategyEffect(player, _StrategyEnum.ReduceUpgradeCost, player.PlayerStage.NowStage)
		
		if self.TypeId == _UpgradeTypeEnum.GrillLevel or self.TypeId == _UpgradeTypeEnum.CounterLevel then
			return math.floor(cost * (1 - strategyEffect ) )
		else
		
			return math.floor(cost * ( 1 + stageConfig) * (1 - strategyEffect ) )
		end
	end

	method string GetConditionValue(Entity player)
		-- 업그레이드 조건 값을 스테이지에 따라 반환
		if not (self.TypeId == _UpgradeTypeEnum.GrillLevel or self.TypeId == _UpgradeTypeEnum.CounterLevel) then
			return self.ConditionValue
		end
		
		local stageData = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage)
		local conditionValue = stageData.UpgradeKitchenLevelCondition[self.Level]
		return conditionValue
	end

	method integer GetUpgradeValue(Entity player)
		-- 전략 효과를 반영한 업그레이드 효과 값을 반환
		local value = self.Value
		if self.TypeId == _UpgradeTypeEnum.TipStorageLevel then
			value = self.Value * (1 + _StrategyEnum:GetPlayerStrategyEffect(player, _StrategyEnum.TipStorageSizeUp, player.PlayerStage.NowStage))
		end
		
		return math.floor(value)
	end

end