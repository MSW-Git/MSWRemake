@Struct
script UpgradeHelpData

	property string Type = ""

	property string Contents = ""

	property string ContentsTextKey = ""

	property string ImageRUID = ""

	property string FormatText0Value = ""

	property string FormatText1Value = ""

	property string FormatText2Value = ""

	property string FormatText3Value = ""

	property string FormatText4Value = ""

	property string FormatText5Value = ""

	method void Load(any row)
		-- CSV 데이터로부터 업그레이드 도움말 정보를 로드
		self.Type = row:GetItem("Type")
		self.Contents = row:GetItem("Contents")
		
		self.ContentsTextKey = row:GetItem("ContentsTextKey")
		
		self.ImageRUID = row:GetItem("ImageRUID")
		
		self.FormatText0Value = row:GetItem("FormatText0Value")
		self.FormatText1Value = row:GetItem("FormatText1Value")
		self.FormatText2Value = row:GetItem("FormatText2Value")
		self.FormatText3Value = row:GetItem("FormatText3Value")
		self.FormatText4Value = row:GetItem("FormatText4Value")
		self.FormatText5Value = row:GetItem("FormatText5Value")
	end

end