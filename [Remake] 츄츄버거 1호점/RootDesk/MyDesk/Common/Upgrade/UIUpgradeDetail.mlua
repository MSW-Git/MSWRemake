@Component
script UIUpgradeDetail extends Component

	property TextComponent NameText = nil

	property TextComponent EffectText = nil

	property Entity Desc = nil

	property Entity ConditionEntity = nil

	property TextComponent ConditionText = nil

	property Entity CostEntity = nil

	property TextComponent CostText = nil

	property Entity UpgradeButton = nil

	property Entity UpgradeButtonDim = nil

	property Entity EndUpgradeImg = nil

	property any upgradeHandler = nil

	property Entity LevelUpEffect = nil

	property Entity Line = nil

	property Entity NoTitle = nil

	property Entity GoldIcon = nil

	property Entity CostTooltip = nil

	property Entity CostInfoBtn = nil

	property TextComponent OriginTitle = nil

	property TextComponent OriginValue = nil

	property TextComponent St_ReduceUpgradeCostTitle = nil

	property TextComponent St_ReduceUpgradeCostValue = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 업그레이드 세부 정보 UI 컴포넌트들을 초기화
		self.NameText = self.Entity:GetChildByName("NameText").TextComponent
		self.EffectText = self.Entity:GetChildByName("EffectText").TextComponent
		
		self.Desc = self.Entity:GetChildByName("Desc")
		
		self.ConditionEntity = self.Entity:GetChildByName("Condition")
			self.ConditionEntity:GetChildByName("TitleText").TextComponent.Text = _GetLocalizationTextLogic:GetText("UpgradeConditionText")
			self.ConditionText = self.ConditionEntity:GetChildByName("ConditionText").TextComponent
			
		self.CostEntity = self.Entity:GetChildByName("Cost")
			self.CostEntity:GetChildByName("TitleText").TextComponent.Text = _GetLocalizationTextLogic:GetText("UpgradeCostText")
			self.CostText = self.CostEntity:GetChildByName("CostText").TextComponent
			self.GoldIcon = self.CostText.Entity:GetChildByName("Icon")
			self.GoldIcon.SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData("G0001").IconRUID
				
		self.UpgradeButton = self.Entity:GetChildByName("UpgradeButton")
			self.UpgradeButtonDim = self.UpgradeButton:GetChildByName("Dim")
		
		self.EndUpgradeImg = self.Entity:GetChildByName("EndUpgradeImg")
		
		self.LevelUpEffect = self.Entity:GetChildByName("Effect_LV_Up")
		
		self.Line = self.Entity:GetChildByName("Line")
		self.NoTitle = self.Entity:GetChildByName("NoTitle")
		
		self.CostInfoBtn = self.CostEntity:GetChildByName("TitleText"):GetChildByName("InfoBtn")
		self.CostTooltip = self.CostInfoBtn:GetChildByName("Tooltip")
		self.CostInfoBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_TooltipService:OpenTooltip(self.CostTooltip, nil)
		end)
		
		local infoList = self.CostTooltip:GetChildByName("InfoList")
		local origin = infoList:GetChildByName("Origin")
		self.OriginTitle = origin:GetChildByName("Title").TextComponent
		self.OriginValue = origin:GetChildByName("Value").TextComponent
		local st_ruc = infoList:GetChildByName("St_ReduceUpgradeCost")
		self.St_ReduceUpgradeCostTitle = st_ruc:GetChildByName("Title").TextComponent
		self.St_ReduceUpgradeCostValue = st_ruc:GetChildByName("Value").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer typeId)
		-- 선택된 업그레이드 타입의 세부 정보를 UI에 갱신
		if self.NameText == nil then
			self:Init()
		end
		
		self.UpgradeButton:DisconnectEvent(ButtonClickEvent, self.upgradeHandler)
		self.upgradeHandler = nil
		
		local typeData = _UpgradeDataSetLogic:GetData(typeId)
		if typeData == nil then
			self:RefreshEmpty()
			return
		end
		
		self.NoTitle.Enable = false
		self.GoldIcon.Enable = true
		
		local player = _UserService.LocalPlayer
		local playerUpgrade = player.PlayerUpgrade
		
		local currentLevel = playerUpgrade:ReturnPlayerUpgradeLevelOfType(typeId)
		local maxLevel = typeData:GetMaxLevel(player)
		local nextLevel = currentLevel + 1
		if nextLevel > maxLevel then
			nextLevel = maxLevel
		end
		
		local currentValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, currentLevel, player)
		local nextValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, nextLevel, player)
		
		local nextLevelData = _UpgradeDataSetLogic:GetLevelData(typeId, nextLevel)
		local helpData = nextLevelData:GetHelpData()
		
		self.NameText.Entity.Enable = true
		self.EffectText.Entity.Enable = true
		self.NameText.Text = _GetLocalizationTextLogic:GetText(typeData.NameKey)
		
		self.Desc.SpriteGUIRendererComponent.Color.a = helpData.Type == "ImageOnly" and 0 or 1
		for i = 1, #self.Desc.Children do
			local child = self.Desc.Children[i]
			if child.Name == helpData.Type then
				child.Enable = true
				self:SetDescEntity(child, helpData, typeId)
			else
				child.Enable = false
			end
		end
		
		if typeData.EffectType == "Level" then
			self.EffectText.Entity.Enable = true
			if currentLevel == maxLevel then
				self.EffectText.Text = "Lv."..currentLevel
			else
				self.EffectText.Text = string.format("Lv.%d > Lv.%d", currentLevel, nextLevel)
			end
			
		elseif typeData.EffectType == "LevelValue" then
			self.EffectText.Entity.Enable = true
			local currentLevelValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeData.Id, currentLevel, player)
			local nextLevelValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeData.Id, nextLevel, player)
			
			if currentLevel == maxLevel then
				self.EffectText.Text = "Lv."..currentLevelValue
			else
				self.EffectText.Text = string.format("Lv.%d > Lv.%d", currentLevelValue, nextLevelValue)
			end
			
		elseif typeData.EffectType == "Open" then
			self.EffectText.Entity.Enable = false
				
		elseif typeData.EffectType == "Interior" then
			self.EffectText.Entity.Enable = true
			
			self.EffectText.Text = _GetLocalizationTextLogic:GetText("InteriorLevel"..nextLevel)
		end
		
		if currentLevel >= maxLevel then
			self.ConditionEntity.Enable = false
			self.CostEntity.Enable = false
			self.EndUpgradeImg.Enable = true
			self.UpgradeButton.Enable = false
			self.Line.Enable = false
			self.CostInfoBtn.Enable = false
			return
		end
		
		self.Line.Enable = true
		self.EndUpgradeImg.Enable = false
		self.UpgradeButton.Enable = true
		self.CostInfoBtn.Enable = true
		self.CostTooltip.Enable = false
		self:RefreshCostTooltip(nextLevelData)
		
		local moneySatisfied = player.PlayerInventory.Money >= nextLevelData:GetUpgradeCost(player)
		local conditionSatisfied = _UpgradeDataSetLogic:IsConditionSatisfied(nextLevelData, player)
		
		self.ConditionEntity.Enable = true
		self.ConditionText.Text = _UpgradeDataSetLogic:ReturnConditionText(nextLevelData)
		if conditionSatisfied == true then
			self.ConditionText.FontColor = _ColorCodeEnum:GetColor("#FFFFFF")
			self.ConditionText.OutlineColor = _ColorCodeEnum:GetColor("#8C7352")
		else
			self.ConditionText.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			self.ConditionText.OutlineColor = _ColorCodeEnum:GetColor("#FFFFFF")
		end
		
		self.CostEntity.Enable = true
		
		self.CostText.Text = _StringUtilLogic:ReturnThousandsSeparatedString(nextLevelData:GetUpgradeCost(player))
		if moneySatisfied == true then
			self.CostText.FontColor = _ColorCodeEnum:GetColor("#FFFFFF")
			self.CostText.OutlineColor = _ColorCodeEnum:GetColor("#8C7352")
		else
			self.CostText.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			self.CostText.OutlineColor = _ColorCodeEnum:GetColor("#FFFFFF")
		end
		
		local canBuy = moneySatisfied and conditionSatisfied
		if canBuy then
			self.UpgradeButtonDim.Enable = false
		else
			self.UpgradeButtonDim.Enable = true
		end
		
		self.upgradeHandler = self.UpgradeButton:ConnectEvent(ButtonClickEvent, function()
		
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			if conditionSatisfied == false then
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("UpgradeErrorMessage3"))
				return
			end
			
			if moneySatisfied == false then
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("NoMoneyToastMsg"))
				return
			end
			
			if playerUpgrade.IsServerProcessing then
				return
			end
			
			if typeId == _UpgradeTypeEnum.DisplayResearch then 
				local maxLv = _UpgradeDataSetLogic:ReturnMaxLevelValueOfType(_UpgradeTypeEnum.DisplayCount, _UserService.LocalPlayer)
				if maxLv > _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.DisplayCount) then 
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("UpgradeErrorMessage4"))
					return 
				end
			end
			
			if typeId == _UpgradeTypeEnum.InteriorLevel then 
				
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
				local onOk = function()
						
					_UIEntityService:PlayUISpriteAnim(self.LevelUpEffect, "58a7d48901d64cc8a4a5d7c2a6c1174c", 1)
					playerUpgrade:ChangeConnectingStatus(true)
					playerUpgrade:RequestUpgrade(typeId, false)
			
				end
						
				local onCancel = function()
					
					_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
				     
				end
					
				local styleName = _GetLocalizationTextLogic:GetText("InteriorLevel"..nextLevel)
				local message = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("UpgradeInteriorConfirmPopupMsg", styleName)
				_UIPopup:Open(message, onOk, onCancel, _GetLocalizationTextLogic:GetText("UpgradeInteriorConfirmPopupTitle"))	
				
				return 
				
			end
		
			_UIEntityService:PlayUISpriteAnim(self.LevelUpEffect, "58a7d48901d64cc8a4a5d7c2a6c1174c", 1)
			playerUpgrade:ChangeConnectingStatus(true)
			playerUpgrade:RequestUpgrade(typeId, false)
			
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetDescEntity(Entity entity, UpgradeHelpData helpData, integer typeId)
		-- 업그레이드 도움말 데이터를 UI 엔티티에 설정
		local helpType = helpData.Type
		if helpType == "TextOnly" then
			
			local textKey = helpData.ContentsTextKey
			
			local formatKeyCount = 0
		
			local arg0 = helpData.FormatText0Value
			local arg1 = helpData.FormatText1Value
			local arg2 = helpData.FormatText2Value
			local arg3 = helpData.FormatText3Value
			local arg4 = helpData.FormatText4Value	
			local arg5 = helpData.FormatText5Value
			
			
			if not _UtilLogic:IsNilorEmptyString(arg5) then
				formatKeyCount = 6		
			elseif not _UtilLogic:IsNilorEmptyString(arg4) then
				formatKeyCount = 5	
			elseif not _UtilLogic:IsNilorEmptyString(arg3) then
				formatKeyCount = 4	
			elseif not _UtilLogic:IsNilorEmptyString(arg2) then
				formatKeyCount = 3
			elseif not _UtilLogic:IsNilorEmptyString(arg1) then
				formatKeyCount = 2
			elseif not _UtilLogic:IsNilorEmptyString(arg0) then
				formatKeyCount = 1
			end
			
			local player = _UserService.LocalPlayer
			local playerUpgrade = player.PlayerUpgrade
			local typeData = _UpgradeDataSetLogic:GetData(typeId)
			local currentLevel = playerUpgrade:ReturnPlayerUpgradeLevelOfType(typeId)
			local nextLevel = currentLevel + 1
			if nextLevel > typeData.MaxLevel then
				nextLevel = typeData.MaxLevel
			end
			
			local currentValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, currentLevel, player)
			local nextValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, nextLevel, player)
			
			if typeId == _UpgradeTypeEnum.TrainingIngreBox then
			
				local ingreGradeLocalizationKeys = _UtilLogic:Split(arg0 , ",")
				local ingreGradeTexts = {}
				
				for i = 1, #ingreGradeLocalizationKeys do
					table.insert(ingreGradeTexts, _GetLocalizationTextLogic:GetText(ingreGradeLocalizationKeys[i]) )
				end
				
				arg0 = ""
				
				for j = 1 , #ingreGradeTexts do
					
					if _UtilLogic:IsNilorEmptyString(arg0) then
						arg0 = ingreGradeTexts[j]
					else
						
						arg0 = arg0..", "..ingreGradeTexts[j]
					end
				end
				
				arg0 = "<color=#ff9813>"..arg0.."</color>"
				
			else	
				
				if arg0 == "level" then
					
					if currentLevel == typeData.MaxLevel then
						currentLevel = currentLevel - 1
					end		
					
					arg0 = currentLevel
					
				elseif arg0 == "nextLevel" then
					arg0 = nextLevel
					
				elseif arg0 == "levelValue" then
					
					if currentLevel == typeData.MaxLevel then
						currentLevel = currentLevel - 1
						currentValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, currentLevel, player)
					end		
					arg0 = currentValue
					
				elseif arg0 == "nextLevelValue" then
					arg0 = nextValue
					
				elseif arg0 == "beforeCustomerCount"	then
					if currentLevel == typeData.MaxLevel then
						currentLevel = currentLevel - 1
					end		
					
					local dataRow = _DataService:GetTable("TrainingUpgradeDataSet"):FindRow("UpgradeLevel", tostring(currentLevel))
					local customerCount = _StringUtilLogic:StringToInt(dataRow:GetItem("TrainingCustomerCount"))
					
					local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage)
					customerCount = math.floor(customerCount * (1 + stageConfig.TrainingMoneyRate))	
			
					arg0 = customerCount
				
				elseif  arg0 == "levelValueDisplay"	then
				
					if currentLevel == typeData.MaxLevel then
						currentLevel = currentLevel - 1
						currentValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, currentLevel, player)
					end		
					
					local effectValue = _KitchenAppService:GetData( _KitchenAppEnumType.Display..tostring(currentValue)).EffectValue
					arg0 = effectValue
				end
			end
			
			
			
			if arg1 == "nextLevel" then
				arg1 = nextLevel
		
			elseif arg1 == "levelValue" then
				
				if currentLevel == typeData.MaxLevel then
					currentLevel = currentLevel - 1
					currentValue = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(typeId, currentLevel, player)
				end		
		
				arg1 = currentValue
				
			elseif arg1 == "nextLevelValue" then
				arg1 = nextValue
				
			elseif arg1 == "afterCustomerCount"	then
				local dataRow = _DataService:GetTable("TrainingUpgradeDataSet"):FindRow("UpgradeLevel", tostring(nextLevel))
				local customerCount = _StringUtilLogic:StringToInt(dataRow:GetItem("TrainingCustomerCount"))
				
				local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage)
				customerCount = math.floor(customerCount * (1 + stageConfig.TrainingMoneyRate))	
		
				arg1 = customerCount
				
			elseif  arg1 == "nextLevelValueDisplay"	then
				
				local effectValue = _KitchenAppService:GetData( _KitchenAppEnumType.Display..tostring(nextValue)).EffectValue
				arg1 = effectValue
			end
			
			if arg2 == "nextLevelValue" then
				arg2 = nextValue 
				
			elseif arg2 == "customerBonus" then		
				local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage)
				local customerBonus = math.floor(stageConfig.TrainingMoneyRate*100)	
				arg2 = customerBonus	
			end	
			
				
			if arg3 == "beforePrice" then		
				
				if currentLevel == typeData.MaxLevel then
					currentLevel = currentLevel - 1
				end		
				
				local dataRow = _DataService:GetTable("TrainingUpgradeDataSet"):FindRow("UpgradeLevel", tostring(currentLevel))
				local burgerPrice = _StringUtilLogic:StringToInt(dataRow:GetItem("TrainingBurgerPrice"))
				
				arg3 = burgerPrice
				
			end
			
			
			if arg4 ==  "afterPrice" then		
				local dataRow = _DataService:GetTable("TrainingUpgradeDataSet"):FindRow("UpgradeLevel", tostring(nextLevel))
				local burgerPrice = _StringUtilLogic:StringToInt(dataRow:GetItem("TrainingBurgerPrice"))
				arg4 = burgerPrice
				
			end
			
			if formatKeyCount == 6 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(textKey, arg0, arg1, arg2, arg3, arg4, arg5 )	
		
			elseif formatKeyCount == 5 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(textKey, arg0, arg1, arg2, arg3, arg4 )	
		
			elseif formatKeyCount == 4 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(textKey, arg0, arg1, arg2, arg3 )	
				
			elseif formatKeyCount == 3 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(textKey, arg0, arg1, arg2 )	
						
			elseif formatKeyCount == 2 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(textKey, arg0, arg1 )	
				
			elseif formatKeyCount == 1 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(textKey, arg0 )	
				
			elseif formatKeyCount == 0 then
				textKey = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetText(textKey)
			end
			
			entity.TextComponent.Text = textKey
			
		elseif helpType == "ImageOnly" then
			entity.SpriteGUIRendererComponent.ImageRUID = helpData.ImageRUID
				
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshEmpty()
		-- 선택된 업그레이드가 없을 때 빈 상태로 UI를 갱신
		self.NameText.Entity.Enable = false
		self.EffectText.Entity.Enable = false
		self.NoTitle.Enable = true
		
		self.ConditionText.Text = "-"
		self.CostText.Text = "-"
		self.GoldIcon.Enable = false
		
		self.ConditionText.FontColor = _ColorCodeEnum:GetColor("#FFFFFF")
		self.ConditionText.OutlineColor = _ColorCodeEnum:GetColor("#8C7352")
		self.CostText.FontColor = _ColorCodeEnum:GetColor("#FFFFFF")
		self.CostText.OutlineColor = _ColorCodeEnum:GetColor("#8C7352")
		self.CostInfoBtn.Enable = false
		
		self.Desc.SpriteGUIRendererComponent.Color.a = 1
		
		for i, child in pairs(self.Desc.Children) do
			child.Enable = child.Name == "TextOnly"
			if child.Enable == true then
				child.TextComponent.Text = "-"
			end
		end
		
		self.UpgradeButton.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void RefreshCostTooltip(UpgradeLevelData nextLevelData)
		-- 업그레이드 비용 툴팁에 원래 비용과 할인 효과를 표시
		local player = _UserService.LocalPlayer
		local upgradeCost = nextLevelData:GetUpgradeCost(player)
		
		local stEffect = _StrategyEnum:GetPlayerStrategyEffect(player, _StrategyEnum.ReduceUpgradeCost, player.PlayerStage.NowStage)
		
		local origin = math.ceil(upgradeCost / (1 - stEffect))
		local stEffectValue = upgradeCost - origin
		
		self.OriginTitle.Text = _GetLocalizationTextLogic:GetText("MoneyBonusText_Origin")
		self.OriginValue.Text = _StringUtilLogic:ReturnThousandsSeparatedString(origin)
		
		self.St_ReduceUpgradeCostTitle.Text = string.format("%s(%d", _GetLocalizationTextLogic:GetText("MoneyBonusText_St_ReduceUpgradeCost"), -math.floor(stEffect*100)).."%)"
		self.St_ReduceUpgradeCostValue.Text = _StringUtilLogic:ReturnThousandsSeparatedString(stEffectValue)
	end

end