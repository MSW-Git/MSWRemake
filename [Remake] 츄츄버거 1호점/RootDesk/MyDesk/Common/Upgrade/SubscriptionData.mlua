@Struct
script SubscriptionData

	property string Id = ""

	property string Type = ""

	property integer Expiration = 0

	property string TargetItem = ""

	method void Load(any dataTable, integer index)
		-- CSV 테이블에서 구독 서비스 데이터를 로드
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		self.Type = row:GetItem("Type")
		self.Expiration = tonumber(row:GetItem("Expiration"))
		self.TargetItem = row:GetItem("TargetItem")
	end

end