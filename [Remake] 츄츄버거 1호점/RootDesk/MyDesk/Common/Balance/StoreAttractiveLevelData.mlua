@Struct
script StoreAttractiveLevelData

	property integer StoreAttractiveLevel = 0

	property SyncTable<integer, number> RequiredAttractiveGroup

	property number ExpectedExpansionAttractive = 0

	property number ExpectedInteriorAttractive = 0

	property number ExpectedDecoAttractive = 0

	property integer MinReputation = 0

	property integer MaxReputation = 0

	property integer MaxCustomerCountPerMonth = 0

	property integer TipValuePerCustomer = 0

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 매장 매력도 레벨 정보를 로드
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.StoreAttractiveLevel = tonumber(row:GetItem("StoreAttractiveLevel"))
		self.ExpectedExpansionAttractive = tonumber(row:GetItem("ExpectedExpansionAttractive"))
		self.ExpectedInteriorAttractive = tonumber(row:GetItem("ExpectedInteriorAttractive"))
		self.ExpectedDecoAttractive = tonumber(row:GetItem("ExpectedDecoAttractive"))
		self.MinReputation = tonumber(row:GetItem("MinReputation"))
		self.MaxReputation = tonumber(row:GetItem("MaxReputation"))
		self.MaxCustomerCountPerMonth = tonumber(row:GetItem("MaxCustomerCountPerMonth"))
		self.TipValuePerCustomer = tonumber(row:GetItem("TipValuePerCustomer"))
		
		for i = 1, 9 do
			self.RequiredAttractiveGroup[i] = tonumber(row:GetItem("RequiredAttractiveGroup"..i))
		end
	end

end