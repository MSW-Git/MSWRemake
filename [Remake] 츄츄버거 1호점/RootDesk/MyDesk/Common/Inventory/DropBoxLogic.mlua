@Logic
script DropBoxLogic extends Logic

	@ExecSpace("ServerOnly")
	method void OpenDropBox(Entity player, string dropBoxId)
		-- 드롭박스 ID에 따라 확률적으로 아이템을 지급하는 메서드
		local dropBoxTable = _ItemDataSetLogic.DropBoxData
		local keys = table.keys(dropBoxTable)
		
		local itemsTable = {}
		
		for i = 1, #keys do
			if keys[i] == dropBoxId then
				table.insert(itemsTable, dropBoxTable[keys[i]])
			end
		end
		
		local totalWeight = 0
		for i = 1, #itemsTable do	
			local weight = tonumber(itemsTable[i]["Weight"])
			totalWeight = totalWeight + weight
		end
		
		local pivot = _UtilLogic:RandomDouble() * totalWeight
		
		local weights = 0
		for i = 1, #itemsTable do
			local weight = tonumber(itemsTable[i]["Weight"])
			weights = weights + weight
			if weights >= pivot then
				self:AddItem(player, itemsTable[i]["ItemId"], tonumber(itemsTable[i]["ItemCount"]))
				break
			end
		end
	end

	@ExecSpace("Server")
	method void AddItem(Entity player, string itemId, integer itemCount)
		-- 플레이어 인벤토리에 아이템을 추가하는 메서드
		if player == nil then
			return
		end
		local result = player.PlayerInventory:AddItem(itemId, itemCount,"DropBox","DropBox poup")
		
	end

	@ExecSpace("Server")
	method void CheckLogic(string dropBoxId)
		-- 드롭박스 확률 로직을 테스트하는 디버그용 메서드
		local dropBoxTable = _DataService:GetTable("DropBoxDataSet")
		local itemsTable = {}
		
		for i = 1, dropBoxTable:GetRowCount() do
			if dropBoxTable:GetRow(i):GetItem("DropBoxId") == dropBoxId then
				table.insert(itemsTable, dropBoxTable:GetRow(i))
			end
		end
		
		local totalWeight = 0
		for i = 1, #itemsTable do
			local weight = tonumber(itemsTable[i]:GetItem("Weight"))
			totalWeight = totalWeight + weight
		end
		
		local testCount = 100000
		for i = 1, testCount do
			local weights = 0
			local pivot = _UtilLogic:RandomDouble() * totalWeight
			for i = 1, #itemsTable do
				local weight = tonumber(itemsTable[i]:GetItem("Weight"))
				weights = weights + weight
				if weights >= pivot then
					break
				end
			end
		end
	end

end