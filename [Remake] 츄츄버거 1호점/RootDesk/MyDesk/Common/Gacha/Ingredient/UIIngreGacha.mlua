@Component
script UIIngreGacha extends Component

	property Entity GachaSlots = "e9d9b262-dff9-478b-a1f6-d7cd061e66a9"

	property boolean isOpenedCompletely = false

	property Entity BG = "dc32b519-24d4-4545-962a-a1551bcc3a5e"

	property Entity IngreBunCollectionBtn = "1d75a423-5151-4033-b477-c37b2c46f128"

	property Entity IngreBunCollectionRedDot = "4dba55a5-eb19-4eac-a5eb-53ca739112ef"

	@ExecSpace("ClientOnly")
	method void Open(boolean openCompletely)
		-- 재료 가챠 UI를 열고 필요시 레시피 그룹도 함께 활성화
		if self.Entity.Enable == true then
			return
		end
		
		if openCompletely then
			_UIGroupManager:EnableRecipeGroup(true)
			_UIEntityLogic_RecipeGroup.UIRecipeBook.Enable = false
		end
		
		
		self.Entity.Enable = true
		self._T.isProcessing = true
		_UIGroupManager:EnableBackToLobbyBtn(false)
		self.IngreBunCollectionBtn.Enable = false
		_UIEntityService:PlayUIOpenAnim(self.BG, self.BG.UITransformComponent.anchoredPosition, Vector2(0,1), nil, nil, nil, nil, function()
			_UIGroupManager:EnableBackToLobbyBtn(nil)
			self.IngreBunCollectionBtn.Enable = true
			self._T.isProcessing = false
		end)
		
		_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting:SetIngreGachaRedDot(false)
		_MainMenuRedDotManager:EnableIngreGachaRedDot(false)
		
		self.isOpenedCompletely = openCompletely
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 재료 가챠 UI를 닫고 관련 UI 상태를 정리
		self.Entity.Enable = false
		if self.isOpenedCompletely then
			_UIGroupManager:EnableRecipeGroup(false)
		else
			if _UIEntityLogic_RecipeGroup.UIIngreCardSetting.Enable then
				_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting:CheckTutorial()
			end	
		end
		
		_UIGroupManager:EnableBackToLobbyBtn(nil)
		
		self.isOpenedCompletely = false
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 가챠 슬롯들을 새로고침하여 아이템 데이터로 UI 업데이트
		for i = 1, #self.GachaSlots.Children do
			self.GachaSlots.Children[i].Enable = false
		end
		
		local itemDataSet = _DataService:GetTable("ItemData")
		local gachaItems = {}
		for i = 1, itemDataSet:GetRowCount() do
			local row = itemDataSet:GetRow(i)
			local category = tonumber(row:GetItem("ItemCategory"))
			if category == 1 then
				table.insert(gachaItems, row:GetItem("Id"))
			end
		end
		
		for i = 1, #gachaItems do
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_UIIngreGachaItemRenderer", i, self.GachaSlots)
			entity.UIIngreGachaItemRenderer:Refresh(gachaItems[i])
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 UI 새로고침
		self:Refresh()
	end

	@EventSender("Entity", "ac447402-4240-4cb6-88db-dea4a37279cf")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 재료 가챠 UI를 닫는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self._T.isProcessing == true then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
		
	end

	@EventSender("Entity", "c125245f-716a-498f-aa74-5211f6b45670")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 재료 가챠 전체 보기 버튼 클릭 시 UI를 완전히 여는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open(true)
	end

	@EventSender("Entity", "c8793ca4-aeb7-4532-bf6f-cd4a2b978bb3")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 배경 클릭 시 재료 가챠 UI를 닫는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self._T.isProcessing == true then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("Entity", "1d75a423-5151-4033-b477-c37b2c46f128")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 재료번 컶렉션 버튼 클릭 시 컶렉션 UI를 여는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self._T.isProcessing == true then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Open_Collection"], 1)
		_UICollectionLogic.uiIngreBunCollection:Open(1)
	end

end