@Logic
script IngredientGachaDataLogic extends Logic

	property table IngreGachaRandomBoxData = {}

	method void OnBeginPlay()
		-- 게임 시작 시 재료 가챠 데이터셋을 로드
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- CSV 파일에서 재료 가챠 랜덤박스 데이터를 로드하여 메모리에 저장
		table.clear(self.IngreGachaRandomBoxData)
		local dataset = _DataService:GetTable("IngredientGachaRandomBoxData")
		for i = 1, dataset:GetRowCount() do
			local data = IngreGachaRandomBoxData()
			data:Load(dataset, i)
			
			if self.IngreGachaRandomBoxData[data.Id] ~= nil then
				break
			end
		
			self.IngreGachaRandomBoxData[data.Id] = data
		end
	end

	@ExecSpace("ServerOnly")
	method integer ReturnMultiCountByGachaId(string gachaId)
		-- 가챠 ID에 따른 멀티 뽑기 개수를 반환 (BN: 3개, IN: 5개)
		if self.IngreGachaRandomBoxData[gachaId] == nil then
			return nil
		end
		
		local gachaType = _UtilLogic:SubString(gachaId, 1, 2)
		if gachaType == "BN" then
			return 3
		elseif gachaType == "IN" then
			return 5
		end
	end

	method IngreGachaRandomBoxData GetIngreGachaRandomBoxData(string id)
		-- ID로 재료 가챠 랜덤박스 데이터를 조회하여 반환
		return self.IngreGachaRandomBoxData[id]
	end

end