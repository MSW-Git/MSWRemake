@Component
script UIIngreGachaItemRenderer extends Component

	property Entity ItemIcon = nil

	property Entity ItemStars = nil

	property Entity NameText = nil

	property Entity CountText = nil

	property Entity TryOnceBtn = nil

	property Entity TryMultiBtn = nil

	property string ItemId = ""

	property integer ExCount = nil

	property Entity IconImage = nil

	property Entity TryOnceDisable = nil

	property Entity TryMultiDisable = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- UI 요소들을 초기화하고 버튼 텍스트 설정
		self.IconImage = self.Entity:GetChildByName("IconImage")
		self.ItemIcon = self.IconImage:GetChildByName("Icon")
		self.ItemStars = self.IconImage:GetChildByName("Stars")
		
		self.NameText = self.Entity:GetChildByName("NameText")
		self.CountText = self.Entity:GetChildByName("CountText")
		self.TryOnceBtn = self.Entity:GetChildByName("TryOnceBtn")
		self.TryOnceBtn.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("IngreGachaCount_Format", 1)
		self.TryOnceDisable = self.TryOnceBtn:GetChildByName("Disable")
		self.TryMultiBtn = self.Entity:GetChildByName("TryMultiBtn")
		self.TryMultiBtn.TextComponent.Text = _GetLocalizationTextLogic:GetText("IngreGachaTryMaxCount")
		self.TryMultiDisable = self.TryMultiBtn:GetChildByName("Disable")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(string itemId)
		-- 아이템 ID로 가챠 아이템 UI를 새로고침하고 이벤트 연결
		if self.ItemIcon == nil then
			self:Init()
		end
		
		
		self.ItemId = itemId
		
		for i = 1, #self.ItemStars.Children do
			self.ItemStars.Children[i].Enable = false
		end
		
		local itemData = _ItemDataSetLogic:GetItemData(itemId)
		
		local boxId = itemData.funcUseItemParam[1]
		local gachaType = _UtilLogic:SubString(boxId, 1, 2)
		
		self.IconImage.SpriteGUIRendererComponent.Color.a = 0
		if gachaType == "IN" then
			local grade = tonumber(string.sub(itemId, string.len(itemId)-1, string.len(itemId)))
			
			for i = 1, grade do
				local star = _UIEntityService:GetOrCreateEntityOfModel("UISprite", i, self.ItemStars)
				star.SpriteGUIRendererComponent.ImageRUID = _StringUtilLogic.StarRUID
				star.UITransformComponent.RectSize = Vector2(30, 30)
			end
			
			if grade == 3 then
				self.IconImage.SpriteGUIRendererComponent.Color.a = 1
				self.IconImage.SpriteGUIRendererComponent.ImageRUID = "3d77a6d8208045c59c5fc55c3e8cc092"
			elseif grade == 2 then
				self.IconImage.SpriteGUIRendererComponent.Color.a = 1
				self.IconImage.SpriteGUIRendererComponent.ImageRUID = "6e899a6478b84758b6c1ba2f89da835c"
			end
		end
		
		self.ItemIcon.SpriteGUIRendererComponent.ImageRUID = itemData.IconRUID
		
		self.NameText.TextComponent.Text = _LocalizationService:GetText(itemData.NameKey)
		
		
		self:RefreshCountText()
		
		self.TryOnceBtn:ConnectEvent(ButtonClickEvent, function()
			local playerInven = _UserService.LocalPlayer.PlayerInventory
			
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			if _UserService.LocalPlayer.PlayerIngredient.IsServerProcessing then
				return
			end
			
			local itemCount = playerInven:GetItemCount(self.ItemId)
			if itemCount == nil then
				itemCount = 0
			end
			
			if itemCount < 1 then
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("IngreGachaError1"))
				return
			end
			
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_IngreBoxOpen"], 1)
		    _UserService.LocalPlayer.PlayerIngredient:ChangeConnectingStatus(true)
			playerInven:RequestUseItem(itemId, 1,"IngreGacha","IngreGacha popup", nil)
		end)
		
		self.TryMultiBtn:ConnectEvent(ButtonClickEvent, function()
			local playerInven = _UserService.LocalPlayer.PlayerInventory
			
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			if _UserService.LocalPlayer.PlayerIngredient.IsServerProcessing then
				return
			end
			
			local itemCount = playerInven:GetItemCount(self.ItemId)
			if itemCount == nil then
				itemCount = 0
			end
			if itemCount < 1 then
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("IngreGachaError1"))
				return
			end
			
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_IngreBoxOpen"], 1)
		    _UserService.LocalPlayer.PlayerIngredient:ChangeConnectingStatus(true)
			playerInven:RequestUseItem(itemId, itemCount,"IngreGacha","IngreGacha popup", nil)
		end)
	end

	@ExecSpace("ClientOnly")
	method void RefreshCountText()
		-- 아이템 수량에 따라 버튼 활성화 상태와 텍스트 색상 업데이트
		if self.TryOnceDisable == nil then
			self:Init()
		end
		
		local playerInven = _UserService.LocalPlayer.PlayerInventory
		local itemCount = playerInven:GetItemCount(self.ItemId)
		if itemCount == nil then
			itemCount = 0
		end
		
		local countColor = "#8b7b63"
		if itemCount > 0 then
			self.TryOnceDisable.Enable = false
			self.TryMultiDisable.Enable = false
		else
			self.TryOnceDisable.Enable = true
			self.TryMultiDisable.Enable = true
			countColor = "#fa5246"
		end
		
		local title = _GetLocalizationTextLogic:GetText("IngreGachaCountTitle").." "
		local colored = "<color="..countColor..">"..itemCount.."</color>"
		local content = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Things_Format", colored)
		
		self.CountText.TextComponent.Text = title..content
		
		if self.ExCount == nil then
			self.ExCount = itemCount
			return
		end
		
		if itemCount > self.ExCount then
			if _UIEntityLogic_RecipeGroup.UIIngreGachaDim.Enable == false then
				local player = _UserService.LocalPlayer
		        local redDotEnable = _UIButtonUnlockLogic.IsUnlockEveryButton == true and true or player.PlayerEvent:IsEventOccured(_TutorialEventEnum.ChickenTagFeedback[1])
				
				_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting:SetIngreGachaRedDot(redDotEnable)
				_MainMenuRedDotManager:EnableIngreGachaRedDot(redDotEnable)
			end
		end
		
		self.ExCount = itemCount
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 재료 가챠 빨간점 비활성화
		_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting:SetIngreGachaRedDot(false)
		_MainMenuRedDotManager:EnableIngreGachaRedDot(false)
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerInventoryItemChangedEvent(PlayerInventoryItemChangedEvent event)
		-- 플레이어 인벤토리 아이템 변경 시 수량 텍스트 업데이트
		if _UserService.LocalPlayer.PlayerInventory:GetItemCount(self.ItemId) ~= self.ExCount then
			self:RefreshCountText()
		end
	end

end