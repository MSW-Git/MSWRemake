@Logic
script BGMService extends Logic

	property string LobbyBGM = "6b68d1ba391643fab60cd5f726cad64c"

	property string RecipeMakingBGM = "fdd63a2f506643f08a6d8e2136a773e3"

	property string TrialBGM = "27845f761e1441fda0a6df50a0ca1027"

	property string TrialResultBGM = "0470e1a58d434a58a00c0bcc955f38a1"

	property string VIPOrderBGM = "1401aacb48bf42fea21c965da4a835a9"

	property string TrainingBGM = "fdd63a2f506643f08a6d8e2136a773e3"

	property string TrainingEDMBGM = "6b71530b3f624ff78b58997c2d0281a8"

	property string OutroBGM = "f5bb92d91e134c699e7bb2cf1aaca8e6"

	property string IntroStartBGM = "8b57ad3bb40742a1b4955390bf14b36d"

	property string IntroEndBgm = "8ddfa1a102e84ad4be587c789fe8e0d9"

	property string ExchangeBgm = "7ca2c33f65204582959207ac4c7c9870"

	property boolean MUTE = false

	@ExecSpace("Client")
	method void ApplyBGM(string BGMRuid)
		-- 지정된 BGM을 현재 맵에 적용하고 재생
		local player = _UserService.LocalPlayer
		local curMap = player.CurrentMap
		
		curMap.SoundComponent:Stop()
		curMap.SoundComponent.AudioClipRUID = BGMRuid
		curMap.SoundComponent.Volume = 0.6
		
		if self.MUTE == false then
			curMap.SoundComponent:Play()
		end
	end

	@ExecSpace("Client")
	method void ApplySpotBGM(string curSpotID)
		-- 스팟 데이터에서 해당 스팟의 BGM을 찾아서 적용
		local spotDataSet = _DataService:GetTable("SpotDataSet")
		local player = _UserService.LocalPlayer
		local curMap = player.CurrentMap
		
		local row = spotDataSet:FindRow("SpotKey", curSpotID)
		if isvalid(row) then
			local spotBGM = row:GetItem("BGMRuid")
			
			if _UtilLogic:IsNilorEmptyString(spotBGM) then
			else
				curMap.SoundComponent:Stop()
				curMap.SoundComponent.AudioClipRUID = spotBGM
				curMap.SoundComponent:Play()
			end
		else
		end
	end

	@ExecSpace("Client")
	method void StopBGM()
		-- 현재 재생 중인 BGM을 정지
		local player = _UserService.LocalPlayer
		local curMap = player.CurrentMap
		curMap.SoundComponent:Stop()
	end

	@ExecSpace("Client")
	method void ResumeBGM()
		-- 정지된 BGM을 다시 재생
		local player = _UserService.LocalPlayer
		local curMap = player.CurrentMap
		curMap.SoundComponent:Play()
	end

	@ExecSpace("Client")
	method void ApplyLobbyBGM()
		-- 현재 스테이지에 맞는 로비 BGM을 적용
		local stageId = _UserService.LocalPlayer.PlayerStage.NowStage
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		local bgm = stageData.Bgm
		
		self:ApplyBGM(bgm)
	end

end