@Logic
script DBUtilLogic extends Logic

	method number GetNumberByTable(table dataTable, string key, integer defaultValue)
		-- 테이블에서 키에 해당하는 숫자 값을 가져오고 없으면 기본값 반환
		local value = dataTable[key]
		if value == nil then
			return defaultValue
		end
		return tonumber(value)
	end

	method string GetStringByTable(table dataTable, string key, string defaultValue)
		-- 테이블에서 키에 해당하는 문자열 값을 가져오고 없으면 기본값 반환
		local value = dataTable[key]
		if value == nil then
			return defaultValue
		end
		return value
	end

	method boolean IsEmpty(table tbl)
		-- 테이블이 비어있거나 nil인지 확인
		if tbl == nil then
			return true
		end
		
		if next(tbl) == nil then
			return true
		end
		
		return false
	end

	method string SerializeAttendTable(table stringStructTable)
		-- 출석 정보 테이블을 문자열로 직렬화 (미구현)
		--    ---@type AttendanceInfo
		return ""
	end

	method table DeserializeAttendTable(string data)
		-- 문자열에서 출석 정보 테이블로 역직렬화 (미구현)
		return {}
	end

end