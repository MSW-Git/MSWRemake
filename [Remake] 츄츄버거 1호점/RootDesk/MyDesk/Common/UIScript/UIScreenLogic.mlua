@Logic
script UIScreenLogic extends Logic

	property UITransformComponent lb = "285395e1-26bb-4881-a5f4-30304a3490af"

	property UITransformComponent rt = "371bed97-3a33-4a3b-beb7-f59f955a6237"

	property Vector2 standard = Vector2(1920,1080)

	method integer GetWidth()
		-- 화면의 너비를 계산하여 반환
		return self.rt.Position.x - self.lb.Position.x
	end

	method integer GetHeight()
		-- 화면의 높이를 계산하여 반환
		return self.rt.Position.y - self.lb.Position.y
	end

	method Vector2 GetResolution()
		-- 현재 화면의 해상도를 Vector2로 반환
		return Vector2(self:GetWidth(), self:GetHeight())
	end

	method integer GetRatioX(integer width)
		-- 기준 해상도 대비 X축 비율을 계산하여 실제 화면 너비로 변환
		return width / self.standard.x * _UILogic.ScreenWidth
	end

	method integer GetRatioY(integer height)
		-- 기준 해상도 대비 Y축 비율을 계산하여 실제 화면 높이로 변환
		return height / self.standard.y * _UILogic.ScreenHeight
	end

	method Vector2 GetPosition(Vector2 pos)
		-- 절대 좌표를 상대 좌표(0~1)로 변환
		local resolution = self:GetResolution()
		local x = pos.x / _UILogic.ScreenWidth
		local y = pos.y / _UILogic.ScreenHeight
		return Vector2(x, y)
	end

	method Vector3 GetPositionFromTouchPoint(Vector2 touchPoint)
		-- 터치 포인트를 UI 좌표계로 변환하여 Vector3로 반환
		return ((self:GetPosition(touchPoint) - Vector2(0.5, 0.5)) * self:GetResolution()):ToVector3()
	end

end