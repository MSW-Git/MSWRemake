@Logic
script UIPopupPurchase extends Logic

	property ButtonComponent btnOk = "a377aebd-b53d-428f-bad2-53cbf79ff0c9"

	property Entity popupGroup = "7ed462c5-0353-4aaf-99ff-de5fc652bfc5"

	property Entity popup = "8bdd1af6-49d7-49b0-a492-4645021e62d7"

	property any onOk = nil

	property number duration = 0.15

	property number from = 0.5

	property number to = 1

	property boolean isOpen = false

	property boolean isTweenPlaying = false

	property number tweenEventId = 0

	property any okHandler = nil

	property TextComponent PriceText = "d1de110e-0cf4-4877-92fc-8fcc0e48e576"

	property Entity TextForSpecialShop = "d8a9b600-c7d5-4c25-afa8-31c3fef5fbdd"

	property Entity TextForBoosterPack = "0bac748e-c3da-473e-a758-85d8a836b099"

	@ExecSpace("Client")
	method void Open(string priceString, any onOk, boolean isBoosterPack)
		-- 구매 팝업을 열고 가격과 콜백 함수를 설정하는 함수
		if self.isOpen == true then
			return
		end
		
		self.PriceText.Text = priceString
		
		self.isOpen = true
		self.popupGroup.Enable = true
		self.onOk = onOk
		
		if isBoosterPack then
			self.TextForSpecialShop.Enable = false
			self.TextForBoosterPack.Enable = true
		else
			self.TextForSpecialShop.Enable = true
			self.TextForBoosterPack.Enable = false
		end
		_UIGroupManager:EnableBackToLobbyBtn(false)
		
		self.okHandler = self.btnOk.Entity:ConnectEvent(ButtonClickEvent, self.OnClickOk)
		self:StartTween(true)
	end

	method void OnClickOk()
		-- 확인 버튼 클릭 시 팝업을 닫고 콜백 함수를 실행하는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self.isTweenPlaying == true then
			return
		end
		if self.onOk ~= nil then
			self.onOk()
			self.onOk = nil
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Close()
	end

	method void Close()
		-- 팝업을 닫고 이벤트 연결을 해제하는 함수
		self.btnOk.Entity:DisconnectEvent(ButtonClickEvent,self.okHandler)
		self:StartTween(false)
		_UIGroupManager:EnableBackToLobbyBtn(nil)
	end

	method void StartTween(boolean open)
		-- 팝업 열기/닫기 트윈 애니메이션을 시작하는 함수
		local transform = self.popup.UITransformComponent
		local canvasGroup = self.popupGroup.CanvasGroupComponent 
		if open == true then
			canvasGroup.GroupAlpha = 0
			transform.UIScale = Vector3(self.from,self.from,1)
		else
			transform.UIScale = Vector3(self.to,self.to,1)
		end
		self.isTweenPlaying = true
		local time = 0
		
		
		local preTime = _UtilLogic.ElapsedSeconds
		
		local tween = function()
			local delta = _UtilLogic.ElapsedSeconds - preTime
			time = time + delta
			local timeValue = time	
			preTime = _UtilLogic.ElapsedSeconds
		
			if time >= self.duration then
				timeValue = self.duration
				if open == false then
					self.popupGroup.Enable = false
					self.isOpen = false
				end
				self.isTweenPlaying = false
				_TimerService:ClearTimer(self.tweenEventId)
		
			end
			if open == false then
				timeValue = self.duration - timeValue
			end
			local tweenValue = _TweenLogic:Ease(self.from, self.to, 
				self.duration, EaseType.SineEaseIn, timeValue)
			transform.UIScale = Vector3(tweenValue,tweenValue,1)
			canvasGroup.GroupAlpha = timeValue / self.duration
		end
		self.tweenEventId = _TimerService:SetTimerRepeat(tween,1/60)
		
	end

	@EventSender("Entity", "288238ba-a84c-4cd0-bee2-104d93389e70")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:Close()
	end

end