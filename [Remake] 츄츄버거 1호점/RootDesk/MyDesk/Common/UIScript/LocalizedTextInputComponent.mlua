@Component
script LocalizedTextInputComponent extends Component

	property number CharacterMultiply = 1.4

	@DisplayName("(입력불필요)OriginCharacterLimit")
	property integer OriginCharacterLimit = 10

	property boolean IsAutoSet = true

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 자동 설정이 활성화되어 있으면 문자 제한을 설정
		if self.IsAutoSet == true then
			self:SetCharacterLimit()
		end
	end

	@ExecSpace("ClientOnly")
	method void SetCharacterLimit()
		-- 현재 로케일에 따라 텍스트 입력 컴포넌트의 문자 제한을 조정
		local textInputComponent = self.Entity.TextInputComponent
		if isvalid(textInputComponent) == false then
			return
		end
		
		self.OriginCharacterLimit = textInputComponent.CharacterLimit
		
		if _LocalizationService.CurrentLocaleId == "en" or _LocalizationService.CurrentLocaleId == "es" then
			textInputComponent.CharacterLimit = self.OriginCharacterLimit * self.CharacterMultiply
		end
	end

end