@Logic
script MainMenuRedDotManager extends Logic

	property Entity MenuBtn = "374d1cb8-196f-48d6-9a39-852e9e197aab"

	property Entity Menu_TrialBtn = "6998ae8e-44d2-41f0-90e6-519fd169f0f6"

	property Entity Menu_ShopBtn = "8dab0a8c-9d39-42aa-a33f-e7ecf5539c7b"

	property Entity Menu_UpgradeBtn = "c23978a3-ef8c-4f46-9328-906d857dc3d5"

	property Entity Menu_AchievementBtn = "463a81ef-5679-4a9d-8e17-ee6bb6c1807b"

	property Entity Menu_IngreGachaBtn = "c125245f-716a-498f-aa74-5211f6b45670"

	property Entity Menu_EmploymentBtn = "effd43c5-4ab2-41a3-b9dd-e1d567d14a68"

	property Entity Menu_TrainingBtn = "910a41c2-a270-464a-b888-25aea19d78bb"

	property Entity Menu_AutoTrainingBtn = "2037e5b6-a84d-4f74-9d4d-cd9ff3101899"

	property Entity Menu_EmployeeManageBtn = "159887a0-6abe-4d33-bebe-018ef295ee07"

	property Entity Menu_RecipeBtn = "126a8047-9083-43cc-950b-228e37023698"

	property Entity Menu_VIPOrderBtn = "e6546503-d989-4590-8dff-f1f0b18bfe1f"

	property Entity Menu_IngreBunCollectionBtn = "5f5b7952-0e5e-4e67-9b2d-6489078df95c"

	property Entity Menu_ChuchuCollectionBtn = "74207717-c424-4857-9d3b-e29a80c0a948"

	property Entity Menu_RankingBtn = "cd6ac1b9-3672-45e2-92fa-df29dcee6247"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 로직 시작 시 모든 메뉴 버튼의 빨간점 UI들을 찾아서 배열에 저장
		local btnEntities = {self.Menu_TrialBtn, self.Menu_ShopBtn, self.Menu_UpgradeBtn, self.Menu_AchievementBtn, self.Menu_IngreGachaBtn,
							self.Menu_EmploymentBtn, self.Menu_TrainingBtn, self.Menu_AutoTrainingBtn, self.Menu_RecipeBtn, self.Menu_EmployeeManageBtn, self.Menu_VIPOrderBtn,
							self.Menu_IngreBunCollectionBtn, self.Menu_RankingBtn, self.Menu_ChuchuCollectionBtn}
		self._T.redDots = {}
		for i, entity in pairs(btnEntities) do
			table.insert(self._T.redDots, entity:GetChildByName("RedDot"))
		end
		
		self._T.menuRedDot = self.MenuBtn:GetChildByName("Icon"):GetChildByName("RedDot")
	end

	@ExecSpace("Client")
	method void SetMenuBtnRedDot()
		-- 모든 메뉴 버튼의 빨간점 상태를 확인하여 메인 메뉴 버튼의 빨간점 표시 여부를 결정
		for i, redDot in pairs(self._T.redDots) do
			if redDot.Enable then
				self._T.menuRedDot.Enable = true
				return
			end
		end
		
		self._T.menuRedDot.Enable = false
	end

	@ExecSpace("Client")
	method void EnableTrialRedDot(boolean enable)
		-- 시험 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_TrialBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableShopRedDot(boolean enable)
		-- 상점 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_ShopBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableUpgradeRedDot(boolean enable)
		-- 업그레이드 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_UpgradeBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableAchievementRedDot(boolean enable)
		-- 업적 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_AchievementBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableIngreGachaRedDot(boolean enable)
		-- 재료 뽑기 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_IngreGachaBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableEmploymentRedDot(boolean enable)
		-- 고용 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_EmploymentBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableTrainingRedDot(boolean enable)
		-- 훈련 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_TrainingBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableAutoTrainingRedDot(boolean enable)
		-- 자동 훈련 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_AutoTrainingBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableEmployeeManageRedDot(boolean enable)
		-- 직원 관리 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_EmployeeManageBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableRecipeRedDot(Entity player)
		-- 레시피 메뉴 버튼의 빨간점을 플레이어의 업그레이드 슬롯 개수와 설정된 레시피 개수를 비교하여 설정
		local upgradeSlotCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.DisplayCount)
		local setCount = 0
		for i, id in pairs(player.PlayerRecipe.SetRecipes) do
			if id ~= nil or id ~= 0 then
				setCount += 1
			end
		end
		
		local redDot = self.Menu_RecipeBtn:GetChildByName("RedDot")
		if upgradeSlotCount > setCount then
			redDot.Enable = true
		else
			redDot.Enable = false
		end
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableVIPOrderRedDot(boolean enable)
		-- VIP 주문 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_VIPOrderBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableIngreBunCollectionRedDot(boolean enable)
		-- 재료 번 컬렉션 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_IngreBunCollectionBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		_UIEntityLogic_RecipeGroup.UIIngreGachaDim.UIIngreGacha.IngreBunCollectionRedDot.Enable = enable
		
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableChuchuCollectionRedDot(boolean enable)
		-- 츄츄 컬렉션 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_ChuchuCollectionBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		self:SetMenuBtnRedDot()
	end

	@ExecSpace("Client")
	method void EnableRankingRedDot(boolean enable)
		-- 랭킹 메뉴 버튼의 빨간점 표시 상태를 설정하고 메인 메뉴 빨간점을 업데이트
		local redDot = self.Menu_RankingBtn:GetChildByName("RedDot")
		redDot.Enable = enable
		_StoreRankingDataSetLogic.UIStoreRanking.UIStoreRanking.ReexamBtn:GetChildByName("RedDot").Enable = enable
		
		self:SetMenuBtnRedDot()
	end

end