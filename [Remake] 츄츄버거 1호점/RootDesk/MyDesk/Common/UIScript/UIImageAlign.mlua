@Component
script UIImageAlign extends Component

	property SpriteGUIRendererComponent SpriteGUI = nil

	property UITransformComponent Transform = nil

	property string CharId = ""

	property string ImageType = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 스프라이트와 트랜스폼 컴포넌트 참조 설정
		self.SpriteGUI = self.Entity.SpriteGUIRendererComponent
		self.Transform = self.Entity.UITransformComponent
	end

	@ExecSpace("ClientOnly")
	method void SetCharId(string charId)
		-- 캐릭터 ID에 따라 이미지 크기를 설정 (S: 400x400, T: 180x180, N: 400x400)
		if not isvalid(self.Entity.UITransformComponent) then return end
		if not isvalid(self.Transform) then return end
		
		self.CharId = charId  
		
		
		if _UtilLogic:IsNilorEmptyString(self.CharId) then
			self.Transform.RectSize.x = 400
			self.Transform.RectSize.y = 400
			return
		end
		
		
		local initial = string.sub(self.CharId , 1 , 1 )
		
		if initial == "S" then
			self.Transform.RectSize.x = 400
			self.Transform.RectSize.y = 400
			
		elseif initial == "T" then
			self.Transform.RectSize.x = 180
			self.Transform.RectSize.y = 180
			
		elseif initial == "N" then
			self.Transform.RectSize.x = 400
			self.Transform.RectSize.y = 400	
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateCanvas(string uiRUID)
		-- RUID 문자열을 파싱하여 이미지 설정 및 애니메이션 타입에 따라 스케일과 위치 조정
		local properties = {}
		for a in string.gmatch(uiRUID, "[^/]+") do
			table.insert(properties, a)
		end
		
		
		if #properties == 1 then
			self.SpriteGUI.ImageRUID = uiRUID
			self.SpriteGUI.LocalScale = Vector2(1,1)
			self.SpriteGUI.LocalPosition = Vector2(0, 0)
			self.SpriteGUI.PreserveSprite = PreserveSpriteType.None
			return
		end
		
		local ruid = properties[1]
		local imageType = properties[2]
		local ratio = Vector2(tonumber(properties[3]), tonumber(properties[4]))
		local offset = Vector2(tonumber(properties[5]), tonumber(properties[6]))
		
		
		if self.SpriteGUI.ImageRUID == uiRUID then
			return
		end
		
		
		self.SpriteGUI.ImageRUID = ruid
		
		if imageType == "Anim" then
			self.SpriteGUI.LocalScale = Vector2(1,1)
			self.SpriteGUI.LocalPosition = Vector2(offset.x, offset.y)
			self.SpriteGUI.PreserveSprite = PreserveSpriteType.AspectOnly
		else
			self.SpriteGUI.LocalScale = Vector2(ratio.x, ratio.y)
			self.SpriteGUI.LocalPosition = Vector2(0, 0)
			self.SpriteGUI.PreserveSprite = PreserveSpriteType.None
		end
		
	end

end