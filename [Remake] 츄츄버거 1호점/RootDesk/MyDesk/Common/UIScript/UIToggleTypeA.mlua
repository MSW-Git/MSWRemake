@Component
script UIToggleTypeA extends Component

	property Entity Button = nil

	property Entity ImgSelect = nil

	property any OnClickedButton = nil

	property Entity TextDesc = nil

	property integer index = 0

	property any OnSelected = nil

	@ExecSpace("ClientOnly")
	method void SetText(string text)
		-- 토글 버튼의 텍스트를 설정
		if self.TextDesc == nil then
			self.TextDesc = self.Entity:GetChildByName("UITextDesc")
		end
		
		self.TextDesc.TextComponent.Text = text
	end

	@ExecSpace("ClientOnly")
	method void SetSelect(boolean isSelected)
		-- 토글 버튼의 선택 상태에 따라 이미지를 변경
		if self.ImgSelect == nil then
			self.ImgSelect = self.Entity:GetChildByName("UISpriteSelect")
		end
		
		local ruid = isSelected and "c126e98243bf4c7cbfa7bcbb278b0f60" or "6cc87742434e42e3b3a988e83142db83"
		self.ImgSelect.SpriteGUIRendererComponent.ImageRUID = ruid
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI 엘리먼트들을 찾고 버튼 이벤트를 연결
		self.Button = self.Entity
		
		self.ImgSelect = self.Entity:GetChildByName("UISpriteSelect")
		self.TextDesc = self.Entity:GetChildByName("UITextDesc")
		
		self.Button:ConnectEvent(ButtonClickEvent, self.OnClickButton)
	end

	method void OnClickButton(ButtonClickEvent event)
		-- 버튼 클릭 시 인덱스 확인 후 외부 콜백 함수 호출
		if self.index <= 0 then
			return
		end
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self.OnClickedButton ~= nil then
			self.OnClickedButton(event, self.index)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetIndex(integer index)
		-- 토글 버튼의 인덱스 번호를 설정
		self.index = index
	end

	@ExecSpace("ClientOnly")
	method void SetTextColor(Color color)
		-- 토글 버튼의 텍스트 색상을 설정
		self.TextDesc.TextComponent.FontColor = color
	end

	@ExecSpace("ClientOnly")
	method void SetTextOutLine(boolean useOutLine, Color color)
		-- 토글 버튼의 텍스트 외곽선 설정
		self.TextDesc.TextComponent.UseOutLine = useOutLine
		
		if useOutLine then
			self.TextDesc.TextComponent.OutlineColor = color	
		end
	end

end