@Component
script UIItemSlot extends Component

	property SpriteGUIRendererComponentRef IconSprite = nil

	property TextComponentRef CountText = nil

	property boolean isShowCountText = true

	property Entity Desc = nil

	property boolean isShowDesc = false

	@ExecSpace("ClientOnly")
	method void SetItem(string itemID, integer count)
		-- 아이템 ID와 개수를 받아 슬롯의 아이콘과 텍스트를 설정
		local itemData = _ItemDataSetLogic:GetItemData(itemID)
		if itemData == nil then
			return
		end
		
		if self.IconSprite ~= nil then
			self.IconSprite.ImageRUID = itemData.IconRUID
		end
		
		if self.isShowCountText == true then
			if self.CountText ~= nil then
				self.CountText.Text = _StringUtilLogic:ReturnThousandsSeparatedString(count)
			end	
		end
		                                    
		self.Desc.UIImageSizeFit:Apply(_GetLocalizationTextLogic:GetText(itemData.NameKey))
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 아이콘, 개수 텍스트, 설명 엔티티들을 찾고 클릭 이벤트 연결
		local iconSpriteEntity = self.Entity:GetChildByName("Icon")
		if iconSpriteEntity ~= nil then
			self.IconSprite = iconSpriteEntity.SpriteGUIRendererComponent
		end
		
		local countTextEntity = self.Entity:GetChildByName("CountText")
		if countTextEntity ~= nil then
			self.CountText = countTextEntity.TextComponent
		end
		
		self.Desc = self.Entity:GetChildByName("UISpriteDesc")
		
		self.Entity:ConnectEvent(ButtonClickEvent, self.OnClickItem)
	end

	method void OnClickItem()
		-- 아이템 클릭 시 설명을 표시할지 확인하고 설명 UI를 표시
		if self.isShowDesc == false then
			return
		end
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		self.Desc.UIImageSizeFit:Show()
	end

end