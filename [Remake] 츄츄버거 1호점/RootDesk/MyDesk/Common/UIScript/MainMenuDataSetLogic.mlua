@Logic
script MainMenuDataSetLogic extends Logic

	property table MainMenuBtnData = {}

	method void OnBeginPlay()
		-- 로직 시작 시 메인 메뉴 데이터셋을 로드
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- 메인 메뉴 버튼 데이터를 CSV에서 읽어와 테이블에 저장
		table.clear(self.MainMenuBtnData)
		local dataSet = _DataService:GetTable("MainMenuBtnData")
		
		for i = 1, dataSet:GetRowCount() do
			local data = MainMenuBtnData()
			
			data:Load(dataSet, i)
			
			if self.MainMenuBtnData[data.Id] ~= nil then
				break
			end
			
			self.MainMenuBtnData[data.Id] = data
		end
	end

	method MainMenuBtnData GetMenuBtnData(string id)
		-- ID로 메인 메뉴 버튼 데이터를 조회하여 반환
		return self.MainMenuBtnData[id]
	end

	@ExecSpace("ClientOnly")
	method void ClearMenuBtnChild()
		-- 모든 메뉴 버튼의 클릭 유도 UI를 비활성화
		for id, _ in pairs( self.MainMenuBtnData) do
			local menuBtnData = self:GetMenuBtnData(id)
			local entity = _EntityService:GetEntityByPath(menuBtnData.EntityPath)
			if isvalid(entity) == false then
				continue
			end
			
			local child = entity:GetChildByName("Model_ClickHereEntity1")
			if isvalid(child) then
				child.Enable = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method Entity SetClickHereOnMenuBtn(string id)
		-- 특정 메뉴 버튼에 클릭 유도 화살표 UI를 생성하고 설정
		local menuBtnData = self:GetMenuBtnData(id)
		local entity = _EntityService:GetEntityByPath(menuBtnData.EntityPath)
		
		if isvalid(entity) == false then
			return
		end
		
		local clickHere = _UIEntityService:GetOrCreateEntityOfModel("Model_ClickHereEntity", 1, entity)
		local arrow = clickHere:GetChildByName("Arrow")
		if isvalid(arrow) then
			arrow.SpriteGUIRendererComponent.ImageRUID = "3a178133919e4171a09ce815f6a58a6a"
		end
		
		return clickHere
	end

end