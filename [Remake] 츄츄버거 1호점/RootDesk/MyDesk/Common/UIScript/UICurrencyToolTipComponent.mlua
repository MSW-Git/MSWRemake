@Component
script UICurrencyToolTipComponent extends Component

	property Entity ToolTipEntity = nil

	property string ItemId = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 툴팁 엔티티를 찾고 데이터를 설정
		local path = self.Entity.Path
		self.ToolTipEntity = _EntityService:GetEntityByPath(path.."/Tooltip")
		
		local nameTextEntity = self.ToolTipEntity:GetChildByName("Title")
		local descTextEntity = self.ToolTipEntity:GetChildByName("Desc")
		nameTextEntity.TextComponent.Text = "" 
		descTextEntity.TextComponent.Text = ""
		
		self:SetData()
	end

	@ExecSpace("Client")
	method void SetData()
		-- 아이템 ID에 따른 툴팁 데이터를 설정하고 텍스트를 업데이트
		local itemData = _ItemDataSetLogic:GetItemData(self.ItemId)
		
		if not isvalid(itemData) then
			return	
		end
		
		local nameText = _GetLocalizationTextLogic:GetText(itemData.NameKey)
		local descText1 = _GetLocalizationTextLogic:GetText(itemData.DescriptionKey)
		local descText2 = _GetLocalizationTextLogic:GetText("MoneyBarToolTipTextFor"..tostring(self.ItemId))
		
		local nameTextEntity = self.ToolTipEntity:GetChildByName("Title")
		local descTextEntity = self.ToolTipEntity:GetChildByName("Desc")
		
		nameTextEntity.TextComponent.Text = nameText 
		descTextEntity.TextComponent.Text = descText1.."\n".. descText2
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 툴팅 데이터를 확인하고 툴팅을 표시
		
		
		if self.ToolTipEntity:GetChildByName("Title").TextComponent.Text == "" then
			self:SetData()
		end
		
		_TooltipService:ShowHUDMoneyBarToolTip(self.ToolTipEntity)
		
		
	end

end