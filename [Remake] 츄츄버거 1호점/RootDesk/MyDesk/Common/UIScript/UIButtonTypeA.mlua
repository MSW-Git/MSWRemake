@Component
script UIButtonTypeA extends Component

	property Entity Button = nil

	property Entity Disabled = nil

	property any OnClickedButton = nil

	property any OnButtonStateChanged = nil

	@ExecSpace("ClientOnly")
	method void SetText(string text)
		-- 버튼에 표시될 텍스트를 설정
		self.Button.TextComponent.Text = text
	end

	@ExecSpace("ClientOnly")
	method void SetEnable(boolean isEnable)
		-- 버튼의 활성화 상태를 설정하여 Disabled 오버레이 제어
		self.Disabled.Enable = not isEnable
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 버튼 엔티티들을 참조하고 이벤트를 연결
		self.Button = self.Entity:GetChildByName("Button")
		self.Disabled = self.Entity:GetChildByName("Disabled")
		
		self.Button:ConnectEvent(ButtonClickEvent, self.OnClickButton)
		self.Button:ConnectEvent(ButtonStateChangeEvent, self.OnButtonStateChange)
	end

	method void OnClickButton(ButtonClickEvent event)
		-- 버튼 클릭 이벤트 처리 및 외부 콜백 함수 호출
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self.OnClickedButton ~= nil then
			self.OnClickedButton(event)
		end
	end

	method void OnButtonStateChange(ButtonStateChangeEvent event)
		-- 버튼 상태 변경 이벤트 처리 및 외부 콜백 함수 호출
		if self.OnButtonStateChanged ~= nil then
			self.OnButtonStateChanged(event)
		end
	end

end