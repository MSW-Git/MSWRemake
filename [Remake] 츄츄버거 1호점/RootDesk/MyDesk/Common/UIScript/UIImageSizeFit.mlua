@Component
script UIImageSizeFit extends Component

	property integer OriginPaddingBottom = 0

	property integer OriginPaddingTop = 0

	method void Apply(string text)
		-- 텍스트의 높이에 맞촰 이미지 사이즈를 조정하고 텍스트를 설정
		self.Entity:SetEnable(false)
		
		local textHeight = self.Entity.TextComponent:GetPreferredHeight(text, self.Entity.TextComponent.ConstraintX)
		
		self.Entity.TextComponent.Padding.bottom = textHeight + self.OriginPaddingBottom
		self.Entity.TextComponent.Padding.top = textHeight + self.OriginPaddingTop
		
		self.Entity.TextComponent.Text = text
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 원본 패딩 값들을 저장
		self.OriginPaddingBottom = self.Entity.TextComponent.Padding.bottom
		self.OriginPaddingTop = self.Entity.TextComponent.Padding.top
	end

	method void Show()
		-- 이미지를 1초간 표시한 후 자동으로 비활성화
		if self.Entity.Enable then
			return
		end 
		
		self.Entity:SetEnable(true)	
		_TimerService:SetTimerOnce(function() self.Entity:SetEnable(false) end, 1)
	end

end