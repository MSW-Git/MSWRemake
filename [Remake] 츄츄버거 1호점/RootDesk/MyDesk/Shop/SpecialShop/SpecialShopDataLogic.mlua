@Logic
script SpecialShopDataLogic extends Logic

	property Entity UISpecialShop = "786a099c-45ec-434d-a7ab-e64a59b2e925"

	property table SpecialShopData = {}

	property table SpecialShopProductData = {}

	property table SpecialShopProductDataByLinkedShopId = {}

	property table SpecialShopProductModelData = {}

	property string Name = "SpecialShop"

	property string DiamondShopId = "1003"

	property string ItemPackageShopId = "1002"

	property string StarterPackShopId = "1001"

	property string EmployeeEquipShopId = "1004"

	method void OnBeginPlay()
		-- 게임 시작 시 특별 상점 데이터셋을 로드
		self:CommonLog(Environment.WorldId)
		
		if self:IsClient() then
			self:LoadAllDataSet()
		else
		
			self:LoadSpecialShopDataSet()
			self:LoadSpecialShopProductDataSet()
			self:CommonLog('데이테셋 로드 완료')
		end
	end

	method void LoadAllDataSet()
		-- 클라이언트에서 모든 특별 상점 관련 데이터셋을 로드
		self:LoadSpecialShopDataSet()
		self:LoadSpecialShopProductDataSet()
		self:LoadSpecialShopProductModelDataSet()
		self:CommonLog('데이테셋 로드 완료')
	end

	method void LoadSpecialShopDataSet()
		-- 특별 상점 기본 정보 데이터셋을 로드
		table.clear(self.SpecialShopData)
		
		local dataSet = _DataService:GetTable("SpecialShopDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = SpecialShopData()
		
			data:LoadFrom(dataSet:GetRow(i))
			if self.SpecialShopData[data.Id] ~= nil then
				break
			end
			self.SpecialShopData[data.Id] = data
		end
	end

	method void LoadSpecialShopProductDataSet()
		-- 특별 상점 상품 데이터셋을 로드하고 상점별로 분류
		table.clear(self.SpecialShopProductData)
		table.clear(self.SpecialShopProductDataByLinkedShopId)
		
		local dataSet = _DataService:GetTable("SpecialShopProductDataSet")
		
		local ruidList = {}
		for i = 1, dataSet:GetRowCount() do
			local data = SpecialShopProductData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.SpecialShopProductData[data.Id] ~= nil then
				break
			end
			self.SpecialShopProductData[data.Id] = data
			if isvalid(self.SpecialShopProductDataByLinkedShopId[data.LinkedShopId]) then
				table.insert(self.SpecialShopProductDataByLinkedShopId[data.LinkedShopId], data)
			else
				self.SpecialShopProductDataByLinkedShopId[data.LinkedShopId] = {}
				table.insert(self.SpecialShopProductDataByLinkedShopId[data.LinkedShopId], data)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void LoadSpecialShopProductModelDataSet()
		-- 클라이언트에서 특별 상점 상품 UI 모델 데이터셋을 로드
		table.clear(self.SpecialShopProductModelData)
		
		local dataSet = _DataService:GetTable("SpecialShopProductModelDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = SpecialShopProductModelData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.SpecialShopProductModelData[data.UISlotModel] ~= nil then
				break
			end
		
			self.SpecialShopProductModelData[data.UISlotModel] = data
		end
	end

	method boolean HasRemainingStock(string productId, integer purchaseCount)
		-- 상품의 구매 가능 재고가 남아있는지 확인
		local itemCount = self.SpecialShopProductData[productId].ItemCount
		return itemCount == -1 or purchaseCount < itemCount 
	end

	method SpecialShopProductData FilterSpecialProductDataByCondition(any condition)
		-- 조건에 맞는 특별 상점 상품 데이터를 필터링하여 반환
		local result = nil
		for _, data in pairs(self.SpecialShopProductData) do
			if condition(data) then
				if result ~= nil then
					self:CommonLog('다음 상품을 노출하려 했으나, 조건을 만족하는 중복되는 데이터가 존재. 일단 먼저 검출된 상품 출력. 확인 필요')
					return result
				end
				result = data
			end
		end
		
		return result
	end

	method boolean IsCurrenyWorldCoin(string productId)
		-- 상품이 월드 코인으로 구매하는 상품인지 확인
		---@type SpecialShopProductData
		local data = self.SpecialShopProductData[productId]
		return self.SpecialShopData[data.LinkedShopId].UseItemId == "G2000"
	end

	method void AbnormalLog()
		-- 비정상 상황에 대한 로그 기록
	end

	method void CommonLog(string msg)
		-- 일반적인 로그 메시지 기록
	end

end