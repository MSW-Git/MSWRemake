@Struct
script SpecialShopProductData

	property string Id = ""

	property string LinkedShopId = ""

	property string ItemId = ""

	property integer SlotNum = 0

	property integer ProductLevel = 0

	property integer ItemCount = 0

	property integer Price = 0

	property string UISlotModel = ""

	property integer BonusDiamondValue = 0

	property number PackageBenefitValue = 0

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 특별 상점 상품 데이터를 로드하여 속성에 설정
		---@type UserDataRow
		local rowData = userdataRow
		
		self.Id = rowData:GetItem(Environment.WorldId)
		self.LinkedShopId = rowData:GetItem("LinkedShopId")
		self.ItemId = rowData:GetItem("ItemId")
		self.SlotNum = tonumber(rowData:GetItem("SlotNum"))
		self.ProductLevel = tonumber(rowData:GetItem("ProductLevel"))
		self.ItemCount = tonumber(rowData:GetItem("ItemCount"))
		self.Price = tonumber(rowData:GetItem("Price"))
		self.UISlotModel = rowData:GetItem("UISlotModel")
		self.BonusDiamondValue = tonumber(rowData:GetItem("BonusDiamondValue"))
		self.PackageBenefitValue = tonumber(rowData:GetItem("PackageBenefitValue"))
		
	end

end