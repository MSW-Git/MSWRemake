@Component
script UIEmployeeEquipShop extends Component

	property UIChuchuCollection UIChuchuCollection = "adbfcb28-8545-4c7d-b2a1-3a49d38fac77"

	property UISpecialShop UISpeicalShop = "786a099c-45ec-434d-a7ab-e64a59b2e925"

	property string EmployeeEquipShopId = "1004"

	property Entity UpgradeEffect_Success = "c7f81b2b-ac78-4796-afb2-578020f20d2f"

	property Entity UpgradeEffect_Fail = "fa8820f8-e9b6-4285-af1a-f79376376215"

	property Entity UpgradeEffect_Ing = "36a949f7-3cef-403d-b90a-5ce9b5218d72"

	property boolean blockClickUpgrade = false

	property number EffectTime_Ing = 1

	property number EffectTime_Succ = 0.6

	property number EffectTime_Fail = 0.6

	@ExecSpace("ClientOnly")
	method void OnPurchaseEquipCompleted(string employeeId)
		-- 직원 장비 구매 완료 시 처리
		self.UIChuchuCollection:CloseBuyEquipPopup()
		
		
		
		self.UIChuchuCollection:OnPurchaseEquipCompleted()
	end

	@ExecSpace("ClientOnly")
	method boolean OnClickBuyEqiup()
		-- 직원 장비 구매 버튼 클릭 이벤트 처리
		local employeeId = self.UIChuchuCollection.SelectedChuchuId
		_PaidLogic:RequestPurchaseEmployeeEquip(employeeId, _UserService.LocalPlayer.PlayerComponent.UserId)
		return false
	end

	@ExecSpace("ClientOnly")
	method void OnClickGotoShop(string itemId)
		-- 샵으로 이동하여 아이템 구매 팝업 열기
		self.UISpeicalShop:Open(self.EmployeeEquipShopId)
		self.UISpeicalShop:OpenPurchasePopup(itemId)
	end

	@ExecSpace("ClientOnly")
	method void OpenGotoShopPopup(string itemId, boolean isPopupAlreadyOpen)
		-- 샵 이동 확인 팝업 열기
		local text = _LocalizationService:GetText("GotoShopPopupMsg")
		local itemName = _LocalizationService:GetText(_ItemDataSetLogic:GetItemData(itemId).NameKey)
		text = _LocalizationService:SmartFormat(text, itemName)
		local title = _LocalizationService:GetText("GotoShopPopupTitle")
		
		if isPopupAlreadyOpen then
			_UIPopup:ResetPopup(text, function() self:OnClickGotoShop(itemId) end, nil, title)
		else
			_UIPopup:Open(text, function() self:OnClickGotoShop(itemId) end, nil, title)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickUpgradeEquip(string currencyId)
		-- 직원 장비 업그레이드 버튼 클릭 이벤트 처리
		
		local player = _UserService.LocalPlayer
		local itemOwnCount = player.PlayerInventory:GetItemCount(currencyId)
		local employeeId = self.UIChuchuCollection.SelectedChuchuId
		
		---@type EmployeeOutgameDetailData
		local myData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeOutgameDetail(employeeId)
		local nextEquipLevel = myData.EquipLevel + 1
		
		if nextEquipLevel > _EmployeeEquipUpgradeDataLogic.MaxUpgradeLevel then
			return
		end
		
		local upgradeCost = _EmployeeEquipUpgradeDataLogic:GetEmployeeEquipUpgrageData(nextEquipLevel).UpgradeCost
		if itemOwnCount < upgradeCost then
			self:OpenGotoShopPopup(currencyId, false)
			return
		end
		
		self.blockClickUpgrade = true
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_EquipUpgrade"], 1)
		self.UpgradeEffect_Ing.SpriteGUIRendererComponent.ImageRUID = ""
		self.UpgradeEffect_Ing.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.EquipUpgradeEffect_Ing
		self.UpgradeEffect_Ing.Enable = true
		_TimerService:SetTimerOnce(function()
			_PaidLogic:RequestUpgradeEmployeeEquip(employeeId, _UserService.LocalPlayer.PlayerComponent.UserId, currencyId)
		end,  self.EffectTime_Ing)
		
	end

	@ExecSpace("ClientOnly")
	method void OnUpgradeEquipCompleted(boolean res, string itemId, integer count, integer equipLevel)
		-- 직원 장비 업그레이드 완료 시 처리 및 이팩트 표시
			self.UpgradeEffect_Ing.Enable = false
			
			_TimerService:SetTimerOnce(function() 
				self.blockClickUpgrade = false
				self.UIChuchuCollection:OnUpgradeEquipCompleted(itemId, count, equipLevel, res)
			end, self.EffectTime_Succ)
			
			if res then
				_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_EquipUpgradeSuccess"], 1)
				self.UpgradeEffect_Success.SpriteGUIRendererComponent.ImageRUID = ""
				self.UpgradeEffect_Success.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.EquipUpgradeEffect_Success
				self.UpgradeEffect_Success.Enable = true
				
				_TimerService:SetTimerOnce(function() 
					self.UpgradeEffect_Success.Enable = false
				end, self.EffectTime_Succ)
			else
				_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_EquipUpgradeFail"], 1)
				self.UpgradeEffect_Fail.SpriteGUIRendererComponent.ImageRUID = ""
				self.UpgradeEffect_Fail.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.EquipUpgradeEffect_Fail
				self.UpgradeEffect_Fail.Enable = true
				
				_TimerService:SetTimerOnce(function() 
					self.UpgradeEffect_Fail.Enable = false
				end, self.EffectTime_Fail)
			end
			
		
		
	end

	@EventSender("Entity", "4dda3933-8741-433c-8ebe-866741a93259")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 직원 장비 구매 버튼 클릭 이벤트 처리
		
		
		local player = _UserService.LocalPlayer
		local itemOwnCount = player.PlayerInventory:GetItemCount(_ItemDataEnum.EmployeeEquipOpenItemId)
		if itemOwnCount < 1 then
			self:OpenGotoShopPopup(_ItemDataEnum.EmployeeEquipOpenItemId, false)
			return
		end
		
		
		local employeeId = self.UIChuchuCollection.SelectedChuchuId
		local text = _LocalizationService:GetText("BuyEquipPopupMsg")
		local equipName = _LocalizationService:GetText(_EmployeeService:GetData(employeeId).EquipNameKey)
		text = _LocalizationService:SmartFormat(text, equipName)
		local title = _LocalizationService:GetText("BuyEquipPopupTitle")
		_UIPopup:Open(text, function() return self:OnClickBuyEqiup() end, nil, title)
		
		
	end

	@EventSender("Entity", "192d5c55-52b8-4d39-a523-ad19f67a9a7a")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 직원 장비 업그레이드 버튼 클릭 이벤트 처리
		
		
		
		local employeeType = _EmployeeService:GetData(self.UIChuchuCollection.SelectedChuchuId).Type
		local itemId
		if employeeType == _EmployeeTypeEnum.Cook then
			itemId =_ItemDataEnum.CookEmployeeEquipUpgradeItemId
		else
			itemId =_ItemDataEnum.ServingEmployeeEquipUpgradeItemId
		end
		
		if self.blockClickUpgrade == false then
			self:OnClickUpgradeEquip(itemId)
		end
	end

end