@Struct
script ShopProductData

	property string ProductId = ""

	property string LinkedShopId = ""

	property string PutoutType = ""

	property number PutoutValue = 0

	property integer SortingOrder = 0

	property integer Price = 0

	property string ItemId = ""

	property integer ItemCount = 0

	property integer MaxQuantity = 0

	property string PurchaseCondition = ""

	property integer PurchaseConditionValue = 0

	property string UnlockCondition = ""

	property integer UnlockConditionValue = 0

	property number SaleRate = 0

	method void LoadFrom(any dataTable, integer index)
		-- 데이터셋에서 상점 상품 정보를 로드
		---@type MODUserDataSet
		local table = dataTable
		local rowData = table:GetRow(index)
		
		self.ProductId = rowData:GetItem("ProductId")
		self.LinkedShopId = rowData:GetItem("LinkedShopId")
		self.PutoutType = rowData:GetItem("PutoutType")
		self.PutoutValue = tonumber(rowData:GetItem("PutoutValue"))
		self.SortingOrder = tonumber(rowData:GetItem("SortingOrder"))
		self.Price = tonumber(rowData:GetItem("Price"))
		self.ItemId = rowData:GetItem("ItemId")
		self.ItemCount = tonumber(rowData:GetItem("ItemCount"))
		self.MaxQuantity = tonumber(rowData:GetItem("MaxQuantity"))
		self.PurchaseCondition = rowData:GetItem("PurchaseCondition")
		self.PurchaseConditionValue = tonumber(rowData:GetItem("PurchaseConditionValue"))
		self.UnlockCondition = rowData:GetItem("UnlockCondition")
		self.UnlockConditionValue = tonumber(rowData:GetItem("UnlockConditionValue"))
		self.SaleRate = tonumber(rowData:GetItem("SaleRate"))
	end

end