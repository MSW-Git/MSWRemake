@Logic
script PiggyBankDataLogic extends Logic

	property table PiggyBankLevelData = {}

	property table PiggyBankLevelUpRewardData = {}

	property string LevelTextDefault = "Lv. "

	property number MaxLevelDefault = 10

	property string AddPointPerEarningRateKey = "PiggyBankAddPointPerEarningRate"

	property SyncTable<string, integer> PiggyBankLevelDataIdByProductId

	property UIPiggyBank UIPiggyBank = "1a0e70eb-8469-4445-879d-fa2a9950d355"

	property string DiamondItemIdDefault = "G1001"

	property string SpecialRewardIdType = "K"

	property integer MaxPointTextOffset = -30

	method void OnBeginPlay()
		-- 저금통 데이터 로직 초기화 시 레벨 데이터와 보상 데이터를 로드
		self:LoadPiggyBankLevelDataSet()
		self:LoadPiggyBankLevelUpRewardDataSet()
	end

	method void LoadPiggyBankLevelDataSet()
		-- CSV 파일에서 저금통 레벨별 데이터를 로드하여 테이블에 저장
		table.clear(self.PiggyBankLevelData)
		
		local dataSet = _DataService:GetTable("PiggyBankLevelDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = PiggyBankLevelData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.PiggyBankLevelData[data.Level] ~= nil then
		
				break
			end
			table.insert(self.PiggyBankLevelData, data)
			self.PiggyBankLevelDataIdByProductId[data.ProductId] = data.Level
		end
	end

	method void LoadPiggyBankLevelUpRewardDataSet()
		-- CSV 파일에서 저금통 레벨업 보상 데이터를 로드하여 테이블에 저장
		table.clear(self.PiggyBankLevelUpRewardData)
		
		local dataSet = _DataService:GetTable("PiggyBankLevelUpRewardDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = PiggyBankLevelUpRewardData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.PiggyBankLevelUpRewardData[data.RewardSlotIndex] ~= nil then
				break
			end
			table.insert(self.PiggyBankLevelUpRewardData, data)
		end
	end

	method PiggyBankLevelData GetPiggyBankLevelData(integer level)
		-- 레벨에 해당하는 저금통 레벨 데이터를 반환
		return self.PiggyBankLevelData[level]
	end

	method PiggyBankLevelData GetPiggyBankLevelDataByProductId(string productId)
		-- 상품 ID에 해당하는 저금통 레벨 데이터를 반환
		return self.PiggyBankLevelData[self.PiggyBankLevelDataIdByProductId[productId]]
	end

	method PiggyBankLevelUpRewardData GetPiggyBankRewardData(integer slotId)
		-- 슬롯 ID에 해당하는 저금통 보상 데이터를 반환
		return self.PiggyBankLevelUpRewardData[slotId]
	end

end