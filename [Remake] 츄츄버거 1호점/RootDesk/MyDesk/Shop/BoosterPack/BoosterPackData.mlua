@Struct
script BoosterPackData

	property integer StageId = 0

	property table BoosterPackItemIdPricePair = {}

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 부스터 팩 데이터를 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.StageId = tonumber(rowData:GetItem("StageId"))
		table.insert(self.BoosterPackItemIdPricePair, {rowData:GetItem("BoosterPack1ItemId"), math.tointeger(tonumber(rowData:GetItem("BoosterPack1Price")))})
		table.insert(self.BoosterPackItemIdPricePair, {rowData:GetItem("BoosterPack2ItemId"), math.tointeger(tonumber(rowData:GetItem("BoosterPack2Price")))})
	end

end