@Component
script UIStagePassLevel extends Component

	property string Id = ""

	property string GroupId = ""

	property SpriteGUIRendererComponent PassLevelIcon = nil

	property TextComponent PassLevelNameText = nil

	property Entity EnableEffect = nil

	property Entity ClearEffect = nil

	property Vector2 PassLevelIconClear_LocaleScale = Vector2(0.7, 0.7)

	property Vector2 PassLevelIconNormal_LocaleScale = Vector2(1, 1)

	property table PassRewardItemEntities = {}

	property UITransformComponent GaugeFillUITransform = nil

	property integer RecycleScrollView_Padding_x = 0

	property integer Gauge_Achieve_Over = 60

	property integer Gauge_Next_Achieve_Over = 30

	property SpriteGUIRendererComponent LineRenderer1 = nil

	property SpriteGUIRendererComponent LineRenderer2 = nil

	property table LinRendererColorCodes = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 컴포넌트들을 초기화하는 함수
		self.PassLevelIcon = self.Entity:GetChildByName("PassLevelIcon").SpriteGUIRendererComponent
		self.PassLevelNameText = self.Entity:GetChildByName("PassLevelNameTag"):GetChildByName("PassLevelNameText").TextComponent
		self.GaugeFillUITransform = self.Entity:GetChildByName("GaugeFillSprite").UITransformComponent
		self.RecycleScrollView_Padding_x = self.Entity.Parent.RecycleScrollView.Padding.x
		
		local passLevelColumn = self.Entity:GetChildByName("PassLevelColumn")
		
		for i=0, _StagePassDataLogic.StagePassProductCount - 1 do
			local groupId = tostring(i)
			table.insert(self.PassRewardItemEntities, passLevelColumn:GetChildByName("RewardItemSlot"..groupId):GetChildByName("PassRewardRenderer"))
		end
		
		self.LineRenderer1 = passLevelColumn:GetChildByName("Line_Blue").SpriteGUIRendererComponent
		self.LineRenderer2 = passLevelColumn:GetChildByName("Line_Orange").SpriteGUIRendererComponent
		self.LinRendererColorCodes = {"#9a9ed1","#f9ba11","#ff8c8c","#a387ff"}
		
		self.PassLevelIcon.Entity:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
			_SoundService:PlaySound(_ResourceManager.SFXTable["System_Gemstone_Button_01"], 1)
			---@type StagePassLevelData
			local levelData = _StagePassDataLogic.StagePassLevelData[self.Id]
			local passDescText = _LocalizationService:GetText(levelData.PassLevelDesc)
			_TooltipService:OpenTooltipWithPadding(_StagePassDataLogic.UIStagePassEntity.UIStagePass.ItemDescTooltip, passDescText, nil, self.PassLevelIcon.Entity.UITransformComponent.WorldPosition)
		end)
	end

	@ExecSpace("ClientOnly")
	method void Init(StagePassLevelData levelData, string groupId)
		-- 스테이지 패스 레벨 데이터로 UI를 초기화하는 함수
		self.Id = levelData.Id
		self.GroupId = groupId
		
		if levelData.StageProgress < 6 then
			self.PassLevelIcon.ImageRUID = _ManagementDataSetLogic:GetManagementLevelData(levelData.StageProgress).IconRUID
			self.PassLevelIcon.LocalScale = self.PassLevelIconNormal_LocaleScale
		else
		
			self.PassLevelIcon.ImageRUID = _StageDataSetLogic:GetStageData(levelData.StageId).StageClearIconRUID
			self.PassLevelIcon.LocalScale = self.PassLevelIconClear_LocaleScale
		end
		
		self.PassLevelNameText.Text = string.format("%d - %d", levelData.StageId, levelData.StageProgress + 1)
		
		local player = _UserService.LocalPlayer
		
		local isAchieve = player.PlayerStage:IsAchieveStageProgress(levelData.StageId, levelData.StageProgress)
		self:SetUILevelByProgress(isAchieve)
		
		local slotId = string.sub(levelData.Id, 2, 3)
		local HasRemainReward = player.PlayerOutgameManager:HasRemainStagePassRewardBySlotId(groupId, slotId, player.PlayerComponent.UserId)
		self:SetUIRewards(slotId, isAchieve)
		
		if groupId == "1" then
			self.LineRenderer1.Color = _ColorCodeEnum:GetColor(self.LinRendererColorCodes[1])
			self.LineRenderer2.Color = _ColorCodeEnum:GetColor(self.LinRendererColorCodes[2])
		else
			self.LineRenderer1.Color = _ColorCodeEnum:GetColor(self.LinRendererColorCodes[3])
			self.LineRenderer2.Color = _ColorCodeEnum:GetColor(self.LinRendererColorCodes[4])
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetUILevelByRewardStatus(boolean isAchieve, boolean HasRemainReward)
		-- 보상 상태에 따라 레벨 UI를 설정하는 함수
		
		if isAchieve then
			if HasRemainReward then
			else
			end
		else
		end
	end

	@ExecSpace("ClientOnly")
	method void SetUIRewards(string slotId, boolean isAchieve)
		-- 보상 UI를 설정하는 함수
		for i, e in pairs(self.PassRewardItemEntities) do
			---@type Entity
			local entity = e
			entity.UIRewardItem.UIStagePassLevel = self
			entity.UIRewardItem:Init(self.GroupId, i-1, slotId, isAchieve)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetUILevelByProgress(boolean isAchieve)
		-- 진행도에 따라 레벨 UI를 설정하는 함수
		
		---@type StagePassLevelData
		local levelData = _StagePassDataLogic.StagePassLevelData[self.Id]
		
		local isFirst = tonumber(string.sub(self.Id, 2, 3)) == 1
		
		local a = self.RecycleScrollView_Padding_x
		local b = self.Entity.UITransformComponent.RectSize.x
		local c = self.Gauge_Achieve_Over
		local d = self.Gauge_Next_Achieve_Over
		
		local player = _UserService.LocalPlayer
		
		local beforeAchieveRectSizeX = 0.5 * b + d
		self.GaugeFillUITransform.anchoredPosition.x = -beforeAchieveRectSizeX
		
		if isAchieve == false then
			if isFirst then
				self.GaugeFillUITransform.RectSize.x = beforeAchieveRectSizeX
			else
				self.GaugeFillUITransform.RectSize.x = 0
			end
		else
			local nextLevel = player.PlayerStage:GetNextStageProgress(levelData.StageId, levelData.StageProgress)
			local isAchieveNextLevel = player.PlayerStage:IsAchieveStageProgress(nextLevel[1], nextLevel[2])
			
			if isAchieveNextLevel then
				self.GaugeFillUITransform.RectSize.x = beforeAchieveRectSizeX + 0.5 * b + d
			else
				self.GaugeFillUITransform.RectSize.x = beforeAchieveRectSizeX + c
			end
		end
	end

end