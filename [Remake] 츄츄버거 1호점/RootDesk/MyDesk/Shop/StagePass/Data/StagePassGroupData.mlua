@Struct
script StagePassGroupData

	property string GroupId = ""

	property string GroupNameKey = ""

	property string GroupDesc = ""

	property string GroupIconRUID = ""

	property integer PassLevelCount = 0

	property string Pass0ProductId = ""

	property string Pass1ProductId = ""

	property string Pass2ProductId = ""

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 스테이지 패스 그룹 데이터를 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.GroupId = rowData:GetItem("GroupId")
		self.GroupNameKey = rowData:GetItem("GroupNameKey")
		self.GroupDesc = rowData:GetItem("GroupDesc")
		self.GroupIconRUID = rowData:GetItem("GroupIconRUID")
		self.PassLevelCount = tonumber(rowData:GetItem("PassLevelCount"))
		self.Pass0ProductId = rowData:GetItem("Pass0ProductId")
		self.Pass1ProductId = rowData:GetItem("Pass1ProductId")
		self.Pass2ProductId = rowData:GetItem("Pass2ProductId")
	end

end