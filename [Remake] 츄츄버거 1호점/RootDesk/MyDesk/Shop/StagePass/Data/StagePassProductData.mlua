@Struct
script StagePassProductData

	property string Id = ""

	property string ProductId = ""

	property string PassNameKey = ""

	property string PassIconRUID = ""

	property integer Price = 0

	property string PurchaseRewardItemId = ""

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 스테이지 패스 상품 데이터를 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.Id = rowData:GetItem("ProductId")
		self.ProductId = rowData:GetItem(Environment.WorldId)
		self.PassNameKey = rowData:GetItem("PassNameKey")
		self.PassIconRUID = rowData:GetItem("PassIconRUID")
		self.Price = tonumber(rowData:GetItem("Price"))
		self.PurchaseRewardItemId = rowData:GetItem("PurchaseRewardItemId")
	end

end