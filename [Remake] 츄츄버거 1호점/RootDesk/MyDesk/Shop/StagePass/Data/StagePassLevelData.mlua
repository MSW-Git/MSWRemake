@Struct
script StagePassLevelData

	property string Id = ""

	property string PassLevelDesc = ""

	property integer StageId = 0

	property integer StageProgress = 0

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 스테이지 패스 레벨 데이터를 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.Id = rowData:GetItem("PassLevelId")
		self.PassLevelDesc = rowData:GetItem("PassLevelDesc")
		self.StageId = tonumber(rowData:GetItem("StageId"))
		self.StageProgress = tonumber(rowData:GetItem("StageProgress"))
	end

end