@Component
script UIStagePassProduct extends Component

	property string ProductId = ""

	property string Id = ""

	property Entity PurchaseReward = nil

	property Entity RewardInfo = nil

	property Entity PassRewardInfoDim = "2029d66e-6c9f-4480-b0e1-a763cd9c08cb"

	property TextComponent NameText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 컴포넌트들을 초기화하는 함수
		self.NameText = self.Entity:GetChildByName("Title").TextComponent
		self.PurchaseReward = self.Entity:GetChildByName("PurchaseRewardBg")
		self.RewardInfo = self.Entity:GetChildByName("RewardInfo")
		
		self.RewardInfo:ConnectEvent(ButtonClickEvent, self.OnRewardInfoButtonClick)
	end

	@ExecSpace("ClientOnly")
	method void Init(StagePassProductData productData)
		-- 스테이지 패스 상품 데이터로 UI를 초기화하는 함수
		self.ProductId = productData.ProductId
		self.Id = productData.Id
		
		self.NameText.Text = _LocalizationService:GetText(productData.PassNameKey)
		self.PurchaseReward.UIStagePassPurchaseReward:Init(self.Id)
		
		if self.PassRewardInfoDim.Enable == true then
			self.PassRewardInfoDim.Extend_UIRewardInfoStagePass:Init(self)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnRewardInfoButtonClick()
		-- 보상 정보 버튼 클릭 시 처리하는 함수
		self.PassRewardInfoDim.Enable = true
		self.PassRewardInfoDim.Extend_UIRewardInfoStagePass:Init(self)
	end

	@ExecSpace("ClientOnly")
	method void OnClickPurchaseButton()
		-- 구매 버튼 클릭 시 처리하는 함수
		if _UtilLogic:IsNilorEmptyString(self.ProductId) then
		    _SpecialShopDataLogic:AbnormalLog()
		    return
		end
		
		---@type StagePassProductData
		local productData = _StagePassDataLogic.StagePassProductData[self.Id]
		
		_UIPurchasePopupLogic:OpenPurchaseConfirmPopup_Immediately(productData.PassNameKey, function() self:OnOkCallback() end)
	end

	@ExecSpace("ClientOnly")
	method void OnOkCallback()
		-- 구매 확인 콜백 함수
		_PaidLogic:RequestPurchaseWorldShopProduct_StagePass(self.ProductId, _UserService.LocalPlayer.PlayerComponent.UserId)
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickPurchaseButton()
	end

end