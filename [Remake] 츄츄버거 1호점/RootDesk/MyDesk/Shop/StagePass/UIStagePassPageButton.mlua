@Component
script UIStagePassPageButton extends Component

	property string RewardSlotId = ""

	property boolean IsLeft = false

	property SpriteGUIRendererComponent ItemIcon = nil

	property TextComponent StageLevelText = nil

	property string StageDefaultText = "StageInfoTabStage"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 컴포넌트를 초기화하는 함수
		self.ItemIcon = self.Entity:GetChildByName("ItemIcon").SpriteGUIRendererComponent
		self.StageLevelText = self.ItemIcon.Entity:GetChildByName("StageLevelText").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Init(string rewardSlotId)
		-- 보상 슬롯 ID로 페이지 버튼을 초기화하는 함수
		self.RewardSlotId = rewardSlotId
		local levelId = string.sub(self.RewardSlotId, 1, 1)..string.sub(self.RewardSlotId, 3, 4)
		
		---@type StagePassLevelData
		local levelData = _StagePassDataLogic.StagePassLevelData[levelId]
		
		---@type StagePassRewardData
		local rewardData = _StagePassDataLogic.StagePassRewardData[self.RewardSlotId]
		
		self.ItemIcon.ImageRUID = _ItemDataSetLogic:GetItemData(rewardData.RewardItemId).IconRUID
		local stageText = _LocalizationService:GetText(self.StageDefaultText)
		self.StageLevelText.Text = stageText.." "..tostring(levelData.StageId)
		
		self.Entity.Enable = true
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_StagePassDataLogic.UIStagePassEntity.UIStagePass:SetScrollToRewardSlotId(self.RewardSlotId)
		
	end

end