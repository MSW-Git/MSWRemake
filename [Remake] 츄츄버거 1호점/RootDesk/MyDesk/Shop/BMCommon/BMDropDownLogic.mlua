@Logic
script BMDropDownLogic extends Logic

	property UISpecialShopRef UISpecialShopGroup = "786a099c-45ec-434d-a7ab-e64a59b2e925"

	property UIStagePass UIStagePass = "f96cb0f0-b032-46a5-b189-a42ab5963b45"

	property UIPiggyBank UIPiggyBank = "1a0e70eb-8469-4445-879d-fa2a9950d355"

	property UIBoosterPack UIBoosterPack = "c4282791-0bc4-4c19-8a67-16b83b0831b0"

	@EventSender("Entity", "79b07c81-eee4-4834-a803-256c6e1fe78c")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 스페셜 샵 열기 버튼 클릭 이벤트 처리
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["System_BlackMarket_Ready_01"], 1)
		
		
		self.UISpecialShopGroup:Open(nil)
	end

	@EventSender("Entity", "d09a64d2-b9eb-4f09-91e9-b97089b74d1f")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 스테이지 패스 열기 버튼 클릭 이벤트 처리
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self.UIStagePass:Open(nil)
	end

	@EventSender("Entity", "4527051f-7d0f-4ca7-8819-086a1a5d3641")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 부스터 팩 열기 버튼 클릭 이벤트 처리
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		self.UIBoosterPack:Open()
	end

end