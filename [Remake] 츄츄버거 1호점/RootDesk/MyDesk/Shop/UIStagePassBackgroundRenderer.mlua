	@ExecSpace("ClientOnly")
	method void ResetResourcesBackgroundByGroupId(string groupId)
		-- 그룹 ID에 따라 스테이지 패스 배경 리소스를 설정
		
		local data = self.ResourcesData[tonumber(groupId)]
		
