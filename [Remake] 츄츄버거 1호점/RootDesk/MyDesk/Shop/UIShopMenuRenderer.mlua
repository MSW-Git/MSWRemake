@Component
script UIShopMenuRenderer extends Component

	property string ShopId = ""

	property SpriteGUIRendererComponentRef BallonSprite = nil

	property SpriteGUIRendererComponentRef IconSprite = nil

	property EntityRef ShopMain = nil

	property TextComponent TitleText = nil

	property string FontColor = "#FFFFFF"

	property string OutlineColor = "#985F05"

	property string DisableFontColor = "#BB9A59"

	property string EnableRuid = "c126e98243bf4c7cbfa7bcbb278b0f60"

	property string DisableRuid = "6cc87742434e42e3b3a988e83142db83"

	method void Init(string shopID)
		-- 상점 ID로 메뉴 렌더러 초기화
		local shopData = _ShopDataLogic:GetShopData(shopID)
		self:InitUI(shopID, shopData.CategoryNameKey, shopData.ShopIconRUID)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 자식 엔티티 참조 설정
		local categoryEntity = self.Entity:GetChildByName("CategoryImage")
		if categoryEntity == nil then
			return
		end
		
		self.BallonSprite = categoryEntity.SpriteGUIRendererComponent
		self.IconSprite = categoryEntity:GetChildByName("IconImage").SpriteGUIRendererComponent
		self.ShopMain = self.Entity.Parent.Parent.Parent
		self.TitleText = self.Entity:GetChildByName("UIText").TextComponent
	end

	method void OnUpdateBallonSprite(boolean isSelected)
		-- 선택 상태에 따라 메뉴 배경 스프라이트 업데이트
		if isSelected == true then
			self.BallonSprite.ImageRUID = self.EnableRuid
		else
			self.BallonSprite.ImageRUID = self.DisableRuid
		end
	end

	method void OnUpdateTextColor(boolean isSelected)
		-- 선택 상태에 따라 메뉴 텍스트 색상 업데이트
		if isSelected == true then
			self.TitleText.FontColor = _ColorCodeEnum:GetColor(self.FontColor)
			self.TitleText.OutlineColor = _ColorCodeEnum:GetColor(self.OutlineColor)
			self.TitleText.UseOutLine = true
		else
			self.TitleText.FontColor = _ColorCodeEnum:GetColor(self.DisableFontColor)
			self.TitleText.UseOutLine = false
		end
	end

	method void OnUpdateIconSprite(boolean isSelected)
		-- 선택 상태에 따라 메뉴 아이콘 투명도 업데이트
		self.IconSprite.Color.a = isSelected and 1 or 0.5
	end

	method void InitUI(string Id, string name, string ruid)
		-- 상점 메뉴 UI 요소들을 초기화
		self.ShopId = Id
		self.TitleText.Text = _GetLocalizationTextLogic:GetText(name)
		self.IconSprite.ImageRUID = ruid
	end

	@ExecSpace("ClientOnly")
	method void SetColorAndRuidForSpecialShop()
		-- 특별 상점용 색상과 리소스 ID 설정
		self.EnableRuid = "a9a2941dd18d4e3fbae3acfab8cc0de7"
		self.DisableRuid = "7306205dce0a405b9c13424d1814b456"
		self.FontColor = "#ffffff"
		self.OutlineColor = "#6246a9"
		self.DisableFontColor = "#8376c6"
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 메뉴 버튼 클릭 시 상점 선택 이벤트 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		if self.ShopMain.UIShop ~= nil then
			self.ShopMain.UIShop:OnShopSelected(self.ShopId, self.Entity)
		else 
			self.ShopMain.UISpecialShop:OnShopSelected(self.Entity, self.ShopId)
		end
	end

end