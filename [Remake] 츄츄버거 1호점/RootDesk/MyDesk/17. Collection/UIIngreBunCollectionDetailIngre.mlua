@Component
script UIIngreBunCollectionDetailIngre extends Component

	property Entity RecipePreview = nil

	property SpriteGUIRendererComponent IngreGrade = nil

	property SpriteGUIRendererComponent IngreIcon = nil

	property TextComponent TasteScoreText = nil

	property TextComponent CostText = nil

	property SpriteGUIRendererComponent TypeIcon = nil

	property TextComponent TypeText = nil

	property TextComponent SpicyPointText = nil

	property SpriteGUIRendererComponent BalanceIcon = nil

	property TextComponent BalanceText = nil

	property SpriteGUIRendererComponent StageIcon = nil

	property TextComponent StageText = nil

	property TextComponent NameText = nil

	method void Init()
		-- 재료 상세 정보 UI 컴포넌트들을 초기화하는 함수
		self.NameText = self.Entity:GetChildByName("Name").TextComponent
		
		self.RecipePreview = self.Entity:GetChildByName("RecipePreview"):GetChildByName("Img")
		local ingreSlot = self.Entity:GetChildByName("IngreSlot")
		self.IngreGrade = ingreSlot:GetChildByName("Grade").SpriteGUIRendererComponent
		self.IngreIcon = ingreSlot:GetChildByName("Icon").SpriteGUIRendererComponent
		
		local list = self.Entity:GetChildByName("List")
		local tasteScore = list:GetChildByName("TasteScore")
		tasteScore:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("TasteScore")
		self.TasteScoreText = tasteScore:GetChildByName("Value").TextComponent
		
		local cost = list:GetChildByName("Cost")
		cost:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("Price")
		cost:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData("G0001").IconRUID
		self.CostText = cost:GetChildByName("Value").TextComponent
		
		local type = list:GetChildByName("Type")
		type:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("IngreBunCollectionFilterTitleTag")
		self.TypeText = type:GetChildByName("Value").TextComponent
		self.TypeIcon = self.TypeText.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		
		local spicyPoint = list:GetChildByName("SpicyPoint")
		self.SpicyPointText = spicyPoint:GetChildByName("Value").TextComponent
		spicyPoint:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("SpicyPoint")
		
		local balancePoint = list:GetChildByName("BalancePoint")
		self.BalanceText = balancePoint:GetChildByName("Value").TextComponent
		self.BalanceIcon = self.BalanceText.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		balancePoint:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("Balance")
		
		local stage = list:GetChildByName("Stage")
		self.StageText = stage:GetChildByName("Value").TextComponent
		self.StageIcon = self.StageText.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		stage:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("Stage")
		
	end

	method void Refresh(integer ingreId)
		-- 지정된 재료 ID의 상세 정보를 화면에 표시하는 함수
		if self.RecipePreview == nil then
			self:Init()
		end
		
		local ingreData = _IngredientDataSetLogic:GetIngredientData(ingreId)
		if isvalid(ingreData) == false then
			return
		end
		
		for i, child in pairs(self.RecipePreview.Children) do
			child.Enable = false
		end
		
		local rectSizeX = self.RecipePreview.UITransformComponent.RectSize.x
		local ingreDraw = RecipeIngreDrawData()
		ingreDraw:Init(ingreId, _RecipeIngreDrawEnum.Ingredient, nil, false, nil)
		local data = _DrawBurgerUIService:ReturnIngreData(ingreDraw, rectSizeX, {0, "", 0, 0, 0, 0, 0, 0})
		local drawData = _DrawBurgerUIService:DrawIngredientUI(data, 1, 1, self.RecipePreview)
		
		self.IngreGrade.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(ingreData.Grade)
		self.IngreIcon.ImageRUID = ingreData.IconRUID
		self.NameText.Text = _GetLocalizationTextLogic:GetText(ingreData.NameKey)
		
		local player = _UserService.LocalPlayer
		local collected = player.PlayerCollection.IngredientCollection[ingreId]
		if collected == nil then collected = false end
		
		local materialId = collected and _IconRuidEnum.EmptyMaterial or _IconRuidEnum.GrayScaleMaterial
		self.IngreIcon:ChangeMaterial(materialId)
		---@type Entity
		local recipeEntity = drawData[8]
		recipeEntity.SpriteGUIRendererComponent:ChangeMaterial(materialId)
		
		self.TasteScoreText.Text = tostring(ingreData.TastePoint)
		self.CostText.Text = tostring(ingreData.BaseCost)
		
		self.SpicyPointText.Text = ingreData.SpicyPoint == nil and _GetLocalizationTextLogic:GetText("NotSpicy") or "+"..tostring(ingreData.SpicyPoint)
		
		local tagData = _RecipeTagDataSetLogic:GetRecipeTagData(ingreData.Type)
		if isvalid(tagData) then
			self.TypeIcon.Entity.Enable = true
			self.TypeIcon.ImageRUID = tagData.IconRUID
			self.TypeText.Text = _GetLocalizationTextLogic:GetText(tagData.TagNameKey)
		else
			self.TypeIcon.Entity.Enable = false
			self.TypeText.Text = _GetLocalizationTextLogic:GetText("TagEtc")
		end
		
		self.BalanceIcon.ImageRUID = ingreData.BalancePoint < 0 and "638317f08f0947db9f5350709a86aca7" or "8e942676a64d421e8eebfa01023be8e8"
		local absBalance = math.abs(ingreData.BalancePoint)
		local balanceText = ingreData.BalancePoint < 0 and _GetLocalizationTextLogic:GetText("BalanceLight") or _GetLocalizationTextLogic:GetText("BalanceHeavy")
		self.BalanceText.Text = string.format("%s +%d", balanceText, absBalance)
		
		local stageData = _StageDataSetLogic:GetStageData(ingreData.RelatedStage)
		if ingreData.RelatedStage == 0 then
			self.StageIcon.ImageRUID = _IconRuidEnum.Stage0Icon
			self.StageText.Text = _GetLocalizationTextLogic:GetText("StageName0")
			
		else
			self.StageIcon.ImageRUID = stageData.BadgeIconRUID
			self.StageText.Text = _GetLocalizationTextLogic:GetText(stageData.NameKey)
		end
		
	end

end