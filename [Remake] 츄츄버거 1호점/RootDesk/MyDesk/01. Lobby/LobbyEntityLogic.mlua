@Logic
script LobbyEntityLogic extends Logic

	property Entity BurgerGroup = "1738ee53-a792-40af-a6ec-998d2607ff89"

	property Entity CustomerExitPos = "93b150d7-17b8-4935-9bf1-1e17f3ba2543"

	property Entity CustomerSpawnGroup = "6171e47d-3df9-4e98-9019-260086b2c902"

	property Entity CustomerGroup = "7a75c0e7-dbfd-464c-8c0e-791ae5beb6b3"

	property Entity EmployeeSpawnPosCook = "783ea056-9ad3-4a13-9cd1-6d3a8fe9e7f2"

	property Entity EmployeeSpawnPosServing = "87b78ae2-1aab-4654-85c2-1ad8b253823a"

	property Entity EmployeeSpawnPosCook_6 = nil

	property Entity EmployeeSpawnPosServing_6 = nil

	property Entity ExpansionParticles = "463ada4e-b056-4e0a-9257-2c67628c11c9"

	@ExecSpace("Client")
	method void SetEntities()
		-- 로비 맵의 주요 엔티티들을 설정하는 함수
		local mapPath = _UserService.LocalPlayer.CurrentMap.Path
		self.BurgerGroup = _EntityService:GetEntityByPath(mapPath.."/BurgerGroup")
		self.CustomerExitPos = _EntityService:GetEntityByPath(mapPath.."/SpawnPosGroup/Exit")
		self.CustomerSpawnGroup = _EntityService:GetEntityByPath(mapPath.."/SpawnPosGroup/Customer")
		self.CustomerGroup = _EntityService:GetEntityByPath(mapPath.."/CustomerGroup")
		
		self.EmployeeSpawnPosCook = _EntityService:GetEntityByPath(mapPath.."/SpawnPosGroup/EmployeeWaitCook")
		self.EmployeeSpawnPosServing = _EntityService:GetEntityByPath(mapPath.."/SpawnPosGroup/EmployeeWaitServing")
		
		self.EmployeeSpawnPosCook_6 = _SpawnService:SpawnByEntity(self.EmployeeSpawnPosCook, "EmployeeWaitCook_6", Vector3(self.EmployeeSpawnPosCook.TransformComponent.Position.x, self.EmployeeSpawnPosCook.TransformComponent.Position.y + 2.3, 0), self.EmployeeSpawnPosServing.Parent, false)
		self.EmployeeSpawnPosServing_6 = _SpawnService:SpawnByEntity(self.EmployeeSpawnPosServing, "EmployeeWaitServing_6", Vector3(self.EmployeeSpawnPosServing.TransformComponent.Position.x, self.EmployeeSpawnPosServing.TransformComponent.Position.y + 1.8, 0), self.EmployeeSpawnPosServing.Parent, false)
		
		self.ExpansionParticles = _EntityService:GetEntityByPath(mapPath.."/ExpansionParticles")
	end

	@ExecSpace("Client")
	method void SpawnDisplayCountText(integer expansionLv)
		-- 확장 레벨에 따라 디스플레이 카운트 텍스트를 생성하는 함수
		
		local kitchenApp =_EntityService:GetEntityByPath(_UserService.LocalPlayer.CurrentMap.Path.."/KitchenApp_Level"..expansionLv)
		
		for _,entity in pairs(kitchenApp.Children) do 
			if string.find(entity.Name,_KitchenAppEnumType.Display) then
				
				local modelId =   _EntryService:GetModelIdByName("Model_DisplayBurgerCount")  
				local spawn = _SpawnService:SpawnByModelId(modelId,"DisplayBurgerCount",Vector3(0,0.75,0),entity)
				spawn.Enable = false
				
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetKitchenAppInfo(integer expansionLv)
		-- 주방 기기 정보를 설정하는 함수
		local apps = _EntityService:GetEntityByPath(_UserService.LocalPlayer.CurrentMap.Path.."/KitchenApp_Level"..expansionLv)
		for _, deco in pairs(apps.Children) do 
			
			local appType = {_KitchenAppEnumType.Counter,_KitchenAppEnumType.Display,_KitchenAppEnumType.Grill}
			
			for i = 1 , #appType do 
				if string.find(deco.Name,appType[i]) then 
					deco.TagComponent.Tags[1] = appType[i]
					deco.TagComponent.Tags[2] = string.sub(deco.Name,string.len("Deco"..appType[i])+1,string.len(deco.Name))
				
					if appType[i] == _KitchenAppEnumType.Display then 
						local temp = tonumber(deco.TagComponent.Tags[2] )
						if temp <= 5 then 
							 deco.TagComponent.Tags[3] = tostring(temp)
						elseif temp >5 and temp<11 then 
							deco.TagComponent.Tags[3] = tostring(temp - 5)
						else
							deco.TagComponent.Tags[3] = tostring(temp - 10)
						end
					end
				end
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void SetModelAfterSpawn(integer expansionLv)
		-- 스폰 후 모델 설정을 처리하는 함수
		self:SpawnDisplayCountText(expansionLv)
		self:SetKitchenAppInfo(expansionLv)
	end

	@ExecSpace("ClientOnly")
	method EntityRef GetEmployeeSpawnPostion(string type)
		-- 직원 타입에 따른 스폰 위치를 반환하는 함수
		local expansionLevel = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer, _UpgradeTypeEnum.ExpansionStep)
		if type == _EmployeeTypeEnum.Cook then
			if expansionLevel == 6  then 
				return self.EmployeeSpawnPosCook_6
			else
				return self.EmployeeSpawnPosCook
			end
		elseif type == _EmployeeTypeEnum.Serving then
			if expansionLevel == 6 then 
				return self.EmployeeSpawnPosServing_6
			else
				return self.EmployeeSpawnPosServing
			end
		end
		
		return nil
	end

end