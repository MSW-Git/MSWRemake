@Logic
script CameraDataSetLogic extends Logic

	property table LobbyCameraData = {}

	property table InteriorEntityCameraData = {}

	method void OnBeginPlay()
		-- 로직 시작 시 카메라 데이터셋을 로드하는 함수
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- 로비 카메라 데이터와 인테리어 카메라 데이터를 로드하는 함수
		table.clear(self.LobbyCameraData)
		local expansionMaxLevelValue = 6
		local dataSet = _DataService:GetTable("LobbyCameraData")
		for i = 1, expansionMaxLevelValue do
		    local data = LobbyCameraData()
		    data:Load(dataSet, i)
		    
		    if self.LobbyCameraData[data.Level] ~= nil then
		        break
		    end
		    
		    self.LobbyCameraData[data.Level] = data
		    
		end
		
		table.clear(self.InteriorEntityCameraData)
		local iDataSet = _DataService:GetTable("InteriorEntityCameraData")
		local rowTable = {}
		for i = 1, iDataSet:GetRowCount() do
			local row = iDataSet:GetRow(i)
			local level = math.floor(tonumber(row:GetItem("UpgradeLevel")))
			if rowTable[level] == nil then
				rowTable[level] = {}
			end
			table.insert(rowTable[level], row)
		end
		
		for level, rows in pairs(rowTable) do
			local data = InteriorEntityCameraData()
			data:Load(level, rows)
			
			if self.InteriorEntityCameraData[data.UpgradeLevel] ~= nil then
				break
			end
			
			self.InteriorEntityCameraData[data.UpgradeLevel] = data
		end
	end

	method InteriorEntityCameraData GetInteriorEntityCameraData(integer level)
		-- 레벨에 해당하는 인테리어 엔티티 카메라 데이터를 반환하는 함수
		return self.InteriorEntityCameraData[level]
	end

	method LobbyCameraData GetLobbyCameraData(integer expansionLv)
		-- 확장 레벨에 해당하는 로비 카메라 데이터를 반환하는 함수
		return self.LobbyCameraData[expansionLv]
	end

end