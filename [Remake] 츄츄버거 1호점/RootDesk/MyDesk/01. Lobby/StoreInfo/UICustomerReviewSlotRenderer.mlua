@Component
script UICustomerReviewSlotRenderer extends Component

	property integer ReviewId = 0

	property SpriteGUIRendererComponent TitleBar = nil

	property SpriteGUIRendererComponent FaceIcon = nil

	property TextComponent PercentText = nil

	property SpriteGUIRendererComponent TypeImage = nil

	property TextComponent ReviewText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 엘리먼트들을 초기화하는 함수
		self.TitleBar = self.Entity:GetChildByName("TitleBar").SpriteGUIRendererComponent
		self.FaceIcon = self.TitleBar.Entity:GetChildByName("FaceIcon").SpriteGUIRendererComponent
		self.PercentText = self.TitleBar.Entity:GetChildByName("PercentText").TextComponent
		self.TypeImage = self.Entity:GetChildByName("TypeImage").SpriteGUIRendererComponent
		self.ReviewText = self.Entity:GetChildByName("ReviewText").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer reviewId, integer score)
		-- 고객 리뷰 슬롯의 데이터를 새로고침하는 함수
		self.ReviewId = reviewId
		
		---@type CustomerReviewData
		local reviewData = _StoreInfoDataSetLogic.CustomerReviewData[reviewId]
		if isvalid(reviewData) == false then
			self.Entity.Enable = false
			return
		end
		
		self.TypeImage.ImageRUID = reviewData.ReviewImageRUID
		
		local reviewState
		local percent
		
		local iconRUID = function(a)
			if a == "Good" then
				return _IconRuidEnum.Face_Good
			elseif a == "Normal" then
				return _IconRuidEnum.Face_Normal
			elseif a == "Bad" then
				return _IconRuidEnum.Face_Bad
			end
			
		end
		
		local outlineColor = function(a)
			if a == "Good" then
				return _ColorCodeEnum:GetColor("#8D5D01")
			elseif a == "Normal" then
				return _ColorCodeEnum:GetColor("#653209")
			elseif a == "Bad" then
				return _ColorCodeEnum:GetColor("#511103")
			end
		end
		
		local titleRUID = function(a)
			if a == "Good" then
				return _IconRuidEnum.DefaultWhiteSquare
			elseif a == "Normal" then
				return "3968f9456590453a9b142b56408e700c"
			elseif a == "Bad" then
				return _IconRuidEnum.DefaultWhiteSquare
			end 
		end
		
		local titleColor = function(a)
			if a == "Good" then
				return _ColorCodeEnum:GetColor("#FAD03E")
			elseif a == "Normal" then
				return _ColorCodeEnum:GetColor("#FFFFFF")
			elseif a == "Bad" then
				return _ColorCodeEnum:GetColor("#BD4D1E")
			end 
		end
		
		if score <= 0 then
			reviewState = "Good"
			
			if reviewData.Category == "Recipe" and reviewData.Type == "Tag" then
				local spawnPool = _UserService.LocalPlayer.CustomerManager.CustomerSpawnDataTable
				local totalCount = #table.keys(spawnPool)
				local tagCount = 0
				for id, info in pairs(spawnPool) do
					local targetTag = info["TargetTag"]
					if targetTag == nil then
						continue
					end
					
					if targetTag == reviewData.TypeDetail then
						tagCount += 1
					end
				end
				
				percent = math.floor(tagCount/totalCount * 100)
			else
				percent = _UtilLogic:RandomIntegerRange(70, 100)
			end	
			
		elseif 0 < score and score <= 50 then
			reviewState = "Normal"
			
			local percentMin = 5
			local percentMax = 70
			local scorePercent = score/50
			if scorePercent > 1 then
				scorePercent = 1
			end
			percent = math.floor(percentMin + (scorePercent * (percentMax-percentMin)))
			
		else
			reviewState = "Bad"
			
			local percentMin = 60
			local percentMax = 90
			local scorePercent = score/100
			if scorePercent > 1 then
				scorePercent = 1
			end
			percent = math.floor(percentMin + (scorePercent * (percentMax-percentMin)))
			
		end
		
		self.TitleBar.ImageRUID = titleRUID(reviewState)
		self.TitleBar.Color = titleColor(reviewState)
		self.FaceIcon.ImageRUID = iconRUID(reviewState)
		self.PercentText.Text = percent.."%"
		self.PercentText.FontColor = Color.white
		self.PercentText.OutlineColor = outlineColor(reviewState)
		
		local descKey = reviewData[reviewState.."DescKey"]
		if reviewId == 20006 then
			local player = _UserService.LocalPlayer
			local lackRecipeId = _StoreInfoDataSetLogic:ReturnLackRecipeId(player)
			
			if reviewState == "Good" or lackRecipeId == 0 then
				self.ReviewText.Text = _GetLocalizationTextLogic:GetText(descKey)
			else
				---@type RecipeData
				local recipeData = player.PlayerRecipe.Recipes[lackRecipeId]
				if isvalid(recipeData) == false then
					self.Entity.Enable = false
					return
				end
				
				local recipeName = recipeData.Name
				self.ReviewText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(descKey, recipeName)
			end
			
		else
			self.ReviewText.Text = _GetLocalizationTextLogic:GetText(descKey)
		end
	end

end