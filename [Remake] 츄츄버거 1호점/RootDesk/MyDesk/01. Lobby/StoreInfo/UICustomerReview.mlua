@Component
script UICustomerReview extends Component

	property Entity CustomerReviewList = nil

	property integer customerReviewMaxCount = 10

	@ExecSpace("ClientOnly")
	method void Open()
		-- 고객 리뷰 UI를 열고 데이터를 새로고침하는 함수
		if self.Entity.Enable == true then
			return
		end
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 고객 리뷰 리스트를 새로고침하는 함수
		for i = 1, #self.CustomerReviewList.Children do
			self.CustomerReviewList.Children[i].Enable = false
		end
		
		local reviewPool = self:ReturnCustomerReviewPool()
		local reviewCount = #reviewPool
		if reviewCount > self.customerReviewMaxCount then
			reviewCount = self.customerReviewMaxCount
		end
		
		for i = 1, reviewCount do
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_CustomerReviewSlotRenderer_New", i, self.CustomerReviewList)
			local reviewData = reviewPool[i]
			local reviewId = reviewData[1]
			local reviewScore = reviewData[2]
			entity.UICustomerReviewSlotRenderer:Refresh(reviewId, reviewScore)
		end
		
		self.CustomerReviewList.ScrollLayoutGroupComponent:SetScrollPositionByItemIndex(1)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 엘리먼트를 초기화하는 함수
		self.CustomerReviewList = self.Entity:GetChildByName("CustomerReviewList")
	end

	@ExecSpace("ClientOnly")
	method table ReturnCustomerReviewPool()
		-- 고객 리뷰 데이터 풀을 점수 순으로 정렬하여 반환하는 함수
		local poolTable = {}
		for k, v in pairs(_StoreInfoDataSetLogic.CustomerReviewData) do
			local score = _StoreInfoDataSetLogic:ReturnPlayerScoreByCustomerReviewId(_UserService.LocalPlayer, k)
			if score ~= nil then
				table.insert(poolTable, {k, score})
			end	
		end
		
		table.sort(poolTable, function(a, b) return a[2] > b[2] end)
		
		return poolTable
	end

end