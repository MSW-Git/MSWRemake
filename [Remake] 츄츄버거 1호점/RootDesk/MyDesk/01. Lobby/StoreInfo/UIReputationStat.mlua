@Component
script UIReputationStat extends Component

	property TextComponent Score = nil

	property SliderComponent Slider = nil

	property TextComponent Count = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- UI 엘리먼트들을 초기화하는 함수
		self.Score = self.Entity:GetChildByName("Score").TextComponent
		self.Slider = self.Entity:GetChildByName("Slider").SliderComponent
		self.Count = self.Entity:GetChildByName("Count").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer score, integer count, integer sliderMax)
		-- 평판 통계 데이터를 UI에 표시하는 함수
		if self.Score == nil then
			self:Init()
		end
		
		self.Score.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Score_Format", score)
		if sliderMax == 0 or isvalid(count) == false then
			self.Slider.Value = 0
			self.Count.Text = "0"
			return
		end
		
		self.Slider.Value = count/sliderMax
		self.Count.Text = _StringUtilLogic:ReturnThousandsSeparatedString(count)
		
	end

end