@Component
script UIStoreInfo extends Component

	property Entity UISettlementRecord = "b0728cb2-f4f9-45ed-be80-9ee85634bb70"

	property SyncTable<integer, Entity> Tabs

	property integer SelectTab = 0

	property SyncTable<integer, Entity> Infos

	property Entity UICustomerReview = "75c55b52-7aac-4268-8954-9a905d0e00bb"

	property Entity UIEmployeeReview = "674efb0b-ade6-4196-9fb3-ca31eca10be1"

	property Entity UIReputationReview = "a2aa1c95-5112-41e7-ac64-92969e07ad13"

	property TextComponent SubTitleText = "4e9a7f4e-2bd1-46a5-ab19-8d779806e523"

	property string OpenParam = ""

	@ExecSpace("ClientOnly")
	method void Open(integer tab, string param)
		-- 상점 정보 UI를 열고 탭을 설정하는 함수
		if self.Entity.Enable then
			return
		end
		
		self.OpenParam = param
		
		_UIGroupManager:EnableStoreInfoGroup(true)
		self.Entity.Enable = true
		
		self:SetSelectTab(tab)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 상점 정보 UI를 닫는 함수
		_UIGroupManager:EnableStoreInfoGroup(false)
		self.Entity.Enable = false
		
		for i, entity in pairs(self.Infos) do
			entity.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 엘리먼트들을 초기화하는 함수
		self:Close()
		
		table.clear(self.Tabs)
		local tabBar = self.Entity:GetChildByName("TabBar"):GetChildByName("TabList")
		for i = 1, #tabBar.Children do
			local entity = tabBar.Children[i]
			self.Tabs[i] = entity
			
			entity:ConnectEvent(ButtonClickEvent, function()
				if _UIGroupManager:IsEnableOpenPopUp() == false then
					return
				end
				
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				self:SetSelectTab(i)
			end)
		end
		
		table.clear(self.Infos)
		local infoArea = self.Entity:GetChildByName("InfoArea")
		for i = 1, #infoArea.Children do
			local entity = infoArea.Children[i]
			self.Infos[i] = entity
			
			entity.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSelectTab(integer selectTab)
		-- 선택된 탭을 설정하는 함수
		self.SelectTab = selectTab
		self:OnSelectTab(selectTab)
	end

	@ExecSpace("ClientOnly")
	method void OnSelectTab(integer selectTab)
		-- 선택된 탭에 따라 UI를 변경하는 함수
		for i, entity in pairs(self.Tabs) do
			local titleText = entity:GetChildByName("Title").TextComponent
			local sprite = entity:GetChildByName("Sprite")
			local categoryImg = entity:GetChildByName("CategoryImage")
			local iconSprite = categoryImg:GetChildByName("IconImage").SpriteGUIRendererComponent
			if i == selectTab then
				titleText.FontColor = Color.white
				titleText.OutlineColor = _ColorCodeEnum:GetColor("#985F05")
				titleText.UseOutLine = true	
				sprite.SpriteGUIRendererComponent.ImageRUID = "c126e98243bf4c7cbfa7bcbb278b0f60"
				iconSprite.Color.a = 1
				
			else
				titleText.FontColor = _ColorCodeEnum:GetColor("#BB9A59")
				titleText.UseOutLine = false
				sprite.SpriteGUIRendererComponent.ImageRUID = "6cc87742434e42e3b3a988e83142db83"
				iconSprite.Color.a = 0.5
				
			end
		end
		
		if selectTab == 1 then
			self.UISettlementRecord.UISettlementRecord:Open()
			self.SubTitleText.Text = _GetLocalizationTextLogic:GetText("SettlementInfoText")
		elseif selectTab == 2 then
			self.UIReputationReview.UIReputationReview:Open()
			self.SubTitleText.Text = _GetLocalizationTextLogic:GetText("StoreInfoReputationSubTitle")
		elseif selectTab == 3 then
			self.UICustomerReview.UICustomerReview:Open()
			self.SubTitleText.Text = _GetLocalizationTextLogic:GetText("CustomerReviewInfoText")
		elseif selectTab == 4 then
			self.UIEmployeeReview.UIEmployeeReview:Open(self.OpenParam)
			self.SubTitleText.Text = _GetLocalizationTextLogic:GetText("EmployeeReviewInfoText")
		end
		
		self.OpenParam = ""
		
		for i, entity in pairs(self.Infos) do
			if i == selectTab then
				entity.Enable = true
			else
				entity.Enable = false
			end
		end
	end

	@EventSender("Entity", "f15630c7-01e3-40e2-ad80-02121a23adec")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("Entity", "a0a83bad-0fba-4e0a-b989-3511c3cbc67c")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 정산 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open(1, nil)
	end

	@EventSender("Entity", "b6da5db9-f66a-4bc9-8e01-adac44600e0c")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 정산 버튼 2 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open(1, nil)
	end

	@EventSender("Entity", "ac400c64-a216-4f46-b9bf-bfe8e7e97b2e")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 평판 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open(2, nil)
	end

end