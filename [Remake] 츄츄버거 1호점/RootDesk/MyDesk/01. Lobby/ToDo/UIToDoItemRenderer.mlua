@Component
script UIToDoItemRenderer extends Component

	property TextComponent Contents = nil

	property Entity Check = nil

	property Entity New = nil

	property integer Id = 0

	property SpriteGUIRendererComponent MenuIcon = nil

	property Entity MoveBtn = nil

	property Entity Dim = nil

	property any buttonHandler = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 구성 요소들을 초기화하는 함수
		self.Contents = self.Entity:GetChildByName("Text").TextComponent
		self.Check = self.Entity:GetChildByName("Box")
		self.New = self.Entity:GetChildByName("New")
		self.Dim = self.Entity:GetChildByName("Dim")
		self.MoveBtn = self.Entity:GetChildByName("MoveBtn")
		
		self.MenuIcon = self.Entity:GetChildByName("MenuHolder"):GetChildByName("Icon").SpriteGUIRendererComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh(ToDoData todoData, boolean isCompleted)
		-- 일반 ToDo 데이터로 UI를 새로고침하는 함수
		if isvalid(self.buttonHandler) then
			self.MoveBtn:DisconnectEvent(ButtonClickEvent, self.buttonHandler)
		end
		
		self.Id = todoData.Id
		
		self.Contents.Text = _GetLocalizationTextLogic:GetText(todoData.ContentsKey)
		
		
		self.New.Enable = not isCompleted
		self.Dim.Enable = isCompleted
		self.Check.Enable = isCompleted
		
		local menuData = _MainMenuDataSetLogic:GetMenuBtnData(todoData.UIOpenType)
		self.MenuIcon.ImageRUID = menuData.IconRUID
		
		self.buttonHandler = self.MoveBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_ToDoManager:OpenRelatedUI(todoData.UIOpenType, todoData.UIOpenTypeValue)
			
		end)
	end

	@ExecSpace("ClientOnly")
	method void RefreshSecretary(ToDoSecretaryData secData, boolean isChecked)
		-- 비서 ToDo 데이터로 UI를 새로고침하는 함수
		if isvalid(self.buttonHandler) then
			self.MoveBtn:DisconnectEvent(ButtonClickEvent, self.buttonHandler)
		end
		
		self.Id = secData.Id
		self.Contents.Text = _GetLocalizationTextLogic:GetText(secData.ContentsKey)
		
		self.New.Enable = not isChecked
		self.Dim.Enable = false
		self.Check.Enable = false
		
		local menuData = _MainMenuDataSetLogic:GetMenuBtnData(secData.UIOpenType)
		self.MenuIcon.ImageRUID = menuData.IconRUID
		
		
		self.buttonHandler = self.MoveBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_ToDoManager:OpenRelatedUI(secData.UIOpenType, secData.UIOpenTypeValue)
			
		end)
	end

end