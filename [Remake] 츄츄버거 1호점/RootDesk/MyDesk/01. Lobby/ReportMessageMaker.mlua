@Logic
script ReportMessageMaker extends Logic

	property number CoolDownTimer3001 = 0

	property number CoolDownTimer3002 = 0

	property number CoolDownTimer3003 = 0

	property number CoolDownTimer3004 = 0

	property number CoolDownTimer3005 = 0

	property number CoolDownTimer3006 = 0

	property number CoolDownTimer3007 = 0

	property number CoolDownTimer2005 = 0

	property number CoolDownTimer2006 = 0

	property integer CoolDownDurationLong = 60

	property integer CoolDownDurationShort = 30

	property table ReportMessageQueue = {}

	property integer ReportTimer = 0

	@ExecSpace("Client")
	method void MakeReport(integer reportId, string param1, string param2, string param3)
		-- 리포트 메시지를 생성하는 함수
		
		
		---@type StoreInfoReportData
		local reportData = _StoreInfoDataSetLogic.StoreInfoReportData[reportId]
		if reportData == nil then return end
		
		local categoryTextKey = reportData.CategoryTextKey
		local reportTexttkey = reportData.ReportTextKey
		local paramCount = tonumber(reportData.ParamCount)
		
		local categoryText = ""
		local reportText = ""
		local message = ""
		
		if paramCount <= 0 then
			reportText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetText(reportTexttkey) 
		
		elseif paramCount <= 1 then
			if self:CheckParamIsNilOrNot(param1) then  return end 
			reportText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(reportTexttkey,param1)
			
		elseif paramCount <= 2 then
			if self:CheckParamIsNilOrNot(param1) then  return end 
			if self:CheckParamIsNilOrNot(param2) then  return end 
				
			reportText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(reportTexttkey,param1,param2)
			
		elseif paramCount <= 3 then
			if self:CheckParamIsNilOrNot(param1) then  return end 
			if self:CheckParamIsNilOrNot(param2) then  return end 
			if self:CheckParamIsNilOrNot(param3) then  return end 
			
			reportText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(reportTexttkey,param1,param2,param3)
		end
		
		if _UtilLogic:IsNilorEmptyString(categoryText) then
			
			message = reportText
		else
			categoryText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetText(categoryTextKey) 
			message = categoryText.." "..reportText
		end
		
		local function resetTimer3001 ()
			_TimerService:ClearTimer(self.CoolDownTimer3001)
			self.CoolDownTimer3001 = 0
		end
		
		local function resetTimer3002 ()
			_TimerService:ClearTimer(self.CoolDownTimer3002)
			self.CoolDownTimer3002 = 0
		end
		
		local function resetTimer3003 ()
			_TimerService:ClearTimer(self.CoolDownTimer3003)
			self.CoolDownTimer3003 = 0
		end
		
		local function resetTimer3004 ()
			_TimerService:ClearTimer(self.CoolDownTimer3004)
			self.CoolDownTimer3004 = 0
		end
		
		local function resetTimer3005 ()
			_TimerService:ClearTimer(self.CoolDownTimer3005)
			self.CoolDownTimer3005 = 0
		end
		
		local function resetTimer3006 ()
			_TimerService:ClearTimer(self.CoolDownTimer3006)
			self.CoolDownTimer3006 = 0
		end
		
		local function resetTimer3007 ()
			_TimerService:ClearTimer(self.CoolDownTimer3007)
			self.CoolDownTimer3007 = 0
		end
		
		
		local function resetTimer2005 ()
			_TimerService:ClearTimer(self.CoolDownTimer2005)
			self.CoolDownTimer2005 = 0
		end
		
		
		
		if reportId == 3001 then
			if self.CoolDownTimer3001 == 0 then
				self.CoolDownTimer3001 = _TimerService:SetTimerOnce( resetTimer3001 , self.CoolDownDurationShort )
		
			else	
				return		
			end
		elseif reportId == 3002 then
			if self.CoolDownTimer3002 == 0 then
				self.CoolDownTimer3002 = _TimerService:SetTimerOnce( resetTimer3002 , self.CoolDownDurationShort )
		
			else
				return		
			end
		elseif reportId == 3003 then
			if self.CoolDownTimer3003 == 0 then
				self.CoolDownTimer3003 = _TimerService:SetTimerOnce( resetTimer3003 , self.CoolDownDurationShort )
			else	
				return		
			end
		elseif reportId == 3004 then
			if self.CoolDownTimer3004 == 0 then
				self.CoolDownTimer3004 = _TimerService:SetTimerOnce( resetTimer3004 , self.CoolDownDurationShort )
			else	
				return		
			end
		elseif reportId == 3005 then
			if self.CoolDownTimer3005 == 0 then
				self.CoolDownTimer3005 = _TimerService:SetTimerOnce( resetTimer3005 , self.CoolDownDurationShort )
			else	
				return		
			end
		elseif reportId == 3006 then
			if self.CoolDownTimer3006 == 0 then
				self.CoolDownTimer3006 = _TimerService:SetTimerOnce( resetTimer3006 , self.CoolDownDurationLong )
			else	
				return		
			end
		elseif reportId == 3007 then
			if self.CoolDownTimer3007 == 0 then
				self.CoolDownTimer3007 = _TimerService:SetTimerOnce( resetTimer3007 , self.CoolDownDurationLong )
			else	
				return		
			end
		elseif reportId == 2005 then
			if self.CoolDownTimer2005 == 0 then
				self.CoolDownTimer2005 = _TimerService:SetTimerOnce( resetTimer2005 , self.CoolDownDurationLong )
			else	
				return		
			end
		
		end
		
		_LobbyHUDService:UpdateStoreInfoReportUI(message , reportId)
		_UIToastLobby:ShowMessage(message)
		
	end

	@ExecSpace("ClientOnly")
	method boolean CheckParamIsNilOrNot(string param)
		-- 파라미터가 nil인지 확인하는 함수
		if _UtilLogic:IsNilorEmptyString(param) then
			return true		
		end
		
		return false
	end

	@ExecSpace("Client")
	method void RequestAddToReportQueue(integer reportId, string param1, string param2, string param3)
		-- 리포트 큐에 추가를 요청하는 함수
		if reportId == 3001 and self.CoolDownTimer3001 ~= 0 then 
			return		
		
		elseif reportId == 3002 and self.CoolDownTimer3002 ~= 0 then
			return
			
		elseif reportId == 3003 and self.CoolDownTimer3003 ~= 0 then
			return		
		
		elseif reportId == 3004 and self.CoolDownTimer3004 ~= 0 then
			return		
		
		elseif reportId == 3005 and self.CoolDownTimer3005 ~= 0 then
			return		
		
		elseif reportId == 3006 and self.CoolDownTimer3006 ~= 0 then
			return		
		
		elseif reportId == 3007 and self.CoolDownTimer3007 ~= 0 then
			return		
		
		elseif reportId == 2005 and self.CoolDownTimer2005 ~= 0 then
			return		
		
		elseif reportId == 2006 and self.CoolDownTimer2006 ~= 0 then
			return		
		end
		
		local reportInfoTable = {}
		reportInfoTable[1] = tostring(reportId)
		reportInfoTable[2] = param1
		reportInfoTable[3] = param2 
		reportInfoTable[4] = param3
		
		local reportInfoStr = _UtilLogic:TableToString(reportInfoTable)
		table.insert(self.ReportMessageQueue , reportInfoStr) 
		
		
		if self.ReportTimer == 0 then
			self:ReserveReport()
		end 
	end

	@ExecSpace("Client")
	method void ReserveReport()
		-- 리포트를 예약하는 함수
		
		local getReport = function()
			
			if #self.ReportMessageQueue ~= 0 then
				if not _UtilLogic:IsNilorEmptyString(self.ReportMessageQueue[1]) then
					local reportInfoTable = _UtilLogic:StringToTable( self.ReportMessageQueue[1] )
					local reportId = tonumber(reportInfoTable[1])
					local param1 = tostring(reportInfoTable[2])
					local param2 = tostring(reportInfoTable[3])
					local param3 = tostring(reportInfoTable[4])
					self:MakeReport( reportId, param1 , param2 ,param3 )
					
					self:RequestRemoveToReportQueue()
				end
				
			elseif #self.ReportMessageQueue == 0 then
				_TimerService:ClearTimer(self.ReportTimer)
				self.ReportTimer = 0 
		
			end
		end
		
		self.ReportTimer = _TimerService:SetTimerRepeat(function() getReport() end,2.5)
	end

	@ExecSpace("ClientOnly")
	method void RequestRemoveToReportQueue()
		-- 리포트 큐에서 제거를 요청하는 함수
		local removeReport = table.remove(self.ReportMessageQueue , 1)
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		-- 게임 종료 시 타이머를 정리하는 함수
		if self.ReportTimer ~= 0 then
			_TimerService:ClearTimer(self.ReportTimer)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 리포트 메시지 메이커를 초기화하는 함수
		self.CoolDownTimer3001 = 0
		self.CoolDownTimer3002 = 0
		self.CoolDownTimer3003 = 0
		self.CoolDownTimer3004 = 0
		self.CoolDownTimer3005 = 0
		self.CoolDownTimer3006 = 0
		self.CoolDownTimer3007 = 0
		self.CoolDownTimer2005 = 0
		self.CoolDownTimer2006 = 0
		
		if self.ReportTimer ~= 0 then
			_TimerService:ClearTimer(self.ReportTimer)
		end
		self.ReportTimer = 0
		
		table.clear(self.ReportMessageQueue)
	end

	@ExecSpace("Client")
	method void ClearReportQueue()
		-- 리포트 큐를 정리하는 함수
		table.clear(self.ReportMessageQueue)
	end

end