@Struct
script ReputationManagementData

	property integer StageId = 0

	property integer ManagementLevel = 0

	property integer VIPOrderReward = 0

	property number MinSpawnDelay = 0

	property number MaxSpawnDelay = 0

	property integer SpeedUpSpawnCustomerCount = 0

	method void Load(any dataTable, integer index)
		-- CSV 데이터 테이블에서 평판 관리 데이터를 로드하여 속성에 저장
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.StageId = tonumber(row:GetItem("StageId"))
		self.ManagementLevel = tonumber(row:GetItem("ManagementLevel"))
		self.VIPOrderReward = tonumber(row:GetItem("VIPOrderReward"))
		self.MinSpawnDelay = tonumber(row:GetItem("MinSpawnDelay"))
		self.MaxSpawnDelay = tonumber(row:GetItem("MaxSpawnDelay"))
		self.SpeedUpSpawnCustomerCount = tonumber(row:GetItem("SpeedUpSpawnCustomerCount"))
	end

end