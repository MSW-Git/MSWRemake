@Struct
script InteriorEntityCameraData

	property integer UpgradeLevel = 0

	property SyncTable<string, string> EntityTargetCamera

	property SyncTable<string, string> EntityTargetCameraSide

	method void Load(integer level, table rows)
		-- 업그레이드 레벨에 따른 카메라 데이터를 로드하는 함수
		self.UpgradeLevel = level
		
		for i = 1, #rows do
			---@type UserDataRow
			local row = rows[i]
			
			local entityName = row:GetItem("EntityName")
			local targetCamera = row:GetItem("TargetCamera")
			local targetCameraSide = row:GetItem("TargetCameraSide")
			
			self.EntityTargetCamera[entityName] = targetCamera
			self.EntityTargetCameraSide[entityName] = targetCameraSide
		end
	end

	method table GetEntitiesOfTargetCamera(string cameraKey)
		-- 특정 카메라 키에 해당하는 엔티티 목록을 반환하는 함수
		local entities = {}
		local cameraSplit = _UtilLogic:Split(cameraKey, "_")
		local targetCamera = cameraSplit[1]
		local targetCameraSide = cameraSplit[2]
		
		for entityName, camera in pairs(self.EntityTargetCamera) do
			if camera ~= targetCamera then
				continue
			end
			
			if _UtilLogic:IsNilorEmptyString(targetCameraSide) == false then
				if self.EntityTargetCameraSide[entityName] ~= targetCameraSide then
					continue
				end
			end
			
			table.insert(entities, entityName)
		end
		
		return entities
	end

end