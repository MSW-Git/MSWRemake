@Component
script UIDiaInfoSlot extends Component

	property Entity title = nil

	property Entity Icon = nil

	property table infoTable = {}

	property string type = ""

	property Entity BonusIcon = nil

	property TextComponent ValueText = nil

	property SpriteGUIRendererComponent ValueIcon = nil

	property string paidBonusRUID = "ac6c4740335042518074efa1bb412ca0"

	property string getFreeRUID = "6acc7b7fdb59436883f66a8dbdca9ea2"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 슬롯 UI 요소들을 초기화하는 함수
		self.title = self.Entity:GetChildByName("Title")
		self.Icon = self.Entity:GetChildByName("Icon")
		self.BonusIcon = self.Entity:GetChildByName("BonusIcon")
		self.ValueIcon = self.BonusIcon:GetChildByName("Value").SpriteGUIRendererComponent
		self.ValueText = self.BonusIcon:GetChildByName("Value").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Init(string title, string iconRUID, boolean bonus)
		-- 다이아 획득 방법 슬롯을 초기화하고 보너스 정보를 설정하는 함수
		self.type = title
		self.title.TextComponent.Text = _LocalizationService:GetText(title)
		self.Icon.SpriteGUIRendererComponent.ImageRUID = iconRUID
		
		if title == "HowtoGetDia_StarterPack" then 
			self.ValueText.Text = _LocalizationService:GetText("WelcomBenefitText")
			self.ValueText.OutlineColor = _ColorCodeEnum:GetColor("#7437c6")
			self.ValueIcon.ImageRUID = self.paidBonusRUID 
		elseif title == "HowtoGetDia_Package" then
			self.ValueText.Text = _LocalizationService:GetText("FirstBenefitText")
			self.ValueText.OutlineColor = _ColorCodeEnum:GetColor("#7437c6")
			self.ValueIcon.ImageRUID = self.paidBonusRUID
		elseif title == "HowtoGetDia_DiaProduct" then
			self.ValueText.Text = _LocalizationService:GetText("FirstBenefitText")
			self.ValueText.OutlineColor = _ColorCodeEnum:GetColor("#7437c6")
			self.ValueIcon.ImageRUID = self.paidBonusRUID
		elseif title == "HowtoGetDia_StagePass" or title == "HowtoGetDia_IngreCollecetion" or title == "HowtoGetDia_ManagementLevel" or title == "HowtoGetDia_StageClear" or title == "HowtoGetDia_ChuchuCollecetion" then
			self.ValueText.Text = _LocalizationService:GetText("GetFree")
			self.ValueText.OutlineColor = _ColorCodeEnum:GetColor("#906623")
			self.ValueIcon.ImageRUID = self.getFreeRUID
		end
		
		self.BonusIcon.Enable = bonus
	end

end