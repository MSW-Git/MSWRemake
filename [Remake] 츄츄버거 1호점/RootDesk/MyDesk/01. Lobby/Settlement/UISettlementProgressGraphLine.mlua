@Component
script UISettlementProgressGraphLine extends Component

	property Entity FillArea = nil

	property Entity MonthText = nil

	property Entity Minus = nil

	property Entity BestText = nil

	property Entity Selected = nil

	property any SettlementData = nil

	property Vector2 originRectSize = Vector2(0,0)

	@ExecSpace("ClientOnly")
	method void Init()
		-- 그래프 라인 UI 컴포넌트를 초기화하는 함수
		self.FillArea = self.Entity:GetChildByName("FillArea")
		self.MonthText = self.Entity:GetChildByName("MonthText")
		self.Minus = self.Entity:GetChildByName("Minus")
		self.BestText = self.Entity:GetChildByName("BestText")
		self.Selected = self.Entity:GetChildByName("Selected")
		
		self.originRectSize = self.Entity.Parent.ScrollLayoutGroupComponent.CellSize
	end

	@ExecSpace("ClientOnly")
	method void Refresh(SettlementData settlementData, boolean isSelected, boolean isInteractable, string parentEntity)
		-- 정산 데이터에 따라 그래프 라인을 갱신하는 함수
		if self.FillArea == nil then
			self:Init()
		end
		
		self.SettlementData = settlementData
		
		self.MonthText.Enable = false
		self.Minus.Enable = false
		self.BestText.Enable = false
		self.Selected.Enable = false
		
		self.Entity.CanvasGroupComponent.Interactable = isInteractable
		
		if settlementData == nil then
			self.FillArea.UITransformComponent.RectSize = Vector2(self.originRectSize.x, 0)
			self.Entity.CanvasGroupComponent.Interactable = false
			return
		end
		
		self.MonthText.Enable = true
		self.MonthText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Month_Format", settlementData.Month)
		
		local recipeEarning = settlementData.P_RecipeTotal
		local bestRecord = _UserService.LocalPlayer.PlayerSettlement.BestRecipeEarnings
		if recipeEarning >= bestRecord then
			if parentEntity == "Settlement" then
				if _SettlementUIService.UISettlement.UISettlementPanel.IsDrawedBestText == false then
					_SettlementUIService.UISettlement.UISettlementPanel.IsDrawedBestText = true
					self.BestText.Enable = true
				end
			elseif parentEntity == "Record" then
				if _SettlementUIService.UISettlementRecord.UISettlementRecord.IsDrawedBestText == false then
					_SettlementUIService.UISettlementRecord.UISettlementRecord.IsDrawedBestText = true
					self.BestText.Enable = true
				end
			end
		end
		
		local isMinusBudget = settlementData.IsMinusBudget
		if isMinusBudget == nil then
			isMinusBudget = 0
		end
		
		if isMinusBudget == 1 then
			self.Minus.Enable = true
		end
		
		local maxValue = math.max(bestRecord, _SettlementUIService.GraphHightMin)
		local ratio = recipeEarning/maxValue
		self.FillArea.UITransformComponent.RectSize = Vector2(self.originRectSize.x, self.originRectSize.y * ratio)
		
		if isSelected then
			self.Selected.Enable = true
		end
	end

end