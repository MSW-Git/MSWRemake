@Logic
script SettlementUIService extends Logic

	property Entity UISettlement = "8725f3e8-d2ae-4d06-8d4d-69e709f3a8a7"

	property integer DrawMonthCount = 6

	property integer GraphHightMin = 10000

	property Entity UISettlementRecord = "b0728cb2-f4f9-45ed-be80-9ee85634bb70"

	@ExecSpace("Client")
	method void OpenUISettlement(SettlementData settlementData)
		-- 정산 UI 패널을 열어주는 함수
		self.UISettlement.UISettlementPanel:Open(settlementData)
	end

	@ExecSpace("Client")
	method void ForceCloseUISettlement()
		-- 정산 UI 패널을 강제로 닫는 함수
		self.UISettlement.UISettlementPanel:ForceClose()
	end

end