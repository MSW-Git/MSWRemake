@Component
script UIStoreInfoRecordPage extends Component

	property TextComponent MonthlyEarnings = nil

	property TextComponent MonthlyMaintenance = nil

	property TextComponent MonthlyCustomer = nil

	property TextComponent MonthlyBurger = nil

	property TextComponent MonthlyWage = nil

	property TextComponent MonthlyStoreManaging = nil

	property TextComponent CustomerCountTitle = nil

	property TextComponent BurgerCountTitle = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 UI 요소들을 초기화하는 함수
		self.MonthlyEarnings = self.Entity:GetChildByName("ItemMonthlySalesMoney"):GetChildByName("Value").TextComponent
		self.MonthlyMaintenance = self.Entity:GetChildByName("ItemMonthlyMaintenaceCost"):GetChildByName("Value").TextComponent
		self.MonthlyWage = self.Entity:GetChildByName("ItemMonthlyWage"):GetChildByName("Value").TextComponent
		self.MonthlyStoreManaging = self.Entity:GetChildByName("ItemMonthlyStoreManaging"):GetChildByName("Value").TextComponent
		self.MonthlyCustomer = self.Entity:GetChildByName("ItemMonthlyCustomerCount"):GetChildByName("Value").TextComponent
		self.MonthlyBurger = self.Entity:GetChildByName("ItemMonthlyBurgerCount"):GetChildByName("Value").TextComponent
		
		self.CustomerCountTitle = self.Entity:GetChildByName("ItemMonthlyCustomerCount").TextComponent
		self.BurgerCountTitle = self.Entity:GetChildByName("ItemMonthlyBurgerCount").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void RefreshData(SettlementData settlementData)
		-- 정산 데이터를 바탕으로 상점 기록 페이지를 갱신하는 함수
		local player = _UserService.LocalPlayer
		
		local earnings = settlementData:ReturnEarnings()
		local recipeTotal = settlementData.P_RecipeTotal
		self.MonthlyEarnings.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Meso_Format", _StringUtilLogic:ReturnThousandsSeparatedString(recipeTotal).." ")
		
		local wage = settlementData.M_AccumSalary
		if wage == nil then
			wage = 0
		end
		local storeManaging = settlementData.M_AccumMaintenance
		if storeManaging == nil then
			storeManaging = 0
		end
		self.MonthlyWage.Text = "-".._LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Meso_Format", _StringUtilLogic:ReturnThousandsSeparatedString(wage).." ")
		self.MonthlyStoreManaging.Text = "-".._LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Meso_Format", _StringUtilLogic:ReturnThousandsSeparatedString(storeManaging).." ")
		
		local maintenance = wage + storeManaging
		self.MonthlyMaintenance.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Meso_Format", _StringUtilLogic:ReturnThousandsSeparatedString(maintenance).." ")
		
		
		
		local customer = settlementData.CustomerCount
		local burger = settlementData.BurgerCount
		
		self.MonthlyCustomer.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("People_Format", _StringUtilLogic:ReturnThousandsSeparatedString(customer).." ")
		self.MonthlyBurger.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Things_Format", _StringUtilLogic:ReturnThousandsSeparatedString(burger).." ")
		self.CustomerCountTitle.Text = string.format("%s :", _GetLocalizationTextLogic:GetText("HUDStoreInfo1CustomerCount"))
		self.BurgerCountTitle.Text = string.format("%s :", _GetLocalizationTextLogic:GetText("HUDStoreInfo1BurgerCount"))
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEmployeeDetailChangeEvent(EmployeeDetailChangeEvent event)
		-- 직원 상세 정보 변경 이벤트를 처리하는 핸들러
		if self.Entity.Enable then
			local player = _UserService.LocalPlayer
			player.PlayerSettlement:RequestSyncSettlementDataFromServer()
		end
	end

end