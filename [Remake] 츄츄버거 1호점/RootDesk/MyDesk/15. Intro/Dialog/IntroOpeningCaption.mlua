@Component
script IntroOpeningCaption extends Component

	property boolean IsPrinting = false

	property number PrintingRepeatTimer = 0

	property string TargetText = ""

	property table RichTextTable = {}

	property integer Const_PrintRepeatVelocity = 10

	property string CaptionText = ""

	property string CaptionTextModel = "model://6535f1bd-f1fc-4ebb-8b81-19d3d929bfb9"

	property table CaptionTexts = {}

	property integer CaptionTextCount = 0

	property integer CaptionTextNum = 0

	property table CaptionEntities = {}

	property integer StartSlowDownTextNum = 2

	@ExecSpace("ClientOnly")
	method void Init()
		-- 인트로 오프닝 캡션을 초기화하고 텍스트 엔티티들을 생성하는 함수
		table.clear( self.CaptionTexts )
		table.clear( self.CaptionEntities )
		local text1 = _LocalizationService:GetText("IntroCaptionText1") 
		local text2 = _LocalizationService:GetText("IntroCaptionText2")
		local text3 = _LocalizationService:GetText("IntroCaptionText3")
		local text4 = _LocalizationService:GetText("IntroCaptionText4")
		local text5 = _LocalizationService:GetText("IntroCaptionText5")
		
		table.insert( self.CaptionTexts , text1 )
		table.insert( self.CaptionTexts , text2 )
		table.insert( self.CaptionTexts , text3 )
		table.insert( self.CaptionTexts , text4 )
		table.insert( self.CaptionTexts , text5 )
		
		self.CaptionTextCount = #self.CaptionTexts
		self.CaptionTextNum = 0
		
		for i = 1 , self.CaptionTextCount do
			local textEntity = _SpawnService:SpawnByModelId( self.CaptionTextModel , "CaptionText"..tostring(i) , Vector3.zero , self.Entity )
			textEntity:SetEnable(false)
			self.CaptionEntities[i] = textEntity
		end
		
		self.Entity:SetEnable(true)
		self:SetData()
	end

	@ExecSpace("ClientOnly")
	method void SetData()
		-- 다음 캡션 텍스트 데이터를 설정하고 타이핑 효과를 시작하는 함수
		self.CaptionTextNum = self.CaptionTextNum + 1
		
		if self.CaptionTextNum > self.CaptionTextCount then
			local endOpening = function()
				_IntroDialogLogic:EndIntroOpeningCaption()
			end
			_TimerService:SetTimerOnce( endOpening , 1)
			return
		end
		self.CaptionText = self.CaptionTexts[self.CaptionTextNum]
		
		if _UtilLogic:IsNilorEmptyString( self.CaptionText ) then
			self:OnPrintEnd()
		end
		
		self.PrintingRepeatTimer = 0
		
		
		
		self.IsPrinting = true
		
		if self.CaptionTextNum == 1 then
			_SoundService:PlayLoopSound( _ResourceManager.SFXTable["KeyboardTyping"], 1)
		elseif self.CaptionTextNum > 1 then
			_SoundService:ResumeSound(_ResourceManager.SFXTable["KeyboardTyping"])
		end
		
		self.CaptionEntities[self.CaptionTextNum].TextComponent.Text = ""
		self.CaptionEntities[self.CaptionTextNum]:SetEnable(true)
		local definitionResult = _DialogDataLogic:ChangeDefinitionWord(self.CaptionText)
		self.TargetText = definitionResult.targetText
		self.RichTextTable = definitionResult.richTextTable
		
		
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnPrintEnd()
		-- 현재 캡션의 타이핑 효과를 종료하고 다음 캡션으로 넘어가는 함수
		self.IsPrinting = false
		
		if self.CaptionTextNum < self.CaptionTextCount then
			_SoundService:PauseSound(_ResourceManager.SFXTable["KeyboardTyping"])
		elseif self.CaptionTextNum >= self.CaptionTextCount then
			_SoundService:StopSound(_ResourceManager.SFXTable["KeyboardTyping"])
		end
		self.CaptionEntities[self.CaptionTextNum].TextComponent.Text =  _DialogDataLogic:SetHighlight(self.TargetText,self.RichTextTable)
		
			
		if self.CaptionTextNum >= (self.CaptionTextCount - self.StartSlowDownTextNum) then	
			
			local afterWait = function()
				self:SetData()	
			end
			_TimerService:SetTimerOnce( afterWait , 0.8)
			
		elseif self.CaptionTextNum < (self.CaptionTextCount - self.StartSlowDownTextNum) then
			
			local afterWait = function()
			self:SetData()
			end
			_TimerService:SetTimerOnce( afterWait , 0.2)
		end
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 캡션을 닫고 모든 텍스트 엔티티들을 초기화하는 함수
		self.Entity:SetEnable(false)
		
		for i = 1 , self.CaptionTextCount do
			self.CaptionEntities[i].TextComponent.Text = ""
			self.CaptionEntities[i]:SetEnable(false)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 타이핑 효과를 업데이트하는 함수
		if not self.IsPrinting then
			return
		end
		
		if delta == 0 then
			delta = 0.01667
		end
		self.PrintingRepeatTimer += delta
		
		local len = math.ceil(self.PrintingRepeatTimer * self.Const_PrintRepeatVelocity)
		if len - 1 > utf8.len(self.TargetText) then
			self:OnPrintEnd()
			return
		end
		
		local offset = utf8.offset(self.TargetText,len) -1
		local text = string.sub(self.TargetText,1,offset)
		self.CaptionEntities[self.CaptionTextNum].TextComponent.Text = _DialogDataLogic:SetHighlight(text,self.RichTextTable)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 캡션 엔티티를 비활성화하는 함수
		self.Entity:SetEnable(false)
	end

end