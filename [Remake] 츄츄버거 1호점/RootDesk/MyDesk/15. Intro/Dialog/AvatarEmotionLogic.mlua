@Logic
script AvatarEmotionLogic extends Logic

	@ExecSpace("ClientOnly")
	method any GetEmotionType(string type)
		-- 문자열 감정 타입을 EmotionalType 열거형으로 변환하는 함수
		if type == "Idle" or type == "idle" or type == "Default" or type == "default" then
			
			return EmotionalType.Default
		
		elseif type == "Hit" then
			return EmotionalType.Hit
			
		elseif type == "Smile" then
			return EmotionalType.Smile
					
		elseif type == "Troubled" then
			return EmotionalType.Troubled
			
		elseif type == "Cry" then
			return EmotionalType.Cry
			
		elseif type == "Angry" then
			return EmotionalType.Angry
			
		elseif type == "Bewildered" then
			return EmotionalType.Bewildered
			
		elseif type == "Stunned" then
			return EmotionalType.Stunned
			
		elseif type == "Vomit" then
			return EmotionalType.Vomit
			
		elseif type == "Oops" then
			return EmotionalType.Oops
			
		elseif type == "Cheers" then
			return EmotionalType.Cheers
			
		elseif type == "Chu" then
			return EmotionalType.Chu
			
		elseif type == "Wink" then
			return EmotionalType.Wink
			
		elseif type == "Pain" then
			return EmotionalType.Pain
			
			
		elseif type == "Glitter" then
			return EmotionalType.Glitter
			
		elseif type == "Despair" then
			return EmotionalType.Despair
			
		elseif type == "Love" then
			return EmotionalType.Love
			
		elseif type == "Shine" then
			return EmotionalType.Shine
			
		elseif type == "Blaze" then
			return EmotionalType.Blaze
			
		elseif type == "Hum" then
			return EmotionalType.Hum
			
			
		elseif type == "Bowing" then
			return EmotionalType.Bowing
			
		elseif type == "Hot" then
			return EmotionalType.Hot
			
			
		elseif type == "Dam" then
			return EmotionalType.Dam
			
		elseif type == "qBlue" then
			return EmotionalType.qBlue
		end
		
	end

end