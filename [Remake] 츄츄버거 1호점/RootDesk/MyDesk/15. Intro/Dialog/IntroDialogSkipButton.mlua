@Component
script IntroDialogSkipButton extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 스킵 버튼 클릭 시 현재 다이얼로그 상태에 따라 적절한 스킵 동작을 수행하는 핸들러
		
		local Entity = event.Entity
		
		if self.Entity.Enable == false then return end
		
		if _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.IntroDialogId1 then 
			
			_IntroDialogLogic:SkipIntroDialog1()
			
		elseif _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.ActionPlayCutSceneIntro then
			
			local onOk = function()
				_IntroDialogLogic:SkipCutScene()		
			end
		
			local titleText = _GetLocalizationTextLogic:GetText("IntroCutSceneSkipPopupTitle")
			local descText = _GetLocalizationTextLogic:GetText("IntroCutSceneSkipPopupDesc")
					
			_UIPopup:Open( descText, onOk , nil ,titleText ) 	
				
			
		elseif _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.IntroDialogId2 then 	
			
			_IntroDialogLogic:SkipIntroDialog2()
			
		elseif _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.OutroDialogId1 then 
			
			_IntroDialogLogic:EndOutro()
		
		else
			_UIDialogLogic:GetNextLine("Skip")
			
		end
		
		
	end

end