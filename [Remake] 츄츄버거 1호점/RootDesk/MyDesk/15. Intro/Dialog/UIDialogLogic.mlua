@Logic
script UIDialogLogic extends Logic

	property any CallbackFunc = nil

	property Entity DialogPanel = nil

	property table CurDialogData = {}

	property boolean OnDialog = false

	@ExecSpace("Client")
	method void MakeDialog(string id, any callback)
		-- 다이얼로그를 생성하고 시작하는 함수
		self:Init()
		
		self._T.nowEventId = id
		
		_ResourceLoadLogic:AvatarResourcesUnload("CustomAvatarDataSet")
		_ResourceLoadLogic:AvatarResourcesLoad("CustomAvatarDataSet", function()  end)
		
		self.CurDialogData = _DialogDataLogic:GetDialogTable(id)
		local firstLineId = _DialogDataLogic:GetFirstLineId(id)
		
		local data = self.CurDialogData[firstLineId]
		self.DialogPanel.UIDialogPanel:Open(data)
		
		self.CallbackFunc = callback
		self.OnDialog = true
		
		local player = _UserService.LocalPlayer
		if player.CurrentMapName ~= player.PlayerDialog.IntroMapName then
			
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
			self:SetHUDOnDialog(self.OnDialog)
		end
		
		if id == _IntroDialogLogic.IntroDialogId1 then
			
		
			local enableSkip = function()
				_IntroDialogLogic.SkipButton:SetEnable(true)	
			end
			_TimerService:SetTimerOnce( enableSkip , 3)
			
		end
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 다이얼로그 시스템을 초기화하는 함수
		if _IntroDialogLogic.DialogGroup.Enable == false then
			_IntroDialogLogic:EnableUIDialogGroup(true)
		end
		
		if isvalid(self.DialogPanel) then
			return
		end
		self.DialogPanel =  _EntityService:GetEntityByPath("/ui/NewDialogGroup/UIDialog")
		
		self.DialogPanel.UIDialogPanel:Init()
	end

	@ExecSpace("ClientOnly")
	method void GetNextLine(string nextId)
		-- 다음 다이얼로그 라인으로 진행하거나 다이얼로그를 종료하는 함수
		
		if _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.IntroDialogId1 then
			
			if nextId == _IntroDialogLogic.IntroPictureShowDialogId then
				_IntroDialogLogic:DialogDimFade(true,3)
				_IntroDialogLogic:ShowPickture()
			end
		end
		
		if self.CurDialogData[nextId] then
			self.DialogPanel.UIDialogPanel:SetData(self.CurDialogData[nextId])
		else
			self:EndDialog(nextId)
			
			if _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.IntroDialogId1 then
				_IntroDialogLogic:SkipPictureShow()
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void EndDialog(string lastSelect)
		-- 다이얼로그를 종료하고 콜백 함수를 호출하는 함수
		self.DialogPanel.UIDialogPanel:Close()
		self.OnDialog = false
		local player = _UserService.LocalPlayer
		if player.CurrentMapName ~= player.PlayerDialog.IntroMapName then
			self:SetHUDOnDialog(self.OnDialog)
		end
		
		if self.CallbackFunc then
			local lastFunc = self.CallbackFunc
			self.CallbackFunc(lastSelect)
			if lastFunc == self.CallbackFunc then 
				self.CallbackFunc = nil
			end
		end
		
		local stageStartDialog = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage).DialogInProgress[0]
		if player.PlayerStage.NowStage == 2 and self._T.nowEventId == stageStartDialog then
			_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.EnterStage2)
		end
		
		self._T.nowEventId = ""
	end

	@ExecSpace("ClientOnly")
	method void SetHUDOnDialog(boolean enable)
		-- 다이얼로그 상태에 따라 HUD와 UI 요소들의 표시 상태를 설정하는 함수
		_UIGroupManager:EnableLobbyHUDGroup(not enable)
		_UIGroupManager.MoneyBarGroup:SetEnable(not enable)
		
		_IntroDialogLogic:DialogDimFade(enable,1)
		if enable == true then
			
			local enableSkipBtn = function()
				_IntroDialogLogic.SkipButton:SetEnable(true)
			end
			_TimerService:SetTimerOnce(enableSkipBtn , 3)
		else	
			_IntroDialogLogic.SkipButton:SetEnable(false)
			_IntroDialogLogic:ResetActor()
			_IntroDialogLogic:EnableUIDialogGroup(false)
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		end
		
		if enable == true then
			_UIGroupManager:EnableToastLobbyGroup(not enable)
		end
		
		
	end

end