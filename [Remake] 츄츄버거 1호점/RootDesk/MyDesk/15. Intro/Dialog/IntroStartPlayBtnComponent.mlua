@Component
script IntroStartPlayBtnComponent extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 게임 시작 버튼 클릭 시 인트로를 종료하고 게임을 시작하는 핸들러
		
		local Entity = event.Entity
		
		if self.Entity.Enable == false then return end
		
		if _IntroDialogLogic.CurrentDialogId == _IntroDialogLogic.IntroDialogId2 then 
			_IntroDialogLogic:EndIntro()
		end
		
	end

end