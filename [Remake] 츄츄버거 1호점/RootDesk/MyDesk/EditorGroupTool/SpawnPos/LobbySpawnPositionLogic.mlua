@Logic
script LobbySpawnPositionLogic extends Logic

	property table CustomerWaitSeatGroup = {}

	property table CustomerExitTempGroup = {}

	property table CustomerEnterGroup = {}

	property table CustomerBeforeEnterGroup = {}

	property table EmployeeUseKitchenAppPosGroup = {}

	property table DisplayOffset = {}

	property table ExpansionTileGroup = {}

	property string rowString = "row"

	property string colString = "col"

	property string xString = "x"

	property string yString = "y"

	property string typeString = "type"

	property string indexString = "index"

	property string dirString = "dir"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 모든 스폰 위치 데이터를 로드
		self:LoadRowColDataSet(self.CustomerWaitSeatGroup, "CustomerWaitSeatGroupDataSet")
		self:LoadRowColDataSet(self.CustomerExitTempGroup, "CustomerExitTempGroupDataSet")
		self:LoadRowDataSet(self.CustomerEnterGroup, "CustomerEnterGroupDataSet")
		self:LoadRowDataSet(self.CustomerBeforeEnterGroup, "CustomerBeforeEnterGroupDataSet")
		self:LoadKitchenAppDataSet(self.EmployeeUseKitchenAppPosGroup, "EmployeeUseKitchenAppPosGroupDataSet")
		self:LoadKitchenAppDataSet(self.DisplayOffset, "DisplayOffsetDataSet")
		self:LoadExpansionTileGroupDataSet()
	end

	@ExecSpace("ClientOnly")
	method void LoadRowColDataSet(table targetTable, string dataSetName)
		-- 행과 열 구조를 가진 데이터셋을 테이블에 로드
		local dataset = _DataService:GetTable(dataSetName)
		
		local rows = dataset:GetAllRow()
		for i, v in pairs(rows) do
			local row = math.tointeger(tonumber(v:GetItem(self.rowString)))
			local col = math.tointeger(tonumber(v:GetItem(self.colString)))
			local x = tonumber(v:GetItem(self.xString))
			local y = tonumber(v:GetItem(self.yString))
			
			if targetTable[row] == nil then
				targetTable[row] = {}
			end
			
			targetTable[row][col] = FastVector3(x, y, 0)
		end
	end

	@ExecSpace("ClientOnly")
	method void LoadRowDataSet(table targetTable, string dataSetName)
		-- 행 구조만 가진 데이터셋을 테이블에 로드
		local dataset = _DataService:GetTable(dataSetName)
		
		local rows = dataset:GetAllRow()
		for i, v in pairs(rows) do
			local row = math.tointeger(tonumber(v:GetItem(self.rowString)))
			local x = tonumber(v:GetItem(self.xString))
			local y = tonumber(v:GetItem(self.yString))
			targetTable[row] = FastVector3(x, y, 0)
		end
	end

	@ExecSpace("ClientOnly")
	method void LoadKitchenAppDataSet(table targetTable, string dataSetName)
		-- 주방기기 타입과 인덱스를 기준으로 데이터셋을 테이블에 로드
		local dataset = _DataService:GetTable(dataSetName)
		
		local rows = dataset:GetAllRow()
		for i, v in pairs(rows) do
			local type = v:GetItem(self.typeString)
			local index = math.tointeger(tonumber(v:GetItem(self.indexString)))
			local x = tonumber(v:GetItem(self.xString))
			local y = tonumber(v:GetItem(self.yString))
			
			if targetTable[type] == nil then
				targetTable[type] = {}
			end
			
			targetTable[type][index] = FastVector3(x, y, 0)
		end
	end

	@ExecSpace("ClientOnly")
	method void LoadExpansionTileGroupDataSet()
		-- 확장 타일 그룹 데이터를 3차원 구조로 로드
		local dataset = _DataService:GetTable("ExpansionTileGroupDataSet")
		
		local rows = dataset:GetAllRow()
		for i, v in pairs(rows) do
			local type = v:GetItem(self.typeString)
			local index = math.tointeger(tonumber(v:GetItem(self.indexString)))
			local dir = v:GetItem(self.dirString)
			local x = tonumber(v:GetItem(self.xString))
			local y = tonumber(v:GetItem(self.yString))
			
			if self.ExpansionTileGroup[type] == nil then
				self.ExpansionTileGroup[type] = {}
			end
			
			if self.ExpansionTileGroup[type][index] == nil then
				self.ExpansionTileGroup[type][index] = {}
			end
			
			self.ExpansionTileGroup[type][index][dir] = FastVector3(x, y, 0)
		end
	end

	@ExecSpace("ClientOnly")
	method void ResetCustomerWaitSeatGroup(number counter, number waiting, number x, number y)
		-- 고객 대기석 그룹의 특정 위치를 업데이트
		self.CustomerWaitSeatGroup[math.tointeger(counter)][math.tointeger(waiting)].x = x
		self.CustomerWaitSeatGroup[math.tointeger(counter)][math.tointeger(waiting)].y = y
	end

	@ExecSpace("ClientOnly")
	method void ResetEmployeeUseKitchenAppPosGroup(string type, integer index, Vector3 newPos)
		-- 직원이 주방기기를 사용할 위치를 업데이트
		if type == nil then
			return
		end
		
		if self.EmployeeUseKitchenAppPosGroup[type] == nil then
			return
		end
		
		self.EmployeeUseKitchenAppPosGroup[type][math.tointeger(index)] = newPos
	end

	method void ResetDisplayOffset(string type, integer index, Vector3 newPos)
		-- 디스플레이 오프셋 위치를 업데이트
		if type == nil then
			return
		end
		
		if self.DisplayOffset[type] == nil then
			return
		end
		
		self.DisplayOffset[type][math.tointeger(index)] = newPos
	end

end