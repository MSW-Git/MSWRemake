@Logic
script SpawnPosEditorLogic extends Logic

	@ExecSpace("ClientOnly")
	method void CustomerWaitSeatGroup()
		-- 고객 대기석 그룹의 위치 정보를 데이터셋에 저장
		local dataSetName = "CustomerWaitSeatGroupDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/CustomerWaitSeatGroup")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local row = math.tointeger((i-1) / 6 + 1)
			local col = math.tointeger((i-1) % 6 + 1)
			local x = v.TransformComponent.Position.x
			local y = v.TransformComponent.Position.y
			_EditorService:DataSetSetCell(dataSetName, i, "row", tostring(row))
			_EditorService:DataSetSetCell(dataSetName, i, "col", tostring(col))
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	method void CustomerExitTempGroup()
		-- 고객 임시 퇴장 그룹의 위치 정보를 데이터셋에 저장
		local dataSetName = "CustomerExitTempGroupDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/CustomerExitTempGroup")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local row = math.tointeger((i-1) / 2 + 1)
			local col = math.tointeger((i-1) % 2 + 1)
			local x = v.TransformComponent.Position.x
			local y = v.TransformComponent.Position.y
		    _EditorService:DataSetInsertRow(dataSetName)
			_EditorService:DataSetSetCell(dataSetName, i, "row", tostring(row))
			_EditorService:DataSetSetCell(dataSetName, i, "col", tostring(col))
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	method void CustomerEnterGroup()
		-- 고객 입장 그룹의 위치 정보를 데이터셋에 저장
		local dataSetName = "CustomerEnterGroupDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/CustomerEnterGroup")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local row = i
			local x = v.TransformComponent.Position.x
			local y = v.TransformComponent.Position.y
		    _EditorService:DataSetInsertRow(dataSetName)
			_EditorService:DataSetSetCell(dataSetName, i, "row", tostring(row))
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	method void CustomerBeforeEnterGroup()
		-- 고객 입장 전 대기 그룹의 위치 정보를 데이터셋에 저장
		local dataSetName = "CustomerBeforeEnterGroupDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/CustomerBeforEnterGroup")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local row = i
			local x = v.TransformComponent.Position.x
			local y = v.TransformComponent.Position.y
		    _EditorService:DataSetInsertRow(dataSetName)
			_EditorService:DataSetSetCell(dataSetName, i, "row", tostring(row))
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	method void EmployeeUseKitchenAppPosGroup()
		-- 직원이 주방기기를 사용할 위치 정보를 데이터셋에 저장
		local dataSetName = "EmployeeUseKitchenAppPosGroupDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/EmployeeUseKitchenAppPosGroup")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local row = math.tointeger((i-1) / 15 + 1)
			local col = math.tointeger((i-1) % 15 + 1)
			local x = v.TransformComponent.WorldPosition.x
			local y = v.TransformComponent.WorldPosition.y
			
			local type = _KitchenAppEnumType.Counter
			if row == 2 then
				type = _KitchenAppEnumType.Display
			elseif row == 3 then
				type = _KitchenAppEnumType.Grill
			end
			
			_EditorService:DataSetSetCell(dataSetName, i, "type", type)
			_EditorService:DataSetSetCell(dataSetName, i, "index", tostring(col))
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	method void DisplayOffset()
		-- 디스플레이 오프셋 위치 정보를 데이터셋에 저장
		local dataSetName = "DisplayOffsetDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/DisplayOffset")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local row = math.tointeger((i-1) / 2 + 1)
			local col = math.tointeger((i-1) % 2 + 1)
			local x = v.TransformComponent.WorldPosition.x
			local y = v.TransformComponent.WorldPosition.y
			
			local type = _EmployeeTypeEnum.Cook
			if col == 2 then
				type = _EmployeeTypeEnum.Serving
			end
			
			_EditorService:DataSetSetCell(dataSetName, i, "type", type)
			_EditorService:DataSetSetCell(dataSetName, i, "index", tostring(row))
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	method void ExpansionTileGroup()
		-- 확장 타일 그룹의 위치 정보를 데이터셋에 저장
		local dataSetName = "ExpansionTileGroupDataSet"
		local parent = _EntityService:GetEntityByPath("/maps/Lobby_Stage_1/ExpansionTileGroup")
		
		local posEntites = parent.Children 
		
		for i,v in pairs(posEntites) do
			local _type = math.tointeger((i-1) / 12 + 1)
			local index = math.tointeger(((i-1) / 2) % 6) + 1
			local _dir = math.tointeger((i-1) % 2 + 1)
			local x = v.TransformComponent.WorldPosition.x
			local y = v.TransformComponent.WorldPosition.y
			
			local type = "Cash"
			if _type == 2 then
				type = "Kitchen"
			end
			
			local dir = "Bottom"
			if _dir == 2 then
				dir = "Top"
			end
			
			_EditorService:DataSetSetCell(dataSetName, i, "type", type)
			_EditorService:DataSetSetCell(dataSetName, i, "index", tostring(index))
			_EditorService:DataSetSetCell(dataSetName, i, "dir", dir)
			_EditorService:DataSetSetCell(dataSetName, i, "x", tostring(x))
			_EditorService:DataSetSetCell(dataSetName, i, "y", tostring(y))
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a0962e70-3938-4f04-90e5-51fdbefccb86")
	handler HandleButtonClickEditorEvent(ButtonClickEditorEvent event)
		-- 에디터 버튼 클릭 이벤트 처리
	end

end