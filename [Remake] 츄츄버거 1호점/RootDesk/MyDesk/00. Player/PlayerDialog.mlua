@Component
script PlayerDialog extends Component

	property string IntroMapName = "IntroMap"

	@ExecSpace("ServerOnly")
	method void OnMapEnter(Entity enteredMap)
		-- 인트로 맵 진입 시 인트로 다이얼로그를 시작하는 함수
		if enteredMap.Name == self.IntroMapName then
			
			_IntroDialogLogic:StartIntro(self.Entity.PlayerComponent.UserId)
			_IntroDialogLogic:SetIntroCamera(self.Entity.PlayerComponent.UserId)
			
		end
	end

end