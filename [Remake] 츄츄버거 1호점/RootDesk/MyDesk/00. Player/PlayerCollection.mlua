@Component
script PlayerCollection extends Component

	@TargetUserSync
	property SyncTable<integer, boolean> IngredientCollection

	@TargetUserSync
	property SyncTable<integer, boolean> BunCollection

	@TargetUserSync
	property SyncTable<integer, boolean> IngredientCollectionGetReward

	@TargetUserSync
	property SyncTable<integer, boolean> BunCollectionGetReward

	@TargetUserSync
	property SyncTable<integer, boolean> BunSkinCollection

	@TargetUserSync
	property SyncTable<integer, boolean> SideMenuCollection

	@TargetUserSync
	property SyncTable<integer, boolean> SideMenuChecked

	@TargetUserSync
	property SyncTable<integer, boolean> StrategyCollection

	property integer Version = 1

	@ExecSpace("ServerOnly")
	method void SaveToDB(table saveData)
		-- 수집 데이터를 데이터베이스에 저장하는 함수
		local dbTable = {}
		
		
		dbTable["IngredientCollection"] = _StringUtilLogic:IntBoolToString(self.IngredientCollection)
		dbTable["BunCollection"] = _StringUtilLogic:IntBoolToString(self.BunCollection)
		dbTable["BunSkinCollection"] = _StringUtilLogic:IntBoolToString(self.BunSkinCollection)
		dbTable["IngredientCollectionGetReward"] = _StringUtilLogic:IntBoolToString(self.IngredientCollectionGetReward)
		dbTable["BunCollectionGetReward"] = _StringUtilLogic:IntBoolToString(self.BunCollectionGetReward)
		dbTable["SideMenuCollection"] = _StringUtilLogic:IntBoolToString(self.SideMenuCollection)
		dbTable["SideMenuChecked"] = _StringUtilLogic:IntBoolToString(self.SideMenuChecked)
		dbTable["StrategyCollection"] = _StringUtilLogic:IntBoolToString(self.StrategyCollection)
		
		
		dbTable["Version"] = self.Version
		
		saveData["Collection"] = dbTable
	end

	@ExecSpace("ServerOnly")
	method void OnLoadedDataFromDB(table loadedData)
		-- 데이터베이스에서 수집 데이터를 로드하는 함수
		local dbTable = loadedData["Collection"]
		if dbTable == nil then
			dbTable = {}
		end
		
		local version = dbTable["Version"]
		if #table.keys(dbTable) > 0 then
			if self.Version == version then
				if dbTable["IngredientCollection"] then
					table.initialize(self.IngredientCollection, _StringUtilLogic:IntBoolToTable(dbTable["IngredientCollection"]))
				end
				
				if dbTable["BunCollection"] then
					table.initialize(self.BunCollection, _StringUtilLogic:IntBoolToTable(dbTable["BunCollection"]))
				end
				
				if dbTable["BunSkinCollection"] then
					table.initialize(self.BunSkinCollection, _StringUtilLogic:IntBoolToTable(dbTable["BunSkinCollection"]))
				end
				
				if dbTable["IngredientCollectionGetReward"] then
					table.initialize(self.IngredientCollectionGetReward, _StringUtilLogic:IntBoolToTable(dbTable["IngredientCollectionGetReward"]))
				end
				
				if dbTable["BunCollectionGetReward"] then
					table.initialize(self.BunCollectionGetReward, _StringUtilLogic:IntBoolToTable(dbTable["BunCollectionGetReward"]))
				end
				
				if dbTable["SideMenuCollection"] then
					table.initialize(self.SideMenuCollection, _StringUtilLogic:IntBoolToTable(dbTable["SideMenuCollection"]))
				end
				
				if dbTable["SideMenuChecked"] then
					table.initialize(self.SideMenuChecked, _StringUtilLogic:IntBoolToTable(dbTable["SideMenuChecked"]))
				end
				
				if dbTable["StrategyCollection"] then
					table.initialize(self.StrategyCollection, _StringUtilLogic:IntBoolToTable(dbTable["StrategyCollection"]))
				end
			else
				if dbTable["IngredientCollection"] then
					table.initialize(self.IngredientCollection, _UtilLogic:StringToTable(dbTable["IngredientCollection"]))
				end
				
				if dbTable["BunCollection"] then
					table.initialize(self.BunCollection, _UtilLogic:StringToTable(dbTable["BunCollection"]))
				end
				
				if dbTable["BunSkinCollection"] then
					table.initialize(self.BunSkinCollection, _UtilLogic:StringToTable(dbTable["BunSkinCollection"]))
				end
				
				if dbTable["IngredientCollectionGetReward"] then
					table.initialize(self.IngredientCollectionGetReward, _UtilLogic:StringToTable(dbTable["IngredientCollectionGetReward"]))
				end
				
				if dbTable["BunCollectionGetReward"] then
					table.initialize(self.BunCollectionGetReward, _UtilLogic:StringToTable(dbTable["BunCollectionGetReward"]))
				end
				
				if dbTable["SideMenuCollection"] then
					table.initialize(self.SideMenuCollection, _UtilLogic:StringToTable(dbTable["SideMenuCollection"]))
				end
				
				if dbTable["SideMenuChecked"] then
					table.initialize(self.SideMenuChecked, _UtilLogic:StringToTable(dbTable["SideMenuChecked"]))
				end
				
				if dbTable["StrategyCollection"] then
					table.initialize(self.StrategyCollection, _UtilLogic:StringToTable(dbTable["StrategyCollection"]))
				end
			end
			
			
		else
			table.clear(self.IngredientCollection)
			table.clear(self.BunCollection)
			table.clear(self.IngredientCollectionGetReward)
			table.clear(self.BunCollectionGetReward)
			table.clear(self.SideMenuCollection)
			table.clear(self.SideMenuChecked)
			table.clear(self.StrategyCollection)
		end
	end

	@ExecSpace("ServerOnly")
	method void AddIngredientCollection(integer ingreId)
		-- 재료 수집에 새로운 재료를 추가하는 함수
		local ingreData = _IngredientDataSetLogic:GetIngredientData(ingreId)
		if isvalid(ingreData) == false then
			return
		end
		
		if self.IngredientCollection[ingreId] == true then
			return
		end
		
		if ingreData.RelatedStage ~= 0 and ingreData.RelatedStage ~= self.Entity.PlayerStage.NowStage then
			return
		end
		
		self.IngredientCollection[ingreId] = true
		
		self:IngreCollectionFlowLog(ingreId, "Ingre")
	end

	@ExecSpace("ServerOnly")
	method void AddBunCollection(integer bunId)
		-- 번 수집에 새로운 번을 추가하는 함수
		local bunData = _IngredientDataSetLogic:GetBunData(bunId)
		if isvalid(bunData) == false then
			return
		end
		
		if self.BunCollection[bunId] == true then
			return
		end
		
		self.BunCollection[bunId] = true
		
		self:IngreCollectionFlowLog(bunId, "Bun")
	end

	@ExecSpace("Server")
	method void RequestGetIngredientCollectionReward(table ingreIds, boolean isTween, string source)
		-- 재료 수집 보상을 요청하는 함수
		if senderUserId ~= self.Entity.PlayerComponent.UserId then
			return
		end
		
		local rewardConfig = _GetConfigDataLogic:GetConfigNumDataByKey("IngreCollectionRewardDiamond")
		local totalAmount = rewardConfig * #ingreIds
		if self.Entity.PlayerInventory:IsItemOverMaxCount(_ItemDataEnum.DiaFree, totalAmount) > 0 then
			local itemData = _ItemDataSetLogic:GetItemData(_ItemDataEnum.DiaFree)
			_UIPurchasePopupLogic:OpenOverMaxCountPopup(itemData.Id, itemData.NameKey, itemData.MaxStackCount, nil, false, false, senderUserId)
			return
		end
		
		for _, ingreId in pairs(ingreIds) do
			local ingreData = _IngredientDataSetLogic:GetIngredientData(ingreId)
			if isvalid(ingreData) == false then
				return
			end
			
			if self.IngredientCollection[ingreId] == nil or self.IngredientCollection[ingreId] == false then
				return
			end
			
			if self.IngredientCollectionGetReward[ingreId] == true then
				return
			end
			
			self:GetIngredientCollectionReward(ingreId, isTween)
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_GainDia"], 1, self.Entity.PlayerComponent.UserId)
		if source == "GetAllRewardButton" and #ingreIds >= 1 then
			_UICollectionLogic:RequestPlayGetAllRewardBtnAnim(#ingreIds, self.Entity.PlayerComponent.UserId)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void GetIngredientCollectionReward(integer ingreId, boolean isTween)
		-- 재료 수집 보상을 지급하는 함수
		local rewardConfig = _GetConfigDataLogic:GetConfigNumDataByKey("IngreCollectionRewardDiamond")
		self.Entity.PlayerOutgameManager:ModifyDiamond(rewardConfig, false, "Ingredient Collection Reward", "Ingredient Collection popup")
		
		self.IngredientCollectionGetReward[ingreId] = true
		
		_UICollectionLogic:EnableIngreBunCollectionSlotRewardDot(ingreId, false, isTween, self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void RequestGetBunCollectionReward(table bunIds, boolean isTween, string source)
		-- 번 수집 보상을 요청하는 함수
		if senderUserId ~= self.Entity.PlayerComponent.UserId then
			return
		end
		
		local rewardConfig = _GetConfigDataLogic:GetConfigNumDataByKey("BunCollectionRewardDiamond")
		local totalAmount = rewardConfig * #bunIds
		if self.Entity.PlayerInventory:IsItemOverMaxCount(_ItemDataEnum.DiaFree, totalAmount) > 0 then
			local itemData = _ItemDataSetLogic:GetItemData(_ItemDataEnum.DiaFree)
			_UIPurchasePopupLogic:OpenOverMaxCountPopup(itemData.Id, itemData.NameKey, itemData.MaxStackCount, nil, false, false, senderUserId)
			return
		end
		
		for _, bunId in pairs(bunIds) do
			local bunData = _IngredientDataSetLogic:GetBunData(bunId)
			if isvalid(bunData) == false then
				return
			end
			
			if self.BunCollection[bunId] == nil or self.BunCollection[bunId] == false then
				return
			end
			
			if self.BunCollectionGetReward[bunId] == true then
				return
			end
			
			self:GetBunCollectionReward(bunId, isTween)
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_GainDia"], 1, self.Entity.PlayerComponent.UserId)
		if source == "GetAllRewardButton" and #bunIds >= 1 then
			_UICollectionLogic:RequestPlayGetAllRewardBtnAnim(#bunIds, self.Entity.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void GetBunCollectionReward(integer bunId, boolean isTween)
		-- 번 수집 보상을 지급하는 함수
		local rewardConfig = _GetConfigDataLogic:GetConfigNumDataByKey("IngreCollectionRewardDiamond")
		self.Entity.PlayerOutgameManager:ModifyDiamond(rewardConfig, false, "Bun Collection Reward", "Bun Collection popup")
		
		self.BunCollectionGetReward[bunId] = true
		
		_UICollectionLogic:EnableIngreBunCollectionSlotRewardDot(bunId, false, isTween, self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void RequestAddBunSkinCollection(integer bunSkinId)
		-- 번 스킨 수집 추가를 요청하는 함수
		local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(bunSkinId)
		if isvalid(bunSkinData) == false then
			return
		end
		
		if self.BunSkinCollection[bunSkinId] == true then
			return
		end
		
		if self:CheckCanGetBunSkin(bunSkinId) ~= 0 then
			return
		end
		
		self:AddBunSkinCollection(bunSkinId)
		
		local itemData = {}
		itemData[bunSkinData.RelatedItemId] = 0
		
		_UIItemRewardService:SetItemRewardUI(itemData, "Buy Bun Skin", self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void AddBunSkinCollection(integer bunSkinId)
		-- 번 스킨 수집에 새로운 스킨을 추가하는 함수
		self.BunSkinCollection[bunSkinId] = true
		
		self:IngreCollectionFlowLog(bunSkinId, "BunSkin")
	end

	@ExecSpace("ServerOnly")
	method integer CheckCanGetBunSkin(integer bunSkinId)
		-- 번 스킨 획득 가능 여부를 확인하는 함수
		local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(bunSkinId)
		if isvalid(bunSkinData) == false then
			return 9
		end
		
		if bunSkinData.GetCondition == "Buy" then
			local cost = tonumber(bunSkinData.ConditionValue)
			local result = self.Entity.PlayerOutgameManager:ModifyDiamond(-cost, false, "Buy bun skin", "Buy bun skin popup")
			if result == false then
				return 1
			end
			
		elseif bunSkinData.GetCondition == "StagePass" then
			
			
		elseif bunSkinData.GetCondition == "StageClear" then
			local stageId = tonumber(bunSkinData.ConditionValue)
			local isCleared = self.Entity.PlayerStage.StageProgress[stageId] >= _StageDataSetLogic:GetStageClearProgress(stageId)
			if isCleared == false then
				return 3
			end
			
		end
		
		return 0
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- 동기화된 속성 변경 시 UI 업데이트를 처리하는 함수
		if name == "BunSkinCollection" then
			if _UIGroupManager.IngreBunCollectionGroup.Enable then
				if _UICollectionLogic.uiIngreBunCollection.SelectTab == 3 then
					_UICollectionLogic.uiIngreBunCollection:RefreshList(_UICollectionLogic.uiIngreBunCollection.SelectTab, _UICollectionLogic.uiIngreBunCollection.NowSelected)
					_UICollectionLogic.uiIngreBunCollection:RefreshSubBar(_UICollectionLogic.uiIngreBunCollection.SelectTab)
					_UICollectionLogic.uiIngreBunCollection:RefreshCollectionProgress(_UICollectionLogic.uiIngreBunCollection.SelectTab)
				end
			end	
			
			if _UIGroupManager.RecipeGroup.Enable then
				if _UIEntityLogic_RecipeGroup.UIRecipeMaking.UIRecipeMaking.ResultEntities.Enable then
					local uiRecipeResult = _UIEntityLogic_RecipeGroup.UIRecipeMaking.UIRecipeMaking.ResultEntities.UIRecipeResult
					uiRecipeResult.UIRecipeBunSkinList.Detail:Refresh(uiRecipeResult.UIRecipeBunSkinList.NowSelected)
				end
			end
			
			_UILobbyManager:RefreshMenuInfo()
			
		elseif name == "IngredientCollectionGetReward" then
			if _UIGroupManager.IngreBunCollectionGroup.Enable then
				_UICollectionLogic.uiIngreBunCollection:CheckCanGetReward()
			end
			
			_UICollectionLogic:SetIngreBunCollectionMenuBtnRedDot()
			
		elseif name == "BunCollectionGetReward" then
			if _UIGroupManager.IngreBunCollectionGroup.Enable then
				_UICollectionLogic.uiIngreBunCollection:CheckCanGetReward()
			end
			
			_UICollectionLogic:SetIngreBunCollectionMenuBtnRedDot()
			
		elseif name == "IngredientCollection" then
			_UICollectionLogic:SetIngreBunCollectionMenuBtnRedDot()
			
		elseif name == "BunCollection" then
			_UICollectionLogic:SetIngreBunCollectionMenuBtnRedDot()
			
		elseif name == "SideMenuCollection" then
			if _UIGroupManager.StageInfoGroup.Enable == true and _StrategyDataSetLogic.UIStageSettingStrategy.Entity.Enable == true then
				_StrategyDataSetLogic.UIStageSettingStrategy:SetSelectTab(_StrategyDataSetLogic.UIStageSettingStrategy.SelectTab)
			end
			
		elseif name == "SideMenuChecked" then
			_StrategyDataSetLogic.UIStageSettingStrategy:RefreshSideMenuTabRedDot()
			
			
		end
	end

	@ExecSpace("ServerOnly")
	method void AddSideMenuCollection(integer sideMenuId)
		-- 사이드 메뉴 수집에 새로운 메뉴를 추가하는 함수
		self.SideMenuCollection[sideMenuId] = true
	end

	@ExecSpace("Server")
	method boolean RequestAddSideMenuCollection(integer sideMenuId, integer stageId)
		-- 사이드 메뉴 수집 추가를 요청하는 함수
		local smData = _StrategyDataSetLogic:GetSideMenuData(sideMenuId)
		if isvalid(smData) == false then
			return false
		end
		
		if self.SideMenuCollection[sideMenuId] == true then
			return false
		end
		
		if self:CheckCanGetSideMenu(sideMenuId) ~= 0 then
			return false
		end
		
		self:AddSideMenuCollection(sideMenuId)
		
		if stageId == nil then
			_UIItemRewardService:SetSideMenuRewardUI(sideMenuId, stageId, self.Entity.PlayerComponent.UserId) 
		end
		
		return true
	end

	@ExecSpace("ServerOnly")
	method integer CheckCanGetSideMenu(integer sideMenuId)
		-- 사이드 메뉴 획득 가능 여부를 확인하는 함수
		local smData = _StrategyDataSetLogic:GetSideMenuData(sideMenuId)
		if smData == nil then
			return 9
		end
		
		if _UtilLogic:IsNilorEmptyString(smData.OpenCondition) == false then
			if smData.OpenCondition == "StageClear" then
				local stageId = tonumber(smData.OpenConditionValue)
				
				if self.Entity.PlayerStage.StageProgress[stageId] == nil then
					return 2
				end	
				
				if self.Entity.PlayerStage.StageProgress[stageId] < _StageDataSetLogic:GetStageClearProgress(stageId) then
					return 2
				end
			end
		end
		
		if smData.GetCondition == "Buy" then
			local cost = tonumber(smData.GetConditionValue)
			local result = self.Entity.PlayerOutgameManager:ModifyDiamond(-cost, false, "Buy Sidemenu", "Buy Sidemenu Popup")
			if result == false then
				return 1
			end
			
		end
		
		return 0
	end

	@ExecSpace("Server")
	method void RequestSetSideMenuChecked(integer sideMenuId, boolean isChecked)
		-- 사이드 메뉴 확인 상태를 설정하는 함수
		local smData = _StrategyDataSetLogic:GetSideMenuData(sideMenuId)
		if smData == nil then
			return
		end
		
		if self.SideMenuChecked[sideMenuId] == isChecked then
			return
		end
		
		self.SideMenuChecked[sideMenuId] = isChecked
	end

	@ExecSpace("ServerOnly")
	method void IngreCollectionFlowLog(integer ingreId, string collectionType)
		-- 재료 수집 플로우 로그를 기록하는 함수
		local success,value = pcall(function()
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			
			_LogStorageLogic:LogValue(
				userId,
				_LogEnumType.IngreCollectionFlow,
				_HttpService:JSONEncode({
					total = tostring(self:GetCollectionRate(0)),
					ingredient = tostring(self:GetCollectionRate(1)),
					bun = tostring(self:GetCollectionRate(2)),
					bunSkin = tostring(self:GetCollectionRate(3))		
				}),
				{
					nickname = nickname,
					id = tostring(ingreId),
					collectionType = collectionType,
					playerStageId = tostring(self.Entity.PlayerStage.NowStage),
					playerLevel = self.Entity.PlayerStage:GetPlayerLastStageProgress()
				}
			)
		end)
		
		
		if not success then  end
	end

	method number GetCollectionRate(integer selectTab)
		-- 선택된 탭의 수집 완료율을 계산하여 반환하는 함수
		local totalCount = 0
		local userCount = 0
		
		local lastStage = _StageDataSetLogic:GetLastStageId()
		
		for id, _ in pairs(_IngredientDataSetLogic.IngredientData) do
			local ingreData = _IngredientDataSetLogic:GetIngredientData(id)
			if ingreData.RelatedStage > lastStage then
				continue
			end
			
			if selectTab == 0 or selectTab == 1 then 
				totalCount += 1
				if self.IngredientCollection[id] == true then
					userCount += 1
				end
			end
		end
		
		for id, _ in pairs(_IngredientDataSetLogic.BunData) do
			if selectTab == 0 or selectTab == 2 then 
				totalCount += 1
				if self.BunCollection[id] == true then
					userCount += 1
				end
			end
		end
		
		for id, _ in pairs(_IngredientDataSetLogic.BunSkinData) do
			if selectTab == 0 or selectTab == 3 then 
				totalCount += 1
				if self.BunSkinCollection[id] == true then
					userCount += 1
				end
			end
		end
		
		
		return math.floor((userCount / totalCount) * 100)/100
	end

	@ExecSpace("ServerOnly")
	method void AddStrategyCollection(integer strategyId)
		-- 전략 수집에 새로운 전략을 추가하는 함수
		self.StrategyCollection[strategyId] = true
	end

	@ExecSpace("Server")
	method boolean RequestAddStrategyCollection(integer strategyId)
		-- 전략 수집 추가를 요청하고 조건을 확인하는 함수
		local stData = _StrategyDataSetLogic:GetStrategyData(strategyId)
		if isvalid(stData) == false then
			return false
		end
		
		if self.StrategyCollection[strategyId] == true then
			return false
		end
		
		if self.Entity.PlayerStage.StageProgress[stData.UnlockStage] == nil then
			return false
		end
		
		if self.Entity.PlayerStage.StageProgress[stData.UnlockStage] < _StageDataSetLogic:GetStageClearProgress(stData.UnlockStage) then
			return false
		end
		
		self:AddStrategyCollection(strategyId)
		return true
	end

end