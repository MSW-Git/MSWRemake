	@ExecSpace("Server")
	method void RequestMenuLog(Entity player, SyncTable<integer, integer> lastMenu, SyncTable<integer, integer> curMenu)
		-- 메뉴 로그 기록을 요청하는 함수
		player.PlayerLog:MenuFlow(lastMenu,curMenu)
	end

	@ExecSpace("ServerOnly")
	method void MenuFlow(SyncTable<integer, integer> lastMenu, SyncTable<integer, integer> CurMenu)
		-- 메뉴 플로우 로그를 기록하는 함수
		local success,value = pcall(function()		
			local recipeTable = {} 
			for k,v in pairs (CurMenu) do
				
				---@type RecipeData
				local recipeData = self.Entity.PlayerRecipe.Recipes[v]
				
				table.insert(recipeTable,
				{
					recipeId = tostring(recipeData.UniqueId),
					recipeName = recipeData.Name,
					price = tostring(recipeData.Cost),
					tag = recipeData.Tag,				
					grade = tostring(_TasteGradeDataSetLogic:ReturnGradeDataByScore(recipeData.TasteScore).Index)
				})
			end
			
			local flowType  = ""
			if #table.keys(lastMenu) < #table.keys(CurMenu) then 
				flowType = "1"
			elseif #table.keys(lastMenu) > #table.keys(CurMenu) then 
				flowType = "2"
			elseif #table.keys(lastMenu) == #table.keys(CurMenu) then 
				flowType = "3"
			end
		
			local combo = self.Entity.PlayerRecipe.ActiveRecipeCombo
			local nowTrend = self.Entity.PlayerRecipe.NowTrend
			local logTrend = ""
			local start = true  
			for k,v in pairs(nowTrend) do 
				if start then 
					logTrend = string.format("%d",k)
					start = false
				else
					logTrend = logTrend..","..string.format("%d",k)			
				end
			end
			
			if _UtilLogic:IsNilorEmptyString(logTrend) == true then
				logTrend = "empty"
			end
			
		
			local nickname = self.Entity.PlayerComponent.Nickname
			local menuSlotCnt = tostring(_UpgradeDataSetLogic:ReturnCurrentPlayerValue(self.Entity, _UpgradeTypeEnum.DisplayCount))
			
			_LogStorageLogic:LogValue(
				self.Entity.PlayerComponent.UserId,
				_LogEnumType.MenuFlow,
			 	_HttpService:JSONEncode(recipeTable),
				{
					nickname = nickname,
					flowType = flowType,
					trendId = logTrend,
			   		recipeComboId = tostring(combo),
					menuSlotCnt = menuSlotCnt,
			    	manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel),
			    	manageIndex = self.Entity.PlayerManagement:GetGoalCount(),
					playerStageId = tostring(self.Entity.PlayerStage.NowStage)
				})
		end)
			
		if not success then  end
	end

	@ExecSpace("ServerOnly")
	method void EmployeeLocation(string employeeId, string locationBef, string locationAft, string flowType)
		-- 직원 위치 변경 로그를 기록하는 함수
		local logName = _LogEnumType.EmployeeLocation
		
		local logFail,value = pcall(
		function()
		
			local userId = self.Entity.PlayerComponent.UserId
			local manageLv = string.format("%d",self.Entity.PlayerManagement.ManagementLevel)
			local mangeIdx =  self.Entity.PlayerManagement:GetGoalCount()
			local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
				
			_LogStorageLogic:LogValue(userId,logName,locationAft,
				{
					employeeId = employeeId,
					flowType = flowType,
					locationBef = locationBef,
					manageLevel = manageLv, 
					manageIdx = mangeIdx,
					playerStageId = playerStageId,
				})
		end)
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void EmployeeFlow(string id, EmployeeDetailData detail, EmployeeData data, string source)
		-- 직원 플로우 로그를 기록하는 함수
		local logName = _LogEnumType.EmployeeFlow
		local userId = self.Entity.PlayerComponent.UserId
		local nickname = self.Entity.PlayerComponent.Nickname
		local profileCode = self.Entity.PlayerComponent.ProfileCode
		local outgameData = self.Entity.EmployeeManager:GetEmployeeOutgameDetail(id)
		local employeeLevel = detail:ReturnTypeLevel(userId) 
		local employeeName = data.NameKey
		local salary = self.Entity.EmployeeManager:ReturnEmployeeSalary(id, employeeLevel, userId)
		
		local skill1Grade = outgameData.Skill1Grade
		local skill2Grade = outgameData.Skill2Grade 
		local skillListString = string.format("(%s, %s), (%s, %s)", data.Skill1Type, skill1Grade, data.Skill2Type, skill2Grade)
		local equipLevel = tostring(outgameData.EquipLevel)
		if outgameData.EquipLevel < 0 then
			equipLevel = "empty"
		end
		
		local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
		
		local logFail,value = pcall(
		function()
		
			_LogStorageLogic:LogValue(userId, logName,
				_HttpService:JSONEncode({
					transferFee = "empty",
					employeeName = employeeName,
					salary = tostring(salary),
					skillList = skillListString
				 }),
				{
					nickname = nickname,
					employeeId = id,
					flowType = "1",
					source = source,
					manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel), 
					manageIndex = self.Entity.PlayerManagement:GetGoalCount(),
					date = self.Entity.TimeManager:GetTimeText(),
					playerStageId = playerStageId,
					equipLevel = equipLevel,
					utc = _DateTimeLogic:GetUtcNowText(),
					profileCode = profileCode,
					employeeType = data.Type,
					employeeLevel = tostring(employeeLevel)
						
				})
		end)
		
		if not logFail then  end
	end

	method string GetRewardStr(SyncTable<string, integer> reward)
		-- 보상 테이블을 문자열로 변환하는 함수
		local rewardStr = "empty"
		if reward ~= nil then
			for i = 1, #table.keys(reward) do
				local itemId = table.keys(reward)[i]
				local itemCount = reward[itemId]
				
				if rewardStr == "empty" then
					rewardStr = ""
				end
				
				rewardStr = rewardStr..string.format("%s,%d", itemId, itemCount)
				
				if i < #table.keys(reward) then
					rewardStr = rewardStr..","
				end
			end
		end
		
		return rewardStr
	end

	@ExecSpace("ServerOnly")
	method void ExchangeFlow(integer chuchuCard, integer burgerCard, integer friesCard, integer cokeCard, integer rewardBonusRate, integer reward, integer ingredientsCount, integer usedCost, integer rewardType)
		-- 교환 플로우 로그를 기록하는 함수
		local success,value = pcall(function()
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			local profileCode = self.Entity.PlayerComponent.ProfileCode
			local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
		
			_LogStorageLogic:LogValue( 
				userId,
			   _LogEnumType.ExchangeFlow,
				_HttpService:JSONEncode(
				{
					chuchuCard = chuchuCard,
					burgerCard = burgerCard,
					friesCard = friesCard,
					cokeCard = cokeCard,
					reward = reward
				}),
				{
					nickname = nickname,
					playerStageId = playerStageId,
					manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel), 
					ingredientsCount = tostring(ingredientsCount),
					usedCost = tostring(usedCost),
					rewardType = tostring(rewardType),
					utc = _DateTimeLogic:GetUtcNowText(),
					profileCode = profileCode,
					rewardBonusRate = tostring(rewardBonusRate)
				}
			)
		end)
		
		if not success then  end
	end

	@ExecSpace("ServerOnly")
	method void VerificationRecipe(table logValue)
		-- 레시피 검증 로그를 기록하는 함수
		local success,value = pcall(function()
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
		
			_LogStorageLogic:LogValue( 
				userId,
			   _LogEnumType.VerificationRecipe,
				_HttpService:JSONEncode(logValue),
				{
					nickname = nickname,
					playerStageId = playerStageId,
					manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel)
				}
			)
		end)
		
		if not success then  end
	end

	method string GetArrayStr(table tb)
		-- 테이블을 배열 문자열로 변환하는 함수
		local result = {}
		for k, v in pairs(tb) do
			table.insert(result, string.format("(%s, %s)", k, v))
		end
		
		local total = table.concat(result, ",")
		
		return total
	end

end