@Component
script PlayerLog extends Component

	property string Recipe = "2"

	property string Training = "2"

	property string AutoTraining = "2"

	property string VipOrder = "2"

	property string Trial = "2"

	property table CategoryFlowType = {}

	property string CurCategory = ""

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 로그 카테고리 플로우 타입을 초기화하는 함수
		table.clear(self.CategoryFlowType)
		self.CategoryFlowType[_LogSourceEnumType.Recipe] = "2"
		self.CategoryFlowType[_LogSourceEnumType.AutoTraining] = "2"
		self.CategoryFlowType[_LogSourceEnumType.Training] = "2"
		self.CategoryFlowType[_LogSourceEnumType.Trial] = "2"
	end

	@ExecSpace("ServerOnly")
	method void PlayflowLog(string category, string flowType)
		-- 플레이 플로우 로그를 기록하는 함수
		if not isvalid(self.Entity) then return end 
		
		self.CurCategory = category 
		self.CategoryFlowType[category] = flowType
		
		local userId = self.Entity.PlayerComponent.UserId
		local logName = _LogEnumType.PlayFlow
		
		local manageLv = string.format("%d", self.Entity.PlayerManagement.ManagementLevel)
		local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
		local money = string.format("%d",self.Entity.PlayerInventory.Money)
		local arcaneSymbol = string.format("%d",self.Entity.PlayerInventory.ArcaneSymbol)
		local heart = string.format("%d",self.Entity.PlayerInventory.Heart)
		local lunchBox = string.format("%d",self.Entity.PlayerInventory.LunchBox)
		local diamond = string.format("%d",self.Entity.PlayerOutgameManager:GetDiamondCount(userId))
		
		local deviceType = "Mobile"
		if  Environment:IsPCPlatform() then 
			deviceType = "PC"
		end
		local playerLevel = self.Entity.PlayerStage:GetPlayerLastStageProgress(userId)
		local stageId = tostring(self.Entity.PlayerStage.NowStage)
		
		local logFail,value = pcall(
			
		function()
				
			_LogStorageLogic:LogValue(userId, logName, 
				_HttpService:JSONEncode({
					money = money,
					clover = arcaneSymbol,
					heart = heart,
					lunchBox = lunchBox,
					diamond = diamond }),
				{
					category = category,
					flowType = flowType,
					deviceType = deviceType,
					playerLevel =  playerLevel,
					stageId = stageId,
					manageLevel = manageLv,
					manageIndex = manageIdx,
					id = "empty"
				})
		
		end)
		
		if not logFail then  end
		
	end

	@ExecSpace("ServerOnly")
	method void ResourceFlow(string logValue, string resourceFlowType, string resourceName, string resourceChangeCnt, string resourceAfterCnt, string resourceMakerDefineTag, string mapName)
		-- 리소스 플로우 로그를 기록하는 함수
		local logName = _LogEnumType.ResourceFlow
		local userId = self.Entity.PlayerComponent.UserId
		local nickname = self.Entity.PlayerComponent.Nickname
		local profileCode = self.Entity.PlayerComponent.ProfileCode
		local itemTarget = "empty" 
		local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
		
		
		local logFail, value = pcall(
			
		function()
				
		local playerLevel = self.Entity.PlayerStage:GetPlayerLastStageProgress(userId) 
		local utc = _DateTimeLogic:GetUtcNowText()
		
			_LogStorageLogic:LogValue(userId,logName,logValue,
			    {
					nickname = nickname,
			        resourceType = "1",
			        resourceFlowType = resourceFlowType,
			        resourceName = resourceName,
					resourceBeforeCnt = logValue,
			        resourceChangeCnt = resourceChangeCnt,
			        resourceAfterCnt = resourceAfterCnt,
			        resourceMakerDefineTag = resourceMakerDefineTag,
			        mapName = mapName,
			        playerLevel = playerLevel,
					itemTarget = itemTarget,
					playerStageId = playerStageId,
					utc = utc,
					profileCode = profileCode
			    }
			)
				
		end)
		
		
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void ItemFlow(string logValue, string resourceFlowType, string resourceName, string resourceChangeCnt, string resourceAfterCnt, string resourceMakerDefineTag, string mapName, string targetChuchuId)
		-- 아이템 플로우 로그를 기록하는 함수
		local userId = self.Entity.PlayerComponent.UserId
		local logName = _LogEnumType.ResourceFlow
		local nickname = self.Entity.PlayerComponent.Nickname
		local profileCode = self.Entity.PlayerComponent.ProfileCode
		local itemTarget = "empty" 
		if not _UtilLogic:IsNilorEmptyString(targetChuchuId) then
			itemTarget = targetChuchuId
		end
		
		
		local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
		local logFail, value = pcall(
			
		function()
				
		local playerLevel = self.Entity.PlayerStage:GetPlayerLastStageProgress(userId) 
		local utc = _DateTimeLogic:GetUtcNowText()
		
			_LogStorageLogic:LogValue(userId,logName,logValue,
			    {
					nickname = nickname,
			        resourceType = "2",
			        resourceFlowType = resourceFlowType,
			        resourceName = resourceName,
					resourceBeforeCnt = logValue,
			        resourceChangeCnt = resourceChangeCnt,
			        resourceAfterCnt = resourceAfterCnt,
			        resourceMakerDefineTag = resourceMakerDefineTag,
			        mapName = mapName,
			        playerLevel = playerLevel,
					itemTarget = itemTarget,
					playerStageId = playerStageId,
					utc = utc,
					profileCode = profileCode
			    }
			)
				
		end)
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void ConnectFlow(string flowType, string mapType)
		-- 연결 플로우 로그를 기록하는 함수
		local logName = _LogEnumType.ConnectFlow
		if not isvalid(self.Entity) then return end
		 
		local logFail,value = pcall(
			
		function()
				
		local userId = self.Entity.PlayerComponent.UserId
		local nickName = self.Entity.PlayerComponent.Nickname
		
		
		
				
			
		local manageName = {"Sprout","Bronze","Silver","Gold","Ruby","Platinum"}
		local manageLv
				
		local mangeIdx
		local playerLevel
				
		if mapType =="Lobby" then 
				
			manageLv = self.Entity.PlayerManagement.ManagementLevel
			
			mangeIdx =  self.Entity.PlayerManagement:GetGoalCount()
			playerLevel = manageName[manageLv].."_"..mangeIdx
					
		else
					
			playerLevel = "empty"
					
		end
		
				_LogStorageLogic:LogValue(userId,logName,nickName,
				    {
				        connectFlowType = flowType,
				        mapName = mapType,
				        playerLevel = playerLevel,
				        worldEnterTicketFlag= "empty"
				    }
				)
			end)
			
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void AutoTrainingFlow(AutoTrainingSlotData slotData, table reward, string flowType)
		-- 자동 훈련 플로우 로그를 기록하는 함수
		local logName = _LogEnumType.AutoTrainingFlow
		
		local logFail,value = pcall(
			
		function()
				
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			local manageLevel = string.format("%d",self.Entity.PlayerManagement.ManagementLevel)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
				
			local chuchuId = slotData.ChuchuId 
			local chuchuSkill1 = _EmployeeService:GetData(chuchuId).Skill1Type
			local outgameDetail = self.Entity.EmployeeManager:GetEmployeeOutgameDetail(chuchuId, userId)
			local chuchuSkill1Grade = tostring(outgameDetail.Skill1Grade)
		
			_LogStorageLogic:LogValue(userId,logName,_HttpService:JSONEncode(reward),
				{
					nickname = nickname,
					employeeId = chuchuId, 
					flowType = flowType,
					employeeSkill1 = chuchuSkill1,
					employeeSkill1Grade = chuchuSkill1Grade,
					manageLevel = manageLevel,
					manageIdx = manageIdx
				})
			
		end)
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void RecipeFlow(string flowType, string grade, string tag, string burgerStack, string bunSkinId, table logValue)
		-- 레시피 플로우 로그를 기록하는 함수
		local success,value = pcall(function()
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			
			local manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
			local date = self.Entity.TimeManager:GetTimeText()
			local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
			
			_LogStorageLogic:LogValue( userId,_LogEnumType.RecipeFlow,_HttpService:JSONEncode(logValue),
			{		
				nickname = nickname,
				flowType = flowType,
			    grade = grade,
			    tag = tag,
			    burgerStack = burgerStack,
				bunSkinId = bunSkinId,
			    manageLevel= manageLevel,
			    manageIndex= manageIdx,
			    date = date,
				playerStageId = playerStageId
			})
		end)
		
		if not success then  end
	end

	@ExecSpace("ServerOnly")
	method void UpgradeFlow(string level, string typeId, string tabCategory, string levelBefore)
		-- 업그레이드 플로우 로그를 기록하는 함수
		local userId = self.Entity.PlayerComponent.UserId
		local nickname = self.Entity.PlayerComponent.Nickname
		local profileCode = self.Entity.PlayerComponent.ProfileCode
		
		local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
		local date = self.Entity.TimeManager:GetTimeText()
		
		
		local logFail,value = pcall(function()
			_LogStorageLogic:LogValue( 
				userId,
		    	_LogEnumType.UpgradeFlow,
				level,
				{
					nickname = nickname,
					upgradeType = typeId,
					category = tabCategory,
					manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel),
					manageIndex = manageIdx,
					date = date,
					playerStageId = tostring(self.Entity.PlayerStage.NowStage),
					utc = _DateTimeLogic:GetUtcNowText(),
					profileCode = profileCode,
					levelAfter = level,
					levelBefore = levelBefore
				}
			)
		end)
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void EmployeeUpgradeFlow(EmployeeDetailData detail, string source, string location, EmployeeData data)
		-- 직원 업그레이드 플로우 로그를 기록하는 함수
		local logName = _LogEnumType.EmployeeUpgradeFlow
		
		local logFail,value = pcall(
		function()
		
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			local manageLevel = string.format("%d",self.Entity.PlayerManagement.ManagementLevel)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
			local date = self.Entity.TimeManager:GetTimeText()
			local skill1type = _EmployeeSkillService:GetData(data.Skill1Type).Type
			local skill2type = _EmployeeSkillService:GetData(data.Skill2Type).Type
			local chuchuLevel = tostring(detail:ReturnTypeLevel(userId))
			local chuchuExp = tostring(detail:ReturnTypeExp(userId))
			local outgameData = self.Entity.EmployeeManager:GetEmployeeOutgameDetail(detail.Id)
			local skill1Grade = tostring(outgameData.Skill1Grade)
			local skill2Grade = tostring(outgameData.Skill2Grade)
			local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
			
			local equipLevel = tostring(outgameData.EquipLevel)
			if outgameData.EquipLevel < 0 then
				equipLevel = "empty"
			end
			local overlimitLevel = tostring(detail.OverLimitLevel)	
				
			_LogStorageLogic:LogValue(userId,logName,
				_HttpService:JSONEncode({
					chuchuLevel = chuchuLevel,
					chuchuExp = chuchuExp,
					skill1Grade = skill1Grade,
					skill2Grade = skill2Grade
				}),
				{
					nickname = nickname,
					employeeId = detail.Id,
					source = source, 
					location = location,
					employeeType = data.Type,
					skill1Type = skill1type,
					skill2Type = skill2type,
					manageLevel = manageLevel,
					manageIndex = manageIdx,
					playerStageId = playerStageId,
					equipLevel = equipLevel,
					overlimitLevel = overlimitLevel
				})
		end)
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void EmployeeOvelimitFlow(string employeeId, string overlimitLevelBefore, string flowType)
		-- 직원 한계돌파 플로우 로그를 기록하는 함수
		local logName = _LogEnumType.EmployeeOverLimitFlow
		
		local logFail,value = pcall(
		function()
		
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			local manageLevel = string.format("%d",self.Entity.PlayerManagement.ManagementLevel)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
			local date = self.Entity.TimeManager:GetTimeText()
				
			local data = _EmployeeService:GetData(employeeId)
			local detail = self.Entity.EmployeeManager:GetEmployeeDetail(employeeId)
			local outgameData = self.Entity.EmployeeManager:GetEmployeeOutgameDetail(employeeId)
				
			local chuchuMaxLevel = tostring(_EmployeeService:ReturnMaxLevelByOverLimitLevel(detail.OverLimitLevel, userId))
			local skill1type = _EmployeeSkillService:GetData(data.Skill1Type).Type
			local skill2type = _EmployeeSkillService:GetData(data.Skill2Type).Type
			local chuchuLevel = tostring(detail:ReturnTypeLevel(userId))
				
			local skill1Grade = outgameData.Skill1Grade
			local skill2Grade = outgameData.Skill2Grade 
			local skillListString = string.format("(%s, %s), (%s, %s)", data.Skill1Type, skill1Grade, data.Skill2Type, skill2Grade)
				
			local playerStageId = tostring(self.Entity.PlayerStage.NowStage)
			local overlimitLevel = tostring(detail.OverLimitLevel)	
				
			_LogStorageLogic:LogValue(userId,logName,
				_HttpService:JSONEncode({
					chuchuLevel = chuchuLevel,
					chuchuMaxLevel = chuchuMaxLevel,
					overlimitLevelBefore = overlimitLevelBefore,
					overlimitLevelAfter = overlimitLevel,
					skillList = skillListString
				}),
				{
					nickname = nickname,
					flowType = flowType,
					employeeId = employeeId,
					employeeType = data.Type,
					skill1Type = skill1type,
					skill2Type = skill2type,
					playerStageId = playerStageId
				})
		end)
		
		if not logFail then  end
	end

	@ExecSpace("ServerOnly")
	method void RankFlow(integer rank, integer rankingScore, string flowType, SyncTable<string, integer> reward)
		-- 랭킹 플로우 로그를 기록하는 함수
		local success,value = pcall(function()
		
			local userId = self.Entity.PlayerComponent.UserId
			local nickname = self.Entity.PlayerComponent.Nickname
			local profileCode = self.Entity.PlayerComponent.ProfileCode
			
			local manageLevel = tostring(self.Entity.PlayerManagement.ManagementLevel)
			local manageIdx = self.Entity.PlayerManagement:GetGoalCount()
			local year = string.format("%d",self.Entity.TimeManager.Utc.Year)
			
			_LogStorageLogic:LogValue(
				userId,
				_LogEnumType.RankFlow,
				self:GetRewardStr(reward),
				{
					nickname = nickname,
					flowType = flowType,
					manageLevel = manageLevel,
					manageIndex = manageIdx,
					rankYear = year,
					ranking = tostring(rank),
					rankingScore = tostring(rankingScore),
					playerStageId = tostring(self.Entity.PlayerStage.NowStage),
					playerLevel = self.Entity.PlayerStage:GetPlayerLastStageProgress(),
					utc = _DateTimeLogic:GetUtcNowText(),
					profileCode = profileCode
				}
			)
		end)
		
		if not success then  end
	end

