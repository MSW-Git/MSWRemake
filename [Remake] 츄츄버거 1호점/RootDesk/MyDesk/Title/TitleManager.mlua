@Component
script TitleManager extends Component

	property string Dest_LobbyEntityPath = "/maps/Lobby/SpawnPosGroup/EmployeeWaitCook"

	property string Dest_IntroEntityPath = "/maps/IntroMap/IntroCameraGroup/DialogStartView"

	property string Dest_TitleEntityPath = "/maps/TitleMap/TeleportPoint"

	property string UserPlayType = "2"

	@ExecSpace("ServerOnly")
	method void OnMapEnter(Entity enteredMap)
		-- 타이틀 맵 진입 시 초기화 및 UI 활성화
		if enteredMap.Name == "TitleMap" then
			self.UserPlayType = "1"
			local userId = self.Entity.PlayerComponent.UserId
			
		    self:PassCheckServer()
			self:OpenTitleUI(userId)
		end
	end

	@ExecSpace("Server")
	method void ReadyForEnterToWorld(boolean isIntroMap)
		-- 월드 진입 준비 및 다음 맵 결정
		local userId = self.Entity.PlayerComponent.UserId
		local nextMapName = "Lobby"
		
		if isIntroMap then
			nextMapName = "Lobby"
		elseif self:PassCheckServer() == false then 
			nextMapName = self.Entity.PlayerDialog.IntroMapName
		end
		
		_GetLocalizationTextLogic:RequestSetLocalizedTextServer(userId)
		self:ShowFade(nextMapName, userId)
	end

	@ExecSpace("Server")
	method boolean PassCheckServer()
		-- 인트로 시청 여부를 확인하여 버튼 상태 설정
		if self.Entity.PlayerOutgameManager.HasSeenIntro == true then
			self:SetButtonAfterCheckPass(true)
			return true
		else
			self:SetButtonAfterCheckPass(false)
			return false
		end
	end

	@ExecSpace("Client")
	method void SetButtonAfterCheckPass(boolean HasPass)
		-- 패스 체크 결과에 따른 버튼 상태 설정
		_UIGroupManager.TitleUIGroup.UITitle:SetButtonScroll(HasPass)
	end

	@ExecSpace("Client")
	method void OpenTitleUI()
		-- 타이틀 UI 활성화 및 리소스 프리로드
		_UIGroupManager.TitleUIGroup.UITitle:TitleUIOn()
		_UIGroupManager:EnableLobbyHUDGroup(false)
		
		_ResourceService:PreloadTileSetAsync("tileset://9c83666b-7388-4664-a444-3ee19e1e7980", function()  end)
		_ResourceService:PreloadTileSetAsync("tileset://660f086b-019f-4423-8d9a-874099926c53", function()  end)
		_ResourceService:PreloadTileSetAsync("tileset://362cff79-7315-493d-bf04-1656dfb05207", function()  end)
	end

	@ExecSpace("ServerOnly")
	method void ResetData()
		-- 플레이어 데이터 초기화 및 추방 처리
		local userId = self.Entity.PlayerComponent.UserId
		
		
		local errorcode = _DataStorageService:DeleteUserDataStorageAndWait(userId)
		
		
		_UIToast:ShowMessage("데이터가 삭제되었습니다. 잠시 후 추방되니 재접속 부탁드립니다.", userId)
		
		_TimerService:SetTimerOnce(function()
		    _UserService:KickUser(userId, KickReason.ETC)
		end, 2)
	end

	@ExecSpace("Server")
	method void RequestResetDataFromClient()
		-- 클라이언트에서 데이터 초기화 요청 처리
		self:ResetData()
	end

	@ExecSpace("Client")
	method void ShowFade(string nextMapName)
		-- 페이드 효과와 함께 다음 맵으로 이동
		if _UserService.LocalPlayer ~= self.Entity then
			return
		end
		
		if self.Entity.PlayerAdmin.IsAdmin == true then
			self.Entity.PlayerAdmin:RequestAdminCheatBtnEnable(false)
		end
		
		
		_FadeService:ShowFade("EnterMap")
		
		_TimerService:SetTimerOnce(function() 
			_UIGroupManager.TitleUIGroup.UITitle:TitleUIOff()
			self:MoveToNextMap(nextMapName) 
		end, 1)
	end

	@ExecSpace("Server")
	method void MoveToNextMap(string nextMapName)
		-- 맵 이름에 따른 목적지 경로 설정 및 텔레포트
		
		local destPath = ""
		if nextMapName == "Lobby" then
			local nowStage = self.Entity.PlayerStage.NowStage
			local mapName = self.Entity.PlayerStage:ReturnMapName(nowStage)
			destPath = string.format("/maps/%s/SpawnPosGroup/EmployeeWaitCook", mapName)
			
		elseif nextMapName == self.Entity.PlayerDialog.IntroMapName then
			destPath = self.Dest_IntroEntityPath
		elseif nextMapName == "Title" then
			destPath = self.Dest_TitleEntityPath
		end
		
		
		_TeleportService:TeleportToEntityPath(self.Entity, destPath)
		_FadeService:HideFade(self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDataFixButton(boolean enable)
		-- 데이터 수정 버튼 활성화/비활성화
		_UIGroupManager.TitleUIGroup.UITitle:EnableFixDataButton(enable)
	end

	@ExecSpace("Client")
	method void SetDataResetButton(boolean enable)
		-- 데이터 리셋 버튼 활성화/비활성화
		local dataResetBtn = _UIGroupManager.TitleUIGroup.UITitle.ResetDataButton
		dataResetBtn.Enable = enable
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키 입력 이벤트를 처리하는 핸들러
		
		local key = event.key
		if key == KeyboardKey.Alpha1 then 
			_TeleportService:TeleportToEntityPath(self.Entity, self.Dest_TitleEntityPath)
		end
	end

end