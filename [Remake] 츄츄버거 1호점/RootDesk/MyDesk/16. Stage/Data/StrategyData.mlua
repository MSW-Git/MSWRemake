@Struct
script StrategyData

	property integer Id = 0

	property string IconRUID = ""

	property integer MaxLevel = 0

	property SyncTable<integer, number> LevelEffect

	property string EffectType = ""

	property SyncTable<integer> RecommendedStage

	property integer SPCost = 0

	property integer UnlockStage = 0

	property string NameKey = ""

	property string DescKey = ""

	property string EffectDescKey = ""

	method void Load(any dataTable, integer index)
		-- CSV 데이터를 읽어서 전략 데이터를 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = tonumber(row:GetItem("Id"))
		self.NameKey = row:GetItem("NameKey")
		self.DescKey = row:GetItem("DescKey")
		self.IconRUID = row:GetItem("IconRUID")
		self.MaxLevel = tonumber(row:GetItem("MaxLevel"))
		self.SPCost = tonumber(row:GetItem("SPCost"))
		self.UnlockStage = tonumber(row:GetItem("UnlockStage"))
		
		table.clear(self.LevelEffect)
		for i = 1, self.MaxLevel do
			local effect = row:GetItem("Effect"..i)
			if isvalid(effect) == false then
				continue
			end
			
			self.LevelEffect[i] = tonumber(effect)	
		end
		
		self.EffectType = row:GetItem("EffectType")
		self.EffectDescKey = row:GetItem("EffectDescKey")
		
		local recommendedStage = row:GetItem("RecommendedStage")
		if _UtilLogic:IsNilorEmptyString(recommendedStage) == false then
			local split = _UtilLogic:Split(recommendedStage, ",")
			for i = 1, #split do
				table.insert(self.RecommendedStage, tonumber(split[i]))
			end
		end
	end

	method number GetLevelEffect(integer level, integer stageId)
		-- 전략의 레벨과 스테이지에 따른 효과 수치를 계산하여 반환하는 함수
		if level == 0 then
			return 0
		end
		
		
		if self.Id == _StrategyEnum.StartWithGold then
			local stageConfigData = _BalanceDataSetLogic:GetStageConfigData(stageId)
			local stageData = _StageDataSetLogic:GetStageData(stageId)
			if stageConfigData == nil or stageData == nil then
				return 0
			end
			
			local earningLevelData = stageData:GetStageEarningLevelData(stageConfigData.StrategyStartWithGoldEarningLevel)
			
			return earningLevelData.BestRecipeEarnings * self.LevelEffect[level]	
		else
			
			return self.LevelEffect[level]
		end
	end

end