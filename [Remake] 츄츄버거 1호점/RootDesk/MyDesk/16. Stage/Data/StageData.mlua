@Struct
script StageData

	property integer StageId = 0

	property string RecipeTrialId = ""

	property string IconRUID = ""

	property string BadgeIconRUID = ""

	property string StageClearIconRUID = ""

	property integer StageClearRewardDiamond = 0

	property boolean HideSlot = false

	property boolean ComingSoon = false

	property table StageEarningLevelData = {}

	property table StageRankingData = {}

	property SyncTable<integer, string> UpgradeKitchenLevelCondition

	property SyncTable<integer, integer> UpgradeGrillLevelCost

	property SyncTable<integer, integer> UpgradeCounterLevelCost

	property string RivalType = ""

	property string RivalTypeValue = ""

	property SyncTable<integer, string> DialogInProgress

	property string RivalStoreNameKey = ""

	property string RivalCharNameKey = ""

	property string DecoType = ""

	property string DecoTopSmall = ""

	property string DecoBottomSmall = ""

	property string StagePhotoRUID = ""

	property string StageIconBGRUID = ""

	property string StageNameEng = ""

	property string DecoTopBig = ""

	property string DecoBottomBig = ""

	property string ChustarChatIconRUID = ""

	property number RivalPosY = 0

	property table StageManagementData = {}

	property integer EmployeeInitLevel = 0

	property table ReputationManagementData = {}

	property table VIPOrderRequirementData = {}

	property table VIPOrderRecipeRewardData = {}

	property table LessThen1YearCustomerOrderTags = {}

	property string Bgm = ""

	property string NameKey = ""

	property string DescKey = ""

	method void Load(any dataTable, integer index)
		-- CSV 데이터를 읽어서 스테이지 데이터를 로드하고 관련 데이터들을 초기화하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.StageId = tonumber(row:GetItem("StageId"))
		self.NameKey = row:GetItem("NameKey")
		self.DescKey = row:GetItem("DescKey")
		
		self.RecipeTrialId = row:GetItem("RecipeTrialId")
		self.IconRUID = row:GetItem("IconRUID")
		self.BadgeIconRUID = row:GetItem("BadgeIconRUID")
		self.StageClearIconRUID = row:GetItem("StageClearIconRUID")
		self.ChustarChatIconRUID = row:GetItem("ChustarChatIconRUID")
		self.StageClearRewardDiamond = tonumber(row:GetItem("StageClearRewardDiamond"))
		self.HideSlot = _StringUtilLogic:GetBoolByString(row:GetItem("HideSlot"), false)
		self.ComingSoon = _StringUtilLogic:GetBoolByString(row:GetItem("ComingSoon"), false)
		self.Bgm = row:GetItem("Bgm")
		
		self.DecoType = row:GetItem("DecoType")
		self.DecoTopSmall = row:GetItem("DecoTopSmall")
		self.DecoBottomSmall = row:GetItem("DecoBottomSmall")
		self.DecoTopBig = row:GetItem("DecoTopBig")
		self.DecoBottomBig = row:GetItem("DecoBottomBig")
		
		self.StagePhotoRUID = row:GetItem("StagePhotoRUID")
		self.StageIconBGRUID = row:GetItem("StageIconBGRUID")
		self.StageNameEng = row:GetItem("StageNameEng")
		
		self.EmployeeInitLevel = tonumber(row:GetItem("EmployeeInitLevel"))
		
		table.clear(self.LessThen1YearCustomerOrderTags)
		
		local recipeTag = _UtilLogic:Split(row:GetItem("LessThen1YearCustomerOrderTags"), ",")
		for _, tag in pairs(recipeTag) do
			table.insert(self.LessThen1YearCustomerOrderTags, tag)
		end
		
		local seDataSet = _DataService:GetTable("EarningLevelStage"..self.StageId)
		if isvalid(seDataSet) then
			for i = 1, seDataSet:GetRowCount() do
				local seData = StageEarningLevelData()
				seData:Load(seDataSet, i)
				
				if self.StageEarningLevelData[seData.EarningLevel] ~= nil then
					break
				end
				
				self.StageEarningLevelData[seData.EarningLevel] = seData
			end
		end
		
		local rkDataSet = _DataService:GetTable("StoreRankingRewardData")
		if isvalid(rkDataSet) then
		    for i = 1, rkDataSet:GetRowCount() do
		        local rkRow = rkDataSet:GetRow(i)
		        if tonumber(rkRow:GetItem("StageId")) ~= self.StageId then
		            continue
		        end
		        
		        local rkData = StoreRankingRewardData()
		        rkData:Load(rkRow)
		        
		        if self.StageRankingData[rkData.Index] ~= nil then
		            break
		        end
		        
		        self.StageRankingData[rkData.Index] = rkData
		        
		    end
		end
		
		local mgDataSet = _DataService:GetTable("ManagementGoalData")
		if isvalid(mgDataSet) then
			local levelTable = {}
			
			for i = 1, mgDataSet:GetRowCount() do
				local mgRow = mgDataSet:GetRow(i)
				if tonumber(mgRow:GetItem("Stage")) ~= self.StageId then
					continue
				end
				
				local level = tonumber(mgRow:GetItem("Level"))
				if levelTable[level] == nil then
					levelTable[level] = {}
				end
				table.insert(levelTable[level], mgRow)		
			end
			
			if #table.keys(levelTable) > 0 then
				for i = 1, _ManagementDataSetLogic.ManagementMaxLevel do
					local data = ManagementGoalData()
					
					data:Load(i, levelTable[i])
					
					if self.StageManagementData[data.Level] ~= nil then
						break
					end
					
					self.StageManagementData[data.Level] = data
				end
			end
		end
		
		local kLvDataSet = _DataService:GetTable("UpgradeKitchenLevelCondition")
		if isvalid(kLvDataSet) then
			local colName = string.format("ConditionValue%d", self.StageId)
			for i = 1, kLvDataSet:GetRowCount() do
				local kLvRow = kLvDataSet:GetRow(i)
				local level = tonumber(kLvRow:GetItem("Level"))
				local condition = kLvRow:GetItem(colName)
				if _UtilLogic:IsNilorEmptyString(condition) then
					continue
				end
				self.UpgradeKitchenLevelCondition[level] = condition
			end
		end
		
		local grillCostDataSet = _DataService:GetTable("UpgradeGrillLevelCostData")
		if isvalid(grillCostDataSet) then
			local colName = string.format("Cost%d", self.StageId)
			for i = 1, grillCostDataSet:GetRowCount() do
				local gCostRow = grillCostDataSet:GetRow(i)
				local level = tonumber(gCostRow:GetItem("Level"))
				local cost = gCostRow:GetItem(colName)
				if _UtilLogic:IsNilorEmptyString(cost) then
					break
				end
				
				self.UpgradeGrillLevelCost[level] = tonumber(cost)
			end
		end
		
		local counterCostDataSet = _DataService:GetTable("UpgradeCounterLevelCostData")
		if isvalid(counterCostDataSet) then
			local colName = string.format("Cost%d", self.StageId)
			for i = 1, counterCostDataSet:GetRowCount() do
				local cCostRow = counterCostDataSet:GetRow(i)
				local level = tonumber(cCostRow:GetItem("Level"))
				local cost = cCostRow:GetItem(colName)
				if _UtilLogic:IsNilorEmptyString(cost) then
					break
				end
				
				self.UpgradeCounterLevelCost[level] = tonumber(cost)
			end
		end
		
		local rmDataSet = _DataService:GetTable("ReputationManagementData")
		if isvalid(rmDataSet) then
			for i = 1, rmDataSet:GetRowCount() do
		        local rmRow = rmDataSet:GetRow(i)
		        if tonumber(rmRow:GetItem("StageId")) ~= self.StageId then
		            continue
		        end
		        
		        local rmData = ReputationManagementData()
				rmData:Load(rmDataSet, i)
				
				
				if self.ReputationManagementData[rmData.ManagementLevel] ~= nil then
		            break
				end
				
				self.ReputationManagementData[rmData.ManagementLevel] = rmData
		    end
		end
		
		local vqDataSet = _DataService:GetTable("VIPOrderRequirementData")
		if isvalid(vqDataSet) then
			for i = 1, vqDataSet:GetRowCount() do
				local vqRow = vqDataSet:GetRow(i)
				if tonumber(vqRow:GetItem("StageId")) ~= self.StageId then
					continue
				end
				
				local vqData = VIPOrderRequirementData()
				vqData:Load(vqDataSet, i)
				
				if self.VIPOrderRequirementData[vqData.ManagementLevel] == nil then
					self.VIPOrderRequirementData[vqData.ManagementLevel] = {}
				end
				
				if self.VIPOrderRequirementData[vqData.ManagementLevel][vqData.BurgerStack] ~= nil then
					break
				end
				
				self.VIPOrderRequirementData[vqData.ManagementLevel][vqData.BurgerStack] = vqData
			end
		end
		
		local vrDataSet = _DataService:GetTable("VIPOrderRecipeRewardData")
		if isvalid(vrDataSet) then
			for i = 1, vrDataSet:GetRowCount() do
				local vrRow = vrDataSet:GetRow(i)
				if tonumber(vrRow:GetItem("StageId")) ~= self.StageId then
					continue
				end
				
				local vrData = VIPOrderRecipeRewardData()
				vrData:Load(vrDataSet, i)
				
				if self.VIPOrderRecipeRewardData[vrData.ManagementLevel] ~= nil then
					break
				end
				
				self.VIPOrderRecipeRewardData[vrData.ManagementLevel] = vrData
			end
		end
		
		self.RivalType = row:GetItem("RivalType")
		self.RivalTypeValue = row:GetItem("RivalTypeValue")
		self.RivalStoreNameKey = row:GetItem("RivalStoreNameKey")
		self.RivalCharNameKey = row:GetItem("RivalCharNameKey")
		self.RivalPosY = tonumber(row:GetItem("RivalPosY"))
		
		for i = 0, 6 do
			local dialogKey = row:GetItem("DialogInProgress"..i)
			self.DialogInProgress[i] = dialogKey
		end
	end

	method StageEarningLevelData GetStageEarningLevelData(integer earningLevel)
		-- 수익 레벨에 해당하는 스테이지 수익 데이터를 반환하는 함수
		return self.StageEarningLevelData[earningLevel]
	end

	method StoreRankingRewardData GetStageRankingData(integer index)
		-- 인덱스에 해당하는 스테이지 랭킹 데이터를 반환하는 함수
		return self.StageRankingData[index]
	end

	method ReputationManagementData GetReputationManagementData(integer managementLevel)
		-- 경영 레벨에 해당하는 평판 관리 데이터를 반환하는 함수
		return self.ReputationManagementData[managementLevel]
	end

	method VIPOrderRequirementData GetVIPOrderRequirementData(integer managementLevel, integer burgerStack)
		-- 경영 레벨과 버거 스택에 해당하는 VIP 주문 요구사항 데이터를 반환하는 함수
		local requirementDatas = self.VIPOrderRequirementData[managementLevel]
		if isvalid(requirementDatas) == false then
			return nil
		end
		
		local minKey = 999
		local maxKey = 0
		for key, v in pairs(requirementDatas) do
			minKey = math.min(minKey, key)
			maxKey = math.max(maxKey, key)
		end
		
		if burgerStack < minKey then
			burgerStack = minKey
		elseif burgerStack > maxKey then
			burgerStack = maxKey
		end
		
		if self.VIPOrderRequirementData[managementLevel][burgerStack] == nil then
			return nil
		end
		
		return requirementDatas[burgerStack]
	end

	method VIPOrderRecipeRewardData GetVIPOrderRecipeRewardData(integer managementLevel)
		-- 경영 레벨에 해당하는 VIP 주문 레시피 보상 데이터를 반환하는 함수
		return self.VIPOrderRecipeRewardData[managementLevel]
	end

end