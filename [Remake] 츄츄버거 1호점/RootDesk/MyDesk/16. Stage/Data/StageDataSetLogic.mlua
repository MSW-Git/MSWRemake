@Logic
script StageDataSetLogic extends Logic

	property table StageData = {}

	property UIStageSelect UIStageSelect = "03dff792-4adf-4673-8717-3756b522866f"

	property UIStageSetting UIStageSetting = "e65b54f0-fa13-4678-a4b7-e03e879b5b19"

	property UIStageInfo UIStageInfo = "c2eacefd-4d13-4936-ad0e-a70f5cf88317"

	property integer LastStageNum = 9

	method void OnBeginPlay()
		-- 게임 시작 시 스테이지 데이터를 로드하는 함수
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- CSV에서 스테이지 데이터를 읽어와 초기화하는 함수
		table.clear(self.StageData)
		local dataSet = _DataService:GetTable("StageData")
		
		for i = 1, dataSet:GetRowCount() do
			local data = StageData()
			data:Load(dataSet, i)
			
			if self.StageData[data.StageId] ~= nil then
				break
			end
			
			self.StageData[data.StageId] = data
		end
		
		local stg0Data = StageData()
		stg0Data.BadgeIconRUID = "7a6fee7392974acbb7d565300f36798f" 
		stg0Data.IconRUID = "010d19b43d4448d49f220c2558028a3f" 
		stg0Data.NameKey = "StageName0" 
		stg0Data.StageId = 0
		self.StageData[stg0Data.StageId] = stg0Data
		
	end

	method StageData GetStageData(integer stageId)
		-- 스테이지 ID에 해당하는 스테이지 데이터를 반환하는 함수
		return self.StageData[stageId]
	end

	method table GetStageOnlyIngredient(integer stageId)
		-- 해당 스테이지에서만 얻을 수 있는 재료 목록을 반환하는 함수
		local stageIngre = {}
		
		for id, data in pairs(_IngredientDataSetLogic.IngredientData) do
			local ingreData = _IngredientDataSetLogic:GetIngredientData(id)
			
			if ingreData.RelatedStage == stageId then
				table.insert(stageIngre, id)
			end	
		end
		
		table.sort(stageIngre, function(a, b)
			local aGrade = _IngredientDataSetLogic:GetIngredientData(a).Grade
			local bGrade = _IngredientDataSetLogic:GetIngredientData(b).Grade
			return aGrade < bGrade	
		end)
		
		return stageIngre
	end

	method table GetStageTotalIngredient(integer stageId, Entity player)
		-- 해당 스테이지에서 사용 가능한 모든 재료 목록을 반환하는 함수
		local stageIngre = {}
		
		for id, data in pairs(_IngredientDataSetLogic.IngredientData) do
			local ingreData = _IngredientDataSetLogic:GetIngredientData(id)
			
			if ingreData.RelatedStage == 0 then
				table.insert(stageIngre, id)
				continue
			end
			
			if ingreData.RelatedStage == stageId then
				table.insert(stageIngre, id)
				
			else
				if player.PlayerCollection.IngredientCollection[id] == true then
					table.insert(stageIngre, id)
				end
			end
		end
		
		return stageIngre
	end

	method number GetStageCollectionRate(string enum, integer stageId, Entity player)
		-- 스테이지 컬렉션 수집률을 계산하여 반환하는 함수
		
		local stageEmployees = _EmployeeService:ReturnStageEmpIdList(stageId)
		local empTotalCount = #stageEmployees
		local empCollectCount = 0
		for i, empId in pairs(stageEmployees) do
			if player.ChuchuCollectionDB.ChuchuCollection[empId] == true then
				empCollectCount += 1
			end
		end
		local empRate = empCollectCount / empTotalCount
		
		if enum == _StageSettingEnum.Employee then
			return empRate
		end
		
		local stageIngredients = _StageDataSetLogic:GetStageOnlyIngredient(stageId)
		local ingreTotalCount = #stageIngredients
		local ingreCollectCount = 0
		for _, ingreId in pairs(stageIngredients) do
			if player.PlayerCollection.IngredientCollection[ingreId] == true then
				ingreCollectCount += 1
			end
		end
		
		if enum == _StageSettingEnum.Ingredient then
			return ingreCollectCount / ingreTotalCount
		end
		
		local collectionRate = (empCollectCount + ingreCollectCount) / (empTotalCount + ingreTotalCount)
		return collectionRate
	end

	method integer GetLastStageId()
		-- 현재 열려있는 마지막 스테이지 ID를 반환하는 함수
		local lastStageId = 1
		for stgId, data in pairs(self.StageData) do
			local stgData = self:GetStageData(stgId)
			
			if stgData.HideSlot == true or stgData.ComingSoon == true then
				break
			end
			
			lastStageId = math.max(lastStageId, stgId)
		end
		
		return lastStageId
	end

	method integer GetStageClearProgress(integer stageId)
		-- 스테이지 클리어에 필요한 진행도를 반환하는 함수
		if stageId == 1 then
			return 2
		else
			return 6
		end
	end

	@ExecSpace("Client")
	method void OpenStageClearRewardUI(integer stageId)
		-- 스테이지 클리어 보상 UI를 여는 함수
		_UIGroupManager.StageClearRewardGroup.UIStageClearRewardGroup:Open(stageId, 1, nil)
	end

end