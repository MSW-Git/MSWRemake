@Struct
script SideMenuData

	property integer Id = 0

	property string DescKey = ""

	property string IconRUID = ""

	property table Effect = {}

	property table SubEffect = {}

	property string GetCondition = ""

	property string GetConditionValue = ""

	property string OpenCondition = ""

	property string OpenConditionValue = ""

	property boolean HideSlot = false

	property Vector2 Pos = Vector2(0,0)

	property string NameKey = ""

	method void Load(any dataTable, integer index)
		-- CSV 데이터를 읽어서 사이드메뉴 데이터를 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = tonumber(row:GetItem("Id"))
		self.NameKey = row:GetItem("NameKey")
		self.DescKey = row:GetItem("DescKey")
		self.IconRUID = row:GetItem("IconRUID")
		self.Effect = _UtilLogic:Split(row:GetItem("Effect"), ",")
		self.SubEffect = _UtilLogic:Split(row:GetItem("SubEffect"), ",")
		self.GetCondition = row:GetItem("GetCondition")
		self.GetConditionValue = row:GetItem("GetConditionValue")
		self.OpenCondition = row:GetItem("OpenCondition")
		self.OpenConditionValue = row:GetItem("OpenConditionValue")
		self.HideSlot = _StringUtilLogic:GetBoolByString(row:GetItem("HideSlot"), false)
		self.Pos = Vector2(tonumber(row:GetItem("PosX")), tonumber(row:GetItem("PosY")))
	end

end