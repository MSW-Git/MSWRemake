@Logic
script StageSettingEnum extends Logic

	property SyncTable<integer, string> Enum

	property string StageInfo = "StageInfo"

	property string Ingredient = "Ingredient"

	property string Employee = "Employee"

	property string Strategy = "Strategy"

	property string SideMenu = "SideMenu"

	method void OnBeginPlay()
		-- 스테이지 설정 메뉴 열거형을 초기화하는 함수
		self.Enum[1] = self.StageInfo
		self.Enum[2] = self.Ingredient
		self.Enum[3] = self.Employee
		self.Enum[4] = self.Strategy
	end

	method integer GetIndexByKey(string key)
		-- 키 문자열로 해당하는 열거형 인덱스를 찾아 반환하는 함수
		for idx, k in pairs(self.Enum) do
			if k == key then
				return idx
			end
		end
		
		return nil
	end

end