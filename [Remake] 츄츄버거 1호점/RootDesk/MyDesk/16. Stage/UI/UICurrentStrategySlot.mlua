@Component
script UICurrentStrategySlot extends Component

	property SpriteGUIRendererComponent Icon = nil

	property SpriteGUIRendererComponent GoodsIcon = nil

	property TextComponent Name = nil

	property TextComponent Effect = nil

	property Entity MinusBtn = nil

	method void Init()
		-- UI 컴포넌트들을 초기화하고 이벤트를 연결하는 함수
		self.Icon = self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		self.GoodsIcon = self.Icon.Entity:GetChildByName("GoodsIcon").SpriteGUIRendererComponent
		self.Name = self.Entity:GetChildByName("Name").TextComponent
		self.Effect = self.Entity:GetChildByName("Effect").TextComponent
		self.MinusBtn = self.Entity:GetChildByName("MinusBtn")
		self.MinusBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_StrategyDataSetLogic.UIStageSettingStrategy:RequestUnsetStrategy(self._T.id)
		end)
	end

	method void Refresh(integer id)
		-- 현재 전략 슬롯 UI를 새로고침하는 함수
		if self.Icon == nil then
			self:Init()
		end
		
		self._T.id = id
		
		local stData = _StrategyDataSetLogic:GetStrategyData(id)
		if stData == nil then
			self.Entity.Enable = false
			return
		end
		
		local nowLevel = _StrategyDataSetLogic.UIStageSettingStrategy.SelectedStrategy[id]
		if nowLevel == nil then
			self.Entity.Enable = false
			return
		end
		
		self.Icon.ImageRUID = stData.IconRUID
		self.GoodsIcon.Enable = false
		self.Name.Text = string.format("%s (%d)", _GetLocalizationTextLogic:GetText(stData.NameKey), nowLevel) 
		self.Effect.Text = _StrategyDataSetLogic:GetStrategyEffectDescText(id, nowLevel, false, _StageDataSetLogic.UIStageSetting.NowStage)
	end

	method string GetGoodsIcon(string relatedGoods)
		-- 관련 아이템에 따른 아이콘 RUID를 반환하는 함수
		if relatedGoods == "Gold" then
			return _ItemDataSetLogic:GetItemData("G0001").IconRUID
		elseif relatedGoods == "Attractive" then
			return _IconRuidEnum.Face_Good
		elseif relatedGoods == "Reputation" then
			return _ItemDataSetLogic:GetItemData("G0006").IconRUID
		elseif relatedGoods == "Heart" then
			return _ItemDataSetLogic:GetItemData("G0005").IconRUID
		elseif relatedGoods == "Clover" then
			return _ItemDataSetLogic:GetItemData("G0004").IconRUID
		end
	end

end