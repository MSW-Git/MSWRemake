@Component
script UICurrentSideMenuSlot extends Component

	property Entity Empty = nil

	property Entity Contents = nil

	property SpriteGUIRendererComponent Icon = nil

	property TextComponent Name = nil

	property TextComponent Effect = nil

	property Entity MinusBtn = nil

	method void Init()
		-- UI 컴포넌트들을 초기화하고 이벤트를 연결하는 함수
		self.Empty = self.Entity:GetChildByName("Empty")
		self.Contents = self.Entity:GetChildByName("Contents")
		self.Icon = self.Contents:GetChildByName("Icon").SpriteGUIRendererComponent
		self.Name = self.Contents:GetChildByName("Name").TextComponent
		self.Effect = self.Contents:GetChildByName("Effect").TextComponent
		self.MinusBtn = self.Contents:GetChildByName("MinusBtn")
		self.MinusBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_StrategyDataSetLogic.UIStageSettingStrategy:RequestUnsetSideMenu()
		end)
	end

	method void Refresh(integer id)
		-- 사이드메뉴 슬롯 UI를 새로고침하는 함수
		if self.Empty == nil then
			self:Init()
		end
		
		self._T.id = id
		
		local smData = _StrategyDataSetLogic:GetSideMenuData(id)
		if smData == nil then
			self.Empty.Enable = true
			self.Contents.Enable = false
			return
		end
		
		self.Empty.Enable = false
		self.Contents.Enable = true
		
		self.Icon.ImageRUID = smData.IconRUID
		self.Name.Text = _GetLocalizationTextLogic:GetText(smData.NameKey)
		self.Effect.Text = _StrategyDataSetLogic:GetSideMenuDescText(id)
	end

end