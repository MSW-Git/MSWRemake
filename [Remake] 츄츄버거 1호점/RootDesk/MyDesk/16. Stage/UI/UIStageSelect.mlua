@Component
script UIStageSelect extends Component

	property integer NowSelected = 0

	property Entity List = "49a77fc9-0adf-43e0-b8db-bf0bb0eaee20"

	property Entity SlotOrigin = "517b7e16-75d6-4193-9a55-abb519a614d3"

	property Entity StartButton = "dc8779fc-e32e-42d7-ae68-c332ee225233"

	property Entity InfoButton = "18466b98-d8c0-49c7-be01-9b98c21b5ae3"

	property Entity ChustarLevelIcon = "9b5592ee-6d25-4743-9e24-d07b952df94c"

	property TextComponent ChustarLevelText = "223564b0-6f39-4ea1-910c-6df298684fc9"

	property Entity Arrow_L = "b0f3aabf-47ba-4f80-84d5-b88cd3e68afb"

	property Entity Arrow_R = "7641bc3c-b347-455d-9974-7b94188c3cc6"

	property Entity ContinueButton = "f7f36399-224f-4432-930e-7611c374d91c"

	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI를 비활성화하는 함수
		self.Entity.Enable = false
		self._T.firstEnter = true
	end

	method void Open(integer stageId)
		-- 스테이지 선택 UI를 여는 함수
		_UIGroupManager:EnableStageInfoGroup(true)
		
		self.Entity.Enable = true
		
		self.SlotOrigin.Enable = false
		self:Refresh(stageId)
	end

	method void Close()
		-- 스테이지 선택 UI를 닫는 함수
		_UIGroupManager:EnableStageInfoGroup(false)
		self.Entity.Enable = false
	end

	method void Refresh(integer stageId)
		-- 스테이지 목록을 새로고침하는 함수
		for i, entity in pairs(self.List.Children) do
			entity.Enable = false
		end
		
		local player = _UserService.LocalPlayer
		
		local originStageId = stageId
		if originStageId == nil then
			stageId = player.PlayerStage.NowStage
		end
		
		local maxStageId = 1
		
		for id, data in pairs(_StageDataSetLogic.StageData) do
			local stageData = _StageDataSetLogic:GetStageData(id)
			if stageData.HideSlot == true or stageData.ComingSoon == true then
				continue
			end
			
			if player.PlayerStage:IsStageOpened(id) == true then
				if originStageId == nil then
					stageId = math.max(id, stageId)
				end
			end
			maxStageId = math.max(id, maxStageId)
		end
		
		self.NowSelected = stageId
		
		self.StartButton.Enable = stageId ~= 1
		self.InfoButton.Enable = stageId ~= 1
		self.ContinueButton.Enable = stageId ~= 1
		
		self.Arrow_L.Enable = stageId > 1
		self.Arrow_R.Enable = stageId < maxStageId
		
		self.InfoButton:GetChildByName("Dim").Enable = false
		self.InfoButton:GetChildByName("Icon"):GetChildByName("Dim").Enable = false
		
		local isOpened = player.PlayerStage:IsStageOpened(stageId)
		self.StartButton:GetChildByName("Dim").Enable = isOpened == false
		self.StartButton:GetChildByName("Icon"):GetChildByName("Dim").Enable = isOpened == false
		
		local isValidStageIngameData = _UtilLogic:IsNilorEmptyString(player.PlayerStage.StageSettingData[stageId]) == false
		self.ContinueButton:GetChildByName("Dim").Enable = isValidStageIngameData == false or stageId == player.PlayerStage.NowStage or isOpened == false
		self.ContinueButton:GetChildByName("Icon"):GetChildByName("Dim").Enable = isValidStageIngameData == false or stageId == player.PlayerStage.NowStage or isOpened == false
		
		_UIEntityService:GetOrCreateEntityOfModel("UIEmpty", 0, self.List)
		
		for i = 1, #_StageDataSetLogic.StageData do
			local stageData = _StageDataSetLogic:GetStageData(i)
			if isvalid(stageData) == false then
				continue
			end
			
			if stageData.HideSlot == true then
				continue
			end
			
			local slot = _UIEntityService:GetOrCreateClonedEntityByName(self.List, self.SlotOrigin.Name..i, self.SlotOrigin)
			slot.UIStageSelectSlot:Refresh(i)
		end
		
		
		if self._T.firstEnter == true then
			wait(0.2)
			self._T.firstEnter = false
		end
		
		self.List.ScrollLayoutGroupComponent:SetScrollPositionByItemIndex(self.NowSelected-1)
		self:RefreshChustarLevel()
	end

	method void OnSelectSlot(integer stageId)
		-- 스테이지 슬롯을 선택했을 때 처리하는 함수
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		if stageData.ComingSoon == true then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("StageSelectToast1")) 
			return
		end
		
		self:Refresh(stageId)
	end

	method void RefreshChustarLevel()
		-- 츄스타 레벨을 새로고침하는 함수
		local player = _UserService.LocalPlayer
		local chustarLevel = player.PlayerStage:GetChustarLevel()
		
		if chustarLevel <= 0 then
			chustarLevel = 1
		end
		
		local stageData = _StageDataSetLogic:GetStageData(chustarLevel)
		self.ChustarLevelIcon.SpriteGUIRendererComponent.ImageRUID = stageData.StageClearIconRUID
		local gradeText = chustarLevel <= 1 and _GetLocalizationTextLogic:GetText("ChustarUnrank") or _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Grade_Format", chustarLevel-2)
		self.ChustarLevelText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Chustar_Format", gradeText)
	end

	@EventSender("Entity", "256803e9-9a7b-4d31-84f0-c5063bfbdfc6")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 첫 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open(_UserService.LocalPlayer.PlayerStage.NowStage)
	end

	@EventSender("Entity", "bf2f379a-e603-4090-ad4b-435f22caa66a")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 두 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("Entity", "18466b98-d8c0-49c7-be01-9b98c21b5ae3")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 세 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_StageDataSetLogic.UIStageInfo:Open(self.NowSelected, false)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "dc8779fc-e32e-42d7-ae68-c332ee225233")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 네 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		local player = _UserService.LocalPlayer
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local isOpened = player.PlayerStage:IsStageOpened(self.NowSelected)
		if isOpened == false then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("StageSelectToast2")) 
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		local onOk = function()
			local stageData = _StageDataSetLogic:GetStageData(self.NowSelected)
			if self.NowSelected == 0 or isvalid(stageData) == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_StageDataSetLogic.UIStageSetting:Open(self.NowSelected)
		end
		
		local contentText = _GetLocalizationTextLogic:GetText("StageSelectStartNewPopupContents1") 
		
		local isValidData = _UtilLogic:IsNilorEmptyString(player.PlayerStage.StageSettingData[self.NowSelected]) == false
		if isValidData == true then
			contentText = contentText.._GetLocalizationTextLogic:GetText("StageSelectStartNewPopupContents2") 
		end
		
		
		_UIPopup:Open(contentText, onOk, function() end, _GetLocalizationTextLogic:GetText("StageSelectStartNewPopupTitle"))
	end

	@EventSender("Entity", "d0e000d2-b609-4b99-9796-4e6d805771e1")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 다섯 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_BMDropDownLogic.UIStagePass:Open(nil)
	end

	@EventSender("Entity", "b0f3aabf-47ba-4f80-84d5-b88cd3e68afb")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 여섯 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Refresh(self.NowSelected-1)
	end

	@EventSender("Entity", "7641bc3c-b347-455d-9974-7b94188c3cc6")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 일곱 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Refresh(self.NowSelected+1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f7f36399-224f-4432-930e-7611c374d91c")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 여덟 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		local player = _UserService.LocalPlayer
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if player.PlayerStage:IsStageOpened(self.NowSelected) == false then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("StageSelectToast2")) 
			return
		end
		
		
		if _UtilLogic:IsNilorEmptyString(player.PlayerStage.StageSettingData[self.NowSelected]) == true then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("StageSelectToast3")) 
			return
		end
		
		if self.NowSelected == player.PlayerStage.NowStage then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("StageSelectToast4")) 
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		local onOk = function()
			local stageData = _StageDataSetLogic:GetStageData(self.NowSelected)
			if self.NowSelected == 0 or isvalid(stageData) == false then
				return
			end
				
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			player.PlayerStage:OnContinueStage(self.NowSelected)
			
			self:Close()
		end
		
		local contentText = _GetLocalizationTextLogic:GetText("StageSelectContinuePopupContents")
		_UIPopup:Open(contentText, onOk, function() end, _GetLocalizationTextLogic:GetText("StageSelectContinuePopupTitle"))
	end

end