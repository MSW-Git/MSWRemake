@Component
script UIStageRewardStrategy extends Component

	property Entity StrategyInfoText = "fa3da18f-7c92-4d74-9310-d82866c5f487"

	property Entity StrategyList = "4bb70b60-fe99-49ba-88c3-cd469e23e445"

	property Entity StrategySlotOrigin = "4c8f1d87-3c72-4c48-ad00-6d37c4e710a2"

	method void StartRender(integer stageId)
		-- 전략 보상 렌더링을 시작하는 함수
		self._T.stageId = stageId
		
		self._T.strategyList = {}
		for id, data in pairs(_StrategyDataSetLogic.StrategyData) do
			local strategyData = _StrategyDataSetLogic:GetStrategyData(id)
			if strategyData.UnlockStage == stageId then
				table.insert(self._T.strategyList, id)
			end
		end
		
		self:SetInfo()
		
		self.Entity.Enable = true
		self.Entity.CanvasGroupComponent.GroupAlpha = 1
		self:PlayAnim(1)
	end

	method void PlayAnim(integer phase)
		-- 전략 보상 애니메이션을 재생하는 함수
		if phase == 1 then
			local duration = 1
			for i, child in pairs(self.StrategyList.Children) do
				_TimerService:SetTimerOnce(function()
					_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_VipOrderSlot"], 1)
					_TweenLogic:PlayTween(0, 1, duration * 0.4, EaseType.Linear, function(t)
						child.CanvasGroupComponent.GroupAlpha = t
					end)
					_TweenLogic:PlayTween(0, 360, duration, EaseType.CubicEaseOut, function(t)
						child.UITransformComponent.Rotation.y = t
					end)
					
					if i == #self.StrategyList.Children then			
						_TimerService:SetTimerOnce(function()
							self:PlayAnim(2)
						end, duration)
					end
				end, duration * (i-1))
			end
			
		elseif phase == 2 then
			local duration = 0.7
			_SoundService:PlaySound(_ResourceManager.SFXTable["Refuel"], 1)
			_TweenLogic:PlayTween(0, 1, duration, EaseType.CubicEaseOut, function(t)
				self.StrategyInfoText.TextComponent.FontColor.a = t
			end)
			
			local delay = 0.5
			_TimerService:SetTimerOnce(function()
				self.Entity.Parent.UIStageClearRewardGroup:SetCanMoveNext(3)
			end, duration + delay)
			
		end
	end

	method void SetInfo()
		-- 전략 정보를 설정하는 함수
		for i, id in pairs(self._T.strategyList) do
			local stData = _StrategyDataSetLogic:GetStrategyData(id)
			local slot = _UIEntityService:GetOrCreateClonedEntityByName(self.StrategyList, self.StrategySlotOrigin.Name..i, self.StrategySlotOrigin)
			slot.UIStrategySlot:Refresh(1, id)
			slot.UIStrategySlot.ST_SetBtn.ButtonComponent.Transition = TransitionType.None
			slot.UIStrategySlot.ST_SetBtn.ButtonComponent.Enable = false
			slot.UIStrategySlot.ST_Recommended.Enable = false
			slot.CanvasGroupComponent.GroupAlpha = 0
		end
	end

	method void ClearUI()
		-- UI를 초기화하는 함수
		self.StrategyInfoText.TextComponent.FontColor.a = 0
		
		for i, child in pairs(self.StrategyList.Children) do
			child.Enable = false
		end
	end

end