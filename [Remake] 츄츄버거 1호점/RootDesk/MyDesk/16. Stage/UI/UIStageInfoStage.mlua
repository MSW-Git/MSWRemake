@Component
script UIStageInfoStage extends Component

	property Entity RewardSlot1 = nil

	property Entity RewardSlot2 = nil

	property SpriteGUIRendererComponent RewardSideMenuIcon = nil

	property Entity RewardSideMenuLocked = nil

	property Entity RewardSideMenuCheck = nil

	property TextComponent RewardSideMenuName = nil

	property Entity RewardSideMenuTooltip = nil

	property SpriteGUIRendererComponent StageCollectProgressSlider = nil

	property TextComponent StageCollectProgressText = nil

	property Entity RewardSlot1Tooltip = nil

	property Entity RewardSlot2Tooltip = nil

	property TextComponent EmpCountText = nil

	property TextComponent IngreCountText = nil

	method void Init()
		-- UI 컴포넌트들을 초기화하고 이벤트를 연결하는 함수
		local stageReward = self.Entity:GetChildByName("StageReward")
		self.RewardSlot1 = stageReward:GetChildByName("RewardSlot1")
		self.RewardSlot2 = stageReward:GetChildByName("RewardSlot2")
		
		local rewardSlot1Name = stageReward:GetChildByName("RewardSlot1_Name") 
		local reward1InfoBtn = rewardSlot1Name:GetChildByName("InfoBtn")
		local reward1InfoTooltip = reward1InfoBtn:GetChildByName("Tooltip")
		reward1InfoTooltip.Enable = false
		reward1InfoBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_TooltipService:OpenTooltip(reward1InfoTooltip, nil)
		end)
		
		local rewardSlot2Name = stageReward:GetChildByName("RewardSlot2_Name")
		local reward2InfoBtn = rewardSlot2Name:GetChildByName("InfoBtn")
		local reward2InfoTooltip = reward2InfoBtn:GetChildByName("Tooltip")
		reward2InfoTooltip.Enable = false
		reward2InfoBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_TooltipService:OpenTooltip(reward2InfoTooltip, nil)
		end)
		
		reward2InfoTooltip.TextComponent.Text = _GetLocalizationTextLogic:GetText(_ItemDataSetLogic:GetItemData("G0008").NameKey)
		reward1InfoTooltip.TextComponent.Text = _GetLocalizationTextLogic:GetText("StageInfoStageRewardDiamondTooltip")
		
		local stageCollectProgress = self.Entity:GetChildByName("StageCollectProgress")
		self.StageCollectProgressSlider = stageCollectProgress:GetChildByName("Slider"):GetChildByName("SliderFill").SpriteGUIRendererComponent
		self.StageCollectProgressText = stageCollectProgress:GetChildByName("Slider"):GetChildByName("Text").TextComponent
		
		self.EmpCountText = stageCollectProgress:GetChildByName("ChuCount"):GetChildByName("Count").TextComponent
		self.IngreCountText = stageCollectProgress:GetChildByName("IngreCount"):GetChildByName("Count").TextComponent
		
		local rewardSideMenu = stageReward:GetChildByName("RewardSideMenu")
		self.RewardSideMenuIcon = rewardSideMenu:GetChildByName("SideSlot"):GetChildByName("Icon").SpriteGUIRendererComponent
		local balloon = rewardSideMenu:GetChildByName("Balloon")
		self.RewardSideMenuLocked = balloon:GetChildByName("Locked")
		self.RewardSideMenuCheck = balloon:GetChildByName("Check")
		self.RewardSideMenuName = rewardSideMenu:GetChildByName("Name").TextComponent
		local rewardSideMenuInfoBtn = self.RewardSideMenuName.Entity:GetChildByName("InfoBtn")
		self.RewardSideMenuTooltip = rewardSideMenuInfoBtn:GetChildByName("Tooltip")
		self.RewardSideMenuTooltip.Enable = false
		
		rewardSideMenuInfoBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_TooltipService:OpenTooltip(self.RewardSideMenuTooltip, nil)
		end)
	end

	method void Refresh(integer stageId)
		-- 스테이지 정보를 새로고침하는 함수
		if self.RewardSlot1 == nil then
			self:Init()
		end
		
		local player = _UserService.LocalPlayer
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		local isStageCleared = player.PlayerStage.StageProgress[stageId] == _StageDataSetLogic:GetStageClearProgress(stageId)
		
		local rewardSP = _GetConfigDataLogic:GetConfigNumDataByKey("StageClearRewardSP")
		local spItemId = "G0008"
		self.RewardSlot1.UIItemRewardSlot:SetItem(spItemId, rewardSP)
		local rewardSlot1Info = self.RewardSlot1:GetChildByName("Info")
		if isvalid(rewardSlot1Info) then
			rewardSlot1Info.TextComponent.Text = _GetLocalizationTextLogic:GetText("OnlyFirstTime")
		end
		local rewardSlotCheck = self.RewardSlot1:GetChildByName("Check")
		rewardSlotCheck.Enable = isStageCleared
		
		local rewardDiamond = stageData.StageClearRewardDiamond
		for i = 1, _ManagementDataSetLogic.ManagementMaxLevel do
			local diaPerLevel = _GetConfigDataLogic:GetConfigNumDataByKey("DiamondRewardManagementLevel"..i)
			rewardDiamond += diaPerLevel
		end
		
		local diamondItemId = "G1001"
		self.RewardSlot2.UIItemRewardSlot:SetItem(diamondItemId, rewardDiamond)
		local rewardSlot2Info = self.RewardSlot2:GetChildByName("Info")
		if isvalid(rewardSlot2Info) then
			rewardSlot2Info.TextComponent.Text = _GetLocalizationTextLogic:GetText("Max")
		end
		
		local sideMenuId = 0
		for id, data in pairs(_StrategyDataSetLogic.SideMenuData) do
			local smData = _StrategyDataSetLogic:GetSideMenuData(id)
			if smData.GetCondition == "StageClear" and tonumber(smData.GetConditionValue) == stageId then
				sideMenuId = id
				break
			end
		end
		
		local sideMenuData = _StrategyDataSetLogic:GetSideMenuData(sideMenuId)
		local haveSideMenu = player.PlayerCollection.SideMenuCollection[sideMenuId]
		if haveSideMenu == nil then
			haveSideMenu = false
		end
		self.RewardSideMenuIcon.ImageRUID = sideMenuData.IconRUID
		_StrategyDataSetLogic:SetSideMenuIconPos(self.RewardSideMenuIcon.Entity, sideMenuId)
		self.RewardSideMenuName.Text = _GetLocalizationTextLogic:GetText(sideMenuData.NameKey)
		self.RewardSideMenuLocked.Enable = not haveSideMenu
		self.RewardSideMenuCheck.Enable = haveSideMenu
		self.RewardSideMenuTooltip.TextComponent.Text = _StrategyDataSetLogic:GetSideMenuDescText(sideMenuId)
		
		
		local progress = _StageDataSetLogic:GetStageCollectionRate(nil, stageId, player)
		self.StageCollectProgressSlider.FillAmount = progress
		self.StageCollectProgressText.Text = math.floor(progress*100).." %"
		
		local specialCount = 0
		local specialIngres = _StageDataSetLogic:GetStageOnlyIngredient(stageId)
		for i, ingreId in pairs(specialIngres) do	
			local haveIngre = player.PlayerCollection.IngredientCollection[ingreId]
			if haveIngre == nil then
				haveIngre = false
			end
			
			if haveIngre == true then
				specialCount += 1
			end
		end
		
		self.IngreCountText.Text = string.format("%d/%d", specialCount, #specialIngres)
		
		local stageEmp = _EmployeeService:ReturnStageEmpIdList(stageId)
		local haveEmpCount = 0
		for i, empId in pairs(stageEmp) do
		    local haveEmp = player.ChuchuCollectionDB.ChuchuCollection[empId]
			if haveEmp == nil then
				haveEmp = false
			end
			if haveEmp == true then
				haveEmpCount += 1
			end
		end
		self.EmpCountText.Text = string.format("%d/%d", haveEmpCount, #stageEmp)
	end

end