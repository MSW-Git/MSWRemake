@Component
script UIStageSettingStageInfo extends Component

	property Entity BGDeco = nil

	property Entity Drawing = nil

	property Entity Photo = nil

	property SpriteGUIRendererComponent PhotoImg = nil

	property Entity PhotoPin = nil

	property Entity Main = nil

	property SpriteGUIRendererComponent StageIconBGImg = nil

	property SpriteGUIRendererComponent StageIcon = nil

	property SpriteGUIRendererComponent StageIconMini = nil

	property TextComponent StageName = nil

	property TextComponent StageDesc = nil

	property SpriteGUIRendererComponent StageCollectSliderFill = nil

	property TextComponent StageCollectText = nil

	property TextComponent StageNameEng = nil

	property TextComponent StoreNameText = nil

	property SpriteGUIRendererComponent DecoTop = nil

	property SpriteGUIRendererComponent DecoBottom = nil

	property boolean IsTween = false

	method void Init()
		-- UI 컴포넌트들을 초기화하는 함수
		self.BGDeco = self.Entity:GetChildByName("BGDeco")
		self.Drawing = self.Entity:GetChildByName("Drawing")
		
		self.Photo = self.Entity:GetChildByName("Photo")
		self.PhotoPin = self.Photo:GetChildByName("Pin")
		self.PhotoImg = self.Photo:GetChildByName("IMG").SpriteGUIRendererComponent
		
		self.Main = self.Entity:GetChildByName("Main")
		self.StageIconBGImg = self.Main:GetChildByName("StageIconBG"):GetChildByName("IMG").SpriteGUIRendererComponent
		self.StageIcon = self.Main:GetChildByName("StageIcon").SpriteGUIRendererComponent
		self.StageIconMini = self.Main:GetChildByName("StageIconMini").SpriteGUIRendererComponent
		self.StageName = self.Main:GetChildByName("StageName").TextComponent
		self.StageDesc = self.Main:GetChildByName("StageDesc").TextComponent
		local collectSlider = self.Main:GetChildByName("StageCollectProgress"):GetChildByName("Slider")
		self.StageCollectSliderFill = collectSlider:GetChildByName("SliderFill").SpriteGUIRendererComponent
		self.StageCollectText = collectSlider:GetChildByName("Text").TextComponent
		self.StageNameEng = self.Main:GetChildByName("Right_StageName").TextComponent
		self.StoreNameText = self.Main:GetChildByName("Right_UserName").TextComponent
		
		local deco = self.Main:GetChildByName("DecoEntity")
		self.DecoTop = deco:GetChildByName("Top").SpriteGUIRendererComponent
		self.DecoBottom = deco:GetChildByName("Bottom").SpriteGUIRendererComponent
		
		self._T.photoOriginPos = self.Photo.UITransformComponent.anchoredPosition
		self._T.drawingOriginPos = self.Drawing.UITransformComponent.anchoredPosition
		self._T.mainOriginPos = self.Main.UITransformComponent.anchoredPosition
	end

	method void Refresh(integer stageId)
		-- 스테이지 정보를 새로고침하는 함수
		if self.StageIcon == nil then
			self:Init()
		end
		
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		
		self.PhotoImg.ImageRUID = stageData.StagePhotoRUID
		self.StageIconBGImg.ImageRUID = stageData.StageIconBGRUID
		self.StageIcon.ImageRUID = stageData.IconRUID
		self.StageIconMini.ImageRUID = stageData.BadgeIconRUID
		
		self.StageName.Text = string.format("%d %s", stageId, _GetLocalizationTextLogic:GetText(stageData.NameKey))
		self.StageDesc.Text = _GetLocalizationTextLogic:GetText(stageData.DescKey)
		self.StageNameEng.Text = stageData.StageNameEng
		
		self.DecoTop.ImageRUID = "1bc4401a3d7e4eb79fb66a5ad5d07eef"
		self.DecoTop.Color = _ColorCodeEnum:GetColor(stageData.DecoTopBig)
		self.DecoBottom.ImageRUID = "0be7e9b472f143179d5e5bb8c12b6f46"
		self.DecoBottom.Color = _ColorCodeEnum:GetColor(stageData.DecoBottomBig)
		
		local player = _UserService.LocalPlayer
		self.StoreNameText.Text = player.PlayerOutgameManager.StoreName
		
		local collectProgress = _StageDataSetLogic:GetStageCollectionRate(nil, stageId, _UserService.LocalPlayer)
		self.StageCollectSliderFill.FillAmount = collectProgress
		self.StageCollectText.Text = math.floor(collectProgress * 100).." %"
		
		self:OpenAnim(1)
	end

	method void OpenAnim(integer phase)
		-- 열기 애니메이션을 실행하는 함수
		
		
		if phase == 1 then
			
			self.BGDeco.CanvasGroupComponent.GroupAlpha = 0
			self.Drawing.CanvasGroupComponent.GroupAlpha = 0
			self.Photo.CanvasGroupComponent.GroupAlpha = 0
			self.Main.CanvasGroupComponent.GroupAlpha = 0
			
			self.IsTween = true
			_StageDataSetLogic.UIStageSetting.NextButton.CanvasGroupComponent.GroupAlpha = 0
			_StageDataSetLogic.UIStageSetting.NextButton.CanvasGroupComponent.Interactable = false
			_StageDataSetLogic.UIStageSetting.NextButton.UITransformComponent.UIScale = Vector3.zero
			
			self:OpenAnim(2)
			
		elseif phase == 2 then
			
			
			
			_UIEntityService:PlayUIOpenAnim(self.Photo, self._T.photoOriginPos, Vector2.right, 0.6, 0, nil, "CubicEaseOut", nil)
			_SoundService:PlaySound(_ResourceManager.SFXTable["ShowFlower_2"], 1)
		
			
			_UIEntityService:PlayUIOpenAnim(self.Drawing, self._T.drawingOriginPos, Vector2.left, 0.6, 0.4, nil, "CubicEaseOut", nil)
			_TimerService:SetTimerOnce(function()
				_SoundService:PlaySound(_ResourceManager.SFXTable["ShowFlower_2"], 1)
		
			end, 0.4)
			
			_UIEntityService:PlayUIOpenAnim(self.Main, self._T.mainOriginPos, Vector2.up, 0.6, 1, nil, "CubicEaseOut", nil)
			_TimerService:SetTimerOnce(function()
				_SoundService:PlaySound(_ResourceManager.SFXTable["System_QuestBookOpen_01"], 1)
			end, 1)
			
			_TimerService:SetTimerOnce(function() 
				_StageDataSetLogic.UIStageSetting.NextButton.CanvasGroupComponent.GroupAlpha = 1
				_TweenLogic:PlayTween(0.8, 1, 0.6, EaseType.BackEaseOut, function(t)
					_StageDataSetLogic.UIStageSetting.NextButton.UITransformComponent.UIScale = Vector3(t, t, t)
				end)
				
			end, 1.2)
			
			_UIEntityService:PlayUIOpenAnim(self.BGDeco, self._T.mainOriginPos, Vector2.zero, 0.4, 1.2, nil, nil, function()
				self.IsTween = false
				_StageDataSetLogic.UIStageSetting.NextButton.CanvasGroupComponent.Interactable = true
			end)
			
			
		end
	end

end