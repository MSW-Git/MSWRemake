@Component
script UIEmployment extends Component

	property Entity SelectedLevelButton = nil

	property string EmploymentState = ""

	property Entity SelectedEmpButton = nil

	property Entity SelectEmploymentTypePanel = "2ba812d3-009c-4439-b90b-18fed22b0382"

	property Entity ProcessingPanel = "ebb3730c-8336-4859-b5a5-9106c7c35e6b"

	property Entity EmployeeListPanel = "2c364c5c-1981-4471-91c1-f1cc57ddb0d0"

	property Entity OkButton = "557c4cf4-e361-494a-af56-50392f877dcf"

	property Entity CloseBtn = "05c81c11-858e-4d21-8f4e-7c6af91f0238"

	property Entity EmpManageBtn = "50fcf8b7-2c0f-4999-89b8-a0104ec6f356"

	property Entity TitleBg = "37ca7769-18e6-4edc-8d9f-2d2fd7c01c5e"

	property Entity EmployeeListOkButton = "1f694c2c-59a0-40f5-ac7a-c978035cedc8"

	property Entity EmploymentLvText = "e45cfd06-6773-4a0b-b6e8-00861d86821c"

	property Entity EmploymentLevelBtn1_Cost = "56d8f1ce-3968-4c21-b187-7666c9e10757"

	property Entity EmploymentLevelBtn2_Cost = "0db12ff4-f83a-4608-9cd6-189572901c9a"

	property Entity EmploymentStageImg = "4cf66d45-ea03-4a18-a260-4be26242d688"

	property Entity EmploymentRerollCost = "4b1ba5a4-2514-4f17-8b6e-9bf65cf67b86"

	property Entity ScoutLvText = "4843ff03-b436-43f6-adf2-6a58b1d41f9e"

	property Entity StartChuchuLvText = "466dd613-f9a5-4412-9277-000663597342"

	property Entity StageLvBonusText = "61421422-3b4c-4a10-88d1-36393a16ee22"

	property Entity LvBonusText = "7d2944a3-5eab-409a-9aba-220657eb7958"

	property boolean CanClickTypeSelectOkBtn = true

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 고용 UI 초기화를 처리하는 함수
		self._T.LevelButtonListPanel = _EntityService:GetEntityByPath("/ui/EmploymentGroup/Panel/EmploymentSelectPanel")
		self._T.ProcessingPanel = _EntityService:GetEntityByPath("/ui/EmploymentGroup/Panel/ProcessingPanel")
		self._T.EmployeeListPanel = _EntityService:GetEntityByPath("/ui/EmploymentGroup/Panel/EmployeeListPanel")
		self._T.OkButton =  _EntityService:GetEntityByPath("/ui/EmploymentGroup/Panel/OkButton")
		
		self._T.LvBonusMax = _GetConfigDataLogic:GetConfigNumDataByKey("EmployeeInitLevelMax")
	end

	@ExecSpace("ClientOnly")
	method void SetEmploymentTypeList(table infoTable)
		-- 고용 타입 목록을 UI에 설정하는 함수
		local scroll = self.SelectEmploymentTypePanel:GetChildByName("EmploymentTypeScroll")
		for i, slot in pairs(scroll.Children) do
			slot.EmploymentLevelButton:SetUI(i, infoTable[i])
		end
		self:UpdateEmploymentLvText()
		self:UpdateScountLvText()
	end

	@ExecSpace("ClientOnly")
	method void OpenUI()
		-- 고용 UI를 여는 함수
		_UIGroupManager.EmploymentGroup.Enable = true
		
		self:SwitchButtonOutline(nil)
		_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(true)
		self:UpdateEmploymentLvText()
		self:UpdateScountLvText()
		self:UpdateEmploymentStageImg()
	end

	@ExecSpace("ClientOnly")
	method void CloseUI()
		-- 고용 UI를 닫는 함수
		_UIGroupManager.EmploymentGroup.Enable = false
		_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(nil)
	end

	@ExecSpace("Client")
	method void ChangeState(string listType)
		-- 고용 UI 상태를 변경하는 함수
		if listType == self.EmploymentState then
			return
		end
		
		self.EmploymentState = listType
		
		if listType == _EmploymentStateEnum.LevelButtonList then
			self.SelectEmploymentTypePanel.Enable = true
			self.ProcessingPanel.Enable = false
			self.EmployeeListPanel.Enable = false
			self.EmpManageBtn.Enable = true
			self:UpdateEmploymentLvText()
			self:UpdateScountLvText()
			self:UpdateEmploymentStageImg()
			
			if self.Entity.Enable then
				_UIGroupManager:EnableBackToLobbyBtn(true)
				_UIGroupManager:EnableMoneyBarGroup(true)
			end
			
		elseif listType == _EmploymentStateEnum.OnProcessing then
			self.ProcessingPanel.Enable = true
			self.SelectEmploymentTypePanel.Enable = false
			self.EmployeeListPanel.Enable = false
			self.EmpManageBtn.Enable = false
			self.TitleBg.Enable = false
			self.CloseBtn.Enable = false
			if self.Entity.Enable then
				_UIGroupManager:EnableBackToLobbyBtn(false)
				_UIGroupManager:EnableMoneyBarGroup(false)
			end
			
		elseif listType == _EmploymentStateEnum.EmployeeList then
			self.EmployeeListPanel.Enable = true
			self.SelectEmploymentTypePanel.Enable = false
			self.ProcessingPanel.Enable = false
			self.EmpManageBtn.Enable = true
			self.TitleBg.Enable = true
			self.CloseBtn.Enable = true
			if self.Entity.Enable then
				_UIGroupManager:EnableBackToLobbyBtn(true)
				_UIGroupManager:EnableMoneyBarGroup(true)
			end
		end
		
	end

	@ExecSpace("Client")
	method void OnCilckLevelButton(Entity buttonEntity)
		-- 고용 레벨 버튼 클릭 시 처리하는 함수
		if isvalid(self.SelectedLevelButton) then
			local player = _UserService.LocalPlayer
			if _UserService.LocalPlayer.EmployeeManager:CheckHasAllEmployee() then
				_UIToast:ShowMessage(_LocalizationService:GetText("CantEmployment")) 
			else
				self.CanClickTypeSelectOkBtn = false
				player.PlayerEmployment:CheckCanStartRecruit(buttonEntity.EmploymentLevelButton.Id)
			end
		else
			_UIToast:ShowMessage(_LocalizationService:GetText("SelectEmploymentTypeMsg")) 
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SwitchButtonOutline(Entity selectedButton)
		-- 버튼 선택 상태를 변경하는 함수
		
		if self.EmploymentState == _EmploymentStateEnum.LevelButtonList then
			local scroll = self.SelectEmploymentTypePanel:GetChildByName("EmploymentTypeScroll")
			if isvalid(selectedButton) then
				self.SelectedLevelButton = selectedButton
			else
				self.SelectedLevelButton = scroll.Children[1]
			end
			
			for _, child in pairs(scroll.Children) do
				if child == self.SelectedLevelButton then
					child:GetChildByName("Outline").Enable = true
				else
					child:GetChildByName("Outline").Enable = false
				end
			end
			
			
		elseif self.EmploymentState == _EmploymentStateEnum.EmployeeList then
			local scroll = self.EmployeeListPanel:GetChildByName("EmployeeListScroll")
			if isvalid(selectedButton) then
				self.SelectedEmpButton = selectedButton
			else
				self.SelectedEmpButton = scroll.Children[1]
			end
			
			for _, child in pairs(scroll.Children) do
				if child == self.SelectedEmpButton then
					child:GetChildByName("Outline").Enable = true
				else
					child:GetChildByName("Outline").Enable = false
				end
			end
			
			self:DisplayDetail()
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnClickOkButton()
		-- 확인 버튼 클릭 시 처리하는 함수
		if _TutorialManager.target == self.EmployeeListOkButton then
			local result = _TutorialManager:CheckForceTo()
			if result == false then
				return
			end
		end
		
		if self.EmploymentState == _EmploymentStateEnum.LevelButtonList then
			if not isvalid(self.SelectedLevelButton) then
				return
			end
			if self.CanClickTypeSelectOkBtn == false then
				return
			end
			self:OnCilckLevelButton(self.SelectedLevelButton)
			
		elseif self.EmploymentState == _EmploymentStateEnum.EmployeeList then
			if not isvalid(self.SelectedEmpButton) then
				return
			end
			self:OnCilckEmpListButton(self.SelectedEmpButton)
		end
		
	end

	@ExecSpace("Client")
	method void FailRecruiting(integer type)
		-- 고용이 실패했을 때 처리하는 함수
		self.CanClickTypeSelectOkBtn = true 
		
		if type == 1 then
			_UIToast:ShowMessage(_LocalizationService:GetText("NoArcaneSymbolToastMsg"))
		elseif type == 2 then
			_UIToast:ShowMessage(_LocalizationService:GetText("CantEmployment")) 
		end
	end

	@ExecSpace("Client")
	method void ShowEmployeeList(table empList, integer employmentId)
		-- 고용 가능한 직원 목록을 보여주는 함수
		if not isvalid(empList) then
		end
		
		self.CanClickTypeSelectOkBtn = true 
		
		local infoTable = _UserService.LocalPlayer.PlayerEmployment.EmploymentTypeInfo[employmentId]
		local title = infoTable["Title"]
		
		_EntityService:GetEntityByPath("/ui/EmploymentGroup/Panel/EmployeeListPanel/SubTitle/UIText").TextComponent.Text = 
			_LocalizationService:GetTextFormat("EmploymentResultDesc", _LocalizationService:GetText(title))
			
		
		local empScroll = self.EmployeeListPanel:GetChildByName("EmployeeListScroll")
		local empSlots = empScroll.Children
		
		for i = 1, #empSlots do
			local empId = empList[i]
			local slot = empSlots[i]
			if #empList >= i then
				---@type EmployeeData
				local data = _EmployeeService:GetData(empId)
			
				slot.UIEmployeeManageListRenderer:Set(empId)
				slot.Enable = true
				slot:GetChildByName("Outline").Enable = false
				slot.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial) 
				
				slot:GetChildByName("Pin").SpriteGUIRendererComponent.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(data.Type)
				
				local chuchuInCollection = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollection[empId]
				if chuchuInCollection then
					slot:GetChildByName("SkillIcon").Enable = false
				else
					slot:GetChildByName("SkillIcon").Enable = true
				end
			else
				slot.Enable = false
			end
		end
		
		self.SelectedEmpButton = empSlots[1]
		local rerollBtn = self.EmployeeListPanel:GetChildByName("RerollBtn")
		self.SelectedEmpButton:GetChildByName("Outline").Enable = true
		if employmentId == 2 then
			self.SelectedEmpButton:GetChildByName("Scout").Enable = true
			rerollBtn.Enable = false
		else
			self.SelectedEmpButton:GetChildByName("Scout").Enable = false
			rerollBtn.Enable = true
			self:UpdateRerollText()
		end
		
		local depositEntity = self.EmployeeListPanel:GetChildByName("OKButton")
		_UIGroupManager.EmploymentGroup.UIEmployment:UpdateDepositUI(depositEntity, employmentId)
		
		self:DisplayDetail()
		
		_ReportMessageMaker:RequestAddToReportQueue(2008, _LocalizationService:GetText(title), "", "")
		
		_MainMenuRedDotManager:EnableEmploymentRedDot(true)
	end

	@ExecSpace("Client")
	method void OnCilckEmpListButton(Entity selectedButton)
		-- 직원 목록에서 직원을 선택했을 때 처리하는 함수
		local player = _UserService.LocalPlayer
		player.PlayerEmployment:CheckCanEmployChuchu(selectedButton.UIEmployeeManageListRenderer.EmployeeId)
	end

	@ExecSpace("Client")
	method void SuccessEmploy(string employeeId)
		-- 직원 고용이 성공했을 때 처리하는 함수
		self:CloseUI()
		
		local empData = _EmployeeService:GetData(employeeId)
		local name = _LocalizationService:GetText(empData.NameKey)
		
		_ReportMessageMaker:RequestAddToReportQueue(2003, name, "", "")
		_MainMenuRedDotManager:EnableEmploymentRedDot(false)
		_MainMenuRedDotManager:EnableEmployeeManageRedDot(true)
	end

	@ExecSpace("Client")
	method void FailEmploy()
		-- 직원 고용이 실패했을 때 처리하는 함수
		_UIToast:ShowMessage(_LocalizationService:GetText("NoMoneyToastMsg"))
	end

	@ExecSpace("ClientOnly")
	method void CancelEmployment()
		-- 고용을 취소했을 때 처리하는 함수
		_UIToast:ShowMessage(_LocalizationService:GetText("EmploymentMsg5"))
		_MainMenuRedDotManager:EnableEmploymentRedDot(false)
	end

	@ExecSpace("ClientOnly")
	method void DisplayDetail()
		-- 선택된 직원의 상세 정보를 보여주는 함수
		local detailEntity = self.EmployeeListPanel:GetChildByName("Model_EmployeeDetail")
		detailEntity.EmploymentDetail:SetUI(self.SelectedEmpButton.UIEmployeeManageListRenderer.EmployeeId)
	end

	@ExecSpace("ClientOnly")
	method void OnClickCancelEmployment()
		-- 고용 취소 버튼을 클릭했을 때 처리하는 함수
		if _TutorialManager.target == self.EmployeeListOkButton then
			_UIToast:ShowMessage("CantGiveUpEmployment") 
			return
		end
		
		
		local player = _UserService.LocalPlayer
		local function onOk ()
			player.PlayerEmployment:OnCancelEmployment(false)
		end
		
		local function onCancel()
		end
		
		_UIPopup:Open(_LocalizationService:GetText("EmploymentCancelPopupDesc"), onOk, onCancel, _LocalizationService:GetText("EmploymentCancelPopupTitle"))
	end

	@ExecSpace("ClientOnly")
	method void UpdateEmploymentLvText()
		-- 고용 레벨 텍스트를 업데이트하는 함수
		local count = _UserService.LocalPlayer.PlayerEmployment.EmploymentLv
		self.EmploymentLvText.TextComponent.Text = _LocalizationService:GetTextFormat("EmploymentCount", _StringUtilLogic:NumToString(count))
		
		local cost = _UserService.LocalPlayer.PlayerEmployment:ReturnCostByEmploymentLv()
		self.EmploymentLevelBtn1_Cost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(cost))
		
		local ui = self.EmploymentLevelBtn1_Cost.Parent
		self:UpdateDepositUI(ui, 1)
		
		if _UserService.LocalPlayer.PlayerEmployment.EmploymentId == 1 then
			local depositEntity = self.EmployeeListPanel:GetChildByName("OKButton")
			_UIGroupManager.EmploymentGroup.UIEmployment:UpdateDepositUI(depositEntity, 1)
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateEmploymentStageImg()
		-- 고용 스테이지 이미지를 업데이트하는 함수
		local stg = _UserService.LocalPlayer.PlayerStage.NowStage
		local img = _StageDataSetLogic:GetStageData(stg).IconRUID
		self.EmploymentStageImg.SpriteGUIRendererComponent.ImageRUID = img
	end

	@ExecSpace("ClientOnly")
	method void UpdateRerollText()
		-- 리롤 비용 텍스트를 업데이트하는 함수
		local cost = _UserService.LocalPlayer.PlayerEmployment:CalcRerollCost()
		self.EmploymentRerollCost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(cost))
	end

	@ExecSpace("ClientOnly")
	method void OnClickRerollBtn()
		-- 리롤 버튼을 클릭했을 때 처리하는 함수
		_UserService.LocalPlayer.PlayerEmployment:RerollList()
	end

	@ExecSpace("ClientOnly")
	method void UpdateDepositUI(Entity ui, integer employmentType)
		-- 고용 보증금 UI를 업데이트하는 함수
		local deposit = _EmployeeService:ReturnDeposit(_UserService.LocalPlayer, employmentType)
		ui:GetChildByName("Deposit"):GetChildByName("Cost").TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(deposit)
		
		if _UserService.LocalPlayer.PlayerInventory.Money < deposit then
			ui:GetChildByName("Deposit"):GetChildByName("Cost").TextComponent.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			ui:GetChildByName("Deposit"):GetChildByName("Cost").TextComponent.OutlineColor = _ColorCodeEnum:GetColor(_ColorCodeEnum.WhiteFont)
		else
			local outlineColor = _ColorCodeEnum:GetColor("#8c7352")
			if ui.Name == "OKButton" then
				outlineColor = _ColorCodeEnum:GetColor("#c15e14")
			end
			ui:GetChildByName("Deposit"):GetChildByName("Cost").TextComponent.FontColor = _ColorCodeEnum:GetColor(_ColorCodeEnum.WhiteFont)
			ui:GetChildByName("Deposit"):GetChildByName("Cost").TextComponent.OutlineColor = outlineColor
		end
		ui:GetChildByName("Deposit").Enable = true
		
		self:UpdateChuchuLevelInfoText()
	end

	@ExecSpace("ClientOnly")
	method void UpdateScountLvText()
		-- 스카웃 레벨 텍스트를 업데이트하는 함수
		local count = _UserService.LocalPlayer.PlayerEmployment.ScoutLv
		self.ScoutLvText.TextComponent.Text = _LocalizationService:GetTextFormat("EmploymentCount", _StringUtilLogic:NumToString(count))
		
		local cost = _UserService.LocalPlayer.PlayerEmployment:ReturnCostByScoutLv()
		self.EmploymentLevelBtn2_Cost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(cost))
		
		local ui = self.EmploymentLevelBtn2_Cost.Parent
		self:UpdateDepositUI(ui, 2)
		
		if _UserService.LocalPlayer.PlayerEmployment.EmploymentId == 2 then
			local depositEntity = self.EmployeeListPanel:GetChildByName("OKButton")
			_UIGroupManager.EmploymentGroup.UIEmployment:UpdateDepositUI(depositEntity, 2)
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateChuchuLevelInfoText()
		-- 츄츄 레벨 정보 텍스트를 업데이트하는 함수
		local lvTable = _UserService.LocalPlayer.PlayerEmployment:CalcEmploymentStartLv()
		local lv = lvTable[1]
		local nowStage = _UserService.LocalPlayer.PlayerStage.NowStage
		local stageName = _LocalizationService:GetText(_StageDataSetLogic:GetStageData(nowStage).NameKey)
		self.StartChuchuLvText.TextComponent.Text = _LocalizationService:GetTextFormat("EmploymentChuchuLvText", tostring(lv), _StringUtilLogic:NumToString(self._T.LvBonusMax))
		self.StageLvBonusText.TextComponent.Text = _LocalizationService:GetTextFormat("EmploymentStartLvText", stageName, tostring(lvTable[2]))
		self.LvBonusText.TextComponent.Text = _LocalizationService:GetTextFormat("EmploymentBonusLvText", tostring(lvTable[3]))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "05c81c11-858e-4d21-8f4e-7c6af91f0238")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if _TutorialManager.target == self.EmployeeListOkButton then
			return
		end
		if _UtilLogic:IsNilorEmptyString(_EventManager.CurrentEventGroupId) == false and not (_TutorialManager.target == self.CloseBtn) then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "557c4cf4-e361-494a-af56-50392f877dcf")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 확인 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickOkButton()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "effd43c5-4ab2-41a3-b9dd-e1d567d14a68")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 고용 UI 열기 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OpenUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "c5f55fa6-feda-4b0e-86c2-361d39596d0d")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 고용 취소 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickCancelEmployment()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "1f694c2c-59a0-40f5-ac7a-c978035cedc8")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 직원 목록 확인 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickOkButton()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "50fcf8b7-2c0f-4999-89b8-a0104ec6f356")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 직원 관리 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if _TutorialManager.target == self.EmployeeListOkButton then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_UIEmployeeManageService:UIOpen()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "dc679b1b-d784-4b64-918f-66b96d5aa915")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 리롤 버튼 클릭 이벤트를 처리하는 함수
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if _TutorialManager.target == self.EmployeeListOkButton then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickRerollBtn()
	end

end