@Struct
script EmployeeStatByLevelData

	property integer Level = 0

	property integer CookSpeed = 0

	property integer CookCount = 0

	property integer ServingSpeed = 0

	property integer ServingCount = 0

	method void Load(string id)
		-- 레벨 ID로 직원 능력 데이터를 로드하는 함수
		local rowData = _DataService:GetTable("EmployeeStatByLevelDataSet"):FindRow("Level",id)
		
		self.Level = tonumber(rowData:GetItem("Level"))
		self.CookSpeed = tonumber(rowData:GetItem("CookSpeed"))
		self.CookCount = tonumber(rowData:GetItem("CookCount"))
		self.ServingSpeed = tonumber(rowData:GetItem("ServingSpeed"))
		self.ServingCount = tonumber(rowData:GetItem("ServingCount"))
	end

	method table ConvertToTable()
		-- 직원 능력 데이터를 테이블로 변환하는 함수
		local result = {}
		
		result["Level"] = self.Level
		
		result["CookSpeed"] = self.CookSpeed
		result["CookCount"] = self.CookCount
		result["ServingSpeed"] = self.ServingSpeed
		result["ServingCount"] = self.ServingCount
		
		return result
	end

end