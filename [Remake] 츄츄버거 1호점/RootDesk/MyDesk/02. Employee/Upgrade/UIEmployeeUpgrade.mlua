	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandlePlayerInventoryItemChangedEvent(PlayerInventoryItemChangedEvent event)
		-- 플레이어 인벤토리 아이템 변경 이벤트를 처리하는 핸들러
		if _EmployeeUpgradeUIServcie.EmployeeUpgrade.Enable then 
			self:SetUIItem()
			self:RefreshLevelUpBtn()
			_EmployeeUpgradeUIServcie.UIUpgradeAuto:RefreshAutoBtn()
			self:RefreshResetBtn()
			self:DisplayOverLimitCost(nil)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEmployeeDetailChangeEvent(EmployeeDetailChangeEvent event)
		-- 직원 상세 정보 변경 이벤트를 처리하는 핸들러
		if not self.Entity.Parent.Enable then return end 
		
		if _UtilLogic:IsNilorEmptyString(self.EmployeeID) then 
			
			local data = _UserService.LocalPlayer.EmployeeManager.EmployeeDetailTable[1]
			self.EmployeeID = data.Id
		end
		
		self:RefreshAfterLevelUp()
		self:SetUIDetail() 
		
		
	end

