@Struct
script EmployeeSkillTypeData

	property string Id = ""

	property string Type = ""

	property string NameKey = ""

	property integer UnLockLevel = 0

	property number Grade1Value = 0

	property number Grade2Value = 0

	property number Grade3Value = 0

	property number Grade4Value = 0

	property number Grade5Value = 0

	property string DescKey = ""

	property string Target = ""

	property string DescValueType = ""

	property string IconRUID = ""

	method void Load(string id)
		-- 직원 스킬 타입 데이터를 로드하는 함수
		local rowData = _DataService:GetTable("EmployeeSkillTypeDataSet"):FindRow("Id",id)
		
		self.Id = id 
		self.Type = rowData:GetItem("Type")
		self.NameKey = rowData:GetItem("NameKey")
		self.Grade1Value = tonumber(rowData:GetItem("Grade1Value"))
		self.Grade2Value = tonumber(rowData:GetItem("Grade2Value"))
		self.Grade3Value = tonumber(rowData:GetItem("Grade3Value"))
		self.Grade4Value = tonumber(rowData:GetItem("Grade4Value"))
		self.Grade5Value = tonumber(rowData:GetItem("Grade5Value"))
		self.DescKey = rowData:GetItem("DescKey")
		self.Target = rowData:GetItem("Target")
		self.DescValueType = rowData:GetItem("DescValueType")
		self.IconRUID = rowData:GetItem("IconRUID")
	end

	method table ConvertToTable()
		-- 데이터를 테이블로 변환하는 함수
		local result = {}
		
		result["Id"] = self.Id
		result["Type"] = self.Type
		result["NameKey"] = self.NameKey
		result["Grade1Value"] = self.Grade1Value
		result["Grade2Value"] = self.Grade2Value
		result["Grade3Value"] = self.Grade3Value
		result["Grade4Value"] = self.Grade4Value
		result["Grade5Value"] = self.Grade5Value
		result["DescKey"] = self.DescKey
		result["Target"] = self.Target
		result["DescValueType"] = self.DescValueType
		result["IconRUID"] = self.IconRUID
		
		return result
	end

end