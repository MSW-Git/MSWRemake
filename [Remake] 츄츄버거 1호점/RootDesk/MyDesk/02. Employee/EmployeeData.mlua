@Struct
script EmployeeData

	property string Id = ""

	property string Desc = ""

	property string NameKey = ""

	property integer Grade = 0

	property integer Cost = 0

	property string Type = ""

	property string Skill1Type = ""

	property string Skill2Type = ""

	property number WorkSpeed = 0

	property integer Strength = 0

	property string WorkRUID = ""

	property string SalesRUID = ""

	property string PortraitRUID = ""

	property string PortraitUIRUID = ""

	property string StandRUID = ""

	property string ChatRUID = ""

	property string MoveRUID = ""

	property string LoveRUID = ""

	property string CryRUID = ""

	property string SleepRUID = ""

	property string StunnedRUID = ""

	property string RestRUID = ""

	property integer MaxLevel = 0

	property string Tag = ""

	property integer GroupId = 0

	property string EquipIcon = ""

	property string EquipNameKey = ""

	property string EquipStandRUID = ""

	property string EquipChatRUID = ""

	property string EquipMoveRUID = ""

	property string EquipLoveRUID = ""

	property string EquipCryRUID = ""

	property string EquipSleepRUID = ""

	property string EquipStunnedRUID = ""

	property string EquipRestRUID = ""

	method void Load(string id)
		-- 직원 ID로 데이터셋에서 직원 정보를 로드하는 함수
		local rowData = _DataService:GetTable("EmployeeDataSet"):FindRow("Id",id)
		
		self.Id = id 
		self.NameKey = rowData:GetItem("NameKey")
		
		self.Grade = 1 
		self.Type = rowData:GetItem("Type")
		self.MaxLevel = 10 
		
		self.Skill1Type = rowData:GetItem("Skill1Type")
		self.Skill2Type = rowData:GetItem("Skill2Type")
		
		self.WorkSpeed = 24 
		self.Strength = 1 
		
		self.WorkRUID = rowData:GetItem("Love")
		self.SalesRUID = rowData:GetItem("Chat")
		
		self.PortraitRUID = rowData:GetItem("Portrait")
		self.PortraitUIRUID = rowData:GetItem("PortraitUIRUID")
		
		self.StandRUID = rowData:GetItem("Stand")
		self.ChatRUID = rowData:GetItem("Chat")
		self.MoveRUID = rowData:GetItem("Move")
		self.LoveRUID = rowData:GetItem("Love")
		self.CryRUID = rowData:GetItem("Cry")
		self.SleepRUID = rowData:GetItem("Sleep")
		self.StunnedRUID = rowData:GetItem("Stunned")
		self.RestRUID = rowData:GetItem("Rest")
		
		self.GroupId = tonumber(rowData:GetItem("GroupId"))
		self.EquipIcon = rowData:GetItem("EquipIcon")
		self.EquipNameKey = rowData:GetItem("EquipNameKey")
		self.EquipStandRUID = rowData:GetItem("EquipStand")
		self.EquipChatRUID = rowData:GetItem("EquipChat")
		self.EquipMoveRUID = rowData:GetItem("EquipMove")
		self.EquipLoveRUID = rowData:GetItem("EquipLove")
		self.EquipCryRUID = rowData:GetItem("EquipCry")
		self.EquipSleepRUID = rowData:GetItem("EquipSleep")
		self.EquipStunnedRUID = rowData:GetItem("EquipStunned")
		self.EquipRestRUID = rowData:GetItem("EquipRest")
	end

	method table ConvertToTable()
		-- 직원 데이터를 테이블 형태로 변환하는 함수
		local result = {}
		
		result["Id"] = self.Id
		result["Desc"] = self.Desc
		result["NameKey"] = self.NameKey
		
		result["Grade"] = self.Grade
		result["Type"] = self.Type
		result["MaxLevel"] = self.MaxLevel
		
		result["Skill1Type"] = self.Skill1Type
		result["Skill2Type"] = self.Skill2Type
		
		result["WorkSpeed"] = self.WorkSpeed
		result["Strength"] = self.Strength
		
		result["MoveRUID"] = self.MoveRUID
		result["WorkRUID"] = self.WorkRUID
		result["SalesRUID"] = self.SalesRUID
		
		result["GroupId"] = self.GroupId
		result["EquipIcon"] = self.EquipIcon
		result["EquipNameKey"] = self.EquipNameKey
		result["EquipStandRUID"] = self.EquipStandRUID
		result["EquipChatRUID"] =  self.EquipChatRUID
		result["EquipMoveRUID"] =  self.EquipMoveRUID
		result["EquipLoveRUID"] =  self.EquipLoveRUID
		result["EquipCryRUID"] =  self.EquipCryRUID
		result["EquipSleepRUID"] =  self.EquipSleepRUID
		result["EquipStunnedRUID"] =  self.EquipStunnedRUID
		result["EquipRestRUID"] =  self.EquipRestRUID
		
		return result
	end

	method string ReturnSpecializedStat()
		-- 직원의 전문 능력 타입을 반환하는 함수
		return self.Type
	end

end