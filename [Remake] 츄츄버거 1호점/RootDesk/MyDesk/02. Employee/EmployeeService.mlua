@Logic
script EmployeeService extends Logic

	property table EmployeeData = {}

	property table EmployeeStatLevelData = {}

	property number EmployeeStateTick = 0.25

	property number WorkDurationMin = 0

	property number WorkDurationMax = 0

	property number WorkProgressConstant1 = 0

	property number WorkProgressConstant2 = 0

	property number WorkProgressConstant3 = 0

	property number WorkProgressConstant4 = 0

	property number WorkProgressCookTimeConstant = 0

	property number WorkProgressCookStatConstant = 0

	property number WorkProgressServingTimeConstant = 0

	property number WorkProgressServingStatConstant = 0

	property number ServingWorkValueConstant = 0

	property table MaxLevelListByOverLimitLevel = {}

	property integer MaxOverLimitLevel = 3

	property number CookEmployeeWarningDuration = 0

	property number ServingEmployeeWarningDuration = 0

	property SyncTable<integer, integer> EmployeeWageDataByOverLimitLevel

	property SyncTable<integer, integer> EmploymentDepositByOverLimitLevel

	property SyncTable<integer, string> CookExpItemTable

	property SyncTable<integer, string> ServingExpItemTable

	property SyncTable<integer, integer> ExpPotionValueByItemLevel

	property integer SkillType2UnlockOverLimitLevel = 0

	method void OnBeginPlay()
		-- 게임 시작 시 직원 서비스를 초기화하는 함수
		self.SkillType2UnlockOverLimitLevel = self.MaxOverLimitLevel - 1
		
		self:LoadData()
		
	end

	method void LoadData()
		-- 직원 관련 데이터를 로드하는 함수
		table.clear(self.EmployeeData)
		local dataSet = _DataService:GetTable("EmployeeDataSet")
		
		for _,row in pairs(dataSet:GetAllRow()) do 
		
			local id = row:GetItem("Id")	
			local data = EmployeeData()
			data:Load(tostring(id))
		
			self.EmployeeData[data.Id] = data
		
			
		end
		
		
		table.clear(self.EmployeeStatLevelData)
		dataSet = _DataService:GetTable("EmployeeStatByLevelDataSet")
		
		for _,row in pairs(dataSet:GetAllRow()) do 
		
			local id = row:GetItem("Level")	
			local data = EmployeeStatByLevelData()
			data:Load(tostring(id))
			self.EmployeeStatLevelData[data.Level] = data
			
		end
		
		table.clear(self.EmployeeWageDataByOverLimitLevel)
		dataSet = _DataService:GetTable("OverLimitCostDataSet")
		
		for i = 1 , dataSet:GetRowCount() do
			local id = dataSet:GetCell( i , "OverLimitLevel" )
			local salary = dataSet:GetCell( i , "Salary" )
			self.EmployeeWageDataByOverLimitLevel[tonumber(id)] = tonumber(salary)
			self.MaxLevelListByOverLimitLevel[i] = tonumber( dataSet:GetCell(i, "MaxLevel") )
		end
		
		self.MaxOverLimitLevel = dataSet:GetRowCount() - 1 
		_ChuchuGroupLogic:LoadDataSet()
	end

	method void LoadConfigData()
		-- 게임 설정 데이터를 로드하는 함수
		self.WorkDurationMin = _GetConfigDataLogic:GetConfigNumDataByKey("WorkDurationMin")
		self.WorkDurationMax = _GetConfigDataLogic:GetConfigNumDataByKey("WorkDurationMax")
		
		self.WorkProgressConstant1 = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressConstant1")
		self.WorkProgressConstant2 = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressConstant2")
		self.WorkProgressConstant3 = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressConstant3")
		self.WorkProgressConstant4 = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressConstant4")
		self.WorkProgressCookTimeConstant = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressCookTimeConstant")
		self.WorkProgressCookStatConstant = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressCookStatConstant")
		
		self.WorkProgressServingTimeConstant = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressServingTimeConstant")
		self.WorkProgressServingStatConstant = _GetConfigDataLogic:GetConfigNumDataByKey("WorkProgressServingStatConstant")
		self.ServingWorkValueConstant = _GetConfigDataLogic:GetConfigNumDataByKey("ServingWorkValueConstant")
		
		self.CookEmployeeWarningDuration = _GetConfigDataLogic:GetConfigNumDataByKey("CookEmployeeWarningWorkDuration")
		self.ServingEmployeeWarningDuration = _GetConfigDataLogic:GetConfigNumDataByKey("ServingEmployeeWarningWorkDuration")
	end

	method EmployeeData GetData(string id)
		-- 직원 ID로 직원 데이터를 반환하는 함수
		if self.EmployeeData == nil then
			return nil
		end
		
		return self.EmployeeData[id]
	end

	method EmployeeStatByLevelData GetStatLevelData(integer level)
		-- 레벨에 따른 직원 능력 데이터를 반환하는 함수
		
		if self.EmployeeStatLevelData == nil then
			return nil
		end
		
		return self.EmployeeStatLevelData[level]
	end

	method number ReturnWorkDuration(string empId, Entity employee, Entity player, string employeeType)
		-- 직원의 작업 소요 시간을 계산하는 함수
		
		---@type EmployeeDetailData
		local detailData = player.EmployeeManager:GetEmployeeDetail(empId)
		
		local overLimitLevel = detailData.OverLimitLevel 
		
		---@type EmployeeData
		local data = self:GetData(empId)
		if not isvalid(detailData) then 
			return
		end
		
		detailData = detailData:ConvertToTable()
		local level =  detailData[employeeType.."Level"]
		local chuchuType = data.Type 
		
		
		
		
		local statLevelData = _EmployeeService:GetStatLevelData(level)
		if not isvalid(statLevelData) then
			return
		end
		
		local statEffectData = statLevelData:ConvertToTable()
		local speed = tonumber(statEffectData[employeeType.."Speed"])
		local count = tonumber(statEffectData[employeeType.."Count"])
		
		local duration = self.WorkDurationMax
		
		local orderGrade
		local orderNum 
		---@type TasteGradeData
		local tasteGradeData
		
		local requiredWork
		
		local skillType2 = _EmployeeSkillService:GetData(data.Skill2Type).Id
		
		
		if employeeType == _EmployeeTypeEnum.Serving then 
		
			local assingedCustomer = employee.ServingEmployeeAIScript.assignedCustomer
			if not isvalid(assingedCustomer) then 
				return nil 
			end
			
			local customerOrderNum = assingedCustomer.CustomerAIScript.OrderNum
			local customerId = assingedCustomer.CustomerAIScript.Id
			local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage).ServingWorkProgressAdd
			requiredWork = ( self.ServingWorkValueConstant*customerOrderNum ) + stageConfig
			if overLimitLevel >=  self.SkillType2UnlockOverLimitLevel then
				if skillType2 == _SkillTypeEnum.ServingSpeedUp then		
					local enableUseSkill = _EmployeeSkillService:CanUseSkill(empId,skillType2,player)
					if enableUseSkill then
						local addLevel = _EmployeeSkillService:ReturnSkillGradeValue(empId,skillType2, player)
						level = level + addLevel
			
						statEffectData = _EmployeeService:GetStatLevelData(level):ConvertToTable()
						speed = tonumber(statEffectData[employeeType.."Speed"])
					end 
					
				elseif skillType2 == _SkillTypeEnum.ServingCountUp then
					local enableUseSkill = _EmployeeSkillService:CanUseSkill(empId,skillType2,player)
					if enableUseSkill then
						local addCount = _EmployeeSkillService:ReturnSkillGradeValue(empId,skillType2, player)			
						count = count + addCount 
					end 
				end
			end
			
			duration = (requiredWork - level - self.WorkProgressServingStatConstant) * self.WorkProgressConstant1 * math.log( customerOrderNum + self.WorkProgressConstant2 , self.WorkProgressConstant3 ) + self.WorkProgressServingTimeConstant + self.WorkProgressConstant4
			duration = math.floor(duration * 100) / 100
		
		
		elseif employeeType == _EmployeeTypeEnum.Cook then 
		
			local makeRecipeId = employee.CookEmployeeAIScript.UniqueRecipeID
			if not isvalid(makeRecipeId) then 
				return nil 
			end
			local menuData = player.MenuManager:ReturnRecipeDataByUniqueID(makeRecipeId)
		    if not isvalid(menuData) then
		        return nil
		    end
			
			local tasteScore = menuData.TasteScore
			if isvalid(tasteScore) == false then
				return nil
			end
			
			tasteGradeData = _TasteGradeDataSetLogic:ReturnGradeDataByScore(menuData.TasteScore)	
			if isvalid(tasteGradeData) == false then
				return nil
			end
			
			orderGrade = tasteGradeData.Index
		
			local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage).CookWorkProgressAdd
			requiredWork = ( tasteGradeData.WorkProgress ) + stageConfig 
			
			if overLimitLevel >=  self.SkillType2UnlockOverLimitLevel then
				if skillType2 == _SkillTypeEnum.CookSpeedUp then		
					local enableUseSkill = _EmployeeSkillService:CanUseSkill(empId,skillType2,player)
					if enableUseSkill then
						local addLevel = _EmployeeSkillService:ReturnSkillGradeValue(empId,skillType2, player)
						level = level + addLevel
						statEffectData = _EmployeeService:GetStatLevelData(level):ConvertToTable()
						speed = tonumber(statEffectData[employeeType.."Speed"])
					end 
				end
				
				if skillType2 == _SkillTypeEnum.CookCountUp then
					local enableUseSkill = _EmployeeSkillService:CanUseSkill(empId,skillType2,player)
					if enableUseSkill then
						local addCount = _EmployeeSkillService:ReturnSkillGradeValue(empId,skillType2, player)			
						count = count + addCount 
					end 
				end
			end
			
			duration = (requiredWork - level - self.WorkProgressCookStatConstant) * self.WorkProgressConstant1 * math.log( orderGrade + self.WorkProgressConstant2 , self.WorkProgressConstant3 ) + self.WorkProgressCookTimeConstant + self.WorkProgressConstant4
			
			duration = math.floor(duration * 100) / 100
		end
		
		if duration > self.WorkDurationMax + self.WorkProgressConstant4 then
			duration = self.WorkDurationMax + self.WorkProgressConstant4
		elseif duration < self.WorkDurationMin + self.WorkProgressConstant4 then
			duration = self.WorkDurationMin + self.WorkProgressConstant4
		end
		
		return duration 
	end

	@ExecSpace("ClientOnly")
	method boolean IsStatLevelLow(string empId, number workDuration, string workType, Entity player)
		-- 직원의 능력 레벨이 낮은지 확인하는 함수
		if workDuration == nil then 
			return false 
		end
		
		if workType == _EmployeeTypeEnum.Cook then 
			
			if workDuration > self.CookEmployeeWarningDuration then
				return true
			end
			
		elseif workType == _EmployeeTypeEnum.Serving then
		
			local stageData = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage)
			local stageEarningLevelData = stageData:GetStageEarningLevelData(player.PlayerSettlement.EarningLevel)
			local minCount = stageEarningLevelData.BurgerOrderCountMin
			
			---@type EmployeeDetailData
			local detailData = player.EmployeeManager:GetEmployeeDetail(empId)
			
			detailData = detailData:ConvertToTable()
			local level =  detailData[workType.."Level"]
		
			local statLevelData = _EmployeeService:GetStatLevelData(level)
			if not isvalid(statLevelData) then
				return
			end	
			local statEffectData = statLevelData:ConvertToTable()
			local count = tonumber(statEffectData[workType.."Count"])
		
				
			local data = _EmployeeService:GetData(empId)
			local skillType2 = _EmployeeSkillService:GetData(data.Skill2Type).Id
		
				if skillType2 == _SkillTypeEnum.ServingCountUp then
					local enableUseSkill = _EmployeeSkillService:CanUseSkill(empId,skillType2,player)
					if enableUseSkill then
						local addCount = _EmployeeSkillService:ReturnSkillGradeValue(empId,skillType2, player)			
						count = count + addCount 
					
					end
		
				end
		
			local shuttleCount = minCount/count
				
			if shuttleCount > 1 then
				return true
			end
			
			if workDuration > self.ServingEmployeeWarningDuration then
				return true
			end
		end
		
		return false	
	end

	@ExecSpace("ClientOnly")
	method boolean IsStatLowByEarningLevelData(string empId, string workType, Entity player)
		-- 수익 레벨 데이터를 기준으로 직원 능력이 낮은지 확인하는 함수
		local stageEarningLevelData = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage):GetStageEarningLevelData(player.PlayerSettlement.EarningLevel)
		
		local empData = player.EmployeeManager:GetEmployeeDetail(empId)
		local empMaxLevel = empData.MaxLevel
		local data = self:GetData(empId)
		
		
		local empName = _GetLocalizationTextLogic:GetText(data.NameKey)
		
		if workType == _EmployeeTypeEnum.Cook then
		elseif workType == _EmployeeTypeEnum.Serving then
			local empLevel = empData.ServingLevel		
			if self.MaxLevelListByOverLimitLevel[empMaxLevel] >= self.SkillType2UnlockOverLimitLevel  then
		
				local skillType2 = _EmployeeSkillService:GetData(data.Skill2Type).Id
				
				if skillType2 == _SkillTypeEnum.ServingSpeedUp then		
					local enableUseSkill = _EmployeeSkillService:CanUseSkill(empId,skillType2,player)
					if enableUseSkill then
						local addLevel = _EmployeeSkillService:ReturnSkillGradeValue(empId,skillType2, player)
						empLevel = empLevel + addLevel
					end 
				end
			end
			
			local servingEmployeeWarningLevel = stageEarningLevelData.ServingEmployeeWarningLevel
			
			if empLevel <= servingEmployeeWarningLevel then
				return true
			end
		end 
		return false
	end

	method integer ReturnTransferHeart(string empId, Entity player)
		-- 직원 전송 시 필요한 하트 비용을 계산하는 함수
		local transferMoney = 0
		
		---@type EmployeeData
		local empData = self:GetData(empId)
		local grade = empData.Grade
		
		---@type EmployeeDetailData
		local detailData = player.EmployeeManager:GetEmployeeDetail(empId)
		local chuchuType = empData.Type
		local curLevel = 1
		
		local expExtra = 0
		
		if chuchuType == _EmployeeTypeEnum.Cook then
			curLevel = detailData.CookLevel
			expExtra = detailData.CookExp
			
		elseif chuchuType == _EmployeeTypeEnum.Serving then
			curLevel = detailData.ServingLevel
			expExtra = detailData.ServingExp
		end
		
		---@type EmployeeStatLevelExpData
		local curLevelExpData = _EmployeeUpgradeService.EmployeeExpData[curLevel]
		local curLevelExpSum = curLevelExpData:GetExpSum(player, player.PlayerComponent.UserId)
		
		local employmentLevel = detailData.EmploymentLevel 
		if not isvalid(employmentLevel) then
			employmentLevel = detailData:InitEmploymentLevel(player, player.PlayerComponent.UserId) 
		end
		---@type EmployeeStatLevelExpData
		local employmentLevelExpData = _EmployeeUpgradeService.EmployeeExpData[employmentLevel]
		local employmentLevelExpSum = employmentLevelExpData:GetExpSum(player, player.PlayerComponent.UserId)
		
		local totalExp = expExtra + curLevelExpSum - employmentLevelExpSum 
		local transforHeart = math.floor(totalExp * tonumber(_GetConfigDataLogic:GetConfigNumDataByKey("HeartValuePerWorkStatExp")))
		
		
		return math.tointeger(transforHeart)
	end

	@ExecSpace("ClientOnly")
	method void UpdateAnim(string state, Entity entity)
		-- 직원 애니메이션을 업데이트하는 함수
		local ruid  
		local id = entity.EmployeeInfoScript.Id 
		local data = self:GetData(id)
		local spriteBef = entity.SpriteRendererComponent.SpriteRUID
		
		local equipRuid
		
		if state == "move" then 
			ruid = data.MoveRUID 
			equipRuid = data.EquipMoveRUID
		elseif state =="work" then 
			ruid = data.ChatRUID 
			equipRuid = data.EquipChatRUID
		elseif state =="sleep" then 
			ruid = data.SleepRUID 
			equipRuid = data.EquipSleepRUID 
		elseif state =="wait" then 
			ruid = data.RestRUID 
			equipRuid = data.EquipRestRUID
		elseif state =="levelUp" then 
			ruid = data.LoveRUID 
			equipRuid = data.EquipLoveRUID	
			entity.EmployeeMoveScript.CanMove = false
			entity.EmployeeInfoScript.AnimProduction = false
			entity.MovementComponent:Stop()
			
			_TimerService:SetTimerOnce(function() 
				entity.SpriteRendererComponent.SpriteRUID = spriteBef 
				entity.EmployeeMoveScript.CanMove = true
				entity.EmployeeInfoScript.AnimProduction = true 
			end,2.5)
		end
		
		
		entity.SpriteRendererComponent.SpriteRUID = ruid
		entity.EmployeeInfoScript.AnimType = state
		
		local equipEntity = entity:GetChildByName("equip")
		
		---@type EmployeeOutgameDetailData
		local outgameData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeOutgameDetail(data.Id)
		if isvalid(outgameData) and outgameData.EquipLevel >= 0 then
			if equipRuid == "---" or _UtilLogic:IsNilorEmptyString(equipRuid) then
				equipRuid = _IconRuidEnum.Empty
			end
			
			equipEntity.SpriteRendererComponent.SpriteRUID = equipRuid
		else
			equipEntity.SpriteRendererComponent.SpriteRUID = _IconRuidEnum.Empty
		end
		
		equipEntity.SpriteRendererComponent.SortingLayer = entity.SpriteRendererComponent.SortingLayer
		equipEntity.SpriteRendererComponent.OrderInLayer = entity.SpriteRendererComponent.OrderInLayer + 1
		equipEntity.Enable = true
		
	end

	@ExecSpace("ClientOnly")
	method table ReturnHasBurgerEntities(Entity employee)
		-- 직원이 보유한 버거 엔티티 목록을 반환하는 함수
		local burgers = {}
		
		local childs = employee.Children
		if isvalid(childs) == false then
			return burgers
		end
		local count = #childs
		for i=1, count do
			local child = childs[i]
			---@type TagComponent
			local tagComponent = child.TagComponent
			if tagComponent == nil then
				continue
			end
			
			if tagComponent.Tags[1] == "burger" then
				table.insert(burgers, child)
			end
		end
		
		return burgers
		
	end

	@ExecSpace("ClientOnly")
	method integer ReturnCanStackByDisplayID(integer uniqueId, integer workId, Entity player)
		-- 디스플레이 ID로 스택 가능한 수량을 반환하는 함수
		local slotId = player.MenuManager:ReturnSlotIdxByUniqueID(uniqueId)
		if slotId == nil then
			return -1
		end
		
		local displayNum = _KitchenAppService:ReturnDisplayNum(player)
		
		local displayLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.DisplaystandLevel)
		
		local displayMaxCount = _KitchenAppService:GetData(_KitchenAppEnumType.Display..displayLv).EffectValue
		
		local canRemainStack = function(displayID) 
			
			local displayData =  player.MenuManager.DisplayBurger[uniqueId]
			
		
			if not isvalid(displayData) then 
				return true
			end
			
			if not isvalid(displayData[displayID]) then 
				return true
			end
			
			
			
			if displayData[displayID] < displayMaxCount then 
				return true	
			end
			
			
			return false
			
		end
		
		
		local displayId = slotId
		if displayNum > 10 and workId > 10 then 
			displayId = displayId + 10
		elseif displayNum > 5 and workId > 5 then 
		
			displayId = displayId + 5
		end
		
		if canRemainStack(displayId) then 
			return displayId
		end
		
		
		
		local displayIds = {slotId,slotId+5,slotId+10}
		for i=1,#displayIds do
			
			if displayIds[i] > displayNum then break end 
		
			if canRemainStack(displayIds[i]) then 
				return displayIds[i]
			end
		
			
		end
		
		return -1
	end

	@ExecSpace("ClientOnly")
	method integer ReturnRemainBurgerByDisplayID(integer recipeId, integer workId, Entity player)
		-- 디스플레이 ID로 남은 버거 수량을 반환하는 함수
		local slotId = player.MenuManager:ReturnSlotIdxByUniqueID(recipeId)
		
		local displayNum = _KitchenAppService:ReturnDisplayNum(player)
		local displayData = player.MenuManager.DisplayBurger[recipeId]
		if not isvalid(displayData) then 
			return slotId
		end
		
		local displayId = slotId
		if displayNum > 10 and workId > 10 then 
			displayId = displayId + 10
		elseif displayNum > 5 and workId > 5 then 
			displayId = displayId + 5
		end
		
		
		if displayData[displayId] > 0 then 
			return displayId
		end
		
		
		
		
		local ids = {slotId+5,slotId+10}
		for i=1,#ids do
			
			if ids[i] > displayNum then break end 
			
			if displayData[ids[i]] > 0 then 
				return ids[i]
			end
				
		end
		
		return slotId
	end

	method integer ReturnChuchuLevel(string empId, Entity player)
		-- 츄츄의 레벨을 반환하는 함수
		local detailData = player.EmployeeManager:GetEmployeeDetail(empId)
		local data = self:GetData(empId)
		local level = detailData.CookLevel
		if data.Type ~= _EmployeeTypeEnum.Cook then
			level = detailData.ServingLevel
		end
		
		
		
		return level
	end

	method integer ReturnOverLimitLevelByMaxLevel(integer maxLevel)
		-- 최대 레벨로 한계돌파 레벨을 반환하는 함수
		if maxLevel <= self.MaxLevelListByOverLimitLevel[1] then
			return 0
			
		elseif maxLevel <= self.MaxLevelListByOverLimitLevel[2] then
			return 1
			
		elseif maxLevel <= self.MaxLevelListByOverLimitLevel[3] then
			return 2	
			
		elseif maxLevel <= self.MaxLevelListByOverLimitLevel[4] then
			return 3
		end
		
		
	end

	method integer ReturnDeposit(Entity player, integer employmentType)
		-- 고용 보증금을 반환하는 함수
		local deposit = 0
		local depositDataSet = _DataService:GetTable("EmploymentLevelDataSet")
		
		if employmentType == 1 then
			local employmentLv = math.min(player.PlayerEmployment.EmploymentLv, player.PlayerEmployment.MaxEmploymentCount) 
			deposit = depositDataSet:GetRow(employmentLv):GetItem("RandomDepositCost")
			
		elseif employmentType == 2 then
			local scoutLv = math.min(player.PlayerEmployment.ScoutLv, player.PlayerEmployment.MaxEmploymentCount) 
			deposit = depositDataSet:GetRow(scoutLv):GetItem("ScoutDepositCost")
		end
		
		local stageConfig = _BalanceDataSetLogic:GetStageConfigData(player.PlayerStage.NowStage).EmploymentCostRate
		deposit = math.floor(deposit * (1 + stageConfig))
		
		
		if employmentType == 1 then
			if player.PlayerStage.NowStage == 1 and player.PlayerAchievement:ReturnAchievementProgress(_TutorialAchievementTypeEnum.EmploymentCount) < 2 then
				deposit = _GetConfigDataLogic:GetConfigNumDataByKey("TutorialTempDeposit")
			end
		end
		
		return deposit
	end

	method integer ReturnMaxLevelByOverLimitLevel(integer overLimitLevel)
		-- 한계돌파 레벨로 최대 레벨을 반환하는 함수
		return self.MaxLevelListByOverLimitLevel[overLimitLevel+1]
	end

	method string ReturnRandomCharId(Entity player, string type)
		-- 랜덤 캐릭터 ID를 반환하는 함수
		local employees = player.EmployeeManager.EmployeeDetailTable
		local randomTable = {}
		for i = 1, #employees do
			---@type EmployeeDetailData
			local data = employees[i]
			local id = data.Id
			
			local empData = _EmployeeService:GetData(id)
			if _UtilLogic:IsNilorEmptyString(type) == false then
				if empData.Type ~= type then
					continue
				end
			end
			
			table.insert(randomTable, id)
		end
		
		local randomIndex = _UtilLogic:RandomIntegerRange(1, #randomTable)
		local randomId = randomTable[randomIndex]
		
		return randomId
	end

	method integer ReturnBestLevelOfType(Entity player, string empType, table exceptions)
		-- 특정 타입의 최고 레벨을 반환하는 함수
		
		local bestLevel = 0
		
		for _, detail in pairs(player.EmployeeManager.EmployeeDetailTable) do
			---@type EmployeeDetailData
			local empDetail = detail
			local empData = _EmployeeService:GetData(empDetail.Id)
			
			if empData.Type ~= empType then
				continue
			end
			
			local isExcepted = false
			for i = 1, #exceptions do
				if exceptions[i] == empDetail.Id then
					isExcepted = true
					break
				end
			end
			
			if isExcepted then
				continue
			end
			
			local empLevel = empDetail:ReturnTypeLevel()
			bestLevel = math.max(empLevel, bestLevel)	
		end
		
		return bestLevel
	end

	method table ReturnChuchuIdListByGroupId(integer groupId)
		-- 그룹 ID로 츄츄 ID 목록을 반환하는 함수
		local list = {}
		
		for i, data in pairs(self.EmployeeData) do
			---@type EmployeeData
			local employeeData = data
			if employeeData.GroupId == groupId then
				table.insert(list, employeeData.Id)
			end
		end
		
		table.sort(list)
		
		return list
	end

	method table ReturnStageEmpIdList(integer stageId)
		-- 스테이지 ID로 직원 ID 목록을 반환하는 함수
		local empList = {}
		for groupId, data in pairs(_ChuchuGroupLogic.ChuchuGroupData) do
			local groupData = _ChuchuGroupLogic:GetChuchuGroupData(groupId)
			if groupData == nil then
				continue
			end
			
			if groupData.StageId ~= stageId then
				continue
			end
			
			local empIds = groupData.GroupChuchuList
			if isvalid(empIds) then
				for i, empId in pairs(empIds) do
					table.insert(empList, empId)
				end
			end
		end
		
		return empList
	end

	@ExecSpace("ClientOnly")
	method integer GetNearestDisplayId(integer recipeId, integer workId, string employeeType, number decoPosX)
		-- 가장 가까운 디스플레이 ID를 반환하는 함수
		
		
		local player = _UserService.LocalPlayer
		local displaySlotId = player.MenuManager:ReturnSlotIdxByUniqueID(recipeId)
		if displaySlotId == nil then
			return -1
		end
		
		local displayCount = _KitchenAppService:ReturnDisplayNum(player)
		local displayLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.DisplaystandLevel)
		local displayMaxCount = _KitchenAppService:GetData(_KitchenAppEnumType.Display..displayLv).EffectValue
		local nearstDisplayId = -1
		local nearstDisplayId_IgnoreBurgerCount = -1
		for i=1, 3 do
			local displayId = displaySlotId + (i-1) * 5
			if displayId > displayCount then
				break
			end
			
			if nearstDisplayId_IgnoreBurgerCount == -1 then
				nearstDisplayId_IgnoreBurgerCount = displayId
			else
				if self:GetCloserDisplayId(decoPosX, displayId, nearstDisplayId_IgnoreBurgerCount, employeeType) == displayId then
					nearstDisplayId_IgnoreBurgerCount = displayId
				end
			end
		
			
			local displayData =  player.MenuManager.DisplayBurger[recipeId]
			if isvalid(displayData) and isvalid(displayData[displayId]) then
				if employeeType == _EmployeeTypeEnum.Cook then
					if player.MenuManager.DisplayBurger[recipeId][displayId] >= displayMaxCount then 
						continue
					end
				else
					if player.MenuManager.DisplayBurger[recipeId][displayId] <= 0 then 
						continue
					end
				end
			end
			
			if nearstDisplayId == -1 then
				nearstDisplayId = displayId
			else
				if self:GetCloserDisplayId(decoPosX, displayId, nearstDisplayId, employeeType) == displayId then
					nearstDisplayId = displayId
				end
			end
		
		end
		
		if employeeType == _EmployeeTypeEnum.Serving and nearstDisplayId == -1 then
			return nearstDisplayId_IgnoreBurgerCount
		end
		
		
		return nearstDisplayId
	end

	@ExecSpace("ClientOnly")
	method integer GetCloserDisplayId(number decoPosX, integer displayId1, integer displayId2, string employeeType)
		-- 두 디스플레이 ID 중 더 가까운 것을 반환하는 함수
		local displayPos1 = _LobbySpawnPositionLogic.DisplayOffset[employeeType][displayId1]
		local displayPos2 = _LobbySpawnPositionLogic.DisplayOffset[employeeType][displayId2] 
		if displayPos1 == nil or displayPos2 == nil then
			return -1
		end
		
		local decoDisplay1_dis = math.abs(displayPos1.x - decoPosX)
		local decoDisplay2_dis = math.abs(displayPos2.x - decoPosX)
		
		if decoDisplay1_dis < decoDisplay2_dis then
			return displayId1
		else
			return displayId2
		end
		
	end

end