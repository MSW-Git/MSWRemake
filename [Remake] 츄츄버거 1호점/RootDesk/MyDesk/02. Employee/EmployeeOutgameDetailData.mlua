@Struct
script EmployeeOutgameDetailData

	property string Id = ""

	property integer EquipLevel = -1

	property integer Skill1Grade = 0

	property integer Skill2Grade = 0

	property integer MoveSpeed = 1

	property integer InCollection = 0

	property integer CanBuyEquip = 0

	method void Load(string id)
		-- 직원 ID로 외부 상세 데이터를 초기화하는 함수
		self.Id = id 
		
		self.EquipLevel = -1
		self.Skill1Grade = 1
		self.Skill2Grade = 1
		self.MoveSpeed = 1
		self.InCollection = 0
		self.CanBuyEquip = 0
	end

	method table ConvertToDBTable_ExceptId()
		-- ID 제외하고 외부 데이터를 DB 테이블로 변환하는 함수
		
		if self.EquipLevel == nil then
			self.EquipLevel = -1
		end
		
		if self.Skill1Grade == nil then
			self.Skill1Grade = 0
		end
		
		if self.Skill2Grade == nil then
			self.Skill2Grade = 0
		end
		
		if self.MoveSpeed == nil then
			self.MoveSpeed = 1
		end
		
		if self.InCollection == nil then
			self.InCollection = 0
		end
		
		if self.CanBuyEquip == nil then
			self.CanBuyEquip = 0
		end
		
		
		local result = {self.EquipLevel, self.Skill1Grade, self.Skill2Grade, self.MoveSpeed, self.InCollection, self.CanBuyEquip}
		
		
		return result
	end

	method void SetFromTable(table data)
		-- 테이블 데이터로부터 외부 상세 정보를 설정하는 함수
		self.Id = data["Id"]
		
		self.EquipLevel = tonumber(data["EquipLevel"])
		self.Skill1Grade = tonumber(data["Skill1Grade"])
		self.Skill2Grade = tonumber(data["Skill2Grade"])
		self.MoveSpeed = tonumber(data["MoveSpeed"])
		self.InCollection = tonumber(data["InCollection"])
		self.CanBuyEquip = tonumber(data["CanBuyEquip"])
	end

	method void SetFromTable_Ver2(string id, table data)
		-- 버전 2 테이블 데이터로부터 외부 상세 정보를 설정하는 함수
		self.Id = id
		self.EquipLevel = tonumber(data[1])
		self.Skill1Grade = tonumber(data[2])
		self.Skill2Grade = tonumber(data[3])
		self.MoveSpeed = tonumber(data[4])
		self.InCollection = tonumber(data[5])
		self.CanBuyEquip = tonumber(data[6])
	end

end