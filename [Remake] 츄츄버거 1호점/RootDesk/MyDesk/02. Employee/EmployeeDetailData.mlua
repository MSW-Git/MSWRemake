@Struct
script EmployeeDetailData

	property string Id = ""

	property integer CookLevel = 1

	property integer ServingLevel = 1

	property number CookExp = 0

	property number ServingExp = 0

	property integer MaxLevel = 10

	property integer OverLimitLevel = 0

	property integer MoveSpeedLevel = 1

	property integer EmploymentLevel = 1

	method void Load(string id)
		-- 직원 ID로 상세 데이터를 초기화하는 함수
		self.Id = id 
		self.CookLevel = 1
		self.ServingLevel = 1
		self.MaxLevel = 10
		self.OverLimitLevel = 0
		self.CookExp = 0
		self.ServingExp = 0
		self.EmploymentLevel = 1
	end

	method table ConvertToTable()
		-- 직원 데이터를 테이블 형태로 변환하는 함수
		local result = {}
		
		result["Id"] = self.Id
		
		result["CookLevel"] = self.CookLevel
		result["ServingLevel"] = self.ServingLevel
		
		result["MaxLevel"] = self.MaxLevel 
		result["OverLimitLevel"] = self.OverLimitLevel
		result["EmploymentLevel"] = self.EmploymentLevel
		
		result["CookExp"] = self.CookExp
		result["ServingExp"] = self.ServingExp
		
		return result
	end

	method table ConvertToDBTable()
		-- 직원 데이터를 DB 저장용 테이블로 변환하는 함수
		local _data = _EmployeeService:GetData(self.Id)
		
		if self.Id == nil then
			self.Id = ""
		end
		
		if self.CookLevel == nil then
			self.CookLevel = 1
		end
		
		if self.ServingLevel == nil then
			self.ServingLevel = 1
		end
		
		if self.CookExp == nil then
			self.CookExp = 0
		end
		
		if self.ServingExp == nil then
			self.ServingExp = 0
		end
		
		if self.MaxLevel == nil then
			self.MaxLevel = 10
		end
		
		if self.OverLimitLevel == nil then
			self.OverLimitLevel = 0
		end
		
		if self.EmploymentLevel == nil then
			self.EmploymentLevel = 1
		end
		
		local result = {self.Id, self.CookLevel, self.ServingLevel, self.MaxLevel, self.OverLimitLevel, self.EmploymentLevel, self.CookExp, self.ServingExp, _data.Type}
		return result
	end

	method void SetFromTable(table data)
		-- 테이블 데이터로부터 직원 정보를 설정하는 함수
		self.Id = data["Id"]
		
		self.CookLevel = tonumber(data["CookLevel"])
		self.ServingLevel = tonumber(data["ServingLevel"])
		
		self.MaxLevel = tonumber(data["MaxLevel"])
		self.OverLimitLevel = tonumber(data["OverLimitLevel"])
		self.EmploymentLevel = tonumber(data["EmploymentLevel"])
		
		self.CookExp = tonumber(data["CookExp"])
		self.ServingExp = tonumber(data["ServingExp"])
		
	end

	method void SetFromTable_Ver2(table data)
		-- 버전 2 테이블 데이터로부터 직원 정보를 설정하는 함수
		self.Id = data[1]
		
		self.CookLevel = tonumber(data[2])
		self.ServingLevel = tonumber(data[3])
		
		self.MaxLevel = tonumber(data[4])
		self.OverLimitLevel = tonumber(data[5])
		self.EmploymentLevel = tonumber(data[6])
		
		self.CookExp = tonumber(data[7])
		self.ServingExp = tonumber(data[8])
		
	end

	method integer ReturnChuchuTotalLevel()
		-- 츄츄의 전체 레벨을 반환하는 함수
		local data = _EmployeeService:GetData(self.Id)
		if data.Type == _EmployeeTypeEnum.Cook then
			return self.CookLevel
		else
			return self.ServingLevel
		end
	end

	method integer ReturnStatLevelByStatType(string statType)
		-- 능력 타입에 따른 레벨을 반환하는 함수
		if statType == _EmployeeStatEnumType.Cook then
			return self.CookLevel
		elseif statType == _EmployeeStatEnumType.Serving then
			return self.ServingLevel
		end
	end

	method integer ReturnTypeLevel()
		-- 직원 타입에 따른 레벨을 반환하는 함수
		local employeeData = _EmployeeService:GetData(self.Id)
		if employeeData.Type == _EmployeeStatEnumType.Cook then
			return self.CookLevel
		elseif employeeData.Type == _EmployeeStatEnumType.Serving then
			return self.ServingLevel
		end
	end

	method integer ReturnMaxLevelFromOverLimitLevel()
		-- 한계돌파 레벨에 따른 최대 레벨을 반환하는 함수
		local maxLevel = _EmployeeSkillService.UnLockLevel[self.OverLimitLevel+1]
		return maxLevel
	end

	method integer ReturnOverLimitLevelFromGrade(integer grade)
		-- 등급에 따른 한계돌파 레벨을 반환하는 함수
		if (not isvalid(grade)) or grade < 1 then
			return 1
		else
			return grade - 1
		end
	end

	method string ReturnMoveSpeedText(integer speedLevel)
		-- 이동 속도 레벨을 텍스트로 변환하는 함수
		local string
		string = _StringUtilLogic:NumToString(speedLevel).._LocalizationService:GetText("ChuchuGroupLevel") 
		
		return string
	end

	method number ReturnTypeExp()
		-- 직원 타입에 따른 경험치를 반환하는 함수
		local employeeData = _EmployeeService:GetData(self.Id)
		if employeeData.Type == _EmployeeStatEnumType.Cook then
			return self.CookExp
		elseif employeeData.Type == _EmployeeStatEnumType.Serving then
			return self.ServingExp
		end
	end

	method integer InitEmploymentLevel(Entity player)
		-- 고용 레벨을 초기화하는 함수
		if not isvalid(self.EmploymentLevel) then
			local nowStage = player.PlayerStage.NowStage
			local stageValue = _StageDataSetLogic:GetStageData(nowStage).EmployeeInitLevel
			self.EmploymentLevel = stageValue
		end
		return self.EmploymentLevel
	end

end