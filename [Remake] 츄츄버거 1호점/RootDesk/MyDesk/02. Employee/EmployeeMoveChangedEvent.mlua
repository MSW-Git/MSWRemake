@Event
script EmployeeMoveChangedEvent extends EventType

	property boolean IsArrive = false

	property Vector3 Target = Vector3(0,0,0)

	property string Type = ""

	method void Init(boolean isArrive, Vector3 targetPosition, string type)
		-- 직원 이동 이벤트를 초기화하는 함수
		self.IsArrive = isArrive
		self.Target = targetPosition
		self.Type = type
	end

	method void InitExcpetType(boolean isArrive, Vector3 targetPosition)
		-- 타입 제외하고 직원 이동 이벤트를 초기화하는 함수
		self.IsArrive = isArrive
		self.Target = targetPosition
	end

end