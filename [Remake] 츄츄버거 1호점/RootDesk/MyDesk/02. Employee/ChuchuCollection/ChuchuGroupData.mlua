@Struct
script ChuchuGroupData

	property string GroupNameKey = ""

	property integer GroupId = 0

	property integer StageId = 0

	property table GroupChuchuList = {}

	property integer GroupLevel = 0

	property integer GroupRewardType = 0

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 그룹 정보를 로드하는 함수
		---@type UserDataRow
		local rowData = dataTable:GetRow(index)
		
		self.GroupNameKey = rowData:GetItem("GroupNameKey")
		self.GroupId = _StringUtilLogic:StringToInt(rowData:GetItem("GroupId"))
		self.StageId = _StringUtilLogic:StringToInt(rowData:GetItem("StageId"))
		self.GroupRewardType =  _StringUtilLogic:StringToInt(rowData:GetItem("RewardType"))
		self.GroupChuchuList = _EmployeeService:ReturnChuchuIdListByGroupId(self.GroupId) 
	end

end