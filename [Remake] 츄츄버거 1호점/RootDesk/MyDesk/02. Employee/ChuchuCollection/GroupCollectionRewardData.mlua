@Struct
script GroupCollectionRewardData

	property integer GroupCollectionLevel = 0

	property string RewardItemType1 = ""

	property string RewardItemType2 = ""

	property integer RewardItemCount = 0

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 그룹 컬렉션 보상 데이터를 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.GroupCollectionLevel = _StringUtilLogic:StringToInt(row:GetItem("GroupCollectionLevel"))
		self.RewardItemType1 = row:GetItem("RewardItemType1")
		self.RewardItemType2 = row:GetItem("RewardItemType2")
		self.RewardItemCount = _StringUtilLogic:StringToInt(row:GetItem("RewardItemCount"))
	end

	method string ReturnRewardIdFromType(integer typeNum)
		-- 보상 타입에 따라 적절한 보상 아이템 ID를 반환하는 함수
		if typeNum == 2 then
			return self.RewardItemType2
		else
			return self.RewardItemType1
		end
	end

end