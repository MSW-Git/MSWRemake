@Component
script UIEmployeeManageDeployListRenderer extends Component

	property string Category = ""

	property string EmployeeId = ""

	property boolean isLocked = true

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 배치 리스트 렌더러를 초기화하는 함수
		self:DisableOutline()
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 배치 리스트 렌더러를 초기화하는 함수
		self.EmployeeId = ""
		self.Entity:GetChildByName("Slot").Enable =  false
		self.Entity:GetChildByName("SlotEmpty").Enable = true
		self.Entity:GetChildByName("Portrait").SpriteGUIRendererComponent.ImageRUID = ""
		self.Entity:GetChildByName("Portrait").Enable = false
		
		self.Entity:GetChildByName("Level").Enable = false
		self.Entity:GetChildByName("StatIcon").Enable = false
	end

	@ExecSpace("ClientOnly")
	method void Set(string employeeId)
		-- 직원 ID로 배치 리스트 렌더러를 설정하는 함수
		self.EmployeeId = employeeId 
		
		---@type EmployeeData
		local data = _EmployeeService:GetData(self.EmployeeId)
		---@type EmployeeDetailData
		local detail = _UserService.LocalPlayer.EmployeeManager:GetEmployeeDetail(self.EmployeeId)
		
		
		if not isvalid(detail) then 
			return
		end
		
		local detailTable = detail:ConvertToTable()
		
		local portrait = self.Entity:GetChildByName("Portrait")
		
		if isvalid(portrait.UIImageAlign) then
			portrait.UIImageAlign:UpdateCanvas(data.PortraitUIRUID)
		else
			portrait.SpriteGUIRendererComponent.ImageRUID = data.PortraitRUID
		end
		portrait.Enable = true
		
		local level = self.Entity:GetChildByName("Level")
		level.TextComponent.Text = "Lv."..detailTable[self.Category.."Level"]
		level.TextComponent.FontColor =  _ColorCodeEnum:GetColor(_ColorCodeEnum.WhiteFont)
		level.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#7A5D1F")
		
		level.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 슬롯 클릭 시 처리하는 함수
			
		
		if self.isLocked then 
			
			_UIToast:ShowMessage(_LocalizationService:GetText("DeployListLockedSlotMsg"))
		
			return 
			
		end
		
		
		if self.EmployeeId == "" then 
			
			_UIToast:ShowMessage(_LocalizationService:GetText("DeployListLockedEmptyMsg"))
		
			return 
			
		end
		
		_UIEmployeeManageService:SelectEmp(self.EmployeeId,_UserService.LocalPlayer)
		
	end

	@ExecSpace("ClientOnly")
	method void EnableOutline()
		-- 슬롯 아웃라인을 활성화하는 함수
		self.Entity:GetChildByName("Select").Enable = true
	end

	@ExecSpace("ClientOnly")
	method void DisableOutline()
		-- 슬롯 아웃라인을 비활성화하는 함수
		
		self.Entity:GetChildByName("Select").Enable = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 배치 리스트 슬롯 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:OnClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEmployeeDetailChangeEvent(EmployeeDetailChangeEvent event)
		-- 직원 상세 정보 변경 이벤트를 처리하는 핸들러
		if _UIGroupManager.EmployeeManageGroup.Enable then 
			if not _UtilLogic:IsNilorEmptyString(self.EmployeeId) then 
				self:Set(self.EmployeeId)
			end
		end
		
	end

end