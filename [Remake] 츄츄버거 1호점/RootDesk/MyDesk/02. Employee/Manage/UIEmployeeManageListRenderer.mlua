@Component
script UIEmployeeManageListRenderer extends Component

	property integer Index = 0

	property string EmployeeId = ""

	property string State = ""

	property Entity slotEntity = nil

	@ExecSpace("Client")
	method void Set(string employeeId)
		-- 직원 ID로 렌더러의 상태를 설정하는 함수
		self.EmployeeId = employeeId
		
		---@type EmployeeData
		local data = _EmployeeService:GetData(self.EmployeeId)
		
		local portrait = self.Entity:GetChildByName("Portrait")
		if not isvalid(portrait) then
			portrait = self.Entity:GetChildByName("Mask"):GetChildByName("Portrait") 
		end
		
		if isvalid(portrait) then
			_EmployeeUIService:DrawPortraitWithEquip(portrait, portrait, data)	
		else	
		end
		
		local typeIcon = self.Entity:GetChildByName("TypeIcon")
		if isvalid(typeIcon) then
			if self.Entity.Parent.Parent.Name == "EmployeeList" then
				typeIcon.SpriteGUIRendererComponent.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(data.Type)
			else
				typeIcon.Enable = false
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	method void EnableOutline()
		-- 선택 외곽선을 활성화하는 함수
		self.Entity:GetChildByName("Select").Enable = true
	end

	@ExecSpace("ClientOnly")
	method void DisableOutline()
		-- 선택 외곽선을 비활성화하는 함수
		self.Entity:GetChildByName("Select").Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 직원 슬롯 클릭 시 처리하는 함수
		_UIEmployeeManageService:SelectEmp(self.EmployeeId,_UserService.LocalPlayer)
	end

	@ExecSpace("ClientOnly")
	method void SwitchOutline(Entity list, boolean selectedSlot)
		-- 선택된 슬롯의 외곽선을 전환하는 함수
		local scroll = list
		for _, child in pairs(scroll.Children) do
			if child == selectedSlot then
				child:GetChildByName("Outline").Enable = true
			else
				child:GetChildByName("Outline").Enable = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Init_EmployeeManage(integer index, string employeeId)
		-- 직원 관리용 렌더러를 초기화하는 함수
		self.Index = index
		self.EmployeeId = employeeId
		
		local player = _UserService.LocalPlayer
		local data = _EmployeeService:GetData(employeeId)
		
		
		if _UtilLogic:IsNilorEmptyString(employeeId) then 
			self.Entity.Enable = false	
			return 
		end 
		if not isvalid(player.EmployeeManager:GetEmployeeDetail(employeeId)) then 
			self.Entity.Enable = false
			return 
		end 
		
		self:Set(employeeId)	
		
		local typeIcon = self.Entity:GetChildByName("TypeIcon")
		if isvalid(typeIcon) then
			typeIcon.SpriteGUIRendererComponent.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(data.Type)
			typeIcon.Enable = true
		end
		
		
		local disableUI = self.Entity:GetChildByName("Disable") 
		disableUI:GetChildByName("UISprite").Enable = false 
		disableUI:GetChildByName("Text").Enable = false 
		disableUI:GetChildByName("Check").Enable = false
		disableUI.Enable = false
		
		local locationData = player.EmployeeManager:GetEmployeeLocation(employeeId)
		if not isvalid(locationData) then
			return
		else
		end
		if locationData.Location ~= _EmployeeTypeEnum.Waiting then
			disableUI.TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_Selected")  
			disableUI:GetChildByName("Check").Enable = true
			
			disableUI.Enable = true
		end
		
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void OnChangeLocation()
		-- 직원 위치 변경 시 UI를 업데이트하는 함수
		local player = _UserService.LocalPlayer
		local disableUI = self.Entity:GetChildByName("Disable") 
		disableUI:GetChildByName("UISprite").Enable = false 
		disableUI:GetChildByName("Text").Enable = false 
		disableUI:GetChildByName("Check").Enable = false
		disableUI.Enable = false
		
		local locationData = player.EmployeeManager:GetEmployeeLocation(self.EmployeeId)
		if not isvalid(locationData) then
			return
		else
		end
		if locationData.Location ~= _EmployeeTypeEnum.Waiting then
			disableUI.TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_Selected")  
			disableUI:GetChildByName("Check").Enable = true
			
			disableUI.Enable = true
		end
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Init_SelectChuchuInCollection(integer index, string employeeId)
		-- 츄츄 컴렉션 선택용 렌더러를 초기화하는 함수
		self.Index = index
		self.EmployeeId = employeeId
		
		self:Set(employeeId)
		self.Entity:GetChildByName("SkillIcon").Enable = false
		self.Entity:GetChildByName("Disable").Enable = false
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Init_Training(integer index, string employeeId, boolean isAutoTraining)
		-- 훈련용 렌더러를 초기화하는 함수
		self.Index = index
		self.EmployeeId = employeeId
		
		local player = _UserService.LocalPlayer
		local employeeData = player.EmployeeManager:GetEmployeeDetail(employeeId)
		---@type EmployeeData
		local data = _EmployeeService:GetData(employeeId)
		
		local trainingAutoCompo = _UIGroupManager.TrainingAutoGroup.UITrainingAuto
		local trainingSettingCompo = _UIGroupManager.TrainingSettingGroup.UITrainingSetting
		
		self:Set(employeeId) 
		
		local skillIconEntity = self.Entity:GetChildByName("SkillIcon")
		local hasTrainingSkill = _EmployeeSkillService:HasSkillOfType(data.Id, "Training", player)
		if hasTrainingSkill == true then
			skillIconEntity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum:GetSkillTypeIcon("Training")
			skillIconEntity.Enable = true
			
			local skill1Data = _EmployeeSkillService:GetData(data.Skill1Type)
			if skill1Data.Type == "Training" then
				if _EmployeeSkillService:CanUseSkill(employeeId, data.Skill1Type, player) then
					self.Entity.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.UI_AdvantageMaterial)
				end
			end	
		else
			skillIconEntity.Enable = false
			self.Entity.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		end
		
		if isAutoTraining then
			self:ChangeChuchuListSlotState_Auto() 
			
		else
			local autoTrainingNum =  self:CheckEmployeeIsAutoTraining()
			if autoTrainingNum > 0 then 
				self.Entity:GetChildByName("Disable").Enable = true
				self.Entity:GetChildByName("Disable"):GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum:GetAutoTrainingIcon(autoTrainingNum) 
				self.Entity:GetChildByName("Disable"):GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_OnProgress") 
				
			elseif self:CheckEmployeeTrainingSetting() then
				self.Entity:GetChildByName("Disable").Enable = true
				self.Entity:GetChildByName("Disable"):GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.CheckSign
				self.Entity:GetChildByName("Disable"):GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_Selected") 
			else
				self.Entity:GetChildByName("Disable").Enable = false
			end
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method boolean CheckEmployeeTrainingSetting()
		-- 직원이 훈련 설정에 포함되어 있는지 확인하는 함수
		local trainingSettingCompo = _UIGroupManager.TrainingSettingGroup.UITrainingSetting
		local seletedChuchuList = trainingSettingCompo.SelectedEmpList
		for i = 1, #seletedChuchuList do
			local empId = seletedChuchuList[i]
			if empId == self.EmployeeId then
				return true
			end
		end
		
		return false
	end

	@ExecSpace("ClientOnly")
	method void ChangeChuchuListSlotState_Auto()
		-- 자동 훈련 상태에 따라 츄츄 리스트 슬롯 상태를 변경하는 함수
		local disable = self.Entity:GetChildByName("Disable")
		
		
		local autoTrainingManager = _UserService.LocalPlayer.PlayerAutoTrainingManager
		for i = 1, 3 do
			---@type AutoTrainingSlotData
			local slotData = autoTrainingManager.AutoTrainingSlotInfoTable[i]
			local state = slotData.State
			local chuchuId = slotData.ChuchuId
			
			if self.EmployeeId == chuchuId then
				
				
				
				if state == _AutoTrainingUIStateEnum.Default or state == _AutoTrainingUIStateEnum.List_Selected then
					disable.Enable = true
					disable:GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_Selected")
					
				elseif state == _AutoTrainingUIStateEnum.OnProgress then
					disable.Enable = true
					disable:GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_OnProgress")
					
				elseif state == _AutoTrainingUIStateEnum.WaitingReward then
					disable.Enable = true
					disable:GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_WaitingReward")
				end
				break
			else
				disable.Enable = false
			end
		
		end
		
		
	end

	method void ChangeChuchuListSlotState_Auto_Fixed(string state)
		-- 고정된 상태로 자동 훈련 슬롯 상태를 변경하는 함수
		local disable = self.Entity:GetChildByName("Disable")	
		
		if state == _AutoTrainingUIStateEnum.Default then
			disable.Enable = false
		
		elseif state == _AutoTrainingUIStateEnum.List_Selected then
			disable.Enable = true
			disable:GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_Selected")
			
		elseif state == _AutoTrainingUIStateEnum.OnProgress then
			disable.Enable = true
			disable:GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_OnProgress")
			
		elseif state == _AutoTrainingUIStateEnum.WaitingReward then
			disable.Enable = true
			disable:GetChildByName("Text").TextComponent.Text = _LocalizationService:GetText("EmployeeSlotState_WaitingReward")
		end
		
	end

	@ExecSpace("ClientOnly")
	method integer CheckEmployeeIsAutoTraining()
		-- 직원이 자동 훈련 중인지 확인하고 슬롯 번호를 반환하는 함수
		local player = _UserService.LocalPlayer
		local autoTrainingManager = _UserService.LocalPlayer.PlayerAutoTrainingManager
		
		for i = 1, 3 do
			---@type AutoTrainingSlotData
			local slotData = autoTrainingManager.AutoTrainingSlotInfoTable[i]
			local employeeId = slotData.ChuchuId
			
			if isvalid(employeeId) and employeeId == self.EmployeeId and slotData.State == _AutoTrainingUIStateEnum.OnProgress then
				return i 
			end
		end
		return 0
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if _UIGroupManager.ChuchuCollectionGroup.Enable then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIGroupManager.ChuchuCollectionGroup.UIChuchuCollection:OnClickChuchuSlot(self.EmployeeId, self.Entity)
			
		elseif _UIGroupManager.SelectChuchuInCollection.Enable then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIGroupManager.SelectChuchuInCollection.UISelectChuchuInCollection:OnClickChuchuSlot(self.EmployeeId)
			
		elseif (_UIGroupManager.EmployeeManageGroup.Enable) then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			self:OnClick()
			
		elseif _UIGroupManager.EmploymentGroup.Enable == true then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			 _UIGroupManager.EmploymentGroup.UIEmployment:SwitchButtonOutline(Entity)
			
		elseif  _UIGroupManager.TrainingAutoGroup.Enable and _UIGroupManager.TrainingAutoGroup.UITrainingAuto.ChuchuListPopup.Enable then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIGroupManager.TrainingAutoGroup.UITrainingAuto:RefreshDetail(self.EmployeeId)
			
		elseif _UIGroupManager.TrainingSettingGroup.Enable then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIGroupManager.TrainingSettingGroup.UITrainingSetting:RefreshDetail(self.EmployeeId)
			
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEmployeeDetailChangeEvent(EmployeeDetailChangeEvent event)
		-- 직원 상세 정보 변경 이벤트를 처리하는 핸들러
		if  _UIGroupManager.EmployeeManageGroup.Enable then 
			if not _UtilLogic:IsNilorEmptyString(self.EmployeeId) then 
				self:Set(self.EmployeeId)
			end
		end
		
	end

end