@Component
script UIEmployeeManageDetailRenderer extends Component

	property string EmployeeId = "E0001"

	property Entity deposit = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 직원 상세 정보 렌더러를 초기화하는 함수
		if isvalid(self.Entity:GetChildByName("Deposit")) then
			self.Entity:GetChildByName("Deposit").Enable = false 
		end
		
		local tooltip = function(btn, tooltipEntity)
			
			if isvalid(btn) then 
				btn:ConnectEvent(ButtonClickEvent, function()
					if _UIGroupManager:IsEnableOpenPopUp() == false then
						return
					end
					
					_TooltipService:OpenTooltip(tooltipEntity, nil)
					 
				end)
			
			end
			
		end
		
		local skill1Btn = self.Entity:GetChildByName("Skill1")
		local skill1InfoBtn = self.Entity:GetChildByName("Skill1"):GetChildByName("UIButton")
		local skill1ToolTip = skill1InfoBtn:GetChildByName("ToolTip")
		skill1ToolTip:SetEnable(false)
		
		local skill2Btn = self.Entity:GetChildByName("Skill2")
		local skill2InfoBtn = self.Entity:GetChildByName("Skill2"):GetChildByName("UIButton")
		local skill2ToolTip = skill2InfoBtn:GetChildByName("ToolTip")
		skill2ToolTip:SetEnable(false)
		
		tooltip(skill1Btn,skill1ToolTip)
		tooltip(skill1InfoBtn,skill1ToolTip)
		tooltip(skill2Btn,skill2ToolTip)
		tooltip(skill2InfoBtn,skill2ToolTip)
		local speedInfoBtn = self.Entity:GetChildByName("Speed"):GetChildByName("Text"):GetChildByName("InfoBtn")
		local speedInfoTooltip = speedInfoBtn:GetChildByName("ToolTip")
		speedInfoTooltip.Enable = false
		tooltip(speedInfoBtn, speedInfoTooltip)
		
	end

	@ExecSpace("ClientOnly")
	method void Set(string employeeID)
		-- 직원 ID로 상세 정보를 설정하는 함수
		if isvalid(employeeID) then 
			self.EmployeeId = employeeID
		end
		
		if self.EmployeeId == nil then
			return
		end
		
		_UIEmployeeListService:Set(self.EmployeeId,self.Entity)
	end

	@ExecSpace("ClientOnly")
	method void SpecializedStat(any data)
		-- 직원의 특화 스탯을 표시하는 함수
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEmployeeDetailChangeEvent(EmployeeDetailChangeEvent event)
		-- 직원 상세 정보 변경 이벤트를 처리하는 핸들러
		if ( _UIGroupManager.EmployeeManageGroup.Enable )and (self.Entity.Parent.Parent == _UIGroupManager.EmployeeManageGroup )then 
			self:Set(_UIEmployeeManageService.UIManageCompo.SelectEmployeeID)
			
		elseif self.Entity.Parent.Enable  then 	
			self:Set(nil)
			
		end
	end

end