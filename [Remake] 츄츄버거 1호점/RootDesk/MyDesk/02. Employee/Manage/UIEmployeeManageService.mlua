	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "d587e582-ffcc-445f-9d82-4eca65f56841")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 업그레이드 버튼 클릭 이벤트를 처리하는 핸들러
		
