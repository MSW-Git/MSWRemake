@Component
script UIEmployeeManageScript extends Component

	property table employeesLocation = {}

	property string SelectEmployeeID = ""

	@ExecSpace("ClientOnly")
	method void Init()
		-- 직원 관리 스크립트를 초기화하는 함수
		table.clear(self.employeesLocation)
		local copy = {}
		for key, value in pairs(_UserService.LocalPlayer.EmployeeManager.EmployeesLocation) do
			table.insert(self.employeesLocation,value)
		end
	end

	@ExecSpace("Client")
	method void ChangeLocationToClient(string location)
		-- 클라이언트에서 직원의 위치를 변경하는 함수
		local player =  _UserService.LocalPlayer
		
		---@type EmployeeLocationData
		local locationData
		for _,data in pairs(self.employeesLocation) do 
			if data.Id == self.SelectEmployeeID then 
				locationData = data
			end
		end
		
		
		local curLocation = locationData.Location
		
		
		local result = false
		local empNum
		
		if curLocation == location then 
			result = true 
			locationData.Location = _EmployeeTypeEnum.Waiting
			locationData.SlotIdx = 0
			_UIEmployeeManageService:RefreshLocation(_UserService.LocalPlayer, locationData.Id)
			_UIEmployeeManageService:SelectEmp(self.SelectEmployeeID,_UserService.LocalPlayer)
		else 
			
		
			if location == _EmployeeTypeEnum.Cook then 
				local grillCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer, _UpgradeTypeEnum.GrillCount)
				
				empNum = _UIEmployeeManageService.UIDeployListCompo.CookEmployeeCount + 1 
				if  empNum <= grillCount then 
					result = true
				end
		
			elseif location == _EmployeeTypeEnum.Serving then 
		
				local counterCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer, _UpgradeTypeEnum.CounterCount)
				
				empNum = _UIEmployeeManageService.UIDeployListCompo.ServingEmployeeCount + 1
				
				if empNum <= counterCount then 
					result = true 			
				end
				
				
			end
				
			
			if result then 
				
				locationData.Location = location
				locationData.SlotIdx =  _UIEmployeeManageService.UIDeployListCompo:ReturnRemainSlotIdx(location)
				_UIEmployeeManageService:RefreshLocation(_UserService.LocalPlayer, locationData.Id)
				_UIEmployeeManageService:SelectEmp(self.SelectEmployeeID,_UserService.LocalPlayer)
		
			else
		
				_UIToast:ShowMessage(_LocalizationService:GetText("CantDeployMsg"))
			
			end
			
		end
	end

	@ExecSpace("Client")
	method void ChangeLocationToServer(Entity player)
		-- 서버로 직원의 위치 변경을 요청하는 함수
		if player ~= _UserService.LocalPlayer then 
			return
		end
		
		for idx, location in pairs(self.employeesLocation) do 
			---@type EmployeeLocationData
			local locationData = location
			if locationData.Location == _EmployeeTypeEnum.Cook or locationData.Location == _EmployeeTypeEnum.Serving then 
				player.EmployeeManager:RequestChangeLocationToStore(locationData.Id,locationData.Location,locationData.SlotIdx)	
			else 
				player.EmployeeManager:RequestChangeLocationToWaiting(locationData.Id)
			end
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnClickDeployBtn()
		-- 배치 버튼 클릭 시 처리하는 함수
		local type = _EmployeeService:GetData(self.SelectEmployeeID).Type
		self:ChangeLocationToClient(type)
		
		_TutorialManager:CheckForceTo()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "53b41baf-9a0a-4c5f-abb8-83ee0bddf82b")
	handler HandleButtonClickEvent1(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:OnClickDeployBtn()
		
	end

end