@Component
script UITweenMoveBounce extends Component

	property number posX = 0

	property number posY = 0

	@ExecSpace("ClientOnly")
	method void StartTween(Vector2 targetPos, number duration, boolean isFadeAfterEnd, number fadeDuration)
		-- 타겟 위치로 바운스 효과와 함께 이동하는 트윈 시작
		self.Entity.Enable = false
		local delay = _UtilLogic:RandomIntegerRange(0, 1000)/10000
		
		self.posX = self.Entity.UITransformComponent.anchoredPosition.x
		self.posY = self.Entity.UITransformComponent.anchoredPosition.y
		
		
		
		local firstTime = duration/7 + delay
		local lastTime = duration - firstTime
		
		local firstTargetPosY = self.posY + _UtilLogic:RandomIntegerRange(0, 1000)/10
		local lastTargetPosY = targetPos.y
		
		_TimerService:SetTimerOnce(function()
			_SoundService:PlaySound(_ResourceManager.SFXTable["IconDrop"], 0.1)
			
			self.Entity.Enable = true
			
			local xTween = _TweenLogic:PlayTween(self.posX, targetPos.x, duration, EaseType.CubicEaseOut, function(t)
				self.posX = t
			end)
			
			local yTweenFirst = _TweenLogic:PlayTween(self.posY, firstTargetPosY, firstTime, EaseType.CircEaseOut, function(t)
				self.posY = t
			end)
			
			_TimerService:SetTimerOnce(function()
				local yTween = _TweenLogic:PlayTween(firstTargetPosY, targetPos.y, lastTime, EaseType.BounceEaseOut, function(t)
					self.posY = t
				end)
			end, firstTime)
			
		end, delay)
		
		if isFadeAfterEnd then
			_TimerService:SetTimerOnce(function()
				local a = self.Entity.CanvasGroupComponent.GroupAlpha
				local aTween = _TweenLogic:PlayTween(a, 0, fadeDuration, EaseType.CubicEaseOut, function(t)
					self.Entity.CanvasGroupComponent.GroupAlpha = t
				end)
				_TimerService:SetTimerOnce(function()
					_EntityService:Destroy(self.Entity)
				end, fadeDuration)
			end, duration + delay)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임 위치 업데이트
		self.Entity.UITransformComponent.anchoredPosition = Vector2(self.posX, self.posY)
	end

end