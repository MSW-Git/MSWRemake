@Component
script UITweenMoveFade extends Component

	property number posX = 0

	property number posY = 0

	property number alpha = 0

	@ExecSpace("ClientOnly")
	method void StartTween(Vector2 direction, number duration, number stayDelay)
		-- 방향에 따른 이동과 페이드 효과 트윈 시작
		self.Entity.Enable = false
		self.Entity.CanvasGroupComponent.GroupAlpha = 0
		
		self.posX = self.Entity.UITransformComponent.anchoredPosition.x
		self.posY = self.Entity.UITransformComponent.anchoredPosition.y
		self.alpha = self.Entity.CanvasGroupComponent.GroupAlpha
		
		local targetPosY = self.posY + direction.y * 50
		local targetPosX = self.posX + direction.x * _UtilLogic:RandomIntegerRange(0, 100)/10
		
		self.Entity.Enable = true
		
		local xTween = _TweenLogic:PlayTween(self.posX, targetPosX, duration, EaseType.CubicEaseOut, function(t)
			self.posX = t
		end)
		
		local yTween = _TweenLogic:PlayTween(self.posY, targetPosY, duration, EaseType.CubicEaseOut, function(t)
			self.posY = t
		end)
		
		local aTween = _TweenLogic:PlayTween(self.alpha, 1, duration, EaseType.CubicEaseOut, function(t)
			self.alpha = t
		end)
		
		_TimerService:SetTimerOnce(function()
			_EntityService:Destroy(self.Entity)
		end, duration+stayDelay)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임 위치와 알파 업데이트
		self.Entity.UITransformComponent.anchoredPosition = Vector2(self.posX, self.posY)
		self.Entity.CanvasGroupComponent.GroupAlpha = self.alpha
	end

end