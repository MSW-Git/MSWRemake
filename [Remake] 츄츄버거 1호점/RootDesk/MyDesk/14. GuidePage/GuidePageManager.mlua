@Logic
script GuidePageManager extends Logic

	property Entity GuideUIGroup = "28a074f4-3627-41b0-8491-2ff35c456c7f"

	property string PageModelId = "model://891defb4-d6e7-478a-ad1d-1b5ddaf4372a"

	property string ContentTitleModelId = "model://89d6a0d6-598c-48d8-a3e0-452cdc8b4b87"

	property string ContentDescModelId = "model://fd0dcc6a-b7a7-4dc0-93b1-ac4c7f52c5e3"

	property table GuidlePageData = {}

	property table GuideContentDataByPage = {}

	property SyncTable<string, Entity> MadeGuidePageEntites

	property string ContentTypeTitle = "Title"

	property string ContentTypeDesc = "Desc"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 가이드 페이지 매니저 초기화 및 모든 가이드 버튼들을 설정하는 함수
		table.clear(self.MadeGuidePageEntites)
		table.clear(self.GuidlePageData)
		table.clear(self.GuideContentDataByPage)
		
		self:LoadDataSet()
		
		self.GuideUIGroup:SetEnable(false)
		self.GuideUIGroup.UIGroupComponent.DefaultShow = false
		
		self:SetGuidePageButton("GP01", _EntityService:GetEntityByPath("/ui/LobbyHUDGroup/MainMenuPanel/Menu_TutorialGuide")) 
		self:SetGuidePageButton("GP03", _EntityService:GetEntityByPath("/ui/LobbyHUDGroup/EmployeeInfo/GuideBtn")) 
		self:SetGuidePageButton("GP03", _EntityService:GetEntityByPath("/ui/EmployeeManageGroup/Main/DeployeList/Btn_Guide")) 
		
		self:SetGuidePageButton("GP04", _EntityService:GetEntityByPath("/ui/EmployeeUpgradeGroup/Main/TitleBg/TxtTitle/GuideBtn")) 
		self:SetGuidePageButton("GP05", _EntityService:GetEntityByPath("/ui/EmployeeManageGroup/Main/EmployeeList/Title/GuideBtn")) 
		self:SetGuidePageButton("GP06", _EntityService:GetEntityByPath("/ui/EmploymentGroup/Panel/TitleBg/TxtTitle/Btn_Guide")) 
		
		self:SetGuidePageButton("GP07", _EntityService:GetEntityByPath("/ui/RecipeGroup/UIRecipeMaking/HelpBtn")) 
		self:SetGuidePageButton("GP07", _EntityService:GetEntityByPath("/ui/RecipeGroup/UIIngreCardSetting/Title/HelpBtn")) 
		
		self:SetGuidePageButton("GP08", _EntityService:GetEntityByPath("/ui/TrainingGroup/Title/TitleText/Btn_Guide")) 
		self:SetGuidePageButton("GP09", _EntityService:GetEntityByPath("/ui/StoreInfoGroup/UIStoreInfo/Title/HelpBtn")) 
		self:SetGuidePageButton("GP10", _EntityService:GetEntityByPath("/ui/TrainingSettingGroup/Panel/TitleBg/TxtTitle/Btn_Guide")) 
		self:SetGuidePageButton("GP10", _EntityService:GetEntityByPath("/ui/AutoTrainingGroup/Panel/TitleBg/TxtTitle/Btn_Guide")) 
		
		self:SetGuidePageButton("GP11", _EntityService:GetEntityByPath("/ui/RecipeGroup/UIIngreGachaDim/BG/Title/HelpBtn")) 
		self:SetGuidePageButton("GP12", _EntityService:GetEntityByPath("/ui/RecipeGroup/UIRecipeBook/Title/HelpBtn")) 
		self:SetGuidePageButton("GP12", _EntityService:GetEntityByPath("/ui/RecipeGroup/UIReceipeComboInfoDim/UIRecipeComboInfo/Title/HelpBtn")) 
		
		self:SetGuidePageButton("GP13", _EntityService:GetEntityByPath("/ui/VIPOrderGroup/VIPOrderPanel/Title/GuideBtn")) 
		self:SetGuidePageButton("GP14", _EntityService:GetEntityByPath("/ui/ManagementGroup/UIManagement/Contents/Title/HelpBtn")) 
		self:SetGuidePageButton("GP15", _EntityService:GetEntityByPath("/ui/TrialGroup/UITrialSelect/TopMenu/TitleBar/GuideBtn")) 
		self:SetGuidePageButton("GP16", _EntityService:GetEntityByPath("/ui/StoreRankingGroup/StoreRanking/Title/HelpBtn")) 
		self:SetGuidePageButton("GP17", _EntityService:GetEntityByPath("/ui/LobbyHUDGroup/MainMenuPanel/UIMainMenu/MainMenuContents/MainMenuTitle_Group4/MainMenuContents_Group4/TrainingGauge/Btn_Guide")) 
		self:SetGuidePageButton("GP18", _EntityService:GetEntityByPath("/ui/LobbyHUDGroup/KitchenAppInfo/GuideBtn")) 
		self:SetGuidePageButton("GP18", _EntityService:GetEntityByPath("/ui/LobbyHUDGroup/KitchenAppNone/GuideBtn")) 
		
		self:SetGuidePageButton("GP19", _EntityService:GetEntityByPath("/ui/StoreInfoGroup/UIStoreInfo/InfoArea/UIReputationReview/LeftSection/HelpBtn")) 
		
		self:SetGuidePageButton("GP20", _EntityService:GetEntityByPath("/ui/StageInfoGroup/StageSelect/Title/HelpBtn")) 
		self:SetGuidePageButton("GP20", _EntityService:GetEntityByPath("/ui/StageInfoGroup/StageInfo/Panel/Title/HelpBtn")) 
		self:SetGuidePageButton("GP20", _EntityService:GetEntityByPath("/ui/StageInfoGroup/StageSetting/Title/HelpBtn")) 
		
		self:SetGuidePageButton("GP21", _EntityService:GetEntityByPath("/ui/IngreBunCollectionGroup/IngreBunCollection/Title/HelpBtn")) 
		self:SetGuidePageButton("GP22", _EntityService:GetEntityByPath("/ui/ChuchuCollectionGroup/TitleBg/TxtTitle/GuideBtn")) 
		self:SetGuidePageButton("GP23", _EntityService:GetEntityByPath("/ui/ChuchuCollectionGroup/BuyEquipPopupDim/BuyEquipPopup/Title/HelpBtn")) 
		self:SetGuidePageButton("GP23", _EntityService:GetEntityByPath("/ui/ChuchuCollectionGroup/UpgradeEquipPopupDim/UpgradeEquipPopup/Title/HelpBtn")) 
		
		self:SetGuidePageButton("GP24", _EntityService:GetEntityByPath("/ui/UIBoosterPackGroup/Dim/Title/DescText1/Btn_Guide")) 
		self:SetGuidePageButton("GP25", _EntityService:GetEntityByPath("/ui/ChuchuCollectionGroup/CollectionProgress/HelpBtn")) 
		self:SetGuidePageButton("GP26", _EntityService:GetEntityByPath("/ui/UIShopGroup/UIShop/TopMenu/TitleBar/GuideBtn")) 
		self:SetGuidePageButton("GP27", _EntityService:GetEntityByPath("/ui/UISpecialShopGroup/UISpecialShop/TopMenu/TitleBar/GuideBtn")) 
		self:SetGuidePageButton("GP28", _EntityService:GetEntityByPath("/ui/UIPiggyBankGroup/Dim/Panel/Title/TitleText/Btn_Guide")) 
		
		self:SetGuidePageButton("GP29", _EntityService:GetEntityByPath("/ui/ExchangeSettingGroup/Title/Btn_Guide")) 
		
		self:SetGuidePageButton("GP30", _EntityService:GetEntityByPath("/ui/IngreSynthGroup/Title/Btn_Guide")) 
	end

	@ExecSpace("ClientOnly")
	method void LoadDataSet()
		-- 가이드 페이지 목록 데이터셋을 로드하여 내부 테이블에 저장하는 함수
		local pageDataSet = _DataService:GetTable("GuidePageListDataSet")
		
		for i = 1, pageDataSet:GetRowCount() do
			local pageData = GuidePageListData()
			pageData:Load(pageDataSet, i)
			
			if self.GuidlePageData[pageData.Id] ~= nil then
				break
			end
		
			self.GuidlePageData[pageData.Id] = pageData
		end
	end

	@ExecSpace("ClientOnly")
	method void GuideUIGroupEnable(boolean enable)
		-- 가이드 UI 그룹의 활성화 상태를 설정하는 함수
		self.GuideUIGroup:SetEnable(enable)
		self.GuideUIGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
	end

	@ExecSpace("ClientOnly")
	method void SetGuidePage(string pageId, Entity openButton)
		-- 특정 가이드 페이지를 설정하고 열기 버튼을 연결하는 함수
		if _UtilLogic:IsNilorEmptyString(pageId) then 
			return 
		end
		if openButton == nil then 
			return 
		end
			
		if self.MadeGuidePageEntites[pageId] == nil then
			self.MadeGuidePageEntites[pageId] = _SpawnService:SpawnByModelId(self.PageModelId , pageId , Vector3.zero , self.GuideUIGroup)
		end
		
		local setButton = function()
		
			if isvalid(self.MadeGuidePageEntites[pageId].GuidePageController) then
				self.MadeGuidePageEntites[pageId].GuidePageController:SetButton(openButton)
				
			else	
			end
			
		end
		
		_TimerService:SetTimerOnce(setButton,0.02)
		
		local path = self.MadeGuidePageEntites[pageId].Path 
		local titleEntity = _EntityService:GetEntityByPath(path.."/GuideTitle")
		if isvalid(titleEntity) then
			titleEntity.TextComponent.Text = _LocalizationService:GetText(self.GuidlePageData[pageId].GuidePageTitleKey)
		end
		
		
		if self.GuideUIGroup.Enable == false then
			self:GuideUIGroupEnable(true)
		end
	end

	@ExecSpace("ClientOnly")
	method any SetGuidePageButton(string pageId, Entity buttonEntity)
		-- 가이드 페이지 버튼에 클릭 이벤트를 연결하는 함수
		if _UtilLogic:IsNilorEmptyString(pageId) then 
			return 
		end
		if buttonEntity == nil then 
			return 
		end
		
		local hdr = buttonEntity:ConnectEvent(ButtonClickEvent, function()
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			self:OpenGuidePage(pageId)
		end)
		
		return hdr
	end

	@ExecSpace("ClientOnly")
	method void OpenGuidePage(string pageId)
		-- 지정된 페이지 ID의 가이드 페이지를 열고 컨텐츠를 로드하는 함수
		if _UtilLogic:IsNilorEmptyString(pageId) then 
			return 
		end
		
		if self.GuideUIGroup.Enable == false then
			self:GuideUIGroupEnable(true)
		end
		
		if self.MadeGuidePageEntites[pageId] == nil then
			self.MadeGuidePageEntites[pageId] = _SpawnService:SpawnByModelId(self.PageModelId , pageId , Vector3.zero , self.GuideUIGroup)
		end
		
		if isvalid(self.MadeGuidePageEntites[pageId].GuidePageController) then
			local contentCount = self.GuidlePageData[pageId].GuideContentCount
			
			if self.MadeGuidePageEntites[pageId].GuidePageController.IsDataLoadCompleted == false then
				self.MadeGuidePageEntites[pageId].GuidePageController:ContentDataSet(pageId,contentCount)
			end
		else	
		end
		
		local path = self.MadeGuidePageEntites[pageId].Path 
		local titleEntity = _EntityService:GetEntityByPath(path.."/GuideTitle")
		if isvalid(titleEntity) then
			titleEntity.TextComponent.Text = _LocalizationService:GetText(self.GuidlePageData[pageId].GuidePageTitleKey)
		end
		
		self.MadeGuidePageEntites[pageId].GuidePageController:Open()
	end

end