@Component
script GuidePageController extends Component

	property Entity CloseButton = nil

	property Entity OpenButton = nil

	property table GuideContentDataByPage = {}

	property integer ContentEntityCount = 0

	property Entity ContentLayout = nil

	property boolean IsDataLoadCompleted = false

	property Entity Arrow = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 가이드 페이지 컨트롤러 초기화 및 닫기 버튼 이벤트 연결하는 함수
		local path = self.Entity.Path
		self.CloseButton = _EntityService:GetEntityByPath(path.."/GuideCloseButton")
		self.CloseButton:ConnectEvent(ButtonClickEvent , function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			self:Close()
		end)
		
		self.ContentLayout = _EntityService:GetEntityByPath(path.."/ContentLayout")
		self.Arrow = _EntityService:GetEntityByPath(path.."/Arrow")
		
		self.IsDataLoadCompleted = false
	end

	@ExecSpace("ClientOnly")
	method void ContentDataSet(string pageId, integer contentCount)
		-- 페이지 ID에 해당하는 가이드 컨텐츠 데이터를 로드하고 UI 엔티티를 생성하는 함수
		local contentDataSet = _DataService:GetTable("GuideContentListDataSet")
		local firstRow = contentDataSet:FindRow("ParentPageId",pageId)
		local startIndex = firstRow:GetItem("RowIndex")	
		
		self.ContentEntityCount = contentCount
		
		table.clear(self.GuideContentDataByPage)
		
		for i = startIndex , (startIndex+contentCount-1) do
			
			local contentData = GuideContentListData() 
			contentData:Load(contentDataSet,i)
		
			if self.GuideContentDataByPage[contentData.Id] ~= nil then
				break
			end
			
			self.GuideContentDataByPage[contentData.OrderIndex] = contentData
			
			if  i-startIndex+1 ~= contentData.OrderIndex then
			end 
			
		end
		
		for i = 1 , #self.GuideContentDataByPage do
			
			if self.GuideContentDataByPage[i].ContentType == _GuidePageManager.ContentTypeTitle then
				local titleEntity = _SpawnService:SpawnByModelId(_GuidePageManager.ContentTitleModelId , tostring(i).."Title" , Vector3.zero , self.ContentLayout)
				titleEntity.TextComponent.Text = _LocalizationService:GetText(self.GuideContentDataByPage[i].GuideContentTextKey)
			
			elseif self.GuideContentDataByPage[i].ContentType == _GuidePageManager.ContentTypeDesc then
				local descEntity = _SpawnService:SpawnByModelId(_GuidePageManager.ContentDescModelId , tostring(i).."Desc" , Vector3.zero , self.ContentLayout)
				descEntity.TextComponent.Text =  _LocalizationService:GetText(self.GuideContentDataByPage[i].GuideContentTextKey)
			else	
			end
		end
		
		self.IsDataLoadCompleted = true
		
		self.Entity:SetEnable(true)
	end

	@ExecSpace("ClientOnly")
	method void SetButton(Entity buttonEntity)
		-- 가이드 페이지를 열기 위한 버튼 엔티티를 설정하고 클릭 이벤트를 연결하는 함수
		self.OpenButton = buttonEntity
		self.OpenButton:ConnectEvent(ButtonClickEvent , self.Open)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 가이드 페이지를 열고 사운드 재생 및 UI 상태를 변경하는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self.Entity:SetEnable(true)
		_UIGroupManager:EnableBackToLobbyBtn(false)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 가이드 페이지를 닫고 사운드 재생 및 UI 상태를 복원하는 함수
		
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self.Entity:SetEnable(false)
		_GuidePageManager:GuideUIGroupEnable(false)
		_UIGroupManager:EnableBackToLobbyBtn(nil)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 스크롤 위치에 따라 화살표 표시 여부를 결정하는 업데이트 함수
		if isvalid(self.ContentLayout) == false then
			return
		end
		
		local scrollPos = self.ContentLayout.ScrollLayoutGroupComponent:GetScrollNormalizedPosition()
		
		if scrollPos.y >= 1 then
			self.Arrow:SetEnable(false)
		else
			local childCount = #self.ContentLayout.Children
			if childCount <= 0 then
				self.Arrow:SetEnable(false)
				return
			end
			
			local lastChild = self.ContentLayout.Children[childCount]
			if (math.abs(lastChild.UITransformComponent.anchoredPosition.y) + lastChild.UITransformComponent.RectSize.y) < self.ContentLayout.UITransformComponent.RectSize.y then
				self.Arrow:SetEnable(false)
			else
				self.Arrow:SetEnable(true)
			end
		end
	end

	@EventSender("Entity", "05cf9676-9238-4d3d-afb3-cbc0add07367")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하여 가이드 페이지를 닫는 핸들러 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		self:Close()
	end

end