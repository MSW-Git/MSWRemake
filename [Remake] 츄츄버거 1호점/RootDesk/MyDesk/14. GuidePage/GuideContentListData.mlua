@Struct
script GuideContentListData

	property string Id = ""

	property string ParentPageId = ""

	property string ContentType = ""

	property integer OrderIndex = 0

	property string GuideContentTextKey = ""

	property integer RowIndex = 0

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 가이드 컨텐츠 정보를 로드하여 속성에 저장하는 함수
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		self.Id = rowData:GetItem("Id")
		self.RowIndex = tonumber(rowData:GetItem("RowIndex"))
		self.ParentPageId = rowData:GetItem("ParentPageId")
		self.ContentType = rowData:GetItem("ContentType")
		self.OrderIndex = tonumber(rowData:GetItem("OrderIndex"))
		self.GuideContentTextKey = rowData:GetItem("GuideContentTextKey")
	end

end