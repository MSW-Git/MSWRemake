@Struct
script KitchenAppData

	property string Id = ""

	property string Group = ""

	property integer Level = 0

	property string EffectType = ""

	property integer EffectValue = 0

	method void Load(string id)
		-- 주방기기 데이터를 ID로 조회하여 속성값들을 로드하는 함수
		local rowData = _DataService:GetTable("KitchenAppDataSet"):FindRow("Id",id)
		
		self.Id = id 
		self.Group = rowData:GetItem("Group")
		self.Level = tonumber(rowData:GetItem("Level"))
		self.EffectType = rowData:GetItem("EffectType")
		self.EffectValue = tonumber(rowData:GetItem("EffectValue"))
	end

end