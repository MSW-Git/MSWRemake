@Component
script KitchenAppManager extends Component

	property table AppUser = {}

	property string PlayerClickKitchenApp = ""

	property string PlayerClickKitchenAppBef = ""

	property string PlayerClickChuChu = ""

	@ExecSpace("Client")
	method void Init()
		-- 주방기기 매니저의 초기화를 수행하는 함수
		self:InitUseApp()
		
		self.PlayerClickKitchenApp = ""
		self.PlayerClickKitchenAppBef = ""
		self.PlayerClickChuChu = ""
	end

	@ExecSpace("ServerOnly")
	method void OnMapEnter(Entity enteredMap)
		-- 플레이어가 로비 맵에 입장할 때 초기화하는 함수
		if _UtilLogic:Contains(enteredMap.Name, "Lobby") then 
			self:Init(self.Entity.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void OnMapLeave(Entity leftMap)
		-- 플레이어가 로비 맵에서 나갈 때 초기화하는 함수
		if _UtilLogic:Contains(leftMap.Name, "Lobby") then 
			self:Init(self.Entity.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ClientOnly")
	method void InitUseApp()
		-- 주방기기 사용자 정보를 초기화하는 함수
		local appType = {_KitchenAppEnumType.Grill,_KitchenAppEnumType.Display,_KitchenAppEnumType.Counter}
		
		table.clear(self.AppUser)
		
		for i=1,3 do 
			
			if not isvalid(self.AppUser[appType[i]]) then 
				self.AppUser[appType[i]] ={}
			end
			
			for j=1,15 do 
				self.AppUser[appType[i]][j] = ""
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	method void ReleaseApp(string kAppType, integer kAppIdx)
		-- 특정 주방기기의 사용자 할당을 해제하는 함수
		self.AppUser[kAppType][kAppIdx] = "" 
	end

	@ExecSpace("ClientOnly")
	method void AssignApp(string appType, integer appIdx, string assignerName)
		-- 특정 주방기기에 사용자를 할당하는 함수
		self.AppUser[appType][appIdx] = assignerName
	end

	@ExecSpace("ClientOnly")
	method integer ReturnAvailableApp(string kAppType, Entity player)
		-- 사용 가능한 주방기기의 인덱스를 순차적으로 반환하는 함수
		
		local kitchenAppNum 
		if kAppType == _KitchenAppEnumType.Display then 
			kitchenAppNum = _KitchenAppService:ReturnDisplayNum(player)
		elseif kAppType == _KitchenAppEnumType.Grill then
			kitchenAppNum = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.GrillCount)
		elseif kAppType == _KitchenAppEnumType.Counter then
			kitchenAppNum = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.CounterCount)
		end
		
		local kitIdx = 0
		
		for i=1,kitchenAppNum do  
			
			if _UtilLogic:IsNilorEmptyString(self.AppUser[kAppType][i]) then 
				kitIdx = i 
				break
			end
		
		end
		return kitIdx
	end

	@ExecSpace("ClientOnly")
	method integer ReturnRandomAvailableApp(string kAppType, Entity player)
		-- 사용 가능한 주방기기 중 랜덤한 인덱스를 반환하는 함수
		
		local kitchenAppNum 
		if kAppType == _KitchenAppEnumType.Display then 
			kitchenAppNum = _KitchenAppService:ReturnDisplayNum(player)
		elseif kAppType == _KitchenAppEnumType.Grill then
			kitchenAppNum = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.GrillCount)
		elseif kAppType == _KitchenAppEnumType.Counter then
			kitchenAppNum = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.CounterCount)
		end
		
		local appIds = {}
		for i=1,kitchenAppNum do  
			
			if _UtilLogic:IsNilorEmptyString(self.AppUser[kAppType][i]) then 
				table.insert(appIds,i)
			end
		
		end
		
		if #appIds < 1 then 
			return 0
		else	
			return appIds[_UtilLogic:RandomIntegerRange(1,#appIds)]
		end
	end

end