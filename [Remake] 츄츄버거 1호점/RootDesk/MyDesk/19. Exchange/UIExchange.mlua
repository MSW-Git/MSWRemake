@Component
script UIExchange extends Component

	property Entity SelectMenu = "50b1f87f-9270-427b-bda7-0fa5bb2b3bbb"

	property table MenuCard = {}

	property table MenuCard_QuestionMark = {}

	property table MenuCard_Img = {}

	property table MenuCardType = {}

	property integer SelectCount = 0

	property Entity SelectedMenu = "00a47fd5-d081-4197-8a32-5e24f0994519"

	property table Tray = {}

	property table Result = {}

	property Entity ResultPanel = "a4564b27-a08c-4189-bc48-5633bbccd6ac"

	property number IngredientCost = 0

	property number RewardCost = 0

	property table EffectTimer = {}

	property Entity SkipBtn = "7710a155-9c8c-4e04-8019-0256ca5b489a"

	property integer RewardType = 0

	property Entity Muto = "2a34d0c8-c1ef-437d-b78c-b65b19870a3a"

	property table ResultChuChuTypeIdx = {}

	property table SelectedCardIdx = {}

	property integer IngredientCount = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 교환 UI 초기화 시 메뉴 카드 타입 배열을 설정하는 함수
		self.MenuCardType = {1, 1, 1, 1, 1, 1, 1, 2, 2, 3, 4, 4}
	end

	@ExecSpace("ClientOnly")
	method void OpenExchangeUI(number IngredientCost, number RewardCost, integer rewardType, integer IngredientCount)
		-- 교환 UI를 열고 초기 설정을 수행하는 함수
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.ExchangeEnter)
		_BGMService:ApplyBGM(_BGMService.ExchangeBgm)
		
		local player = _UserService.LocalPlayer
		player.ExchangeManager:ExchangePlayFlow()
		
		self.IngredientCost = IngredientCost
		self.RewardCost = RewardCost
		self.RewardType = rewardType
		self.IngredientCount = IngredientCount
		
		_UIGroupManager:EnableExchangeGroup(true)
		self.SelectMenu:SetVisible(true)
		self.ResultPanel:SetVisible(false)
		self.SelectMenu.UITransformComponent.Position = Vector3.zero
		self.SelectedMenu.UITransformComponent.Position = Vector3(0, 200, 0)
		self.ResultPanel:GetChildByName("Result").UITransformComponent.Position = Vector3(-400, 800, 0)
		self.Muto.UITransformComponent.Position =  Vector3(500, -700, 0)
		self.SkipBtn:SetEnable(false)
		
		local icon = self.ResultPanel:GetChildByName("Result"):GetChildByName("Icon")
		if self.RewardType == 1 then
			icon.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.Heart
		else
			icon.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.AcaneSimbol
		end
		self.Muto.SpriteGUIRendererComponent.ImageRUID = _MenuCardLogic:GetMutoImgRUID(1)
		
		if #self.MenuCard == 0 then
			self.MenuCard = {}
			for i=1, 12 do
				local name = "Menu"..i
				table.insert(self.MenuCard, self.SelectMenu:GetChildByName(name))
				table.insert(self.MenuCard_QuestionMark, self.MenuCard[i]:GetChildByName("QuestionMark"))
				table.insert(self.MenuCard_Img, self.MenuCard[i]:GetChildByName("Img"))
			end
		end
		
		if #self.Tray == 0 then
			self.Tray = {}
			for i=1, 5 do
				local name = "Tray"..i
				table.insert(self.Tray, self.SelectedMenu:GetChildByName(name):GetChildByName("Food"))
			end
		end
		
		for i=1, 5 do
			local name = "Tray"..i
			local effect = self.SelectedMenu:GetChildByName(name):GetChildByName("Effect"..i)
			effect.TextComponent.Text = ""
		end
		
		self.Result = {}
		self.ResultChuChuTypeIdx = {}
		self.SelectedCardIdx = {}
		
		self:InitMenuCard()
		self:InitTray()
		_UIGroupManager:EnableBackToLobbyBtn(nil)
		
		_FadeService:HideFade()
	end

	@ExecSpace("ClientOnly")
	method void CloseExchangeUI()
		-- 교환 UI를 닫는 함수
		_UIGroupManager:EnableExchangeGroup(false)
	end

	@ExecSpace("ClientOnly")
	method void InitMenuCard()
		-- 메뉴 카드를 초기화하고 설정하는 함수
		self:ShuffleMenuCard()
		self.SelectMenu.UITransformComponent.Position = Vector3.zero
		self.SelectCount = 0
		
		for i=1, #self.MenuCard do
			---@type Entity
			local menucard = self.MenuCard[i]
			---@type Entity
			local questionMark = self.MenuCard_QuestionMark[i]
			---@type Entity
			local img = self.MenuCard_Img[i]
			---@type Entity
			local effect = menucard:GetChildByName("effect")
			local ruid = _MenuCardLogic:GetEffectWord(self.MenuCardType[i])
			effect.SpriteGUIRendererComponent.ImageRUID = ruid
			
			questionMark.SpriteGUIRendererComponent.Color.a = 1
			img.SpriteGUIRendererComponent.Color.a = 0
			if self.MenuCardType[i] == 4 then
				img.UITransformComponent.RectSize = Vector2(80, 80)
				self.ResultChuChuTypeIdx[i] = _MenuCardLogic:RandomChuChuRUID()
				img.UIImageAlign:UpdateCanvas(_MenuCardLogic:GetMenuImgRUID(self.MenuCardType[i], self.ResultChuChuTypeIdx[i]))
			else
				self.ResultChuChuTypeIdx[i] = 0
				img.UITransformComponent.RectSize = Vector2(100, 100)
				img.SpriteGUIRendererComponent.LocalScale = Vector2(1, 1)
				img.SpriteGUIRendererComponent.ImageRUID = _MenuCardLogic:GetMenuImgRUID(self.MenuCardType[i], self.ResultChuChuTypeIdx[i])
			end
			menucard.SpriteGUIRendererComponent.ImageRUID = "062d6c5a736845818c0795d7c5fdec4a"
		end
	end

	@ExecSpace("ClientOnly")
	method void ShuffleMenuCard()
		-- 메뉴 카드 타입을 랜덤하게 섮는 함수
		for i= #self.MenuCardType, 2, -1 do
			local j = _UtilLogic:RandomIntegerRange(1, i)
			self.MenuCardType[i], self.MenuCardType[j] = self.MenuCardType[j], self.MenuCardType[i]
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickMenuCard(integer num)
		-- 메뉴 카드 클릭 시 처리하는 함수
		---@type Entity
		local menuCard = self.MenuCard[num]
		---@type Entity
		local menuCard_img = self.MenuCard_Img[num]
		---@type Entity
		local menuCard_QuestionMark = self.MenuCard_QuestionMark[num] 
		
		if menuCard_img.SpriteGUIRendererComponent.Color.a == 1 then
			return
		end
		
		menuCard.SpriteGUIRendererComponent.ImageRUID = _MenuCardLogic:GetBGRUID(self.MenuCardType[num])
		menuCard_img.SpriteGUIRendererComponent.Color.a = 1
		
		self.SelectCount += 1
		table.insert(self.Result, self.MenuCardType[num]) 
		table.insert(self.SelectedCardIdx, num)
		
		---@type Entity
		local effect = self.SelectedMenu:GetChildByName("Tray"..self.SelectCount):GetChildByName("Effect"..self.SelectCount)
		
		self:ShowTray(self.MenuCardType[num], num)
		self:ShowWordEffect(self.MenuCardType[num], self.MenuCard[num])
		
		if self.SelectCount == 5 then
			_TimerService:SetTimerOnce(function() self.SelectMenu:SetVisible(false) self:ShowResult() end, 3)
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowTray(integer type, integer num)
		-- 선택된 메뉴를 트레이에 표시하는 함수
		---@type Entity
		local tray = self.Tray[self.SelectCount]
		if isvalid(tray.UIImageAlign) then
			tray.UIImageAlign:UpdateCanvas(_MenuCardLogic:GetMenuImgRUID(type, self.ResultChuChuTypeIdx[num]))
		end
		tray.UITransformComponent.Position = _MenuCardLogic:GetImgOffset(type):ToVector3()
		if type == 4 then
			tray.SpriteGUIRendererComponent.PreserveSprite = PreserveSpriteType.NativeSize
			tray.SpriteGUIRendererComponent.LocalScale = Vector2(1.8,1.8)
			tray.SpriteGUIRendererComponent.LocalPosition = Vector2(0,-25)
		end
		tray.SpriteGUIRendererComponent.Color.a = 1
	end

	@ExecSpace("ClientOnly")
	method void InitTray()
		-- 트레이를 초기화하는 함수
		for i=1, #self.Tray do
			---@type Entity
			local tray = self.Tray[i]
			tray.SpriteGUIRendererComponent.ImageRUID = ""
			tray.SpriteGUIRendererComponent.Color.a = 0
			tray.SpriteGUIRendererComponent.PreserveSprite = PreserveSpriteType.None
			tray.SpriteGUIRendererComponent.LocalScale = Vector2(1,1)
			tray.SpriteGUIRendererComponent.LocalPosition = Vector2(0,0)
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowWordEffect(integer type, Entity menucard)
		-- 카드 선택 시 단어 효과를 보여주는 함수
		local pos = Vector3(0, 50, 0)
		
		local effect = menucard:GetChildByName("effect")
		
		effect.UITransformComponent.Position = pos
		effect.SpriteGUIRendererComponent.Color.a = 0
		
		local effectTween = function(tweenValue)
			effect.SpriteGUIRendererComponent.Color.a = tweenValue
			effect.UITransformComponent.Position.y += tweenValue
		end
		
		local tween = _TweenLogic:MakeTween(0, 1, 0.5, EaseType.Linear, effectTween)
		tween.LoopType = TweenLoopType.Restart
		tween.AutoDestroy = true
		tween:Play()
		
		local tween2 = _TweenLogic:MakeTween(1, 0, 0.5, EaseType.Linear, effectTween)
		tween2.AutoDestroy = true
		_TimerService:SetTimerOnce(function() tween2:Play() end, 1)
		
		_MenuCardLogic:PlayEffectSound(type)
		
	end

	@ExecSpace("ClientOnly")
	method void ShowResult()
		-- 교환 결과를 보여주는 함수
		local cost = self.ResultPanel:GetChildByName("Result"):GetChildByName("RewardCost")
		
		_TimerService:SetTimerOnce(function() self.SkipBtn:SetEnable(true) end, 1.2)
		
		if self.RewardType == 1 then
			cost.TextComponent.FontColor = _ColorCodeEnum:GetColor("#ff94b2")
			cost.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#690014")
		elseif self.RewardType == 2 then
			cost.TextComponent.FontColor = _ColorCodeEnum:GetColor("#d6ff1f")
			cost.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#3e501b")
		end
		
		local enableFunc = function(value)
			self.ResultPanel:SetVisible(true)
			self.ResultPanel:GetChildByName("Result"):SetVisible(true)
			cost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(value))
			self:ShowRewardEffect()
		end
		
		local selectedMenuTween = function(tweenValue)
			self.SelectedMenu.UITransformComponent.Position.y = tweenValue
		end
		local resultPanelTween = function(tweenValue)
			self.ResultPanel:GetChildByName("Result").UITransformComponent.Position.y = tweenValue
		end
		local mutoTween = function(tweenValue)
			self.Muto.UITransformComponent.Position.y = tweenValue
		end
		
		local tween = _TweenLogic:MakeTween(200, -300, 0.5, EaseType.SineEaseIn, selectedMenuTween)
		tween.AutoDestroy = true
		tween:Play()
		
		local tween2 = _TweenLogic:MakeTween(800, 200, 0.5, EaseType.CircEaseOut, resultPanelTween)
		tween2.AutoDestroy = true
		
		local tween3 = _TweenLogic:MakeTween(-700, 70, 0.5, EaseType.CircEaseOut, mutoTween)
		tween3.AutoDestroy = true
		
		_TimerService:SetTimerOnce(function() tween2:Play() tween3:Play() enableFunc(self.RewardCost) end, 1)
	end

	@ExecSpace("ClientOnly")
	method void ShowRewardEffect()
		-- 보상 효과를 보여주고 계산을 수행하는 함수
		local cost = self.ResultPanel:GetChildByName("Result"):GetChildByName("RewardCost")
		local rewardCost = self.RewardCost
		
		for i=1, 5 do
			local name = "Tray"..i
			local effect = self.SelectedMenu:GetChildByName(name):GetChildByName("Effect"..i)
			
			local effectTween = function(value)
				effect.UITransformComponent.Position.y += value
			end
			
			effect.UITransformComponent.Position.y = 50
			
			local chuchuMove = function(value) 
				self.Tray[i].UITransformComponent.Position.y = value
			end
			
			local timer = _TimerService:SetTimerOnce(function() 
				
				if self.Result[i] ~= 4 then
					local color = "#ffffff"
		
					if self.Result[i] == 2 then
						color = "#ffe65e"
					elseif self.Result[i] == 3 then
						color = "#ffc0fb"
					end
			
					if self.Result[i] == 1 then
						effect.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#534833")
					elseif self.Result[i] == 2 then
						effect.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#5e3c00")
					elseif self.Result[i] == 3 then
						effect.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#5e107e")
					end
		
					effect.TextComponent.OutlineColor.a = 1
						
					local bonusRate = 0
					local bonusRateName = "ExchangeCard" .. self.Result[i] .. "BonusRate"
					bonusRate = tonumber(_DataService:GetTable("GameConfigData"):FindRow("ConfigType", bonusRateName):GetItem("ConfigValue"))	
					
					local rateText = _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(bonusRate*100))
					effect.TextComponent.Text = "<color="..color..">+ " .. rateText .. "%</color>"
					
					local tween1 = _TweenLogic:MakeTween(0, 2, 0.6, EaseType.Linear, effectTween)
					tween1.AutoDestroy = true
					tween1:Play()
					
					_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_TrainingSpinSuccess"], 1)
				else
					self.Tray[i].SpriteGUIRendererComponent.ImageRUID = _MenuCardLogic:GetMenuImgRUID(5, self.ResultChuChuTypeIdx[self.SelectedCardIdx[i]])
					self.Tray[i].SpriteGUIRendererComponent.PreserveSprite = PreserveSpriteType.NativeSize
					self.Tray[i].SpriteGUIRendererComponent.LocalScale = Vector2(1.8,1.8)
					self.Tray[i].UITransformComponent.Position = Vector3(0,-50,0) 
					local chuchuMoveTween = _TweenLogic:MakeTween(self.Tray[i].UITransformComponent.Position.y, -400, 3, EaseType.Linear, chuchuMove)
					chuchuMoveTween.AutoDestroy = true
					chuchuMoveTween:Play()
					
					_SoundService:PlaySound(_ResourceManager.SFXTable["System_Item_Small_01"], 1)
				end
				self.Muto.SpriteGUIRendererComponent.ImageRUID = _MenuCardLogic:GetMutoImgRUID(self.Result[i])
			end, 0.7*i)
			
			table.insert(self.EffectTimer, timer)
		end
		
		local RewardCostTween = function(value)
			local rounded = string.format("%.0f", value)
			cost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(tonumber(rounded))
		end
		
		local rewardCostTimer = _TimerService:SetTimerOnce(function()
			local rewardTween = _TweenLogic:MakeTween(rewardCost, self:CalculateReward(), 3.5, EaseType.Linear, RewardCostTween)
			rewardTween.AutoDestroy = true
			rewardTween:Play()
			_SoundService:PlayLoopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"], 1)
			local costSoundTimer = _TimerService:SetTimerOnce(function() _SoundService:StopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"]) end, 3.5)
			table.insert(self.EffectTimer, costSoundTimer)
		end, 0.7)
		table.insert(self.EffectTimer, rewardCostTimer)
		
		local rewardTimer = _TimerService:SetTimerOnce(function() self:RequestReward() end, 5)
		table.insert(self.EffectTimer, rewardTimer)
	end

	@ExecSpace("ClientOnly")
	method number CalculateReward()
		-- 카드 결과에 따라 최종 보상을 계산하는 클라이언트 함수
		local reward = self.RewardCost
		local rewardRate = 1
		
		
		for i=1, #self.Result do
			if self.Result[i] == 4 then
				continue
			end
			local name = "ExchangeCard" .. self.Result[i] .. "BonusRate"
			local bonusRate = tonumber(_DataService:GetTable("GameConfigData"):FindRow("ConfigType", name):GetItem("ConfigValue"))
			rewardRate += bonusRate
		end
		
		return tonumber(string.format("%.0f", reward * rewardRate))
	end

	@ExecSpace("ClientOnly")
	method void OnClickSkipBtn()
		-- 스킵 버튼 클릭 시 효과를 건너뛰고 결과를 즈시 보여주는 함수
		self.SkipBtn:SetEnable(false)
		
		for i=1, #self.EffectTimer do
			_TimerService:ClearTimer(self.EffectTimer[i])
		end
		
		_SoundService:StopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"])
		
		local removeEffect = function()
			for i=1, 5 do
				local name = "Tray"..i
				local effect = self.SelectedMenu:GetChildByName(name):GetChildByName("Effect" .. i)
				effect.TextComponent.Text = ""
				effect.TextComponent.FontColor.a = 0
				effect.TextComponent.OutlineColor.a = 0
		
				local cost = self.ResultPanel:GetChildByName("Result"):GetChildByName("RewardCost")
				cost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(self:CalculateReward())
			end
			self.Muto.SpriteGUIRendererComponent.ImageRUID = _MenuCardLogic:GetMutoImgRUID(1)
		end
		
		_TimerService:SetTimerOnce(removeEffect, 0.5)
		_TimerService:SetTimerOnce(function() self:RequestReward() end, 1.5)
	end

	@ExecSpace("ClientOnly")
	method void RequestReward()
		-- 서버에 보상 지급을 요청하는 함수
		local player = _UserService.LocalPlayer
		player.ExchangeManager:GiveReward(self.RewardCost, self.Result, self.IngredientCost, self.RewardType, self.IngredientCount)
	end

	@EventSender("Model", "5c20b5ac-0745-4eae-a648-236be0a2cd24")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self.SelectCount == 5 then
			return
		end
		
		local name = event.Entity.Name
		local num, i = name:gsub("Menu", "")
		self:OnClickMenuCard(tonumber(num))
	end

	@EventSender("Entity", "7710a155-9c8c-4e04-8019-0256ca5b489a")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 두 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:OnClickSkipBtn()
	end

end