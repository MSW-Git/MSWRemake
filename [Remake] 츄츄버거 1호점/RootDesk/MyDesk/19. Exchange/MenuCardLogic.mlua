@Logic
script MenuCardLogic extends Logic

	property integer RandomIndex = 0

	@ExecSpace("ClientOnly")
	method string GetMenuImgRUID(integer menutype, integer idx)
		-- 메뉴 타입에 따라 적절한 이미지 RUID를 반환하는 함수
		
		local ruid = ""
		local stage = _UserService.LocalPlayer.PlayerStage.NowStage
		if stage == 1 then
			stage = 2
		end
		
		if menutype == 1 then
			ruid = "ddbe86ff8db64fb398607b125e7c97b6"
		elseif menutype == 2 then
			ruid = "be5ea06989b546918237cc6fd82bdbe0"
		elseif menutype == 3 then
			ruid = "878b86a716584fc7b54974f377d316e3"
		elseif menutype == 4 then
			local EmployeeId = _ExchangeDataSetLogic:GetExchangeChuChuData(stage, idx).Id
			---@type EmployeeData
			local data = _EmployeeService:GetData(EmployeeId)
			ruid = data.PortraitUIRUID
		elseif menutype == 5 then
			local EmployeeId = _ExchangeDataSetLogic:GetExchangeChuChuData(stage, idx).Id
			local data = _EmployeeService:GetData(EmployeeId)
			ruid = data.MoveRUID
		end
		
		return ruid
	end

	@ExecSpace("ClientOnly")
	method string GetEffectWord(integer type)
		-- 카드 타입에 따라 효과 텍스트 이미지 RUID를 반환하는 함수
		local ruid = ""
		
		if type == 1 then
			ruid = "cd60f19feb5843f4ae685e1aeef81dc4" 
		elseif type == 2 then
			ruid = "7b8234f35a7d4a42aa1b6d3653439af9"
		elseif type == 3 then
			ruid = "e5b771782c3d4efd9ee4bb00a5c30d03"
		elseif type == 4 then
			ruid = "4d00fc736da54dbaa3c282d23b3d795f"
		end
		
		return ruid
	end

	@ExecSpace("ClientOnly")
	method Vector2 GetImgOffset(integer menutype)
		-- 메뉴 타입에 따라 이미지 오프셋 위치를 반환하는 함수
		
		
		local offset = Vector2(2, 10)
		
		if menutype == 1 then
			offset = Vector2(2, 20)
		elseif menutype == 2 then
			offset = Vector2(2, 30)
		elseif menutype == 3 then
			offset = Vector2(5, 35)
		elseif menutype == 4 then
			offset = Vector2(2, 10)
		end
		
		return offset
	end

	@ExecSpace("ClientOnly")
	method string GetBGRUID(integer menutype)
		-- 메뉴 타입에 따라 배경 이미지 RUID를 반환하는 함수
		
		local ruid = ""
		
		if menutype == 1 then
			ruid = "e52fcb61cd604b6bafe109509a7da170"
		elseif menutype == 2 then
			ruid = "da562bf30a0241eeb7c8750200401366"
		elseif menutype == 3 then
			ruid = "60aa2ce5a7cd47a0bae8135180a46163"
		elseif menutype == 4 then
			ruid = "3ff95ba9d743433681f6b9d431c1df1d"
		end
		
		return ruid
	end

	@ExecSpace("ClientOnly")
	method void PlayEffectSound(integer type)
		-- 카드 타입에 따라 적절한 효과 사운드를 재생하는 함수
		if type == 4 then
			_SoundService:PlaySound(_ResourceManager.SFXTable["System_Item_Small_01"], 2)
		else 
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_Overlimit"], 1)
		end
	end

	@ExecSpace("ClientOnly")
	method integer RandomChuChuRUID()
		-- 현재 스테이지에 따라 랜덤한 츄츄 인덱스를 반환하는 함수
		local player = _UserService.LocalPlayer
		local currentStage = player.PlayerStage.NowStage
		if currentStage == 1 then
			currentStage = 2
		end
		
		local idx = _RandomLogic:RandomIntegerRange(1, _ExchangeDataSetLogic.ExchangeChuChuCount[currentStage])
		
		return idx
	end

	@ExecSpace("ClientOnly")
	method string GetMutoImgRUID(integer menutype)
		-- 메뉴 타입에 따라 무토 캐릭터 이미지 RUID를 반환하는 함수
		
		local ruid = ""
		if menutype == 1 then
			ruid = _ResourceLoadLogic:OptimizeMobileResource("9772c701cd2e4d3b8a3c4b75a72a5883") 
		elseif menutype == 2 or menutype == 3 then
			ruid = _ResourceLoadLogic:OptimizeMobileResource("f6ee2a9ea8b54bdaa6e73631f934c16d")
		elseif menutype == 4 then
			ruid = _ResourceLoadLogic:OptimizeMobileResource("9d3314d29f934a21a441c1df68052643")
		end
		
		return ruid
	end

end