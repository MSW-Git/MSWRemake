@Struct
script ExchangeIngredient

	property integer ManagementLevel = 0

	property integer Index = 0

	property string ruid = ""

	method void Load(any dataTable, integer index)
		-- 교환 시스템에서 사용할 재료 데이터를 CSV에서 로드하고 인덱스를 계산하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.ManagementLevel = tonumber(row:GetItem("ManageMentLevel"))
		if index % 10 == 0 then
			self.Index = 10
		else
			self.Index = index % 10
		end
		self.ruid = row:GetItem("RUID")
	end

end