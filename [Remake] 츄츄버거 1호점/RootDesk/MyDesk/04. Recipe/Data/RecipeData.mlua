@Struct
script RecipeData

	property string Name = ""

	property table IngreList = {}

	property integer TasteScore = 0

	property number BalancePoint = 0

	property number SpicyPoint = 0

	property integer Cost = 0

	property string Tag = ""

	property boolean IsTrialBuff = false

	property integer TrialBuffProgress = 0

	property integer TrialBuffExpireDate = 0

	property number TrialSkillBonus = 0

	property integer UniqueId = 0

	method table ConvertToTable()
		-- 레시피 데이터를 테이블로 변환하는 함수
		local result = {}
		result["UniqueId"] = self.UniqueId
		result["Name"] = self.Name
		result["IngreList"] = _RecipeIngreDrawEnum:EncodeIngreList(self.IngreList)
		result["TasteScore"] = self.TasteScore
		result["BalancePoint"] = self.BalancePoint
		result["SpicyPoint"] = self.SpicyPoint
		result["Cost"] = self.Cost
		result["Tag"] = self.Tag
		result["IsTrialBuff"] = self.IsTrialBuff
		result["TrialBuffProgress"] = self.TrialBuffProgress
		result["TrialBuffExpireDate"] = self.TrialBuffExpireDate
		result["TrialSkillBonus"] = self.TrialSkillBonus
		
		return result
	end

	method void SetFromTable(table data)
		-- 테이블 데이터로부터 레시피 데이터를 설정하는 함수
		self.UniqueId = data["UniqueId"]
		self.Name = data["Name"]
		self.IngreList = _RecipeIngreDrawEnum:DecodeIngreList(data["IngreList"])
		self.TasteScore = tonumber(data["TasteScore"])
		self.BalancePoint = tonumber(data["BalancePoint"])
		self.SpicyPoint = tonumber(data["SpicyPoint"])
		self.Cost = tonumber(data["Cost"])
		self.Tag = data["Tag"]
		self.IsTrialBuff = data["IsTrialBuff"]
		self.TrialBuffProgress = tonumber(data["TrialBuffProgress"])
		self.TrialBuffExpireDate = tonumber(data["TrialBuffExpireDate"])
		self.TrialSkillBonus = tonumber(data["TrialSkillBonus"])
	end

	method boolean GetIsBunSkinned()
		-- 번에 스킨이 적용되었는지 확인하는 함수
		for i, data in pairs(self.IngreList) do
			---@type RecipeIngreDrawData
			local drawData = data
			
			if drawData.DrawType == _RecipeIngreDrawEnum.Bun then
				return drawData.IsBunSkinned
			end
		end
		
		return false
	end

	method table ConvertToDBTable()
		-- 데이터베이스 테이블로 변환하는 함수
		if self.UniqueId == nil then
			self.UniqueId = 0
		end
		
		if self.Name == nil then
			self.Name = ""
		end
		
		if self.IngreList == nil then
			self.IngreList = {}
		end
		
		if self.TasteScore == nil then
			self.TasteScore = 0
		end
		
		if self.BalancePoint == nil then
			self.BalancePoint = 0
		end
		
		if self.SpicyPoint == nil then
			self.SpicyPoint = 0
		end
		
		if self.Cost == nil then
			self.Cost = 0
		end
		
		if self.Tag == nil then
			self.Tag = ""
		end
		
		if self.IsTrialBuff == nil then
			self.IsTrialBuff = false
		end
		
		if self.TrialBuffProgress == nil then
			self.TrialBuffProgress = 0
		end
		
		if self.TrialBuffExpireDate == nil then
			self.TrialBuffExpireDate = 0
		end
		
		if self.TrialSkillBonus == nil then
			self.TrialSkillBonus = 0
		end
		
		local result = {self.UniqueId, self.Name, _RecipeIngreDrawEnum:EncodeIngreList(self.IngreList), self.TasteScore, self.BalancePoint, 
			self.SpicyPoint, self.Cost, self.Tag, self.IsTrialBuff, self.TrialBuffProgress, self.TrialBuffExpireDate, self.TrialSkillBonus}
		return result
	end

	method void SerFromDBTable_Ver1(table data)
		-- 데이터베이스 테이블 버전 1에서 데이터를 역직렬화하는 함수
		self.UniqueId = data[1]
		self.Name = data[2]
		self.IngreList = _RecipeIngreDrawEnum:DecodeIngreList(data[3])
		self.TasteScore = tonumber(data[4])
		self.BalancePoint = tonumber(data[5])
		self.SpicyPoint = tonumber(data[6])
		self.Cost = tonumber(data[7])
		self.Tag = data[8]
		self.IsTrialBuff = data[9]
		self.TrialBuffProgress = tonumber(data[10])
		self.TrialBuffExpireDate = tonumber(data[11])
		self.TrialSkillBonus = tonumber(data[12])
	end

end