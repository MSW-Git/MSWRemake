@Struct
script TasteGradeData

	property integer Index = 0

	property string Grade = ""

	property number GradeValue = 0

	property number GoldBonus = 0

	property number AttractiveScore = 0

	property number WorkProgress = 0

	property string RUID = ""

	method void Load(any dataTable, integer index)
		-- 맛 등급 데이터를 CSV에서 로드하는 함수
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		self.Index = tonumber(rowData:GetItem("Index"))
		self.Grade = rowData:GetItem("Grade")
		self.GradeValue = tonumber(rowData:GetItem("Value"))
		self.GoldBonus = tonumber(rowData:GetItem("GoldBonus"))
		self.AttractiveScore = tonumber(rowData:GetItem("AttractiveScore"))
		self.WorkProgress = tonumber(rowData:GetItem("WorkProgress")) 
		self.RUID = rowData:GetItem("RUID")
	end

end