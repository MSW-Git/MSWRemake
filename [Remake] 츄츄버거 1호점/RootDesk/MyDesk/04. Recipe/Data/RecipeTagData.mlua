@Struct
script RecipeTagData

	property string Type = ""

	property string SlotRUID = ""

	property string IconRUID = ""

	property string PackRUID = ""

	property string SmallPackRUID = ""

	property Color OutlineColor = Color(0,0,0,0)

	property Color TypeColor = Color(0,0,0,0)

	property integer SortIndex = 0

	property Color SlotColor = Color(0,0,0,0)

	property string NameTagRUID = ""

	property Color NameOutlineColor = Color(0,0,0,0)

	property Color TagOutlineColor = Color(0,0,0,0)

	property string TagNameKey = ""

	method void Load(any dataTable, integer index)
		-- 레시피 태그 데이터를 CSV에서 로드하고 색상 정보를 설정하는 함수
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		self.Type = rowData:GetItem("Type")
		self.SlotRUID = rowData:GetItem("SlotRUID")
		self.IconRUID = rowData:GetItem("IconRUID")
		self.TagNameKey = rowData:GetItem("TagNameKey")
		self.PackRUID = rowData:GetItem("PackRUID")
		self.SmallPackRUID = rowData:GetItem("SmallPackRUID")
		self.OutlineColor = _ColorCodeEnum:GetColor(rowData:GetItem("OutlineColor"))
		self.TypeColor = _ColorCodeEnum:GetColor(rowData:GetItem("TypeColor"))
		self.SortIndex = tonumber(rowData:GetItem("SortIndex"))
		self.SlotColor = _ColorCodeEnum:GetColor(rowData:GetItem("SlotColor"))
		
		self.NameTagRUID = rowData:GetItem("NameTagRUID")
		self.NameOutlineColor = _ColorCodeEnum:GetColor(rowData:GetItem("NameOutlineColor"))
		self.TagOutlineColor = _ColorCodeEnum:GetColor(rowData:GetItem("TagOutlineColor"))
	end

end