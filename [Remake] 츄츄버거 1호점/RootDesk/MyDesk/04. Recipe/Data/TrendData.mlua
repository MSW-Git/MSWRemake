@Struct
script TrendData

	property integer Id = 0

	property string Type = ""

	property string TargetTag = ""

	property string OccurEvent = ""

	property string EndEvent = ""

	method void Load(any dataTable, integer index)
		-- 트렌드 데이터를 CSV에서 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = tonumber(row:GetItem("Id"))
		self.Type = row:GetItem("Type")
		self.TargetTag = row:GetItem("TargetTag")
		self.OccurEvent = row:GetItem("OccurEvent")
		self.EndEvent = row:GetItem("EndEvent")
	end

end