@Struct
script IngredientData

	property integer Index = 0

	property string Name = ""

	property integer Grade = 0

	property string Type = ""

	property integer BalancePoint = 0

	property integer SpicyPoint = 0

	property integer TastePoint = 0

	property integer BaseCost = 0

	property string RecipeRUID = ""

	property string IconRUID = ""

	property number Width = 0

	property number Height = 0

	property number PosY = 0

	property string NameKeyword = ""

	property number UpperPosY = 0

	property number PosX = 0

	property integer RelatedStage = 0

	property string NameKey = ""

	property string NameKeywordKey = ""

	method void Load(any dataTable, integer index)
		-- CSV 데이터로부터 재료 정보를 로드하는 함수
		---@type MODUserDataSet
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		self.Index = tonumber(rowData:GetItem("Index"))
		self.NameKey = rowData:GetItem("NameKey")
		self.NameKeywordKey = rowData:GetItem("NameKeywordKey")
		self.Grade = tonumber(rowData:GetItem("Grade"))
		self.Type = rowData:GetItem("Type")
		
		self.BalancePoint = tonumber(rowData:GetItem("BalancePoint"))
		self.SpicyPoint = tonumber(rowData:GetItem("SpicyPoint"))
		self.TastePoint = tonumber(rowData:GetItem("TastePoint"))
		
		self.BaseCost = tonumber(rowData:GetItem("BaseCost"))
		
		self.RecipeRUID = rowData:GetItem("RecipeRUID")
		self.IconRUID = rowData:GetItem("IconRUID")
		
		self.Width = tonumber(rowData:GetItem("Width"))
		self.Height = tonumber(rowData:GetItem("Height"))
		self.PosY = tonumber(rowData:GetItem("PosY"))
		self.UpperPosY = tonumber(rowData:GetItem("UpperPosY"))
		self.PosX = tonumber(rowData:GetItem("PosX"))
		
		self.RelatedStage = tonumber(rowData:GetItem("RelatedStage"))
	end

	method integer GetTasteScore(integer nowStage, Entity player)
		-- 현재 스테이지와 플레이어 상태에 따른 재료의 맛 점수를 계산하는 함수
		local score = self.TastePoint
		
		if self:IsIngreBuffed(nowStage, player) == true then
			local config = _GetConfigDataLogic:GetConfigNumDataByKey("IngredientTastePointVariationUnit")
			score += config*2
		end
		
		
		if self:IsIngreStageBuffed(player.PlayerStage.NowStage) == true then
			score = math.floor(score * (1 + _StrategyEnum:GetPlayerStrategyEffect(player, _StrategyEnum.SpecialIngredientBonus, player.PlayerStage.NowStage)))
		end
		
		return score
	end

	method integer GetCost(integer nowStage, Entity player)
		-- 현재 스테이지와 플레이어 상태에 따른 재료의 비용을 계산하는 함수
		local cost = self.BaseCost
		if self:IsIngreBuffed(nowStage, player) then
			local config = _GetConfigDataLogic:GetConfigNumDataByKey("IngredientCostVariationUnit")
			cost += config*2
		end
		
		if self:IsIngreStageBuffed(player.PlayerStage.NowStage) == true then
			cost = math.floor(cost * (1 + _StrategyEnum:GetPlayerStrategyEffect(player, _StrategyEnum.SpecialIngredientBonus, player.PlayerStage.NowStage)))
		end
		
		return cost
	end

	method boolean IsIngreBuffed(integer nowStage, Entity player)
		-- 재료가 현재 스테이지나 플레이어 효과로 버프를 받고 있는지 확인하는 함수
		local stageIngres = _StageDataSetLogic:GetStageOnlyIngredient(nowStage)
		for _, ingreId in pairs(stageIngres) do
			if ingreId == self.Index then
				return true
			end
		end
		
		local promotedIngres = player.PlayerIngameManager.StageIngredient
		for _, ingreId in pairs(promotedIngres) do
			if ingreId == self.Index then
				return true
			end
		end
		
		return false
	end

	method boolean IsIngreStageBuffed(integer nowStage)
		-- 재료가 현재 스테이지에서 버프를 받고 있는지 확인하는 함수
		local stageIngres = _StageDataSetLogic:GetStageOnlyIngredient(nowStage)
		for _, ingreId in pairs(stageIngres) do
			if ingreId == self.Index then
				return true
			end
		end
		
		return false
	end

end