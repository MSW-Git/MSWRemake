@Struct
script RecipeIngreDrawData

	property integer Id = 0

	property string DrawType = ""

	property string DrawDetailType = ""

	property boolean IsBunSkinned = false

	property integer BunSkinId = 0

	method table DataToTable()
		-- 레시피 재료 그리기 데이터를 테이블 형태로 변환하는 함수
		return {self.Id, self.DrawType, self.DrawDetailType, self.IsBunSkinned, self.BunSkinId}
	end

	method void TableToData(table table)
		-- 테이블 데이터를 레시피 재료 그리기 데이터로 변환하는 함수
		self.Id = tonumber(table[1])
		self.DrawType = table[2]
		self.DrawDetailType = table[3]
		self.IsBunSkinned = table[4]
		self.BunSkinId = tonumber(table[5])
	end

	method void Init(integer id, string drawType, string drawDetailType, boolean isBunSkinned, integer bunSkinId)
		-- 레시피 재료 그리기 데이터를 초기화하는 함수
		self.Id = id
		self.DrawType = drawType
		self.DrawDetailType = drawDetailType
		self.IsBunSkinned = isBunSkinned
		self.BunSkinId = bunSkinId
	end

end