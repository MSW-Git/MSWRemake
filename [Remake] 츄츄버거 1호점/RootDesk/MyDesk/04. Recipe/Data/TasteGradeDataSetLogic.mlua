@Logic
script TasteGradeDataSetLogic extends Logic

	property table TasteGradeData = {}

	property number FinalBalanceBonus = 0

	property number FinalBalancePenalty = 0

	property number BunTypeBonus = 0

	property number FinalComboBonus = 0

	property integer MaxTasteScoreCap = 0

	method void OnBeginPlay()
		-- 게임 시작 시 데이터셋을 로드하는 함수
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- 맛 등급 데이터셋을 로드하는 함수
		table.clear(self.TasteGradeData)
		local gradeDataSet = _DataService:GetTable("TasteGradeData")
		for i = 1, gradeDataSet:GetRowCount() do
			local gradeData = TasteGradeData()
			gradeData:Load(gradeDataSet, i)
			
			if self.TasteGradeData[gradeData.Index] ~= nil then
				break
			end
		
			self.TasteGradeData[gradeData.Index] = gradeData
		end
	end

	method TasteGradeData ReturnGradeDataByScore(number score)
		-- 점수에 따른 등급 데이터를 반환하는 함수
		local gradeIndex = 0
		for i = 1, #self.TasteGradeData do
			---@type TasteGradeData
			local gradeData = self.TasteGradeData[i]
			if gradeData.GradeValue > score then
				break
			end
			
			gradeIndex = i
			
		end
		
		return self.TasteGradeData[gradeIndex]
	end

	method number ReturnAttractiveScoreByScore(number score)
		-- 점수에 따른 매력도 점수를 반환하는 함수
		local gradeData = self:ReturnGradeDataByScore(score)
		return gradeData.AttractiveScore
	end

	method TasteGradeData GetTasteGradeData(integer gradeIndex)
		-- 등급 인덱스로 맛 등급 데이터를 가져오는 함수
		return self.TasteGradeData[gradeIndex]
	end

	method number GetFinalComboBonus(Entity player)
		-- 플레이어의 최종 콤보 보너스를 계산하는 함수
		local bonus = _StrategyEnum:GetSideMenuEffect(player.PlayerIngameManager.StageSideMenu, _StrategyEnum.SideMenu_MaxComboBonus, nil)
		if bonus == 0 then
			bonus = _GetConfigDataLogic:GetConfigNumDataByKey("RecipeComboBonusRate")
		end
		
		return bonus
	end

	method number GetFinalBalanceBonus(Entity player)
		-- 플레이어의 최종 밸런스 보너스를 계산하는 함수
		local bonus = _StrategyEnum:GetSideMenuEffect(player.PlayerIngameManager.StageSideMenu, _StrategyEnum.SideMenu_BalanceBonus, nil)
		if bonus == 0 then
			bonus = _GetConfigDataLogic:GetConfigNumDataByKey("RecipeBalanceSucessBonus")
		end
		
		return bonus
	end

end