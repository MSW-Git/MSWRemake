@Struct
script RecipeComboData

	property integer Id = 0

	property string EffectTarget = ""

	property number EffectAmount = 0

	property SyncTable<string, integer> CountTable

	property string NameKey = ""

	method void Load(any dataTable, integer index)
		-- 레시피 콤보 데이터를 CSV에서 로드하고 태그별 필요 개수를 설정하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = tonumber(row:GetItem("Id"))
		self.NameKey = row:GetItem("NameKey")
		self.EffectTarget = row:GetItem("EffectTarget")
		self.EffectAmount = tonumber(row:GetItem("EffectAmount"))
		local tags = {_RecipeTagEnum.Meat, _RecipeTagEnum.Chicken, _RecipeTagEnum.Seafood, _RecipeTagEnum.Veggie, _RecipeTagEnum.Spicy}
		for i = 1, #tags do
			local tag = tags[i]
			local item = row:GetItem(tag)
			
			if _UtilLogic:IsNilorEmptyString(item) == false then
				self.CountTable[tag] = tonumber(item)
			end
			
		end
	end

end