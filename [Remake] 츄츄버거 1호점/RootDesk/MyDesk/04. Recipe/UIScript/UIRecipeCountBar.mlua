@Component
script UIRecipeCountBar extends Component

	property Entity RedDot = nil

	property TextComponent CountText = nil

	property Entity UpgradeBtn = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 레시피 카운트 바를 초기화하는 함수
		self.RedDot = self.Entity:GetChildByName("RedDot")
		self.CountText = self.Entity:GetChildByName("CountText").TextComponent
		self.UpgradeBtn = self.Entity:GetChildByName("UpgradeBtn")
		
		self.UpgradeBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UpgradeDataSetLogic.UIUpgradePanel.UIUpgradePanel:Open(_UpgradeTypeEnum.RecipeBoxCount)
		end)
		
		if isvalid(self.CountText.Entity.ButtonComponent) then
			self.CountText.Entity:ConnectEvent(ButtonClickEvent, function()
				if _UIGroupManager:IsEnableOpenPopUp() == false then
					return
				end
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				_UIEntityLogic_RecipeGroup.UIRecipeList.UIRecipeListHolder:Open(nil, "Recipe", nil)
			end)
		end
	end

	@ExecSpace("ClientOnly")
	method boolean Refresh()
		-- 레시피 카운트 바를 새로고침하는 함수
		local playerRecipe = _UserService.LocalPlayer.PlayerRecipe
		local recipeCount = #table.keys(playerRecipe.Recipes)
		local recipeMaxCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer, _UpgradeTypeEnum.RecipeBoxCount)
		
		self.CountText.Text = recipeCount.."/"..recipeMaxCount
		
		if recipeCount >= recipeMaxCount then
			self.CountText.OutlineColor = _ColorCodeEnum:GetColor("#fa5246")
			self.RedDot.Enable = true
			return true
		else
			self.CountText.OutlineColor = _ColorCodeEnum:GetColor("#a87811")
			self.RedDot.Enable = false
			return false
		end
	end

end