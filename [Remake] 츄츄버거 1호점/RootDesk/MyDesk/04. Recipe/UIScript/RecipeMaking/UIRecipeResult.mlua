@Component
script UIRecipeResult extends Component

	property Entity UIRecipeMaking = "927e3468-be6d-48fc-9366-8e578c5f2d1f"

	property Entity EndText = "fbd44f59-dcd7-43d8-a23f-17166a9c8e39"

	property Entity DoNameText = "aa3ef415-d9c1-48fc-b233-e12dc4b8b02d"

	property Entity BurgerNameInput = "bc3a15e9-f3e5-4803-a9f5-294a9779a728"

	property Entity BurgerStats = "34db859e-e30d-424d-9be4-8317b4bdb854"

	property Entity TasteScoreBar = "9233c09b-c44b-469b-b438-f1a499f98b3c"

	property Entity TasteScoreText = "7532f280-53ac-4be3-aec4-d03eb59d910a"

	property Entity TasteScoreGrade = "68795ba4-0314-4ca4-b362-2ebfe318df92"

	property Entity BalanceScoreBar = "82a6997c-c031-41e4-a008-0fa89bada3fa"

	property Entity BalanceZone = "9d9f5670-3294-4f0e-a2a3-52c9cd9552fe"

	property Entity BalancePointer = "fc92a3bb-b92b-44d9-b973-65a860a2a5ac"

	property Entity BalanceText = "31d0a482-509e-406c-84a1-b5f98ea789a5"

	property Entity SpicinessScoreBar = "dc034027-8259-4a49-9290-8297edb0b928"

	property Entity SpicinessBar = "1fd74dcc-0191-4443-a9bd-38e2c61dedab"

	property Entity PriceBar = "78eda5d5-5260-4a81-bb9e-9c0895145ee2"

	property Entity PriceText = "f54499ee-2d2f-4003-baca-8ef488fdcc06"

	property number defaultDuration = 1

	property number FinalTasteScore = 0

	property integer renderIndex = 0

	property number defaultDelay = 0.6

	property boolean isSpicy = false

	property Entity EndButton = "199258c1-32ec-43c4-ac0e-5ca78abd42b6"

	property number FinalPrice = 0

	property Entity TagBar = "925817e3-f22f-4a1e-904a-42f12dc19eb1"

	property integer starIndex = 0

	property Vector2 infoTextOriginPos = Vector2(0,150)

	property Entity InfoText = "b81fd5b0-9ca9-4d84-82de-6eaf0a464585"

	property Entity UIRecipeEmployeeList = "60c38e57-c0c0-4a8e-b4c8-2db885b07bdd"

	property string SelectedEmployeeId = ""

	property Entity SelectedEmployee = "48f97306-0134-4a49-8b99-a7e2af94461c"

	property Entity EmployeeCommentText = "b8fe7b8d-1183-4d53-b03a-3e9c7a18ba69"

	property Entity SkillInfoArea = "eeabd667-0a19-4299-b337-402fa112a9c5"

	property Entity EmployeeChatBalloon = "9b937d48-9ab3-40e9-bda8-d81f98498811"

	property Entity EmployeeChatBalloonIcon = "f22049d9-05f8-477c-bd7e-43c5bbab6361"

	property Entity SkipButton = "d788d716-6245-4a12-8638-0a35b73c4d7c"

	property integer phaseTimer = 0

	property SyncTable<string, boolean> UsedSkillList

	property Entity GradeChangeSuccess = "60263231-9674-4f15-9e6d-c72fe7f629e8"

	property Entity GradeChangeFail = "39908403-69ba-41c7-a0e6-6861de7d32fe"

	property Entity SpicinessGauge = "e760668d-348a-48c1-ba5a-2d91695990c7"

	property UIRecipeBunSkinList UIRecipeBunSkinList = "9745b64c-dda2-4dbd-97fc-474eaf6418e3"

	property integer SelectedBunSkinId = 0

	property string BurgerCompleteEffectRUID = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 버거 완성 효과 리소스를 최적화하여 로드하는 함수
		self.BurgerCompleteEffectRUID = _ResourceLoadLogic:OptimizeMobileResource("87c7259db24d4e22974822e9d0279bdb")
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 레시피 결과 UI의 모든 요소를 초기화하는 함수
		self.EndText.Enable = false
		self.DoNameText.Enable = false
		self.BurgerStats.Enable = false
		self.BurgerNameInput.Enable = false
		self.TasteScoreBar.Enable = false
		self.BalanceScoreBar.Enable = false
		self.SpicinessScoreBar.Enable = false
		self.PriceBar.Enable = false
		self.EndButton.Enable = false
		self.SelectedEmployee.Enable = false
		self.EmployeeCommentText.Enable = false
		self.SkillInfoArea.Enable = false
		self.SkipButton.Enable = false
		self.GradeChangeFail.Enable = false
		self.GradeChangeSuccess.Enable = false
		
		self.BurgerNameInput.TextInputComponent.PlaceHolder = ""
		self.BurgerNameInput.TextComponent.Text = ""
		
		self.TasteScoreText.TextComponent.Text = "0"
		
		local initialGradeData = _TasteGradeDataSetLogic:GetTasteGradeData(1)
		self.TasteScoreGrade.SpriteGUIRendererComponent.ImageRUID = initialGradeData.RUID
		
		local balanceBarLine_L = self.BalanceScoreBar:GetChildByName("BalanceBar"):GetChildByName("Left")
		local balanceBarLine_R = self.BalanceScoreBar:GetChildByName("BalanceBar"):GetChildByName("Right")
		
		local balanceThreshold = _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer)
		self.BalanceZone.UITransformComponent.RectSize.x = self.BalanceZone.Parent.UITransformComponent.RectSize.x * balanceThreshold / 50
		self.BalancePointer.UITransformComponent.anchoredPosition = Vector2(0, self.BalancePointer.UITransformComponent.anchoredPosition.y)
		balanceBarLine_L.UITransformComponent.anchoredPosition = Vector2(-self.BalanceZone.UITransformComponent.RectSize.x/2, balanceBarLine_L.UITransformComponent.anchoredPosition.y)
		balanceBarLine_R.UITransformComponent.anchoredPosition = Vector2(self.BalanceZone.UITransformComponent.RectSize.x/2, balanceBarLine_R.UITransformComponent.anchoredPosition.y)
		
		self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "3a178133919e4171a09ce815f6a58a6a"
		self.BalanceText.Enable = false
		self.starIndex = 0
		
		self.SpicinessGauge.SpriteGUIRendererComponent.FillAmount = 0
		self.SpicinessBar:GetChildByName("SpicyIcon").Enable = false
		self.isSpicy = false
		
		self:SetFinalScore(0)
		self.FinalPrice = 0
		self.SelectedEmployeeId = nil
		table.clear(self.UsedSkillList)
		
		self.InfoText.Enable = false
		self.InfoText.CanvasGroupComponent.GroupAlpha = 0
		
		local tag = self.TagBar:GetChildByName("RecipeTag")
		tag.UIRecipeTag:Clear()
		self.TagBar.Enable = false
		
		self.PriceText.TextComponent.Text = "0"
		
		self.UIRecipeBunSkinList.Detail:Refresh(0)
		
		self:ChangeRenderIndex(1)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 레시피 결과 UI를 여는 함수
		self:Init()
		
		self.Entity.Enable = true
		self.UIRecipeMaking.UIRecipeMaking.ChoiceEntities.Enable = false
		
		local player = _UserService.LocalPlayer
		player.PlayerRecipe:ChangeConnectingStatus(false)
		
	end

	@ExecSpace("ClientOnly")
	method void MakeTweenNumTextRising(Entity entity, number startValue, number endValue, number duration, boolean isThousandSeparated)
		-- 숫자 텍스트가 상승하는 트윈 애니메이션을 만드는 함수
		local onFinal = false
		if isvalid(self._T.riseTween) and entity == self.TasteScoreText then
			self._T.riseTween:Destroy()
		end
		
		if isvalid(self._T.riseTimer) then
			_SoundService:StopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"])
			_TimerService:ClearTimer(self._T.riseTimer)
			self._T.riseTimer = nil
		end
		
		_SoundService:PlayLoopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"], 1)
		
		self._T.riseTween = _TweenLogic:PlayTween(startValue, endValue, duration, EaseType.CubicEaseOut, function(t)
			if t >= endValue - 1 then
				t = endValue
			end
			
			local startGrade = _TasteGradeDataSetLogic:ReturnGradeDataByScore(startValue)
			local endGrade = _TasteGradeDataSetLogic:ReturnGradeDataByScore(endValue)
			local isDrawEffect = startGrade ~= endGrade
			
			local text = tostring(math.floor(t))
			if isThousandSeparated then
				text = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(t))
			end
			entity.TextComponent.Text = text
			if entity == self.TasteScoreText then
				if t >= endValue - 0.5 then
					if onFinal == false then
		
						self.TasteScoreGrade.SpriteGUIRendererComponent.ImageRUID = endGrade.RUID
						if startValue < endValue then
							if isDrawEffect then
								_SoundService:PlaySound(_ResourceManager.SFXTable["Buff"], 1)
								_UIEntityService:PlayUISpriteAnim(self.GradeChangeSuccess, "a7beeedf5d364c0ca34d74879a26e8bf", 0.8)
							end
							
						elseif startValue > endValue then
							if isDrawEffect then
								_SoundService:PlaySound(_ResourceManager.SFXTable["Debuff"], 1)
								_UIEntityService:PlayUISpriteAnim(self.GradeChangeFail, "2da83fd3537c48e9a541035928e115e7", 0.8)
							end					
						end
						
						onFinal = true
						_SoundService:StopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"])
						_TimerService:ClearTimer(self._T.riseTimer)
					end	
				end		
			end
		end)
		
		self._T.riseTimer = _TimerService:SetTimerOnce(function()
			_SoundService:StopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"])
		end, duration*0.8)
	end

	@ExecSpace("ClientOnly")
	method void RequestRefreshTasteScoreBar(number startValue, number endValue, number duration)
		-- 맛 점수 바를 새로고침 요청하는 함수
		local burgerParent = self.UIRecipeMaking.UIRecipeMaking.BurgerParent
		local parent = self.UIRecipeMaking.UIRecipeMaking.BurgerRenderParent
		if startValue > 0 then
			self.starIndex = _UIEntityService:MakeStarIconForTasteScore(self.starIndex, endValue-startValue, burgerParent, parent, _UIEntityLogic_RecipeGroup.BonusMaterial)
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_RecipeIcon"], 1)
		end
		
		self:MakeTweenNumTextRising(self.TasteScoreText, startValue, endValue, duration, false)
	end

	@ExecSpace("ClientOnly")
	method void RequestRefreshBalanceScoreBar(number endValue, number duration)
		-- 밸런스 점수 바를 새로고침 요청하는 함수
		local balanceBarLength = self.BalanceZone.Parent.UITransformComponent.RectSize.x
		
		local balanceThreshold = _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer)
		
		local lastPos = self.BalancePointer.UITransformComponent.anchoredPosition
		local newPosX = balanceBarLength/2 * endValue / 50
		if newPosX >= balanceBarLength/2 then
			newPosX = balanceBarLength/2
		end
		if newPosX <= -balanceBarLength/2 then
			newPosX = -balanceBarLength/2
		end
		
		local tween = _TweenLogic:PlayTween(lastPos, Vector2(newPosX, lastPos.y), duration, EaseType.CubicEaseOut, function(t)
			self.BalancePointer.UITransformComponent.anchoredPosition = t
			if math.abs(self.BalancePointer.UITransformComponent.anchoredPosition.x) >= (math.abs(endValue)-1) then
				if self.BalanceText.Enable == false then
					self.BalanceText.Enable = true
					self:RequestRefreshBalanceBonus(self:SetBalanceResult(endValue, balanceThreshold))
				end
			end
		end)
		
		_TimerService:SetTimerOnce(function()	
			if endValue >= -balanceThreshold and endValue <= balanceThreshold then
				self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "3a178133919e4171a09ce815f6a58a6a"
			else
				self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "e7d7ef61793f426097204ceec35045b1"
			end
		end, duration/2)
	end

	@ExecSpace("ClientOnly")
	method boolean SetBalanceResult(number value, number threshold)
		-- 밸런스 결과를 설정하고 성공 여부를 반환하는 함수
		
		if math.abs(value) <= threshold then
			self.BalanceText.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.RecipeBalanceGood
			_SoundService:PlaySound(_ResourceManager.SFXTable["Buff"], 1)
			return true
		
		else
			self.BalanceText.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.RecipeBalanceBad
			_SoundService:PlaySound(_ResourceManager.SFXTable["Debuff"], 1)
			return false
		end
	end

	@ExecSpace("ClientOnly")
	method void RequestRefreshBalanceBonus(boolean isBalanced)
		-- 밸런스 보너스를 새로고침 요청하는 함수
		local balanceBonus
		if isBalanced then
			balanceBonus = _TasteGradeDataSetLogic:GetFinalBalanceBonus(_UserService.LocalPlayer)
			self:SetInfoText(_GetLocalizationTextLogic:GetText("RecipeBonusBalance"), self.defaultDelay+self.defaultDuration, "fe50a69061af452c8ba794664a8b0ca5", false, false)
		else
			balanceBonus = _TasteGradeDataSetLogic.FinalBalancePenalty
			self:SetInfoText(_GetLocalizationTextLogic:GetText("RecipePaneltyBalance"), self.defaultDelay+self.defaultDuration, "fe50a69061af452c8ba794664a8b0ca5", false, false)
		end
		
		local originTasteScore = self.FinalTasteScore
		local newScore = self.FinalTasteScore * balanceBonus
		self:SetFinalScore(newScore)
		self:RequestRefreshTasteScoreBar(originTasteScore, self.FinalTasteScore, self.defaultDelay)
	end

	@ExecSpace("ClientOnly")
	method void RequestRefreshSpicinessScoreBar(number addValue, number duration)
		-- 매운맛 점수 바를 새로고침 요청하는 함수
		local spiciness = self.UIRecipeMaking.UIRecipeMaking.SpicyPoint + addValue
		local spicinessThreshold = _IngredientDataSetLogic:GetSpicyThreshold(_UserService.LocalPlayer)
		
		if spiciness >= spicinessThreshold then
			self.isSpicy = true
			spiciness = spicinessThreshold
		
		else
			self.isSpicy = false
		end
		
		local spicyValue = spiciness / spicinessThreshold
		if spicyValue >= 1 then
			spicyValue = 1
		end
		
		local tween = _TweenLogic:PlayTween(self.SpicinessGauge.SpriteGUIRendererComponent.FillAmount, spicyValue, duration, EaseType.CubicEaseOut, function(t)
			self.SpicinessGauge.SpriteGUIRendererComponent.FillAmount = t
			if t >= (spicyValue - 0.05) then
				self:SetSpicyResult()
			end
		end)
		
		self.UIRecipeMaking.UIRecipeMaking.SpicyPoint = spiciness
		if self.isSpicy then
			local tagEntity = self.TagBar:GetChildByName("RecipeTag")
			self.UIRecipeMaking.UIRecipeMaking.Tag = _RecipeTagEnum.Spicy
			tagEntity.UIRecipeTag:Refresh(self.UIRecipeMaking.UIRecipeMaking.Tag, true)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSpicyResult()
		-- 매운맛 결과를 설정하는 함수
		if self.isSpicy then
			self.SpicinessBar:GetChildByName("SpicyIcon").Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void RequestRefreshPriceBar(number duration)
		-- 가격 바를 새로고침 요청하는 함수
		local priceValue = 0
		local selectedIngres = self.UIRecipeMaking.UIRecipeMaking.SelectedIngres
		for k, v in pairs(selectedIngres) do
			---@type RecipeIngreDrawData
			local drawData = v
			
			local basePrice
			if drawData.DrawType == _RecipeIngreDrawEnum.Ingredient then
				basePrice = _IngredientDataSetLogic:GetIngredientData(drawData.Id):GetCost(_UserService.LocalPlayer.PlayerStage.NowStage, _UserService.LocalPlayer)
			else
				basePrice = _IngredientDataSetLogic:GetBunDetailData(drawData.Id, drawData.DrawDetailType).BaseCost
			end
			
			priceValue = priceValue + basePrice
		end
		
		local gradeData = _TasteGradeDataSetLogic:ReturnGradeDataByScore(self.FinalTasteScore)
		priceValue = priceValue * gradeData.GoldBonus
		self.FinalPrice = math.floor(priceValue)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Refuel"], 1)
		self:MakeTweenNumTextRising(self.PriceText, 0, priceValue, duration, true)
	end

	@ExecSpace("ClientOnly")
	method void RequestTagIconPopped()
		-- 태그 아이콘이 팝업되도록 요청하는 함수
		local selectedIngres = self.UIRecipeMaking.UIRecipeMaking.SelectedIngres
		local ingreCount = #table.keys(selectedIngres)
		local delay = 0.3
		
		local index = 1
		for k, v in pairs(selectedIngres) do
			---@type RecipeIngreDrawData
			local drawData = v
			
			if drawData.DrawType == _RecipeIngreDrawEnum.Ingredient then
				local ingreData = _IngredientDataSetLogic:GetIngredientData(drawData.Id)
				local ingreType = ingreData.Type
				
				if isvalid(_RecipeTagDataSetLogic.RecipeTagData[ingreType]) then
					_TimerService:SetTimerOnce(function()
						local burgerEntity = self.UIRecipeMaking.UIRecipeMaking.BurgerParent:GetChildByName("Model_RecipeIngredient"..k)
						local burgerParent = self.UIRecipeMaking.UIRecipeMaking.BurgerParent
						local parent = self.UIRecipeMaking.UIRecipeMaking.BurgerRenderParent
						_RecipeTagDataSetLogic:PopRecipeTypeIcon(burgerParent, parent, drawData.Id, 0.55)
					end, 0)
					index = index + 1
				end
			end
		end
		
		if index > 1 then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_RecipeIcon"], 1)
		end
		
		_TimerService:SetTimerOnce(function()
			
			local tagEntity = self.TagBar:GetChildByName("RecipeTag")
			local tag = _RecipeTagDataSetLogic:ReturnMainTypeOfIngres(self.UIRecipeMaking.UIRecipeMaking.SelectedIngres, _UserService.LocalPlayer)
			self.UIRecipeMaking.UIRecipeMaking.Tag = tag
			
			tagEntity.UIRecipeTag:Refresh(tag, true)
			self.TagBar.Enable = true
			
		end, self.defaultDelay)
	end

	@ExecSpace("ClientOnly")
	method void ChangeRenderIndex(integer renderIndex)
		-- 렌더링 인덱스를 변경하는 함수
		self.renderIndex = renderIndex
		self:RenderFunction(renderIndex)
		_UserService.LocalPlayer.PlayerDebugMonitor:UpdateDebugMonitorRecipeMaking("Result")
	end

	@ExecSpace("ClientOnly")
	method void RenderFunction(integer renderIndex)
		-- 렌더링 단계에 따라 결과를 표시하는 함수
		_TimerService:ClearTimer(self.phaseTimer)
		if renderIndex == 0 then
			return
		end
		
		local longDuration = self.defaultDelay + self.defaultDuration
		
		if renderIndex == 1 then 
			
			self.EndText.UITweenAlpha:Play()
			self.EndText.UITweenScale:Play()
			self.EndText.Enable = true
			
			_UIEntityService:PlayUISpriteAnim(self.UIRecipeMaking.UIRecipeMaking.CompleteEffect, self.BurgerCompleteEffectRUID, 1)
			_SoundService:PlaySound(_ResourceManager.SFXTable["System_cinematic_get_01"], 1)
			
			_RecipeDataSetLogic:RequestSetRandomRecipeName(_UserService.LocalPlayer, self.UIRecipeMaking.UIRecipeMaking.SelectedIngres) 
			
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self.SkipButton.Enable = true
				self.BurgerStats.Enable = true 
				self.phaseTimer = _TimerService:SetTimerOnce(function()
					self:ChangeRenderIndex(2)
				end, self.defaultDelay)
			end, 1)
			
		elseif renderIndex == 2 then 
			
			self.TasteScoreBar.Enable = true
			self:SetFinalScore(self.UIRecipeMaking.UIRecipeMaking.TasteScore)
			self:RequestRefreshTasteScoreBar(0, self.FinalTasteScore, self.defaultDuration)
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(3)
			end, longDuration)
			
		elseif renderIndex == 3 then 
			
			local maxCombo = self.UIRecipeMaking.UIRecipeMaking.MaxCombo
			if maxCombo <= 0 then
				self:ChangeRenderIndex(4)
				return
			end
			
			local maxComboBonusMultiply = 1 + _TasteGradeDataSetLogic:GetFinalComboBonus(_UserService.LocalPlayer)*maxCombo
			local maxComboBonus = math.floor(self.FinalTasteScore * maxComboBonusMultiply)
			
			local exTasteScore = self.FinalTasteScore
			local newTasteScore = self:ReturnValueCapApplied(maxComboBonus)
			local text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RecipeBonusMaxCombo", maxCombo)
			self:SetInfoText(text, longDuration, "40939c80a38a4e0183a76e88370b3068", false, false)
			self:RequestRefreshTasteScoreBar(exTasteScore, newTasteScore, self.defaultDuration)
			
			self:SetFinalScore(newTasteScore)
			
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(4)
			end, longDuration)
			
		elseif renderIndex == 4 then 
			
			self.BalanceScoreBar.Enable = true
			local balanceScore = self.UIRecipeMaking.UIRecipeMaking.BalancePoint
		 	self:RequestRefreshBalanceScoreBar(balanceScore, self.defaultDuration) 
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(5)
			end, longDuration)
			
		elseif renderIndex == 5 then 
			
			self.SpicinessScoreBar.Enable = true
			self:RequestRefreshSpicinessScoreBar(0, self.defaultDuration)
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(6)
			end, longDuration)
			
		elseif renderIndex == 6 then 
			
			self:RequestTagIconPopped()
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(7)
			end, longDuration)
			
		elseif renderIndex == 7 then 
			
			local selectedIngres = self.UIRecipeMaking.UIRecipeMaking.SelectedIngres	
			local bunDrawData = selectedIngres[1]	
			local bunData = _IngredientDataSetLogic:GetBunData(bunDrawData.Id)
			
			local tag = bunData.Tag
			
			local answerTag = self.UIRecipeMaking.UIRecipeMaking.Tag
			local isTagMatch = false
			if answerTag == tag then
				isTagMatch = true
			end
				
			if isTagMatch then
				local exTasteScore = self.FinalTasteScore
				local newTasteScore = math.floor(self.FinalTasteScore * _TasteGradeDataSetLogic.BunTypeBonus)
				self:SetInfoText(_GetLocalizationTextLogic:GetText("RecipeBonusBun"), longDuration, "30295af190384654aebfd6f30b8bc12e", false, false)	
				self:SetFinalScore(newTasteScore)
				self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), self.defaultDuration)
				
				self.phaseTimer = _TimerService:SetTimerOnce(function()
					self:ChangeRenderIndex(8)
				end, longDuration)
			else
				self:ChangeRenderIndex(8)
			end
			
		elseif renderIndex == 8 then 
			
			local sideMenuId = _UserService.LocalPlayer.PlayerIngameManager.StageSideMenu
			local smData = _StrategyDataSetLogic:GetSideMenuData(sideMenuId)
			if smData == nil then
				self:ChangeRenderIndex(9)
				return
			end
			
			if _UtilLogic:IsNilorEmptyString(smData.Effect[1]) then
				self:ChangeRenderIndex(9)
				return
			end
			
			local effectSplit = _UtilLogic:Split(smData.Effect[1], "_")
			local effectKey = effectSplit[1]
			local tag = self.UIRecipeMaking.UIRecipeMaking.Tag
			
			local smEffect = _StrategyEnum:GetSideMenuEffect(sideMenuId, effectKey, tag)
			if smEffect == 0 then
				self:ChangeRenderIndex(9)
				return
			end
			
			local exTasteScore = self.FinalTasteScore
			local newTasteScore = math.floor(self.FinalTasteScore * (1+smEffect))
			
			local infoText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RecipeBonusSideMenu", _GetLocalizationTextLogic:GetText(smData.NameKey))
			self:SetInfoText(infoText, longDuration, smData.IconRUID, true, false)	
			self:SetFinalScore(newTasteScore)
			self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), self.defaultDuration)
			
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(9)
			end, longDuration)
			
		elseif renderIndex == 9 then 
			
		    self.EndText.Enable = false
			self.SkipButton.Enable = false
		    
		    self.UIRecipeEmployeeList.UIRecipeEmployeeList:Open()
			
			
		elseif renderIndex == 10 then 
			
			if _UtilLogic:IsNilorEmptyString(self.SelectedEmployeeId) then
				self:ChangeRenderIndex(11)
			else
				
				local skillDuration = 2
				
				local employeeData = _EmployeeService:GetData(self.SelectedEmployeeId)
				local skills = {employeeData.Skill1Type, employeeData.Skill2Type}
				local canUseSkills = {}
				for i = 1, #skills do
					local skillId = skills[i]
					self.UsedSkillList[skillId] = false
					local skillType = _EmployeeSkillService:GetData(skillId).Type
					if skillType == "Recipe" then
						if _EmployeeSkillService:CanUseSkill(self.SelectedEmployeeId, skillId, _UserService.LocalPlayer) then
							table.insert(canUseSkills, skillId)
						end
					end			
				end
				
				for i = 1, #canUseSkills do
					_TimerService:SetTimerOnce(function()
						self:UseSkill(canUseSkills[i], 1.8)
					end, skillDuration * (i-1))
				end
				self.phaseTimer = _TimerService:SetTimerOnce(function()
					self:ChangeRenderIndex(11)
				end, skillDuration * #canUseSkills)
			end
			
		elseif renderIndex == 11 then 
			self.EndText.Enable = true
			self.EndText.UITweenAlpha:Play()
			self.EndText.UITweenScale:Play()
				
			self.SelectedEmployee.Enable = false
			
			self.PriceBar.Enable = true
			self:RequestRefreshPriceBar(self.defaultDuration)
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(12)
			end, longDuration)
			
		elseif renderIndex == 12 then 
			self.UIRecipeBunSkinList:Open()
			
		elseif renderIndex == 13 then 
			
			local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(self.SelectedBunSkinId)
			if isvalid(bunSkinData) == false then
				self:ChangeRenderIndex(14)
				return
			end
			
			_UIEntityService:PlayUISpriteAnim(self.UIRecipeMaking.UIRecipeMaking.CompleteEffect, self.BurgerCompleteEffectRUID, 1)
			_SoundService:PlaySound(_ResourceManager.SFXTable["ShowGachaResult"], 1)
			
			local effectAmount = _GetConfigDataLogic:GetConfigNumDataByKey("BunSkinUseBonusAmount")
			local exPrice = self.FinalPrice
			self.FinalPrice = self.FinalPrice * (1+effectAmount)
			
			_TimerService:SetTimerOnce(function()
				local infoText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RecipeBonusBunSkin", _GetLocalizationTextLogic:GetText(bunSkinData.Top.NameKey))
				self:SetInfoText(infoText, longDuration, bunSkinData.Top.IconRUID, false, true)	
				_UIEntityService:PlayMoneyPopFade(self.FinalPrice-exPrice, self.UIRecipeMaking.UIRecipeMaking.BurgerParent, self.UIRecipeMaking.UIRecipeMaking.BurgerRenderParent)
				_SoundService:PlaySound(_ResourceManager.SFXTable["Refuel"], 1)
				self:MakeTweenNumTextRising(self.PriceText, exPrice, self.FinalPrice, 1, true)
			end, self.defaultDelay)
				
			self.phaseTimer = _TimerService:SetTimerOnce(function()
				self:ChangeRenderIndex(14)
			end, longDuration+self.defaultDelay)
			
		elseif renderIndex == 14 then 
			
			self.DoNameText.Enable = true
			self.BurgerNameInput.Enable = true
			self.EndButton.Enable = true
			
			if _VIPOrderDataSetLogic.UIVIPOrderPreviewNowSlot == nil or _VIPOrderDataSetLogic.UIVIPOrderPreviewNowSlot == 0 then
				self.UIRecipeMaking.UIRecipeMaking.UIVIPOrderPreview.Entity:SetEnable(false)
			else
				self.UIRecipeMaking.UIRecipeMaking.UIVIPOrderPreview:Refresh(nil)
			end
			
			self:ChangeRenderIndex(0)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetInfoText(string text, number duration, string iconRUID, boolean isSideMenu, boolean isBunSkin)
		-- 정보 텍스트를 설정하고 표시하는 함수
		local icon = self.InfoText:GetChildByName("Icon")
		local sideMenuIcon = self.InfoText:GetChildByName("SideMenuIcon")
		local bunSkinIcon = self.InfoText:GetChildByName("BunSkinIcon")
		
		local targetIcon = icon
		if isSideMenu == true then
			targetIcon = sideMenuIcon
		elseif isBunSkin == true then
			targetIcon = bunSkinIcon
		end
		
		icon.Enable = not isSideMenu and not isBunSkin
		sideMenuIcon.Enable = isSideMenu and not isBunSkin
		bunSkinIcon.Enable = isBunSkin and not isSideMenu
		
		self.InfoText.UITransformComponent.anchoredPosition = Vector2(self.infoTextOriginPos.x, self.infoTextOriginPos.y)
		self.InfoText.CanvasGroupComponent.GroupAlpha = 0
		self.InfoText.TextComponent.Text = text
		targetIcon.SpriteGUIRendererComponent.ImageRUID = iconRUID
		self.InfoText.Enable = true
		
		local targetPos = Vector2(self.infoTextOriginPos.x, self.infoTextOriginPos.y + 100)
		
		local moveVec = targetPos.y - self.infoTextOriginPos.y
		local fadeIn = _TweenLogic:PlayTween(0, 1, duration/3, EaseType.CubicEaseOut, function(t)
			self.InfoText.UITransformComponent.anchoredPosition = Vector2(self.infoTextOriginPos.x, self.infoTextOriginPos.y + moveVec*t)
			self.InfoText.CanvasGroupComponent.GroupAlpha = t
		end)
		
		_TimerService:SetTimerOnce(function()
				
		end, duration/3)
		
		_TimerService:SetTimerOnce(function()
			local startPosY = self.InfoText.UITransformComponent.anchoredPosition.y
			local fadeOut = _TweenLogic:PlayTween(0, 1, duration/3, EaseType.CubicEaseOut, function(t)
				self.InfoText.UITransformComponent.anchoredPosition = Vector2(self.infoTextOriginPos.x, startPosY - moveVec/2*t)
				self.InfoText.CanvasGroupComponent.GroupAlpha = (1-t)
			end)
		end, duration/3*2)
		
		_TimerService:SetTimerOnce(function()
			self.InfoText.Enable = false
			self.InfoText.TextComponent.Text = ""
			self.InfoText.CanvasGroupComponent.GroupAlpha = 0
		end, duration)
	end

	@ExecSpace("ClientOnly")
	method void SetSelectedEmployeeInfo(string employeeId, string animType, string comment, number commentDuration, string reactionType)
		-- 선택된 직원의 정보를 설정하는 함수
		self.SelectedEmployee.Enable = true
		_TrialLogic:PlayUIEmployeeAnim(self.SelectedEmployee, employeeId, animType, true, _UserService.LocalPlayer)
		
		if _UtilLogic:IsNilorEmptyString(comment) == false then
			self.EmployeeCommentText.TextComponent.Text = comment
			self.EmployeeCommentText.Enable = true
			
			_TimerService:SetTimerOnce(function()
				self.EmployeeCommentText.Enable = false
			end, commentDuration)
		end
		
		if _UtilLogic:IsNilorEmptyString(reactionType) == false then
			self.EmployeeChatBalloon.Enable = true
			if reactionType == "LackOfLevel" then
				self.EmployeeChatBalloonIcon.SpriteGUIRendererComponent.ImageRUID = _PeedbackRUID.NeedEmployeeUpgrade
			elseif reactionType == "Discontent" then
				self.EmployeeChatBalloonIcon.SpriteGUIRendererComponent.ImageRUID = _PeedbackRUID.Discontent
			else
				self.EmployeeChatBalloon.Enable = false
			end
		else
			self.EmployeeChatBalloon.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSkillInfo(string skillId, number duration, boolean isSuccess, integer skillLevel)
		-- 스킬 정보를 설정하고 표시하는 함수
		local skillInfo = _EmployeeSkillService:GetData(skillId)
		self.SkillInfoArea.Enable = true
		local skillNameEntity = self.SkillInfoArea:GetChildByName("SkillName")
		local skillNameText = skillNameEntity.TextComponent
		local skillDescText = self.SkillInfoArea:GetChildByName("SkillDesc").TextComponent
		
		local blur = self.SkillInfoArea:GetChildByName("Blur")
		local decoL = skillNameEntity:GetChildByName("Deco_L")
		local decoR = skillNameEntity:GetChildByName("Deco_R")
		local decos = {blur, decoL, decoR}
		
		local skillName = _EmployeeSkillService:ReturnSkillName(skillId, skillLevel)
		local skillDesc = _EmployeeSkillService:ReturnSkillDesc(skillId, skillLevel)
		
		local employeeInfo = _EmployeeService:GetData(self.SelectedEmployeeId)
		local employeeName = _GetLocalizationTextLogic:GetText(employeeInfo.NameKey)
		
		_TimerService:SetTimerOnce(function()
			self.SkillInfoArea.Enable = false
		end, duration)
		
		if isSuccess then
			skillNameText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RecipeUseSkillInfoSuccess", employeeName, skillName)
			skillNameText.FontColor = _ColorCodeEnum:GetColor("#ffec6f")
			skillNameText.OutlineColor = _ColorCodeEnum:GetColor("#5d3a09")
			
			skillDescText.Text = skillDesc
			skillDescText.FontColor = _ColorCodeEnum:GetColor("#faf2da")
			skillDescText.OutlineColor = _ColorCodeEnum:GetColor("#5d3a09")
			
			for _, entity in pairs(decos) do
				entity.Enable = true
			end
			
			local commentPool = {_GetLocalizationTextLogic:GetText("RecipeSkillComment1"), _GetLocalizationTextLogic:GetText("RecipeSkillComment2"), _GetLocalizationTextLogic:GetText("RecipeSkillComment3"),
			_GetLocalizationTextLogic:GetText("RecipeSkillComment4"), _GetLocalizationTextLogic:GetText("RecipeSkillComment5"), _GetLocalizationTextLogic:GetText("RecipeSkillComment6"),
			_GetLocalizationTextLogic:GetText("RecipeSkillComment7")}
			if skillId == _SkillTypeEnum.SpicyPoint then
				table.insert(commentPool, _GetLocalizationTextLogic:GetText("RecipeSkillComment9"))
			else
				table.insert(commentPool, _GetLocalizationTextLogic:GetText("RecipeSkillComment8"))
			end
			
			local randomIndex = _UtilLogic:RandomIntegerRange(1, #commentPool)
			local comment = commentPool[randomIndex]
			
			self:SetSelectedEmployeeInfo(self.SelectedEmployeeId, "Love", comment, duration, nil)
			_TimerService:SetTimerOnce(function()
				self:SetSelectedEmployeeInfo(self.SelectedEmployeeId, "Stand", nil, 0, nil)
			end, duration)
			
			
		else
			local fontColor = _ColorCodeEnum:GetColor("#cccccc")
			local fontOutlineColor = _ColorCodeEnum:GetColor("#383737")
			
			skillNameText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RecipeUseSkillInfoFail", employeeName, skillName)
			skillNameText.FontColor = fontColor
			skillNameText.OutlineColor = fontOutlineColor
			
			skillDescText.Text = _GetLocalizationTextLogic:GetText("RecipeSkillErrorMessage2")
			skillDescText.FontColor = fontColor
			skillDescText.OutlineColor = fontOutlineColor
			
			for _, entity in pairs(decos) do
				entity.Enable = false
			end
			
			self:SetSelectedEmployeeInfo(self.SelectedEmployeeId, "Stunned", _GetLocalizationTextLogic:GetText("SkillFailComment"), duration, nil)
			_TimerService:SetTimerOnce(function()
				self:SetSelectedEmployeeInfo(self.SelectedEmployeeId, "Stunned", nil, 0, nil)
			end, duration)
		end
	end

	@ExecSpace("ClientOnly")
	method void UseSkill(string skillId, number duration)
		-- 직원의 스킬을 사용하는 함수
		local employeeData = _EmployeeService:GetData(self.SelectedEmployeeId)
		local skillIndex = _EmployeeSkillService:HasSkill(employeeData.Id, skillId)
		local skillData = _EmployeeSkillService:GetData(skillId)
		local skillGrade = _EmployeeSkillService:ReturnSkillGrade(self.SelectedEmployeeId, skillId, _UserService.LocalPlayer)
		
		local skillValue = _EmployeeSkillService:ReturnSkillGradeValue(self.SelectedEmployeeId, skillId, _UserService.LocalPlayer)
		local isSuccess = false
		if skillId == _SkillTypeEnum.MeatTasteScore then
			local tag = self.UIRecipeMaking.UIRecipeMaking.Tag
			if tag == _RecipeTagEnum.Meat then
				local exTasteScore = self.FinalTasteScore
				local newTasteScore = self.FinalTasteScore * (1+skillValue)
				self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), duration)
				
				self:SetFinalScore(newTasteScore)
				
				isSuccess = true
			else
				isSuccess = false
			end
			
		elseif skillId == _SkillTypeEnum.ChickenTasteScore then
			local tag = self.UIRecipeMaking.UIRecipeMaking.Tag
			if tag == _RecipeTagEnum.Chicken then
				local exTasteScore = self.FinalTasteScore
				local newTasteScore = self.FinalTasteScore * (1+skillValue)
				self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), duration)
				
				self:SetFinalScore(newTasteScore)
				
				isSuccess = true
			else
				isSuccess = false
			end
			
		elseif skillId == _SkillTypeEnum.SeafoodTasteScore then
			local tag = self.UIRecipeMaking.UIRecipeMaking.Tag
			if tag == _RecipeTagEnum.Seafood then
				local exTasteScore = self.FinalTasteScore
				local newTasteScore = self.FinalTasteScore * (1+skillValue)
				self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), duration)
				
				self:SetFinalScore(newTasteScore)
				
				isSuccess = true
			else
				isSuccess = false
			end
				
		elseif skillId == _SkillTypeEnum.VeggieTasteScore then
			local tag = self.UIRecipeMaking.UIRecipeMaking.Tag
			if tag == _RecipeTagEnum.Veggie then
				local exTasteScore = self.FinalTasteScore
				local newTasteScore = self.FinalTasteScore * (1+skillValue)
				self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), duration)
				
				self:SetFinalScore(newTasteScore)
				
				isSuccess = true
			else
				isSuccess = false
			end
			
			
		elseif skillId == _SkillTypeEnum.SpicyTasteScore then
			local tag = self.UIRecipeMaking.UIRecipeMaking.Tag
			if tag == _RecipeTagEnum.Spicy then
				local exTasteScore = self.FinalTasteScore
				local newTasteScore = self.FinalTasteScore * (1+skillValue)
				self:RequestRefreshTasteScoreBar(exTasteScore, self:ReturnValueCapApplied(newTasteScore), duration)
				
				self:SetFinalScore(newTasteScore)
				
				isSuccess = true
			else
				isSuccess = false
			end
				
		elseif skillId == _SkillTypeEnum.SpicyPoint then
			self:RequestRefreshSpicinessScoreBar(skillValue, duration)
			isSuccess = true	
		end
		
		self.UsedSkillList[skillId] = isSuccess
		
		_TimerService:SetTimerOnce(function()
			if isSuccess then
				_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_RecipeSkill"], 1)
				_UIEntityService:PlayUISpriteAnim(self.UIRecipeMaking.UIRecipeMaking.CompleteEffect, self.BurgerCompleteEffectRUID, 1)
			else
				_SoundService:PlaySound(_ResourceManager.SFXTable["TrialFail"], 1)
			end
		end, 0.3)
		
		self:SetSkillInfo(skillId, duration, isSuccess, skillGrade)
	end

	@ExecSpace("ClientOnly")
	method void SkipResultRender()
		-- 결과 렌더링을 스킵하는 함수
		_TimerService:ClearTimer(self.phaseTimer)
		if isvalid(self._T.riseTimer) then
			_TimerService:ClearTimer(self._T.riseTimer)
			_SoundService:StopSound(_ResourceManager.SFXTable["Eff_CountUp_Loop"])
			self._T.riseTimer = nil
		end
		
		local originTasteScore = self.UIRecipeMaking.UIRecipeMaking.TasteScore
		local lastTasteScore = originTasteScore
		
		local maxCombo = self.UIRecipeMaking.UIRecipeMaking.MaxCombo
		local maxComboBonusMultiply = 1 + _TasteGradeDataSetLogic:GetFinalComboBonus(_UserService.LocalPlayer)*maxCombo
		lastTasteScore = math.floor(lastTasteScore * maxComboBonusMultiply)
		
		local originBalanceScore = self.UIRecipeMaking.UIRecipeMaking.BalancePoint
		local isBalanced = self:SetBalanceResult(originBalanceScore, _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer))
		if isBalanced then
			lastTasteScore = math.floor(lastTasteScore * _TasteGradeDataSetLogic:GetFinalBalanceBonus(_UserService.LocalPlayer))
		else
			lastTasteScore = math.floor(lastTasteScore * _TasteGradeDataSetLogic.FinalBalancePenalty)
		end
		
		
		local spiciness = self.UIRecipeMaking.UIRecipeMaking.SpicyPoint
		if spiciness >= _IngredientDataSetLogic:GetSpicyThreshold(_UserService.LocalPlayer) then
			self.isSpicy = true
		end
		
		local tagEntity = self.TagBar:GetChildByName("RecipeTag")
		local tag = _RecipeTagDataSetLogic:ReturnMainTypeOfIngres(self.UIRecipeMaking.UIRecipeMaking.SelectedIngres, _UserService.LocalPlayer)
		self.UIRecipeMaking.UIRecipeMaking.Tag = tag
		tagEntity.UIRecipeTag:Refresh(tag, true)
		
		
		local selectedIngres = self.UIRecipeMaking.UIRecipeMaking.SelectedIngres
		---@type RecipeIngreDrawData
		local bunDrawData = selectedIngres[1]
		
		local bunData = _IngredientDataSetLogic:GetBunData(bunDrawData.Id)
		
		local answerTag = self.UIRecipeMaking.UIRecipeMaking.Tag
		if answerTag == bunData.Tag then
			lastTasteScore = math.floor(lastTasteScore * _TasteGradeDataSetLogic.BunTypeBonus)
		end
		
		local sideMenuId = _UserService.LocalPlayer.PlayerIngameManager.StageSideMenu
		local smData = _StrategyDataSetLogic:GetSideMenuData(sideMenuId)
		
		if smData ~= nil then
			if _UtilLogic:IsNilorEmptyString(smData.Effect[1]) == false then
				local effectSplit = _UtilLogic:Split(smData.Effect[1], "_")
				local effectKey = effectSplit[1]
				
				local smEffect = _StrategyEnum:GetSideMenuEffect(sideMenuId, effectKey, answerTag)
				lastTasteScore = math.floor(lastTasteScore * (1+smEffect))
			end
		end
		
		self:SetFinalScore(lastTasteScore)
		
		local longDuration = self.defaultDelay + self.defaultDuration
		_TimerService:SetTimerOnce(function()
			self.TagBar.Enable = true
			self.SpicinessScoreBar.Enable = true
			self.BalanceScoreBar.Enable = true
			self.TasteScoreBar.Enable = true
			
			self:RequestRefreshTasteScoreBar(self.FinalTasteScore, lastTasteScore, longDuration)
			self:RequestRefreshSpicinessScoreBar(0, longDuration)
			
			local balanceBarLength = self.BalanceZone.Parent.UITransformComponent.RectSize.x
			local balanceThreshold = _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer)
			
			local lastPos = self.BalancePointer.UITransformComponent.anchoredPosition
			local newPosX = balanceBarLength/2 * originBalanceScore / 50
			if newPosX >= balanceBarLength/2 then
				newPosX = balanceBarLength/2
			end
			if newPosX <= -balanceBarLength/2 then
				newPosX = -balanceBarLength/2
			end
			
			local tween = _TweenLogic:PlayTween(lastPos, Vector2(newPosX, lastPos.y), longDuration, EaseType.CubicEaseOut, function(t)
				self.BalancePointer.UITransformComponent.anchoredPosition = t
				if math.abs(self.BalancePointer.UITransformComponent.anchoredPosition.x) >= (math.abs(originBalanceScore)-1) then
					if self.BalanceText.Enable == false then
						self.BalanceText.Enable = true
					end
				end
			end)
			
			_TimerService:SetTimerOnce(function()	
				if originBalanceScore >= -balanceThreshold and originBalanceScore <= balanceThreshold then
					self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "3a178133919e4171a09ce815f6a58a6a"
				else
					self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "e7d7ef61793f426097204ceec35045b1"
				end
			end, longDuration/2)
			
			self:ChangeRenderIndex(9)
		end, self.defaultDelay)
		
	end

	@ExecSpace("ClientOnly")
	method void SetFinalScore(number value)
		-- 최종 점수를 설정하는 함수
		self.FinalTasteScore = self:ReturnValueCapApplied(value)
	end

	method integer ReturnValueCapApplied(number value)
		-- 값에 상한선을 적용하여 반환하는 함수
		if value > _TasteGradeDataSetLogic.MaxTasteScoreCap then
			value = _TasteGradeDataSetLogic.MaxTasteScoreCap
		end
		
		return math.floor(value)
	end

	@EventSender("Entity", "d788d716-6245-4a12-8638-0a35b73c4d7c")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 스킵 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:SkipResultRender()
	end

end