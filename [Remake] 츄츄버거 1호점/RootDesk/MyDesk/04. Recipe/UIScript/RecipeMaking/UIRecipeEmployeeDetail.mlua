@Component
script UIRecipeEmployeeDetail extends Component

	property Entity EmployeeName = nil

	property Entity EmployeeImage = nil

	property Entity EmployeeSkills = nil

	property Entity EmployeeLevel = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 직원 상세 정보 UI 요소들을 초기화하는 함수
		self.EmployeeName = self.Entity:GetChildByName("EmployeeName")
		
		if isvalid(self.Entity:GetChildByName("Mask")) then
			self.EmployeeImage = self.Entity:GetChildByName("Mask"):GetChildByName("EmployeeImage")
		else
			self.EmployeeImage = self.Entity:GetChildByName("EmployeeImage")
			
		end
		self.EmployeeSkills = self.Entity:GetChildByName("EmployeeSkills")
		
		self.EmployeeLevel = self.Entity:GetChildByName("ChuChuLevel")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(string employeeId)
		-- 직원 상세 정보를 새로고침하는 함수
		if self.EmployeeName == nil then
			self:Init() 
		end
		
		local employeeData = _EmployeeService:GetData(employeeId)
		local detailData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeDetail(employeeId)
		if isvalid(self.EmployeeLevel) then 
			self.EmployeeLevel.TextComponent.Text = tostring(_EmployeeService:ReturnChuchuLevel(employeeId, _UserService.LocalPlayer))	
		end
		self.EmployeeName.TextComponent.Text = _GetLocalizationTextLogic:GetText(employeeData.NameKey)
		
		_EmployeeUIService:DrawPortraitWithEquip(self.EmployeeImage, self.EmployeeImage, employeeData)
		
		local skills = {employeeData.Skill1Type, employeeData.Skill2Type}
		for i = 1, #skills do
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_EmployeeSkillSlot_Small", i, self.EmployeeSkills)
			if isvalid(entity) then
				entity.UIEmployeeSkillSlotSmall:Refresh(employeeId, skills[i])
				if i == 2 then
					entity.Enable = false 
				end
			end
		end
	end

end