@Component
script UIBunSkinListSlot extends Component

	property SpriteGUIRendererComponent Icon = nil

	property Entity Selected = nil

	property integer Id = 0

	property Entity Locked = nil

	property Entity NoneIcon = nil

	method void Init()
		-- 번 스킨 리스트 슬롯 UI 요소들을 초기화하는 함수
		self.Entity:GetChildByName("BG").SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.BunSkinSlotBG
		self.Icon = self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		self.Selected = self.Entity:GetChildByName("Selected")
		self.Locked = self.Entity:GetChildByName("Locked")
		self.NoneIcon = self.Entity:GetChildByName("Icon_None")
	end

	method void Refresh(integer bunSkinId)
		-- 번 스킨 슬롯을 새로고침하는 함수
		if self.Icon == nil then
			self:Init()
		end
		
		local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(bunSkinId)
		
		self.Id = bunSkinId
		
		if isvalid(bunSkinData) == false then
			self.NoneIcon.Enable = true
			self.Locked.Enable = false
			self.Icon.Enable = false
			return
		end
		
		self.NoneIcon.Enable = false
		
		local bunSkinDetailData = _IngredientDataSetLogic:GetBunSkinDetailData(bunSkinId, "Top")
		self.Icon.Enable = true
		self.Icon.ImageRUID = bunSkinDetailData.IconRUID
		
		local haveBunSkin = _UserService.LocalPlayer.PlayerCollection.BunSkinCollection[bunSkinId]
		if haveBunSkin == nil then
			haveBunSkin = false
		end
		
		self.Locked.Enable = not haveBunSkin
	end

	method void EnableSelected(boolean isSelected)
		-- 선택 상태를 설정하는 함수
		self.Selected.Enable = isSelected
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["System_Bingo_UI_01"], 1)
		_UIEntityLogic_RecipeGroup.UIRecipeMaking.UIRecipeMaking.ResultEntities.UIRecipeResult.UIRecipeBunSkinList:OnClickSlot(self.Id)
	end

end