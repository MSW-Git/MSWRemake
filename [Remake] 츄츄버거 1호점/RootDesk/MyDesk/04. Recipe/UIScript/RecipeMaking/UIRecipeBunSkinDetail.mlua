@Component
script UIRecipeBunSkinDetail extends Component

	property SpriteGUIRendererComponent BunSkinIcon = nil

	property TextComponent UseEffectText = nil

	property Entity BuyButton = nil

	property TextComponent Name = nil

	property Entity CollectEffectText = nil

	property Entity UseButton = nil

	property Entity UseText = nil

	property Entity BuyInfo = nil

	property Entity UseBtnDim = nil

	property Entity UnlockInfo = nil

	property TextComponent CostText = nil

	property Entity NoneText = nil

	property Entity EffectTitle = nil

	property Entity CollectEffectTitle = nil

	property Entity Line = nil

	property TextComponent CostTitleText = nil

	method void Init()
		-- 번 스킨 상세 정보 UI 요소들을 초기화하는 함수
		local bunSkinSlot = self.Entity:GetChildByName("BunSkinSlot")
		bunSkinSlot.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.BunSkinSlotBG
		self.BunSkinIcon = bunSkinSlot:GetChildByName("Icon").SpriteGUIRendererComponent
		
		self.Name = self.Entity:GetChildByName("Name").TextComponent
		
		self.EffectTitle = self.Entity:GetChildByName("EffectTitle")
		self.UseEffectText = self.Entity:GetChildByName("EffectText").TextComponent
		self.CollectEffectTitle = self.Entity:GetChildByName("CollectEffectTitle")
		local collectEffect = _GetConfigDataLogic:GetConfigNumDataByKey("BunSkinCollectBonusAmountPerCount")
		self.CollectEffectText = self.Entity:GetChildByName("CollectEffectText")
		self.CollectEffectText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("BunSkinCollectEffectText", math.floor(collectEffect*100))
		
		self.Line = self.Entity:GetChildByName("Line")
		self.NoneText = self.Entity:GetChildByName("Text_None")
		
		self.UseButton = self.Entity:GetChildByName("UseButton")
		self.UseBtnDim = self.UseButton:GetChildByName("Dim")
		self.UseText = self.UseButton:GetChildByName("UseText")
		self.UnlockInfo = self.UseButton:GetChildByName("UnlockInfo")
		self.BuyInfo = self.UseButton:GetChildByName("BuyInfo")
		self.CostText = self.BuyInfo:GetChildByName("CostText").TextComponent
		self.CostTitleText = self.BuyInfo:GetChildByName("BuyText").TextComponent
		self.BuyInfo:GetChildByName("CostIcon").SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData("G1001").IconRUID
		
		self.UseButton:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			local skinData = _IngredientDataSetLogic:GetBunSkinData(self._T.bunSkinId)
			if skinData == nil then
				return
			end
			
			local player = _UserService.LocalPlayer
			local haveBunSkin = player.PlayerCollection.BunSkinCollection[self._T.bunSkinId]
			if haveBunSkin == nil then
				haveBunSkin = false
			end
			
			if haveBunSkin == true then
				_SoundService:PlaySound(_ResourceManager.SFXTable["System_cinematic_get_01"], 1)
				_UIEntityLogic_RecipeGroup.UIRecipeMaking.UIRecipeMaking.ResultEntities.UIRecipeResult.UIRecipeBunSkinList:OnClickUseBtn()
						
			else
				if skinData.GetCondition ~= "Buy" then
					return
				end		
				
				local cost = tonumber(skinData.ConditionValue)
				if player.PlayerOutgameManager:GetDiamondCount() < cost then
					_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("NoDiaToastMsg"))
					return
				end
				
				local onOk = function()	
					_SoundService:PlaySound(_ResourceManager.SFXTable["System_CashShop_Buy_01"], 1)
					player.PlayerCollection:RequestAddBunSkinCollection(self._T.bunSkinId)
				end
				
				local onCancel = function() end
				
				
				local costText = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(tonumber(skinData.ConditionValue)))
				_UIPurchasePopupLogic:OpenNoRefunablePurchasePopup(costText, onOk, false)
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				
			end
			
		end)
	end

	method void Refresh(integer bunSkinId)
		-- 번 스킨 상세 정보를 새로고침하는 함수
		if self.Name == nil then
			self:Init()
		end
		
		local player = _UserService.LocalPlayer
		local haveBunSkin = player.PlayerCollection.BunSkinCollection[bunSkinId]
		if haveBunSkin == nil then
			haveBunSkin = false
		end
		
		self._T.bunSkinId = bunSkinId
		local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(bunSkinId)
			
		self.NoneText.Enable = bunSkinId == nil or bunSkinId == 0
			
		self.Name.Entity.Enable = not (bunSkinId == nil or bunSkinId == 0)
		self.BunSkinIcon.Entity.Parent.Enable = not (bunSkinId == nil or bunSkinId == 0)
		self.EffectTitle.Enable = not (bunSkinId == nil or bunSkinId == 0)
		self.UseEffectText.Entity.Enable = not (bunSkinId == nil or bunSkinId == 0)
		self.CollectEffectTitle.Enable = not (bunSkinId == nil or bunSkinId == 0)
		self.CollectEffectText.Enable = not (bunSkinId == nil or bunSkinId == 0)
		self.Line.Enable = not (bunSkinId == nil or bunSkinId == 0)
		
		if bunSkinId == nil or bunSkinId == 0 then
			self.UseBtnDim.Enable = true
			self.UseText.Enable = true
			self.BuyInfo.Enable = false
			self.UnlockInfo.Enable = false
			
			self.Entity.Parent.UIRecipeBunSkinList:OnSelectBunSkinId(bunSkinId)
			return
		end
		
		local bunSkinDetailData = _IngredientDataSetLogic:GetBunSkinDetailData(bunSkinId, "Top")
		
		self.Name.Text = _GetLocalizationTextLogic:GetText(bunSkinDetailData.NameKey)
		self.BunSkinIcon.ImageRUID = bunSkinDetailData.IconRUID
		
		local useEffect = _GetConfigDataLogic:GetConfigNumDataByKey("BunSkinUseBonusAmount")
		self.UseEffectText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("BunSkinUseEffectText", math.floor(useEffect*100))
		
		if haveBunSkin == true then
			self.UseText.Enable = true
			self.BuyInfo.Enable = false
			self.UnlockInfo.Enable = false
			self.UseBtnDim.Enable = false
			
		else
			self.UseText.Enable = bunSkinData.GetCondition ~= "Buy"
			self.BuyInfo.Enable = bunSkinData.GetCondition == "Buy"
			self.UnlockInfo.Enable = bunSkinData.GetCondition ~= "Buy"
			self.UseBtnDim.Enable = bunSkinData.GetCondition ~= "Buy"
				
			if bunSkinData.GetCondition == "Buy" then
				local cost = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(tonumber(bunSkinData.ConditionValue)))
				self.CostText.Text = cost
				self.CostText.FontColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#fa5246") or _ColorCodeEnum:GetColor("#ffffff")
				self.CostText.OutlineColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#ffffff") or _ColorCodeEnum:GetColor("#af7016")
				self.CostTitleText.FontColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#fa5246") or _ColorCodeEnum:GetColor("#ffffff")
				self.CostTitleText.OutlineColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#ffffff") or _ColorCodeEnum:GetColor("#af7016")
				
			else
				if bunSkinData.GetCondition == "StagePass" then
					self.UnlockInfo.TextComponent.Text = _GetLocalizationTextLogic:GetText("BunSkinConditionStagePass")
				elseif bunSkinData.GetCondition == "PiggyBank" then
					self.UnlockInfo.TextComponent.Text = _GetLocalizationTextLogic:GetText("BunSkinConditionPiggyBank")
				end
				
			end	
		end
		
		self.Entity.Parent.UIRecipeBunSkinList.Slots[bunSkinId].UIBunSkinListSlot:Refresh(bunSkinId)
		self.Entity.Parent.UIRecipeBunSkinList:OnSelectBunSkinId(bunSkinId)
	end

end