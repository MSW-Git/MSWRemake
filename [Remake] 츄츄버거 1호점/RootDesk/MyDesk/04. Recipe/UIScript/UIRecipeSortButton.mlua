@Component
script UIRecipeSortButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 레시피 정렬 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		local uiRecipeListHolder = _UIEntityLogic_RecipeGroup.UIRecipeList.UIRecipeListHolder
		local topBar = uiRecipeListHolder.TopBar["Recipe"]
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		uiRecipeListHolder:RefreshListAndDetail(nil, self.Entity.Name)
		topBar.UIRecipeSetTopBar:SetEnableSortList(false)
	end

end