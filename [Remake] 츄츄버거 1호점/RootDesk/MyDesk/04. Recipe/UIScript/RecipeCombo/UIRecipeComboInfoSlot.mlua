@Component
script UIRecipeComboInfoSlot extends Component

	property Entity NameText = nil

	property Entity DescText = nil

	property Entity IsActiveEntity = nil

	property Entity ComboTagList = nil

	property Entity TopBG = nil

	property Entity TopLine = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 레시피 콤보 정보 슬롯 UI 요소들을 초기화하는 함수
		local topBar = self.Entity:GetChildByName("TopBar")
		local bottomBar = self.Entity:GetChildByName("BottomBar")
		self.NameText = topBar:GetChildByName("NameText")
		self.DescText = topBar:GetChildByName("DescText")
		self.IsActiveEntity = topBar:GetChildByName("IsActive")
		self.TopBG = topBar:GetChildByName("BG")
		self.TopLine = topBar:GetChildByName("Line")
		self.ComboTagList = bottomBar:GetChildByName("ComboTagList")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer comboId)
		-- 레시피 콤보 정보 슬롯을 새로고침하는 함수
		if self.NameText == nil then
			self:Init()
		end
		
		for i = 1, #self.ComboTagList.Children do
			self.ComboTagList.Children[i].Enable = false
		end
		
		---@type RecipeComboData
		local comboData = _RecipeTagDataSetLogic.RecipeComboData[comboId]
		
		local effectTarget = comboData.EffectTarget
		---@type RecipeTagData
		local targetTagData = _RecipeTagDataSetLogic.RecipeTagData[effectTarget]
		local targetTagName = _GetLocalizationTextLogic:GetText(targetTagData.TagNameKey)
		
		self.NameText.TextComponent.Text = _GetLocalizationTextLogic:GetText(comboData.NameKey)
		local percent = math.floor(comboData.EffectAmount*100).."%"
		self.DescText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("MenuComboSlotDescText", targetTagName, percent)
		
		local keyTable = {}
		local countTable = {}
		for k, v in pairs(comboData.CountTable) do
			table.insert(keyTable, k)
			countTable[k] = 0
		end
		
		table.sort(keyTable, function(a, b)
			return _RecipeTagDataSetLogic:ReturnRecipeTagSortIndex(a) < _RecipeTagDataSetLogic:ReturnRecipeTagSortIndex(b)
		end)
		
		
		local player = _UserService.LocalPlayer
		if player.PlayerRecipe.ActiveRecipeCombo == comboId then
			self.IsActiveEntity.Enable = true
			self.NameText.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#d98a1a")
			self.DescText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#93640a")
			self.TopBG.SpriteGUIRendererComponent.Color = _ColorCodeEnum:GetColor("#fac629")
			self.TopLine.SpriteGUIRendererComponent.Color = _ColorCodeEnum:GetColor("#d4991d")
		else
			self.IsActiveEntity.Enable = false
			self.NameText.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#919191")
			self.DescText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#737171")
			self.TopBG.SpriteGUIRendererComponent.Color = _ColorCodeEnum:GetColor("#d3d3d3")
			self.TopLine.SpriteGUIRendererComponent.Color = _ColorCodeEnum:GetColor("#acacac")
		end
		
		for i, v in pairs(player.PlayerRecipe.SetRecipes) do
			---@type RecipeData
			local recipeData = player.PlayerRecipe.Recipes[v]
			
			local recipeTag = recipeData.Tag
			for k, v in pairs(countTable) do
				if k == recipeTag then
					countTable[k] = countTable[k] + 1
					break
				end
			end
			
		end
		
		local index = 0
		for i = 1, #keyTable do
			local key = keyTable[i]
			local count = comboData.CountTable[key]
			for j = 1, count do
				index = index + 1
		        local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_RecipeComboTagSlot", index, self.ComboTagList)
				entity.UIRecipeComboTagSlot:Refresh(key, j <= countTable[key])
			end
		end
	end

end