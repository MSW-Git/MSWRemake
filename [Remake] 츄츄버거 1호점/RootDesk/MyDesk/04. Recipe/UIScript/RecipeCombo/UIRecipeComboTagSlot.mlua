@Component
script UIRecipeComboTagSlot extends Component

	@ExecSpace("ClientOnly")
	method void Refresh(string tag, boolean isActive)
		-- 레시피 콤보 태그 슬롯을 새로고침하는 함수
		---@type RecipeTagData
		local tagData = _RecipeTagDataSetLogic.RecipeTagData[tag]
		
		local iconEntity = self.Entity:GetChildByName("Icon")
		iconEntity.SpriteGUIRendererComponent.ImageRUID = tagData.IconRUID
		
		if isActive then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "eb17e4fba2844c71b467cb84b465d5d7"
			iconEntity.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		else
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "a376ea7ad3e04aaab46f07e2630a74ff"
			iconEntity.SpriteGUIRendererComponent:ChangeMaterial(_StringUtilLogic.GrayScaleMaterial)
		end
	end

end