@Component
script UIRecipeListHolder extends Component

	property Entity RecipeList = nil

	property Entity RecipeDetail = nil

	property SyncTable<string, Entity> TopBar

	property SyncTable<string, Entity> ButtonArea

	property integer NowSelected = 0

	property Entity RecipeCountBar = nil

	property string NowKey = ""

	property table NowParams = {}

	property Entity NoRecipeText = nil

	property Entity Line = nil

	property Entity UIPanel = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 레시피 리스트 홀더를 초기화하는 함수
		self.UIPanel = self.Entity:GetChildByName("UIRecipeList")
		
		self.RecipeList = self.UIPanel:GetChildByName("RecipeScroll")
		self.RecipeDetail = self.UIPanel:GetChildByName("Detail")
		self.NoRecipeText = self.UIPanel:GetChildByName("NoRecipeText")
		self.Line = self.UIPanel:GetChildByName("Line")
		
		local keys = {"Recipe", "Trial", "VIPOrder"}
		local topBar = self.UIPanel:GetChildByName("TopBar")
		self.RecipeCountBar = topBar:GetChildByName("RecipeCountBar")
		local buttonArea = self.UIPanel:GetChildByName("ButtonArea")
		
		for i = 1, #keys do
			local key = keys[i]
			local topBarEntity = topBar:GetChildByName(key)
			self.TopBar[key] = topBarEntity
			local buttonAreaEntity = buttonArea:GetChildByName(key)
			self.ButtonArea[key] = buttonAreaEntity
		end
		
		self.Entity.Enable = false
		
		local closeBtn = self.Entity:GetChildByName("CloseBtn")
		closeBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
			self:Close()
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open(integer index, string key, table params)
		-- 레시피 리스트 홀더를 여는 함수
		_UIGroupManager:EnableRecipeSetGroup(true)
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(false)
		
		if _UtilLogic:IsNilorEmptyString(key) == false then
			self.NowKey = key
		end
		self.NowParams = params
		
		self:SetEntitiesEnableByKey(key, params)
		self:RefreshListAndDetail(index, nil)
		
		if key == "Trial" then
			_UserService.LocalPlayer.PlayerTrial:ChangeConnectingStatus(false)
			_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.TrialPrepareEnter)
		elseif key == "Recipe" then
			self.TopBar[key].UIRecipeSetTopBar:SetEnableSortList(false)
		elseif key == "VIPOrder" then
			_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.VIPOrderRecipeListEnter)
		end
		
		_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		
		self._T.isProcessing = true
		_UIEntityService:PlayUIOpenAnim(self.UIPanel, self.UIPanel.UITransformComponent.anchoredPosition, Vector2.up, nil, nil, nil, nil, function()
			self._T.isProcessing = false
		end)
		
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 레시피 리스트 홀더를 닫는 함수
		if self._T.isProcessing == true then
			return
		end
		
		_UIGroupManager:EnableRecipeSetGroup(false)
		_UIEntityLogic_RecipeGroup.UIRecipeBook.UIRecipeBook.NowSlot = 0
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(nil)
		
		self.NowSelected = 0
		self.NowKey = ""
		self.NowParams = {}
		
		_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
	end

	@ExecSpace("ClientOnly")
	method void RefreshListAndDetail(integer index, string sortKey)
		-- 레시피 리스트와 상세 정보를 새로고침하는 함수
		self.RecipeList.UIRecipeList:RefreshListByKey(self.NowKey, self.NowParams, index, sortKey)
		
		self:RefreshRecipeCountBar()
	end

	@ExecSpace("ClientOnly")
	method void RefreshRecipeCountBar()
		-- 레시피 카운트 바를 새로고침하는 함수
		if self.NowKey == "Recipe" then
			self.RecipeCountBar.UITransformComponent.anchoredPosition = Vector2(-157, 18)
		else
			self.RecipeCountBar.UITransformComponent.anchoredPosition = Vector2(-19, 0)
		end
		
		local enable = self.RecipeCountBar.UIRecipeCountBar:Refresh()
		if self.NowKey == "VIPOrder" then
			self.ButtonArea[self.NowKey].UIRecipeSetButtonArea:RefreshMoveToMakeBtnDim(enable)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetEntitiesEnableByKey(string key, table params)
		-- 키에 따라 엔티티들의 활성화 상태를 설정하는 함수
		for k, entity in pairs(self.ButtonArea) do
			if k == key then
				entity.Enable = true
			else
				entity.Enable = false
			end
		end
		
		for k, entity in pairs(self.TopBar) do
			if k == key then
				entity.Enable = true
				entity.UIRecipeSetTopBar:Refresh(params)
			else
				entity.Enable = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshSetButton()
		-- 설정 버튼을 새로고침하는 함수
		self.ButtonArea[self.NowKey].UIRecipeSetButtonArea:RefreshSetButton()
	end

	@ExecSpace("ClientOnly")
	method void SetButtonDim(boolean enable)
		-- 버튼의 비활성화 상태를 설정하는 함수
		if self.NowKey == "VIPOrder" or self.NowKey == "Trial" then
			local selectBtn = self.ButtonArea[self.NowKey]:GetChildByName("SelectButton")
			if isvalid(selectBtn) then
				selectBtn:GetChildByName("Dim").Enable = enable
			end
		end
		
	end

end