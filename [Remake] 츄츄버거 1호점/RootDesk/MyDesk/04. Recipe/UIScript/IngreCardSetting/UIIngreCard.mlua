@Component
script UIIngreCard extends Component

	property integer ingreId = 0

	property Entity IngreCardBtn = nil

	property Entity IngreIconHolder = nil

	property Entity IngreIcon = nil

	property TextComponent NameText = nil

	property TextComponent CountText = nil

	property Entity Property = nil

	property TextComponent PriceText = nil

	property TextComponent TasteScoreText = nil

	property Entity Selected = nil

	property Entity SpicyInfo = nil

	property Entity VIPOrderIcon = nil

	property Entity TouchArea = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 재료 카드 UI 요소들을 초기화하고 클릭 이벤트를 연결하는 함수
		self.IngreCardBtn = self.Entity:GetChildByName("BG")
		
		self.Selected = self.IngreCardBtn:GetChildByName("Selected")
		self.IngreIconHolder = self.IngreCardBtn:GetChildByName("IngreIconHolder")
			self.IngreIcon = self.IngreIconHolder:GetChildByName("IngreIcon")
		
		
		self.NameText = self.IngreCardBtn:GetChildByName("NameText").TextComponent
		self.CountText = self.IngreCardBtn:GetChildByName("CountText").TextComponent
		self.Property = self.IngreCardBtn:GetChildByName("Property")
		
		self.SpicyInfo = self.IngreCardBtn:GetChildByName("SpicyInfo")
		
		local rect = self.IngreCardBtn:GetChildByName("Rect")
		self.PriceText = rect:GetChildByName("PriceText").TextComponent
		self.TasteScoreText = rect:GetChildByName("TasteScoreText").TextComponent
		self.VIPOrderIcon = self.IngreCardBtn:GetChildByName("VIPOrderIcon")
		
		local player = _UserService.LocalPlayer
		self.IngreCardBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			if player.PlayerRecipe.IsServerProcessing then
				return
			end
			
			if _IngredientDataSetLogic:GetIngredientData(self.ingreId) == nil then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
			_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting.AutoSetSelectArea.UIIngreAutoSetSelectArea:Close()
			_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting.FilterSelectArea.UIIngreFilterSelectArea:Close()
			_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting.SortSelectArea.Enable = false
			
			_IngreCardSetLogic:SetIngreCard(self.ingreId, true)
		end)
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer ingreId, integer count)
		-- 재료 카드의 정보를 새로고침하는 함수
		if count == nil then
			count = 0
		end
		
		self.ingreId = ingreId
		if self.IngreCardBtn == nil then
			self:Init()
		end
		
		local ingreData = _IngredientDataSetLogic:GetIngredientData(ingreId)
		local ingreCount = _UserService.LocalPlayer.PlayerIngredient.IngredientCards[ingreId]
		
		local player = _UserService.LocalPlayer
		local isOrderRelated = _VIPOrderDataSetLogic:IsIngreRelatedToOrder(ingreId, _VIPOrderDataSetLogic.UIVIPOrderPreviewNowSlot, player)
		
		self.VIPOrderIcon.Enable = isOrderRelated
		if isOrderRelated then
			self.IngreCardBtn.SpriteGUIRendererComponent:ChangeMaterial("material://75929c89-78d0-49c8-855c-aff5c09300e8")
		else
			self.IngreCardBtn.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		end
		
		if count <= 0 then
			self.Selected.Enable = false
			
			self.CountText.FontColor = _ColorCodeEnum:GetColor("#72634b")
			self.CountText.Text = "x"..tostring(ingreCount)
		else
			self.Selected.Enable = true
			
			self.CountText.FontColor = _ColorCodeEnum:GetColor("#fa5246")
			self.CountText.Text = "x"..tostring(ingreCount - count)
			
		end
		
		local iconRUID = ingreData.IconRUID
		self.IngreIcon.SpriteGUIRendererComponent.ImageRUID = iconRUID
		
		self.IngreIconHolder.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(ingreData.Grade)
		
		local name = _GetLocalizationTextLogic:GetText(ingreData.NameKey)
		self.NameText.Text = name
		
		local balancePoint = ingreData.BalancePoint
		local spicyPoint = ingreData.SpicyPoint
		
		local propertyIndex = 1
		if isvalid(balancePoint) then
			local type = ""
			if balancePoint < 0 then
				self.IngreCardBtn.SpriteGUIRendererComponent.ImageRUID = "429ea5587d4046bfbfda7311954a743f"
				self.NameText.OutlineColor = _ColorCodeEnum:GetColor("#5f6f16")
				type = "light"
			else
				type = "heavy"
				self.IngreCardBtn.SpriteGUIRendererComponent.ImageRUID = "226068cf32474d35b343bda0202df635"
				self.NameText.OutlineColor = _ColorCodeEnum:GetColor("#a17407")
			end
			
			self.Property.UIIngredientProperty:Refresh(type, math.abs(balancePoint))
		end
		
		if isvalid(spicyPoint) then
			self.SpicyInfo.Enable = true
			self.SpicyInfo.TextComponent.Text = "+"..spicyPoint
		else
			self.SpicyInfo.Enable = false
		end
		
		local price = ingreData:GetCost(_UserService.LocalPlayer.PlayerStage.NowStage, _UserService.LocalPlayer)
		self.PriceText.Text = tostring(math.floor(price))
		
		local tasteScore = ingreData:GetTasteScore(_UserService.LocalPlayer.PlayerStage.NowStage, _UserService.LocalPlayer)
		self.TasteScoreText.Text = tostring(math.floor(tasteScore))
		
		local isBuffed = ingreData:IsIngreBuffed(_UserService.LocalPlayer.PlayerStage.NowStage, _UserService.LocalPlayer)
		self.TasteScoreText.FontColor = isBuffed and _ColorCodeEnum:GetColor("#FFE84E") or _ColorCodeEnum:GetColor("#72634b")
		self.TasteScoreText.OutlineColor = isBuffed and _ColorCodeEnum:GetColor("#814514") or _ColorCodeEnum:GetColor("#ffffff")
		self.PriceText.FontColor = isBuffed and _ColorCodeEnum:GetColor("#FFE84E") or _ColorCodeEnum:GetColor("#72634b")
		self.PriceText.OutlineColor = isBuffed and _ColorCodeEnum:GetColor("#814514") or _ColorCodeEnum:GetColor("#ffffff")
	end

	@EventSender("LocalPlayer")
	handler HandleChangedSelectedIngreCardsEvent(ChangedSelectedIngreCardsEvent event)
		-- 선택된 재료 카드 변경 이벤트를 처리하는 핸들러
		local ingreId = event.ingreId
		if self.ingreId == 0 then
			return
		end
		
		if ingreId == -1 then
			ingreId = self.ingreId
		end
		
		if self.ingreId == ingreId then
			self:Refresh(ingreId, _IngreCardSetLogic.SelectedIngreCards[ingreId])
		end
	end

end