@Component
script UIIngredientProperty extends Component

	property SpriteGUIRendererComponent Icon = nil

	property TextComponent Text = nil

	@ExecSpace("ClientOnly")
	method void Refresh(string type, number value)
		-- 재료 속성 정보를 새로고침하는 함수
		if self.Icon == nil then
			self:Init()
		end
		
		self.Icon.ImageRUID = _IngredientDataSetLogic:ReturnPropertyIconRUIDByType(type)
		self.Text.Text = "+"..tostring(math.floor(value))
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 재료 속성 UI 요소들을 초기화하는 함수
		self.Text = self.Entity:GetChildByName("Text").TextComponent
		self.Icon = self.Text.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
	end

end