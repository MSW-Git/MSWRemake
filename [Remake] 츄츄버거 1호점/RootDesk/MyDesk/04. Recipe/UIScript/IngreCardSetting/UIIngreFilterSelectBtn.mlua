@Component
script UIIngreFilterSelectBtn extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 재료 필터 선택 버튼을 초기화하고 클릭 이벤트를 연결하는 함수
		local tag = self.Entity.Name
		
		if tag == _RecipeTagEnum.All then
			_SelectDropDownLogic:SetTextInfo(self.Entity, _GetLocalizationTextLogic:GetText("IngreCardFilterAllText"))
		else
			_SelectDropDownLogic:SetTextInfo(self.Entity, _GetLocalizationTextLogic:GetText("Tag"..tag))
		end
		
		
		---@type RecipeTagData
		local tagData = _RecipeTagDataSetLogic.RecipeTagData[tag]
		local iconEntity = self.Entity:GetChildByName("Icon")
		if isvalid(iconEntity) then
			local iconRUID = tagData.IconRUID
			if _UtilLogic:IsNilorEmptyString(iconRUID) then
				iconRUID = _StringUtilLogic.EmptyRUID
			end
			iconEntity.SpriteGUIRendererComponent.ImageRUID = iconRUID
		end
		
		self.Entity:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting:SetFilter(tag)
		end)
	end

end