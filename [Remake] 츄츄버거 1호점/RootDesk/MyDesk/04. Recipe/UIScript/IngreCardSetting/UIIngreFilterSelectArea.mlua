@Component
script UIIngreFilterSelectArea extends Component

	@ExecSpace("ClientOnly")
	method void Open()
		-- 재료 필터 선택 영역을 여는 함수
		_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting.AutoSetSelectArea.UIIngreAutoSetSelectArea:Close()
		_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting.SortSelectArea.Enable = false
		
		if self.Entity.Enable == true then
			self:Close()
			return
		end
		
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 재료 필터 선택 영역을 닫는 함수
		self.Entity.Enable = false
	end

end