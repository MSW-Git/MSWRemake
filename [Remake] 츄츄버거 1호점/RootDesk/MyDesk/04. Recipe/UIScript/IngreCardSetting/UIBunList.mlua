@Component
script UIBunList extends Component

	property Entity BunList = "57b5bc2c-41e2-4ca5-ac19-71b0627f7217"

	property Entity BunDetail = "6695a2f7-2c94-46a6-bb24-7fe9da32446d"

	property integer NowSelected = 0

	property Entity SetBunBtn = "7f7dd13a-c844-402f-bbc3-f133f91d54b7"

	property Entity UIPanel = "92bd7ecd-179a-427d-a3fb-b6732f9144bc"

	@ExecSpace("ClientOnly")
	method void Open()
		-- 번 선택 UI를 여는 함수
		if self.Entity.Enable == true then
			return
		end
		
		self.Entity.Enable = true
		
		self.NowSelected = _UserService.LocalPlayer.PlayerRecipe.SetBun
		self:RefreshDetail(self.NowSelected)
		self:RefreshList()
		
		_UIGroupManager:EnableBackToLobbyBtn(false)
		
		_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting.BunSelectBtn:GetChildByName("RedDot").Enable = false
		
		self._T.isProcessing = true
		_UIEntityService:PlayUIOpenAnim(self.UIPanel, self.UIPanel.UITransformComponent.anchoredPosition, Vector2.up, nil, nil, nil, nil, function()
			self._T.isProcessing = false
		end)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 번 선택 UI를 닫는 함수
		if self._T.isProcessing == true then
			return
		end
		
		self.Entity.Enable = false
		_UIGroupManager:EnableBackToLobbyBtn(nil)
	end

	@ExecSpace("ClientOnly")
	method void RefreshList()
		-- 번 목록을 새로고침하는 함수
		local bunDatas = _IngredientDataSetLogic.BunData
		local bunKeys = table.keys(bunDatas)
		table.sort(bunKeys, function(a, b) return a < b end)
		
		for i = 1, #bunKeys do
			local key = bunKeys[i]
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_UIBunSelectBtn", key, self.BunList)
			entity.UIBunSelectBtn:Refresh(key, key == self.NowSelected)
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshDetail(integer selected)
		-- 선택된 번의 상세 정보를 새로고침하는 함수
		self.BunDetail.UIBunDetail:Refresh(selected)
		
		if self.NowSelected ~= selected then
			local exSlotEntity = self.BunList:GetChildByName("Model_UIBunSelectBtn"..self.NowSelected)
			exSlotEntity.UIBunSelectBtn:Refresh(self.NowSelected, false)
		end
		
		local slotEntity = self.BunList:GetChildByName("Model_UIBunSelectBtn"..selected)
		if isvalid(slotEntity) then
			slotEntity.UIBunSelectBtn:Refresh(selected, true)
			self.NowSelected = selected
		end
		
		local playerIngre = _UserService.LocalPlayer.PlayerIngredient
		local dim = self.SetBunBtn:GetChildByName("Dim")
		if playerIngre.Buns[self.NowSelected] == nil or playerIngre.Buns[self.NowSelected] <= 0 then
			dim.Enable = true
		else
			dim.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnSetFunction()
		-- 선택된 번을 설정하는 함수
		local playerIngre = _UserService.LocalPlayer.PlayerIngredient
		if playerIngre.Buns[self.NowSelected] == nil or playerIngre.Buns[self.NowSelected] <= 0 then
			_UserService.LocalPlayer.PlayerRecipe:ChangeConnectingStatus(false)
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("BunSetErrorMessage1"))
			return
		end
		
		_UserService.LocalPlayer.PlayerIngredient:RequestSetBun(self.NowSelected)
		self:Close()
		
		_UserService.LocalPlayer.PlayerRecipe:ChangeConnectingStatus(false)
	end

	@EventSender("Entity", "64f4f061-8dc8-4013-98ac-dbe965f5890d")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("Entity", "7f7dd13a-c844-402f-bbc3-f133f91d54b7")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 번 설정 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerRecipe.IsServerProcessing then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		player.PlayerRecipe:ChangeConnectingStatus(true)
		self:OnSetFunction()
	end

	@EventSender("Entity", "65430fa9-9eae-4ee7-9769-87c77cdf1f4a")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 배경 클릭으로 닫기 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

end