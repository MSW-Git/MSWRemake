@Component
script UIVIPOrderScoreExtraReward extends Component

	property Entity BG = "4127f4e1-4c9c-40dc-bccd-cac1c8b00639"

	property SpriteGUIRendererComponent NPC = "825dd36a-6179-4abb-bb85-1f4e3cdf2e76"

	property UIItemRewardSlot ItemSlot = "c94f6e3c-829d-434f-bf38-5880bc709708"

	property TextComponent ResultText = "c218ec9e-b5db-477d-8587-bc15c9b25051"

	property TextComponent InfoText = "381e54e3-6bd0-4d52-bd8b-8d32bc469b12"

	@ExecSpace("ClientOnly")
	method void Open(integer gap)
		-- 추가 보상 팝업을 열고 보상 등급에 따른 애니메이션 시작
		if gap == 0 or gap == nil then
			return
		end
		
		if self.Entity.Enable then
			return
		end
		
		
		local bgSize = self.BG.UITransformComponent.RectSize.x
		self.BG.CanvasGroupComponent.GroupAlpha = 0
		self.BG.UITransformComponent.anchoredPosition = Vector2(bgSize+300, self.BG.UITransformComponent.anchoredPosition.y) 
		
		local resultText = function(a)
			if a == 1 then
				return "GOOD"
			elseif a == 2 then
				return "GREAT"
			else
				return "PERFECT"
			end
		end
		self.ResultText.Text = resultText(gap)
		
		self._T.rewardAmount = math.floor(_GetConfigDataLogic:GetConfigNumDataByKey("VIPOrderScoreExtraReward"..gap))
		self.ItemSlot:SetItem("G0007", self._T.rewardAmount)
		
		self.Entity.Enable = true
		self:StartRender()
	end

	@ExecSpace("ClientOnly")
	method void StartRender()
		-- 보상 팝업의 페이드 인 애니메이션과 점수 드롭 효과 시작
		local bgFadeInDuration = 0.2
		local endTime = 2.3
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_VipOrderBonus"], 1)
		
		_TweenLogic:PlayTween(0, 1, bgFadeInDuration, EaseType.Linear, function(t)
			self.BG.CanvasGroupComponent.GroupAlpha = t
		end)
		local bgPos = self.BG.UITransformComponent.anchoredPosition
		_TweenLogic:PlayTween(bgPos, Vector2(160, bgPos.y), bgFadeInDuration, EaseType.CubicEaseOut, function(t)
			self.BG.UITransformComponent.anchoredPosition = t
		end)
		
		_TimerService:SetTimerOnce(function()
			_VIPOrderResultRenderLogic:DropSeasonScores(self.ItemSlot.Entity, self._T.rewardAmount)
		end, bgFadeInDuration)
		
		_TimerService:SetTimerOnce(function()
			self:EndRender()
		end, endTime)
		
	end

	@ExecSpace("ClientOnly")
	method void EndRender()
		-- 보상 팝업의 페이드 아웃 애니메이션과 정리 작업
		local bgPos = self.BG.UITransformComponent.anchoredPosition
		local bgSize = self.BG.UITransformComponent.RectSize.x
		
		local moveDuration = 0.3
		_TweenLogic:PlayTween(bgPos, Vector2(bgSize+300, bgPos.y), moveDuration, EaseType.CubicEaseOut, function(t)
			self.BG.UITransformComponent.anchoredPosition = t
		end)
		
		_TimerService:SetTimerOnce(function()
			self.Entity.Enable = false
		end, moveDuration)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 팝업을 비활성화 상태로 초기화
		self.Entity.Enable = false
	end

end