@Component
script UIVIPOrderNewSeasonPopup extends Component

	property TextComponent PeriodText = nil

	property SpriteGUIRendererComponent MainTagIcon = nil

	property TextComponent MainTagText = nil

	@ExecSpace("ClientOnly")
	method void Open()
		-- 새 시즌 팝업을 열어서 시즌 정보를 표시
		if self.Entity.Enable then
			return
		end
		
		self.Entity:SetEnable(true)
		_UIGroupManager:EnableBackToLobbyBtn(false)
		self:Refresh()
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Bell"], 1)
		
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- UI 컴포넌트들을 초기화하고 참조를 설정
		local panel = self.Entity:GetChildByName("Panel")
		
		self.PeriodText = panel:GetChildByName("PeriodInfo"):GetChildByName("PeriodText").TextComponent
		local mainTagSlot = panel:GetChildByName("MainTagInfo"):GetChildByName("MainTagSlot")
		self.MainTagIcon = mainTagSlot:GetChildByName("TagIcon").SpriteGUIRendererComponent
		self.MainTagText = mainTagSlot:GetChildByName("TagText").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 현재 시즌의 메인 태그와 기간 정보를 새로고침
		if self.PeriodText == nil then
			self:Init()
		end
		
		local player = _UserService.LocalPlayer
		
		local mainTag = player.PlayerVIPOrder.NowSeasonMainTag
		local tagData = _RecipeTagDataSetLogic:GetRecipeTagData(mainTag)
		self.MainTagIcon.ImageRUID = tagData.IconRUID
		self.MainTagText.Text = string.format("#%s", _GetLocalizationTextLogic:GetText(tagData.TagNameKey))
		
		local nowSeasonStartElapsed = player.PlayerVIPOrder.NowSeasonStartUtcElapsed
		local nowSeasonStartMonth = _VIPOrderDataSetLogic:ReturnFixedStartMonthByStartElapsed(nowSeasonStartElapsed)
		local nowSeasonEndMonth = DateTime(_VIPOrderDataSetLogic:ReturnSeasonEndElapsedByStartElapsed(nowSeasonStartElapsed)).Month - 1
		
		self.PeriodText.Text = string.format("%s ~ %s", _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Month_Format", nowSeasonStartMonth),
			_LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Month_Format", nowSeasonEndMonth))
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 새 시즌 팝업을 닫고 관련 UI 상태를 복원
		self.Entity:SetEnable(false)
		_UIGroupManager:EnableBackToLobbyBtn(nil)
		_VIPOrderDataSetLogic.UIVIPOrderPanel:EndWaitRefresh()
	end

	@EventSender("Entity", "f7e4cb01-fafa-4f0d-b5fb-c4ec929c9045")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 팝업 닫기 버튼 클릭 시 팝업을 닫는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

end