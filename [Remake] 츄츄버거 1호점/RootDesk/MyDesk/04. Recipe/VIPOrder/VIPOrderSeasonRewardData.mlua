@Struct
script VIPOrderSeasonRewardData

	property integer ManagementLevel = 0

	property table SeasonRewardData = {}

	method void Load(integer managementLevel, table rows)
		-- 관리 레벨과 CSV 행 데이터를 기반으로 시즌 보상 데이터를 로드
		self.ManagementLevel = managementLevel
		
		for i, row in pairs(rows) do
			local orderCount = math.floor(tonumber(row:GetItem("OrderCount")))
			local itemData = _UtilLogic:Split(row:GetItem("ItemData"), ",")
			local reward = {}
			for j = 1, #itemData, 2 do
				local itemId = itemData[j]
				local itemCount = tonumber(itemData[j+1])
				reward[itemId] = itemCount
			end
			
			self.SeasonRewardData[orderCount] = reward
		end
	end

end