@Component
script UIVIPOrderPreviewSlot extends Component

	property Entity Pin = nil

	property Entity RequirementsList = nil

	property integer OrderIndex = 0

	@ExecSpace("ClientOnly")
	method void Init()
		-- 미리보기 슬롯의 UI 컴포넌트들을 초기화
		self.Pin = self.Entity:GetChildByName("Pin")
		self.RequirementsList = self.Entity:GetChildByName("RequirementsList")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer orderIndex, boolean isPinned)
		-- 주문 인덱스와 고정 상태에 따라 슬롯을 새로고침
		if self.Pin == nil then
			self:Init()
		end
		
		self.OrderIndex = orderIndex
		if orderIndex == 0 or orderIndex == nil then
			self.Pin.Enable = false
			self.RequirementsList.Enable = false
			return
		end
		
		self.RequirementsList.Enable = true
		self.Pin.Enable = isPinned
		
		local reqIndex = 0
		
		local player = _UserService.LocalPlayer
		local slotData = player.PlayerVIPOrder.VIPOrderSlotData[orderIndex]
		local requirements = _VIPOrderDataSetLogic:ReturnRequirementDatasTableForUI(slotData)
		
		for i = 1, #requirements do
			local reqEntity = _UIEntityService:GetOrCreateEntityOfModel("Model_VIPOrderPreviewRequirement", i, self.RequirementsList)
			_VIPOrderDataSetLogic:RefreshRequirementSlotIcon(requirements[i][1], requirements[i][2], reqEntity, reqEntity:GetChildByName("Icon"), false, nil)
		end
	end

end