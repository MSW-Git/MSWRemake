@Struct
script VIPOrderRecipeRewardData

	property integer ManagementLevel = 0

	property integer StandardRewardHeart = 0

	property integer RecommendedIngreGrade = 0

	property table RewardGrades = {}

	method void Load(any dataTable, integer index)
		-- CSV 데이터에서 레시피 보상 정보를 로드하고 파싱
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.ManagementLevel = tonumber(row:GetItem("ManagementLevel"))
		self.StandardRewardHeart = tonumber(row:GetItem("StandardRewardHeart"))
		self.RecommendedIngreGrade = tonumber(row:GetItem("RecommendedIngreGrade"))
		
		for i = 1, 5 do
			local rewardGradePool = row:GetItem(string.format("RewardGrade%dTasteGrade", i))
			
			if _UtilLogic:IsNilorEmptyString(rewardGradePool) then
				continue
			end
			local gradePool = _UtilLogic:Split(rewardGradePool, ",")
			
			local numberPool = {}
			for j = 1, #gradePool do
				table.insert(numberPool, tonumber(gradePool[j]))
			end
			
			self.RewardGrades[i] = numberPool
		end
	end

	method integer ReturnRewardGradeByTasteGrade(integer tasteGrade)
		-- 맛 등급에 해당하는 보상 등급을 찾아서 반환
		for key, pool in pairs(self.RewardGrades) do
			for i = 1, #pool do
				local poolGrade = pool[i]
				if tasteGrade == poolGrade then
					return key
				end
			end
		end
		
		return 0
	end

end