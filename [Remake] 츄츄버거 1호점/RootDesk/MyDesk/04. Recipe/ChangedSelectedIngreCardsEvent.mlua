@Event
script ChangedSelectedIngreCardsEvent extends EventType

	property integer ingreId = 0

	property boolean refreshBalance = false

	method void Init(integer ingreId, boolean refreshBalance)
		-- 선택된 재료 카드 변경 이벤트를 초기화하는 함수
		self.ingreId = ingreId
		self.refreshBalance = refreshBalance
	end

end