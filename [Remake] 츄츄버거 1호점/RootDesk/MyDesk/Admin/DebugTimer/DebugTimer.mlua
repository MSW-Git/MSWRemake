@Component
script DebugTimer extends Component

	property TextComponent TimeText = "582a47ad-ea65-42cc-bde4-971e4fbc9489"

	property TextComponent GameTimeText = "7ec26aaa-b90f-41c8-b9d8-a8029602eea6"

	property boolean isRunning = false

	property boolean isPaused = false

	property number elapsedTime = 0

	property Entity ToggleStart = "66c09d09-9a1c-4716-8c00-8e4591c45b52"

	property Entity SimmpleToggleButton = "875dc08b-0acc-4869-acfe-cc5ff63ab55e"

	property Entity MainTimer = "8f366ff8-dbd5-4e53-b730-a65d2640625a"

	property Entity SimpleTimer = "d28749e8-c593-4150-acc6-18cbfae164e5"

	property table records = {}

	property table recordEntity = {}

	property Entity RecordsUI = "004d6459-19b1-4189-9aac-631efcaf2027"

	property integer recordNum = 1

	property Entity ReservationPanel = "09f5c5cd-60f2-497c-9c14-78affb53f6f8"

	property boolean isReserved = false

	property integer reservedTime = 0

	property Entity ReserveButton = "c8287df1-d91a-409e-9ec6-73d30ff5bf1a"

	property boolean isOpenReservUI = false

	property boolean useIngameTime = false

	property Entity InGameTime = "2db7990e-cd90-4c92-a4bd-75f58134b8a4"

	property TextComponent SimpleTimeText = nil

	property integer gameDay = 0

	property integer gameMonth = 0

	property integer gameYear = 0

	property string reservePeriod = ""

	property table month31day = {}

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 타이머가 실행 중일 때 경과 시간을 업데이트
		if self.isRunning and not self.isPaused then
			self.elapsedTime = self.elapsedTime + delta
			self:UpdateUI()
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateUI()
		-- 타이머 UI를 업데이트하고 예약된 시간에 도달하면 자동 정지
		local totalSeconds = math.floor(self.elapsedTime)
		local milliseconds = math.floor((self.elapsedTime - totalSeconds) * 100)
		local hours = math.floor(totalSeconds / 3600)
		local minutes = math.floor((totalSeconds % 3600) / 60)
		local seconds = totalSeconds % 60
		
		local formattedTime = string.format("%02d:%02d:%02d.%02d", hours, minutes, seconds, milliseconds)
		if self.TimeText then
			self.TimeText.Text = formattedTime
		end
		if self.SimpleTimeText then
			self.SimpleTimeText.Text = formattedTime
		end
		
		
		local formattedGameTime = string.format("%d년차 %d월 %d일", self.gameYear,self.gameMonth,self.gameDay)
		
		if self.GameTimeText then
			self.GameTimeText.Text = formattedGameTime
		end
		
		
		if self.isReserved then
			if self.reservePeriod =="Month" then
				if self.gameDay == self.reservedTime then
					self:ToggleStartPuase()
					self.isReserved = false
					self.ReserveButton.SpriteGUIRendererComponent.Color = Color.white
					self.ReserveButton.TextComponent.Text = "예약"
				end	
			elseif self.reservePeriod == "Year" then
				if self.gameYear == self.reservedTime then
					self:ToggleStartPuase()
					self.isReserved = false
					self.ReserveButton.SpriteGUIRendererComponent.Color = Color.white
					self.ReserveButton.TextComponent.Text = "예약"
				end	
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void ToggleStartPuase()
		-- 타이머 시작/정지 상태를 토글하고 게임 내 시간 흐름을 제어
		local startIcon = "98484878393c4badb46df810da44c660"
		local pauseIcon = "f7f90d336de74a42b9fa35b6c6c9fa27"
		
		if not self.isRunning then
			self.isRunning = true
			self.ToggleStart.TextComponent.Text = "정지"
			self.SimmpleToggleButton.TextComponent.Text = "정지"
			self:TimeFlow(true)
		else
			self.isRunning = false
			self.ToggleStart.TextComponent.Text = "시작"
			self.SimmpleToggleButton.TextComponent.Text = "시작"
			self:TimeFlow(false)
		end
	end

	method void TimerReset()
		-- 타이머를 초기화하고 모든 기록과 예약을 리셋
		self.isRunning = false
		self.isPaused = false
		self.elapsedTime = 0
		
		self.reservedTime = 0
		self.isReserved = false
		self.ReserveButton.SpriteGUIRendererComponent.Color = Color.white
		self.ReserveButton.TextComponent.Text = "예약"
		
		self.ToggleStart.TextComponent.Text = "시작"
		local startIcon = "98484878393c4badb46df810da44c660"
		self.SimmpleToggleButton.TextComponent.Text = "시작"
		
		self.recordNum = 1 
		for i = 1, #self.recordEntity do 
			self.recordEntity[i]:Destroy()
		end
		
		self:UpdateUI() 
	end

	method void TimeRecord()
		-- 현재 시간을 기록하고 UI에 새로운 기록 항목을 추가
		local totalSeconds = math.floor(self.elapsedTime)
		local milliseconds = math.floor((self.elapsedTime - totalSeconds) * 100)
		local hours = math.floor(totalSeconds / 3600)
		local minutes = math.floor((totalSeconds % 3600) / 60)
		local seconds = totalSeconds % 60
		
		local formattedTime = string.format("%02d:%02d:%02d.%02d", hours, minutes, seconds, milliseconds)
		local formattedGameTime = string.format("%d년차 %d월 %d일", self.gameYear,self.gameMonth,self.gameDay)
		
		if self.RecordsUI then
			local newRecordText = _SpawnService:SpawnByModelId("model://0e721b1c-f05a-43ad-983e-db3f02137f44", "record" , Vector3.zero, self.RecordsUI)
			
			if self.useIngameTime then
				newRecordText.TextComponent.Text = self.recordNum ..". ".. formattedTime .."/ " .. formattedGameTime 
			else
				newRecordText.TextComponent.Text = self.recordNum ..". ".. formattedTime
			end
			self.recordNum += 1
			table.insert(self.recordEntity, newRecordText)
		end
		
		
	end

	method void Reserve(string Period)
		-- 지정된 기간에 따라 타이머 자동 정지를 예약 설정
		local lastTime = 0
		
		if Period == "Month" then
			lastTime = self.gameMonth
			self.isReserved = true
			self.reservePeriod = "Month"
			if lastTime ==2 then
				self.reservedTime = 28
			elseif self.month31day[lastTime] then
				self.reservedTime = 31		
			else
				self.reservedTime = 30
			end
			self.ReserveButton.SpriteGUIRendererComponent.Color = Color.yellow
			self.ReserveButton.TextComponent.Text = "예약됨"
		elseif	Period == "Quarter" then
			lastTime = self.gameMonth
			self.reservePeriod = "Month"
			self.isReserved = true
			if lastTime + 3 < 12 then
				self.reservedTime = lastTime + 3
			else
				self.reservedTime = lastTime + 3 - 12
			end
			self.ReserveButton.SpriteGUIRendererComponent.Color = Color.yellow
			self.ReserveButton.TextComponent.Text = "예약됨"
		elseif	Period == "HalfYear" then
			lastTime = self.gameMonth
			self.reservePeriod = "Month"
			self.reservedTime = 6
			self.isReserved = true
			if lastTime + 3 < 12 then
				self.reservedTime = lastTime + 3
			else
				self.reservedTime = lastTime + 3 - 12
			end
			self.ReserveButton.SpriteGUIRendererComponent.Color = Color.yellow
			self.ReserveButton.TextComponent.Text = "예약됨"
		elseif Period == "Year" then
			lastTime = self.gameYear
			self.reservePeriod = "Year"
			self.reservedTime = lastTime + 1
			self.ReserveButton.SpriteGUIRendererComponent.Color = Color.yellow
			self.ReserveButton.TextComponent.Text = "예약됨"
		else 
			self.reservedTime = 0
			self.isReserved = false
			self.ReserveButton.SpriteGUIRendererComponent.Color = Color.white
			self.ReserveButton.TextComponent.Text = "예약"
		end
		
	end

	method void Init()
		-- 디버그 타이머 UI와 예약 버튼들을 초기화
		
		if self.useIngameTime then
			self.InGameTime:SetEnable(true)
		else
			self.InGameTime:SetEnable(false)
			self.MainTimer:GetChildByName("Time").UITransformComponent.Position = Vector3(70, 70, 0)
		end 
		
		local Month = _SpawnService:SpawnByModelId("model://70eb54ab-5f9f-4db5-b34a-703ad711690d", "Month", Vector3(0,300,0), self.ReservationPanel)
		Month.TextComponent.Text = "한달"
		local Quarter = _SpawnService:SpawnByModelId("model://70eb54ab-5f9f-4db5-b34a-703ad711690d", "Quarter", Vector3(0,150,0), self.ReservationPanel)
		Quarter.TextComponent.Text = "분기"
		local HalfYear = _SpawnService:SpawnByModelId("model://70eb54ab-5f9f-4db5-b34a-703ad711690d", "HalfYear", Vector3(0,0,0), self.ReservationPanel)
		HalfYear.TextComponent.Text = "반년"
		local Year = _SpawnService:SpawnByModelId("model://70eb54ab-5f9f-4db5-b34a-703ad711690d", "Year", Vector3(0,-150,0), self.ReservationPanel)
		Year.TextComponent.Text = "일년"
		local Cancel = _SpawnService:SpawnByModelId("model://70eb54ab-5f9f-4db5-b34a-703ad711690d", "Cancel", Vector3(0,-300,0), self.ReservationPanel)
		Cancel.TextComponent.Text = "취소"
		
		self.Entity:SetEnable(true)
		self:UpdateUI()
	end

	method void TimeFlow(boolean bool)
		-- 게임 내 시간 흐름을 제어
		_UserService.LocalPlayer.TimeManager:debugTimeFlow(bool)
	end

	method void UpdateTime(integer day, integer month, integer year)
		-- 게임 내 날짜 정보를 업데이트
		self.gameDay = day
		self.gameMonth = month
		self.gameYear = year
		
		self:UpdateUI()
	end

	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI 요소들을 찾아서 연결하고 31일 달 정보를 설정
		self.MainTimer = self.Entity:GetChildByName("MainTimer")
		self.SimpleTimer = self.Entity:GetChildByName("SimpleTimer")
		
		self.TimeText = self.MainTimer:GetChildByName("Time").TextComponent
		self.ToggleStart = self.MainTimer:GetChildByName("StartButton")
		self.SimmpleToggleButton = self.SimpleTimer:GetChildByName("StartButton")
		self.RecordsUI = self.MainTimer:GetChildByName("Records")
		self.ReservationPanel = self.MainTimer:GetChildByName("ReservationPanel")
		self.ReserveButton = self.MainTimer:GetChildByName("ReserveButton")
		self.InGameTime = self.MainTimer:GetChildByName("InGametime")
		self.SimpleTimeText = self.SimpleTimer:GetChildByName("Time").TextComponent
		self.GameTimeText = self.InGameTime.TextComponent
		
		
		self.month31day[1] = true
		self.month31day[3] = true
		self.month31day[5] = true
		self.month31day[7] = true
		self.month31day[8] = true
		self.month31day[10] = true
		self.month31day[12] = true
	end

	@EventSender("Entity", "620242f2-259d-4c4a-915b-43cd232773ae")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 메인 타이머의 시작/정지 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		self:ToggleStartPuase()
		
	end

	@EventSender("Entity", "0e7d0f8c-6c61-4b3f-b4c4-bbff1a4edcc8")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 간단한 타이머의 시작/정지 버튼 클릭 이벤트 처리
		
		self:ToggleStartPuase()
	end

	@EventSender("Entity", "68ed4ef0-03d8-43d8-8e14-a010bf650fd4")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 타이머 리셋 버튼 클릭 이벤트 처리
		
		self:TimerReset()
	end

	@EventSender("Entity", "d1af1cdb-1f23-4bca-bea7-7e59de4e688b")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 메인 타이머의 시간 기록 버튼 클릭 이벤트 처리
		
		self:TimeRecord()
	end

	@EventSender("Entity", "70fd09b0-2cc5-47a6-8737-7e2c53ddf3ac")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 간단한 타이머의 시간 기록 버튼 클릭 이벤트 처리
		
		self:TimeRecord()
	end

	@EventSender("Entity", "981f0688-91cd-41bd-8fa6-2f1d563202a5")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 간단한 타이머 모드로 전환하는 버튼 클릭 이벤트 처리
		
		self.MainTimer:SetEnable(false)
		self.SimpleTimer:SetEnable(true)
	end

	@EventSender("Entity", "e9801bf9-e5a4-4238-8eb2-0101eb82bf72")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 메인 타이머 모드로 전환하는 버튼 클릭 이벤트 처리
		
		self.SimpleTimer:SetEnable(false)
		self.MainTimer:SetEnable(true)
		
	end

	@EventSender("Entity", "07103aa2-0668-4fb7-95cd-f3b79ddc67db")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 예약 UI 패널을 토글하는 버튼 클릭 이벤트 처리
		
		if self.isOpenReservUI then 
			self.ReservationPanel:SetEnable(false)
			self.isOpenReservUI = false
		else
			self.ReservationPanel:SetEnable(true)
			self.isOpenReservUI = true
		end
		
	end

	@EventSender("Model", "70eb54ab-5f9f-4db5-b34a-703ad711690d")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 예약 기간 선택 버튼들의 클릭 이벤트 처리
		
		local Entity = event.Entity
		local name = Entity.Name
		self:Reserve(name)
		Entity.Parent:SetEnable(false)
	end

end