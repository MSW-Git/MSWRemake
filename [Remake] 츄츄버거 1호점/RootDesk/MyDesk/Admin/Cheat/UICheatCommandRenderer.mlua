@Component
script UICheatCommandRenderer extends Component

	property TextComponentRef CommandText = nil

	property TextComponentRef CommandDescText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 치트 명령어 렌더러 UI 요소들을 초기화
		self.CommandText = self.Entity:GetChildByName("CommandText").TextComponent
		self.CommandDescText = self.Entity:GetChildByName("DetailText").TextComponent
	end

	method void Set(string command, string desc)
		-- 명령어와 설명을 UI에 설정
		self.CommandText.Text = command
		self.CommandDescText.Text = desc
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 명령어 렌더러 버튼 클릭 시 명령어를 입력 필드에 설정
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local scrollLaypout = self.Entity.Parent
		local downPanel = scrollLaypout.Parent
		local cheatPanel = downPanel.Parent
		
		cheatPanel.UICheat:SetCommand(self.CommandText.Text)
	end

end