@Logic
script CheatPresetDataLogic extends Logic

	property table TestKeyTable = {}

	property table CheatPresetUpgradeTypeEnum = {}

	property table CheatPresetData = {}

	property table CheatPresetUpgrade = {}

	property table CheatPresetEmployee = {}

	property table CheatPresetUpgradeTypeIds = {}

	property integer UpgradeTypeCount = 21

	@ExecSpace("ServerOnly")
	method void Load()
		-- 치트 프리셋 데이터를 로드하는 함수
		table.clear(self.TestKeyTable)
		table.clear(self.CheatPresetData)
		table.clear(self.CheatPresetUpgrade)
		table.clear(self.CheatPresetEmployee)
		table.clear(self.CheatPresetUpgradeTypeEnum)
		table.clear(self.CheatPresetUpgradeTypeIds)
		
		
		local desc = "Desc"
		
		local managementLv = "ManagementLv"
		local earningLevel = "EarningLevel"
		local reputation0 = "Reputation0"
		local reputation1 = "Reputation1"
		local reputation2 = "Reputation2"
		
		local employeeTestKey = "EmployeeTestKey" 		
		local needEmployeeCount = "NeedEmployeeCount"	
		
		local cookEmployeeLevel0 = "CookEmployeeLevel0"
		local servingEmployeeLevel0 = "ServingEmployeeLevel0"
		local cookEmployeeLevel1 = "CookEmployeeLevel1"
		local servingEmployeeLevel1 = "ServingEmployeeLevel1"
		local cookEmployeeLevel2 = "CookEmployeeLevel2"
		local servingEmployeeLevel2 = "ServingEmployeeLevel2"
		local equipLevel0 = "EquipLevel0"
		local equipLevel1 = "EquipLevel1"
		local equipLevel2 = "EquipLevel2"
		local recipeKeyStart = "RecipeKeyStart"
		local recipeKeyEnd = "RecipeKeyEnd"
		
		local diamond = "Diamond"
		local clover = "Clover"
		local heart = "Heart"
		local medal = "Medal"
		local exp = "Exp"
		local B0001 = "B0001"
		local B0002 = "B0002"
		local B0003 = "B0003"
		local B0004 = "B0004"
		
		
		local dataSet = _DataService:GetTable("CheatPresetTestKey")
		for i = 1 , dataSet:GetRowCount() do	
			local testKey = dataSet:GetCell( i , "TestKey")
			table.insert( self.TestKeyTable, tonumber(testKey) )
			
			local dataRow = dataSet:FindRow("TestKey" , testKey)
			
			local testKeyInfo = {}
			testKeyInfo[desc] = dataRow:GetItem(desc)
			testKeyInfo[managementLv] = tonumber( dataRow:GetItem(managementLv) )
			testKeyInfo[earningLevel] = tonumber( dataRow:GetItem(earningLevel) )
			
			testKeyInfo[reputation0] = tonumber( dataRow:GetItem(reputation0) )
			testKeyInfo[reputation1] = tonumber( dataRow:GetItem(reputation1) )
			testKeyInfo[reputation2] = tonumber( dataRow:GetItem(reputation2) )
			
			testKeyInfo[employeeTestKey] = tonumber( dataRow:GetItem(employeeTestKey) )
			testKeyInfo[needEmployeeCount] = tonumber( dataRow:GetItem(needEmployeeCount) )
			
			
			testKeyInfo[cookEmployeeLevel0] = tonumber( dataRow:GetItem(cookEmployeeLevel0) )
			testKeyInfo[servingEmployeeLevel0] = tonumber( dataRow:GetItem(servingEmployeeLevel0) )
			
			testKeyInfo[cookEmployeeLevel1] = tonumber( dataRow:GetItem(cookEmployeeLevel1) )
			testKeyInfo[servingEmployeeLevel1] = tonumber( dataRow:GetItem(servingEmployeeLevel1) )
			
			testKeyInfo[cookEmployeeLevel2] = tonumber( dataRow:GetItem(cookEmployeeLevel2) )
			testKeyInfo[servingEmployeeLevel2] = tonumber( dataRow:GetItem(servingEmployeeLevel2) )
			
			testKeyInfo[equipLevel0] = tonumber( dataRow:GetItem(equipLevel0) )
			testKeyInfo[equipLevel1] = tonumber( dataRow:GetItem(equipLevel1) )
			testKeyInfo[equipLevel2] = tonumber( dataRow:GetItem(equipLevel2) )
			
			testKeyInfo[recipeKeyStart] = tonumber( dataRow:GetItem(recipeKeyStart) )
			testKeyInfo[recipeKeyEnd] = tonumber( dataRow:GetItem(recipeKeyEnd) )
			
			testKeyInfo[diamond] = tonumber( dataRow:GetItem(diamond) )
			testKeyInfo[clover] = tonumber( dataRow:GetItem(clover) )
			testKeyInfo[heart] = tonumber( dataRow:GetItem(heart) )
			testKeyInfo[medal] = tonumber( dataRow:GetItem(medal) )
			testKeyInfo[exp] = tonumber( dataRow:GetItem(exp) )
			
			testKeyInfo[B0001] = tonumber( dataRow:GetItem(B0001) )
			testKeyInfo[B0002] = tonumber( dataRow:GetItem(B0002) )
			testKeyInfo[B0003] = tonumber( dataRow:GetItem(B0003) )
			testKeyInfo[B0004] = tonumber( dataRow:GetItem(B0004) )
			
			self.CheatPresetData[tonumber(testKey)] = testKeyInfo
		end
		
		table.clear(self.CheatPresetUpgradeTypeEnum)
		
		self.CheatPresetUpgradeTypeEnum[1] = "ExpansionStep"
		self.CheatPresetUpgradeTypeEnum[2] = "InteriorLevel"
		self.CheatPresetUpgradeTypeEnum[3] = "StoreDeco"
		self.CheatPresetUpgradeTypeEnum[4] = "TipStorageLevel"
		self.CheatPresetUpgradeTypeEnum[5] = "GrillCount"
		self.CheatPresetUpgradeTypeEnum[6] = "DisplayCount"
		self.CheatPresetUpgradeTypeEnum[7] = "CounterCount"
		self.CheatPresetUpgradeTypeEnum[8] = "DisplayResearch"
		self.CheatPresetUpgradeTypeEnum[9] = "GrillLevel"
		self.CheatPresetUpgradeTypeEnum[10] = "DisplaystandLevel"
		self.CheatPresetUpgradeTypeEnum[11] = "CounterLevel"
		self.CheatPresetUpgradeTypeEnum[12] = "TrainingUpgrade"
		self.CheatPresetUpgradeTypeEnum[13] = "TrainingIngreBox"
		self.CheatPresetUpgradeTypeEnum[14] = "TrainingBreadBoxOpen"
		self.CheatPresetUpgradeTypeEnum[15] = "LunchBoxGainSpeed"
		self.CheatPresetUpgradeTypeEnum[16] = "LunchBoxCapacity"
		self.CheatPresetUpgradeTypeEnum[17] = "AutoTrainingOpen"
		self.CheatPresetUpgradeTypeEnum[18] = "BurgerStack"
		self.CheatPresetUpgradeTypeEnum[19] = "RecipeRerollCount"
		self.CheatPresetUpgradeTypeEnum[20] = "RecipeBoxCount"
		self.CheatPresetUpgradeTypeEnum[21] = "VIPOrderCount"
		
		dataSet = _DataService:GetTable("CheatPresetUpgrade")
		for i = 1 , dataSet:GetRowCount() do
			local dataRow = dataSet:FindRow("TestKey" , tostring(self.TestKeyTable[i]) )
			
			local testKeyInfo = {}
			testKeyInfo[desc] = dataRow:GetItem(desc)
			
			for j = 1 , self.UpgradeTypeCount do
				local upgradeTypeEnum = self.CheatPresetUpgradeTypeEnum[j]
				testKeyInfo[upgradeTypeEnum] = tonumber( dataRow:GetItem(upgradeTypeEnum) )
			end
			
			self.CheatPresetUpgrade[self.TestKeyTable[i]] = testKeyInfo
		end
		
		self.CheatPresetUpgradeTypeIds["ExpansionStep"] = tostring(_UpgradeTypeEnum.ExpansionStep)
		self.CheatPresetUpgradeTypeIds["InteriorLevel"] =  tostring(_UpgradeTypeEnum.InteriorLevel)
		self.CheatPresetUpgradeTypeIds["StoreDeco"] =  tostring(_UpgradeTypeEnum.StoreDeco)
		self.CheatPresetUpgradeTypeIds["TipStorageLevel"] = tostring(_UpgradeTypeEnum.TipStorageLevel)
		self.CheatPresetUpgradeTypeIds["GrillCount"] = tostring(_UpgradeTypeEnum.GrillCount)
		self.CheatPresetUpgradeTypeIds["DisplayCount"] = tostring(_UpgradeTypeEnum.DisplayCount)
		self.CheatPresetUpgradeTypeIds["CounterCount"] = tostring(_UpgradeTypeEnum.CounterCount)
		self.CheatPresetUpgradeTypeIds["DisplayResearch"] = tostring(_UpgradeTypeEnum.DisplayResearch)
		self.CheatPresetUpgradeTypeIds["GrillLevel"] = tostring(_UpgradeTypeEnum.GrillLevel)
		self.CheatPresetUpgradeTypeIds["DisplaystandLevel"] = tostring(_UpgradeTypeEnum.DisplaystandLevel)
		self.CheatPresetUpgradeTypeIds["CounterLevel"] = tostring(_UpgradeTypeEnum.CounterLevel)
		self.CheatPresetUpgradeTypeIds["TrainingUpgrade"] = tostring(_UpgradeTypeEnum.TrainingUpgrade)
		self.CheatPresetUpgradeTypeIds["TrainingIngreBox"] = tostring(_UpgradeTypeEnum.TrainingIngreBox)
		self.CheatPresetUpgradeTypeIds["TrainingBreadBoxOpen"] = tostring(_UpgradeTypeEnum.TrainingBreadBoxOpen)
		self.CheatPresetUpgradeTypeIds["LunchBoxGainSpeed"] = tostring(_UpgradeTypeEnum.LunchBoxGainSpeed)
		self.CheatPresetUpgradeTypeIds["LunchBoxCapacity"] = tostring(_UpgradeTypeEnum.LunchBoxCapacity)
		self.CheatPresetUpgradeTypeIds["AutoTrainingOpen"] = tostring(_UpgradeTypeEnum.AutoTrainingOpen)
		self.CheatPresetUpgradeTypeIds["BurgerStack"] = tostring(_UpgradeTypeEnum.BurgerStack)
		self.CheatPresetUpgradeTypeIds["RecipeRerollCount"] = tostring(_UpgradeTypeEnum.RecipeRerollCount)
		self.CheatPresetUpgradeTypeIds["RecipeBoxCount"] = tostring(_UpgradeTypeEnum.RecipeBoxCount)
		self.CheatPresetUpgradeTypeIds["VIPOrderCount"] = tostring(_UpgradeTypeEnum.VIPOrderCount)
		
		
		dataSet = _DataService:GetTable("CheatPresetEmployee")
		
		local employeeTestGroup1 = {}
		local employeeTestGroup2 = {}
		local employeeTestGroup3 = {}
		local employeeTestGroup4 = {}
		local employeeTestGroup5 = {}
		local employeeTestGroup6 = {}
		local employeeTestGroup7 = {}
		local employeeTestGroup8 = {}
		local employeeTestGroup9 = {}
		
		for i = 1 , dataSet:GetRowCount() do	
			local employeeId = dataSet:GetCell( i , "EmployeeId")
			local testKey = tonumber( dataSet:GetCell( i , "TestKey") ) 
			
			if testKey == 1 then
				table.insert ( employeeTestGroup1 , employeeId )
			elseif testKey == 2 then	
				table.insert ( employeeTestGroup2 , employeeId )
			elseif testKey == 3 then	
				table.insert ( employeeTestGroup3 , employeeId )
			elseif testKey == 4 then	
				table.insert ( employeeTestGroup4 , employeeId )
			elseif testKey == 5 then	
				table.insert ( employeeTestGroup5 , employeeId )
			elseif testKey == 6 then	
				table.insert ( employeeTestGroup6 , employeeId )
			elseif testKey == 7 then	
				table.insert ( employeeTestGroup7 , employeeId )
			elseif testKey == 8then	
				table.insert ( employeeTestGroup8 , employeeId )
			elseif testKey == 9 then	
				table.insert ( employeeTestGroup9 , employeeId )
			end
		end
		
		self.CheatPresetEmployee[1] = employeeTestGroup1
		self.CheatPresetEmployee[2] = employeeTestGroup2
		self.CheatPresetEmployee[3] = employeeTestGroup3
		self.CheatPresetEmployee[4] = employeeTestGroup4
		self.CheatPresetEmployee[5] = employeeTestGroup5
		self.CheatPresetEmployee[6] = employeeTestGroup6
		self.CheatPresetEmployee[7] = employeeTestGroup7
		self.CheatPresetEmployee[8] = employeeTestGroup8
		self.CheatPresetEmployee[9] = employeeTestGroup9
		
	end

	@ExecSpace("ServerOnly")
	method table GetCheatPresetData(integer testKey)
		-- 테스트 키로 치트 프리셋 데이터를 가져오는 함수
		return self.CheatPresetData[testKey]
	end

	@ExecSpace("ServerOnly")
	method table GetCheatPresetUpgrade(integer testKey)
		-- 테스트 키로 치트 프리셋 업그레이드 데이터를 가져오는 함수
		return self.CheatPresetUpgrade[testKey]
	end

	@ExecSpace("ServerOnly")
	method table GetCheatPresetEmployees(integer testKey)
		-- 테스트 키로 치트 프리셋 직원 데이터를 가져오는 함수
		
		local firstKey = string.sub( tostring(testKey) , 1 , 1)
		return self.CheatPresetEmployee[tonumber(firstKey)]
		
		
	end

	@ExecSpace("ServerOnly")
	method string GetManagementLv(integer testKey)
		-- 테스트 키로 관리 레벨을 가져오는 함수
		local info = self.CheatPresetData[testKey]
		
		return tostring ( info["ManagementLv"] )
		
	end

	method string GetUpgradeTypeId(string typeEnum)
		-- 타입 열거형으로 업그레이드 타입 ID를 가져오는 함수
		
		return self.CheatPresetUpgradeTypeIds[typeEnum]
	end

end