@Component
script UICheat extends Component

	property TextComponentRef CommandText = nil

	property EntityRef CommandEntity = nil

	property EntityRef ScollLayOutEntity = nil

	method void FindCommand(string command)
		-- 입력된 명령어와 매칭되는 치트 명령어들을 찾아 표시
		self:ClearCommandRenderer()
		if command == nil then
			return
		end
		
		local playerCheat = _UserService.LocalPlayer.PlayerCheatComponent
		local commandLower = string.lower(command)
		
		local foundList = {}
		for k,v in pairs(playerCheat.commandToDesc) do
			local keyLower = string.lower(k)
			local startIndex, endIndex = string.find(keyLower, commandLower)
			if startIndex then
				foundList[k] = v
			end
		end
		
		
		local index = 1
		self.CommandText.Text = ""
		for k,v in pairs(foundList) do
			local rendererEntity = self:GetOrCreateCommandRenderer(index)
			local rendererComponent = rendererEntity.UICheatCommandRenderer
			rendererComponent:Set(k, v)
			index += 1
			if commandLower == string.lower(k) then
				self.CommandText.Text = v
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 치트 UI 초기화 및 이벤트 연결
		self.ScollLayOutEntity = self.Entity:GetChildByName("Scroll_Layout", true)
		
		self.CommandText = self.Entity:GetChildByName("CommandDesc", true).TextComponent
		self.CommandEntity = self.Entity:GetChildByName("Command", true)
		self.CommandEntity:ConnectEvent(TextInputValueChangeEvent, self.OnTextInputValueChanged)
		self.CommandEntity:ConnectEvent(TextInputSubmitEvent, self.OnTextInputSumit)
	end

	method void OnTextInputValueChanged(TextInputValueChangeEvent event)
		-- 텍스트 입력이 변경될 때 명령어 검색 수행
		local text = event.text
		local command = text:match("(%S+)") 
		self:FindCommand(command)
	end

	method void OnTextInputSumit(TextInputSubmitEvent event)
		-- 엔터 키를 눌렀을 때 치트 명령어 전송
		_UserService.LocalPlayer.PlayerCheatComponent:SendCheat(event.Text)
	end

	method void SetCommand(string command)
		-- 명령어를 입력 필드에 설정하고 활성화
		self.CommandEntity.TextInputComponent.Text = command .. " "
		self.CommandEntity.TextInputComponent:ActivateInputField()
	end

	method Entity GetOrCreateCommandRenderer(integer index)
		-- 명령어 렌더러 엔티티를 가져오거나 새로 생성
		local entityName = "CheatCommandRednerer" .. tostring(index)
		local entity = self.ScollLayOutEntity:GetChildByName(entityName)
		if entity == nil then
			local rendererModel = _EntryService:GetModelIdByName("Model_CheatCommandRenderer")
			local parent = self.ScollLayOutEntity
			local newEntity = _SpawnService:SpawnByModelId(rendererModel, entityName, Vector3.zero, parent)
			return newEntity
		end
		entity.Enable = true
		return entity
	end

	method void ClearCommandRenderer()
		-- 모든 명령어 렌더러를 비활성화
		local commandRenderers = self.ScollLayOutEntity.Children
		for i, entity in ipairs(commandRenderers) do
			entity.Enable = false
		end
	end

	method void ToggleUI()
		-- 치트 UI를 토글하여 보이거나 숨김
		if Environment.WorldId == "21ad8c8b33f34d5aa8be5827a7b07246" then
			return
		end
		
		if self.Entity.Enable == true then
			self.Entity.Enable = false
		else
			self.Entity.Enable = true
			self.Entity.Parent.Enable = true
			self.Entity.Parent.UIGroupComponent.DefaultShow = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키 입력 이벤트를 처리하는 핸들러
		
		local key = event.key
		if not isvalid(_UserService.LocalPlayer) then return end 
		
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		
		if key == KeyboardKey.Slash then
			self:ToggleUI()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "931706e3-2952-4e0a-9625-1408eddc0a5f")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		
		self:ToggleUI()
	end

end