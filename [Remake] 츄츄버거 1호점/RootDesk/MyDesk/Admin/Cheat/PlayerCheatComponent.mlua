		self.Entity.PlayerInventory:ModifyReputation(value)
		_UIToast:ShowMessage("Change Reputation", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void OpenVIPOrder()
		-- VIP 주문을 열기 위한 조건을 설정하는 치트 함수
		if self.Entity.PlayerManagement.ManagementLevel < 1 then
			self.Entity.PlayerManagement:SetManagementLevel(1)
		end
		
		local isVIPOrderOpened = _UIButtonUnlockLogic:IsButtonUnlocked(_ButtonUnlockEnum.MainMenuVIPOrder, self.Entity)
		if isVIPOrderOpened == false then
		    local achiId = _UIButtonUnlockLogic:GetButtonUnlockData(_ButtonUnlockEnum.MainMenuVIPOrder).AchievementCondition
			local achiLevelData = _AchievementDataSetLogic:GetAchievementIdData(achiId)
			self.Entity.PlayerAchievement:ChangeProgress(achiLevelData.Type, _AchievementLogic:GetFixedTypeValue(self.Entity, achiLevelData.Type, achiLevelData.TypeValue))
		end
		
		self.Entity.PlayerVIPOrder:StartNewSeason(true)
		
		_UIToast:ShowMessage("Open VIPOrder", self.UserId)
	end

