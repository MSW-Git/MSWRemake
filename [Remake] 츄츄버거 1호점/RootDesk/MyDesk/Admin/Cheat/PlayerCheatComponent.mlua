	@ExecSpace("ServerOnly")
	method void ClearEventCompleteStatus(string eventGroupId)
		-- 이벤트 완료 상태를 초기화하는 치트 함수
		local isClearAll = true
		if _UtilLogic:IsNilorEmptyString(eventGroupId) == false then
			local eventGroupData = _EventDataSetLogic.EventGroupData[eventGroupId]
			if isvalid(eventGroupData) then
				isClearAll = false
			end
		end
		
		if isClearAll then
			table.clear(self.Entity.PlayerEvent.Events)
			table.clear(self.Entity.PlayerTutorialEvent.TutorialEvents)
		else
			self.Entity.PlayerEvent.Events[eventGroupId] = nil
			self.Entity.PlayerTutorialEvent.TutorialEvents[eventGroupId] = nil
		end
	end

	@ExecSpace("ServerOnly")
	method void GetExpPotionItemByExpValue(string expValue, string statType)
		-- 경험치 값에 따른 경험치 포션 아이템을 획득하는 치트 함수
		if _UtilLogic:IsNilorEmptyString(expValue) then 
			
			_UIToast:ShowMessage("expValue is nil", self.UserId)
			return
		end
		
		
		if statType == "1" then
			
			local itemCountTable1 = _EmployeeUpgradeService:RetrunExpItemCountTable( _EmployeeTypeEnum.Cook , tonumber(expValue) )	
			
			self.Entity.PlayerInventory:AddItems(itemCountTable1 ,"Get Exp Cheat" , "Get Exp Cheat")
			_UIItemRewardService:SetItemRewardUI(itemCountTable1, "Cheat", self.UserId)
			
			
		elseif statType == "2" then	
			
			local itemCountTable2 = _EmployeeUpgradeService:RetrunExpItemCountTable( _EmployeeTypeEnum.Serving , tonumber(expValue) )
			self.Entity.PlayerInventory:AddItems(itemCountTable2 ,"Get Exp Cheat" , "Get Exp Cheat")
			
			self.Entity.PlayerInventory:AddItems(itemCountTable2 ,"Get Exp Cheat" , "Get Exp Cheat")
			_UIItemRewardService:SetItemRewardUI(itemCountTable2, "Cheat", self.UserId)
			
			
		elseif _UtilLogic:IsNilorEmptyString(statType) then
				
			local itemCountTable1 = _EmployeeUpgradeService:RetrunExpItemCountTable( _EmployeeTypeEnum.Cook , tonumber(expValue) )	
			local itemCountTable2 = _EmployeeUpgradeService:RetrunExpItemCountTable( _EmployeeTypeEnum.Serving , tonumber(expValue) )
			
			local mergeTable = {} 
			for itemId ,count in pairs(itemCountTable1) do
				mergeTable[itemId] = count		
			end
			
			for itemId ,count in pairs(itemCountTable2) do 
				mergeTable[itemId] = count	
			end
			
			self.Entity.PlayerInventory:AddItems(mergeTable ,"Get Exp Cheat" , "Get Exp Cheat")
			_UIItemRewardService:SetItemRewardUI(mergeTable, "Cheat", self.UserId)
			
		else	
			_UIToast:ShowMessage("statType is invalid.", self.UserId)
			return
		end
	end

