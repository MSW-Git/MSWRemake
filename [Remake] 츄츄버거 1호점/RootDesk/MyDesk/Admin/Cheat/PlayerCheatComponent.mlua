	@ExecSpace("ServerOnly")
	method void AddAllIngredientCards(string grade)
		-- 모든 재료 카드를 추가하는 치트 함수
		grade = tonumber(grade)
		if grade == nil or grade > 3 or grade < 1 then
			grade = 0
		end
		
		local player = self.Entity
		for id = 1, #_IngredientDataSetLogic.IngredientData do
			if grade ~= 0 then
				local g = _IngredientDataSetLogic:GetIngredientData(id).Grade
				if grade == g then
					player.PlayerIngredient:AddIngredientCard(id, 50, "Cheat")
				end
			else
				player.PlayerIngredient:AddIngredientCard(id, 50, "Cheat")
			end
			
		end
	end

