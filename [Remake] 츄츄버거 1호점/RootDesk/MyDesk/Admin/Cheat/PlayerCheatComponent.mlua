	@ExecSpace("ServerOnly")
	method void GainItem(string itemId, string itemCountString)
		-- 아이템을 획득하는 치트 함수
		local player = self.Entity
		
		local itemCount = tonumber(itemCountString)
		if itemCount == nil then
			itemCount = 1
		end
		
		local itemData = _ItemDataSetLogic:GetItemData(itemId)
		if itemCount > 999999999999999999 then 
			itemCount = math.min(itemCount, 999999999999999999)
			_UIToast:ShowMessage("입력 값을 최대 '999999999999999999'로 자동 치환합니다.", self.UserId)
		end
		
		player.PlayerInventory:AddItem(itemId, itemCount,"Use GainItem cheat","Cheat popup")
		_UIToast:ShowMessage("Add Item", self.UserId)
		
	end

