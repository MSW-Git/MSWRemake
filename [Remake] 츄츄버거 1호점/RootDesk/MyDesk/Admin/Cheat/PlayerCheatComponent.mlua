@Component
script PlayerCheatComponent extends Component

	@Sync
	property string AdminPassWord = "/enable cheat"

	property SyncTable<string, string> commandToDesc

	property table commandToFunc = {}

	property string UserId = ""

	property boolean TimeStop = false

	@TargetUserSync
	property boolean IsCheatMode = false

	method void OnBeginPlay()
		-- 치트 컴포넌트 초기화 시 사용자 ID 설정 및 모든 치트 명령어 등록
		self.UserId = self.Entity.PlayerComponent.UserId
		
		
		self:RegisterCheat("GainDiamondFree", "무료 다이아를 획득합니다. 첫번째 인자에 해당 값을 입력합니다. 음수의 경우 무료+유료 다이아를 소모합니다.", self.GainDiamondFree)
		self:RegisterCheat("GainDiamondPaid", "유료 다이아를 획득합니다. 첫번째 인자에 해당 값을 입력합니다. 음수의 경우 유료 다이아를 소모합니다.", self.GainDiamondPaid)
		
		self:RegisterCheat("GainMeso", "돈을 획득합니다. 첫번째 인자에 해당 메소를 입력합니다. 음수의 경우 메소를 소모합니다.", self.GainMeso)
		self:RegisterCheat("GainClover", "크로버를 획득합니다. 첫번째 인자에 해당 아케인 심볼을 입력합니다. 음수의 경우 아케인 심볼을 소모합니다.", self.GainClover)
		self:RegisterCheat("GainHeart", "하트를 획득합니다. 첫번째 인자에 해당 하트를 입력합니다. 음수의 경우 하트를 소모합니다.", self.GainHeart)
		self:RegisterCheat("GainTip", "Tip을 획득합니다. 첫번째 인자에 해당 팁을 입력합니다. 음수의 경우 팁을 소모합니다. 팁 보관함이 1레벨 이상이어야 합니다.", self.GainTip)
		self:RegisterCheat("SubMesoUnderZero", "메소를 소모합니다. 0 미만이 될 수 있습니다. 첫번째 인자에 소모할 메소를 입력합니다. (절대값으로 입력)", self.SubMesoUnderZero)
		
		
		self:RegisterCheat("GainItem", "아이템을 획득합니다. 첫번째 인자에 itemID, 두번재 인자에 count 를 입력합니다.", self.GainItem)
		self:RegisterCheat("ClearInventory", "나의 Inventory 를 초기화 합니다.", self.ClearInventory)
		self:RegisterCheat("GainDropBox", "드랍박스를 Open 합니다. 첫번째 인자에 해당 boxId 를 입력합니다.", self.GainDropBox)
		
		self:RegisterCheat("GainStrategyPointSP", "SP를 획득합니다. 첫번째 인자에 해당 값을 입력합니다. 음수의 경우 SP를 소모합니다.", self.GainStrategyPointSP)
		
		self:RegisterCheat("SetTrialProgress", "트라이얼의 진행도를 수정합니다. 첫번째 인자에 trialId, 두번째 인자에 progress(0-0 형태)를 입력합니다.", self.SetTrialProgress)
		self:RegisterCheat("SetUnofficialTrials", "비공식 대회 목록을 갱신합니다.", self.SetUnofficialTrials)
		
		self:RegisterCheat("AddIngredientCard", "재료 카드를 획득합니다. 첫번째 인자에 재료 카드의 Id, 두번째 인자에 수량을 입력합니다.", self.AddIngredientCard)
		self:RegisterCheat("AddAllIngredientCards", "모든 종류의 재료 카드를 50개씩 획득합니다. 인자로 1~3 숫자를 입력하면 해당 등급의 재료만 획득합니다.", self.AddAllIngredientCards)
		self:RegisterCheat("RemoveAllIngredientCards", "모든 종류의 재료 카드를 50개씩 삭제합니다. 인자로 1~3 숫자를 입력하면 해당 등급의 재료만 삭제합니다.", self.RemoveAllIngredientCards)
		
		self:RegisterCheat("SetIngreSynthGreatSuccessProb", "재료 합성 시 대성공 확률을 강제로 변경합니다. 0: 기본 확률, 1: 대성공 100%", self.SetIngreSynthGreatSuccessProb)
		self:RegisterCheat("IngreSynthSimulator", "재료 합성 시뮬레이션 결과를 출력합니다. 인자로 시행 횟수, 합성 유형, 태그 번호를 입력합니다.", self.IngreSynthSimulator)
		
		self:RegisterCheat("OpenVIPOrder", "의뢰 시스템에 필요한 조건(업적, 경영등급)을 달성시키고 새 시즌을 시작합니다.", self.OpenVIPOrder)
		self:RegisterCheat("StartNewVIPOrderSeason", "새 의뢰 시즌을 시작합니다.", self.StartNewVIPOrderSeason)
		self:RegisterCheat("CreateVIPOrderSlotData", "재화 소모 없이 의뢰 슬롯에 새 의뢰를 생성합니다. 첫번째 인자에 slotIndex(1~3)를 입력합니다.", self.CreateVIPOrderSlotData)
		self:RegisterCheat("SetVIPOrderCompleteCount", "의뢰 완료 횟수를 설정합니다. 첫번째 인자에 completeCount를 입력합니다.", self.SetVIPOrderCompleteCount)
		self:RegisterCheat("SetVIPOrderCount", "의뢰 가능 횟수를 설정합니다. 첫번째 인자에 orderCount를 입력합니다.", self.SetVIPOrderCount)
		self:RegisterCheat("SetVIPOrderSeasonCompleteScore", "의뢰 시즌 점수를 설정합니다. 첫번째 인자에 score를 입력합니다.", self.SetVIPOrderSeasonCompleteScore)
		
		self:RegisterCheat("ChangeTimeFlowDelay", "인게임 시간 흐름의 딜레이를 수정합니다. 첫번째 인자에 시간을 입력합니다.", self.ChangeTimeFlowDelay)
		
		self:RegisterCheat("AddTimeSecond", "디버깅용으로 시간값을 더합니다. 초 단위를 더합니다", self.AddTimeSecond)
		self:RegisterCheat("AddTimeMinute", "디버깅용으로 시간값을 더합니다. 분 단위를 더합니다.", self.AddTimeMinute)
		
		self:RegisterCheat("ChangePlayerStoreRanking", "맛집 랭킹 순위를 수정합니다. 첫번째 인자에 순위를 입력합니다.", self.ChangePlayerStoreRanking)
		
		self:RegisterCheat("ChangeAchievementProgress", "업적의 진행도를 수정합니다. 첫번째 인자에 achiType, 두번째 인자에 progress를 입력합니다.", self.ChangeAchievementProgress)
		
		self:RegisterCheat("AddEmployee", "츄츄를 추가합니다. 첫번째 인자에 employeeId를 입력합니다.", self.AddEmployee)
		self:RegisterCheat("AddAllEmployee", "모든 츄츄를 추가합니다. ", self.AddAllEmployee)
		self:RegisterCheat("RemoveEmployee", "츄츄를 삭제합니다. 첫번째 인자에 employeeId를 입력합니다. ", self.RemoveEmployee)
		
		self:RegisterCheat("ChangeEmploymentCount", "츄츄 영입 횟수를 변경합니다. 1 ~ 28 사이의 값을 첫번째 인자로 입력합니다.", self.ChangeEmploymentCount)
		
		self:RegisterCheat("ChangeChuchuCollectionState", "츄츄의 도감 등록 상태를 변경합니다. 첫번째 인자에 employeeId, 두번째 인자에 상태를 입력합니다. (도감 등록: 1, 해제: 0)", self.ChangeChuchuCollectionState)
		
		self:RegisterCheat("ChangeEmployeeLevel", "츄츄의 레벨을 변경합니다. 첫번째 인자에 employeeId, 두번째 인자에 레벨을 입력합니다. 자동으로 한계돌파가 됩니다.", self.ChangeEmployeeLevel)
		self:RegisterCheat("ChangeEmployeeLevelAll", "보유한 모든 츄츄의 레벨을 변경합니다. 첫번째 인자에 레벨을 입력합니다. 자동으로 한계돌파가 됩니다.", self.ChangeEmployeeLevelAll)
		self:RegisterCheat("GetExpPotionItemByExpValue","Exp 결정을 획득합니다.첫번째 인자에 EXP 수치를 입력합니다. 두 번째 인자에 원하는 경험치 타입 1:Cook , 2:Serving , 없으면 둘 다 지급 ",self.GetExpPotionItemByExpValue)
		
		self:RegisterCheat("ResetEmployeeEquipCurrency", "츄츄 의상 관련 재화 0으로 모두 초기화. M4001 ~ M4003", self.ResetEmployeeEquipCurrency)
		self:RegisterCheat("ChangeChuchuEquipLv", "츄츄 의상의 레벨을 바꿉니다. employeeId, equipLevel.\n equipLevel == -1 이면 의상 구매 전으로 초기화합니다.", self.ChangeChuchuEquipUgradeLevel)
		self:RegisterCheat("BuyChuchuEquip", "보유한 모든 츄츄의 의상을 구매 상태로 바꿉니다.", self.BuyChuchuEquip)
		self:RegisterCheat("BuyChuchuEquipAll", "보유한 모든 츄츄의 의상을 구매 상태로 바꿉니다.", self.BuyChuchuEquipAll)
		
		
		self:RegisterCheat("EmployeeEquipUpgradeSimulator1", "입력한 강화 단계를 입력한 횟수 만큼 실행 했을 때의 결과를 출력합니다.\n강화단계(1~8), 시도횟수(1~10000)", self.EmployeeEquipUpgradeSimulator1)
		self:RegisterCheat("EmployeeEquipUpgradeSimulator2", "1강 ~ 8강 까지 올리는데 시도한 횟수와 소모된 주문서 양을 출력합니다.\n루아로그와 같이 확인해주세요", self.EmployeeEquipUpgradeSimulator2)
		
		self:RegisterCheat("ChangeCustomerSpawnDelay", "손님 스폰 딜레이를 변경합니다.. 첫번째 인자에 딜레이 시간을 입력합니다. ", self.ChangeCustomerSpawnDelay)
		
		self:RegisterCheat("SetUpgradeLevel", "업그레이드를 진행합니다. 첫번째 인자에 업그레이드 타입Id, 두번째 인자에 레벨을 입력합니다. 선행 조건이 만족되어야 정상적으로 레벨업합니다.", self.SetUpgradeLevel)
		self:RegisterCheat("UnlockEveryUpgrades", "목록에 모든 업그레이드가 보이도록 해금합니다.", self.UnlockEveryUpgrades)
		
		
		self:RegisterCheat("ChangeManagementLevel", "경영 레벨을 수정합니다. 첫번째 인자에 레벨을 입력합니다.", self.ChangeManagementLevel)
		self:RegisterCheat("ChangeManagementInprogress", "경영 진척도를 수정합니다. 첫번째 인자에 진척도 인덱스(몇 번째 별인지), 두번째 인자에 진척도 값을 입력합니다.", self.ChangeManagementInprogress)
		
		self:RegisterCheat("CallEvent", "이벤트를 호출합니다. 첫번째 인자에 EventGroupId, (필요한 경우에만) 두번째 인자에 ReferKey를 입력합니다.", self.CallEvent)
		self:RegisterCheat("CallRankingEvent", "랭킹 이벤트를 호출합니다. 첫번째 인자에 점수를 넣으면 해당 점수로 랭킹이 발표됩니다.", self.CallRankingEvent)
		self:RegisterCheat("StartIntroDialog", "인트로 연출을 호출합니다.", self.StartIntroDialog)
		self:RegisterCheat("StartOutroDialog", "아웃트로 연출을 호출합니다.", self.StartOutroDialog)
		self:RegisterCheat("PlayDialog", "대화 연출을 첫 번째 인자에 DialogId를 입력합니다.", self.PlayDialog)
		
		self:RegisterCheat("SetSkipTutorial", "튜토리얼을 스킵하도록 설정합니다.", self.SetSkipTutorial)
		self:RegisterCheat("ClearEventCompleteStatus", "이벤트를 재생했었는지(완료) 여부를 설정합니다. 첫번째 인자에 EventGroupId 혹은 비우기(모두 초기화)", self.ClearEventCompleteStatus)
		self:RegisterCheat("SetEveryButtonsUnlock", "업적이나 이벤트에 의해 오픈되는 모든 버튼을 Enable합니다.", self.SetEveryButtonsUnlock)
		self:RegisterCheat("EndEventNow", "현재 진행 중인 이벤트를 종료합니다.", self.EndEventNow)
		self:RegisterCheat("ForceSetEventOccured", "이벤트를 강제 완료(본 것으로) 처리합니다. 첫번째 인자에 EventGroupId를 입력합니다.", self.ForceSetEventOccured)
		
		self:RegisterCheat("ChangeTrend", "유행을 바꿉니다.", self.ChangeTrend)
		self:RegisterCheat("StartTrend", "유행을 설정합니다. 첫번째 인자로 긍정유행 Id, 두번째 인자로 부정유행 Id를 입력합니다. 두번째 인자를 비워둘 수 있습니다.", self.StartTrend)
		self:RegisterCheat("EndTrend", "현재 진행 중인 유행을 모두 종료합니다.", self.EndTrend)
		
		self:RegisterCheat("TrainingSkip", "힌트 단계 선택을 스킵합니다.", self.TrainingSkip)
		self:RegisterCheat("GainTrainingTicket", "단체 출장 입장권을 지급합니다. 첫번째 인자로 개수를 입력합니다. (-2 ~ 2사이).", self.GainTrainingTicket)
		self:RegisterCheat("FindHotPlace", "단체 출장의 정답 장소(핫플레이스)를 토스트 메세지로 알려줍니다.", self.FindHotPlace)
		self:RegisterCheat("AutoTrainingSkip", "출발한 개인 출장을 즉시완료 시킵니다. 첫번째 인자로 호차 번호(1~3)를 입력합니다.", self.AutoTrainingSkip)
		
		self:RegisterCheat("AllShopCountReset", "모든 상점의 리셋 횟수를 초기화힙니다.", self.AllShopCountReset)
		
		self:RegisterCheat("SetAttractiveScore", "매장의 매력도 점수를 임의로 변경합니다. 첫번째 인자에 숫자(150 ~ 1500 정도)를 입력합니다.", self.SetAttractiveScore)
		self:RegisterCheat("ResetAttractiveScore", "매장의 매력도 점수 현재 매장과 메뉴 상태에 따른 기준 밸런스 값으로 되돌립니다.", self.ResetAttractiveScore)
		self:RegisterCheat("AddMonthlyEarning", "정산의 월 매출 값에 입력 값을 더합니다. 첫번째 인자에 숫자를 입력합니다.", self.AddMonthlyEarning)
		
		self:RegisterCheat("ChangeReputation", "평판 점수를 변화시킵니다. 첫번째 인자에 변화량을 입력합니다.", self.ChangeReputation)
		
		self:RegisterCheat("SetStageProgress", "스테이지의 진행도를 수정합니다. (0: 오픈, 1~5: 경영등급, 6: 클리어) 첫번째 인자에 stageId, 두번째 인자에 progress를 입력합니다.", self.SetStageProgress)
		
		self:RegisterCheat("SetBunSkinCollection", "번 스킨의 획득 여부를 수정합니다. 첫번째 인자에 Id, 두 번째 인자에 True/False를 입력합니다. (입력하지 않으면 True로 처리)", self.SetBunSkinCollection)
		
		self:RegisterCheat("ClearAllDB", "인아웃게임의 모든 DB 를 초기화합니다. 타이틀 화면에서 진행해주세요. (매장에서 사용하면 잘 안됩니다)", self.ClearAllDB)
		self:RegisterCheat("ClearIngameDB", "인게임 DB 를 초기화합니다. 첫번째 인자에 스테이지 Id를 입력합니다. 타이틀 화면에서 진행해주세요. (매장에서 사용하면 잘 안됩니다)", self.ClearIngameDB)
		self:RegisterCheat("SetEnableLobbyHUD", "LobbyHUD를 켜거나 끕니다. 첫번째 인자에 true / false를 입력합니다.", self.SetEnableLobbyHUD)
		self:RegisterCheat("SetEnableMoneyBar", "상단의 재화 바를 켜거나 끕니다. 첫번째 인자에 true / false를 입력합니다.", self.SetEnableMoneyBar)
		self:RegisterCheat("HUDOnOff", "영상 촬영을 위해 HUD를 켜거나 끕니다. 토글로 작동합니다.", self.HUDOnOff)
		self:RegisterCheat("SetDropdownTestTimer", "HUD 드롭다운 테스트를 위해 0.01초마다 드롭다운을 클릭하는 처리를 하는 타이머를 세팅합니다.", self.SetDropdownTestTimer)
		
		self:RegisterCheat("MakeStoreInfoReport", "매장 최근 기록을 추가합니다. 데이터에 사전 정의된 ReportId,param1,param2,param3 값을 입력하세요.(콤마로 나열)", self.MakeStoreInfoReport)
		self:RegisterCheat("ClearStoreInfoReport", "매장 최근 소식 출력 대기열을 비우고, 메시지 출력을 멈춥니다.", self.ClearStoreInfoReport)
		self:RegisterCheat("StopTimeFlow", "시간을 멈춥니다.", self.StopTimeFlow)
		self:RegisterCheat("ForceSaveDB", "강제로 DB를 저장합니다. SetAndWait이므로 지연이 발생할 수 있습니다.", self.ForceSaveDB)
		
		self:RegisterCheat("TestPresetMapSetting","매장 맵 상태를 바꿉니다. testKey 값을 입력하세요 1 ~ 9", self.TestPresetMapSetting)
		self:RegisterCheat("SetIsCheatMode", "치트 모드를 설정합니다. 치트 모드는 각종 연출 등을 스킵하는 용도입니다.", self.SetIsCheatMode)
		
		self:RegisterCheat("TestPresetStart","PresetCheat Data Load / 튜토리얼 스킵,메뉴 오픈, 업그레이드 항목 해금",self.TestPresetStart)
		self:RegisterCheat("TestPresetStep1Management", "첫 번째 인자에 TestKey / 경영 등급 설정&재화 획득" , self.TestPresetStep1Management)
		self:RegisterCheat("TestPresetStep2Upgrade","첫 번째 인자에 TestKey / 업그레이드 일괄 실행",self.TestPresetStep2Upgrade)
		self:RegisterCheat("TestPresetStep3Employee","첫 번째 인자에 TestKey ,두 번째 인자에 츄츄 성장 수준(0:낮음, 1:보통, 2:높음) / 츄츄 획득 및 성장",self.TestPresetStep3Employee)
		self:RegisterCheat("TestPresetStep4Recipe","첫 번째 인자에 TestKey / 레시피 즉시 생성",self.TestPresetStep4Recipe)
		self:RegisterCheat("TestPresetStep5Earning", "첫 번째 인자에 TestKey , 두 번째 인자에 평판 수준(0:낮음, 1:보통, 2:높음) / EarningLevel 및 평판 세팅 " ,self.TestPresetStep5Earning)
		self:RegisterCheat("TestPresetAll","Step 1~5 순차 실행 / 첫 번째 인자에 TestKey , 두 번째 인자에 성장 수준(0:낮음, 1:보통, 2:높음) / TestPresetStart 선행 필요",self.TestPresetAll)
		
		self:RegisterCheat("GainPackage", "패키지 상품 획득", self.GainPackage)
