	@ExecSpace("ServerOnly")
	method void SetStoreUpgradeLevel(integer interiorLevel, integer expansionLevel, integer decoLevel)
		-- 상점 업그레이드 레벨을 설정하는 치트 함수
		local interiorTpyeId = tonumber(_CheatPresetDataLogic:GetUpgradeTypeId("InteriorLevel"))
		local expansionTypeId = tonumber(_CheatPresetDataLogic:GetUpgradeTypeId("ExpansionStep"))
		local storeDecoTypeId = tonumber(_CheatPresetDataLogic:GetUpgradeTypeId("StoreDeco"))
		
		if self.IsCheatMode == false then
			self:SetIsCheatMode("True")
		end
		
		local storeUpgradeTable = {interiorTpyeId, expansionTypeId, storeDecoTypeId}
		
		local nowInteriorLevel = self.Entity.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(interiorTpyeId)
		local nowExpansionLevel = self.Entity.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(expansionTypeId)
		local nowDecoLevel = self.Entity.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(storeDecoTypeId)
		local interiorStep = 0
		local expansionStep = 0
		local decoStep = 0
		
		if nowInteriorLevel < interiorLevel then 
			interiorStep = interiorLevel - nowInteriorLevel
		end 
		
		if nowExpansionLevel < expansionLevel then
			expansionStep = expansionLevel - nowExpansionLevel
		end
		
		if nowDecoLevel < decoLevel then
			decoStep = decoLevel - nowDecoLevel
		end
		
		local maxStep = math.max(interiorStep, expansionStep, decoStep)
		local nextLevel = math.min(nowInteriorLevel, nowExpansionLevel , nowDecoLevel) + 1
		
		for i = 1 , maxStep do
			if nextLevel > nowInteriorLevel then
				local nextinteriorLevel = nowInteriorLevel + i
				local interiorLevelData = _UpgradeDataSetLogic:GetLevelData(interiorTpyeId, nextinteriorLevel)
				
				if isvalid(interiorLevelData) and interiorLevelData:GetUpgradeCost(self.Entity) ~= nil then
					if _UpgradeDataSetLogic:IsConditionSatisfied(interiorLevelData, self.Entity) then
						self.Entity.PlayerInventory:ModifyMoney(interiorLevelData:GetUpgradeCost(self.Entity), "Use SetUpgradeLevel cheat", "Cheat popup")
						self.Entity.PlayerUpgrade:UpgradeFunction(interiorTpyeId, true)
					end	
				end
			end
			
			if nextLevel > nowExpansionLevel then
				local nextExpansionLevel = nowExpansionLevel + i
				local ExpansionLevelData = _UpgradeDataSetLogic:GetLevelData(expansionTypeId, nextExpansionLevel)
				
				if isvalid(ExpansionLevelData) and ExpansionLevelData:GetUpgradeCost(self.Entity) ~= nil then
					if _UpgradeDataSetLogic:IsConditionSatisfied(ExpansionLevelData, self.Entity) then
						self.Entity.PlayerInventory:ModifyMoney(ExpansionLevelData:GetUpgradeCost(self.Entity), "Use SetUpgradeLevel cheat", "Cheat popup")
						self.Entity.PlayerUpgrade:UpgradeFunction(expansionTypeId, true)
					end	
				end
			end
			if nextLevel > nowDecoLevel then
				local nextDecoLevel = nowDecoLevel + i
				local decoLevelData = _UpgradeDataSetLogic:GetLevelData(storeDecoTypeId, nextDecoLevel)
				if isvalid(decoLevelData) and decoLevelData:GetUpgradeCost(self.Entity) ~= nil then
					if _UpgradeDataSetLogic:IsConditionSatisfied(decoLevelData, self.Entity) then
						self.Entity.PlayerInventory:ModifyMoney(decoLevelData:GetUpgradeCost(self.Entity), "Use SetUpgradeLevel cheat", "Cheat popup")
						self.Entity.PlayerUpgrade:UpgradeFunction(storeDecoTypeId, true)
					end	
				end
			end
		end
		
		_UIToast:ShowMessage("Set Upgrade Store Level", self.UserId)
		self:SetIsCheatMode("False")
	end

	@ExecSpace("ServerOnly")
	method void IngreSynthSimulator(string times, string filterType, string tagNum)
		-- 재료 합성 시뮬레이터를 실행하는 치트 함수
		local player = self.Entity
		
		if _UtilLogic:IsNilorEmptyString(times) or  _UtilLogic:IsNilorEmptyString(filterType) or _UtilLogic:IsNilorEmptyString(tagNum) then
			_UIToast:ShowMessage("3개의 인자를 정확히 입력해주세요.", self.UserId)
			return
		end
		
		times = _StringUtilLogic:StringToInt(times)
		filterType = _StringUtilLogic:StringToInt(filterType)
		tagNum = _StringUtilLogic:StringToInt(tagNum)
		
		if times < 1 or times > 1000000 then
			_UIToast:ShowMessage("시행 횟수는 1 ~ 100000 범위로 입력해주세요.", self.UserId)
			return
		end
		
		if filterType < 1 or filterType > 3 then
			_UIToast:ShowMessage("합성 유형은 1 ~ 3 범위로 입력해주세요.", self.UserId)
			return
		end
		
		if tagNum < 1 or tagNum > 5 then
			_UIToast:ShowMessage("태그 번호는 1 ~ 5 범위로 입력해주세요.", self.UserId)
			return
		end
		
		_IngreSynthLogic:IngreSynthSimul(player, times, filterType, tagNum)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleChatBalloonEvent(ChatBalloonEvent event)
		-- 채팅 말풍선 이벤트를 처리하는 핸들러
		
		local Message = event.Message
		local SenderName = event.SenderName
		local UserId = event.UserId
		if self.Entity.PlayerComponent.UserId ~= UserId then
			return
		end
		
		
		if self:HasAuthority() and string.sub(Message, 1, 1) == "/" then
			self:SendCheat(Message)
		end
	end

end