		if num < 0 then
			_UIToast:ShowMessage("매출 기록은 줄일 수 없습니다. DB 초기화 하고 다시 설정해주세요.")
		end
		
		self.Entity.PlayerSettlement:AddValueForSettlement(_SettlementPropertyEnum.P_RecipeTotal, num)
	end

	@ExecSpace("ServerOnly")
	method void SetUpgradeLevel(string typeId, string level)
		-- 업그레이드 레벨을 설정하는 치트 함수
		typeId = tonumber(typeId)
		level = tonumber(level)
		
		
		if self.IsCheatMode == false then
			self:SetIsCheatMode("True")
		end
		
		local nowLevel = self.Entity.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(typeId)
		if nowLevel >= level then
			return
		end
		
		local step = level - nowLevel
		for i = 1, step do
			local nextLevel = nowLevel+i
			local typeData = _UpgradeDataSetLogic:GetData(typeId)
			local levelData = _UpgradeDataSetLogic:GetLevelData(typeId, nextLevel)
			
			if isvalid(levelData) then
				if levelData:GetUpgradeCost(self.Entity) == nil then
					break
				end
				
				if _UpgradeDataSetLogic:IsConditionSatisfied(levelData, self.Entity) then
					self.Entity.PlayerInventory:ModifyMoney(levelData:GetUpgradeCost(self.Entity), "Use SetUpgradeLevel cheat", "Cheat popup")
					self.Entity.PlayerUpgrade:UpgradeFunction(typeId, true)
				end		
			end
		end
		
		_UIToast:ShowMessage("Set Upgrade Level", self.UserId)
		self:SetIsCheatMode("False")
	end

