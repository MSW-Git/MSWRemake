	@ExecSpace("ServerOnly")
	method void ResetEmployeeEquipCurrency()
		-- 직원 장비 화폐를 리셋하는 치트 함수
		local itemIds = {_ItemDataEnum.EmployeeEquipOpenItemId, _ItemDataEnum.CookEmployeeEquipUpgradeItemId, _ItemDataEnum.ServingEmployeeEquipUpgradeItemId}
		for _, itemId in pairs(itemIds) do
			local itemData = _ItemDataSetLogic:GetItemData(itemId)
			if itemData.SaveToOutgameDB == true then
				self.Entity.PlayerOutgameManager.OutgameInventory[itemId] = 0
			else
				self.Entity.PlayerInventory.Items[itemId] = 0
			end
		end
		
		_UIToast:ShowMessage("츄츄 의상 강화 재화의 아이템을 모두 0개로 초기화했습니다.", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void ChangeChuchuEquipUgradeLevel(string employeeId, string equipLevelStr)
		-- 츄츄 장비 업그레이드 레벨을 변경하는 치트 함수
		local equipLevel = tonumber(equipLevelStr)
		
		if equipLevel == nil or equipLevel < -1 or equipLevel > _EmployeeEquipUpgradeDataLogic.MaxUpgradeLevel then
			_UIToast:ShowMessage('두번째 인자를 잘못 입력했습니다.', self.UserId)
			return
		end
		
		self.Entity.EmployeeManager:SetEmployeeEquipLevel_ForCheat(employeeId, equipLevel)
		
		_UIToast:ShowMessage("츄츄 의상 강화 레벨 변경 성공", self.UserId)
	end

