	@ExecSpace("ServerOnly")
	method void SetIngreSynthGreatSuccessProb(string onOff)
		-- 재료 합성 대성공 확률을 설정하는 치트 함수
		if onOff == "0" then
			_IngreSynthLogic.ForceGreatSuccess = false
			_UIToast:ShowMessage("대성공 확률이 정상 확률로 적용됩니다.", self.UserId)
		elseif onOff == "1" then
			_IngreSynthLogic.ForceGreatSuccess = true
			_UIToast:ShowMessage("대성공 확률을 100%로 바꿉니다.", self.UserId)
		else
			_UIToast:ShowMessage("0 or 1을 입력해주세요.", self.UserId)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void RemoveAllIngredientCards(string grade)
		-- 모든 재료 카드를 제거하는 치트 함수
		grade = tonumber(grade)
		if grade == nil or grade < 1 or grade > 3 then
			grade = 0
		end
		
		local player = self.Entity
		for id = 1, #_IngredientDataSetLogic.IngredientData do
			if grade ~= 0 then
				local g = _IngredientDataSetLogic:GetIngredientData(id).Grade
				if grade == g then
					local ingreCount = player.PlayerIngredient.IngredientCards[id]
					if isvalid(ingreCount) and ingreCount > 0 then
						player.PlayerIngredient:RemoveIngredientCard(id, ingreCount, "Cheat")
					end
				end
			else
				local ingreCount = player.PlayerIngredient.IngredientCards[id]
				if isvalid(ingreCount) and ingreCount > 0 then
					player.PlayerIngredient:RemoveIngredientCard(id, ingreCount, "Cheat")
				end
			end
		end
	end

