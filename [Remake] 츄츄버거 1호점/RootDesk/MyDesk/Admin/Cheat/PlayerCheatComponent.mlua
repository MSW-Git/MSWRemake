	@ExecSpace("ServerOnly")
	method void ResetPassPurchaseRecord(string productId)
		-- 패스 구매 기록을 리셋하는 치트 함수
		
		local res = self.Entity.PlayerOutgameManager:ResetPurchseCount(productId)
		
		if res == nil then
			_SpecialShopDataLogic:AbnormalLog('구매이력이 없거나 잘못된 상품 키 입니다.')
		else
			_UIToast:ShowMessage("초기화 완료. 초기화 전 구매횟수 - "..tostring(res), self.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void ResetPassLevelReward(string productId)
		-- 패스 레벨 보상을 리셋하는 치트 함수
		local changedCount = 0
		
		if productId == nil then
			for i, data in pairs(_StagePassDataLogic.StagePassProductData) do
				---@type StagePassProductData
				local productData = data
				local res = self.Entity.PlayerOutgameManager:ResetStagePassRewardReceived(productData.Id)
				changedCount += res
			end
		else
			local res = self.Entity.PlayerOutgameManager:ResetStagePassRewardReceived(productId)
			changedCount = res
		end
		
		_UIToast:ShowMessage("초기화 완료. 초기화 전 구매횟수 - "..tostring(changedCount), self.UserId)
	end

