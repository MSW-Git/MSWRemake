	@ExecSpace("ServerOnly")
	method boolean IsValidTestKey(string testKey)
		-- 테스트 키가 유효한지 확인하는 함수
		local isValidKey = false
		
		if #_CheatPresetDataLogic.TestKeyTable == 0 then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return isValidKey
		end
		
		for i , v in ipairs(_CheatPresetDataLogic.TestKeyTable) do
			if testKey == tostring(v) then
				isValidKey = true
			end
		end
		
		if not isValidKey then
			_UIToast:ShowMessage("TestKey is not valid", self.UserId)
		end
		
		return isValidKey
	end

	@ExecSpace("ServerOnly")
	method void TestPresetMapSetting(string testKey)
		-- 테스트 프리셋 맵 설정을 적용하는 치트 함수
		self.Entity.PlayerTutorialEvent:SetIsSkipTutorial(true)
		
		self:TestPresetStart()
		if  self:IsValidTestKey(testKey) == false then return end 
		
		self:ChangeAchievementProgress("90004", "4") 
		self:ChangeAchievementProgress("90008","5") 
		self:ChangeAchievementProgress("90021","6") 
		
		local testKeyNum = tonumber(testKey)
		
		local upgradePresetData = _CheatPresetDataLogic:GetCheatPresetUpgrade( testKeyNum )
		if not isvalid(upgradePresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		
		self:SetIsCheatMode("true")
		
		self:ChangeManagementLevel( _CheatPresetDataLogic:GetManagementLv( testKeyNum ) )
		
		
		for i = 1 , 3 do
			local upgradeTypeEnum = _CheatPresetDataLogic.CheatPresetUpgradeTypeEnum[i]
			local typeLevel = upgradePresetData[upgradeTypeEnum]
			
			self:SetUpgradeLevel(_CheatPresetDataLogic:GetUpgradeTypeId(upgradeTypeEnum) ,tostring(typeLevel))
		end
		
		self:SetIsCheatMode("false")
	end

	@ExecSpace("ServerOnly")
	method void TestPresetStep1Management(string testKey)
		-- 테스트 프리셋 1단계 경영 설정을 적용하는 치트 함수
		if  self:IsValidTestKey(testKey) == false then return end 
		local testKeyNum = tonumber(testKey)
		
		local cheatPresetData = _CheatPresetDataLogic:GetCheatPresetData(testKeyNum)
		if not isvalid(cheatPresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		
		self:ChangeManagementLevel( _CheatPresetDataLogic:GetManagementLv( testKeyNum ) )
		
		
		self:GainDiamondFree ( tostring(cheatPresetData["Diamond"]) )
		self:GainClover( tostring(cheatPresetData["Clover"]) )
		self:GainHeart( tostring(cheatPresetData["Heart"]) )
		self:GainItem( "M3001" , tostring(cheatPresetData["Medal"]) )
		self:GainItem( "M3002" , tostring(cheatPresetData["Medal"]) )
		
		self:GetExpPotionItemByExpValue( tostring(cheatPresetData["Exp"]) , nil )
		
		self:GainItem( "B0001" , tostring(cheatPresetData["B0001"]) )
		self:GainItem( "B0002" , tostring(cheatPresetData["B0002"]) )
		self:GainItem( "B0003" , tostring(cheatPresetData["B0003"]) )
		self:GainItem( "B0004" , tostring(cheatPresetData["B0004"]) )
		
		local targetEarningLevel = cheatPresetData["EarningLevel"]
		local stageId = self.Entity.PlayerStage.NowStage
		local myBestRecipeEarnings= _StageDataSetLogic:GetStageData(self.Entity.PlayerStage.NowStage):GetStageEarningLevelData(targetEarningLevel).BestRecipeEarnings
		self:GainMeso ( tostring(myBestRecipeEarnings) )
		
		local desc = cheatPresetData["Desc"]
		_UIToast:ShowMessage("Preset Test Step1 : Management (stage "..tostring(stageId)..") : " .. tostring(testKey) .. " = " .. tostring(desc) , self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void TestPresetStep2Upgrade(string testKey)
		-- 테스트 프리셋 2단계 업그레이드 설정을 적용하는 치트 함수
		if  self:IsValidTestKey(testKey) == false then return end 
		local testKeyNum = tonumber(testKey)
		
		local upgradePresetData = _CheatPresetDataLogic:GetCheatPresetUpgrade( testKeyNum )
		if not isvalid(upgradePresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		
		self:ChangeAchievementProgress("90004", "4") 
		self:ChangeAchievementProgress("90008","5") 
		self:ChangeAchievementProgress("90021","6") 
		
		self:SetIsCheatMode("true")
		
		local stageId = self.Entity.PlayerStage.NowStage
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		local stageConfigData = _BalanceDataSetLogic:GetStageConfigData(stageId)
		local storeUpgradeBool = false
		for i = 1 , _CheatPresetDataLogic.UpgradeTypeCount do
			local upgradeTypeEnum = _CheatPresetDataLogic.CheatPresetUpgradeTypeEnum[i]
			local typeLevel = upgradePresetData[upgradeTypeEnum]
			
			if upgradeTypeEnum == "InteriorLevel" or upgradeTypeEnum == "ExpansionStep" or upgradeTypeEnum == "StoreDeco" then
				if storeUpgradeBool == false then
					local interiorLevel = upgradePresetData["InteriorLevel"]
					local expansionLevel = upgradePresetData["ExpansionStep"] 
					local decoLevel = upgradePresetData["StoreDeco"] 
				
					self:SetStoreUpgradeLevel(interiorLevel, expansionLevel, decoLevel)
					storeUpgradeBool = true
				end
			else
				if upgradeTypeEnum == "GrillLevel" then
					typeLevel = math.floor( ( stageConfigData.GrillUpgradeMaxLevel ) * typeLevel )
				
				elseif upgradeTypeEnum == "CounterLevel" then
					typeLevel = math.floor( ( stageConfigData.CounterUpgradeMaxLevel ) * typeLevel )
				end	
			
				if typeLevel > 0 then
					self:SetUpgradeLevel(_CheatPresetDataLogic:GetUpgradeTypeId(upgradeTypeEnum) ,tostring(typeLevel))
				end
			end
		end
		
		local desc = upgradePresetData["Desc"]
		
		_UIToast:ShowMessage("Preset Test Step2 : Upgrade (stage "..tostring(stageId)..") : " .. tostring(testKey) .. " = " .. tostring(desc) , self.UserId)
		self:SetIsCheatMode("false")
		
		self:ClearStoreInfoReport()
	end

	@ExecSpace("ServerOnly")
	method void TestPresetStep3Employee(string testKey, string level)
		-- 테스트 프리셋 3단계 직원 설정을 적용하는 치트 함수
		if  self:IsValidTestKey(testKey) == false then return end 
		
		local testKeyNum = tonumber(testKey)
		
		if not (level == "0" or level == "1" or level == "2" or level == nil ) then
			_UIToast:ShowMessage("성장 수준 값 오류 ( 0:Low , 1:Mid , 2:High 중 하나를 입력하세요. 생략하면 0:낮음 수준으로 적용됩니다. )", self.UserId)
			return
		end
		
		if _UtilLogic:IsNilorEmptyString(level) then
			level = "0"
		end
		local levelText ="Low"
		
		if level == "1" then
			levelText ="Mid"
		elseif level == "2" then	
			levelText ="High"
		end
		
		local employeeTestGroupNum = _UtilLogic:SubString(testKey , 1 , 1)
		
		local employeeListByTestKey = {}
		
		local employeeGroupData  = _CheatPresetDataLogic:GetCheatPresetEmployees(testKeyNum)
		if not isvalid(employeeGroupData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		
		local cheatPresetData = _CheatPresetDataLogic:GetCheatPresetData(testKeyNum)
		if not isvalid(cheatPresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		
		local employees = {} 
		
		local employeeNeedCount = cheatPresetData["NeedEmployeeCount"]
		
		for i = 1 , employeeNeedCount do	
			table.insert(employees , employeeGroupData[i])
		end
		
		
		for i , empId in ipairs(employees) do
		
			self:AddEmployee(empId)
			self:ChangeChuchuCollectionState(empId,"1")
			self:BuyChuchuEquip( empId )	
			
			---@type EmployeeData
			local empData = _EmployeeService:GetData(empId)
			
			---@type EmployeeDetailData
			local detailData = self.Entity.EmployeeManager:GetEmployeeDetail(empId)
			local chuchuType = empData.Type
			if chuchuType == _EmployeeTypeEnum.Cook then
				self:ChangeEmployeeLevel( empId , tostring(cheatPresetData["CookEmployeeLevel"..tostring(level)]) )
			
			elseif chuchuType == _EmployeeTypeEnum.Serving then
				self:ChangeEmployeeLevel( empId , tostring(cheatPresetData["ServingEmployeeLevel"..tostring(level)]) )
			end
			
			self:ChangeChuchuEquipUgradeLevel( empId , tostring(cheatPresetData["EquipLevel"..tostring(level)]) )
		end
		
		_UIToast:ShowMessage("Preset Test Step3 : Employee : ".. tostring(#employees) .. "마리 츄츄 추가 (성장 수준 ="..tostring(levelText)..")", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void TestPresetStep4Recipe(string testKey)
		-- 테스트 프리셋 4단계 레시피 설정을 적용하는 치트 함수
		if  self:IsValidTestKey(testKey) == false then return end 
		local testKeyNum = tonumber(testKey)
		
		local cheatPresetData = _CheatPresetDataLogic:GetCheatPresetData(testKeyNum)
		if not isvalid(cheatPresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		local desc = cheatPresetData["Desc"]
		
		local recipeKeyStart = cheatPresetData["RecipeKeyStart"]
		local recipeKeyEnd = cheatPresetData["RecipeKeyEnd"]
		
		for i = recipeKeyStart , recipeKeyEnd do
			self:AddRecipe(tostring(i) , "0")
		end
		
		_UIToast:ShowMessage("Preset Test Step4 : Recipe : " .. tostring(testKey) .. " = " .. tostring(desc) , self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void TestPresetStep5Earning(string testKey, string level)
		-- 테스트 프리셋 5단계 수익 설정을 적용하는 치트 함수
		if  self:IsValidTestKey(testKey) == false then return end 
		local testKeyNum = tonumber(testKey)
		
		if not (level == "0" or level == "1" or level == "2" or level == nil ) then
			_UIToast:ShowMessage("성장 수준 값 오류 ( 0:Low , 1:Mid , 2:High 중 하나를 입력하세요. 생략하면 0:낮음 수준으로 적용됩니다. )", self.UserId)
			return
		end
		
		if _UtilLogic:IsNilorEmptyString(level) then
			level = "0"
		end
		local levelText ="Low"
		
		if level == "1" then
			levelText ="Mid"
		elseif level == "2" then	
			levelText ="High"
		end
		
		local cheatPresetData = _CheatPresetDataLogic:GetCheatPresetData(testKeyNum)
		if not isvalid(cheatPresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		local desc = cheatPresetData["Desc"]
		
		local stageId = self.Entity.PlayerStage.NowStage
		local myBestRecipeEarnings= _StageDataSetLogic:GetStageData(stageId):GetStageEarningLevelData(self.Entity.PlayerSettlement.EarningLevel).BestRecipeEarnings
		local myReputationValue = self.Entity.PlayerInventory.Reputation
		
		local setEarningLevel = cheatPresetData["EarningLevel"]
		
		local setBestRecipeEarnings = _StageDataSetLogic:GetStageData(stageId):GetStageEarningLevelData(tonumber(setEarningLevel)).BestRecipeEarnings
		
		local setReputationRateValue = cheatPresetData["Reputation"..tostring(level)]
		
		
		local stageEarningLevelData = _StageDataSetLogic:GetStageData(self.Entity.PlayerStage.NowStage):GetStageEarningLevelData(tonumber(setEarningLevel))
		local storeAttractiveData = _BalanceDataSetLogic:GetStoreAttractiveLevelData(stageEarningLevelData.StoreAttractiveLevel)
		
		local minReputation = storeAttractiveData.MinReputation
		local maxReputation = storeAttractiveData.MaxReputation
		
		local diffEarningValue = setBestRecipeEarnings - myBestRecipeEarnings  
		
		if setBestRecipeEarnings > myBestRecipeEarnings then
			diffEarningValue = math.abs (diffEarningValue)
			self:AddMonthlyEarning( tostring(diffEarningValue) )
			
		elseif setBestRecipeEarnings <  myBestRecipeEarnings then
			 _UIToast:ShowMessage("월 매출 금액을 낮출 수 없습니다.")
		end
		
		local setReputationValue = tonumber(maxReputation) * tonumber(setReputationRateValue)
		
		local diffReputationValue = setReputationValue - myReputationValue
		
		if setReputationValue > myReputationValue then
			diffReputationValue = math.abs(diffReputationValue)
			self:ChangeReputation( tostring(diffReputationValue) )
		elseif setReputationValue < myReputationValue then
			diffReputationValue = -math.abs(diffReputationValue)
			self:ChangeReputation( tostring(diffReputationValue) )
		end
		
		
		_UIToast:ShowMessage("Preset Test Step5 : Earnings&Reputation : " .. tostring(testKey) .. " = " .. tostring(desc) .." (성장 수준 ="..tostring(levelText)..")", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void TestPresetAll(string testKey, string level)
		-- 모든 테스트 프리셋을 적용하는 치트 함수
		if  self:IsValidTestKey(testKey) == false then return end 
		
		if not (level == "0" or level == "1" or level == "2" or level == nil ) then
			_UIToast:ShowMessage("성장 수준 값 오류 ( 0:Low , 1:Mid , 2:High 중 하나를 입력하세요. 생략하면 0:낮음 수준으로 적용됩니다. )", self.UserId)
			return
		end
		
		if _UtilLogic:IsNilorEmptyString(level) then
			level = "0"
		end
		
		local testKeyNum = tonumber(testKey)
		local cheatPresetData = _CheatPresetDataLogic:GetCheatPresetData(testKeyNum)
		if not isvalid(cheatPresetData) then
			_UIToast:ShowMessage("TestPresetStart 명령어를 먼저 실행하세요.", self.UserId)
			return 
		end
		local desc = cheatPresetData["Desc"]
		
		_UIToast:ShowMessage("TestPresetAll : Step 1~5 순차 실행합니다. " .. tostring(desc) .. " 잠시 기다려주세요. ")  
		
		local step1 = function()
			self:TestPresetStep1Management(testKey)
			_UIToast:ShowMessage("Step 1 : Management "  .. tostring(desc) .. "수준 세팅 완료" )  
		end
		
		local step2 = function()
			self:TestPresetStep2Upgrade(testKey)
			_UIToast:ShowMessage("Step 2 : Upgrade "  .. tostring(desc) .. "수준 세팅 완료" )  
		end
		
		local step3 = function()
			self:TestPresetStep3Employee(testKey ,level )
			_UIToast:ShowMessage("Step 3 : Employee "  .. tostring(desc) .. " / " .. tostring(level) .. "수준 세팅 완료" )  
		end
		
		local step4 = function()
			self:TestPresetStep4Recipe(testKey)
			_UIToast:ShowMessage("Step 4 : Recipe "  .. tostring(desc) .. " 수준 레시피 생성 완료 완료" )  
		end
		
		local step5 = function()
			self:TestPresetStep5Earning(testKey ,level)
			_UIToast:ShowMessage("Step 5 : Earning & Reputation "  .. tostring(desc) .. " / " .. tostring(level) .. "수준 세팅 완료" )  
		end
		
		_TimerService:SetTimerOnce ( step1 , 0 )
		_TimerService:SetTimerOnce ( step2 , 1 )
		_TimerService:SetTimerOnce ( step3 , 1.5 )
		_TimerService:SetTimerOnce ( step4 , 2 )
		_TimerService:SetTimerOnce ( step5 , 3 )
		
	end

