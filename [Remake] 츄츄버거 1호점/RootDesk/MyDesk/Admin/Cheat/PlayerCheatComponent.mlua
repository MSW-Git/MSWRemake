	@ExecSpace("ServerOnly")
	method void AddTimeSecond(string secondString)
		-- 시간을 초 단위로 추가하는 치트 함수
		local second = tonumber(secondString)
		if second == nil then
			return
		end
		
		if second < 0 then
			return
		end
		
		local milliSecond = second * 1000
		_DateTimeLogic:AddTime(milliSecond)
		_UIToast:ShowMessage("시간이 변경되었습니다.")	
	end

	@ExecSpace("ServerOnly")
	method void AddTimeMinute(string minuteString)
		-- 시간을 분 단위로 추가하는 치트 함수
		local min = tonumber(minuteString)
		if min == nil then
			return
		end
		
		if min < 0 then
			return
		end
		
		local milliSecond = min * 1000 * 60
		_DateTimeLogic:AddTime(milliSecond)
		_UIToast:ShowMessage("시간이 변경되었습니다.")	
	end

