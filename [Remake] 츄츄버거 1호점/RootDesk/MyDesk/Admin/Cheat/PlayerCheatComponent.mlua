		self.Entity.PlayerVIPOrder:StartNewSeason(true)
		
		_UIToast:ShowMessage("Start New VIPOrder Season", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void CreateVIPOrderSlotData(string slotIndex)
		-- VIP 주문 슬롯 데이터를 생성하는 치트 함수
		slotIndex = tonumber(slotIndex)
		
		local playerVIPOrder = self.Entity.PlayerVIPOrder
		local orderData = playerVIPOrder.VIPOrderSlotData[slotIndex]
		local isReroll = false
		if orderData ~= {} and orderData ~= nil then
			if orderData["OrderType"] == _VIPOrderTypeEnum.Recipe or orderData["OrderType"] == _VIPOrderTypeEnum.Ingre then
				isReroll = true
			end
		end
		
		self.Entity.PlayerVIPOrder:CreateVIPOrderSlotData(tonumber(slotIndex), isReroll, "5")
		
		_UIToast:ShowMessage("Create VIPOrder Slot Data", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void SetVIPOrderCompleteCount(string completeCount)
		-- VIP 주문 완료 횟수를 설정하는 치트 함수
		completeCount = tonumber(completeCount)
		if completeCount > _UpgradeDataSetLogic:ReturnCurrentPlayerValue(self.Entity, _UpgradeTypeEnum.VIPOrderCount) then
			completeCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(self.Entity, _UpgradeTypeEnum.VIPOrderCount)
		end
		
		self.Entity.PlayerVIPOrder.SeasonCompleteCount = completeCount
		
		_UIToast:ShowMessage("Set VIPOrder Complete Count", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void SetVIPOrderCount(string orderCount)
		-- VIP 주문 가능 횟수를 설정하는 치트 함수
		orderCount = tonumber(orderCount)
		local upgradeType = _UpgradeTypeEnum.VIPOrderCount
		local upgradeData = _UpgradeDataSetLogic:GetData(upgradeType)
		local upgradeLevel
		for level, _ in pairs(upgradeData.LevelData) do
			local levelData = _UpgradeDataSetLogic:GetLevelData(upgradeType, level)
			if levelData:GetUpgradeValue(self.Entity) == orderCount then
				upgradeLevel = level
				break
			end
		end
		
		if isvalid(upgradeLevel) then
			self:SetUpgradeLevel(tostring(upgradeType), tostring(upgradeLevel))
			_UIToast:ShowMessage("Set VIPOrder Count", self.UserId)
		else
		end
	end

