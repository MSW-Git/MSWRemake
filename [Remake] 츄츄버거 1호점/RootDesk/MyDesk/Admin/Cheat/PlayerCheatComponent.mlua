	@ExecSpace("ServerOnly")
	method void AddRecipeGrade(string gradeKey)
		-- 레시피 등급을 추가하는 치트 함수
		local recipes = self.Entity.PlayerRecipe.Recipes
		local recipeCount = #table.keys(recipes)
		local recipeMaxCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(self.Entity, _UpgradeTypeEnum.RecipeBoxCount)
		
		if recipeCount >= recipeMaxCount then
			_UIToast:ShowMessage("레시피가 가득 찼습니다.", self.UserId)
			return
		end
		
		local data = _DataService:GetTable("CheatPresetRecipe")
		local burgerData = {}
		local check = false
		
		local bottomBun = RecipeIngreDrawData()
		bottomBun:Init(1, _RecipeIngreDrawEnum.Bun, "Bottom", false, nil)
		
		local ingre1 = RecipeIngreDrawData()
		ingre1:Init(16, _RecipeIngreDrawEnum.Ingredient, "", false, nil)
		
		local ingre2 = RecipeIngreDrawData()
		ingre2:Init(43, _RecipeIngreDrawEnum.Ingredient, "", false, nil)
		
		local topBun = RecipeIngreDrawData()
		topBun:Init(1, _RecipeIngreDrawEnum.Bun, "Top", false, nil)
		
		local ingres = {bottomBun, ingre1, ingre2, topBun}
		
		for i = 1, 6 do
			local RecipeKey = gradeKey..tostring(i)
			local row = data:FindRow( "RecipeKey" , RecipeKey )
		
			local bugerName = row:GetItem("BugerName")
			local ingreList = _RecipeIngreDrawEnum:EncodeIngreList(ingres)
			local tasteScore = tonumber(row:GetItem("TasteScore"))
			local balancePoint = tonumber(row:GetItem("BalancePoint"))	
			local spicyPoint = tonumber(row:GetItem("SpicyPoint"))
			local cost = tonumber(row:GetItem("Cost"))
			local tag = row:GetItem("Tag")
			local trialSkillBonus = tonumber(row:GetItem("TrialSkillBonus"))
			local usedSkillList = ""
			local employeeId = ""
		
			burgerData = {bugerName, ingreList, tasteScore, balancePoint, spicyPoint, cost, tag, trialSkillBonus, usedSkillList, employeeId}
			check = true
		
			if check == true then 
				self.Entity.PlayerRecipe:AddNewRecipe(burgerData, true)
			else
				_UIToast:ShowMessage("해당 키의 레시피 데이터 그룹이 없습니다.", self.UserId)
				return
			end
		end
		
		_UIToast:ShowMessage("레시피 6종 추가 완료", self.UserId)
		
	end

