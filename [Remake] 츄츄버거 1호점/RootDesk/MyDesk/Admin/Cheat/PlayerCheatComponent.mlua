	@ExecSpace("ServerOnly")
	method void ResetShopItemCount(string shopId)
		-- 상점 아이템 구매 횟수를 리셋하는 치트 함수
		local products = _SpecialShopDataLogic.SpecialShopProductData
		
		for _,d in pairs(products) do
			---@type SpecialShopProductData
			local data = d
			if data.LinkedShopId == shopId then
				self.Entity.PlayerOutgameManager:SubPurchaseCount(data.Id, true)
			end
		end
		
		_UIToast:ShowMessage("ResetShopItemCount 성공!!", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void StartTrend(string positiveId, string negativeId)
		-- 트렌드를 시작하는 치트 함수
		positiveId = tonumber(positiveId)
		
		
		local positiveTrendData = _RecipeDataSetLogic:GetTrendData(positiveId)
		if positiveTrendData == nil then
			return
		end
		
		local curDay = self.Entity.TimeManager.Utc.Day
		local data = "0/"..curDay
		
		local playerRecipe = self.Entity.PlayerRecipe
		table.clear(playerRecipe.NowTrend)
		
		playerRecipe.NowTrend[positiveId] = data
		if _EventDataSetLogic.EventGroupData[positiveTrendData.OccurEvent] ~= nil then
			_EventManager:SetEventReferKeyData(positiveTrendData.OccurEvent, positiveTrendData.TargetTag, self.Entity.PlayerComponent.UserId)
			self.Entity.PlayerEvent:RequestCallEvent(positiveTrendData.OccurEvent)
		end
		
		if _UtilLogic:IsNilorEmptyString(negativeId) == false then
			negativeId = tonumber(negativeId)
			local negativeTrendData = _RecipeDataSetLogic:GetTrendData(negativeId)
			if negativeTrendData == nil then
				return
			end
			
			if negativeTrendData.TargetTag == positiveTrendData.TargetTag then
				return
			end
			
			playerRecipe.NowTrend[negativeId] = data
			if _EventDataSetLogic:GetEventGroupData(negativeTrendData.OccurEvent) ~= nil then
				_EventManager:SetEventReferKeyData(negativeTrendData.OccurEvent, negativeTrendData.TargetTag, self.Entity.PlayerComponent.UserId)
				self.Entity.PlayerEvent:RequestCallEvent(negativeTrendData.OccurEvent)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void EndTrend()
		-- 트렌드를 종료하는 치트 함수
		self.Entity.PlayerRecipe:EndTrend(table.keys(self.Entity.PlayerRecipe.NowTrend))
	end

