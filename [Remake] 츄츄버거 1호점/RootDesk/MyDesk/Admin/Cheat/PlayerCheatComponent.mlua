	@ExecSpace("ServerOnly")
	method void HUDOnOff()
		-- HUD 표시를 토글하는 치트 함수
		if self._T.HUDOnOff == nil then
			self._T.HUDOnOff = true
		elseif self._T.HUDOnOff == true then
			self._T.HUDOnOff = false
		elseif self._T.HUDOnOff == false then
			self._T.HUDOnOff = true
		end
		self:HUDOnOffClient(not self._T.HUDOnOff , self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void HUDOnOffClient(boolean onOff)
		-- 클라이언트에서 HUD 표시를 제어하는 함수
		local moneyBar = _UIGroupManager.MoneyBarGroup
		local hudToast = _UIGroupManager.ToastLobbyGroup
		
		_UIGroupManager:EnableLobbyHUDGroup(onOff)
		moneyBar:SetEnable(onOff)
		hudToast:SetVisible(onOff)
		
	end

	@ExecSpace("ServerOnly")
	method void AddPiggyBankPoint(string pointString)
		-- 돼지 저금통 포인트를 추가하는 치트 함수
		local point = tonumber(pointString)
		if point == nil then
			point = 0
		end
		self.Entity.PlayerOutgameManager:ForceAddPiggyBankPoint_ForCheat(point)
		
		_UIToast:ShowMessage("저금통 포인트 변경 성공", self.UserId)
		
	end

	@ExecSpace("ServerOnly")
	method void SetPiggyBankLevel(string levelString, string pointString)
		-- 돼지 저금통 레벨을 설정하는 치트 함수
		local level = tonumber(levelString)
		local point = tonumber(pointString)
		if level == nil or level < 1 or level > 10 then
			local msg = '유효하지 않는 레벨입니다.'
			_SpecialShopDataLogic:AbnormalLog(msg)
			_UIToast:ShowMessage(msg, self.UserId)
			return
		end
		
		if point == nil then
			point = 0
		end
		
		self.Entity.PlayerOutgameManager:ForceSetPiggyBankLevelAndPoint_ForCheat(level, point)
	end

	@ExecSpace("ServerOnly")
	method void PlayDialog(string dialogId)
		-- 다이얼로그를 재생하는 치트 함수
		_UIDialogLogic:MakeDialog( dialogId , nil , self.Entity.PlayerComponent.UserId)
		
	end

	@ExecSpace("ServerOnly")
	method void ResetBoosterPackPurchase(string numString)
		-- 부스터 팩 구매를 리셋하는 치트 함수
		if numString == nil then
			_UIToast:ShowMessage("1 or 2 입력하세요", self.UserId)
			return
		end
		
		local num = tonumber(numString)
		if num < 0 or num > 2 then
			_UIToast:ShowMessage("인자 오류", self.UserId)
			return 
		end
		
		self.Entity.PlayerManagement:InitBoosterPackPurchase(num)
		
		_UIToast:ShowMessage("부스터팩 구매 초기화 성공", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void AddRecipe(string RecipeKey, string enableTrialBuff)
		-- 레시피를 추가하는 치트 함수
		
		local recipes = self.Entity.PlayerRecipe.Recipes
		local recipeCount = #table.keys(recipes)
		local recipeMaxCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(self.Entity, _UpgradeTypeEnum.RecipeBoxCount)
		
		if recipeCount >= recipeMaxCount then
			_UIToast:ShowMessage("레시피가 가득 찼습니다.")
			return
		end
		
		local data = _DataService:GetTable("CheatPresetRecipe")
		local burgerData = {}
		local check = false
		
		local bottomBun = RecipeIngreDrawData()
		bottomBun:Init(1, _RecipeIngreDrawEnum.Bun, "Bottom", false, nil)
		
		local ingre1 = RecipeIngreDrawData()
		ingre1:Init(16, _RecipeIngreDrawEnum.Ingredient, "", false, nil)
		
		local ingre2 = RecipeIngreDrawData()
		ingre2:Init(43, _RecipeIngreDrawEnum.Ingredient, "", false, nil)
		
		local topBun = RecipeIngreDrawData()
		topBun:Init(1, _RecipeIngreDrawEnum.Bun, "Top", false, nil)
		
		local ingres = {bottomBun, ingre1, ingre2, topBun}
		
		local row = data:FindRow( "RecipeKey" , RecipeKey )
		
		local bugerName = row:GetItem("BugerName")
		local ingreList = _RecipeIngreDrawEnum:EncodeIngreList(ingres)
		local tasteScore = tonumber(row:GetItem("TasteScore"))
		local balancePoint = tonumber(row:GetItem("BalancePoint"))	
		local spicyPoint = tonumber(row:GetItem("SpicyPoint"))
		local cost = tonumber(row:GetItem("Cost"))
		local tag = row:GetItem("Tag")
		
		local trialSkillBonus = tonumber(row:GetItem("TrialSkillBonus"))	
		if enableTrialBuff == "1" then
			trialSkillBonus = enableTrialBuff	
		end
		local usedSkillList = ""
		local employeeId = ""
		
		burgerData = {bugerName, ingreList, tasteScore, balancePoint, spicyPoint, cost, tag, trialSkillBonus, usedSkillList, employeeId}
		check = true
		
		if check == true then 
			self.Entity.PlayerRecipe:AddNewRecipe(burgerData, true)
			_UIToast:ShowMessage("레시피 추가 완료")
		else
			_UIToast:ShowMessage("해당 테스트키의 레시피 데이터가 없습니다.")
		end
	end

	@ExecSpace("ServerOnly")
	method void ClearStoreInfoReport()
		-- 상점 정보 리포트를 초기화하는 치트 함수
		_ReportMessageMaker:ClearReportQueue(self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void LaunchingEventChangeDay(string day, string time)
		-- 런칭 이벤트 날짜를 변경하는 치트 함수
		if time == nil then
			time = "00:00:00"
		end
		
		local daytime = day.." "..time
		
		local diff = DateTime(daytime).Elapsed - _DateTimeLogic:GetUtc9Elapsed() 
		  
		_DateTimeLogic:AddTime(diff)
		
		
		
		_UIToast:ShowMessage(DateTime(_DateTimeLogic:GetUtc9Elapsed()):ToFormattedString("F").." 설정 후 출석 확인 완료")
	end

	@ExecSpace("ServerOnly")
	method void LaunchingEventReset()
		-- 런칭 이벤트를 리셋하는 치트 함수
		local userData = _DataStorageService:GetUserDataStorage(self.Entity.PlayerDBManager.DBVersion)
		
		userData:DeleteAndWait("FirstConnectDate")
		userData:DeleteAndWait("ConnectDate")
		
		userData:DeleteAndWait("SendMail1")
		userData:DeleteAndWait("SendMail2")
		
		for i = 1 ,14, 1 do
			local mailId = 100 + i
			local dbKey = string.format("SendMail%d", mailId)
			userData:DeleteAndWait(dbKey)
		end
		
		
		_UIToast:ShowMessage("런칭 이벤트 초기화 완료")
	end

	method void ChangeOfflineRewardTime(string time)
		-- 오프라인 보상 시간을 변경하는 치트 함수
		local timeSplit = _UtilLogic:Split(time, ":")
		local hour = tonumber(timeSplit[1])
		local min = tonumber(timeSplit[2])
		local sec = tonumber(timeSplit[3])
		
		local totalSec = hour * 60 * 60 + min * 60 + sec
		local totalElapsed = totalSec * 1000
		local nowElapsed = _DateTimeLogic:GetUtcNowElapsed()
		
		local timeElapsed = nowElapsed - totalElapsed
		self.Entity.PlayerOutgameManager.LogoutTimeElapsed = timeElapsed
		
		_UIToast:ShowMessage(string.format("Set OfflineRewardTime: %s / LogoutElapsed: %d", time, self.Entity.PlayerOutgameManager.LogoutTimeElapsed), self.Entity.PlayerComponent.UserId)
	end

