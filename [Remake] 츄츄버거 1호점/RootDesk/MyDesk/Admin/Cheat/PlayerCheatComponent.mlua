	@ExecSpace("ServerOnly")
	method void ChangeChuchuCollectionState(string employeeID, string state)
		-- 츄츄 컬렉션 상태를 변경하는 치트 함수
		local player = self.Entity
		if not _UtilLogic:IsNilorEmptyString(employeeID) then 
			if not _UtilLogic:IsNilorEmptyString(state) then
				if not isvalid(_EmployeeService:GetData(employeeID)) then 
					_UIToast:ShowMessage("잘못된 employeeID를 입력했습니다.", self.UserId)
				else
					self.Entity.ChuchuCollectionDB:ChangeChuchuCollectionState(employeeID, _StringUtilLogic:StringToInt(state))
					_UIToast:ShowMessage("Add Employee", self.UserId)
				end
			else
				_UIToast:ShowMessage("변경할 상태를 입력하세요. (등록: 1, 해제: 0)", self.UserId)
			end
			
		else 
			_UIToast:ShowMessage("츄츄 id를 입력하세요", self.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void ChangeEmploymentCount(string count)
		-- 고용 횟수를 변경하는 치트 함수
		if not _UtilLogic:IsNilorEmptyString(count) then
			local lv = _StringUtilLogic:StringToInt(count) 
			local maxLv = self.Entity.PlayerEmployment.MaxEmploymentCount
			if 0 < lv and lv <= maxLv then
				self.Entity.PlayerEmployment:ModifyEmploymentLv(lv)
			else
				_UIToast:ShowMessage("범위 내의 값을 입력하세요.", self.UserId)
			end
			
		else
			_UIToast:ShowMessage("변경할 값을 입력하세요.", self.UserId)
		end
	end

