	@ExecSpace("ServerOnly")
	method void AddEmployee(string employeeID)
		-- 직원을 추가하는 치트 함수
		local player = self.Entity
		if not _UtilLogic:IsNilorEmptyString(employeeID) then 
			
			if isvalid(player.EmployeeManager:GetEmployeeDetail(employeeID)) then 
				_UIToast:ShowMessage("이미 보유 중인 츄츄입니다.", self.UserId)
				
			elseif not isvalid(_EmployeeService:GetData(employeeID)) then 
				_UIToast:ShowMessage("잘못된 employeeID를 입력했습니다.", self.UserId)
			
			else
				player.EmployeeManager:AddEmployee(employeeID,"Cheat")
				_UIToast:ShowMessage("Add Employee", self.UserId)
			end
		else 
			_UIToast:ShowMessage("츄츄 id를 입력하세요", self.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void AddAllEmployee()
		-- 모든 직원을 추가하는 치트 함수
		local player = self.Entity
		
		local dataSet = _DataService:GetTable("EmployeeDataSet")
		
		for _,row in pairs (dataSet:GetAllRow()) do 
			local id = row:GetItem("Id")
			player.EmployeeManager:AddEmployee(id,"Cheat")
		end
		
		_UIToast:ShowMessage("Add All Employee", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void RemoveEmployee(string employeeID)
		-- 직원을 제거하는 치트 함수
		local player = self.Entity
		
		local chuchuNum = #player.EmployeeManager.EmployeeDetailTable
		
		if not isvalid(_EmployeeService:GetData(employeeID)) then 
			_UIToast:ShowMessage("존재하지 않는 데이터입니다.", self.UserId)
			return 
			
		elseif chuchuNum <= 2 then 
			_UIToast:ShowMessage("삭제할 수 없습니다. 츄츄는 최소 2마리를 보유해야합니다.", self.UserId)
			return 
			
		else
			
			player.EmployeeManager:RequestTransferEmployee(employeeID,false,"Cheat")
		
			_UIToast:ShowMessage("Remove Employee ", self.UserId)
		end
		
		
	end

	@ExecSpace("ServerOnly")
	method void ChangeEmployeeLevel(string employeeID, string level)
		-- 직원 레벨을 변경하는 치트 함수
		local player = self.Entity
		
		if tonumber(level) < 1 then 
			_UIToast:ShowMessage("1이상의 숫자를 입력하세요.", self.UserId)
			return
		end 
		
		if tonumber(level) > 70 then
			level = tostring(70) 
		end
		
		local detail =  self.Entity.EmployeeManager:GetEmployeeDetail(employeeID, self.Entity.PlayerComponent.UserId)
		local overlimitLevel 
		if tonumber(level) >= _EmployeeService.MaxLevelListByOverLimitLevel[3] then 
			overlimitLevel = 3
		elseif tonumber(level) >= _EmployeeService.MaxLevelListByOverLimitLevel[2] then 
			overlimitLevel = 2
		elseif tonumber(level) >= _EmployeeService.MaxLevelListByOverLimitLevel[1] then 
			overlimitLevel = 1
		else
			overlimitLevel = 0	
		end
		player.EmployeeManager:UpdateDetailData(employeeID, "OverLimitLevel", _StringUtilLogic:NumToString(overlimitLevel))
		
		
		local type = _EmployeeService:GetData(employeeID).Type
		local result = self.Entity.EmployeeManager:UpdateDetailData(employeeID,type.."Level",level)
		
		if result then 
			_UIToast:ShowMessage("ChangeEmployeeLevel", self.UserId)
		else
			_UIToast:ShowMessage("최대 레벨을 넘어서 치트가 사용되지 않았습니다.", self.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void CallEvent(string eventGroupId, string referKey)
		-- 이벤트를 호출하는 치트 함수
		local player = self.Entity
		
		if _UtilLogic:IsNilorEmptyString(referKey) == false then
			_EventManager:SetEventReferKeyData(eventGroupId, referKey, self.UserId)
		end
		
		self.Entity.PlayerEvent:RequestCallEvent(eventGroupId)
		_UIToast:ShowMessage("Call Event", self.UserId)
	end

	@ExecSpace("ServerOnly")
	method void ChangeManagementLevel(string level)
		-- 경영 레벨을 변경하는 치트 함수
		local player = self.Entity
		
		if tonumber(level) > 5 then 
			_UIToast:ShowMessage("경영 등급 최대 입력값은 5입니다.", self.UserId)
		else
			player.PlayerManagement:SetManagementLevel(tonumber(level))
			player.PlayerStage:DrawStageClearRewardQueue()
			_UIToast:ShowMessage("ChangeManagementLevel", self.UserId)
		end
		
		
	end

	@ExecSpace("ServerOnly")
	method void ChangeManagementInprogress(string inprogress, string value)
		-- 경영 진행도를 변경하는 치트 함수
		local player = self.Entity
		
		if tonumber(inprogress) >= 5 then 
			_UIToast:ShowMessage("진척도 단계 최대 입력값은 4입니다.", self.UserId)
		else
		
			
		local playerManageCompo = player.PlayerManagement
		local nextLevel = playerManageCompo.ManagementLevel + 1
		local levelData = _ManagementDataSetLogic:GetManagementGoalData(player.PlayerStage.NowStage, nextLevel)
		if levelData == nil then
			return
		end
		
		local indexDatas = levelData.IndexData
		for idx, v in pairs(indexDatas) do
					
			if idx ~= tonumber(inprogress) then continue end 
		
			---@type ManagementGoalIndexData
			local indexData = v
					
			local achiId = indexData.AchievementType
			player.PlayerAchievement:RequestChangeProgress(achiId, tonumber(value))
			
			break
				
		end
			
		
			_UIToast:ShowMessage("ChangeManagementInprogress", self.UserId)
		end
	end

