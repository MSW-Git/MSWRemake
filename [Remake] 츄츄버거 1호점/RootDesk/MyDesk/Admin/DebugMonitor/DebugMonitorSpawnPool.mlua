@Component
script DebugMonitorSpawnPool extends Component

	property Entity MaxSpawnCountText = nil

	property Entity refreshBtn = nil

	property Entity CustomerInfoText = nil

	property table customer = {}

	property Entity customerGroup = nil

	property table textGroup = {}

	property integer nowPage = 1

	property Entity PageText = nil

	property Entity NowSpawnText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스폰 풀 모니터 UI 요소들을 초기화
		self.MaxSpawnCountText = self.Entity:GetChildByName("MaxSpawnCount")
		self.CustomerInfoText = self.Entity:GetChildByName("SpawnCustomer")
		self.refreshBtn = self.Entity:GetChildByName("RefreshBtn")
		self.PageText = self.Entity:GetChildByName("Page")
		self.NowSpawnText = self.Entity:GetChildByName("NowSpawn")
	end

	@ExecSpace("ClientOnly")
	method void UpdateMonitor()
		-- 고객 스폰 풀 데이터를 읽어서 모니터 UI에 표시
		table.clear(self.textGroup)
		self.nowPage = 1
		
		self.refreshBtn.SpriteGUIRendererComponent.Color = Color.white
		
		local player = _UserService.LocalPlayer
		local spawnPool = player.CustomerManager.CustomerSpawnDataTable
		local spawnPoolCount = 0
		local maxSpawnCount = player.CustomerManager.MaxCustomerSpawnNum
		local avatarPool = player.CustomerManager.AvatarPool
		
		if spawnPool == nil then 
			_UIToast:ShowMessage("스폰테이블이 없습니다.")
			return
		end
		
		for _,_ in pairs(spawnPool) do
			spawnPoolCount += 1
		end
		
		self.MaxSpawnCountText.TextComponent.Text = tostring(spawnPoolCount)
		
		self.NowSpawnText.TextComponent.Text = tostring(maxSpawnCount - #avatarPool)
		
		local spawnPoolText = ""
		local counter = 0
		local interval = 30
		local modelId = _EntryService:GetModelIdByName("Model_SpawnPoolInputText")
		
		for i, pool in pairs(spawnPool) do
			local num = i
			local group = pool.Group
			local orderCount = pool.OrderCount
			local requiredAttractive = pool.RequiredAttractive
			local targetTag = pool.TargetTag
			local tip = pool.Tip
			local uniqueId = pool.UniqueId
			local dataText = num..". "..group.." / "..orderCount.." / "..requiredAttractive.." / "..targetTag.." / "..tip.." / "..uniqueId.."\n"
			
			spawnPoolText = spawnPoolText..dataText
			counter = counter + 1
			
			if counter % interval == 0 then
				local entityName = "inputText"..#self.textGroup + 1
				local inputText
				if not isvalid(self.CustomerInfoText:GetChildByName(entityName)) then
					inputText = _SpawnService:SpawnByModelId(modelId,entityName,Vector3.zero,self.CustomerInfoText )
				else
					inputText = self.CustomerInfoText:GetChildByName(entityName)
				end
				inputText.TextComponent.Text = spawnPoolText
				inputText.Enable = false	
				table.insert(self.textGroup, inputText)
				spawnPoolText = ""
			end 
		end
		
		if spawnPoolText ~= "" then
			local entityName = "inputText"..#self.textGroup + 1
			local inputText
			if not isvalid(self.CustomerInfoText:GetChildByName(entityName)) then
				inputText = _SpawnService:SpawnByModelId(modelId,entityName,Vector3.zero,self.CustomerInfoText )
			else
				inputText = self.CustomerInfoText:GetChildByName(entityName)
			end
			inputText.TextComponent.Text = spawnPoolText
			inputText.Enable = false	
			table.insert(self.textGroup, inputText)
		end
		
		self.textGroup[1].Enable = true
		
		if #self.textGroup <= 1 then
			self.Entity:GetChildByName("NextBtn").Enable = false
			self.Entity:GetChildByName("PrevBtn").Enable = false
		else
			self.Entity:GetChildByName("NextBtn").Enable = true
			self.Entity:GetChildByName("PrevBtn").Enable = true
		end
		
		self.PageText.TextComponent.Text = self.nowPage .."/"..#self.textGroup
	end

	@ExecSpace("ClientOnly")
	method void PageChange(string type)
		-- 스폰 풀 데이터 페이지를 변경하여 다음/이전 페이지로 이동
		if #self.textGroup <= 1 then
			return
		end
		
		local nextPage = self.nowPage+1
		if self.nowPage +1 > #self.textGroup then
			nextPage = 1
		end
		
		local prevPage = self.nowPage -1 
		if self.nowPage -1 < 1 then
			prevPage = #self.textGroup
		end
		
		if type == "Next" then
			self.textGroup[self.nowPage].Enable = false
			self.textGroup[nextPage].Enable = true
			self.nowPage = nextPage
		elseif type == "Prev" then
			self.textGroup[self.nowPage].Enable = false
			self.textGroup[prevPage].Enable = true
			self.nowPage = prevPage
		end
		
		self.PageText.TextComponent.Text = self.nowPage .."/"..#self.textGroup
	end

	@ExecSpace("Client")
	method void ResetButtonHilight()
		-- 새로고침 버튼의 색상을 노란색으로 변경하여 업데이트 필요 상태 표시
		self.refreshBtn.SpriteGUIRendererComponent.Color = Color.yellow
	end

end