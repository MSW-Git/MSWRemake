@Component
script DebugMonitorUICustomer extends Component

	property integer InfoTextUiLength = 270

	property SyncTable<string, Entity> InfoEntityList

	property Entity CustomerEntity = nil

	property integer Id = 0

	property SyncTable<string, string> SpawnTableCategoryInfos

	property SyncTable<string, string> MapCategoryInfos

	property SyncTable<string, string> AiScriptCategoryInfos

	property string CategorySpawnTable = "SpawnTable"

	property string CategoryMap = "Map"

	property string CategoryAiScript = "AiScript"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 고객 디버그 모니터 UI를 초기화하고 데이터 설정
		local dataSet = _DataService:GetTable("DebugMonitorCustomerInfo")
		local player = _UserService.LocalPlayer
		table.clear(self.InfoEntityList)
		self.Id = 0
		
		for i = 1 , dataSet:GetRowCount() do
			
			local inforKey = dataSet:GetCell( i , 1)
			
			local entity = _SpawnService:SpawnByModelId(player.PlayerDebugMonitor.MonitorInfoText , inforKey , Vector3.zero, self.Entity)
			entity.UITransformComponent.RectSize.x = self.InfoTextUiLength
			entity.TextComponent.Text = inforKey.." :"
			self.InfoEntityList[inforKey] = entity
			
			local category = dataSet:GetCell( i , 2)
			local valueText = "text"
			
				
			if category == self.CategorySpawnTable then
				self.SpawnTableCategoryInfos[inforKey] = valueText
				
			elseif category == self.CategoryMap then
				self.MapCategoryInfos[inforKey] = valueText
			
			elseif category == self.CategoryAiScript then
				self.AiScriptCategoryInfos[inforKey] = valueText
			end
			
			entity.TextComponent.Text = inforKey.." : "..valueText
			
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSelectedCustomer(Entity customer)
		-- 선택된 고객 엔티티를 설정하고 모니터 정보를 업데이트
		self.CustomerEntity = customer
		self.Id = self.CustomerEntity.CustomerAIScript.Id 
		
		if isvalid(_UserService.LocalPlayer.PlayerDebugMonitor.CustomerInfoMonitor) then
			if _UserService.LocalPlayer.PlayerDebugMonitor.CustomerInfoMonitor.Enable == true then
				_UserService.LocalPlayer.PlayerDebugMonitor:UpdateCustomerInfoMonitor()
			end
		end
		
		self:SetUiSpawnTableInfo()
		self:SetUiMapInfo()
		self:SetUiAiScriptInfo()
	end

	@ExecSpace("ClientOnly")
	method void SetUiSpawnTableInfo()
		-- 고객의 스폰 테이블 정보를 UI에 설정
		
		local customerAIScript = self.CustomerEntity.CustomerAIScript
		local debugInfos = customerAIScript.DebugInfos
		local group = debugInfos["Group"]
		local targetTag = debugInfos["TargetTag"]
		local attractive = debugInfos["Attractive"]
		local orderCount = debugInfos["OrderCount"]
		local tip = debugInfos["DropTip"]
		
		for key , v in pairs(self.SpawnTableCategoryInfos) do
			
			if key == "Attractive" then
				self.InfoEntityList[key].TextComponent.Text = key.." : ".. tostring(attractive) .. " ( "..tostring(group).." )"
				
			elseif key == "TargetTag" then
				self.InfoEntityList[key].TextComponent.Text = key.." : ".. tostring(targetTag)
							
			elseif key == "OrderCount" then
				self.InfoEntityList[key].TextComponent.Text = key.." : ".. tostring(orderCount) 
				
			elseif key == "DropTip" then
				self.InfoEntityList[key].TextComponent.Text = key.." : ".. tostring(tip) 
				
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetUiMapInfo()
		-- 고객의 맵 관련 정보를 UI에 설정
		
		for key , v in pairs(self.MapCategoryInfos) do
			
			if key == "SortingLayer" then
				self.InfoEntityList[key].TextComponent.Text = key.." : ".. tostring(self.CustomerEntity.AvatarRendererComponent.SortingLayer) 
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void SetUiAiScriptInfo()
		-- 고객의 AI 스크립트 정보를 UI에 설정
		for key , v in pairs(self.AiScriptCategoryInfos) do
			if key == "RecipeUniqueId" then
				self.InfoEntityList[key].TextComponent.Text = key.." : "..tostring(self.CustomerEntity.CustomerAIScript.UniqueRecipeId)
				
			elseif key == "MoveSpeed" then
				local moveSpeed = self.CustomerEntity.MovementComponent.InputSpeed
				self.InfoEntityList[key].TextComponent.Text = key.." : "..tostring(math.floor(moveSpeed*1000)/1000).. "(unit/sec)"
				
			elseif key == "WaitingTime" then
				self.InfoEntityList[key].TextComponent.Text = key.." : "..tostring(self.CustomerEntity.CustomerAIScript.WaitTime) .."초"
			
			end	
			
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateWaitingTime(number time)
		-- 고객의 대기 시간을 실시간으로 업데이트
		local key = "WaitingTime"
		self.InfoEntityList[key].TextComponent.Text = key.." : "..tostring(time)
	end

end