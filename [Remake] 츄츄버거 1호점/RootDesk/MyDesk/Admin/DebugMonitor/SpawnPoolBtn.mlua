@Component
script SpawnPoolBtn extends Component

	property string Type = ""

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 스폰 풀 모니터의 버튼 클릭 이벤트를 타입에 따라 처리
		
		if self.Type == "Refresh" then
			self.Entity.Parent.DebugMonitorSpawnPool:UpdateMonitor()	
		elseif self.Type == "Next" then
			self.Entity.Parent.DebugMonitorSpawnPool:PageChange("Next")
		elseif self.Type == "Prev" then
			self.Entity.Parent.DebugMonitorSpawnPool:PageChange("Prev")
		end
		
		
	end

end