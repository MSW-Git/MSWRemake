@Component
script PlayerDebugMonitor extends Component

	property Entity DebugMonitorGroup = "d5a43539-b473-4515-bd0e-eaead82fbe5e"

	property Entity StoreInfoMonitor = nil

	property Entity CustomerInfoMonitor = nil

	property Entity EmployeeInfoMonitor = nil

	property Entity MaintainInfoMonitor = nil

	property Entity RecipeInfoMonitor = nil

	property string ModelStoreInfoMonitor = "model://503c0e6f-8aa3-47e5-8f37-a35da1f6eca6"

	property string ModelCustomerInfoMonitor = "model://7ce98a20-14cb-442e-bf83-e36630024688"

	property string MonitorInfoText = "model://07e92e59-b473-4b02-82cf-7523abf6a91a"

	property string ModelEmployeeInfoMonitor = "model://73b808a6-629b-4b6b-a8f2-6cab9e027b20"

	property string ModelmaintainInfoMonitor = "model://4a8fb004-d642-4cae-a9c9-7e182de96135"

	property Entity DebugTimer = "19da80a7-01b9-4aba-9da7-6175ef1002d1"

	property string EmployeeMonitorState = ""

	property Entity SpawnPoolMonitor = nil

	property string ModelSpawnPoolMonitor = "model://7d605d52-7ae0-4b85-b0eb-f0abde7d7ab2"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 디버그 모니터 그룹을 활성화하고 초기 상태 설정
		
		self.DebugMonitorGroup:SetEnable(true)
		self.DebugMonitorGroup.UIGroupComponent.DefaultShow = true
		self.EmployeeMonitorState = "Off"
	end

	@ExecSpace("Client")
	method void SpawnUIMonitorEntity()
		-- 모든 디버그 모니터 UI 엔티티들을 생성하고 위치 설정
		
		if not isvalid(self.StoreInfoMonitor) then
			self.StoreInfoMonitor = _SpawnService:SpawnByModelId(self.ModelStoreInfoMonitor,"StoreInfoMonitor",Vector3.zero,self.DebugMonitorGroup)
		
			self.StoreInfoMonitor.UITransformComponent.anchoredPosition.x = -20 
			self.StoreInfoMonitor.UITransformComponent.anchoredPosition.y = -80
		end
		
		if not isvalid(self.CustomerInfoMonitor) then
			self.CustomerInfoMonitor = _SpawnService:SpawnByModelId(self.ModelCustomerInfoMonitor,"CustomerInfoMonitor",Vector3.zero,self.DebugMonitorGroup)
			
			self.CustomerInfoMonitor.UITransformComponent.anchoredPosition.x = -170
			self.CustomerInfoMonitor.UITransformComponent.anchoredPosition.y = -670
		end
		
		if not isvalid(self.RecipeInfoMonitor) then
			self.RecipeInfoMonitor = _UIEntityService:GetOrCreateEntityOfModel("Model_UIRecipeDebug", 1, self.DebugMonitorGroup)
			self.RecipeInfoMonitor.UITransformComponent.anchoredPosition = Vector2(25, -25)
			
			self.RecipeInfoMonitor.Enable = false
			
		end
		
		if not isvalid(self.EmployeeInfoMonitor) then
			self.EmployeeInfoMonitor = _SpawnService:SpawnByModelId(self.ModelEmployeeInfoMonitor,"EmployeeInfoMonitor",Vector3.zero,self.DebugMonitorGroup)
			
			self.EmployeeInfoMonitor.UITransformComponent.anchoredPosition.x = 620
			self.EmployeeInfoMonitor.UITransformComponent.anchoredPosition.y = -50
		end
		
		if not isvalid(self.MaintainInfoMonitor) then
			self.MaintainInfoMonitor = _SpawnService:SpawnByModelId(self.ModelmaintainInfoMonitor,"ModelmaintainInfoMonitor",Vector3.zero,self.DebugMonitorGroup)
			
			self.MaintainInfoMonitor.UITransformComponent.anchoredPosition.x = -700
			self.MaintainInfoMonitor.UITransformComponent.anchoredPosition.y = -15
		end
		
		if not isvalid(self.SpawnPoolMonitor) then
			self.SpawnPoolMonitor = _SpawnService:SpawnByModelId(self.ModelSpawnPoolMonitor,"SpawnPoolMonitor",Vector3.zero, self.DebugMonitorGroup)
			self.SpawnPoolMonitor.UITransformComponent.anchoredPosition.x = -1000
			self.SpawnPoolMonitor.UITransformComponent.anchoredPosition.y = -50
			self.SpawnPoolMonitor.Enable = false
		end
		
		if isvalid(self.StoreInfoMonitor) then
			self:EnableStoreInfoMonitor(false)
		end
		if isvalid(self.CustomerInfoMonitor) then
			self:EnableCustomerInfoMonitor(false)
		end
		if isvalid(self.EmployeeInfoMonitor) then
			self:EnableEmployeeInfoMonitor(false)
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableStoreInfoMonitor(boolean enable)
		-- 상점 정보 모니터를 활성화/비활성화하고 관련 정보를 업데이트
		
		self.StoreInfoMonitor:SetEnable(enable)
		
		if enable == true then	
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:SetUiManagementInfo()
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:SetAttractiveInfo()	
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:SetReputationInfo()
			self:UpdateDebugMonitorReputationChangeByContents(0)
			self:EnableRecipeInfoMonitor(true)
			
		elseif enable == false then
			if isvalid(self.CustomerInfoMonitor) then
				if self.CustomerInfoMonitor.Enable == false then
					self:EnableRecipeInfoMonitor(false)	
				end
			end	
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableCustomerInfoMonitor(boolean enable)
		-- 고객 정보 모니터를 활성화/비활성화하고 정보를 업데이트
		self.CustomerInfoMonitor:SetEnable(enable)
		
		if enable then
			self:UpdateCustomerInfoMonitor()
			self:EnableRecipeInfoMonitor(true)
			
		elseif enable == false then
			if isvalid(self.StoreInfoMonitor) then
				if self.StoreInfoMonitor.Enable == false then
					self:EnableRecipeInfoMonitor(false)		
				end
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	method void UpdateCustomerInfoMonitor()
		-- 고객 정보 모니터의 표시 상태를 고객 ID에 따라 업데이트
		if self.CustomerInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUICustomer.Id == 0 then
		
			self.CustomerInfoMonitor:GetChildByName("InfoLayout").TextComponent.Enable = true
			
			for i , entity in ipairs(self.CustomerInfoMonitor:GetChildByName("InfoLayout").Children) do
				entity:SetEnable(false)
			end
		else
			self.CustomerInfoMonitor:GetChildByName("InfoLayout").TextComponent.Enable = false
			for i , entity in ipairs(self.CustomerInfoMonitor:GetChildByName("InfoLayout").Children) do
				entity:SetEnable(true)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableRecipeInfoMonitor(boolean enable)
		-- 레시피 정보 모니터들을 활성화/비활성화
		for i, entity in pairs(_UILobbyManager.MenuLayout.Children) do
			if isvalid(entity.UIMenuInfoComponent.DebugMonitor) then
				
				entity.UIMenuInfoComponent.DebugMonitor:SetEnable(enable)
				
			end	
		end
	end

	@ExecSpace("Client")
	method void UpdateDebugMonitorAttractive()
		-- 상점의 매력도 정보를 업데이트
		if isvalid(self.StoreInfoMonitor) then
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:SetAttractiveInfo()	
		end
		
	end

	@ExecSpace("Client")
	method void ResetDebugMonitorMonthlyReputation()
		-- 월간 평판 변화량을 리셋
		if isvalid(self.StoreInfoMonitor) then
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:ResetReputationChangeByReview()
		end
	end

	@ExecSpace("Client")
	method void UpdateDebugMonitorReputationChangeByContents(number reputationReward)
		-- 콘텐츠에 의한 평판 변화량을 업데이트
		if isvalid(self.StoreInfoMonitor) then
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:SetReputationChangeByContents(reputationReward)
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateDebugMonitorRecipeMaking(string key)
		-- 레시피 제작 모니터의 정보를 키에 따라 업데이트
		if isvalid(self.RecipeInfoMonitor) == false then
			return
		end
		
		if key == "Making" then
			self.RecipeInfoMonitor.UIRecipeDebug:RefreshMakingText()
		elseif key == "Result" then
			self.RecipeInfoMonitor.UIRecipeDebug:RefreshResultText()
		else
			self.RecipeInfoMonitor.UIRecipeDebug:RefreshMakingText()
			self.RecipeInfoMonitor.UIRecipeDebug:RefreshResultText()
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableEmployeeInfoMonitor(boolean enable)
		-- 직원 정보 모니터를 활성화/비활성화하고 정보를 업데이트
		self.EmployeeInfoMonitor:SetEnable(enable)
		
		if enable then
			self.EmployeeInfoMonitor.DebugMonitorUIEmployee:UpdateEmpDebugInfo()
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableMaintainInfoMonitor(boolean enable)
		-- 유지보수 정보 모니터를 활성화하고 비용 계산
		self.MaintainInfoMonitor:SetEnable(enable)
		self.MaintainInfoMonitor.DebugMonitorUIMaintain:Calcost()
	end

	@ExecSpace("Client")
	method void UpdateMonitor()
		-- 모든 모니터 정보를 업데이트
		if isvalid(self.MaintainInfoMonitor) then
			self.MaintainInfoMonitor.DebugMonitorUIMaintain:Calcost()
		end	
		if isvalid(self.EmployeeInfoMonitor) then
			self.EmployeeInfoMonitor.DebugMonitorUIEmployee:LevelSet()
		end
	end

	@ExecSpace("Client")
	method void UpdatePiggyBankInfo(integer requiredEarnings, integer PiggyBankEarnings)
		-- 저금통 정보를 업데이트
		if isvalid(self.StoreInfoMonitor) then
			self.StoreInfoMonitor:GetChildByName("InfoLayout").DebugMonitorUIStore:SetPiggyBankInfo(requiredEarnings, PiggyBankEarnings)	
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableSpawnPoolMonitor(boolean enable)
		-- 스폰 풀 모니터를 활성화하고 데이터를 업데이트
		self.SpawnPoolMonitor:SetEnable(enable)
		if enable then
			self.SpawnPoolMonitor.DebugMonitorSpawnPool:UpdateMonitor()	
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력으로 각종 디버그 모니터들을 토글하는 이벤트 처리
		
		local key = event.key
		
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		
		if Environment.WorldId == "21ad8c8b33f34d5aa8be5827a7b07246" then
			return
		end
		
		if key == KeyboardKey.F5 then
		
			if isvalid(self.StoreInfoMonitor) then
				
				if self.StoreInfoMonitor.Enable == false then
					self:EnableStoreInfoMonitor(true)
				else
					self:EnableStoreInfoMonitor(false)
				end
			end
			
		elseif key == KeyboardKey.F6 then
		
			if isvalid(self.CustomerInfoMonitor) then
				
				if self.CustomerInfoMonitor.Enable == false then
					self:EnableCustomerInfoMonitor(true)
				else
					self:EnableCustomerInfoMonitor(false)
				end
			end
			
		elseif key == KeyboardKey.F4 then
			
			if isvalid(self.RecipeInfoMonitor) then
				
				if self.RecipeInfoMonitor.Enable == false then
					if not (_UIGroupManager.RecipeGroup.Enable == true and _UIEntityLogic_RecipeGroup.UIRecipeMaking.Enable == true) then
						return
					end
				end	
						
				self.RecipeInfoMonitor.Enable = not self.RecipeInfoMonitor.Enable
				if self.RecipeInfoMonitor.Enable == true then
					self.RecipeInfoMonitor.UIRecipeDebug:OpenTab("Making")
				end
				
			end
			
		elseif key == KeyboardKey.F3 then
			
			if isvalid(self.DebugTimer) then
				if self.DebugTimer.Enable ~= true then
					self.DebugTimer.DebugTimer:Init()
				else
					self.DebugTimer.Enable = false
				end	
			end
			
		elseif key == KeyboardKey.F9 then
		
			if isvalid(self.EmployeeInfoMonitor) then
				
				if self.EmployeeInfoMonitor.Enable == false then
					self:EnableEmployeeInfoMonitor(true)
				else
					self:EnableEmployeeInfoMonitor(false)
				end
			end	
			
		elseif key == KeyboardKey.Comma then
			
			if isvalid(self.MaintainInfoMonitor) then
				if self.MaintainInfoMonitor.Enable == false then
					self:EnableMaintainInfoMonitor(true)
				else
					self:EnableMaintainInfoMonitor(false)
				end
			end
		
		elseif key == KeyboardKey.Period then
			if isvalid(self.SpawnPoolMonitor) then
				if self.SpawnPoolMonitor.Enable == false then
					self:EnableSpawnPoolMonitor(true)
				else
					self:EnableSpawnPoolMonitor(false)
				end
			end
		end
		
	end

end