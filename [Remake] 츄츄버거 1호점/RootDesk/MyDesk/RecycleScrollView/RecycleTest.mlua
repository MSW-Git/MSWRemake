@Component
script RecycleTest extends Component

	property table NewValue1 = {}

	property number NewValue2 = 2

	method void Function1(integer index, Entity cellItem)
		-- 스크롤뷰 셀 아이템의 텍스트를 현재 인덱스로 업데이트
		cellItem.TextComponent.Text = " Current : "..index
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스크롤뷰 초기화 및 테스트 데이터 설정
		self.Entity.RecycleScrollView.onUpdateCell = function(index, entity) self:Function1(index, entity) end
		
		table.insert(self.NewValue1, 32)
		table.insert(self.NewValue1, 32)
		table.insert(self.NewValue1, 32)
		table.insert(self.NewValue1, 32)
		table.insert(self.NewValue1, 32)
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력으로 스크롤뷰 테스트 기능 실행
		
		local key = event.key
		
		if key == KeyboardKey.M  then
			self.Entity.RecycleScrollView.TotalCount = 100
			
			self.Entity.RecycleScrollView:Refresh(false)
		end
		if key == KeyboardKey.K  then
			self.Entity.RecycleScrollView:SetTotalCount(self.NewValue2)
			self.NewValue2 += 1
		end
		
		if key == KeyboardKey.L  then
			self.Entity.RecycleScrollView:OnScroll(Vector2(30000,30000))
		end
		if key == KeyboardKey.J  then
			self.Entity.RecycleScrollView:OnDrag(Vector2(-10000,-1000))
		end
	end

end