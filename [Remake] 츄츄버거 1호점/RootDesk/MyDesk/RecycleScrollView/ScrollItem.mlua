@Struct
script ScrollItem

	property integer RealIndex = 0

	property integer CurrentIndex = 0

	property Entity Entity = nil

	method void Reset(integer realIndex, integer currentIndex)
		-- 스크롤 아이템의 인덱스 값들을 초기화
		self.RealIndex = 0
		self.CurrentIndex =  0
	end

	method void Init(integer realIndex, integer currentIndex, Entity entity)
		-- 스크롤 아이템을 실제 인덱스, 현재 인덱스, 엔티티로 초기화
		self.RealIndex = realIndex
		self.CurrentIndex = currentIndex
		self.Entity = entity
	end

end