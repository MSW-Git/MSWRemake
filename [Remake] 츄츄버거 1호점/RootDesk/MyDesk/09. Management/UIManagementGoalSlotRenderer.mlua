@Component
script UIManagementGoalSlotRenderer extends Component

	property Entity GoalText = nil

	property Entity ImgStarOn = nil

	property Entity GaugeBar = nil

	property Entity Tooltip = nil

	property Entity Right = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 관리 목표 슬롯의 하위 UI 요소들을 초기화하고 클릭 이벤트를 연결하는 함수
		self.ImgStarOn = self.Entity:GetChildByName("ImgStarOn")
		self.GaugeBar = self.Entity:GetChildByName("Gauge")
		self.GoalText = self.Entity:GetChildByName("Title")
		self.Tooltip = self.Entity:GetChildByName("Tooltip")
		self.Right = self.Entity:GetChildByName("Right")
		
		self.Entity:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_TooltipService:OpenTooltip(self.Tooltip, self._T.Desc)
		end)
		self.Tooltip.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void Refresh(ManagementGoalIndexData indexData, boolean isCompleted, integer index)
		-- 관리 목표 슬롯의 데이터와 완료 상태에 따라 UI를 갱신하는 함수
		local indexColor = function(a)
			if index == 1 then
				return _ColorCodeEnum:GetColor("#E1B2A5")
			elseif index == 2 then
				return _ColorCodeEnum:GetColor("#AAC9CC")
			elseif index == 3 then
				return _ColorCodeEnum:GetColor("#E7C37D")
			elseif index == 4 then
				return _ColorCodeEnum:GetColor("#A6CCB9")
			end
		end
		self.Right.SpriteGUIRendererComponent.Color = indexColor(index)
		
		self:RefreshGaugeBar(indexData)
		
		if isCompleted then
			self.ImgStarOn.Enable = true
		else
			self.ImgStarOn.Enable = false
		end
		
		self.GoalText.TextComponent.Text = _AchievementLogic:ReturnAchievementNameText(indexData.AchievementType, _AchievementLogic:GetFixedTypeValue(_UserService.LocalPlayer, indexData.AchievementType, indexData.TypeValue))
		
		self._T.Desc = _AchievementLogic:ReturnAchievementDescText(indexData.AchievementType)
	end

	@ExecSpace("ClientOnly")
	method void RefreshGaugeBar(ManagementGoalIndexData indexData)
		-- 목표 진행도에 따라 게이지 바를 업데이트하는 함수
		local player = _UserService.LocalPlayer
		local typeValue = _AchievementLogic:GetFixedTypeValue(player, indexData.AchievementType, indexData.TypeValue)
		
		local userTypeValue = player.PlayerAchievement:ReturnAchievementProgress(indexData.AchievementType)
		
		local sliderValue = userTypeValue/typeValue
		self.GaugeBar.SliderComponent.Value = sliderValue
		
		local userTypeValueText = _AchievementLogic:ReturnConvertedTypeValue(indexData.AchievementType, userTypeValue)
		local typeValueText = _AchievementLogic:ReturnConvertedTypeValue(indexData.AchievementType, typeValue)
		self.GaugeBar:GetChildByName("Text").TextComponent.Text = userTypeValueText.."/"..typeValueText
	end

end