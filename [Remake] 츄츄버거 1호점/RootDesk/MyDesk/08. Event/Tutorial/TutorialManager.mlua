@Logic
script TutorialManager extends Logic

	property UITransformComponent TopRight = "a52704a7-65e2-411a-b438-c710a262f128"

	property UITransformComponent TopLeft = "17f4c128-6951-4ac3-938c-eb5484a6918b"

	property UITransformComponent BottomLeft = "b34c6e9b-ad75-447c-9949-dee7d1496b14"

	property UITransformComponent BottomRight = "38060034-cbb6-4bf0-948e-d4e8b2a4887c"

	property Entity parent = "3b78b7bb-dcac-407f-a196-5af513e2bd3a"

	property Entity target = nil

	property Entity group = "88f05bcc-85ca-497c-9393-f519a2d2d085"

	property UITransformComponent Highlighting = "7c03f9ee-81d0-40b2-bf5f-b05bc99fe1c8"

	property Entity GuideText = "c85aa7e6-1b59-44ca-9d60-5ce15caf82e0"

	property Entity button = "fea362c8-b976-49e4-9a0d-9ee7003e2ea6"

	property number autoNextDelay = 0.8

	property number lastShowTime = 0

	@ExecSpace("ClientOnly")
	method boolean IsEnableOpenPopUp()
		-- 팝업을 열 수 있는지 시간 간격을 체크하는 함수
		local diff = _UtilLogic.ElapsedSeconds - self.lastShowTime
		
		if diff < 0.5 then
			return false
		end
		self.lastShowTime = _UtilLogic.ElapsedSeconds
		
		return true
	end

	@ExecSpace("ClientOnly")
	method Entity GetTargetEntity(TutorialData tutorialData)
		-- 튜토리얼 데이터에 따라 타겟 엔티티를 찾아 반환하는 함수
		if _UtilLogic:IsNilorEmptyString(tutorialData.TargetPathFix) then
			return _EntityService:GetEntityByPath(tutorialData.TargetPath)
			
		else
			local fixData = _UtilLogic:Split(tutorialData.TargetPathFix, ",")
			local fixKey = fixData[1]
			local fixParam = ""
			
			if isvalid(fixData[2]) then
				fixParam = _UtilLogic:Trim(fixData[2])
			end
			local parent = _EntityService:GetEntityByPath(tutorialData.TargetPath)
			if fixKey == "EmployeeManageList" then
				local empId = fixParam
				for i, child in pairs(parent.Children) do
					if child.UIEmployeeManageListRenderer.EmployeeId == empId then
						return child
					end
				end
				
			elseif fixKey == "Upgrade" then
				local upgradeId = math.floor(tonumber(fixParam))
				for i, child in pairs(parent.Children) do
					if child.UIUpgradeListSlot.typeId == upgradeId then
						return child
					end
				end
				
			elseif fixKey == "CustomerOrderTag" then
				for i, child in pairs(parent.Children) do
					if child.CustomerAIScript.Prefer == fixParam then
						if isvalid(child.CustomerAIScript.PeedbackUI) then
							if child.CustomerAIScript.PeedbackUI.Enable then
								return child
							end
						end				
					end
				end
				
			elseif fixKey == "RecipeListId" then
				for i, child in pairs(parent.Children) do
					local slotId = child.UIRecipeBurgerSlot.RecipeId
					if slotId == tonumber(fixParam) then
						return child
					end
				end
				
			elseif fixKey == "RecipeListFirstEnable" then
				for i, child in pairs(parent.Children) do
					if child.Enable then
						return child
					end
				end
				
			elseif fixKey == "RecipeListTrialBuff" then
				for i, child in pairs(parent.Children) do
					if child.Enable == false then
						continue
					end
					
					local burgerSlot = child.UIRecipeBurgerSlot
					if burgerSlot.TrialBuff.Enable then
						return burgerSlot.TrialBuff
					end
				end
				
			elseif fixKey == "CustomerFeedbackUI" then
				parent = _UserService.LocalPlayer.CurrentMap:GetChildByName("CustomerGroup")
				
				for i, child in pairs(parent.Children) do
					if isvalid(child.CustomerAIScript.PeedbackUI) then
						if child.CustomerAIScript.PeedbackUI.Enable and child.CustomerAIScript.PeedbackType == "discontent" and child.CustomerAIScript.CanUseWaitSpot then
							return child:GetChildByName("Model_PeedbackUI")
						end
					end		
				end
				
			elseif fixKey == "CustomerReview" then
				for i, child in pairs(parent.Children) do
					if isvalid(child.UICustomerReviewSlotRenderer) then
						if child.UICustomerReviewSlotRenderer.ReviewId == tonumber(fixParam) then
							return child
						end
					end
				end
				
				return parent 
				
			elseif fixKey == "LackOfStatEmployee" then
				parent = _UserService.LocalPlayer.CurrentMap
				
				for i, child in pairs(parent.Children) do
					if isvalid(child.EmployeeInfoScript) == false then
						continue
					end
						
					local peedbackUI = child.EmployeeInfoScript.PeedbackUI			
					local peedbackKey = child.EmployeeInfoScript.PeedbackKey
					if peedbackKey == "EmployeeUpgrade" and peedbackUI.Enable then
						return child
					end
				end
				
			elseif fixKey == "HaveTrainingSkillEmployee" then
				for i, child in pairs(parent.Children) do
					if child.Enable == false then
						continue
					end
					
					local skillIcon = child:GetChildByName("SkillIcon")
					if isvalid(skillIcon) then
						if skillIcon.Enable then
							return child
						end
					end
				end
				
			elseif fixKey == "BunId" then
				for i, child in pairs(parent.Children) do
					local bunId = child.UIBunSelectBtn.Index
					if bunId == tonumber(fixParam) then
						return child
					end
				end
				
			elseif fixKey == "ToDoItem" then
				for i, child in pairs(parent.Children) do
					local todoId = child.UIToDoItemRenderer.Id
					if todoId == tonumber(fixParam) then
						return child
					end
				end
				
			elseif fixKey == "SelectedEmpCollectionGroupSetBtn" then
				local uiChuchuCollection = parent.Parent.UIChuchuCollection
				local selectedGroup = _EmployeeService:GetData(uiChuchuCollection.SelectedChuchuId).GroupId
				
				uiChuchuCollection:ScrollToGroup(selectedGroup)
				wait(0.2)
				for i, child in pairs(parent.Children) do
					if child.Enable == true then
						local groupKey = child.UIChuchuCollectionSlot.GroupId
						if groupKey == selectedGroup then
							return child:GetChildByName("GroupPanel"):GetChildByName("SetBtn")
						end
					end
				end
				
			elseif fixKey == "SideMenuSetButton" then
				for i, child in pairs(parent.Children) do
					if child.UIStrategySlot.Id == tonumber(fixParam) then
						return child.UIStrategySlot.SM_SetBtn
					end
				end
				
			elseif fixKey == "FirstReviewEmpBtnHolder" then
				for i, child in pairs(parent.Children) do
					if child.Enable == true then 
						return child.UIEmployeeReviewSlotRenderer.ButtonHolder				
					end
				end
				
			end
		end
		
		return nil
	end

	@ExecSpace("ClientOnly")
	method void SetTargetPosition(Entity target, Entity parent)
		-- 타겟 엔티티의 위치를 부모에 맞춰 설정하는 함수
		target:AttachTo(parent)
		target.UITransformComponent.anchoredPosition = Vector2.zero
		target.UITransformComponent.Scale = Vector3.one
	end

	@ExecSpace("ClientOnly")
	method Entity MirroringUIParent(Entity target)
		-- 타겟 UI의 부모 구조를 미러링하여 튜토리얼 오버레이를 생성하는 함수
		local parents = {}
		
		self._T.getParent = function(entity)
			if entity.UIGroupComponent ~= nil then
				return nil
			end
			table.insert(parents,entity)
			self._T.getParent(entity.Parent)
		end
		
		self._T.getParent(target)
		
		local result = self.parent
		
		local uiUpdate = {}
		
		for i = 1, #parents do
			---@type Entity
			local entity = parents[#parents - i + 1]
			if isvalid(entity) then
				local empty = _SpawnService:SpawnByModelId("model://uiempty",entity.Name,entity.TransformComponent.Position,result)
				local emptyUI = empty.UITransformComponent
				local entityUI = entity.UITransformComponent
				local updateUI = function()
					emptyUI.anchoredPosition = entityUI.anchoredPosition
					
					
					emptyUI.RectSize = entityUI.RectSize
					emptyUI.AlignmentOption = entityUI.AlignmentOption
					emptyUI.OffsetMax = entityUI.OffsetMax
					emptyUI.OffsetMin = entityUI.OffsetMin
					emptyUI.Pivot = entityUI.Pivot
					emptyUI.Scale = entityUI.Scale
					
					
					emptyUI.ZRotation = entityUI.ZRotation
					emptyUI.AnchorsMin = entityUI.AnchorsMin		
					emptyUI.AnchorsMax = entityUI.AnchorsMax
				end
				table.insert(uiUpdate,updateUI)
				
				result = empty
			end
		end
		
		local updateHighlight = function() 
			self.Highlighting.Entity:AttachTo(result)
			self.Highlighting.OffsetMin = Vector2.zero
			self.Highlighting.OffsetMax = Vector2.zero
		end
		table.insert(uiUpdate,updateHighlight)
		updateHighlight()
		
		self._T.uiUpdateEventId = _TimerService:SetTimerRepeat(function() 
			
			for k,v in pairs(uiUpdate) do
				v()
			end
		
		end,0.1)
		
		return result
	end

	@ExecSpace("ClientOnly")
	method void ShowMask(TutorialData tutorialData, Entity target)
		-- 튜토리얼 마스크를 표시하고 가이드 텍스트를 배치하는 함수
		self:IsEnableOpenPopUp()
		
		self.target = target
		
		local isMapEntity = _UtilLogic:Contains(target.Path, "maps/")
		if isMapEntity then
			self:SetGuideTextPosition(target, AlignmentType.TopCenter,Vector2(0.5,1), Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
			self.GuideText.UITransformComponent.anchoredPosition = Vector2(0, -150)
			
			if tutorialData.ClickEntity then
				self._T.clickEntity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_ClickHereMapEntity"), "ClickEntity", Vector3.zero, target)
			end
			
			_SettlementUIService:ForceCloseUISettlement()
			
		else 
			
			local parent = self:MirroringUIParent(target)
			local targetUI = target.UITransformComponent
				
			local width = math.abs(targetUI.RectSize.x)
			local height = math.abs(targetUI.RectSize.y)
			self:SetTargetPosition(self.TopRight.Entity,parent)
			self:SetTargetPosition(self.BottomRight.Entity,parent)
			self:SetTargetPosition(self.BottomLeft.Entity,parent)
			self:SetTargetPosition(self.TopLeft.Entity,parent)
			self:SetTargetPosition(self.GuideText,parent)
			
			self.TopRight.anchoredPosition =  Vector2(-0.5 * width,height * 0.5) 
			self.BottomRight.anchoredPosition =  Vector2(0.5 * width,height * 0.5) 
			self.BottomLeft.anchoredPosition = Vector2(0.5 * width,-height * 0.5) 
			self.TopLeft.anchoredPosition = Vector2(-0.5 * width,-height * 0.5)
			
			if tutorialData.Alignment == "TopRight" then
				self.GuideText:AttachTo(self.TopRight.Entity)
				self:SetGuideTextPosition(target,AlignmentType.BottomLeft,self.TopRight.Pivot,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "BottomRight" then
				self.GuideText:AttachTo(self.BottomRight.Entity)
				self:SetGuideTextPosition(target,AlignmentType.TopLeft,self.BottomRight.Pivot,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "BottomLeft" then
				self.GuideText:AttachTo(self.BottomLeft.Entity)
				self:SetGuideTextPosition(target,AlignmentType.TopRight,self.BottomLeft.Pivot,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "TopLeft" then
				self.GuideText:AttachTo(self.TopLeft.Entity)
				self:SetGuideTextPosition(target,AlignmentType.BottomRight,self.TopLeft.Pivot,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "ScreenTopLeft" then
				self.GuideText:AttachTo(_UIGroupManager.TutorialGroup)
				self:SetGuideTextScreenPosition(target,AlignmentType.TopLeft,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "ScreenTopCenter" then
				self.GuideText:AttachTo(_UIGroupManager.TutorialGroup)
				self:SetGuideTextScreenPosition(target,AlignmentType.TopCenter,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "ScreenTopRight" then
				self.GuideText:AttachTo(_UIGroupManager.TutorialGroup)
				self:SetGuideTextScreenPosition(target,AlignmentType.TopRight,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "ScreenBottomLeft" then
				self.GuideText:AttachTo(_UIGroupManager.TutorialGroup)
				self:SetGuideTextScreenPosition(target,AlignmentType.BottomLeft,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "ScreenBottomCenter" then
				self.GuideText:AttachTo(_UIGroupManager.TutorialGroup)
				self:SetGuideTextScreenPosition(target,AlignmentType.BottomCenter,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			elseif tutorialData.Alignment == "ScreenBottomRight" then
				self.GuideText:AttachTo(_UIGroupManager.TutorialGroup)
				self:SetGuideTextScreenPosition(target,AlignmentType.BottomRight,Vector2(tutorialData.Offset.x, tutorialData.Offset.y))
				self.GuideText:AttachTo(parent)
				
			end
			
			if tutorialData.ClickEntity then
				self._T.clickEntity = _UIEntityService:GetOrCreateEntityOfModel("Model_ClickHereEntity", 1, parent)
			end
		end
		
		_UIGroupManager:EnableTutorialGroup(true)
		self.GuideText.Enable = tutorialData.TextVisible
		self.GuideText.TextComponent.Text = _GetLocalizationTextLogic:GetText(tutorialData.GuideTextKey)
		
		if tutorialData.AutoNext then
			_TimerService:SetTimerOnce(function()
				self:HideMask()
			end, self.autoNextDelay)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void HideMask()
		-- 튜토리얼 마스크를 숨기고 정리 작업을 수행하는 함수
		if self._T.uiUpdateEventId ~= nil then
			_TimerService:ClearTimer(self._T.uiUpdateEventId)
		end
		_UIGroupManager:EnableTutorialGroup(false)
		
		self.TopRight.Entity:AttachTo(self.group)
		self.BottomRight.Entity:AttachTo(self.group)
		self.BottomLeft.Entity:AttachTo(self.group)
		self.TopLeft.Entity:AttachTo(self.group)
		self.GuideText:AttachTo(self.group)
		self.Highlighting.Entity:AttachTo(self.group)
		for k,v in pairs(self.parent.Children) do
			v:Destroy()
		end
		
		self.target = nil
		self._T.forceTo = nil
		
		if isvalid(self._T.clickEntity) then
			_EntityService:Destroy(self._T.clickEntity)
		end
		
		if self._T.callbackHideMask ~= nil then
			self._T.callbackHideMask()
			self._T.callbackHideMask = nil
		end
		
		
		if self._T.callback ~= nil then
			self._T.callback()
			self._T.callback = nil
		else
			_EventManager:SetCanMoveNext(true)
			_EventManager:MoveNextDialog()
		end
	end

	@ExecSpace("ClientOnly")
	method void PlayTutorial(string id)
		-- 튜토리얼을 실행하고 설정에 따라 UI를 표시하는 함수
		local tutorialData = _TutorialDataSetLogic:GetTutorialData(id)
		if tutorialData == nil then 
			self:HideMask()
			return
		end
		
		if self.target ~= nil then 
			return
		end
		
		local target = self:GetTargetEntity(tutorialData)
		if isvalid(target) == false then 
			self:HideMask()
			return
		end
		
		self.Highlighting.Enable = tutorialData.Highlight
		self.TopLeft.Entity.Visible = tutorialData.Mask
		self.TopRight.Entity.Visible = tutorialData.Mask
		self.BottomLeft.Entity.Visible = tutorialData.Mask
		self.BottomRight.Entity.Visible = tutorialData.Mask
		self.button.Enable = true
		self._T.autoNext = tutorialData.AutoNext
		self._T.funcOnTouch = tutorialData.FuncOnTouch
		
		self.TopLeft.Entity.SpriteGUIRendererComponent.RaycastTarget = not tutorialData.TouchAnywhere
		self.TopRight.Entity.SpriteGUIRendererComponent.RaycastTarget = not tutorialData.TouchAnywhere
		self.BottomLeft.Entity.SpriteGUIRendererComponent.RaycastTarget = not tutorialData.TouchAnywhere
		self.BottomRight.Entity.SpriteGUIRendererComponent.RaycastTarget = not tutorialData.TouchAnywhere
		
		
		self:ShowMask(tutorialData, target)
		_UIGroupManager:EnableMoneyBarGroup(nil)
		
		if _UtilLogic:IsNilorEmptyString(tutorialData.funcCallback) == false then
			if tutorialData.funcCallback == "Wait" then
				local waitTime = tonumber(tutorialData.callbackParams[1])
				self._T.callback = function()
					_TimerService:SetTimerOnce(function()
						_EventManager:SetCanMoveNext(true)
						_EventManager:MoveNextDialog()
					end, waitTime)
				end
				
			elseif tutorialData.funcCallback == "OpenUI" then
				local uiType = tutorialData.callbackParams[1]
				local param2 = tutorialData.callbackParams[2]
				self._T.callback = function()
					self._T.functions[tutorialData.funcCallback](uiType, param2)
					_EventManager:SetCanMoveNext(true)
					_EventManager:MoveNextDialog()
				end
						
			elseif tutorialData.funcCallback == "CloseUI" then
				local uiType = tutorialData.callbackParams[1]
				self._T.callback = function()
					self._T.functions[tutorialData.funcCallback](uiType)
					_EventManager:SetCanMoveNext(true)
					_EventManager:MoveNextDialog()
				end		
						
			end
			
			
		end
		
		if _UtilLogic:IsNilorEmptyString(tutorialData.ForceTo) == false then
			local forceData = _UtilLogic:Split(tutorialData.ForceTo, ",")
			local forceKey = _UtilLogic:Trim(forceData[1])
			local forceParam = forceData[2]
			if _UtilLogic:IsNilorEmptyString(forceParam) == false then
				_UtilLogic:Trim(forceParam)
			end
			
			self:RegisterForceTo(forceKey, forceParam)
				
			self.button.Enable = false
		end
		
		if _UtilLogic:IsNilorEmptyString(tutorialData.funcExecute) == false then
			if tutorialData.funcExecute == "ZoomToTarget" then 
				self._T.functions[tutorialData.funcExecute](target)
				
			elseif tutorialData.funcExecute == "OpenUI" then 
				local uiType = tutorialData.executeParams[1]
				local param2 = tutorialData.executeParams[2]
				self._T.functions[tutorialData.funcExecute](uiType, param2)
				
			elseif tutorialData.funcExecute == "CloseUI" then
				local uiType = tutorialData.executeParams[1]
				self._T.functions[tutorialData.funcExecute](uiType)
				
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		-- 게임 종료 시 타이머를 정리하는 함수
		_TimerService:ClearTimer(self._T.uiUpdateEventId)
	end

	@ExecSpace("Client")
	method boolean SendTutorialTriggerEvent(table tutorialEventIdEnum)
		-- 튜토리얼 트리거 이벤트를 전송하는 함수
		local player = _UserService.LocalPlayer
		if player.PlayerTutorialEvent:IsEventOccured(tutorialEventIdEnum[1]) == false then
			local tutorialTrigger = TutorialTriggerEvent()
			tutorialTrigger.key = tutorialEventIdEnum[2]
			player:SendEvent(tutorialTrigger)
			return true
		end
		
		return false
	end

	@ExecSpace("ClientOnly")
	method boolean CheckForceTo()
		-- 강제 조건을 체크하는 함수
		if self._T.forceTo == nil then
			return true
		end
		
		return self._T.forceTo()
	end

	@ExecSpace("ClientOnly")
	method void RegisterFunction()
		-- 튜토리얼에서 사용할 함수들을 등록하는 함수
		self._T.functions = {}
		
		local openUI = function(param1, param2) 
			
			if param1 == "ToDo" then 
				if not _UILobbyManager.StoreInfoEnable then
					_UILobbyManager:ShowStoreInfoArea()
				end
				_UILobbyManager.StoreInfoArea.UIStoreInfoPageManager:SetTabPage(4)		
				
			elseif param1 == "Upgrade" then
				_UpgradeDataSetLogic.UIUpgradePanel.UIUpgradePanel:Open(tonumber(param2))
				
			elseif param1 == "TrainingGuidePopup" then
				_UIGroupManager.TrainingGroup.UITraining:EnableGuidePopup(true)
				
			elseif param1 == "StoreInfo" then
				_StoreInfoDataSetLogic.UIStoreInfo:Open(tonumber(param2), nil)
				
			elseif param1 == "EmployeeManage" then
				_UIEmployeeManageService:UIOpen()
				
			elseif param1 == "RecipeList" then
				_UIEntityLogic_RecipeGroup.UIRecipeBook.UIRecipeBook.NowSlot = 0
				_UIEntityLogic_RecipeGroup.UIRecipeList.UIRecipeListHolder:Open(nil, "Recipe", nil)
				
			elseif param1 == "Shop" then
				
				local uiShop = _EntityService:GetEntityByPath("/ui/UIShopGroup/UIShop")
				uiShop.UIShop:Open("GeneralShop", param2)
				
			elseif param1 == "StoreInfoRecord" then
				if not _UILobbyManager.StoreInfoEnable then
					_UILobbyManager:ShowStoreInfoArea()
				end
				_UILobbyManager.StoreInfoArea.UIStoreInfoPageManager:SetTabPage(1)
				
			elseif param1 == "MainMenu" then
				_UILobbyManager:OpenMainMenu()
				_UIGroupManager:EnableMoneyBarGroup(nil)
						
			elseif param1 == "ForceEmployeeManageAfterOverLimit" then
				_EmployeeUpgradeUIServcie:UIClose()
				_StoreInfoDataSetLogic.UIStoreInfo:Close()
				
				if _UIGroupManager.EmployeeManageGroup.Enable == false then
					_UIEmployeeManageService:UIOpen()
					local overLimitEmpId = ""
					for idx, detail in pairs(_UserService.LocalPlayer.EmployeeManager.EmployeeDetailTable) do
						---@type EmployeeDetailData
						local empDetail = detail
						
						if empDetail.OverLimitLevel >= 1 then
							overLimitEmpId = empDetail.Id
							break
						end
					end
								
					if _UtilLogic:IsNilorEmptyString(overLimitEmpId) == false then
						_UIEmployeeManageService:SelectEmp(overLimitEmpId, _UserService.LocalPlayer)
					end
					
				end		
			end
		end
		self._T.functions["OpenUI"] = openUI
		
		local closeUI = function(param)
			if param == "StoreInfo" then
				_UIGroupManager.StoreInfoGroup:GetChildByName("UIStoreInfo").UIStoreInfo:Close()
				
			elseif param == "EmployeeUpgrade" then
				_EmployeeUpgradeUIServcie:UIClose()	
				
			elseif param == "RecipeList" then
				_UIEntityLogic_RecipeGroup.UIRecipeList.UIRecipeListHolder:Close()
				
			elseif param == "Shop" then
				local uiShop = _EntityService:GetEntityByPath("/ui/UIShopGroup/UIShop")
				uiShop.UIShop:Close()
				
			elseif param == "Reward" then
				_UIItemRewardService:CloseUI()
				
			elseif param == "MainMenu" then
				_UILobbyManager:CloseMainMenu()
				
			elseif param == "Upgrade" then
				_UpgradeDataSetLogic.UIUpgradePanel.UIUpgradePanel:Close()
				
			elseif param == "VIPOrderNewSeasonPopup" then
				_VIPOrderDataSetLogic.UIVIPOrderNewSeasonPopup:Close()
				
			end
		end
		self._T.functions["CloseUI"] = closeUI
		
		local zoomToTarget = function(param)
			_LobbyCameraService:ChangeCameraTo("FullView")
				
			if isvalid(param.CameraComponent) == false then
				param:AddComponent(CameraComponent)
				param.Enable = true
				param.CameraComponent.Enable = true
			end
			
			param.CameraComponent.ZoomRatio = _LobbyCameraService:GetZoomRatio(80)
			param.CameraComponent.DeadZone = Vector2.zero
			param.CameraComponent.SoftZone = Vector2.zero
			param.CameraComponent.Damping = Vector2.zero
			param.CameraComponent.IsAllowZoomInOut = false
			
			_CameraService.TransitionBlendTime = 0
			_CameraService:SwitchCameraTo(param.CameraComponent)
			_CameraService:ZoomTo(150, 0)
		end
		self._T.functions["ZoomToTarget"] = zoomToTarget
		
		local clearAllUI = function()
			_UIGroupManager:ClearAllUI()
		end
		self._T.functions["ClearAllUI"] = clearAllUI
	end

	@ExecSpace("ClientOnly")
	method void RegisterForceTo(string forceKey, string forceParam)
		-- 튜토리얼 강제 조건들을 등록하는 함수
		if forceKey == "EmploymentEmployeeType" then
			self._T.forceTo = function()
				local selectedEmployee = _UIGroupManager.EmploymentGroup.UIEmployment.SelectedEmpButton.UIEmployeeManageListRenderer.EmployeeId
				if _EmployeeService:GetData(selectedEmployee) == nil then
					return false
				end
				
				if _EmployeeService:GetData(selectedEmployee).Type == _EmployeeStatEnumType.Serving then
					_EventManager:SetEventReferKeyData(_EventManager.CurrentEventGroupId, selectedEmployee)
					self:HideMask()
					return true
				end
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("TutorialForceToToastEmploymentEmployeeType"))
				return false
			end
			
		elseif forceKey == "TrainingSelectEmployee" then
			self._T.forceTo = function()
				local empSelectCount = _UIGroupManager.TrainingSettingGroup.UITrainingSetting:GetSelectedChuchuNum()
				if empSelectCount < tonumber(forceParam) then
					_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("TutorialForceToToastTrainingSelectEmployee"))
					return false
				end
				
				self:HideMask()
				return true
			end
				
		elseif forceKey == "TrainingSelectSpot" then
			self._T.forceTo = function()
				local lastPickSpot = _UserService.LocalPlayer.PlayerTrainingManager.LastPickSpot
				if lastPickSpot == nil then
					_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("TutorialForceToToastTrainingSelectSpot"))
					return false
				end
				
				self:HideMask()
				return true
			end
			
		elseif forceKey == "RecipeChoiceFunction" then
			self._T.forceTo = function()
				self:HideMask()
				return true
			end
			
		elseif forceKey == "SelectLevelUpItems" then
			self._T.forceTo = function()
				local uiEmployeeUpgrade = _EmployeeUpgradeUIServcie.UIEmployeeUpgradeCompo
				
				local noneSelectItem = true 
				for k,v in pairs(uiEmployeeUpgrade.selectItems)do 
					if isvalid(v) then 
						if v ~= 0 then 
							noneSelectItem = false 
						end		
					end
				end
				
				if noneSelectItem then
					_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("TutorialForceToToastSelectLevelUpItems"))	
					return false
					
				end
				
				self:HideMask()
				return true
			end
			
		elseif forceKey == "SetEmployee" then
			local player = _UserService.LocalPlayer
			self._T.forceTo = function()
				local clientLocations = _UIEmployeeManageService.UIManageCompo.employeesLocation
				local userSetCount = 0
				for _, employeeData in pairs(clientLocations) do
					local empData = player.EmployeeManager:GetEmployeeDetail(employeeData.Id)
					if not isvalid(empData) then continue end
					
					---@type EmployeeLocationData
					local locationData = employeeData
				
					if locationData.Location == _EmployeeTypeEnum.Waiting then continue end
					userSetCount += 1			
				end
				
				if userSetCount >= tonumber(forceParam) then
					self:HideMask()
					return true
				end
				
				return false
			end
			
		elseif forceKey == "SetStartingEmployee" then
			self._T.forceTo = function()
				self:HideMask()
				return true
			end
			
		elseif forceKey == "SetStrategy" then
			self._T.forceTo = function()
				self:HideMask()
				return true
			end
			
		elseif forceKey == "SetPromotedIngre" then
			self._T.forceTo = function()
				self:HideMask()
				return true
			end
			
		elseif forceKey == "ClearAllUI" then
			self._T.forceTo = function()
				self:HideMask()
				return true
			end			
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 함수를 등록하는 함수
		self:RegisterFunction()
	end

	@ExecSpace("ClientOnly")
	method void SetCallbackHideMask(any callback)
		-- 마스크 숨김 콜백을 설정하는 함수
		self._T.callbackHideMask = callback
	end

	@ExecSpace("ClientOnly")
	method void SetGuideTextPosition(Entity target, any alignment, Vector2 pivot, Vector2 offset)
		-- 가이드 텍스트의 위치를 설정하는 함수
		local originPos
		if isvalid(target.UITransformComponent) then
			local targetSize = target.UITransformComponent.RectSize
			if alignment == AlignmentType.TopRight then
				originPos = Vector2(-targetSize.x/3, -targetSize.y/2)
			elseif alignment == AlignmentType.TopLeft then
				originPos = Vector2(targetSize.x/3, -targetSize.y/2)
			elseif alignment == AlignmentType.BottomRight then
				originPos = Vector2(-targetSize.x/3, targetSize.y/2)
			elseif alignment == AlignmentType.BottomLeft then
				originPos = Vector2(targetSize.x/3, targetSize.y/2)
			end
		end
		
		
		if originPos == nil then
			originPos = Vector2.zero
		end
		
		self.GuideText.UITransformComponent.AlignmentOption = alignment
		self.GuideText.UITransformComponent.Pivot = pivot
		self.GuideText.UITransformComponent.anchoredPosition = originPos + offset
	end

	@ExecSpace("ClientOnly")
	method void SetGuideTextScreenPosition(Entity target, any alignment, Vector2 offset)
		-- 화면 기준으로 가이드 텍스트의 위치를 설정하는 함수
		local moveVec = 100
		local originPos = Vector2.zero
		
		if isvalid(target.UITransformComponent) then
			
			if alignment == AlignmentType.TopLeft then
				self.GuideText.UITransformComponent.Pivot = Vector2(0, 1)
				originPos = Vector2(moveVec, -moveVec)
			elseif alignment == AlignmentType.TopCenter then
				self.GuideText.UITransformComponent.Pivot = Vector2(0.5, 1)
				originPos = Vector2(0, -moveVec)
			elseif alignment == AlignmentType.TopRight then
				self.GuideText.UITransformComponent.Pivot = Vector2(1, 1)
				originPos = Vector2(-moveVec, -moveVec)
			elseif alignment == AlignmentType.BottomLeft then
				self.GuideText.UITransformComponent.Pivot = Vector2(0, 0)
				originPos = Vector2(moveVec, moveVec)
			elseif alignment == AlignmentType.BottomCenter then
				self.GuideText.UITransformComponent.Pivot = Vector2(0.5, 0)
				originPos = Vector2(0, moveVec)
			elseif alignment == AlignmentType.BottomRight then
				self.GuideText.UITransformComponent.Pivot = Vector2(1, 0)
				originPos = Vector2(-moveVec, moveVec)
			end
			
			self.GuideText.UITransformComponent.AlignmentOption = alignment
			self.GuideText.UITransformComponent.anchoredPosition = originPos + offset
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "fea362c8-b976-49e4-9a0d-9ee7003e2ea6")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 튜토리얼 버튼 클릭을 처리하고 타겟 엔티티의 이벤트를 전달하는 핸들러
		
		local Entity = event.Entity
		if self:IsEnableOpenPopUp() == false then
			return
		end
		
		
		if isvalid(self.target) == false then
		    return
		end
		
		if self._T.autoNext then
			return
		end
		
		if self._T.funcOnTouch == false then
			self:HideMask()
			return
		end
		
		if isvalid(self.target.ButtonComponent) then
		    self.target:SendEvent(ButtonClickEvent(self.target))
		end
		
		if isvalid(self.target.InteractionScript) then
			self.target.InteractionScript:OnTouch()
		end
		
		if isvalid(self.target.InteractionTipScript) then
			self.target.InteractionTipScript:GetItem(_UserService.LocalPlayer)
		end
		
		if isvalid(self.target.InteractionPeedbackScript) then
			self.target.InteractionPeedbackScript:OnTouch()
		end
		
		self:HideMask()
	end

end