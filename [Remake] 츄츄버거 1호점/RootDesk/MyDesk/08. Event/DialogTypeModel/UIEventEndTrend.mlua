@Component
script UIEventEndTrend extends Component

	property Entity EventTitle = nil

	property Entity Frame = nil

	property Entity TagIcon = nil

	property Entity DialogText = nil

	property Entity Cross = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 트렌드 종료 이벤트 UI 요소들을 초기화하는 함수
		self.EventTitle = self.Entity:GetChildByName("EventTitle")
		self.Frame = self.Entity:GetChildByName("Frame")
		
		local tagHolder = self.Frame:GetChildByName("TagHolder")
		self.TagIcon = tagHolder:GetChildByName("TagIcon")
		self.DialogText = self.Entity:GetChildByName("DialogText")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(EventDialogData dialogData)
		-- 트렌드 종료 이벤트 정보를 화면에 표시하고 보고서를 생성하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		local isPositive = dialogData.TitleInfo[1]
		
		local tag = _UserService.LocalPlayer.PlayerEvent.EventReferKey[dialogData.EventGroupId]
		---@type RecipeTagData
		local tagData = _RecipeTagDataSetLogic.RecipeTagData[tag]
		
		if isPositive == "TRUE" or isPositive == "True" or isPositive == "true" then
			self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventTitlePositiveTrendEnd")
			_ReportMessageMaker:RequestAddToReportQueue(5003, _GetLocalizationTextLogic:GetText(tagData.TagNameKey), "", "")
		else
			self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventTitleNegativeTrendEnd")
			_ReportMessageMaker:RequestAddToReportQueue(5004, _GetLocalizationTextLogic:GetText(tagData.TagNameKey), "", "")
		end
		
		
		if isvalid(tagData) then
			self.TagIcon.SpriteGUIRendererComponent.ImageRUID = tagData.IconRUID
		end
		
		self.DialogText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.DialogInfoKey, _GetLocalizationTextLogic:GetText(tagData.TagNameKey))
		_SoundService:PlaySound(_ResourceManager.SFXTable["Popup_TrendEnd"], 1)
	end

	@ExecSpace("ClientOnly")
	method void Reset()
		-- UI 요소들을 초기 상태로 되돌리는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.TagIcon.SpriteGUIRendererComponent.ImageRUID = _StringUtilLogic.EmptyRUID
	end

end