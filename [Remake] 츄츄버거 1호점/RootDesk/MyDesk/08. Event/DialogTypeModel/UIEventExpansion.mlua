@Component
script UIEventExpansion extends Component

	property Entity HideLayer = nil

	property string LoadingMaterial = "material://eb4373c5-909b-4449-b57f-b6c3496b4a9c"

	property SoundComponent LoadingSFX = nil

	property Entity WhiteLayer = nil

	property Entity Toast = nil

	property SyncTable<integer, Vector3> CameraLBBounds

	property SyncTable<integer, Vector3> CameraRTBounds

	property string referKey = ""

	@ExecSpace("ClientOnly")
	method void Init()
		-- 확장 이벤트 UI 요소들과 카메라 경계를 초기화하는 함수
		self.HideLayer = self.Entity:GetChildByName("HideLayer")
		self.LoadingSFX = self.Entity:GetChildByName("LoadingSFX").SoundComponent
		self.WhiteLayer = self.Entity:GetChildByName("WhiteLayer")
		self.Toast = self.Entity:GetChildByName("Toast")
		
		self.CameraLBBounds[1] = Vector3(-8.5, 0, 1)
		self.CameraRTBounds[1] = Vector3(10.5, 8, 1)
		
		self.CameraLBBounds[2] = Vector3(-8, 0, 1)
		self.CameraRTBounds[2] = Vector3(12, 9, 1)
		
		self.CameraLBBounds[3] = Vector3(-11, 0, 1)
		self.CameraRTBounds[3] = Vector3(16, 13, 1)
		
		self.CameraLBBounds[4] = Vector3(-9.5, 0, 1)
		self.CameraRTBounds[4] = Vector3(18, 13.5, 1)
		
		self.CameraLBBounds[5] = Vector3(-5.5, 0, 1)
		self.CameraRTBounds[5] = Vector3(22, 13.5, 1)
		
		self.CameraLBBounds[6] = Vector3(-5, 0, 1)
		self.CameraRTBounds[6] = Vector3(22, 14, 1)
	end

	@ExecSpace("ClientOnly")
	method void StartRender()
		-- 확장 이벤트 렌더링을 시작하고 초기 설정을 진행하는 함수
		if self.HideLayer == nil then
			self:Init()
		end
		
		self.referKey = _UserService.LocalPlayer.PlayerEvent.EventReferKey[_EventManager.CurrentEventGroupId]
		if _UtilLogic:IsNilorEmptyString(self.referKey) then
			self.referKey = "Expansion"
		end
		self:SetToastInfo(self.referKey)
		
		self.LoadingSFX.Enable = false
		self.WhiteLayer.Enable = false
		
		self.Toast.Enable = false
		
		_UIGroupManager:EnableMoneyBarGroup(false)
		_UIGroupManager:EnableLobbyHUDGroup(false)
		
		_EventUIManager.Dim.Enable = false
		
		self:ChangePhase(0)
	end

	@ExecSpace("ClientOnly")
	method void EndRender()
		-- 렌더링을 종료하고 다음 단계로 이동을 허용하는 함수
		_EventManager:SetCanMoveNext(true)
	end

	@ExecSpace("ClientOnly")
	method void ChangePhase(integer phase)
		-- 지정된 단계로 변경하는 함수
		self:PhaseFunction(phase)
	end

	@ExecSpace("ClientOnly")
	method void PhaseFunction(integer phase)
		-- 단계별 확장 애니메이션을 실행하는 함수
		local player = _UserService.LocalPlayer
		local expansionLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.ExpansionStep)
		local interiorLv = _UpgradeDataSetLogic:ReturnCurrentPlayerLevel(player, _UpgradeTypeEnum.InteriorLevel)
		local decoLv = _UpgradeDataSetLogic:ReturnCurrentPlayerLevel(player, _UpgradeTypeEnum.StoreDeco)
		
		local grillCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.GrillCount)
		local displayCount = _KitchenAppService:ReturnDisplayNum(player)
		local counterCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.CounterCount)
		
		local duration = 1
		local cameraDuration = 2
		
		if phase == 0 then
			self.HideLayer.Enable = true
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_InteriorConstruct_v2"], 1)
			
			
			
			_TimerService:SetTimerOnce(function()
				
				if self.referKey == "Expansion" then
					_LobbyRenovationService:ExpandLobby(expansionLv,interiorLv,decoLv,grillCount,displayCount,counterCount,player)
				elseif self.referKey == "Interior" then
					_LobbyRenovationService:RedesignInterior(interiorLv,expansionLv, decoLv)
					_KitchenAppService:VisibleKitAppsEntity(expansionLv,interiorLv,grillCount,displayCount,counterCount)
				end
						
				self:ChangePhase(1)
			end, cameraDuration)
			
		elseif phase == 1 then 
			self.HideLayer.Enable = false
			self.WhiteLayer.Enable = true
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_CamMovingInterior"], 1)
			_TweenLogic:PlayTween(1, 0, duration, EaseType.Linear, function(t)
				self.WhiteLayer.CanvasGroupComponent.GroupAlpha = t
			end)
			
			self:StartCameraTween(expansionLv, "CookingView", cameraDuration, Vector2(-1, 0))
			
			_TimerService:SetTimerOnce(function()
				self:ChangePhase(2)
			end, cameraDuration)
			
		elseif phase == 2 then 
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_CamMovingInterior"], 1)
			_TweenLogic:PlayTween(1, 0, duration, EaseType.Linear, function(t)
				self.WhiteLayer.CanvasGroupComponent.GroupAlpha = t
			end)
			
			self:StartCameraTween(expansionLv, "EntranceView", cameraDuration, Vector2(1, 0))
			
			_TimerService:SetTimerOnce(function()
				self:ChangePhase(3)
			end, cameraDuration)
			
		elseif phase == 3 then 
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_CamMovingZoomOut"], 1)
			_TweenLogic:PlayTween(1, 0, duration, EaseType.Linear, function(t)
				self.WhiteLayer.CanvasGroupComponent.GroupAlpha = t
			end)
			
			self:StartCameraTween(expansionLv, "FullView", cameraDuration, Vector2.zero)
			
			_TimerService:SetTimerOnce(function()
				self.WhiteLayer.Enable = false
				self:ChangePhase(4)
				
			end, cameraDuration)
			
		elseif phase == 4 then
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Audience"], 1)
			_SoundService:PlayLoopSound(_ResourceManager.SFXTable["Firework"], 1)
			
			self:SetParticlesPos()
			_LobbyEntityLogic.ExpansionParticles.Enable = true
				
		    _EventUIManager.ConfettiSpawner.UIEventConfettiSpawner:StartSpawnConfetties()
			
			self:StartToastTween(duration)
			self:MakeReport(self.referKey)
			
			_TimerService:SetTimerOnce(function()
				self:ChangePhase(5)
			end, cameraDuration)
			
			
		elseif phase == 5 then 
			
			self:EndRender()
			
		end
	end

	@ExecSpace("ClientOnly")
	method void StartCameraTween(integer level, string key, number duration, Vector2 direction)
		-- 카메라 전환 애니메이션을 시작하는 함수
		local cameraData = _CameraDataSetLogic:GetLobbyCameraData(level)
		
		_LobbyCameraService:ChangeCameraTo(key)
		
		local cameraComponent = _LobbyCameraService.lobbyCameras[key]
		local cameraPos = cameraComponent.Entity.TransformComponent.Position
		local cameraZoomRatio = _LobbyCameraService:GetZoomRatio(cameraComponent.ZoomRatio)
		
		local moveVec = 1
		local startPos = Vector3(cameraPos.x + (-direction.x *  moveVec), cameraPos.y + (-direction.y * moveVec), 1)
		local endPos = Vector3(cameraPos.x + (direction.x * moveVec), cameraPos.y + (direction.y * moveVec), 1)
		
		local moveZoom = 50
		local startZoomRatio = key == "FullView" and cameraZoomRatio + moveZoom or cameraZoomRatio
		local endZoomRatio = cameraZoomRatio
		
		local movingCamera = _LobbyCameraService.lobbyCameras["MovingCamera"]
		
		_TweenLogic:PlayTween(0, 1, duration, EaseType.Linear, function(t)
			movingCamera.Entity.TransformComponent.Position = Vector3.Lerp(startPos, endPos, t)
			movingCamera.ZoomRatio = self:Lerp(startZoomRatio, endZoomRatio, t)
		end)
		
	end

	@ExecSpace("ClientOnly")
	method void StartToastTween(number duration)
		-- 완료 토스트 메시지 애니메이션을 시작하는 함수
		self.Toast.CanvasGroupComponent.GroupAlpha = 0
		self.Toast.Enable = true
		
		local endPos = Vector2(0, -200)
		local yTweenValue = 100
		local startPos = Vector2(endPos.x, endPos.y - yTweenValue)
		
		_TweenLogic:PlayTween(startPos, endPos, duration, EaseType.SineEaseIn, function(t)
			self.Toast.UITransformComponent.anchoredPosition = t
		end)
		
		_TweenLogic:PlayTween(0, 1, duration, EaseType.SineEaseIn, function(t)
			self.Toast.CanvasGroupComponent.GroupAlpha = t
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetParticlesPos()
		-- 확장 레벨에 맞는 파티클 이팩트 위치를 설정하는 함수
		local parent = _LobbyEntityLogic.ExpansionParticles
		
		local firework1 = parent:GetChildByName("Firework1")
		local firework2 = parent:GetChildByName("Firework2")
		local fireworkCluster = parent:GetChildByName("FireworkCluster")
		
		local firework1Pos = Vector2(0.75, 0.1)
		local firework2Pos = Vector2(0.2, 0.4)
		local fireworkClusterPos = Vector2(0.85, 0.75)
		
		local player = _UserService.LocalPlayer
		local level = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.ExpansionStep)
		local nowLB = self.CameraLBBounds[level]
		local nowRT = self.CameraRTBounds[level]
		
		local xSub = nowRT.x - nowLB.x
		local ySub = nowRT.y - nowLB.y
		
		firework1.TransformComponent.Position = Vector3(nowLB.x + xSub*firework1Pos.x, nowLB.y + ySub*firework1Pos.y, 1)
		firework2.TransformComponent.Position = Vector3(nowLB.x + xSub*firework2Pos.x, nowLB.y + ySub*firework2Pos.y, 1)
		fireworkCluster.TransformComponent.Position = Vector3(nowLB.x + xSub*fireworkClusterPos.x, nowLB.y + ySub*fireworkClusterPos.y, 1)
	end

	@ExecSpace("ClientOnly")
	method void SetToastInfo(string referKey)
		-- 토스트 아이콘과 텍스트를 설정하는 함수
		local icon = self.Toast:GetChildByName("Icon_Upgrade")
		local text = self.Toast:GetChildByName("Text")
		
		if referKey == "Expansion" then
			icon.SpriteGUIRendererComponent.ImageRUID = _EventDataSetLogic.OpenFunctionRUIDs["Expansion"]
			text.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventExpansionEnd")
			
		elseif referKey == "Interior" then
			icon.SpriteGUIRendererComponent.ImageRUID = _EventDataSetLogic.OpenFunctionRUIDs["Interior"]
			text.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventInteriorEnd")
			
		end
	end

	@ExecSpace("ClientOnly")
	method void MakeReport(string referKey)
		-- 확장/인테리어 업그레이드 보고서를 생성하는 함수
		local player = _UserService.LocalPlayer
		
		if self.referKey == "Expansion" then
			local levelValue = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.ExpansionStep)
			_ReportMessageMaker:RequestAddToReportQueue(8004, tostring(levelValue), "", "")
			
		elseif self.referKey == "Interior" then
			local level = _UpgradeDataSetLogic:ReturnCurrentPlayerLevel(player, _UpgradeTypeEnum.InteriorLevel)
			local interiorName = _GetLocalizationTextLogic:GetText("InteriorLevel"..level)
			_ReportMessageMaker:RequestAddToReportQueue(8005, interiorName, "", "")
			
		end
	end

	method number Lerp(number a, number b, number t)
		-- 두 값 사이를 선형 보간하는 함수
		return a + (b-a) * t
	end

end