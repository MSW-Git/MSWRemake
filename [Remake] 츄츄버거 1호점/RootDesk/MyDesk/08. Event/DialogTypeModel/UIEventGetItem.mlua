@Component
script UIEventGetItem extends Component

	property Entity EventTitle = nil

	property Entity Item = nil

	property Entity DialogText = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 아이템 획득 이벤트 UI 요소들을 초기화하는 함수
		self.EventTitle = self.Entity:GetChildByName("EventTitle")
		local itemHolder = self.Entity:GetChildByName("ItemHolder")
		self.Item = _UIEntityService:GetOrCreateEntityOfModel("Model_UIItemRewardSlot", 1, itemHolder)
		self.DialogText = self.Entity:GetChildByName("DialogText")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(EventDialogData dialogData)
		-- 아이템 획득 이벤트 UI를 새로고침하고 획득한 아이템을 표시하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventTitleGetItem")
		
		---@type EventGroupData
		local eGroupData = _EventDataSetLogic.EventGroupData[dialogData.EventGroupId]
		
		local itemId = dialogData.TitleInfo[1]
		local itemCount = dialogData.TitleInfo[2]
		
		if itemId == "ReferKey" then
			for i = 1, #eGroupData.funcRewardPairs do
				local rewardData = eGroupData.funcRewardPairs[i]
				local rewardId = rewardData[1]
					if rewardId == "GetItem" then
						local params = rewardData[2]
						itemId = params[1]
						itemCount = params[2]
						break			
					end
			end
			
		end
		
		self.Item.UIItemRewardSlot:SetItem(itemId, tonumber(itemCount))
		
		self.DialogText.TextComponent.Text = _GetLocalizationTextLogic:GetText(dialogData.DialogInfoKey)
		_SoundService:PlaySound(_ResourceManager.SFXTable["GetItem"], 1)
	end

	@ExecSpace("ClientOnly")
	method void Reset()
		-- 아이템 획득 이벤트 UI를 초기 상태로 리셋하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.Item.UIItemRewardSlot:ResetItemRUID()
	end

end