@Logic
script TrialResultUILogic extends Logic

	property Entity ResultUI = "8cee6e1a-6ebb-4fcc-a998-47895b67ba41"

	property Entity LayoutUI = "8792f26f-2d5e-4b32-ab18-69c9608e65b0"

	property Entity ScreenUI = "5116559b-2543-473a-8718-331e868bc54b"

	property integer phase = 0

	property Vector2 CharInfoStartPos = Vector2(0,-407)

	property Vector2 CharInfoOriginPos = Vector2(-305,-407)

	property Vector2 NameInfoStartPos = Vector2(0,-355)

	property Vector2 NameInfoOriginPos = Vector2(0,-155)

	property Vector2 TrialInfoStartPos = Vector2(2000,-457)

	property Vector2 TrialInfoOriginPos = Vector2(214,-457)

	property Entity CharInfoEntity = "95d048ba-a89c-47a4-8ab2-ce581651f070"

	property Entity TrialInfoEntity = "06d392c6-4825-4984-aa13-6fa3df7a1516"

	property Entity TargetImageEntity = "d572b054-ca68-4858-87c0-b4d8baea310c"

	property Entity ResultEffectEntity = "5288d80b-d09a-4454-abe8-6d1202c9f6b2"

	property boolean isPlayerWinner = false

	property Entity TrialTitleText = "1a57aa88-b0a7-4378-bd91-10d9d1cfef92"

	property Entity RankListEntity = "d8b70153-70cc-4904-9e07-7da524015b56"

	property Entity RewardListEntity = "4da26b6b-1540-4adc-8dc4-acdfa3f6e515"

	property Entity ResultWinText = "e2c9ae52-f426-4957-a430-885aa295af71"

	property Entity ResultLoseText = "837de8ff-d82d-4d91-aa67-fdc26b9cedf1"

	property Entity FeedbackText = "d8bf5e74-8c13-4c5b-922a-bef5e188eedc"

	property Entity RewardInfo = "82003888-5844-4fb6-bf1f-5b17fac434a1"

	property Entity WinEffect = "298d0432-48e9-4046-aa4b-2a7b89836586"

	property Entity LoseEffect = "3cbe949e-431c-4d07-aeab-f6d1f90c050d"

	property Entity FailAnimHolder = "3a937ff9-1b30-4119-99bb-8a30b75e8316"

	property Entity TouchToEndText = "b4793224-000c-4323-8316-75e7a5d361a5"

	property Entity UITrialGradeUp = "879e8645-8121-457d-906b-c2d2db943e73"

	property UITrialProgress TrialProgress = "61ad203f-d695-44a6-b772-c97de649dd24"

	property Entity NameInfo = "13a92fd4-4ff4-42c8-960a-1535c2a4f764"

	property Entity ImgDeco = "d26cddb7-185c-4718-8ceb-9a289c118ca5"

	property Entity TrialInfoDecoWin = "b8422dbb-9feb-4220-a223-17b317607d29"

	property Entity TrialInfoDecoLose = "161c9563-27fd-4475-97d5-103df94ecdae"

	property Entity TrialInfoLineRight = "03c7e3b0-d76e-4919-bf3d-bebc8d02abbc"

	property Entity TrialInfoLineLeft = "5ae2eeb7-ac63-40df-bbc0-21852b25ae51"

	@ExecSpace("ClientOnly")
	method void EnableTrialResultUI(boolean enable)
		-- Trial 결과 UI의 활성화/비활성화를 제어하는 클라이언트 전용 함수
		if enable then
			self.ResultUI.Enable = true
			self.UITrialGradeUp.Enable = false
			self.LayoutUI.Enable = false
			self.ScreenUI.Enable = false
			self:UpdateTrialResultInfo()
		else
			self.ResultUI.Enable = false
			self.LayoutUI.Enable = true
			self.ScreenUI.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateTrialResultInfo()
		-- Trial 결과 정보를 업데이트하고 UI 요소들을 설정하는 클라이언트 전용 함수
		self._T.gradeUpRenderType = 0
		
		
		local player = _UserService.LocalPlayer
		local trialId = player.PlayerTrial.SelectedTrialId
		local trialData = _TrialDataSetLogic:GetTrialData(trialId)
		local position = trialData.Type
		
		
		local challengingData = _TrialLogic:GetChallengingTrialData(trialId, player, player.PlayerTrial.NowOfficialType)
		
		self.TrialTitleText.TextComponent.Text = _TrialLogic:ReturnTrialName(trialId, challengingData.Grade, challengingData.Difficulty)
		self.TrialProgress:Refresh(challengingData.Grade, challengingData.Difficulty, trialId)
		self.NameInfo.CanvasGroupComponent.GroupAlpha = 0
		self.NameInfo.UITransformComponent.anchoredPosition = Vector2(self.NameInfoStartPos.x, self.NameInfoStartPos.y)
		
		local winnerCharData = player.PlayerTrial.CharacterData[1]
		self.isPlayerWinner = winnerCharData[2]
		
		local playerIndex
		for k, v in pairs(player.PlayerTrial.CharacterData) do
			local isPlayer = v[2]
			if isPlayer then
				playerIndex = k
			end
		end
		
		local employeeEntity = self.TargetImageEntity:GetChildByName("Employee")
		local recipeEntity = self.TargetImageEntity:GetChildByName("Recipe")
		
		local playerCharData = player.PlayerTrial.CharacterData[playerIndex]
		local playerLayoutIndex = playerCharData[4]
		
		if trialData.Target == "Employee" then
			employeeEntity.Enable = true
			recipeEntity.Enable = false
			
			local employeeImg = employeeEntity:GetChildByName("Employee")
				
			if self.isPlayerWinner then
				_TrialLogic:PlayUIEmployeeAnim(employeeImg, playerCharData[1], "Love", true, player)
			else
				_TrialLogic:PlayUIEmployeeAnim(employeeImg, playerCharData[1], "Cry", true, player)
			end
		else
			employeeEntity.Enable = false
			recipeEntity.Enable = true
			local recipeRect = recipeEntity:GetChildByName("RecipeRect")
		
			local ingreData = _UserService.LocalPlayer.PlayerTrial.IngredientData[playerLayoutIndex]
			local ingreList = ingreData["IngreList"]
			_DrawBurgerUIService:DrawBurgerUI(recipeRect, ingreList, recipeRect.UITransformComponent.RectSize.x)
			
		end
		
		local panelColor = function(isWin, isPlayer)
			if isWin then
				if isPlayer then
					return _ColorCodeEnum:GetColor("#F9C645")
				else
					return _ColorCodeEnum:GetColor("#593A03")
				end
			else
				if isPlayer then
					return _ColorCodeEnum:GetColor("#C4C4C4")
				else
					return _ColorCodeEnum:GetColor("#585858")
				end
			end
		end
		
		local fontColor = function(isWin, isPlayer)
			if isWin then
				if isPlayer then
					return _ColorCodeEnum:GetColor("#6B4219")
				else
					return _ColorCodeEnum:GetColor("#B07D13")
				end
			else
				if isPlayer then
					return _ColorCodeEnum:GetColor("#444444")
				else
					return _ColorCodeEnum:GetColor("#A5A5A5")
				end
			end
		end
		
		local layout = trialData.Layout
		local rankChildren = self.RankListEntity.Children
		for i = 1, #rankChildren do
			local slot = rankChildren[i]
			if i > layout then
				slot.Enable = false
				continue
			end
			
			slot.Enable = true
			local slotData = player.PlayerTrial.CharacterData[i]
			
			local rankIndexEntity = slot:GetChildByName("RankIndex")
			local storeNameEntity = slot:GetChildByName("StoreName")
			local targetNameEntity = slot:GetChildByName("TargetName")
			
			rankIndexEntity.TextComponent.Text = tostring(math.floor(i))
			
			local storeName = slotData[3]
			storeNameEntity.TextComponent.Text = _GetLocalizationTextLogic:GetText(storeName)
			
			local layoutIndex = slotData[4]
			if trialData.Target == "Employee" then		
				local charId = slotData[1]
				local targetName = _GetLocalizationTextLogic:GetText("Name"..charId)
				targetNameEntity.TextComponent.Text = targetName
				
			elseif trialData.Target == "Recipe" then
				
				local ingreData = _UserService.LocalPlayer.PlayerTrial.IngredientData[layoutIndex]	
				local burgerName = ingreData["BurgerName"]
				targetNameEntity.TextComponent.Text = burgerName
			end
			
			rankIndexEntity.SpriteGUIRendererComponent.Color = panelColor(self.isPlayerWinner, i==playerIndex)
			storeNameEntity.SpriteGUIRendererComponent.Color = panelColor(self.isPlayerWinner, i==playerIndex)
			
			rankIndexEntity.TextComponent.FontColor = fontColor(self.isPlayerWinner, i==playerIndex)
			storeNameEntity.TextComponent.FontColor = fontColor(self.isPlayerWinner, i==playerIndex)
			
			targetNameEntity.Enable = i == playerIndex
			targetNameEntity.TextComponent.FontColor = fontColor(self.isPlayerWinner, i==playerIndex)
		end
		
		self.ResultWinText.Enable = false
		self.ResultLoseText.Enable = false
		
		self.ImgDeco.Enable = true
		
		self.WinEffect.Enable = false
		self.LoseEffect.Enable = false
		self.FailAnimHolder.Enable = false
		for i = 1, #self.FailAnimHolder.Children do
			self.FailAnimHolder.Children[i].Enable = false
		end
		
		local rewardChildren = self.RewardListEntity.Children
		for i = 1, #rewardChildren do
			rewardChildren[i].Enable = false
		end
		
		self.TrialInfoDecoWin.Enable = self.isPlayerWinner
		self.TrialInfoDecoLose.Enable = not self.isPlayerWinner
		self.FeedbackText.TextComponent.FontColor = self.isPlayerWinner and _ColorCodeEnum:GetColor("#FFF1C2") or _ColorCodeEnum:GetColor("#D3D3D3")
		
		if self.isPlayerWinner then
			local rewardData = player.PlayerTrial.NowOfficialType == _TrialOfficialTypeEnum.Official and challengingData.OfficialReward or challengingData.UnofficialReward
			local rewardKeys = table.keys(rewardData)
			table.sort(rewardKeys, function(a, b) return a > b end)
			
			for i = 1, #rewardKeys do
				local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_UIItemRewardSlot", i, self.RewardListEntity)
				local k = rewardKeys[i]
				local v = rewardData[k]
				entity.UIItemRewardSlot:SetItem(k, v)
			end
			
			
			self.ImgDeco.SpriteGUIRendererComponent.Color = _ColorCodeEnum:GetColor("#4f4122")
			self.FeedbackText.TextComponent.Text = _GetLocalizationTextLogic:GetText(trialData.WinFeedback)
			
			self.TrialInfoLineRight.SpriteGUIRendererComponent.ImageRUID = "ce4aa97d6a684462b72b89ae2088b64c"
			self.TrialInfoLineLeft.SpriteGUIRendererComponent.ImageRUID = "ce4aa97d6a684462b72b89ae2088b64c"
			
		else
			self.ImgDeco.SpriteGUIRendererComponent.Color = _ColorCodeEnum:GetColor("#40382f")
			self.FeedbackText.TextComponent.Text = _GetLocalizationTextLogic:GetText(trialData.LoseFeedback)
			
			self.TrialInfoLineRight.SpriteGUIRendererComponent.ImageRUID = "98dc75a7f1cb442ca41b36ab5601cc43"
			self.TrialInfoLineLeft.SpriteGUIRendererComponent.ImageRUID = "98dc75a7f1cb442ca41b36ab5601cc43"
		end
		
		self:ChangePhase(0)
	end

	@ExecSpace("ClientOnly")
	method void ChangePhase(integer phaseIndex)
		-- Trial 결과 UI의 페이즈를 변경하고 해당 페이즈에 맞는 초기화를 수행하는 클라이언트 전용 함수
		self.phase = phaseIndex
		
		self:InitEntitiesForPhase(phaseIndex)
		self:PhaseFunction(phaseIndex)
		_UserService.LocalPlayer.PlayerTrial:ChangeConnectingStatus(false)
	end

	@ExecSpace("ClientOnly")
	method void InitEntitiesForPhase(integer phase)
		-- 특정 페이즈에 필요한 UI 엔티티들의 상태를 초기화하는 클라이언트 전용 함수
		if phase == 0 then 
			self.CharInfoEntity.Enable = false
			self.CharInfoEntity.UITransformComponent.anchoredPosition = Vector2(self.CharInfoStartPos.x, self.CharInfoStartPos.y)
			
			self.TrialInfoEntity.Enable = false
			self.TrialInfoEntity.UITransformComponent.anchoredPosition = Vector2(self.TrialInfoStartPos.x, self.TrialInfoStartPos.y)
			
			self.TargetImageEntity.CanvasGroupComponent.GroupAlpha = 0
			
			self.RewardInfo.Enable = false
			self.TouchToEndText.Enable = false
			
			self.NameInfo.Enable = true
			
		elseif phase == 1 then 
			self.CharInfoEntity.Enable = true
			
		elseif phase == 2 then 
			self.TrialInfoEntity.Enable = true
			
		elseif phase == 3 then 
			self.CharInfoEntity.Enable = true
			self.CharInfoEntity.UITransformComponent.anchoredPosition = Vector2(self.CharInfoOriginPos.x, self.CharInfoOriginPos.y)
			
			self.TrialInfoEntity.Enable = true
			self.TrialInfoEntity.UITransformComponent.anchoredPosition = Vector2(self.TrialInfoOriginPos.x, self.TrialInfoOriginPos.y)
			
			self.TargetImageEntity.CanvasGroupComponent.GroupAlpha = 1
				
			if self.isPlayerWinner then
				self.RewardInfo.Enable = true
			end
			
		elseif phase == 4 then 
			self.TouchToEndText.Enable = true
			self.TouchToEndText.TextComponent.Text = _GetLocalizationTextLogic:GetText("TouchToMoveNext")
				
		elseif phase == 5 then 
			self.TouchToEndText.Enable = true
			self.TouchToEndText.TextComponent.Text = _GetLocalizationTextLogic:GetText("TouchToLeave")
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void PhaseFunction(integer phase)
		-- 각 페이즈에서 실행할 애니메이션과 로직을 처리하는 클라이언트 전용 함수
		local trialId = _UserService.LocalPlayer.PlayerTrial.SelectedTrialId
		local trialData = _TrialDataSetLogic:GetTrialData(trialId)
		
		if phase == 0 then
			_TimerService:SetTimerOnce(function() self:ChangePhase(1) end, 1)
			
		elseif phase == 1 then
			local duration = 0.8
			local phase1Function = function()
				local effectKey
				if self.isPlayerWinner then
					effectKey = "ResultWin"
					
					_SoundService:PlaySound(_ResourceManager.SFXTable["System_Dice_GetItem_02"], 1)
					_UIEntityService:PlayUISpriteAnim(self.WinEffect, "a7beeedf5d364c0ca34d74879a26e8bf", duration)
				else
					effectKey = "ResultLose"
					_SoundService:PlaySound(_ResourceManager.SFXTable["TrialLose"], 1)
				end
				
				_TweenLogic:PlayTween(0, 1, duration, EaseType.CubicEaseOut, function(t)
					self.TargetImageEntity.CanvasGroupComponent.GroupAlpha = t
				end)
				
				_TweenLogic:PlayTween(0, 1, duration, EaseType.CubicEaseOut, function(t)
					self.NameInfo.CanvasGroupComponent.GroupAlpha = t
				end)
				
				_TweenLogic:PlayTween(self.NameInfoStartPos, self.NameInfoOriginPos, duration, EaseType.CubicEaseOut, function(t)
					self.NameInfo.UITransformComponent.anchoredPosition = t
				end)
				
				_TimerService:SetTimerOnce(function()
					self:ChangePhase(2)
				end, duration)
			end
			
			_TimerService:SetTimerOnce(phase1Function, 1)
			
		elseif phase == 2 then
			local tweenDuration = 1
			_TweenLogic:PlayTween(self.CharInfoEntity.UITransformComponent.anchoredPosition, self.CharInfoOriginPos, tweenDuration, EaseType.CubicEaseOut, function(t)
				self.CharInfoEntity.UITransformComponent.anchoredPosition = t
			end)
			_TweenLogic:PlayTween(self.TrialInfoEntity.UITransformComponent.anchoredPosition, self.TrialInfoOriginPos, tweenDuration, EaseType.CubicEaseOut, function(t)
				self.TrialInfoEntity.UITransformComponent.anchoredPosition = t
			end)
				
			local player = _UserService.LocalPlayer
			local challengingData = _TrialLogic:GetChallengingTrialData(trialId, player, player.PlayerTrial.NowOfficialType)
					
			if self.isPlayerWinner then
				self.ResultWinText.Enable = true
				self.ResultWinText.CanvasGroupComponent.GroupAlpha = 0
				_TimerService:SetTimerOnce(function()
					_SoundService:PlaySound(_ResourceManager.SFXTable["WinVoice"], 1)			
					_TweenLogic:PlayTween(0, 1, 0.8, EaseType.CubicEaseOut, function(t)
						self.ResultWinText.CanvasGroupComponent.GroupAlpha = t
					end)
					self.ResultWinText.UITweenTextScale:Play()
				end, 0.5)
			else
				self.ResultLoseText.Enable = true
				self.ResultLoseText.CanvasGroupComponent.GroupAlpha = 0
				_TimerService:SetTimerOnce(function()
					_TweenLogic:PlayTween(0, 1, 0.8, EaseType.CubicEaseOut, function(t)
						self.ResultLoseText.CanvasGroupComponent.GroupAlpha = t
					end)
					self.ResultLoseText.UITweenTextScale:Play()
					_SoundService:PlaySound(_ResourceManager.SFXTable["LoseVoice"], 1)
					
				end, 0.5)
				
			end
			
			_TimerService:SetTimerOnce(function()
				self:ChangePhase(3)
						
			end, 2)
			
		elseif phase == 3 then
			if self.isPlayerWinner then
				local player = _UserService.LocalPlayer
				local challengingData = _TrialLogic:GetChallengingTrialData(trialId, player, player.PlayerTrial.NowOfficialType)
				
				
				if player.PlayerTrial.NowOfficialType == _TrialOfficialTypeEnum.Official then
					local nextProgress = _TrialLogic:ReturnNextProgress(string.format("%d-%d", challengingData.Grade, challengingData.Difficulty), trialId)
					
					if nextProgress == nil then
						self._T.gradeUpRenderType = 2
						self:ChangePhase(4)
					else
						local nextGrade = tonumber(_UtilLogic:Split(nextProgress, "-")[1])
						if nextGrade > challengingData.Grade then
							self._T.gradeUpRenderType = 1
							self:ChangePhase(4)
						else
							self:ChangePhase(5)
						end
						
					end
					
				else
					self:ChangePhase(5)
					
				end	
				
			else
				self:ChangePhase(5)
				
			end
				
		elseif phase == 4 then
			
			
		elseif phase == 5 then
				
		end
	end

	@EventSender("Entity", "bff88988-5930-4d4a-9452-2189409b5bb1")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- Trial 결과 화면에서 버튼 클릭을 처리하는 이벤트 핸들러
		
		local Entity = event.Entity
		local player = _UserService.LocalPlayer
		local playerTrial = player.PlayerTrial
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self.phase == 4 then
			if self.UITrialGradeUp.UITrialGradeUpRenderer.IsRendering == true then
				return
			end
			
			self.UITrialGradeUp.UITrialGradeUpRenderer:StartRender(self._T.gradeUpRenderType)
			return
		end
		
		if self.phase ~= 5 then
			return
		end
		
		if playerTrial.IsServerProcessing then return end
		playerTrial:ChangeConnectingStatus(true, player.PlayerComponent.UserId)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_FadeService:ShowFade("TrialEnd", player.PlayerComponent.UserId)
	end

end