@Component
script UITrialSetTopBar extends Component

	property Entity TrialDescText = nil

	property Entity TrialName = nil

	property Entity TrialIcon = nil

	property Entity TrialProgress = nil

	property Entity RecommendedTitle = nil

	property Entity RecommendedValueText = nil

	property Entity RecommendedValueImg = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 상단바 UI 요소들을 연결하고 이벤트를 설정하는 클라이언트 전용 함수
		local trialDescBtn = self.Entity:GetChildByName("TrialName"):GetChildByName("TrialDescBtn")
		self.TrialDescText = trialDescBtn:GetChildByName("TrialDescText")
		
		trialDescBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_TooltipService:OpenTooltip(self.TrialDescText, nil)
		end)
		
		self.TrialName = self.Entity:GetChildByName("TrialName")
		self.TrialIcon = self.TrialName:GetChildByName("TrialIconHolder"):GetChildByName("Icon")
		self.TrialProgress = self.Entity:GetChildByName("TrialProgress")
		
		local recommended = self.Entity:GetChildByName("Recommended")
		self.RecommendedTitle = recommended:GetChildByName("Title")
		self.RecommendedValueText = recommended:GetChildByName("ValueText")
		self.RecommendedValueImg = recommended:GetChildByName("ValueImg")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(string trialId)
		-- Trial 정보로 상단바 UI를 업데이트하고 추천 레벨을 표시하는 함수
		self.TrialDescText.Enable = false
		
		local trialData = _TrialDataSetLogic:GetTrialData(trialId)
		local challengingData = _TrialLogic:GetChallengingTrialData(trialId, _UserService.LocalPlayer, _TrialUILogic.UITrialSelect.UITrialSelect.SelectTab)
		
		self.TrialName.TextComponent.Text = _TrialLogic:ReturnTrialName(trialId, challengingData.Grade, challengingData.Difficulty)
		self.TrialDescText.TextComponent.Text = _GetLocalizationTextLogic:GetText(trialData.Desc)
		
		self.TrialIcon.Enable = true
		self.TrialIcon.SpriteGUIRendererComponent.ImageRUID = trialData.IconRUID
		local rectSize = 62
		if trialData.Target == "Recipe" then
			rectSize = 32
		end
		self.TrialIcon.UITransformComponent.RectSize = Vector2(rectSize, rectSize)
		
		self.TrialProgress.UITrialProgress:Refresh(challengingData.Grade, challengingData.Difficulty, trialId)
		
		self.RecommendedTitle.TextComponent.Text = trialData.Target == "Recipe" and _GetLocalizationTextLogic:GetText("TrialResultGuessRecommendRecipe") or _GetLocalizationTextLogic:GetText("TrialResultGuessRecommendEmployee")
		self.RecommendedValueImg.Enable = trialData.Target == "Recipe"
		self.RecommendedValueText.Enable = not (trialData.Target == "Recipe")
		if trialData.Target == "Recipe" then
			local tasteGradeData = _TasteGradeDataSetLogic:ReturnGradeDataByScore(challengingData.Requirement)
			self.RecommendedValueImg.SpriteGUIRendererComponent.ImageRUID = tasteGradeData.RUID
		else
			local level = challengingData.Requirement
			self.RecommendedValueText.TextComponent.Text = string.format("Lv.%d", challengingData.Requirement)
		end
	end

	@ExecSpace("ClientOnly")
	method void ToggleTrialDescText()
		-- Trial 설명 톨틁을 열고 닫는 토글 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_TooltipService:OpenTooltip(self.TrialDescText, nil)
	end

end