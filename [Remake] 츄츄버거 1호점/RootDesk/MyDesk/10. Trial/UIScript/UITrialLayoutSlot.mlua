@Component
script UITrialLayoutSlot extends Component

	property Entity BurgerParent = nil

	property Entity Avatar = nil

	property Entity Char = nil

	property Entity Firework = nil

	property Entity Notify = nil

	property Entity Nametag = nil

	property Entity NTStoreName = nil

	property Entity NTTargetName = nil

	property Entity NTOnlyStoreName = nil

	property Entity ScoreBoard = nil

	property Entity SBRankText = nil

	property Entity SBScoreText = nil

	property Entity LogArea = nil

	property Entity Box = nil

	property Entity BoxStackArea = nil

	property Entity BoxSlider = nil

	property Entity VoteBoard = nil

	property Entity VoteArea = nil

	property Entity CustomerParent = nil

	property SyncTable<integer, Entity> StackEntities

	property SyncTable<integer, Entity> StatLogEntities

	property integer notifyTimer = 0

	property SyncTable<integer, Entity> VoteEntities

	property SyncTable<integer, Entity> CustomerEntities

	property Entity SBImgStampWin = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 모든 UI 요소들을 찾아 연결하는 클라이언트 전용 함수
		self.BurgerParent = self.Entity:GetChildByName("BurgerParent")
		self.Avatar = self.Entity:GetChildByName("Avatar")
		self.Char = self.Entity:GetChildByName("Char")
		self.Firework = self.Entity:GetChildByName("Firework")
		self.Notify = self.Entity:GetChildByName("Notify")
		
		self.Nametag = self.Entity:GetChildByName("Nametag")
		self.NTStoreName = self.Nametag:GetChildByName("StoreName")
		self.NTTargetName = self.Nametag:GetChildByName("TargetName")
		self.NTOnlyStoreName = self.Nametag:GetChildByName("OnlyStoreName")
		
		self.ScoreBoard = self.Entity:GetChildByName("ScoreBoard")
		self.SBRankText = self.ScoreBoard:GetChildByName("RankText")
		self.SBScoreText = self.ScoreBoard:GetChildByName("ScoreText")
		self.SBImgStampWin = self.ScoreBoard:GetChildByName("ImgStampWin")
		
		self.LogArea = self.Entity:GetChildByName("LogArea")
		
		self.Box = self.Entity:GetChildByName("Box")
		self.BoxStackArea = self.Entity:GetChildByName("BoxStackArea")
		self.BoxSlider = self.Box:GetChildByName("Slider")
		
		self.VoteBoard = self.Entity:GetChildByName("VoteBoard")
		self.VoteArea = self.VoteBoard:GetChildByName("VoteArea")
		
		self.CustomerParent = self.Entity:GetChildByName("CustomerParent")
		
	end

	@ExecSpace("ClientOnly")
	method void SetBoxSlider(number value)
		-- 박스 슬라이더의 값을 설정하는 클라이언트 전용 함수
		self.BoxSlider.SliderComponent.Value = value
	end

	@ExecSpace("ClientOnly")
	method void SetScoreboard(integer rankIndex, integer score)
		-- 점수판에 순위와 점수를 표시하는 클라이언트 전용 함수
		self.SBImgStampWin.CanvasGroupComponent.GroupAlpha = 0
		self.SBRankText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Ranking_Format", rankIndex)
		self.SBScoreText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Score_Format", score)
	end

	@ExecSpace("ClientOnly")
	method void SetNametag(string storeName, string targetName, boolean isOnlyStoreName)
		-- 이름표를 설정하고 표시 모드를 결정하는 클라이언트 전용 함수
		self.Nametag.Enable = true
		
		if isOnlyStoreName then
			self.NTStoreName.Enable = false
			self.NTTargetName.Enable = false
			self.NTOnlyStoreName.Enable = true
			
			self.NTOnlyStoreName.TextComponent.Text = storeName
			self.Nametag.SpriteGUIRendererComponent.ImageRUID = "3d3890e6c1414870901ede6d396b070b"
			
		else
			self.NTStoreName.Enable = true
			self.NTTargetName.Enable = true
			self.NTOnlyStoreName.Enable = false
			
			self.NTStoreName.TextComponent.Text = storeName
			self.NTTargetName.TextComponent.Text = targetName
			self.Nametag.SpriteGUIRendererComponent.ImageRUID = "1f214b5f48124364af6a92446ae58a5f"
			
		end
	end

	@ExecSpace("ClientOnly")
	method void SetStatLogData(integer score, string targetStat)
		-- 통계 로그 데이터를 설정하는 클라이언트 전용 함수
		local bigCount = math.floor(score/10)
		local smallCount = score%10
		
		local ruid = _TrialUILogic:ReturnIconRUIDByTargetStat(targetStat)
		
		for i = 1, (bigCount+smallCount) do
			local log = _UIEntityService:GetOrCreateEntityOfModel("Model_StatIconLog", i, self.LogArea)
			log.SpriteGUIRendererComponent.ImageRUID = ruid
			if i > bigCount then
				log.UITransformComponent.RectSize = Vector2(50, 50)
			else
				log.UITransformComponent.RectSize = Vector2(70, 70)
			end
			
			log.CanvasGroupComponent.GroupAlpha = 0
			
			self.StatLogEntities[i] = log
		end
	end

	@ExecSpace("ClientOnly")
	method void SetNotifyEnable(boolean enable, string text, number duration, boolean ignoreDelay)
		-- 알림을 활성화하고 텍스트와 지속시간을 설정하는 클라이언트 전용 함수
		self.Notify.TextComponent.Text = text
		self.Notify.Enable = enable
		
		local timerFunction = function()
			self:SetNotifyEnable(false, "", 0, true)
			
			_TimerService:ClearTimer(self.notifyTimer)
			self.notifyTimer = 0
		end
		
		if enable == false then return end
		
		if duration > 0 then
			if ignoreDelay or self.notifyTimer == 0 then
				_TimerService:ClearTimer(self.notifyTimer)	
				 self.notifyTimer = _TimerService:SetTimerOnce(timerFunction, duration)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetVoteEntities(integer score)
		-- 투표 엔티티들을 점수에 따라 설정하는 클라이언트 전용 함수
		local bigCount = math.floor(score/10)
		local smallCount = score%10
		
		local bigRuid = "cb1c678f3de14a4982e2d5072223ebc4"
		local smallRuid = "a587c180c1934348a8b0039c97e8e61f"
		
		local indexTable = {}
		for i = 1, (bigCount+smallCount) do
			table.insert(indexTable, i)
		end
		
		for i = 1, (bigCount+smallCount) do
			local entity = _UIEntityService:GetOrCreateEntityOfModel("UISprite", i, self.VoteArea)
			entity.SpriteGUIRendererComponent.PreserveSprite = PreserveSpriteType.NativeSize
			entity.UITransformComponent.RectSize = Vector2(64, 64)
			
			if i > bigCount then
				entity.SpriteGUIRendererComponent.ImageRUID = smallRuid
				entity.SpriteGUIRendererComponent.LocalScale = Vector2(2, 2)
			else
				entity.SpriteGUIRendererComponent.ImageRUID = bigRuid
				entity.SpriteGUIRendererComponent.LocalScale = Vector2(4, 4)
			end
			
			entity.Enable = false
			local randomX = _UtilLogic:RandomIntegerRange(-500, 500)/10
			local randomY = _UtilLogic:RandomIntegerRange(-350, 350)/10
			entity.UITransformComponent.anchoredPosition = Vector2(randomX, randomY)
			
			local randomIndex = _UtilLogic:RandomIntegerRange(1, #indexTable)
		    local randomPosition = indexTable[randomIndex]
			self.VoteEntities[randomPosition] = entity
			table.remove(indexTable, randomIndex)
			
		end
	end

	@ExecSpace("ClientOnly")
	method void SetLayoutCustomerEntities(integer count, string targetType)
		-- 레이아웃에 고객 엔티티들을 설정하는 클라이언트 전용 함수
		for i = 1, count do
			local customer = _UIEntityService:GetOrCreateEntityOfModel("Model_TrialCustomerAvatar", i, self.CustomerParent)
			_CustomerAvatarService:SetRandomCostume(customer.CostumeManagerComponent)
			
			customer.Enable = false
			customer.UITrialCustomer:SetItem(targetType)
			
			self.CustomerEntities[i] = customer
		end
	end

end