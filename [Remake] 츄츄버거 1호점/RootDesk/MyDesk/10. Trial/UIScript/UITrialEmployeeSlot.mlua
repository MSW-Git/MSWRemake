@Component
script UITrialEmployeeSlot extends Component

	property string EmployeeId = ""

	property Entity Select = nil

	property Entity Portrait = nil

	property SpriteGUIRendererComponent TypeIcon = nil

	property Entity Ban = nil

	method void Init()
		-- 직원 슬롯 UI 요소들을 초기화하고 클릭 이벤트를 연결하는 함수
		self.Select = self.Entity:GetChildByName("Select")
		self.Portrait = self.Entity:GetChildByName("Mask"):GetChildByName("Portrait")
		self.TypeIcon = self.Entity:GetChildByName("TypeIcon").SpriteGUIRendererComponent
		self.Ban = self.Entity:GetChildByName("Ban")
		self.Entity:GetChildByName("Disable").Enable = false
		
		self.Entity:GetChildByName("Slot"):ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)	
			self:SelectEmp()
		end)
	end

	method void Refresh(string employeeId)
		-- 직원 슬롯을 주어진 직원 ID로 새로고침하는 함수
		if self.Select == nil then
			self:Init()
		end
		
		self.EmployeeId = employeeId
		
		local uiTrialSetEmployee = _TrialUILogic.UITrialSetEmployee.UITrialSetEmployee
		local empData = _EmployeeService:GetData(employeeId)
		
		self.Select.Enable = uiTrialSetEmployee.SelectedEmployeeId == employeeId
		
		_EmployeeUIService:DrawPortraitWithEquip(self.Portrait, self.Portrait, empData)
		self.TypeIcon.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(empData.Type)
		
		self.Ban.Enable = false
		if _TrialUILogic.UITrialSelect.UITrialSelect.SelectTab == _TrialOfficialTypeEnum.Official then
			if employeeId == _TrialLogic:GetExEmployeeIdOfType(_UserService.LocalPlayer, _TrialDataSetLogic:GetTrialData(uiTrialSetEmployee.nowTrialId).TargetStat) then
				self.Ban.Enable = true		
			end	
		end
	end

	method void SelectEmp()
		-- 직원을 선택하여 상세 정보를 업데이트하는 함수
		local uiTrialSetEmployee = _TrialUILogic.UITrialSetEmployee.UITrialSetEmployee
		uiTrialSetEmployee:RefreshDetail(self.EmployeeId)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 초기화를 수행하는 클라이언트 전용 함수
		self:Init()
	end

end