@Struct
script TrialDifficultyData

	property string TrialId = ""

	property integer Grade = 0

	property integer Difficulty = 0

	property SyncTable<string, integer> OfficialReward

	property number Requirement = 0

	property SyncTable<string, integer> UnofficialReward

	property integer OfficialCost = 0

	property integer UnOfficialCost = 0

	method void Load(string trialId, integer grade, any rowData)
		-- CSV 데이터에서 Trial 난이도 정보를 로드하여 보상 및 비용 데이터를 설정하는 함수
		self.TrialId = trialId
		self.Grade = grade
		
		---@type UserDataRow
		local row = rowData
		
		local difficulty = tonumber(row:GetItem("Difficulty"))
		self.Difficulty = math.floor(difficulty)
		
		local offRewardKV = _UtilLogic:Split(row:GetItem("OfficialReward"), ",")
		for i = 1, #offRewardKV, 2 do
			local k = offRewardKV[i]
			local v = offRewardKV[i+1]
			
			self.OfficialReward[k] = v
		end
		
		local unoffRewardKV = _UtilLogic:Split(row:GetItem("UnofficialReward"), ",")
		for i = 1, #unoffRewardKV, 2 do
			local k = unoffRewardKV[i]
			local v = unoffRewardKV[i+1]
			
			self.UnofficialReward[k] = v
		end
		
		self.OfficialCost = tonumber(row:GetItem("OfficialCost"))
		self.UnOfficialCost = tonumber(row:GetItem("UnofficialCost"))
		
		self.Requirement = tonumber(row:GetItem("Requirement"))
	end

	method integer GetTrialCost(integer officialType, Entity player)
		-- 플레이어의 현재 스테이지와 Trial 타입에 따라 참가 비용을 계산하여 반환하는 함수
		local stageId = player.PlayerStage.NowStage
		local stageConfig = _BalanceDataSetLogic:GetStageConfigData(stageId).TrialCostRate
		
		local cost = officialType == _TrialOfficialTypeEnum.Official and self.OfficialCost or self.UnOfficialCost
		cost = cost * (1 + stageConfig)
		
		return math.floor(cost)
	end

end