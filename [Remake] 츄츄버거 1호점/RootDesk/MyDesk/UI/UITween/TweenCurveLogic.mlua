@Logic
script TweenCurveLogic extends Logic

	method number GetTweenValue(number time, table keyframes)
		-- 키프레임 기반 트윈 값 계산 (베지어 곡선 지원)
		  if not keyframes then
		        return nil
		    end
		    ---@type table
		    local prevKeyframe = nil
		    ---@type table
		    local nextKeyframe = nil
		    
		    for i, keyframe in ipairs(keyframes) do
		        if keyframe.time <= time then
		            prevKeyframe = keyframe
		        else
		            nextKeyframe = keyframe
		            break
		        end
		    end
		    
		    if not nextKeyframe then
		        return keyframes[#keyframes].value
		    end
		    if prevKeyframe == nil then
				return 0
			end
		    local deltaTime = nextKeyframe.time - prevKeyframe.time
		    local t = (time - prevKeyframe.time) / deltaTime
		
		  	local p0 = prevKeyframe.value
		    local p3 = nextKeyframe.value
		    
		    local value = nil
		
			if prevKeyframe.tangentMode == 1 then
			    value = p0 * (1-t) + p3 * t 
			else
			   local p1 = p0 + prevKeyframe.outTangent * deltaTime * (prevKeyframe.outWeight == nil and 0 or prevKeyframe.outWeight)
			   local p2 = p3 - nextKeyframe.inTangent * deltaTime * (nextKeyframe.inWeight == nil and 0 or nextKeyframe.inWeight)
			    value = self:BezierInterpolation(p0, p1, p2, p3, t)
			end
		    return value
	end

	method number BezierInterpolation(number p0, number p1, number p2, number p3, number t)
		-- 베지어 곡선 보간 계산
		 local u = 1 - t
		    local tt = t * t
		    local uu = u * u
		    local uuu = uu * u
		    local ttt = tt * t
		    local result = uuu * p0
		    result = result + 3 * uu * t * p1
		    result = result + 3 * u * tt * p2
		    result = result + ttt * p3
		    return result
	end

	method any GetTweenEnumByString(string key)
		-- 문자열로 EaseType 열거형 값 반환
		for k,v in pairs(EaseType) do
			if k == key then
				return v
			end
		end
		return EaseType.Linear
	end

end