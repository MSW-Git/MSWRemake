@Struct
script CustomerAvatarData

	property string Id = ""

	property string Body = ""

	property string Face = ""

	property string Hair = ""

	property string Longcoat = ""

	property string Shoes = ""

	property string Cap = ""

	method void Load(any dataTable, integer index, table ruids)
		-- CSV 데이터에서 고객 아바타 정보를 로드하고 리소스 ID를 수집하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		self.Body = row:GetItem("Body")
		self.Face = row:GetItem("Face")
		self.Hair = row:GetItem("Hair")
		self.Longcoat = row:GetItem("Longcoat")
		self.Shoes = row:GetItem("Shoes")
		self.Cap = row:GetItem("Cap")
		
		if not _UtilLogic:IsNilorEmptyString(self.Body) then
			table.insert(ruids, self.Body)
		end
		if not _UtilLogic:IsNilorEmptyString(self.Face) then
			table.insert(ruids, self.Face)
		end
		if not _UtilLogic:IsNilorEmptyString(self.Hair) then
			table.insert(ruids, self.Hair)
		end
		if not _UtilLogic:IsNilorEmptyString(self.Longcoat) then
			table.insert(ruids, self.Longcoat)
		end
		if not _UtilLogic:IsNilorEmptyString(self.Shoes) then
			table.insert(ruids, self.Shoes)
		end
		if not _UtilLogic:IsNilorEmptyString(self.Cap) then
			table.insert(ruids, self.Cap)
		end
	end

end