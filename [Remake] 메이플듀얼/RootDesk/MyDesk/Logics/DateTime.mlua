@Logic
script DateTime extends Logic

	property any timeSpan = nil

	method void OnBeginPlay()
		-- 로직 초기화 시 시간 오프셋을 0으로 설정
		self.timeSpan = TimeSpan.Zero
	end

	method any KtcNow()
		-- 현재 UTC 시간에 한국 시간대(+9)와 오프셋을 적용하여 반환
		return DateTime.UtcNow + TimeSpan(9, 0, 0) + self.timeSpan
	end

	method integer KtcNowDays()
		-- 한국 시간 기준으로 총 일수를 계산하여 반환
		return (self:KtcNow() - DateTime.MinValue).Days
	end

	method void SetKtcNow(any dateTime)
		-- 한국 시간을 지정된 시간으로 설정
		self:ResetKtcNow()
		self.timeSpan = dateTime - self:KtcNow()
	end

	method void ResetKtcNow()
		-- 시간 오프셋을 0으로 초기화
		self.timeSpan = TimeSpan.Zero
	end

end