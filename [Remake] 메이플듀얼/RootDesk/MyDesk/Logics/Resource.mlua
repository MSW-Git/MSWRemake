@Logic
script Resource extends Logic

	@ExecSpace("ClientOnly")
	method number GetTotalDelay(string animation)
		-- 애니메이션의 전체 재생 시간을 계산하여 반환
		local animationClip = _ResourceService:LoadAnimationClipAndWait(animation)
		local totalDelay = 0
		for _, frame in ipairs(animationClip.Frames) do
			totalDelay += frame.Delay
		end
		
		return totalDelay
	end

	method number GetStartFrameDelay(string animation)
		-- 애니메이션 첫 번째 프레임의 지연 시간을 반환
		local animationClip = _ResourceService:LoadAnimationClipAndWait(animation)
		return animationClip.Frames[1].Delay
	end

	method number GetEndFrameDelay(string animation)
		-- 애니메이션 마지막 프레임의 지연 시간을 반환
		local animationClip = _ResourceService:LoadAnimationClipAndWait(animation)
		return animationClip.Frames[#animationClip.Frames].Delay
	end

end