@Logic
script Screen extends Logic

	property Vector3 effectOffset = Vector3(0,-0.475,0)

	property Vector3 effectSize = Vector3(640,360,0)

	property number defaultHeightPc = 720

	property number defaultHeightMobile = 540

	property number defaultAspectRatio = 1.778

	property number defaultZoomRatio = 100

	@ExecSpace("ClientOnly")
	method integer PlayEffect(string animation, table options)
		-- 화면 전체에 이팩트를 재생하고 ID를 반환
		local scale = self.defaultHeightPc / self.effectSize.y
		return _EffectService:PlayEffect(animation, _UserService.LocalPlayer, self.effectOffset * scale, 0, Vector3.one * scale, false, options)
	end

	@ExecSpace("ClientOnly")
	method number GetZoomRatio()
		-- 화면 비율과 플랫폼에 따른 줄 비율을 계산
		local aspectRatio = _UILogic.ScreenWidth / _UILogic.ScreenHeight
		local aspectRatioFactor = 
			aspectRatio < self.defaultAspectRatio and aspectRatio / self.defaultAspectRatio or 1
		local platformFactor = Environment:IsPCPlatform() and 1 or self.defaultHeightMobile / self.defaultHeightPc
		return self.defaultZoomRatio * aspectRatioFactor * platformFactor
	end

end