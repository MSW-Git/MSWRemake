@Logic
script Event extends Logic

	method BuyCard BuyCard(table info)
		-- 카드 구매 이벤트를 생성하여 반환
		local event = BuyCard()
		event.info = info
		
		return event
	end

	method Unfriend Unfriend(string userId)
		-- 친구 삭제 이벤트를 생성하여 반환
		local event = Unfriend()
		event.userId = userId
		
		return event
	end

	method SellCard SellCard(table info)
		-- 카드 판매 이벤트를 생성하여 반환
		local event = SellCard()
		event.info = info
		
		return event
	end

	method GetChannels GetChannels(table channelArray)
		-- 채널 목록 조회 이벤트를 생성하여 반환
		local event = GetChannels()
		event.channelArray = channelArray
		
		return event
	end

	method GetFriendlyMatchRooms GetFriendlyMatchRooms(table roomArray)
		-- 친선 경기 방 목록 조회 이벤트를 생성하여 반환
		local event = GetFriendlyMatchRooms()
		event.roomArray = roomArray
		
		return event
	end

	method SetRoom SetRoom(table room)
		-- 방 설정 이벤트를 생성하여 반환
		local event = SetRoom()
		event.room = room
		
		return event
	end

	method GetFriends GetFriends(table userIdArray, table friendArray)
		-- 친구 목록 조회 이벤트를 생성하여 반환
		local event = GetFriends()
		event.userIdArray = userIdArray
		event.friendArray = friendArray
		
		return event
	end

end