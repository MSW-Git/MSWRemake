@Logic
script Table extends Logic

	method void Clear(table t)
		-- 테이블의 모든 요소를 제거
		for key, _ in pairs(t) do
			t[key] = nil
		end 
	end

	method table ShallowCopy(table t)
		-- 테이블의 얼없은 복사본을 생성하여 반환
		if not t then
			return nil
		end
		
		local ret = {}
		for key, value in pairs(t) do
			ret[key] = value
		end
		return ret
	end

	method table DeepCopy(table t)
		-- 테이블의 깊은 복사본을 생성하여 반환 (중첩된 테이블도 재귀적으로 복사)
		if not t then
			return nil
		end
		
		local ret = {}
		for key, value in pairs(t) do
			if type(key) == "table" then
				key = self:DeepCopy(key)
			end
			if type(value) == "table" then
				value = self:DeepCopy(value)
			end
			ret[key] = value
		end
		return ret
	end

	method void Shuffle(table a)
		-- Fisher-Yates 알고리즘을 사용하여 배열을 셔플
		for i, value in ipairs(a) do
			local j = _UtilLogic:RandomIntegerRange(1, i)
			a[i], a[j] = a[j], a[i]
		end
	end

	method number GetSize(table t)
		-- 테이블의 요소 개수를 반환
		local size = 0
		if t then
			for _, _ in pairs(t) do
				size = size + 1
			end
		end
		return size
	end

	method boolean IsEmpty(table t)
		-- 테이블이 비어있는지 확인
		return not t or next(t) == nil
	end

	method boolean IsArray(table t)
		-- 테이블이 연속된 인덱스를 가진 배열인지 확인
		local index = 1
		local isArray = true
		for key, value in pairs(t) do
			if key ~= index then
				isArray = false
			end
			index = index + 1
		end
		return isArray
	end

	method void Assign(table fromT, table toT)
		-- 소스 테이블의 모든 요소를 대상 테이블로 복사
		if not fromT or not toT then
			return
		end
		
		for key, value in pairs(fromT) do
			toT[key] = value
		end
	end

	method void Append(table toA, table fromA)
		-- 소스 배열의 모든 요소를 대상 배열의 끝에 추가
		table.move(fromA, 1, #fromA, #toA + 1, toA)
	end

	method table Concat(table a1, table a2)
		-- 두 배열을 연결한 새로운 배열을 반환
		local ret = {self:Unpack(a1)}
		table.move(a2, 1, #a2, #ret + 1, ret)
		return ret
	end

	method table Merge(table t1, table t2)
		-- 두 테이블을 병합한 새로운 테이블을 반환
		local ret = {}
		self:Assign(t1, ret)
		self:Assign(t2, ret)
		return ret
	end

	method table Convert(table t, string methodName)
		-- 테이블의 모든 요소에 지정된 메소드를 적용하여 변환
		if not t then
			return nil
		end
		
		local ret = {}
		for key, value in pairs(t) do
			local keyType = type(key)
			if keyType == "table" then
				key = self:Convert(key, methodName)
			elseif keyType == "characterdata" then
				local converter = key[methodName]
				if converter then
					key = converter(key)
				end
			end
			
			local valueType = type(value)
			if valueType == "table" then
				value = self:Convert(value, methodName)
			elseif valueType == "characterdata" then
				local converter = value[methodName]
				if converter then
					value = converter(value)
				end
			end
			
			ret[key] = value
		end
		return ret
	end

	method boolean Contains(table a, any value)
		-- 배열에 지정된 값이 포함되어 있는지 확인
		for _, item in ipairs(a) do
			if item == value then
				return true
			end
		end
		
		return false
	end

	method table Select(table a, any selector)
		-- 선택 조건을 만족하는 요소들만 필터링하여 반환
		local ret = {}
		for _, item in ipairs(a) do
			if selector(item) then
				table.insert(ret, item)
			end
		end
		
		return ret
	end

	method any GetRandomElement(table a)
		-- 배열에서 랜덤한 요소 하나를 반환
		return a[_UtilLogic:RandomIntegerRange(1, #a)]
	end

	method table GetRandomElements(table a, integer count)
		-- 배열에서 중복 가능한 랜덤 요소들을 지정된 개수만큼 반환
		local ret = {}
		local indexArray = _Util:GetRandomIntegersRange(1, #a, count)
		for _, i in ipairs(indexArray) do
			table.insert(ret, a[i])
		end
		return ret
	end

	method table GetRandomPermutation(table a, integer count)
		-- 배열에서 중복 없는 랜덤 요소들을 지정된 개수만큼 반환
		local ret = {}
		local indexArray = _Util:GetRandomPermutationRange(1, #a, count)
		for _, i in ipairs(indexArray) do
			table.insert(ret, a[i])
		end
		return ret
	end

	method void InsertToRandomIndex(table a, any item)
		-- 배열의 랜덤한 위치에 요소를 삽입
		table.insert(a, _UtilLogic:RandomIntegerRange(1, #a + 1), item)
	end

	method integer Find(table a, any value)
		-- 배열에서 지정된 값의 인덱스를 찾아 반환
		for i, item in ipairs(a) do
			if item == value then
				return i
			end
		end
		
		return nil
	end

	method void Remove(table a, any value)
		-- 배열에서 지정된 값을 처음 발견되는 것만 제거
		local index = self:Find(a, value)
		if index then
			table.remove(a, index)
		end
	end

	method void RemoveAll(table a, any value)
		-- 배열에서 지정된 값을 모두 제거
		while true do
			local index = self:Find(a, value)
			if index then
				table.remove(a, index)
			else
				break
			end
		end
	end

	method integer MaxN(table t)
		-- 테이블에서 가장 큰 숫자 키를 찾아 반환
		local max = 0
		for key, _ in pairs(t) do
			if type(key) == "number" and key > max then
				max = key
			end
		end
		
		return max
	end

	method any Unpack(table t)
		-- 테이블을 언팩하여 여러 값으로 반환
		return table.unpack(t, 1, self:MaxN(t))
	end

	method table Intersection(table a1, table a2)
		-- 두 배열의 합집을 반환 (중복 제거)
		local ret = self:ShallowCopy(a1)
		for _, value in ipairs(a2) do
			if not self:Contains(a1, value) then
				table.insert(ret, value)
			end
		end
		
		return ret
	end

	method any Difference(table a1, table a2)
		-- 첫 번째 배열에서 두 번째 배열에 있는 요소들을 제거한 차집합을 반환
		local ret = self:ShallowCopy(a1)
		for _, value in ipairs(a2) do
			self:Remove(ret, value)
		end
		
		return ret
	end

	method void StableSort(table a, any comparer)
		-- 삽입 정렬을 사용하여 안정적으로 배열을 정렬
		for i = 2, #a do
			local value = a[i]
			local j = i - 1
			while j > 0 and comparer(value, a[j]) do
				a[j + 1] = a[j]
				j -= 1
			end
			a[j + 1] = value
		end
	end

	method table RemoveDuplicates(table a)
		-- 배열에서 중복된 요소들을 제거하고 정렬된 배열을 반환
		local t = {}
		for _, item in ipairs(a) do
			t[item] = true
		end
		
		local ret = table.keys(t)
		table.sort(ret)
		
		return ret
	end

	method boolean Compare(table t1, table t2)
		-- 두 테이블을 재귀적으로 비교하여 동일한지 확인
		for key, value in pairs(t1) do
			if type(value) == "table" then
				if not self:Compare(value, t2[key]) then
					return false
				end
			else
				if value ~= t2[key] then
					return false
				end
			end
		end
		
		return true
	end

end