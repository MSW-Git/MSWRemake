@Component
script DuelModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity menuEntity = nil

	property ButtonComponent cardButton = nil

	property ButtonComponent shopButton = nil

	property ButtonComponent returnButton = nil

	property Entity eventEntity = nil

	property boolean isOpen = false

	property any menuTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 듀얼 모듈 초기화 시 카드, 상점, 돌아가기 버튼 이벤트를 연결하고 오픈 이벤트를 설정
		local character = _UserService.LocalPlayer.Character
		
		self.cardButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if isvalid(character.player) then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.uiManager.CardModule:Open(false)
		end)
		
		self.shopButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if isvalid(character.player) then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.uiManager.ShopModule:Open()
		end)
		
		self.returnButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if isvalid(character.player) then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			local room = self.Entity.CurrentMap.Room
			if isvalid(room) then
				_Server:Request(room, "ReturnToLobby", {character})
			end
			
			local home = self.Entity.CurrentMap.Home
			if isvalid(home) then
				_Server:Request(home, "ReturnToLobby", {character})
			end
		end)
		
		character.Entity:ConnectEvent(SetOpenEventCardPackCount, function()
			self:ShowOpenEvent()
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 듀얼 모듈 메뉴를 열고 화면에 표시하는 애니메이션을 실행하며 오픈 이벤트를 표시
		self.isOpen = true
		self.uiManager:UpdateButtons()
		
		if self.menuTweener then
			self.menuTweener:Destroy()
		end
		self.menuTweener = _Tween:ScaleTo(self.menuEntity, Vector2.one, 0.125, EaseType.Linear)
		
		self:ShowOpenEvent()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 듀얼 모듈 메뉴를 닫고 화면에서 숨기는 애니메이션을 실행
		self.isOpen = false
		self.uiManager:UpdateButtons()
		
		if self.menuTweener then
			self.menuTweener:Destroy()
		end
		self.menuTweener = _Tween:ScaleTo(self.menuEntity, Vector2.zero, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 듀얼 모듈의 모든 버튼들의 활성화 상태를 설정
		self.cardButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.shopButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.returnButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void ShowOpenEvent()
		-- 오픈 이벤트 기간과 카드팩 수량을 확인하여 이벤트 UI 표시 여부를 결정
		local dateTime = _DateTime:KtcNow()
		local character = _UserService.LocalPlayer.Character
		if dateTime < DateTime(2024, 12, 27) and character:GetOpenEventCardPackCount() > 0 then
			self.eventEntity.Enable = true
		else
			self.eventEntity.Enable = false
		end
	end

end