@Component
script EmoteModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property TouchReceiveComponent touchArea = nil

	property Entity panelEntity = "18034c0c-381c-416c-bb53-976fe4e224b1"

	property table emoteImageArray = {}

	property boolean isOpen = false

	property boolean NewValue1 = false

	property any panelTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 이모트 모듈 초기화 시 이모트 이미지들을 설정하고 터치 이벤트를 연결하여 원형 이모트 선택 처리
		for i = 1, 6 do
			local emoteImage = self.panelEntity:GetChildByName(string.format("Emote_%d", i)).SpriteRendererComponent
			table.insert(self.emoteImageArray, emoteImage)
		end
		
		self.touchArea.Entity:ConnectEvent(TouchEvent, function(event)
			local TouchPoint = event.TouchPoint
			
			local character = _UserService.LocalPlayer.Character
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if not self.isOpen then
				return
			end
			
			local panelPosition = self.panelEntity.TransformComponent.WorldPosition
			local touchPosition = _UILogic:ScreenToWorldPosition(TouchPoint)
			
			local x = touchPosition.x - panelPosition.x
			local y = touchPosition.y - panelPosition.y
			
			local r = math.sqrt(x * x + y * y)
			local theta = _Math:Atan2(y, x)
			
			if r < 0.085 or r > 0.85 then
				self:Close()
				return
			end
			
			local index
			if theta < 0 then
				index = 6 - math.floor(3 * math.abs(theta) / math.pi)
			else
				index = math.floor(3 * theta / math.pi) + 1
			end
			
			_Server:Request(character, "PlayEmote", {index})
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 이모트 패널을 열고 플레이어 위치에 표시하는 애니메이션을 실행
		self.isOpen = true
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.touchArea.Entity.Enable = true
		
		local character = _UserService.LocalPlayer.Character
		local worldPosition = character.Entity.TransformComponent.WorldPosition
		local transform = self.panelEntity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		transform.WorldPosition.x = worldPosition.x
		transform.WorldPosition.y = worldPosition.y + 0.28
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.panelEntity, Vector2.one, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 이모트 패널을 닫고 화면에서 숨기는 애니메이션을 실행
		self.isOpen = false
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.touchArea.Entity.Enable = false
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.panelEntity, Vector2.zero, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 이모트 모듈의 터치 영역 활성화 상태를 설정
		self.touchArea.Enable = enable
	end

end