@Component
script DeckMenu extends Component

	property DeckManager deckManager = "e920267e-c338-457c-af06-67081552ceca"

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity leftArrowButtonEntity = nil

	property Entity rightArrowButtonEntity = nil

	property ButtonComponent leftArrowButton = nil

	property ButtonComponent rightArrowButton = nil

	property SpriteRendererComponent deckImage = nil

	property Vector2 deckImageScale = Vector2(0.25,0.25)

	property Entity labelEntity = nil

	property Entity deckNameEntity = nil

	property TextComponent deckNameText = nil

	property TextComponent deckIndexText = nil

	property WarningSign warningSign = nil

	property any deckImageTweener = nil

	property any deckNameTweener = nil

	property any leftArrowButtonTweener = nil

	property any rightArrowButtonTweener = nil

	property any warningSignTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 덱 메뉴 초기화 시 경고 사인을 생성하고 좌우 화살표 버튼 이벤트를 연결하며 덱 상태 이벤트들을 연결
		self.warningSign = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("WarningSign"), "WarningSign", 
			Vector3.zero, self.Entity).WarningSign
		local deckImageTransform = self.deckImage.Entity.TransformComponent
		local warningSignTransform = self.warningSign.Entity.TransformComponent
		warningSignTransform.Position.x = deckImageTransform.Position.x
		warningSignTransform.Position.y = deckImageTransform.Position.y
		warningSignTransform.Position.z = deckImageTransform.Position.z - 1
		warningSignTransform.Scale.x = 0
		warningSignTransform.Scale.y = 0
		
		local character = _UserService.LocalPlayer.Character
		
		self.leftArrowButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if isvalid(character.player) or character.isMatching then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			_Server:Request(character, "SetDeckIndex", {character.deckIndex - 1})
		end)
		
		self.rightArrowButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if isvalid(character.player) or character.isMatching then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			_Server:Request(character, "SetDeckIndex", {character.deckIndex + 1})
		end)
		
		self.deckImage.Entity:ConnectEvent(TouchEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if isvalid(character.player) or character.isMatching then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.uiManager.CardModule:Open(true)
		end)
		
		character.Entity:ConnectEvent(SetDeckIndex, function()
			deckImageTransform.Scale.x = 0
			deckImageTransform.Scale.y = 0
			if self.deckImageTweener then
				self.deckImageTweener:Destroy()
			end
			
			local deckNameTransform = self.deckNameEntity.TransformComponent
			deckNameTransform.Scale.x = 0
			deckNameTransform.Scale.y = 0
			if self.deckNameTweener then
				self.deckNameTweener:Destroy()
			end
			
			warningSignTransform.Scale.x = 0
			warningSignTransform.Scale.y = 0
			if self.warningSignTweener then
				self.warningSignTweener:Destroy()
			end
			
			self.deckImage.Color = Color.white
			self.deckIndexText.Text = ""
			
			local deck = character:GetDeck()
			if _Table:IsEmpty(deck) then
				self.warningSign.text.Text = _LocalizationService:GetText("NoDeck")
				self.warningSignTweener = _Tween:ScaleTo(self.warningSign.Entity, Vector2.one, 0.125, EaseType.Linear)
				return
			elseif not self.deckManager:IsDeckComplete(deck) then
				self.deckImage.Color = Color.gray
				self.warningSign.text.Text = _LocalizationService:GetText("Incomplete")
				self.warningSignTweener = _Tween:ScaleTo(self.warningSign.Entity, Vector2.one, 0.125, EaseType.Linear)
			end
			
			self.deckImage.SpriteRUID = self.resourceManager:GetResource("Deck")[deck.class]
			self.deckImageTweener = _Tween:ScaleTo(self.deckImage.Entity, self.deckImageScale, 0.125, EaseType.Linear)
			
			self.deckNameText.Text = deck.name
			self.deckIndexText.Text = string.format("%d/%d", character.deckIndex, #character.deckArray)
			self.deckNameTweener = _Tween:ScaleTo(self.deckNameEntity, Vector2.one, 0.125, EaseType.Linear)
		end)
		
		character.Entity:ConnectEvent(FinishDeck, function()
			if self.warningSignTweener then
				self.warningSignTweener:Destroy()
			end
			
			local deck = character:GetDeck()
			if self.deckManager:IsDeckComplete(deck) then
				self.deckImage.Color = Color.white
				self.warningSignTweener = _Tween:ScaleTo(self.warningSign.Entity, Vector2.zero, 0.125, EaseType.Linear)
			else
				self.deckImage.Color = Color.gray
				self.warningSign.text.Text = _LocalizationService:GetText("Incomplete")
				self.warningSignTweener = _Tween:ScaleTo(self.warningSign.Entity, Vector2.one, 0.125, EaseType.Linear)
			end
		end)
		character.Entity:ConnectEvent(SaveDeck, function()
			if self.warningSignTweener then
				self.warningSignTweener:Destroy()
			end
			
			local deck = character:GetDeck()
			if self.deckManager:IsDeckComplete(deck) then
				self.deckImage.Color = Color.white
				self.warningSignTweener = _Tween:ScaleTo(self.warningSign.Entity, Vector2.zero, 0.125, EaseType.Linear)
			else
				self.deckImage.Color = Color.gray
				self.warningSign.text.Text = _LocalizationService:GetText("Incomplete")
				self.warningSignTweener = _Tween:ScaleTo(self.warningSign.Entity, Vector2.one, 0.125, EaseType.Linear)
			end
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 덱 메뉴의 버튼들의 활성화 상태를 설정
		self.leftArrowButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.rightArrowButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.deckImage.Entity.TouchReceiveComponent.Enable = enable
	end

	@ExecSpace("ClientOnly")
	method void ShowArrowButtons()
		-- 좌우 화살표 버튼들을 화면에 표시하는 애니메이션을 실행
		if self.leftArrowButtonTweener then
			self.leftArrowButtonTweener:Destroy()
		end
		self.leftArrowButtonTweener = _Tween:ScaleTo(self.leftArrowButtonEntity, Vector2.one, 0.125, EaseType.Linear)
		
		if self.rightArrowButtonTweener then
			self.rightArrowButtonTweener:Destroy()
		end
		self.rightArrowButtonTweener = _Tween:ScaleTo(self.rightArrowButtonEntity, Vector2.one, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void HideArrowButtons()
		-- 좌우 화살표 버튼들을 화면에서 숨김
		if self.leftArrowButtonTweener then
			self.leftArrowButtonTweener:Destroy()
		end
		self.leftArrowButtonTweener = _Tween:ScaleTo(self.leftArrowButtonEntity, Vector2.zero, 0.125, EaseType.Linear)
		
		if self.rightArrowButtonTweener then
			self.rightArrowButtonTweener:Destroy()
		end
		self.rightArrowButtonTweener = _Tween:ScaleTo(self.rightArrowButtonEntity, Vector2.zero, 0.125, EaseType.Linear)
	end

end