@Component
script ToastModule extends Component

	property Entity toastEntity = nil

	property TextComponent text = nil

	property any tweener = nil

	property integer timer = 0

	@ExecSpace("ClientOnly")
	method void ShowMessage(string message)
		-- 토스트 메시지 표시
		local transform = self.toastEntity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		if self.tweener then
			self.tweener:Destroy()
		end
		self.tweener = _Tween:ScaleTo(self.toastEntity, Vector2.one, 0.125, EaseType.Linear)
		
		self.text.Text = message
		
		_TimerService:ClearTimer(self.timer)
		self.timer = _TimerService:SetTimerOnce(function()
			if self.tweener then
				self.tweener:Destroy()
			end
			self.tweener = _Tween:ScaleTo(self.toastEntity, Vector2.zero, 0.125, EaseType.Linear)
		end, 4)
	end

	@ExecSpace("ClientOnly")
	method void Clear()
		-- 토스트 메시지 제거
		_TimerService:ClearTimer(self.timer)
		if self.tweener then
			self.tweener:Destroy()
		end
		self.tweener = _Tween:ScaleTo(self.toastEntity, Vector2.zero, 0.125, EaseType.Linear)
	end

end