@Component
script RankedWinMeso extends Component

	property TextComponent titleText = nil

	property SpriteGUIRendererComponent mesoIcon = nil

	property TextComponent deltaText = nil

	property TextComponent warningText = nil

	@ExecSpace("ClientOnly")
	method void Initialize(integer delta, boolean isEnded, boolean hotTime)
		-- 랭크 승리 메소 보상 정보 초기화
		if isEnded then
			self.titleText.Entity.Enable = false
			self.mesoIcon.Entity.Enable = false
			self.deltaText.Entity.Enable = false
			self.warningText.Entity.Enable = true
		else
			self.titleText.Entity.Enable = true
			self.mesoIcon.Entity.Enable = true
			self.deltaText.Entity.Enable = true
			self.warningText.Entity.Enable = false
			
			self.titleText.Text = hotTime and _LocalizationService:GetText("RankedWinHotTime") or _LocalizationService:GetText("RankedWin")
			self.deltaText.Text = string.format("+%d", delta)
		end
	end

end