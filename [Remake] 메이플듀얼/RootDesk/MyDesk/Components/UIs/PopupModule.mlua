@Component
script PopupModule extends Component

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property ChatComponent chat = "e5b214f8-01d7-43b2-b93f-59d66a9488d7"

	property Entity fadeEntity = nil

	property Entity popupEntity = nil

	property TextComponent text = nil

	property Entity okButtonEntity = nil

	property Entity cancelButtonEntity = nil

	property ButtonComponent okButton = nil

	property ButtonComponent cancelButton = nil

	property boolean isOpen = false

	property any okHandle = nil

	property any cancelHandle = nil

	property any popupTweener = nil

	property number okButtonXPosition = 0

	property ButtonComponent refundInfoButton = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 팝업 모듈 초기화 시 환불 정보 버튼 이벤트를 연결
		self.refundInfoButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 팝업 모듈의 버튼들의 활성화 상태를 설정
		self.okButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.cancelButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void Open(string message, boolean isOkOnly, any okFunc, any cancelFunc)
		-- 팝업을 열고 메시지와 버튼 설정에 따라 UI를 구성
		self.isOpen = true
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		_SoundService:PlaySound(self.resourceManager:GetResource("PopupModule").openSound, 1)
		
		self.fadeEntity.Enable = true
		
		if self.popupTweener then
			self.popupTweener:Destroy()
		end
		self.popupTweener = _Tween:ScaleTo(self.popupEntity, Vector2.one, 0.125, EaseType.Linear)
		
		self.text.Text = message
		if isOkOnly then
			self.cancelButtonEntity.Enable = false
			self.okButtonEntity.TransformComponent.Position.x = 0
		end
		
		self.okHandle = self.okButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if okFunc ~= nil then
				okFunc()
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			self:Close()
		end)
		
		self.cancelHandle = self.cancelButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if cancelFunc ~= nil then
				cancelFunc()
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			self:Close()
		end)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 팝업을 닫고 모든 상태를 초기화
		self.isOpen = false
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = false
		
		local transform = self.popupEntity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		if self.popupTweener then
			self.popupTweener:Destroy()
		end
		
		self.text.Text = ""
		if self.okHandle ~= nil then
			self.okButton.Entity:DisconnectEvent(ButtonClickEvent, self.okHandle)
			self.okHandle = nil
		end
		if self.cancelHandle ~= nil then
			self.cancelButton.Entity:DisconnectEvent(ButtonClickEvent, self.cancelHandle)
			self.cancelHandle = nil
		end
		
		self.cancelButtonEntity.Enable = true
		self.okButtonEntity.TransformComponent.Position.x = self.okButtonXPosition
		
		self.refundInfoButton.Entity.SpriteGUIRendererComponent.RaycastTarget = false
	end

	@ExecSpace("ClientOnly")
	method void ShowBanMessage(string banStartDate, string banEndDate, string banReason)
		-- 밴 메시지를 표시하고 채팅을 비활성화
		self.isOpen = true
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.fadeEntity.Enable = true
		self.fadeEntity.SpriteRendererComponent.Color = Color.black
		
		self.chat.Enable = false
		self.chat.UseChatBalloon = false
		
		if self.popupTweener then
			self.popupTweener:Destroy()
		end
		self.popupTweener = _Tween:ScaleTo(self.popupEntity, Vector2.one, 0.125, EaseType.Linear)
		
		self.text.Text = string.format("%s\n%s\n%s\n~\n%s", _LocalizationService:GetText("YouAreBanned"), banReason, banStartDate, banEndDate)
		self.okButtonEntity.Enable = false
		self.cancelButtonEntity.Enable = false
	end

end