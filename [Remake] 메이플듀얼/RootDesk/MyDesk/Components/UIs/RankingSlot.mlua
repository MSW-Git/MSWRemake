@Component
script RankingSlot extends Component

	property RankManager rankManager = "84709e8b-278d-431c-bc06-a7fe8874ca23"

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property TextComponent rankingText = nil

	property TextComponent nicknameText = nil

	property TextComponent rankText = nil

	property TextComponent rankPointText = nil

	property SpriteGUIRendererComponent rankImage = nil

	@ExecSpace("ClientOnly")
	method void Initialize(string nickname, integer rankPoint, integer ranking)
		-- 랭킹 슬롯 정보 초기화
		local resource = self.resourceManager:GetResource("Rank")
		
		local majorRank = self.rankManager:GetMajorRank(rankPoint, ranking)
		local minorRank = self.rankManager:GetMinorRank(rankPoint)
		
		self.nicknameText.Text = nickname
		self.rankingText.Text = tostring(ranking)
		self.rankImage.ImageRUID = resource[majorRank]
		
		self.rankText.Text = self.rankManager:GetRankName(rankPoint, ranking)
		local colorTable = {
			Iron = Color.FromHexCode("#BA7E06"), 
			Bronze = Color.FromHexCode("#FEA537"),
			Silver = Color.FromHexCode("#BFBFBF"), 
			Gold = Color.FromHexCode("#FFD400"), 
			Platinum = Color.FromHexCode("#03FFAF"), 
			Master = Color.FromHexCode("#D95AFF"), 
			Legend = Color.FromHexCode("#FF3E3E"), 
		}
		self.rankText.FontColor = colorTable[majorRank]
		self.rankPointText.Text = self.rankManager:GetRankPoint(rankPoint)
	end

end