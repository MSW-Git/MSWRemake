@Component
script RoomMenu extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property Entity leftArrowButtonEntity = nil

	property Entity rightArrowButtonEntity = nil

	property Entity newRoomButtonEntity = nil

	property ButtonComponent leftArrowButton = nil

	property ButtonComponent rightArrowButton = nil

	property ButtonComponent newRoomButton = nil

	property any leftArrowButtonTweener = nil

	property any rightArrowButtonTweener = nil

	property any newRoomButtonTweener = nil

	property table roomButtonTweenerArray = {}

	property table roomButtonArray = {}

	property Vector2 gridSize = Vector2(0,0)

	property Vector2 gridCenter = Vector2(0,0)

	property Vector2 gridOffset = Vector2(0,0)

	property table roomArray = {}

	property integer pageIndex = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 룸 메뉴 초기화 및 이벤트 연결
		self.leftArrowButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			if self.pageIndex > 1 then
				self:ShowRoomButtons(self.pageIndex - 1)
			end
		end)
		
		self.rightArrowButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			if self.pageIndex < math.ceil(#self.roomArray / (self.gridSize.x * self.gridSize.y - 1)) then
				self:ShowRoomButtons(self.pageIndex + 1)
			end
		end)
		
		self.newRoomButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			_Server:Request(self.Entity.CurrentMap.Home, "CreateFriendlyMatchRoom", {_UserService.LocalPlayer.Character})
		end)
		
		self.Entity.CurrentMap:ConnectEvent(GetFriendlyMatchRooms, function(event)
			local roomArray = event.roomArray
			
			self.roomArray = roomArray
			self:ShowArrowButtons()
			self:ShowRoomButtons(1)
		end)
		
		for row = 1, self.gridSize.y do
			for col = 1, self.gridSize.x do
				local x = self.gridCenter.x - (self.gridSize.x - 1) * self.gridOffset.x * 0.5 + (col - 1) * self.gridOffset.x
				local y = self.gridCenter.y + (self.gridSize.y - 1) * self.gridOffset.y * 0.5 - (row - 1) * self.gridOffset.y
				
				if row == 1 and col == 1 then
					local transform = self.newRoomButtonEntity.TransformComponent
					transform.Position.x = x
					transform.Position.y = y
					
					continue
				end
				
				local roomButton = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("RoomButton"), "RoomButton", Vector3(x, y, -1), self.Entity).RoomButton
				table.insert(self.roomButtonArray, roomButton)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 룸 목록 요청 및 열기
		_Server:Request(self.Entity.CurrentMap.Home, "GetFriendlyMatchRooms", {})
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 룸 목록 닫기
		self:HideArrowButtons()
		self:HideRoomButtons()
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 룸 목록 버튼들의 활성화 상태 설정
		self.leftArrowButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.rightArrowButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.newRoomButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		for _, roomButton in ipairs(self.roomButtonArray) do
			roomButton.button.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowArrowButtons()
		-- 화살표 버튼 표시
		if self.leftArrowButtonTweener then
			self.leftArrowButtonTweener:Destroy()
		end
		self.leftArrowButtonTweener = _Tween:ScaleTo(self.leftArrowButtonEntity, Vector2.one, 0.125, EaseType.Linear)
		
		if self.rightArrowButtonTweener then
			self.rightArrowButtonTweener:Destroy()
		end
		self.rightArrowButtonTweener = _Tween:ScaleTo(self.rightArrowButtonEntity, Vector2.one, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void HideArrowButtons()
		-- 화살표 버튼 숨기기
		local leftArrowButtonTransform = self.leftArrowButtonEntity.TransformComponent
		leftArrowButtonTransform.Scale.x = 0
		leftArrowButtonTransform.Scale.y = 0
		if self.leftArrowButtonTweener then
			self.leftArrowButtonTweener:Destroy()
		end
		
		local rightArrowButtonTransform = self.rightArrowButtonEntity.TransformComponent
		rightArrowButtonTransform.Scale.x = 0
		rightArrowButtonTransform.Scale.y = 0
		if self.rightArrowButtonTweener then
			self.rightArrowButtonTweener:Destroy()
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowRoomButtons(integer pageIndex)
		-- 지정된 페이지의 룸 버튼들 표시
		self.pageIndex = pageIndex
		
		if self.newRoomButtonTweener then
			self.newRoomButtonTweener:Destroy()
		end
		self.newRoomButtonTweener = _Tween:ScaleTo(self.newRoomButtonEntity, Vector2.one, 0.125, EaseType.Linear)
		
		for i = 1, #self.roomButtonArray do
			local roomButtonTransform = self.roomButtonArray[i].Entity.TransformComponent
			roomButtonTransform.Scale.x = 0
			roomButtonTransform.Scale.y = 0
			local roomButtonTweener = self.roomButtonTweenerArray[i]
			if roomButtonTweener then
				roomButtonTweener:Destroy()
			end
		end
		
		local buttonsPerPage = self.gridSize.x * self.gridSize.y - 1
		local start = 1 + buttonsPerPage * (pageIndex - 1)
		local finish = math.min(buttonsPerPage * pageIndex, #self.roomArray)
		for roomIndex = start, finish do
			local buttonIndex = (roomIndex - 1) % buttonsPerPage + 1
			local roomButton = self.roomButtonArray[buttonIndex]
			local room = self.roomArray[roomIndex]
			
			roomButton:SetRoom(room)
			
			self.roomButtonTweenerArray[buttonIndex] = _Tween:ScaleTo(roomButton.Entity, Vector2.one, 0.125, EaseType.Linear)
		end
	end

	@ExecSpace("ClientOnly")
	method void HideRoomButtons()
		-- 모든 룸 버튼 숨기기
		local newRoomButtonTransform = self.newRoomButtonEntity.TransformComponent
		newRoomButtonTransform.Scale.x = 0
		newRoomButtonTransform.Scale.y = 0
		if self.newRoomButtonTweener then
			self.newRoomButtonTweener:Destroy()
		end
		
		for i = 1, #self.roomButtonArray do
			local roomButtonTransform = self.roomButtonArray[i].Entity.TransformComponent
			roomButtonTransform.Scale.x = 0
			roomButtonTransform.Scale.y = 0
			local roomButtonTweener = self.roomButtonTweenerArray[i]
			if roomButtonTweener then
				roomButtonTweener:Destroy()
			end
		end
		table.clear(self.roomButtonTweenerArray)
	end

end