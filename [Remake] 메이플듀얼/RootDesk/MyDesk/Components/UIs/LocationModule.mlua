@Component
script LocationModule extends Component

	property TextComponent text = nil

	@ExecSpace("ClientOnly")
	method void SetLobby()
		-- 로비 위치 정보를 설정하여 현재 채널 번호를 표시
		local channel = _UserService.LocalPlayer.CurrentMap.Home.channel
		if not _Table:IsEmpty(channel) then
			self.text.Text = string.format("%s %d", _LocalizationService:GetText("Channel"), channel.id)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetRankedMatch()
		-- 랭크 매치 위치 정보를 설정하여 텍스트 표시
		self.text.Text = _LocalizationService:GetText("RankedMatch")
	end

	@ExecSpace("ClientOnly")
	method void SetFriendlyMatch()
		-- 친선전 위치 정보를 설정하여 현재 방 번호를 표시
		local room = _UserService.LocalPlayer.CurrentMap.Room.room
		if not _Table:IsEmpty(room) and not _Table:IsEmpty(room.channel) then
			self.text.Text = string.format("%s %d-%d", _LocalizationService:GetText("Room"), room.channel.id, room.id) 
		end
	end

	@ExecSpace("ClientOnly")
	method void SetPractice()
		-- 연습 모드 위치 정보를 설정하여 텍스트 표시
		self.text.Text = _LocalizationService:GetText("Practice")
	end

	@ExecSpace("ClientOnly")
	method void SetTutorial()
		-- 튜토리얼 위치 정보를 설정하여 텍스트 표시
		self.text.Text = _LocalizationService:GetText("Tutorial")
	end

end