@Component
script MesoModule extends Component

	property TextComponent text = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 메소 모듈 초기화 시 플레이어 메소 변경 이벤트를 연결하고 UI 업데이트
		local character = _UserService.LocalPlayer.Character
		character.Entity:ConnectEvent(SetMeso, function()
			self.text.Text = tostring(character.meso)
		end)
	end

end