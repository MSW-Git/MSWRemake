@Component
script RankedMatchModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity panelEntity = nil

	property Entity gameStartButtonEntity = nil

	property ButtonComponent gameStartButton = nil

	property Entity cancelButtonEntity = nil

	property ButtonComponent cancelButton = nil

	property Entity messageEntity = nil

	property SpriteRendererComponent rankImage = nil

	property TextComponent rankNameText = nil

	property TextComponent rankPointText = nil

	property DeckMenu deckMenu = nil

	property boolean isMatching = false

	property any messageTweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 랭크 매치 모듈 초기화 및 이벤트 연결
		self.deckMenu = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("DeckMenu"), "DeckMenu", Vector3(0, -0.54, 0), self.panelEntity).DeckMenu
		
		local character = _UserService.LocalPlayer.Character
		_UserService.LocalPlayer:ConnectEvent(SetRank, function()
			local resource = self.resourceManager:GetResource("Rank")
			
			local majorRank = character:GetMajorRank()
			self.rankImage.SpriteRUID = resource[majorRank]
			local colorTable = {
				Iron = Color.FromHexCode("#BA7E06"), 
				Bronze = Color.FromHexCode("#FEA537"),
				Silver = Color.FromHexCode("#BFBFBF"), 
				Gold = Color.FromHexCode("#FFD400"), 
				Platinum = Color.FromHexCode("#03FFAF"), 
				Master = Color.FromHexCode("#D95AFF"), 
				Legend = Color.FromHexCode("#FF3E3E"), 
			}
			self.rankNameText.Text = character:GetRankName()
			self.rankNameText.FontColor = colorTable[majorRank]
			self.rankPointText.Text = character:GetRankPoint()
		end)
		
		self.gameStartButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() or not character:IsAbleToMatch() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			local home = self.Entity.CurrentMap.Home
			_Server:Request(home, "BeginMatching", {character})
		end)
		
		self.cancelButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() or not character.isMatching then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickRawSound, 1)
			
			local home = self.Entity.CurrentMap.Home
			_Server:Request(home, "CancelMatching", {character})
		end)
		
		self.rankImage.Entity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() or character.isMatching then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self.uiManager.RankingModule:Open()
		end)
	end

	@ExecSpace("ClientOnly")
	method void SetButtonsEnable(boolean enable)
		-- 랭크 매치 관련 버튼들의 활성화 상태 설정
		self.gameStartButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.cancelButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.deckMenu:SetButtonsEnable(enable)
	end

	@ExecSpace("ClientOnly")
	method void SetMatching(boolean isMatching)
		-- 매칭 상태에 따라 UI 요소들의 표시 상태 변경
		self.isMatching = isMatching
		
		if self.messageTweener then
			self.messageTweener:Destroy()
		end
		
		if isMatching then
			self.gameStartButtonEntity.Enable = false
			self.cancelButtonEntity.Enable = true
			
			self.messageTweener = _Tween:ScaleTo(self.messageEntity, Vector2.one, 0.125, EaseType.Linear)	
			self.deckMenu:HideArrowButtons()
		else
			self.gameStartButtonEntity.Enable = true
			self.cancelButtonEntity.Enable = false
			
			self.messageTweener = _Tween:ScaleTo(self.messageEntity, Vector2.zero, 0.125, EaseType.Linear)
			self.deckMenu:ShowArrowButtons()
		end
	end

end