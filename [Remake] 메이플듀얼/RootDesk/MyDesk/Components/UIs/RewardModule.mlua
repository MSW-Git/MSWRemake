@Component
script RewardModule extends Component

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property UIManager uiManager = "89581f5f-f2ca-4453-af02-8a4d31de7d93"

	property Entity cancelEntity = "c5a80165-7e20-430e-9d0f-0d16ce9d0bf3"

	property Entity blockEntity = "d70ab9f9-cbee-48b8-8c7b-eccc90623815"

	property Entity panelEntity = "91f0ece8-d99e-4438-be32-39aec0ca0a12"

	property Entity rewardButtonEntity = nil

	property ButtonComponent rewardButton = nil

	property ButtonComponent dailyButton = nil

	property ButtonComponent rankButton = nil

	property Entity dailyMenuEntity = nil

	property Entity rankMenuEntity = nil

	property ButtonComponent leftArrowButton = nil

	property ButtonComponent rightArrowButton = nil

	property TextComponent pageNumberText = nil

	property boolean isOpen = false

	property any panelTweener = nil

	property table dailyRewardSlotArray = {}

	property table rankRewardSlotArray = {}

	property string mode = ""

	property integer pageIndex = 0

	property table mesoArray = {}

	property any tweener = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 보상 모듈 초기화 및 이벤트 연결
		local character = _UserService.LocalPlayer.Character
		
		self.cancelEntity:ConnectEvent(TouchEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			self:Close()
		end)
		
		self.rewardButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			if character.isMatching or isvalid(character.player) then
				return
			end
			
			if self.isOpen then
				self:Close()
			else
				_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
				
				self:Open()
			end
		end)
		
		self.dailyRewardSlotArray = {
			self.dailyMenuEntity:GetChildByName("RewardSlot_1").RewardSlot,
			self.dailyMenuEntity:GetChildByName("RewardSlot_2").RewardSlot,
			self.dailyMenuEntity:GetChildByName("RewardSlot_3").RewardSlot,
			self.dailyMenuEntity:GetChildByName("RewardSlot_4").RewardSlot,
			self.dailyMenuEntity:GetChildByName("RewardSlot_5").RewardSlot,
		}
		
		self.rankRewardSlotArray = {
			self.rankMenuEntity:GetChildByName("RewardSlot_1").RewardSlot,
			self.rankMenuEntity:GetChildByName("RewardSlot_2").RewardSlot,
			self.rankMenuEntity:GetChildByName("RewardSlot_3").RewardSlot,
			self.rankMenuEntity:GetChildByName("RewardSlot_4").RewardSlot,
			self.rankMenuEntity:GetChildByName("RewardSlot_5").RewardSlot,
		}
		
		self.mesoArray = {500, 500, 500, 3000, 500, 500, 500, 5000, 1000, 1000, 1000, 10000, 1000, 1000, 1000, 20000, 3000, 3000, 3000, 40000}
		
		self.dailyButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self:SetMode("Daily")
		end)
		
		self.rankButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if not character.isLoaded or _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickOpenSound, 1)
			
			self:SetMode("Rank")
		end)
		
		self.leftArrowButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			if self.pageIndex > 1 then
				self:ShowRankRewards(self.pageIndex - 1)
			end
		end)
		
		self.rightArrowButton.Entity:ConnectEvent(ButtonClickEvent, function()
			if _Server:IsRequesting() then
				return
			end
			
			_SoundService:PlaySound(self.resourceManager:GetResource("UI").buttonClickSwitchSound, 1)
			
			if self.pageIndex < math.ceil(#self.mesoArray / #self.rankRewardSlotArray) then
				self:ShowRankRewards(self.pageIndex + 1)
			end
		end)
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- 보상 모듈 열기
		self.isOpen = true
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.cancelEntity.Enable = true
		self.blockEntity.Enable = true
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.panelEntity, Vector2.one, 0.125, EaseType.Linear)
		
		self:SetMode("Daily")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 보상 모듈 닫기
		self.isOpen = false
		self.uiManager:UpdateButtons()
		self.uiManager:UpdateMobileUI()
		
		self.cancelEntity.Enable = false
		self.blockEntity.Enable = false
		
		if self.panelTweener then
			self.panelTweener:Destroy()
		end
		self.panelTweener = _Tween:ScaleTo(self.panelEntity, Vector2.zero, 0.125, EaseType.Linear)
		
		self.mode = ""
	end

	@ExecSpace("ClientOnly")
	method void SetRewardButtonEnable(boolean enable)
		-- 보상 버튼의 활성화 상태 설정
		self.rewardButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void SetPanelButtonsEnable(boolean enable)
		-- 보상 패널 버튼들의 활성화 상태 설정
		self.dailyButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.rankButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		
		self.leftArrowButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
		self.rightArrowButton.Entity.SpriteGUIRendererComponent.RaycastTarget = enable
	end

	@ExecSpace("ClientOnly")
	method void SetMode(string mode)
		-- 보상 모드 전환 (일일/랭크)
		if self.mode == mode then
			return
		end
		self.mode = mode
		
		local resource = self.resourceManager:GetResource("RewardModule")
		if self.mode == "Daily" then
			self.dailyButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			self.rankButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			self.dailyMenuEntity.Enable = true
			self.rankMenuEntity.Enable = false
			
			self:ShowDailyRewards()
		elseif self.mode == "Rank" then
			self.dailyButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.unselectedMode
			self.rankButton.Entity.SpriteGUIRendererComponent.ImageRUID = resource.selectedMode
			self.dailyMenuEntity.Enable = false
			self.rankMenuEntity.Enable = true
			
			self:ShowRankRewards(1)
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowDailyRewards()
		-- 일일 보상 목록 표시
		for _, rewardSlot in ipairs(self.dailyRewardSlotArray) do
			rewardSlot:SetDailyReward()
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowRankRewards(integer pageIndex)
		-- 랭크 보상 목록 표시
		self.pageIndex = pageIndex
		
		for _, rewardSlot in ipairs(self.rankRewardSlotArray) do
			rewardSlot.Entity.Enable = false
		end
		
		local start = 1 + (pageIndex - 1) * #self.rankRewardSlotArray
		local finish = math.min(pageIndex * #self.rankRewardSlotArray, #self.mesoArray)
		
		for i = start, finish do
			local rewardSlot = self.rankRewardSlotArray[(i - 1) % #self.rankRewardSlotArray + 1]
			local meso = self.mesoArray[i]
			
			rewardSlot.Entity.Enable = true
			rewardSlot:SetRankReward(500 + i * 100, meso)
		end
		
		self.pageNumberText.Text = string.format("%d/%d", pageIndex, math.max(1, math.ceil(#self.mesoArray / #self.rankRewardSlotArray)))
	end

	@ExecSpace("ClientOnly")
	method void Show()
		-- 보상 버튼 표시
		if self.tweener then
			self.tweener:Destroy()
		end
		self.tweener = _Tween:ScaleTo(self.rewardButtonEntity, Vector2.one, 0.125, EaseType.Linear)
	end

	@ExecSpace("ClientOnly")
	method void Hide()
		-- 보상 버튼 숨기기
		if self.tweener then
			self.tweener:Destroy()
		end
		self.tweener = _Tween:ScaleTo(self.rewardButtonEntity, Vector2.zero, 0.125, EaseType.Linear)
		
		self:Close()
	end

end