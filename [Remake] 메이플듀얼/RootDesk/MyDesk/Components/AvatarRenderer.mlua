@Component
script AvatarRenderer extends AvatarRendererComponent

	property string emotionalType = ""

	property string actionName = ""

	property integer frameIndex = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 아바타 렌더러 초기화 및 감정/동작 설정
		self.ShowDefaultWeaponEffects = false
		
		self:PlayEmotion(_UtilLogic:IsNilorEmptyString(self.emotionalType) and EmotionalType.Default or EmotionalType.CastFrom(self.emotionalType), 3.402823466e+38)
		
		local bodyEntity = self:GetBodyEntity()
		bodyEntity:SendEvent(ActionStateChangedEvent(self.actionName, self.actionName, 1, SpriteAnimClipPlayType.Loop, self.frameIndex, self.frameIndex))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "EditorService")
	handler HandleScreenTouchEditorEvent(ScreenTouchEditorEvent event)
		-- 에디터 화면 터치 이벤트 처리 시 아바타 상태 재설정
		--------------- Native Event Sender Info ----------------
		-- Sender: EditorService
		-- Space: Editor
		---------------------------------------------------------
		
		-- Parameters
		local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		
		self:PlayEmotion(_UtilLogic:IsNilorEmptyString(self.emotionalType) and EmotionalType.Default or EmotionalType.CastFrom(self.emotionalType), 3.402823466e+38)
		
		local bodyEntity = self:GetBodyEntity()
		bodyEntity:SendEvent(ActionStateChangedEvent(self.actionName, self.actionName, 1, SpriteAnimClipPlayType.Loop, self.frameIndex, self.frameIndex))
	end

end