@Component
script DeckManager extends Component

	property CardManager cardManager = "aa80dcbc-1e88-4f95-9e8e-f3e3b9749e7d"

	property any dataSet = nil

	property table adjectiveArray = {}

	method void OnBeginPlay()
		-- 덱 매니저 초기화 시 데이터셋과 형용사 배열을 설정
		self.dataSet = _DataService:GetTable("Deck")
		
		local column = self.dataSet:GetColumn("key")
		self.adjectiveArray = {}
		for i = 6, #column do
			table.insert(self.adjectiveArray, column[i])
		end
	end

	method boolean IsDeckValid(table deck)
		-- 덱이 유효한지 검사 (클래스, 이름, 카드 수, 카드 제한 등)
		if _Table:IsEmpty(deck) then
			return false
		end
		
		if not (deck.class == "Warrior" or deck.class == "Magician" or deck.class == "Bowman" or deck.class == "Thief" or deck.class == "Pirate") then
			return false
		end
		
		if _UtilLogic:IsNilorEmptyString(deck.name) then
			return false
		end
		
		if deck.cardTable ~= nil then
			if self:GetDeckSize(deck) > 20 then
				return false
			end
			
			for name, _ in ipairs(deck.cardTable) do
				local class = self.cardManager:GetClass(name)
				if not (class == "Common" or class == deck.class) then
					return false
				end
				
				if self:GetCardCountByName(deck, name) > 2 then
					return false
				end
			end
		end
		
		return true
	end

	method boolean IsDeckComplete(table deck)
		-- 덱이 완성되었는지 검사 (유효하고 20장인지)
		if not self:IsDeckValid(deck) then
			return false
		end
		
		return self:GetDeckSize(deck) == 20
	end

	method integer GetDeckSize(table deck)
		-- 덱의 총 카드 수를 계산하여 반환
		local size = 0
		
		if deck.cardTable ~= nil then
			for name, t1 in pairs(deck.cardTable) do
				for variant, t2 in pairs(t1) do
					for quality, count in pairs(t2) do
						size += count
					end
				end
			end
		end
		
		return size
	end

	method integer GetCardCountByName(table deck, string name)
		-- 덕에서 특정 이름의 카드 총 개수를 계산하여 반환
		if deck.cardTable == nil then
			return 0
		end
		
		if deck.cardTable[name] == nil then
			return 0
		end
		
		local count = 0
		for _, t2 in pairs(deck.cardTable[name]) do
			for _, value in pairs(t2) do
				count += value
			end 
		end
		
		return count
	end

	method integer GetCardCountByInfo(table deck, table info)
		-- 덕에서 특정 카드 정보(이름, 변형, 품질)의 개수를 반환
		local name = info.name
		local variant = info.variant
		local quality = info.quality
		
		return (deck.cardTable and deck.cardTable[name] and deck.cardTable[name][variant] and deck.cardTable[name][variant][quality]) and 
			deck.cardTable[name][variant][quality] or 0
	end

	method string GetText(string localeId, string key)
		-- 데이터셋에서 지역화 텍스트를 가져옴 (한국어/영어 지원)
		if not (localeId == "ko" or localeId == "en") then
			localeId = nil
		end
		
		local row = self.dataSet:FindRow("key", key)
		return row:GetItem(localeId or "Source")
	end

	method table GetNewDeck(string class, string localeId)
		-- 지정된 클래스와 언어로 빈 덕을 생성 (랜덤 형용사로 이름 생성)
		return {
			class = class,
			name = string.format("%s %s %s", self:GetText(localeId, _Table:GetRandomElement(self.adjectiveArray)), self:GetText(localeId, class), self:GetText(localeId, "Deck")),
			cardTable = nil
		}
	end

