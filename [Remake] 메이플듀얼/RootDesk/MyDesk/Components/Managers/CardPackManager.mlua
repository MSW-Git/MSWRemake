@Component
script CardPackManager extends Component

	property CardManager cardManager = "aa80dcbc-1e88-4f95-9e8e-f3e3b9749e7d"

	property ResourceManager resourceManager = "6c93cf84-def7-4ef2-9b6f-3581aa970c82"

	property any dataSet = nil

	property table cardPackNameTable = {}

	property table cardPackPool = {}

	property table thumbnailPool = {}

	property table positionArray = {}

	property integer count = 0

	property number zPosition = 3000

	method void OnBeginPlay()
		-- 카드팩 매니저 초기화 시 데이터셋 로드 및 테마별 카드팩 분류
		self.dataSet = _DataService:GetTable("CardPack")
		
		for _, name in ipairs(self.dataSet:GetColumn("name")) do
			local theme = self:GetTheme(name)
			self.cardPackNameTable[theme] = self.cardPackNameTable[theme] or {}
			table.insert(self.cardPackNameTable[theme], name)
		end
		
		self.positionArray = {Vector2(0, 2.5), Vector2(-1, 2.2), Vector2(-0.5, 1.1), Vector2(0.5, 1.1), Vector2(1, 2.2)}
	end

	method string GetTheme(string name)
		-- 카드팩의 테마를 반환
		return self.dataSet:FindRow("name", name):GetItem("theme")
	end

	method string GetQuality(string name)
		-- 카드팩의 품질을 반환
		return self.dataSet:FindRow("name", name):GetItem("quality")
	end

	method string GetRarity(string name)
		-- 카드팩의 희귀도를 반환
		return self.dataSet:FindRow("name", name):GetItem("rarity")
	end

	method string GetCurrency(string name)
		-- 카드팩의 구매 화폐 종류를 반환
		return self.dataSet:FindRow("name", name):GetItem("currency")
	end

	method integer GetSingleMesoPrice(string name)
		-- 카드팩의 단일 메소 가격을 반환
		return tonumber(self.dataSet:FindRow("name", name):GetItem("singleMesoPrice"))
	end

	method integer GetMultipleMesoPrice(string name)
		-- 카드팩의 다중 메소 가격을 반환
		return tonumber(self.dataSet:FindRow("name", name):GetItem("multipleMesoPrice"))
	end

	method integer GetSingleWorldCoinPrice(string name)
		-- 카드팩의 단일 월드코인 가격을 반환
		return tonumber(self.dataSet:FindRow("name", name):GetItem("singleWorldCoinPrice"))
	end

	method integer GetMultipleWorldCoinPrice(string name)
		-- 카드팩의 다중 월드코인 가격을 반환
		return tonumber(self.dataSet:FindRow("name", name):GetItem("multipleWorldCoinPrice"))
	end

	method table GetCardPackNames(string theme)
		-- 특정 테마의 카드팩 이름 목록을 반환
		return self.cardPackNameTable[theme]
	end

	method integer GetSinglePrice(string name)
		-- 카드팩의 단일 구매 가격을 화폐 종류에 따라 반환
		local currency = self:GetCurrency(name)
		if currency == "Meso" then
			return self:GetSingleMesoPrice(name)
		elseif currency == "WorldCoin" then
			return self:GetSingleWorldCoinPrice(name)
		end
	end

	method integer GetMultiplePrice(string name)
		-- 카드팩의 다중 구매 가격을 화폐 종류에 따라 반환
		local currency = self:GetCurrency(name)
		if currency == "Meso" then
			return self:GetMultipleMesoPrice(name)
		elseif currency == "WorldCoin" then
			return self:GetMultipleWorldCoinPrice(name)
		end
	end

	@ExecSpace("ServerOnly")
	method table GetInfos(string cardPackName)
		-- 카드팩을 열었을 때 나올 5장의 카드 정보를 희귀도에 따라 랜덤 생성
		local cardPackTheme = self:GetTheme(cardPackName)
		local cardPackQuality = self:GetQuality(cardPackName)
		local cardPackRarity = self:GetRarity(cardPackName)
		
		local infoArray = {}
		for i = 1, 5 do
			local name
			local variant
			local quality
			
			local value
			
			if cardPackRarity == "Epic" then
				value = _UtilLogic:RandomDouble()
				if value < 0.25 then
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Epic"))
				else
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Rare"))
				end
			elseif cardPackRarity == "Unique" then
				value = _UtilLogic:RandomDouble()
				if value < 0.05 then
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Unique"))
				elseif value < 0.35 then
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Epic"))
				else
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Rare"))
				end
			elseif cardPackRarity == "Legendary" then
				value = _UtilLogic:RandomDouble()
				if value < 0.025 then
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Legendary"))
				elseif value < 0.1 then
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Unique"))
				elseif value < 0.5 then
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Epic"))
				else
					name = _Table:GetRandomElement(self.cardManager:GetCardNamesByThemeAndRarity(cardPackTheme, "Rare"))
				end
			end
			
			value = _UtilLogic:RandomDouble()
		 	if value < 0.05 then
				variant = _Table:GetRandomElement(self.cardManager:GetVariants(name)) or "Default"
			else
				variant = "Default"
			end
			
			if cardPackQuality == "Gold" then
				value = _UtilLogic:RandomDouble()
				if value < 0.1 then
					quality = "Gold"
				else
					quality = "Silver"
				end
			else
				quality = "Silver"
			end
			
			infoArray[i] = {name = name, variant = variant, quality = quality}
		end
		
		return infoArray
	end

	@ExecSpace("ClientOnly")
	method void OpenCardPack(Character character, string cardPackName, table infoArray)
		-- 클라이언트에서 카드팩 개봉 애니메이션과 카드 썸네일 표시 처리
		self.count += 1
		self.zPosition -= 1
		
		local zPosition = self.zPosition
		local characterPosition = character.Entity.TransformComponent.WorldPosition:ToVector2()
		 
		local cardPack = self:AcquireCardPack()
		cardPack.SpriteRendererComponent.SpriteRUID = self.resourceManager:GetResource("CardPack")[cardPackName]
		local cardPackTransform = cardPack.TransformComponent
		cardPackTransform.Position.x = characterPosition.x
		cardPackTransform.Position.y = characterPosition.y
		cardPackTransform.Position.z = zPosition
		cardPackTransform.Scale.x = 0
		cardPackTransform.Scale.y = 0
		
		local cardPackTweener = _Tween:MoveAndScaleTo(cardPack, characterPosition + Vector2(0, 1.75), 0.25 * Vector2.one, 0.125, EaseType.Linear, EaseType.Linear, true)
		local cardPackTimer = _TimerService:SetTimerOnce(function()
			if cardPackTweener then
				cardPackTweener:Destroy()
			end
			cardPackTweener = _Tween:Twitch(cardPack, 0, 8, 0.75)
		end, 0.25)
		
		_TimerService:SetTimerOnce(function()
			cardPackTweener:Destroy()
			cardPackTransform.Scale.x = 0
			cardPackTransform.Scale.y = 0
			
			self:ReleaseCardPack(cardPack)
			
			for i, info in ipairs(infoArray) do
				local thumbnail = self:AcquireThumbnail()
				thumbnail:SetInfo(info)
				local thumbnailTransform = thumbnail.Entity.TransformComponent
				thumbnailTransform.Position.x = characterPosition.x
				thumbnailTransform.Position.y = characterPosition.y + 1.75
				thumbnailTransform.Position.z = zPosition
				thumbnailTransform.Scale.x = 0
				thumbnailTransform.Scale.y = 0
				
				local thumbnailTweener = _Tween:MoveAndScaleTo(thumbnail.Entity, characterPosition + self.positionArray[i], Vector2.one, 0.25, EaseType.CubicEaseOut, EaseType.CubicEaseOut, true)
				
				_TimerService:SetTimerOnce(function()
					_EffectService:PlayEffectAttached(self.resourceManager:GetResource("CardPackModule")["Front" .. thumbnail.rarity], thumbnail.rarityEntity, Vector3(0, 0, -0.001), 0, 0.666 * Vector3.one, false, {SortingLayer = "Decoration", OrderInLayer = 5})
					
					if thumbnail.rarity ~= "Rare" then
						_EffectService:PlayEffectAttached(self.resourceManager:GetResource("CardPackModule")["Back" .. thumbnail.rarity], thumbnail.rarityEntity, Vector3(0, 0, 0.001), 0, 0.666 * Vector3.one, false, {SortingLayer = "Decoration", OrderInLayer = 5})
					end	
				end, 0.25)
				
				_TimerService:SetTimerOnce(function()
					thumbnailTweener:Destroy()
					thumbnailTweener = _Tween:ScaleTo(thumbnail.Entity, Vector2.zero, 0.125, EaseType.Linear)
					
					wait(0.25)
					
					thumbnailTweener:Destroy()
					thumbnail:ClearInfo()
					self:ReleaseThumbnail(thumbnail)
				end, 6.25)
			end
			
			wait(6.5)
			
			self.count -= 1
			if self.count <= 0 then
				self.zPosition = 1000
			end
		end, 1.5)
	end

	@ExecSpace("ClientOnly")
	method Thumbnail AcquireThumbnail()
		-- 썸네일 객체를 풀에서 가져오거나 새로 생성하여 반환
		local thumbnail
		if _Table:IsEmpty(self.thumbnailPool) then
			thumbnail = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Thumbnail"), "Thumbnail", 
				Vector3.zero, _UserService.LocalPlayer.CurrentMap).Thumbnail
		else
			thumbnail = table.remove(self.thumbnailPool)
		end	
		
		return thumbnail
	end

	@ExecSpace("ClientOnly")
	method void ReleaseThumbnail(Thumbnail thumbnail)
		-- 사용한 썸네일 객체를 풀로 반환하여 재사용 가능하게 함
		table.insert(self.thumbnailPool, thumbnail)
	end

	@ExecSpace("ClientOnly")
	method Entity AcquireCardPack()
		-- 카드팩 엔티티를 풀에서 가져오거나 새로 생성하여 반환
		local cardPack
		if _Table:IsEmpty(self.cardPackPool) then
			cardPack = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("CardPack"), "CardPack", 
				Vector3.zero, _UserService.LocalPlayer.CurrentMap)
		else
			cardPack = table.remove(self.cardPackPool)
		end	
		
		return cardPack
	end

	@ExecSpace("ClientOnly")
	method void ReleaseCardPack(Entity cardPack)
		-- 사용한 카드팩 엔티티를 풀로 반환하여 재사용 가능하게 함
		table.insert(self.cardPackPool, cardPack)
	end

end