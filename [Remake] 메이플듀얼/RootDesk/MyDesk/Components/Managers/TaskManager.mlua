	method void SortMinions(table fieldArray, any comparer)
		-- 필드의 미니언들을 주어진 비교 함수로 정렬
		local objectArray = fieldArray
		local taskName = "SortMinions"
		local args = {comparer}
		self.duel:Sort(objectArray)
		
		self:RunBatch(objectArray, taskName, args, nil, nil, nil)
		
		self.commandManager:InputGate()
	end

	method void MoveMinionToFarLeft(Minion minion)
		-- 미니언을 필드의 가장 왼쪽 끝으로 이동
		local objectArray = {minion.field}
		local taskName = "MoveMinionToFarLeft"
		local args = {minion}
		
		self:RunBatch(objectArray, taskName, args, nil, nil, nil)
		
		self.commandManager:InputGate()
	end

	method void MoveMinionToFarRight(Minion minion)
		-- 미니언을 필드의 가장 오른쪽 끝으로 이동
		local objectArray = {minion.field}
		local taskName = "MoveMinionToFarRight"
		local args = {minion}
		
		self:RunBatch(objectArray, taskName, args, nil, nil, nil)
		
		self.commandManager:InputGate()
	end

	method void Cross(Minion minion, string actionName)
		-- 미니언을 상대방 필드로 이동시켜 소유권 변경
		if minion.player.opponent.field:IsFull() then
			return
		end
		
		local objectArray = {minion}
		local taskName = "Cross"
		local args = {}
		
		self:RunBatch(objectArray, taskName, args, nil, actionName, nil)
		
		local fromField = minion.player.field
		local toField = minion.player.opponent.field
		
		fromField:RemoveMinions(objectArray)
		toField:InsertMinions(objectArray, nil)
		minion:SetPlayer(minion.player.opponent)
		minion:TransformToAnchor()
		
		self.commandManager:InputGate()
	end

	method void InsertSetRandomBattleEnchantment(boolean isRandomBattle, boolean remover)
		-- 듀얼에 랜덤 전투 인챈트먼트를 설정하여 전투 방식 변경
		local objectArray = {self.duel}
		local taskName = "InsertSetRandomBattleEnchantment"
		local args = {isRandomBattle, remover}
		
		self:RunBatch(objectArray, taskName, args, nil, nil, nil)
	end

end