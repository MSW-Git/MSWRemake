		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames(self.commandManager:ShareRandomElementsInArray(self.cardManager:GetMinionNamesByCost(2), 2))
				self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
			end, "ClawMachine")
