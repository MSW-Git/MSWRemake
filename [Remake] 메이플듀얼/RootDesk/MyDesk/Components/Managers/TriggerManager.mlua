	method void TaeRoon(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local minion = receiver.player.opponent.field:GetRightmostMinion()
				if isvalid(minion) then
					self.taskManager:Battle({receiver, minion})
					if minion.isDead then
						self.taskManager:Draw({[receiver.player] = 1}, nil, false)
					end
				end
			end, "TaeRoon")
	end

