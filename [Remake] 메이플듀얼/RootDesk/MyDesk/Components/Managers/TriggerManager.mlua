	method void CloudFox(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local minionArray = receiver:ShareRandomOurOtherMinions(1, nil)
				if not _Table:IsEmpty(minionArray) then
					local nameArray = {}
					for i, minion in ipairs(minionArray) do
						nameArray[i] = minion.name
					end
					local blueprintArray = receiver:GetBlueprintsByNames(nameArray)
					self.taskManager:Add({[receiver.player] = blueprintArray}, receiver, nil)
				end
			end, "CloudFox")
	end

