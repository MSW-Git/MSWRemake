	method void NinjaStorm(Card invoker, Card receiver, table result, Minion target)
		self.taskManager:RunProcess(function()
				local minionArray = target:GetSelfAndAdjacentMinions(nil)
				local eachArgs = {}
				for _, minion in ipairs(minionArray) do
					if minion == target then
						eachArgs[minion] = {receiver, 1}
					else
						eachArgs[minion] = {receiver, 3}
					end
				end
				self.taskManager:Damage(minionArray, receiver, nil, eachArgs, "NinjaStorm", nil)
			end, "NinjaStorm")
	end

