	method void Clang(Duel invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				self.taskManager:Damage({receiver.player.opponent}, receiver, 2, nil, "Clang", nil)
			end, "Clang")
	end

	method boolean ClangCondition(string triggerKey, Duel invoker, Minion receiver, table result, table minionArray)
		if triggerKey == "PostBattle" and _Table:Contains(minionArray, receiver) then
			for _, minion in ipairs(minionArray) do
				if minion ~= receiver then
					return minion.isDead
				end
			end
		end
		
		return false
	end

