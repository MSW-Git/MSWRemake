	end

	method void Zakum(Minion invoker, Minion receiver)
		for i = 1, self.history:GetThisGameSkillCountByCostOrMore(receiver.player, 4) do
			local randomInteger = self.commandManager:ShareRandomIntegerRange(1, 3)
			if randomInteger == 1 then
				self.taskManager:RunProcess(function()
						self.taskManager:Damage(receiver.player.opponent:GetUnits(), receiver, 2, nil, "Zakum_1", nil)
					end, "Zakum_1")
			elseif randomInteger == 2 then
				self.taskManager:RunProcess(function()
						local blueprintArray = self.commandManager:ShareRandomElementsInArray(receiver:GetBlueprintsByNames({"Puco", "Punco", "Cuzco"}), 1) 
						self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
					end, "Zakum_2")
			elseif randomInteger == 3 then
				self.taskManager:RunProcess(function()
						self.taskManager:InsertAddMaxHpEnchantment({receiver}, 3, nil, nil, nil, nil)
						self.taskManager:InsertAddAtkEnchantment({receiver}, 3, nil, nil, nil, nil)
					end, "Zakum_3")
			end
		end
	end

	method boolean ZakumCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Summon" and invoker == receiver
	end

	method void Zeno(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				self.taskManager:InsertAddMaxHpEnchantment({receiver}, 1, nil, nil, nil, nil)
				self.taskManager:InsertAddAtkEnchantment({receiver}, 1, nil, nil, nil, nil)
			end, "Zeno")
	end

	method boolean ZenoCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "LoseBarrier" and invoker.player == receiver.player
	end

	method void ZombieLupin(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				self.taskManager:Damage(receiver.player.opponent:ShareRandomUnits(1), receiver, 1, nil, "ZombieLupin", nil)
			end, "ZombieLupin")
	end

	method boolean ZombieLupinCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Dead" and invoker.player == receiver.player and invoker ~= receiver
	end

	method void ZombieMushroom(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames(self.commandManager:SharePrivateRandomElementsInArray(receiver.player, "", self.cardManager:GetMinionNamesByTag("Mushroom"), 1))
				self.taskManager:Add({[receiver.player] = blueprintArray}, receiver, nil)
			end, "ZombieMushroom")
	end

	method boolean ZombieMushroomCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Dead" and invoker == receiver
	end

end