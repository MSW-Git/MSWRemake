		return triggerKey == "Summon" and invoker == receiver
	end

	method void Disorder(Card invoker, Card receiver, table result, Minion target)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames({target.name})
				self.taskManager:Kill({target}, "Disorder", nil)
				while self.duel:HasDeadMinion() do
					self.taskManager:Dead()
				end
				self.taskManager:Summon({[receiver.player] = blueprintArray}, nil, false)
			end, "Disorder")
	end

	method boolean DisorderCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

