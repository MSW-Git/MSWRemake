	method void BombingFishHouseDead(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames({"Goby", "Goby", "Goby"})
				for _, blueprint in ipairs(blueprintArray) do
					table.insert(blueprint.enchantmentArray, {methodName = "AddMaxHpEnchantment", args = {receiver.temp.stat or 0}})
					table.insert(blueprint.enchantmentArray, {methodName = "AddAtkEnchantment", args = {receiver.temp.stat or 0}})
				end
				self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
		
			end, "BombingFishHouseDead")
	end

