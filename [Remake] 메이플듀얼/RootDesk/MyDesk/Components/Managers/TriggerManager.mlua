	method void Hogul(Duel invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				self.taskManager:InsertAddAtkEnchantment({receiver}, 2, nil, nil, nil, nil)
			end, "Hogul")
	end

	method boolean HogulCondition(string triggerKey, Duel invoker, Minion receiver, table result, table minionArray)
		if triggerKey == "PostBattle" and _Table:Contains(minionArray, receiver) then
			for _, minion in ipairs(minionArray) do
				if minion ~= receiver then
					return minion.isDead
				end
			end
		end
		
		return false
	end

