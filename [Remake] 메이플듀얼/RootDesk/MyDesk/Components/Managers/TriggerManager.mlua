	method void Pepe(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local yeti
				for _, minion in ipairs(receiver.field.minionArray) do
					if minion.name == "Yeti" then
						yeti = minion
						break
					end
				end
				
				if isvalid(yeti) then
					local player = receiver.player
					local blueprintArray = receiver:GetBlueprintsByNames({"YetiAndPepe"})
		
					self.taskManager:Vanish({receiver, yeti}, "Pepe", nil)
					self.taskManager:Summon({[player] = blueprintArray}, nil, false)
				end
			end, "Pepe")
	end

	method boolean PepeCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Summon" and invoker == receiver
	end

