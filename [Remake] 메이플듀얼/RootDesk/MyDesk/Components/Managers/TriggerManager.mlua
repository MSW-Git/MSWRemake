	method void Papulatus(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
			local cardArray
			if self:IsServer() then
				cardArray = self.duel:GetHandCards(self.taskManager.minionSelector)
				self.commandManager:PushPackage(cardArray)
			else
				cardArray = self.commandManager:PopPackage()
			end
			self.taskManager:Place(cardArray, nil, false, false)
			end, "Papulatus")
	end

