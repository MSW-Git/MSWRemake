	method void Winston(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local cardTable = self.taskManager:Draw({[receiver.player] = #receiver.player.field:GetMinions(self.taskManager.plantSelector)}, nil, false)
				self.taskManager:InsertAddCostEnchantment(cardTable[receiver.player], -1, nil, nil, "Winston", nil)
			end, "Winston")
	end

	method boolean WinstonCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Summon" and invoker == receiver
	end

