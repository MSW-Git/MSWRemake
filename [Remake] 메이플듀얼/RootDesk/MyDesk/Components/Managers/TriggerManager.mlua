	method void EnergyDrain(Card invoker, Card receiver)
		self.taskManager:RunProcess(function()
				local resultTable = self.taskManager:Damage(receiver.player.opponent:GetUnits(), receiver, 1, nil, "EnergyDrain", nil)
				local totalDamage = 0
				for _, result in pairs(resultTable) do
					totalDamage += result.damage
				end
				self.taskManager:Heal({receiver.player}, totalDamage, nil, nil, nil)
			end, "EnergyDrain")
	end

	method boolean EnergyDrainCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

	method void EnergyOrb(Card invoker, Card receiver, table result, Unit target)
		self.taskManager:RunProcess(function()
				local damage = 3
				if self.history:GetThisRoundCardCount(receiver.player) >= 4 then
					damage += 3
				end
				self.taskManager:Damage({target}, receiver, damage, nil, "EnergyOrb", nil)
			end, "EnergyOrb")
	end

	method boolean EnergyOrbCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

