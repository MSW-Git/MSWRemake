	method void Rurumo(Duel invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local count = self.history:GetThisRoundCardCount(receiver.player) - 1
				self.taskManager:Damage({receiver.player}, receiver, count, nil, "Rurumo", nil)
				self.taskManager:GainMp({receiver.player}, count, nil, nil, nil)
			end, "Rurumo")
	end

