		self.taskManager:RunProcess(function()
				local minionArray = self.duel:ShareRandomMinions(1, self.taskManager.mushroomSelector)
				if not _Table:IsEmpty(minionArray) then
					local minion = minionArray[1]
					self.taskManager:Kill(minionArray, "Ronnie", nil)
					self.taskManager:InsertAddMaxHpEnchantment({receiver}, minion.hp, nil, nil, nil, nil)
					self.taskManager:InsertAddAtkEnchantment({receiver}, minion.atk, nil, nil, nil, nil)
				end
			end, "Ronnie")
