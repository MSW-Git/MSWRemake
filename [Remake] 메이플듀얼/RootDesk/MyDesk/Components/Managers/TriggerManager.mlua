		return triggerKey == "Summon" and invoker == receiver
	end

	method void Patricia(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames({"BrownTeddy", "PinkTeddy", "PandaTeddy"})
				self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
