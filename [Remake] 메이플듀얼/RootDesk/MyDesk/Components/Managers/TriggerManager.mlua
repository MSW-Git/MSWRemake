	method void Sacrifice(Card invoker, Card receiver, table result, Minion target)
		self.taskManager:RunProcess(function()
				self.taskManager:Kill({target}, "Sacrifice", nil)
				while self.duel:HasDeadMinion() do
					self.taskManager:Dead()
				end
				self.taskManager:Place(receiver.player.hand:ShareRandomCards(1, self.taskManager.minionSelector), nil, false, false)
			end, "Sacrifice")
	end

