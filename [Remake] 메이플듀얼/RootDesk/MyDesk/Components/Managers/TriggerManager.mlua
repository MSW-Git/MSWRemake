		self.taskManager:RunProcess(function()
				local cardTable = self.taskManager:Kick(receiver:GetOurOtherMinions(self.taskManager.petSelector), false, "Cloy", nil)
				if not _Table:IsEmpty(cardTable) then
					self.taskManager:InsertAddCostEnchantment(cardTable[receiver.player], -1, nil, nil, nil, nil)
				end
			end, "Cloy")
