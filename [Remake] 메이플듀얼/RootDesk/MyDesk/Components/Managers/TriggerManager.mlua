		return triggerKey == "Summon" and invoker == receiver
	end

	method void Rush(Card invoker, Card receiver, table result, Unit target)
		self.taskManager:RunProcess(function()
				local cardTable = self.taskManager:Draw({[receiver.player] = 1}, self.taskManager.minionSelector, false)
				if not _Table:IsEmpty(cardTable) and not _Table:IsEmpty(cardTable[receiver.player]) then
					local damage = nil
					if self:IsServer() then
						damage = cardTable[receiver.player][1].atk
						self.commandManager:PushPackage(damage)
					else
						damage = self.commandManager:PopPackage()
					end
					self.taskManager:Damage({target}, receiver, damage, nil, "Rush", nil)
				end
			end, "Rush")
	end

	method boolean RushCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

