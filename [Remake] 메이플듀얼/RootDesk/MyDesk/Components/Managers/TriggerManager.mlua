	method void Ayan(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver.player.hand:ShareRandomBlueprints(1, self.taskManager.minionSelector)
				if not _Table:IsEmpty(blueprintArray) then
					local blueprint = blueprintArray[1]
					table.insert(blueprint.enchantmentArray, {methodName = "SetMaxHpEnchantment", args = {1}})
					table.insert(blueprint.enchantmentArray, {methodName = "SetAtkEnchantment", args = {1}})
					self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
				end
			end, "Ayan")
	end

	method boolean AyanCondition(string triggerKey, Minion invoker, Minion receiver)
