	method void ChiefStan(Duel invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local nameArray = {}
				local oneArray = self.history:GetThisGameMinionsByCost(receiver.player, 1)
				local twoArray = self.history:GetThisGameMinionsByCost(receiver.player, 2)
				local threeArray = self.history:GetThisGameMinionsByCost(receiver.player, 3)
				if not _Table:IsEmpty(oneArray) then
					table.insert(nameArray, self.commandManager:ShareRandomElementInArray(oneArray))
				end
				if not _Table:IsEmpty(twoArray) then
					table.insert(nameArray, self.commandManager:ShareRandomElementInArray(twoArray))
				end
				if not _Table:IsEmpty(threeArray) then
					table.insert(nameArray, self.commandManager:ShareRandomElementInArray(threeArray))
				end
		
				if not _Table:IsEmpty(nameArray) then
					local blueprintArray = receiver:GetBlueprintsByNames(nameArray)
					self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
				end
			end, "ChiefStan")
	end

	method boolean ChiefStanCondition(string triggerKey, Duel invoker, Minion receiver)
		return triggerKey == "Summon" and invoker == receiver
	end

