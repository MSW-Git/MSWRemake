	method void BellflowerRoot(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local nameArray = self.history:GetThisGameDiscardedCards(receiver.player)
				if not _Table:IsEmpty(nameArray) then
					local blueprintArray = receiver:GetBlueprintsByNames(self.commandManager:SharePrivateRandomElementsInArray(receiver.player, "", nameArray, 1))
					local cardTable = self.taskManager:Add({[receiver.player] = blueprintArray}, receiver, nil)
					if not _Table:IsEmpty(cardTable) then
						self.taskManager:InsertAddCostEnchantment(cardTable[receiver.player], -2, nil, nil, nil, nil)
					end
				end
			end, "BellflowerRoot")
	end

