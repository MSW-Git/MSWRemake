	method void Tangyoon(Duel invoker, Minion receiver, table result, table minionArray)
		self.taskManager:RunProcess(function()
				for _, minion in ipairs(minionArray) do
					if minion.player == receiver.player then
						self.taskManager:Heal({minion}, 1, nil, "Tangyoon", nil)
					end
				end
			end, "Tangyoon")
	end

	method boolean TangyoonCondition(string triggerKey, Duel invoker, Minion receiver, table result, table minionArray)
		if triggerKey == "PostBattle" and not _Table:Contains(minionArray, receiver) then
			for _, minion in ipairs(minionArray) do
				if minion.player ~= receiver.player then
					return minion.isDead
				end
			end
		end
		
		return false
	end

