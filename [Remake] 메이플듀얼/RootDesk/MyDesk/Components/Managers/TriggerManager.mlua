	end

	method boolean TauromacisCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Summon" and invoker == receiver
	end

	method void TheRemembererSummon(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local minionArray = receiver.player.field:ShareRandomMinions(1, self.taskManager.devilSelector)
				if not _Table:IsEmpty(minionArray) then
					self.taskManager:Kill(minionArray, "TheRemembererSummon", nil)
					receiver.temp.name = minionArray[1].name
				end
			end, "TheRemembererSummon")
	end

	method boolean TheRemembererSummonCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Summon" and invoker == receiver
	end

	method void TheRemembererDead(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames({receiver.temp.name, receiver.temp.name})
				self.taskManager:Summon({[receiver.player] = blueprintArray}, receiver:GetLeftMinion(nil), false)
			end, "TheRemembererDead")
	end

	method boolean TheRemembererDeadCondition(string triggerKey, Minion invoker, Minion receiver)
		return triggerKey == "Dead" and invoker == receiver and not _UtilLogic:IsNilorEmptyString(receiver.temp.name)
	end

	method void Threaten(Card invoker, Card receiver, table result, Minion target)
		self.taskManager:RunProcess(function()
				self.taskManager:Scare({target}, "Threaten", nil)
			end, "Threaten")
	end

	method boolean ThreatenCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

	method void ThreeSnails(Card invoker, Card receiver)
		self.taskManager:RunProcess(function()
				local blueprintArray = receiver:GetBlueprintsByNames({"RedSnail", "BlueSnail", "Snail"})
				self.taskManager:Summon({[receiver.player] = blueprintArray}, nil, false)
			end, "ThreeSnails")
