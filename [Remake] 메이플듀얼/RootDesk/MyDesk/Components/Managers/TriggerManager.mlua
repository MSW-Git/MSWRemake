	method void Deo(Minion invoker, Minion receiver)
		self.taskManager:RunProcess(function()
				local minionArray = receiver:GetOurOtherMinions(nil)
				local eachArgs = {}
				for _, minion in ipairs(minionArray) do
					eachArgs[minion] = {minion.hp}
				end
				self.taskManager:InsertSetAtkEnchantment(minionArray, nil, nil, eachArgs, "Deo", nil)
			end, "Deo")
	end

