	end

	method void ThunderBolt(Card invoker, Card receiver)
		self.taskManager:RunProcess(function()
				local unitArray = receiver.player.opponent:GetUnits()
				local eachArgs = {}
				for _, unit in ipairs(unitArray) do
					eachArgs[unit] = {receiver, self.commandManager:ShareRandomIntegerRange(1, 3)}
				end
				self.taskManager:Damage(unitArray, receiver, nil, eachArgs, "ThunderBolt", nil)
			end, "ThunderBolt")
	end

	method boolean ThunderBoltCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

	method void ThunderSpear(Card invoker, Card receiver, table result, Minion target)
		self.taskManager:RunProcess(function()
				local resultTable = self.taskManager:Damage({target}, receiver, 5, nil, "ThunderSpear", nil)
				local excessDamage = resultTable[target].excessDamage
				if excessDamage > 0 then
					self.taskManager:GainMp({receiver.player}, excessDamage, nil, nil, nil)
				end
			end, "ThunderSpear")
	end

	method boolean ThunderSpearCondition(string triggerKey, Card invoker, Card receiver)
		return triggerKey == "Cast" and invoker == receiver
	end

	method void Timer(Duel invoker, Minion receiver)
		self.taskManager:RunProcess(function()
			self.taskManager:Place(receiver.player.hand:ShareRandomCards(1, self.taskManager.minionSelector), nil, false, false)
			end, "Timer")
	end

	method boolean TimerCondition(string triggerKey, Duel invoker, Minion receiver)
		return triggerKey == "BeginRound"
	end

