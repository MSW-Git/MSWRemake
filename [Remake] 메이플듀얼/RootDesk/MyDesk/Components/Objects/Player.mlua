			bodyEntity:SendEvent(ActionStateChangedEvent("shoot2", "shoot2"))
			self.animationTimer = _TimerService:SetTimerOnce(function()
					self.character.Entity:SendEvent(BodyActionStateChangeEvent(false, MapleAvatarBodyActionState.Alert))
				end, 0.8)
		elseif toAnimationState == "Idle" then
			if self.isPlaying then
				self:Animate("Play")
			else
				self.character.Entity:SendEvent(StateChangeEvent("IDLE", "IDLE"))
			end
		elseif toAnimationState == "Play" then
			self.character.Entity:SendEvent(BodyActionStateChangeEvent(false, MapleAvatarBodyActionState.Alert))
		else
			toAnimationState = string.upper(toAnimationState)
			self.character.Entity:SendEvent(StateChangeEvent(toAnimationState, toAnimationState))
		end
	end

	method boolean IsOurTurn()
		-- 현재 이 플레이어의 턴인지 확인
		return self == self.duel.turnPlayer
	end

	@ExecSpace("ClientOnly")
	method void ShowClassTag()
		-- 플레이어의 클래스 태그를 표시
		if isvalid(self.character) then
			local classTag = self.character.classTag
			classTag.Entity.Enable = true
			classTag.NameTagRUID = self.resourceManager:GetResource("NameTag")[self.class]
			classTag.Name = _LocalizationService:GetText(self.class) 
		end
	end

	@ExecSpace("ClientOnly")
	method void HideClassTag()
		-- 플레이어의 클래스 태그를 숨김
		if isvalid(self.character) then
			local classTag = self.character.classTag
			classTag.Entity.Enable = false
			classTag.NameTagRUID = ""
			classTag.Name = ""
		end
	end

	@ExecSpace("ClientOnly")
	method void ShowDetails()
		-- 플래이어의 HP, MP 세부 정보를 표시
		self.mpEntity.Enable = true
		self.hpEntity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void HideDetails()
		-- 플래이어의 HP, MP 세부 정보를 숨김
		self.mpEntity.Enable = false
		self.hpEntity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void TransformAnchorToPlay()
		-- 플래이어 앵커를 플레이 위치로 이동
		if not isvalid(self.anchorEntity) then
			return
		end
		
		self:DestroyAnchorTweener()
		self.anchorTweener = _Tween:MoveTo(self.anchorEntity, self.playPosition, 0.75, EaseType.CubicEaseOut, false)
	end

	@ExecSpace("ClientOnly")
	method void TransformAnchorToEndRound()
		-- 플래이어 앵커를 전투 위치로 이동
		if not isvalid(self.anchorEntity) then
			return
		end
		
		self:DestroyAnchorTweener()
		self.anchorTweener = _Tween:MoveTo(self.anchorEntity, self.battlePosition, 0.75, EaseType.CubicEaseOut, false)
	end

	@ExecSpace("ClientOnly")
	method void SetPlaying(boolean isPlaying)
		-- 플래이어의 플레이 상태를 설정하고 애니메이션 조정
		self.isPlaying = isPlaying
		
		if isPlaying then
			if self.animationState == "Idle" then
				self:Animate("Play")
			end
		else
			if self.animationState == "Play" then
				self:Animate("Idle")
			end	
		end
	end

	@ExecSpace("ClientOnly")
	method void SetRoundPlayerSign(boolean isRoundPlayer)
		-- 라운드 플레이어 표시를 설정 (배경 색상 변경)
		self.backgroundEntity.SpriteRendererComponent:ChangeMaterial(isRoundPlayer and _EntryService:GetMaterialIdByName("LimLightOrange") or "")
	end

	@ExecSpace("ClientOnly")
	method boolean JobsDone()
		-- 플레이어가 더 이상 플레이할 카드가 없는지 확인
		local jobsDone = true
		for _, card in ipairs(self.hand.cardArray) do
			if card.isPlayable then
				jobsDone = false
				break
			end
		end
		
		return jobsDone
	end

	method table GetUnits()
		-- 플래이어와 그의 미니언들을 모두 포함한 유닛 배열 반환
		return _Table:Concat(self.field:GetMinions(nil), {self})
	end

	method table ShareRandomUnits(integer count)
		-- 랜덤으로 선택된 이 플레이어의 유닛들을 공유하여 반환
		return self.commandManager:ShareRandomPermutationInArray(_Table:Select(self:GetUnits(), self.taskManager.liveSelector), count)
	end

	method table GetCards(any selector)
		-- 선택자에 따른 플래이어의 모든 카드들을 반환 (덱 + 핸드)
		return _Table:Concat(self.deck:GetCards(selector), self.hand:GetCards(selector))
	end

	method void DeclareEndRound(boolean isTimeout)
		-- 플래이어가 라운드 종료를 선언
		self:SetEndRoundDeclared(true)
		
		if self:IsClient() then
			-- _SoundService:PlaySound(self.resourceManager:GetResource("DeclareEndRound").sound, 1)
			
			self.endRoundSignEntity.Visible = true
			self:TransformAnchorToEndRound()
			self.hand:TransformToEndRound()
		end
	end

	method void SetEndRoundDeclared(boolean isEndRoundDeclared)
		-- 라운드 종료 선언 상태를 설정
		if self.isEndRoundDeclared == isEndRoundDeclared then
			return
		end
		
		self.isEndRoundDeclared = isEndRoundDeclared
	end

	method void SetMaxMp(integer maxMp)
		-- 플래이어의 최대 MP를 설정
		maxMp = math.max(0, maxMp)
		if self.maxMp == maxMp then
			return
		end
		
		self.maxMp = maxMp
		
		if self.mp then
			self:SetMp(math.min(self.mp, self.maxMp))
		end
	end

	method void SetMp(integer mp)
		-- 플래이어의 현재 MP를 설정하고 UI 업데이트
		mp = math.max(0, math.min(mp, self.maxMp))
		if self.mp == mp then
			return
		end
		
		if self:IsClient() then
			self.mpInteger:SetInteger(mp)
			if mp == self.maxMp then
				self.mpInteger:SetColor(Color.green)
			else
				self.mpInteger:SetColor(Color.white)
			end
			
			if self.mpTweener then
				self.mpTweener:Destroy()
			end
			if self.mp ~= nil then
				self.mpTweener = _Tween:Damp(self.mpEntity, Vector2.one, 1, 0.5)
			end
		end
		
		self.mp = mp
	end

	method void GainMp(integer delta)
		-- MP를 획득하고 이팩트 표시
		self:SetMp(self.mp + math.max(0, delta))
		
		if self:IsClient() then
			local position = self:GetActorPosition():ToVector3()
			position.y += 0.3
			local entity = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("GainMp"), "GainMp", 
				position, self.Entity.CurrentMap)
			local integer = entity:GetChildByName("Integer").Integer
			integer:SetPositiveInteger(delta)
			---@type table
			local rendererArray = entity:GetChildComponentsByTypeName("SpriteRendererComponent", true)
			local tweener = _TweenLogic:PlayTween(0, 1, 1, EaseType.Linear, function(t)
					entity.TransformComponent.WorldPosition.y = position.y + 0.3 * t
					for _, renderer in ipairs(rendererArray) do
						renderer.Color.a = _TweenLogic:Ease(1, 0, 1, EaseType.CubicEaseIn, t)
					end
				end)
			_TimerService:SetTimerOnce(function()
					tweener:Destroy()
					entity:Destroy()
				end, 1)
		end
	end

	method void LoseMp(integer delta)
		-- MP를 잃음
		self:SetMp(self.mp - math.max(0, delta))
	end

	method void SetSkillDamage(integer skillDamage)
		-- 플래이어의 스킬 데미지를 설정
		if self.skillDamage == skillDamage then
			return
		end
		
		self.skillDamage = skillDamage
	end

	method void AddSkillDamageEnchantment(integer delta)
		-- 인챈트먼트로 스킬 데미지를 추가
		local skillDamage = self.dependentVariableTable.skillDamage or self.entry.skillDamage or 0
		self.dependentVariableTable.skillDamage = skillDamage + delta
	end

	method void InsertAddSkillDamageEnchantment(integer delta, any remover)
		-- 스킬 데미지 추가 인챈트먼트를 삽입
		self:InsertEnchantment({methodName = "AddSkillDamageEnchantment", args = {delta}, remover = remover})
	end

	method void SetTaggedSkillDamages(table taggedSkillDamageTable)
		-- 태그별 스킬 데미지 테이블을 설정
		if self.taggedSkillDamageTable == taggedSkillDamageTable then
			return
		end
		
		self.taggedSkillDamageTable = taggedSkillDamageTable
	end

	method void AddSkillDamageByTagEnchantment(string tag, integer delta)
		-- 인챈트먼트로 특정 태그의 스킬 데미지를 추가
		local taggedSkillDamageTable = self.dependentVariableTable.taggedSkillDamageTable or {}
		if taggedSkillDamageTable == self.entry.taggedSkillDamageTable then
			taggedSkillDamageTable = _Table:ShallowCopy(self.entry.taggedSkillDamageTable)
		end
		taggedSkillDamageTable[tag] = (taggedSkillDamageTable[tag] or 0) + delta
		self.dependentVariableTable.taggedSkillDamageTable = taggedSkillDamageTable
	end

	method void InsertAddSkillDamageByTagEnchantment(string tag, integer delta, any remover)
		-- 태그별 스킬 데미지 추가 인챈트먼트를 삽입
		self:InsertEnchantment({methodName = "AddSkillDamageByTagEnchantment", args = {tag, delta}, remover = remover})
	end

	@ExecSpace("ClientOnly")
	method void Chat(string message)
		-- 플래이어 위에 채팅 메시지를 표시
		self.chatBalloon.Message = message
		self.chatBalloon.AutoShowEnabled = true
		if self.chatTimer then
			_TimerService:ClearTimer(self.chatTimer)
		end
		self.chatTimer = _TimerService:SetTimerOnce(function()
			self.chatTimer = nil
			self.chatBalloon.AutoShowEnabled = false
		end, 5)
	end

	@ExecSpace("ClientOnly")
	method void ClearChat()
		-- 채팅 메시지를 제거
		if self.chatTimer then
			_TimerService:ClearTimer(self.chatTimer)
		end
		self.chatTimer = nil
		self.chatBalloon.AutoShowEnabled = false
	end

	@ExecSpace("ClientOnly")
	method void SpawnAndSetFriendRequestButton()
		-- 친구 요청 버튼을 생성하고 설정
		self.friendRequestButton = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("FriendRequestButton"), "FriendRequestButton", Vector3(100, 100, 0), self.Entity).FriendRequestButton
		local transform = self.friendRequestButton.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
		self.friendRequestButton.button.Entity:ConnectEvent(ButtonClickEvent, function()
			_Server:Request(_UserService.LocalPlayer.Character, "SendFriendRequest", {self.character}) 
		end)
	end

	@ExecSpace("ClientOnly")
	method void ShowFriendRequestButton()
		-- 친구 요청 버튼을 표시 (조건 충족 시)
		local character = _UserService.LocalPlayer.Character 
		if isvalid(self.character) and not character:IsFriendWith(self.character) and not isvalid(character.player) and self.character:IsUser() then
			if self.friendRequestButtonTweener then
				self.friendRequestButtonTweener:Destroy()
			end
			self.friendRequestButtonTweener = _Tween:ScaleTo(self.friendRequestButton.Entity, Vector2.one, 0.125, EaseType.Linear)
		end
	end

	@ExecSpace("ClientOnly")
	method void HideFriendRequestButton()
		-- 친구 요청 버튼을 숨김
		local transform = self.friendRequestButton.Entity.TransformComponent
		transform.Scale.x = 0
		transform.Scale.y = 0
	end

	method void SetImmuneToDirectAttack(boolean isImmuneToDirectAttack)
		-- 직접 공격 면역 상태를 설정
		if self.isImmuneToDirectAttack == isImmuneToDirectAttack then
			return
		end
		
		self.isImmuneToDirectAttack = isImmuneToDirectAttack
	end

	method void SetImmuneToDirectAttackEnchantment(boolean isImmuneToDirectAttack)
		-- 인챈트먼트로 직접 공격 면역 상태를 설정
		self.dependentVariableTable.isImmuneToDirectAttack = isImmuneToDirectAttack
	end

	method void InsertSetImmuneToDirectAttackEnchantment(boolean isImmuneToDirectAttack, table remover)
		-- 직접 공격 면역 인챈트먼트를 삽입
		self:InsertEnchantment({methodName = "SetImmuneToDirectAttackEnchantment", args = {isImmuneToDirectAttack}, remover = _Table:DeepCopy(remover)})
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력 이벤트 처리 (Alt/Space로 듀얼 나가기)
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		
		if self.isServing and self.isReady and (key == KeyboardKey.LeftAlt or key == KeyboardKey.Space) then
			_Server:Request(self, "Tardy", {})
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "81bb477a-f6c1-4e39-b280-94e2a8980a31")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트 처리 (듀얼 나가기)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		
		if self.isServing and self.isReady then
			_Server:Request(self, "Tardy", {})
		end
	end

	@EventSender("Entity", "e5b214f8-01d7-43b2-b93f-59d66a9488d7")
	handler HandleChatEvent(ChatEvent event)
		-- 채팅 이벤트 처리 (플래이어 채팅 메시지 표시)
		--------------- Native Event Sender Info ----------------
		-- Sender: ChatComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local Message = event.Message
		local SenderName = event.SenderName
		local UserId = event.UserId
		---------------------------------------------------------
		
		if isvalid(self.character) and self.character.Entity.Name == UserId and self.uiManager.chat.UseChatBalloon then
			self:Chat(Message)
		end
	end

end