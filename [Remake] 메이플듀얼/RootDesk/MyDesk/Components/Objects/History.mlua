@Component
script History extends Object

	property CardManager cardManager = "aa80dcbc-1e88-4f95-9e8e-f3e3b9749e7d"

	property table thisGameCardTable = {}

	property table thisRoundCardTable = {}

	property table thisGameDeadMinionTable = {}

	property table thisRoundDeadMinionTable = {}

	property table thisGameMpTable = {}

	property table thisGameDiscardedCardTable = {}

	method table GetProperties()
		-- 히스토리 데이터를 네트워크 동기화를 위해 테이블로 반환
		local propertyTable = {
			thisGameCardTable = self.thisGameCardTable,
			thisRoundCardTable = self.thisRoundCardTable,
			thisGameDeadMinionTable = self.thisGameDeadMinionTable,
			thisRoundDeadMinionTable = self.thisRoundDeadMinionTable,
			thisGameMpTable = self.thisGameMpTable,
			thisGameDiscardedCardTable = self.thisGameDiscardedCardTable
		}
		
		_Table:Assign(__base:GetProperties(), propertyTable)
		
		return propertyTable
	end

	method void Initialize()
		-- 듀얼 시작 시 모든 플레이어의 히스토리 데이터 테이블 초기화
		__base:Initialize()
		
		for _, player in ipairs(self.duel.playerArray) do
			self.thisGameCardTable[player] = {}
			self.thisRoundCardTable[player] = {}
			self.thisGameDeadMinionTable[player] = {}
			self.thisRoundDeadMinionTable[player] = {}
			self.thisGameMpTable[player] = 0
			self.thisGameDiscardedCardTable[player] = {}
		end
	end

	method void Clear()
		-- 듀얼 종료 시 모든 히스토리 데이터를 완전히 초기화
		__base:Clear()
		
		self.thisGameCardTable = {}
		self.thisRoundCardTable = {}
		self.thisGameDeadMinionTable = {}
		self.thisRoundDeadMinionTable = {}
		self.thisGameMpTable = {}
		self.thisGameDiscardedCardTable = {}
	end

	method integer GetThisRoundCardCount(Player player)
		-- 현재 라운드에서 플레이어가 플레이한 총 카드 수 반환
		return #self.thisRoundCardTable[player]
	end

	method integer GetThisRoundMinionCount(Player player)
		-- 현재 라운드에서 플레이어가 소환한 미니언 카드 수 계산
		local count = 0
		for _, name in ipairs(self.thisRoundCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Minion" then
				count += 1
			end
		end
		
		return count
	end

	method integer GetThisRoundMinionCountByTag(Player player, string tag)
		-- 현재 라운드에서 특정 태그를 가진 미니언 카드 소환 수 계산
		local count = 0
		for _, name in ipairs(self.thisRoundCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Minion" and _Table:Contains(self.cardManager:GetTags(name), tag) then
				count += 1
			end
		end
		
		return count
	end

	method integer GetThisRoundSkillCount(Player player)
		-- 현재 라운드에서 플레이어가 사용한 스킬 카드 수 계산
		local count = 0
		for _, name in ipairs(self.thisRoundCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Skill" then
				count += 1
			end
		end
		
		return count
	end

	method void ClearThisRoundCard(Player player)
		-- 라운드 종료 시 플레이어의 라운드별 카드 사용 기록 초기화
		self.thisRoundCardTable[player] = {}
	end

	method void AddThisRoundCard(Player player, string name)
		-- 플레이어가 카드를 플레이할 때 라운드 기록에 추가
		table.insert(self.thisRoundCardTable[player], name)
	end

	method integer GetThisGameCardCount(Player player)
		-- 현재 게임에서 플레이어가 플레이한 총 카드 수 반환
		return #self.thisGameCardTable[player]
	end

	method integer GetThisGameMinionCount(Player player)
		-- 현재 게임에서 플레이어가 소환한 미니언 카드 총 수 계산
		local count = 0
		for _, name in ipairs(self.thisGameCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Minion" then
				count += 1
			end
		end
		
		return count
	end

	method table GetThisGameMinionsByTag(Player player, string tag)
		-- 현재 게임에서 특정 태그를 가진 미니언들의 이름 목록 반환
		local nameArray = {}
		for _, name in ipairs(self.thisGameCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Minion" and _Table:Contains(self.cardManager:GetTags(name), tag) then
				table.insert(nameArray, name)
			end 
		end
		
		return nameArray
	end

	method table GetThisGameMinionsByCost(Player player, integer cost)
		-- 현재 게임에서 특정 코스트를 가진 미니언들의 이름 목록 반환
		local nameArray = {}
		for _, name in ipairs(self.thisGameCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Minion" and self.cardManager:GetCost(name) == cost then
				table.insert(nameArray, name)
			end 
		end
		
		return nameArray
	end

	method integer GetThisGameSkillCount(Player player)
		-- 현재 게임에서 플레이어가 사용한 스킬 카드 총 수 계산
		local count = 0
		for _, name in ipairs(self.thisGameCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Skill" then
				count += 1
			end
		end
		
		return count
	end

	method integer GetThisGameSkillCountByCostOrMore(Player player, integer cost)
		-- 현재 게임에서 지정된 코스트 이상의 스킬 카드 사용 수 계산
		local count = 0
		for _, name in ipairs(self.thisGameCardTable[player]) do
			if self.cardManager:GetCategory(name) == "Skill" and self.cardManager:GetCost(name) >= cost then
				count += 1
			end
		end
		
		return count
	end

	method void ClearThisGameCard(Player player)
		-- 게임 종료 시 플레이어의 게임별 카드 사용 기록 초기화
		self.thisGameCardTable[player] = {}
	end

	method void AddThisGameCard(Player player, string name)
		-- 플레이어가 카드를 플레이할 때 게임 전체 기록에 추가
		table.insert(self.thisGameCardTable[player], name)
	end

	method table GetThisGameDeadMinions(Player player)
		-- 현재 게임에서 사망한 플레이어의 미니언 목록 반환
		return self.thisGameDeadMinionTable[player]
	end

	method table GetThisGameDeadMinionsByTag(Player player, string tag)
		-- 현재 게임에서 사망한 미니언 중 특정 태그를 가진 미니언 목록 반환
		local nameArray = {}
		for _, name in ipairs(self.thisGameDeadMinionTable[player]) do
			if _Table:Contains(self.cardManager:GetTags(name), tag) then
				table.insert(nameArray, name)
			end 
		end
		
		return nameArray
	end

	method void ClearThisGameDeadMinion(Player player)
		-- 게임 종료 시 플레이어의 사망 미니언 기록 초기화
		self.thisGameDeadMinionTable[player] = {}
	end

	method void AddThisGameDeadMinion(Player player, string name)
		-- 미니언이 사망할 때 게임 전체 사망 기록에 추가
		table.insert(self.thisGameDeadMinionTable[player], name)
	end

	method integer GetThisRoundDeadMinionCount(Player player)
		-- 현재 라운드에서 사망한 미니언 수 반환
		return #self.thisRoundDeadMinionTable[player]
	end

	method table GetThisRoundDeadMinions(Player player)
		-- 현재 라운드에서 사망한 미니언 목록 반환
		return self.thisRoundDeadMinionTable[player]
	end

	method void ClearThisRoundDeadMinion(Player player)
		-- 라운드 종료 시 플레이어의 라운드별 사망 미니언 기록 초기화
		self.thisRoundDeadMinionTable[player] = {}
	end

	method void AddThisRoundDeadMinion(Player player, string name)
		-- 미니언이 사망할 때 라운드별 사망 기록에 추가
		table.insert(self.thisRoundDeadMinionTable[player], name)
	end

	method integer GetThisGameMp(Player player)
		-- 현재 게임에서 플레이어가 사용한 총 마나 포인트 반환
		return self.thisGameMpTable[player]
	end

	method void AddThisGameMp(Player player, integer mp)
		-- 플레이어가 마나를 소모할 때 게임 전체 마나 사용량에 추가
		self.thisGameMpTable[player] += mp
	end

	method integer GetThisGameDiscardedCardCount(Player player)
		-- 현재 게임에서 버려진 카드 수 반환
		return #self.thisGameDiscardedCardTable[player]
	end

	method table GetThisGameDiscardedCards(Player player)
		-- 현재 게임에서 버려진 카드 목록 반환
		return self.thisGameDiscardedCardTable[player]
	end

	method void AddThisGameDiscardedCard(Player player, string name)
		-- 카드가 버려질 때 게임 전체 버림 기록에 추가
		table.insert(self.thisGameDiscardedCardTable[player], name)
	end

end