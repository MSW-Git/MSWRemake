@Component
script Cook_MakeButton extends Component

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		local kitchenSuit_Generation = player.PlayerData.CurSuit_Level
		local kitchenSuit_Buff = tonumber(_DataService:GetCell("CookDataSet_Suit", kitchenSuit_Generation, "ReduceGaugeBuff")) * 0.01 
		
		local minimumQuantity = tonumber(_DataService:GetCell("CookDataSet_Base", 1, "condition"))
		local requiredQuantity = minimumQuantity - math.floor(minimumQuantity * kitchenSuit_Buff)
		
		if not (player.PlayerData.CurPotGauge >= requiredQuantity) then
			return
		end
		
		local button_Fill = _EntityService:GetEntityByPath("/ui/CookGroup/CookPopUp/Button_Fill")
		button_Fill.TextComponent.FontColor.a = 0.3 
		button_Fill.ButtonComponent.Enable = false
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		_CookService:DoCook(player)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end