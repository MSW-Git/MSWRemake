@Component
script Cook_FillButton extends Component

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		if player.PlayerData.CurPotGauge >= _CookService.CurPotMaxGauge then
			log("꽉 참")
			return
		end
		
		if not isvalid(_CookService.IngredientTable) then
			return
		end
		
		local kitchenRecipe_Generation = player.PlayerData.CurRecipe_Level
		local kitchenRecipe_Buff = tonumber(_DataService:GetCell("CookDataSet_Recipe", kitchenRecipe_Generation, "UpgradeValueBuff")) * 0.01 
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		_CookService:PutAutoIngredient(player, _CookService.IngredientTable, _CookService.CurPotMaxGauge, kitchenRecipe_Buff)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end