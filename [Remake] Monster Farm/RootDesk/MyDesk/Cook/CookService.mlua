			self.Text_Tool_Generation.Text = "★★<color=#6b6b6b>★★★</color>"
		elseif kitchenTool_Level == 3 then
			self.Text_Tool_Generation.Text = "★★★<color=#6b6b6b>★★</color>"
		elseif kitchenTool_Level == 4 then
