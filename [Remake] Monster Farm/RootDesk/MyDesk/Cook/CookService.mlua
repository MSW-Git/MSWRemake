@Logic
script CookService extends Logic

	property Entity CookUI = "a47591e5-d757-491b-8c89-8a4581f17987"

	property Entity UI_Lock = "2b224e68-5578-4f01-9409-8468881144ac"

	property Entity Item = "a21a9dfd-8cdb-4380-9fb6-84e5ac423b3e"

	property Entity List = "bde594cd-0d65-4e1f-8a87-b468b1d47b49"

	property Entity CookUI_Text = "81a6acb2-7d68-4b5e-a4e4-6f5f33b4b8a1"

	property number CurPotMaxGauge = 0

	property SyncTable<number> IngredientTable

	property Entity Button_Put = "535a3a77-24d1-4b00-8754-378b2c4d1129"

	property Entity Button_Cook = "1ece8df4-ca60-4853-aef3-fbdc469d68b0"

	property Entity Text_Timer = "4d7c0b94-b8df-48fd-85d1-0d713a54e15b"

	property Entity UI_Gauge = "0ff65569-ce7e-469d-bf1d-0278c8b7a87d"

	property Entity Item_Cook = "d0da3f3e-eaa9-4c42-bea3-d720bfb56b3f"

	property Entity List_Cook = "f910b582-ed60-40b8-b11b-5773f3fe6444"

	property SyncTable<number> Background_Target_X_Position

	property SyncTable<number> Cook_Conditions

	property number Player_CookProgress = 0

	property number Player_Cur_Background_Level = 0

	property Entity Image_Background = "590c6574-bd39-4243-a99f-79289bdc6da0"

	property number Origin_CookQuantity = 4

	property number Origin_CookMaxTimer = 180

	property string Filter = "Ingredient"

	property Entity List_Owner_Cook = "bae8d8d0-2088-4970-903f-1803aee2e429"

	property Entity Item_Owner_Cook = "ad291ebe-7c6d-4d71-8fb7-049831fe0ba3"

	property Entity Button_Ready = "8bd7ab5a-ad0e-41fc-85a7-4de959850351"

	property Entity Button_Category_Ingredient = "3128ebdc-17fa-4052-b61f-4a019b986d69"

	property Entity Button_Category_Cook = "e7b8bc94-f314-4ad6-a4ad-a606ec4286e6"

	property Entity Button_Category_Ingredient_Inner = "c7a6b6c1-f644-471b-98fb-577002253841"

	property Entity Button_Category_Cook_Inner = "803f7e64-fd8c-42e2-9867-9a63f5630cd2"

	property SpriteGUIRendererComponent Image_Pot = "0926315d-db2e-41eb-9e01-3697b79e2143"

	property SpriteGUIRendererComponent Image_KitchenTool = "01477845-e55e-44b7-9d6c-4d7da18293ca"

	property SpriteGUIRendererComponent Image_Recipe = "1683dc19-1552-4095-ad45-78897220c85b"

	property SpriteGUIRendererComponent Image_Suit = "df956e5a-0a17-4cea-8f71-15f6a23d769f"

	property TextComponent Text_PotName = "d85813f9-08f3-413f-b8ca-21e7b7055a78"

	property Entity UpgradeUI = "095d16e3-5d8a-4a75-bbd8-4bf7bdfc713b"

	property number A_Grade_Point = 1

	property number B_Grade_Point = 0.75

	property number C_Grade_Point = 0.5

	property TextComponent Text_Pot_Generation = "26302ba5-29ac-40b2-8076-1d9b6586152b"

	property TextComponent Text_Tool_Generation = "c0a3433a-d290-416f-906d-3b49655ff700"

	property TextComponent Text_Suit_Generation = "9065320b-0888-479a-a13a-18b3ef4971bd"

	property TextComponent Text_Recipe_Generation = "199cc791-76db-4d29-8ce8-9a9554cf0426"

	@ExecSpace("ClientOnly")
	method void Open()
		-- 요리 UI를 엽니다. ------------------------------------------------------
		local player = _UserService.LocalPlayer
		player.PlayerMove.Type ="UI"
		
		
		if player.PlayerData.IsCooked then
			self.Text_Timer.Enable = true
			self.UI_Gauge.Enable = false
		else
			self.Text_Timer.Enable = false
			self.UI_Gauge.Enable = true
		end
		
		self.CookUI.Enable = true
		
		
		-- 요리 아이템을 생성합니다. ----------------------------------------------
		self:CreateCookItems()
		
		-- 설정된 필터대로 카테고리를 적용합니다. ---------------------------------
		self:ChangeCategory(self.Filter)
		
		-- 요리 UI를 갱신합니다. --------------------------------------------------
		self:RefreshPotUI(true)
		
		-- 장비 UI를 갱신합니다. --------------------------------------------------
		self:RefreshTools()
		
		-- 타이머 UI를 갱신합니다. ------------------------------------------------
		_CookService:RefreshTimer(player.PlayerData.CurPotTimer)
		
		-- 효과음 재생 ------------------------------------------------------------
		_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.UI_Lock.Enable = true
		
		if self.CookUI.Enable then
			local player = _UserService.LocalPlayer
			player.PlayerMove.Type ="none"
		
			self.CookUI.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshItems()
		local player = _UserService.LocalPlayer
		
		local list_Children = self.List.Children
		local list_owner_Children = self.List_Owner_Cook.Children
		
		-- 식재료 아이템만 인벤토리에서 가져옵니다. ------------------------------
		local dataSetName = "ItemDataSet_Base" 
		
		
		-- 기존 식재료 테이블을 초기화합니다. ------------------------------------
		table.clear(self.IngredientTable)
		
		local cook_ItemTable = {}
		
		-- 식재료 아이템만 테이블에 담습니다. ------------------------------------
		for i = 1, #player.PlayerData.Inventory_Type do
			local itemType = player.PlayerData.Inventory_Type[i] 
			if isvalid(itemType) and itemType == "식재료" then
				table.insert(self.IngredientTable, i)
			
			elseif isvalid(itemType) and itemType == "요리" then
				table.insert(cook_ItemTable, i)
			end
		end
		
		-- 재료 아이템의 종류만큼 Item을 생성합니다. -----------------------------
		for x = #list_Children, #self.IngredientTable do
			local newItem = self.Item:Clone("Item_"..tostring(x))
		end
		
		list_Children = self.List.Children
		
		
		-- 요리 아이템의 종류만큼 Item을 생성합니다. -----------------------------
		for x = #list_owner_Children, #cook_ItemTable do
			local newItem = self.Item_Owner_Cook:Clone("Item_"..tostring(x))
		end
		
		list_owner_Children = self.List_Owner_Cook.Children
		
		
		if self.Filter == "Ingredient" then
			-- 재료 아이템의 정보를 갱신합니다. ----------------------------------
			for i = 2, #list_Children do
				list_Children[i].Cook_Item.Idx = self.IngredientTable[i-1]
				list_Children[i].Cook_Item:RefreshInfo()
			end
			
		elseif self.Filter == "Cook" then
			-- 요리 아이템의 정보를 갱신합니다. ----------------------------------
			for i = 2, #list_owner_Children do
				list_owner_Children[i].Cook_Owner_Item.Idx = cook_ItemTable[i-1]
				list_owner_Children[i].Cook_Owner_Item:RefreshInfo()
			end
		end
		
		
		if self.UI_Lock.Enable then
			self.UI_Lock.Enable = false
		end
		
		self:RefreshButtons()
	end

	@ExecSpace("Server")
	method void PutIngredient(Entity player, number idx, number recipe_Level_Buff)
		-- 솥에 재료를 넣습니다. ------------------
		_PlayerService:DestroyItem(player, idx, 1)
		
		local itemGeneration = tonumber(_DataService:GetCell("ItemDataSet_Base", idx - 20000, "generation"))
		local itemGrade = _DataService:GetCell("ItemDataSet_Base", idx - 20000, "etc")
		
		local originValue = tonumber(_DataService:GetCell("CookDataSet_Ingredient_Value", itemGeneration, "value"))
		
		local gradePoint = 0
		
		-- 등급에 따른 가산 비율을 적용합니다. ----
		if itemGrade == "A" then
			gradePoint = self.A_Grade_Point
			 
		elseif itemGrade == "B" then
			gradePoint = self.B_Grade_Point 
			
		elseif itemGrade == "C" then
			gradePoint = self.C_Grade_Point
		end
		
		local totalPoint = ((originValue * gradePoint) + ((originValue * gradePoint) * recipe_Level_Buff))
		
		player.PlayerData.CurPotGauge = player.PlayerData.CurPotGauge + totalPoint
		
		_SoundService:PlaySound("029be48569da47e99012b93a23f1b64d", 1, player.Name)
		
		-- 통신합니다. ================
		_TransferService:Transfer("out")
		--=============================
	end

	@ExecSpace("Server")
	method void PutAutoIngredient(Entity player, SyncTable<number> ingredients_IDX, number potMaxGauge, number recipe_Level_Buff)
		-- 재료를 자동 채우기 합니다. -----------------------------------------------------------------------
		local totalGauge = 0
		
		local ingredient_ID_Table = {}
		local ingredient_Quantity_Table = {}
		local ingredient_Subtraction_Table = {}
		
		-- 식재료 아이템의 수량을 담는 테이블과 감산할 수량을 담는 테이블을 생성합니다. ---------------------
		for i = 1, #ingredients_IDX do
			table.insert(ingredient_Quantity_Table, player.PlayerData.Inventory_Quantity[ingredients_IDX[i]])
			table.insert(ingredient_Subtraction_Table, 0)
		end
		
		-- 식재료 테이블을 세대를 기준으로 정렬합니다. ------------------------------------------------------
		for i = 1, #ingredients_IDX do
			for x = 1, #ingredients_IDX - 1 do
				local curGeneration = tonumber(_DataService:GetCell("ItemDataSet_Base", player.PlayerData.Inventory_Name[ingredients_IDX[x]] - 20000, "generation"))
				local nextGeneration = tonumber(_DataService:GetCell("ItemDataSet_Base", player.PlayerData.Inventory_Name[ingredients_IDX[x+1]] - 20000, "generation"))
				
				if curGeneration > nextGeneration then
					ingredients_IDX[x], ingredients_IDX[x+1] = ingredients_IDX[x+1], ingredients_IDX[x]
					ingredient_Quantity_Table[x], ingredient_Quantity_Table[x+1] = ingredient_Quantity_Table[x+1], ingredient_Quantity_Table[x] 
				end
			end
		end
		
		--  플레이어가 보유한 식재료의 ID 값만 담는 테이블을 생성합니다. ------------------------------------
		for i = 1, #ingredients_IDX do
			table.insert(ingredient_ID_Table, player.PlayerData.Inventory_Name[ingredients_IDX[i]])
		end
		
		-- PotGauge에 가산할 총량입니다. --------------------------------------------------------------------
		local totalValue = 0
		
		-- 재료 테이블을 순회하며 점수 계산 + 감산할 개수를 계산합니다. -------------------------------------
		for i = 1, #ingredients_IDX do
			local itemGeneration = tonumber(_DataService:GetCell("ItemDataSet_Base", player.PlayerData.Inventory_Name[ingredients_IDX[i]] - 20000, "generation"))
			local originValue = tonumber(_DataService:GetCell("CookDataSet_Ingredient_Value", itemGeneration, "value"))
			local itemGrade = _DataService:GetCell("ItemDataSet_Base", player.PlayerData.Inventory_Name[ingredients_IDX[i]] - 20000, "etc")
			local gradePoint = 0
		
			-- 등급에 따른 가산 비율을 적용합니다. ----
			if itemGrade == "A" then
				gradePoint = self.A_Grade_Point
				 
			elseif itemGrade == "B" then
				gradePoint = self.B_Grade_Point 
				
			elseif itemGrade == "C" then
				gradePoint = self.C_Grade_Point
			end
		
			for x = 1, ingredient_Quantity_Table[i] do
				local totalPoint = ((originValue * gradePoint) + ((originValue * gradePoint) * recipe_Level_Buff))
				totalValue = totalValue + totalPoint
				ingredient_Subtraction_Table[i] = ingredient_Subtraction_Table[i] + 1
				
				if player.PlayerData.CurPotGauge + totalValue >= potMaxGauge then
					break
				end
			end
			
			if player.PlayerData.CurPotGauge + totalValue >= potMaxGauge then
				break
			end
		end
		
		-- PotGauge에 TotalValue를 가산합니다. --------------------------------------------------------------
		player.PlayerData.CurPotGauge = player.PlayerData.CurPotGauge + totalValue
		
		-- 사용한 식재료를 소모합니다. ---------------------------------------------------------------------- 
		for i = 1, #ingredient_ID_Table do
			
			if ingredient_Subtraction_Table[i] >= 1 then
				_PlayerService:DestroyItem(player, ingredient_ID_Table[i], ingredient_Subtraction_Table[i])
			end
		end
		
		_SoundService:PlaySound("029be48569da47e99012b93a23f1b64d", 1, player.Name)
		
		-- 통신합니다. ================
		_TransferService:Transfer("out")
		--=============================
	end

	@ExecSpace("ClientOnly")
	method void RefreshPotUI(boolean isCalledByOpenFunction)
		-- 요리 UI를 갱신합니다. ---------------------------------------------------
		
		local player = _UserService.LocalPlayer
		
		local curPotLevel = player.PlayerData.CurPotLevel
		local curPotGauge = player.PlayerData.CurPotGauge
		
		local cookGauge = _EntityService:GetEntityByPath(self.UI_Gauge.Path.."/UI_Gauge_Body")
		
		-- 플레이어가 장착하고 있는 항아리의 맥스 게이지를 가져옵니다.
		self.CurPotMaxGauge = tonumber(_DataService:GetCell("CookDataSet_Pot", curPotLevel, "maxQuantity"))
					
		local potPercent = (curPotGauge * 100) / self.CurPotMaxGauge
				
		cookGauge.SliderComponent.Value = potPercent * 0.01
		
		
		local kitchenSuit_Generation = player.PlayerData.CurSuit_Level
		local kitchenSuit_Buff = tonumber(_DataService:GetCell("CookDataSet_Suit", kitchenSuit_Generation, "ReduceGaugeBuff")) * 0.01 
		
		local minimumQuantity = tonumber(_DataService:GetCell("CookDataSet_Base", 1, "condition"))
		local requiredQuantity = minimumQuantity - math.floor(minimumQuantity * kitchenSuit_Buff)
		
		-- 요리를 할 수 있는 정도의 게이지를 올렸다면 -----------------------------
		if curPotGauge >= requiredQuantity then
			cookGauge.SliderComponent.FillRectColor = Color.FromHexCode("#675fff")
		else
			cookGauge.SliderComponent.FillRectColor = Color.FromHexCode("#dadada")
		end
		
		-- UI에 반영합니다. -------------------------------------------------------
		if potPercent > 100 then
			potPercent = 100
		end
		
		if curPotGauge > self.CurPotMaxGauge then
			curPotGauge = self.CurPotMaxGauge
		end
		
		self.CookUI_Text.TextComponent.Text = "<color=#fffff>"..tostring(math.floor(curPotGauge)).." / "..tostring(math.floor(self.CurPotMaxGauge)).."</color> ("..tostring(math.floor(potPercent)).."%)"
					
		if not isCalledByOpenFunction then
			cookGauge.Cook_BlinkButton:whiteEffect(cookGauge.SliderComponent.FillRectColor)
		end
		
		-- UI를 갱신합니다. -------------------------------------------------------
		self:RefreshCookUI()
		self:RefreshButtons()
	end

	@ExecSpace("ClientOnly")
	method void RefreshButtons()
		local player = _UserService.LocalPlayer
		
		-- '일괄 넣기' 버튼 Refresh ------------------------------------------------------------
		
		if player.PlayerData.CurPotGauge >= self.CurPotMaxGauge or #self.List.Children == 1 or self.Filter == "Cook" then
			self.Button_Put.ButtonComponent.Enable = false
			self.Button_Put.TextComponent.FontColor.a = 0.3
			
		else
			if not player.PlayerData.IsCooked then
				self.Button_Put.ButtonComponent.Enable = true
				self.Button_Put.TextComponent.FontColor.a = 1
			end
		end
		
		-- '만들기' 버튼 Refresh ------------------------------------------------------------
		
		local kitchenSuit_Generation = player.PlayerData.CurSuit_Level
		local kitchenSuit_Buff = tonumber(_DataService:GetCell("CookDataSet_Suit", kitchenSuit_Generation, "ReduceGaugeBuff")) * 0.01 
		
		local minimumQuantity = tonumber(_DataService:GetCell("CookDataSet_Base", 1, "condition"))
		local requiredQuantity = minimumQuantity - math.floor(minimumQuantity * kitchenSuit_Buff)
		
		-- 최소 필요 게이지 이상이라면 ------------------------------------------------------
		if not player.PlayerData.IsCooked then
			if player.PlayerData.CurPotGauge == 0 then
				self.Button_Cook.ButtonComponent.Enable = false
				self.Button_Cook.TextComponent.FontColor.a = 0.3
				self.Button_Ready.Enable = false
				
			elseif player.PlayerData.CurPotGauge >= requiredQuantity then
				self.Button_Cook.ButtonComponent.Enable = true
				self.Button_Cook.TextComponent.FontColor.a = 1
				self.Button_Ready.Enable = false
				
			elseif player.PlayerData.CurPotGauge >= 1 then
				self.Button_Cook.ButtonComponent.Enable = true
				self.Button_Cook.TextComponent.FontColor.a = 1
				self.Button_Ready.Enable = true
			end
		
		else
			-- 최소 필요 게이지를 도달하지 못했다면 ---------------------------------------------
			self.Button_Cook.ButtonComponent.Enable = false
			self.Button_Ready.Enable = false
			self.Button_Cook.TextComponent.FontColor.a = 0.3
		end
		
		-- 게이지, 요리 회수 버튼 Refresh ---------------------------------------------------
		local cookGauge = _EntityService:GetEntityByPath(self.CookUI.Path.."/CookPopUp/UI_Left/UI_Gauge")
		local cookTimer = _EntityService:GetEntityByPath(self.CookUI.Path.."/CookPopUp/UI_Left/UI_Timer")
		
					
		cookGauge.Enable = not player.PlayerData.IsCooked
		cookTimer.Enable = player.PlayerData.IsCooked
		
	end

	@ExecSpace("Server")
	method void DoCook(Entity player)
		-- 플레이어를 요리 상태로 변경합니다. -------
		player.PlayerData.IsCooked = true
		
		-- 통신합니다. ================
		_TransferService:Transfer("out", player.Name)
		--=============================
	end

	@ExecSpace("Server")
	method void GetCook(Entity player)
		-- 소요 시간이 끝나고 요리를 얻습니다. ------
		player.PlayerData.CurPotTimer = 0
		player.PlayerData.CurPotGauge = 0
		player.PlayerData.IsCooked = false
		
		player.PlayerSubData.GetCookCount = player.PlayerSubData.GetCookCount + 1
		
		self:GiveReward(player.Name)
		
	end

	@ExecSpace("Client")
	method void GiveReward()
		-- 가챠 창을 엽니다. --------------------------------------------------------------
		local player = _UserService.LocalPlayer
		local player_Progress = self.Player_CookProgress
		local dataSetName = "CookDataSet_Base"
		
		-- 예외 처리 ----------------------------------------------------------------------
		local gap = 1 
		
		if player_Progress < self.Origin_CookQuantity then
			gap = 1
		else
			gap = player_Progress - 3
		end
		-----------------------------------------------------------------------------------
		
		
		-- 플레이어가 획득하게 될 요리 아이템들을 테이블에 넣습니다. ----------------------
		local item_Table = {}
		for i = gap, player_Progress do
			table.insert(item_Table, tonumber(_DataService:GetCell(dataSetName, i, "id")))
		end
		-----------------------------------------------------------------------------------
		
		-- 테이블에 담은 요리 아이템 중 하나를 랜덤으로 획득하게 합니다. ------------------
		local randNumber = 0
		-----------------------------------------------------------------------------------
		
		local randValue = _UtilLogic:RandomIntegerRange(0, 100)
			
		-- 획득 공식을 적용합니다. --------------------------------------------------------
		if #item_Table == 1 then
			
			-- 100% 확률로 당첨
			randNumber = 1
			
		elseif #item_Table == 2 then
		
			-- 75%의 확률로 ID 1, 25% 확률로 ID 2인 아이템 당첨
			if randValue > 75 then
				randNumber = 1
			else
				randNumber = 2
			end
				
		elseif #item_Table == 3 then
		
			-- 50%의 확률로 ID 1, 25% 확률로 ID 2, 25% 확률로 ID 3인 아이템 당첨
			if randValue > 50 then
				randNumber = 1
			elseif randValue > 25 then
				randNumber = 2
			else
				randNumber = 3
			end
			
		elseif #item_Table == 4 then
		
			-- 25%의 확률로 ID 1, 25% 확률로 ID 2, 25% 확률로 ID 3, 25% 확률로 ID 4인 아이템 당첨
			if randValue > 75 then
				randNumber = 1
			elseif randValue > 50 then
				randNumber = 2
			elseif randValue > 25 then
				randNumber = 3
			else
				randNumber = 4
			end	
		end
		
		-- 퀘스트:12 요리 등급 이상 시도,16 등급 이상  ----------------------------------------------
		local rewardItem_ID = item_Table[randNumber] -- 20033
		local rewardItem_Rank = tonumber(_DataService:GetCell("ItemDataSet_Base", rewardItem_ID - 20000, "etc"))
		
		if _QuestService:CheckHaveQuest(player,17) then 
			if rewardItem_Rank >= 8 then
			_SubDataService:playerCookCountUp(player,17)
			end
		end
		if _QuestService:CheckHaveQuest(player,19) then 
			if rewardItem_Rank >= 12 then
			_SubDataService:playerCookCountUp(player,19)
			end
		end
		if _QuestService:CheckHaveQuest(player,23) then 
			if rewardItem_Rank >= 16 then
			_SubDataService:playerCookCountUp(player,23)
			end
		end
		
		----------------------------------------------
		
		_GachaService:DecisionOpen(rewardItem_ID, "아이템", "730834f3a80f42a696bdaaf1a177be60", 1, nil, "Cook")
		
		self.Player_CookProgress = 0
		self.Player_Cur_Background_Level = 0
		
		self:Close()
	end

	@ExecSpace("ClientOnly")
	method void RefreshTimer(number value)
		-- 예외 처리 -----------------------------------------------------
		if not isvalid(value) then
			value = 0
		end
		
		local player = _UserService.LocalPlayer
		
		
		-- 요리가 완료되면 버튼을 활성화합니다. --------------------------
		local kitchenTool_Generation = player.PlayerData.CurKitchenTool_Level
		local kitchenTool_Buff = tonumber(_DataService:GetCell("CookDataSet_KitchenTool", kitchenTool_Generation, "ReduceTimeBuff")) * 0.01 
		local cookMaxTimer = _CookService.Origin_CookMaxTimer - math.floor(_CookService.Origin_CookMaxTimer * kitchenTool_Buff)
		
		-- 요리 텍스트에 남은 시간을 반영합니다. -------------------------
		self.Text_Timer.TextComponent.Text = self:RemainingTimeCalculator(cookMaxTimer, value)
		
		
		-- 타이머가 채워지지 않았다면 '요리 완성' 버튼을 비활성화합니다. -
		self.Text_Timer.ButtonComponent.Enable = (cookMaxTimer - value <= 0)
	end

	@ExecSpace("ClientOnly")
	method string RemainingTimeCalculator(number maxTimer, number timer)
		local time = maxTimer - timer
		
		-- 요리 완료까지 남은 시간을 계산해서 return합니다. ---------------
		local hour = 0
		local minute = 0 
		local second = 0
		local time_text = ''
		
		if time < 0 then
			time = 0
		else
			hour = math.floor(time / 3600)
			time = time - hour * 3600
			
			minute = math.floor(time / 60)
			time = time - minute * 60
			
			second = time
		end
		 
		
		if hour >= 1 then
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("UI_fusion_RemainingTime_Full", math.floor(hour), math.floor(minute), math.floor(second))
			
		elseif minute >= 1 then
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("UI_fusion_RemainingTime_Short", math.floor(minute), math.floor(second))
			
		elseif second <= 0 then
			time_text = _LocalizationService.LocalTranslator:GetText("Cook_getCook")
		else
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("UI_fusion_RemainingTime_VeryShort", math.floor(second))
		
		end
		
		return time_text
	end

	@ExecSpace("ClientOnly")
	method void CreateCookItems()
		local player = _UserService.LocalPlayer
		
		local list_Children = self.List_Cook.Children
		
		local dataSetName = "CookDataSet_Base" 
		
		-- 요리 아이템들을 List 하위에 생성합니다. --------------
		for i = #list_Children, _DataService:GetRowCount(dataSetName) do
			local newItem = self.Item_Cook:Clone("Item_"..tostring(i))
			local newItem_ID = tonumber(_DataService:GetCell(dataSetName, i, "id"))
			newItem.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", (newItem_ID - 20000), "ruid")
		end
		
		self:RefreshCookUI()
	end

	@ExecSpace("ClientOnly")
	method void RefreshCookUI()
		local player = _UserService.LocalPlayer
		
		local dataSetName = "CookDataSet_Base"
		local length = _DataService:GetRowCount(dataSetName)
		
		-- 요리의 최대 세대는 5입니다. --------------------------
		local maxGeneration = math.floor(length / self.Origin_CookQuantity) -- 5
		---------------------------------------------------------
		
		-- 배경 Target Position과 조건을 가져옵니다. ------------
		if #self.Background_Target_X_Position == 0 then
			
			for i = 1, length do
				local background_X = _DataService:GetCell(dataSetName, i, "background_X")
				
				table.insert(self.Cook_Conditions, tonumber(_DataService:GetCell(dataSetName, i, "condition")))
		
				if isvalid(background_X) then
					table.insert(self.Background_Target_X_Position, tonumber(background_X))
				end
			end
		end
		
		
		local kitchenSuit_Generation = player.PlayerData.CurSuit_Level
		local kitchenSuit_Buff = tonumber(_DataService:GetCell("CookDataSet_Suit", kitchenSuit_Generation, "ReduceGaugeBuff")) * 0.01 
		
		-- 플레이어의 게이지에 해당하는 진행도를 가져옵니다. (최적화 겸용) -
		for i = self.Player_CookProgress + 1, #self.Cook_Conditions do
			
			local minimumQuantity = self.Cook_Conditions[i]
			local requiredQuantity = self.Cook_Conditions[i] - math.floor(self.Cook_Conditions[i] * kitchenSuit_Buff)
			
			if player.PlayerData.CurPotGauge >= requiredQuantity then
				self.Player_CookProgress = i 
				self.Player_Cur_Background_Level = tonumber(_DataService:GetCell(dataSetName, i, "backgroundID"))
			else
				break
			end
		end
		
		
		
		-- 배경 이동 --
		local cur_Background_Gap = 0
		
		if self.Player_Cur_Background_Level >= 1 then
			cur_Background_Gap = self.Background_Target_X_Position[self.Player_Cur_Background_Level]
		end
		
		local prev_Background_Gap = 0 
		
		if self.Player_Cur_Background_Level >= 1 then
			prev_Background_Gap = self.Player_Cur_Background_Level == 1 and 0 or self.Background_Target_X_Position[self.Player_Cur_Background_Level - 1] 
		end
		
		local background_Pos_Gap =  (cur_Background_Gap - prev_Background_Gap) / self.Origin_CookQuantity
		
		local cur_Cook_Index_InGroup = self.Player_CookProgress % self.Origin_CookQuantity
		
		if self.Player_CookProgress ~= 0 and cur_Cook_Index_InGroup == 0 then
			cur_Cook_Index_InGroup = self.Origin_CookQuantity
		end
		
		local prevPos = self.Image_Background.UITransformComponent.WorldPosition
		self.Image_Background.TweenLineComponent.Positions[1] = Vector2(prev_Background_Gap + (background_Pos_Gap * cur_Cook_Index_InGroup), 0)
		
		self.Image_Background.UITransformComponent.WorldPosition = prevPos
		self.Image_Background.TweenLineComponent:RestartFromCurrentPosition()
		
		
		-- 아이템 이동 --
		local maxPosition = -2600
		local list_Children = self.List_Cook.Children
		local list_Length = #list_Children
		local posGap = maxPosition / (list_Length - 1)
		
		local prevItem_Pos = self.List_Cook.UITransformComponent.WorldPosition
		self.List_Cook.TweenLineComponent.Positions[1] = Vector2(self.Player_CookProgress * posGap, 0)
		
		self.List_Cook.UITransformComponent.WorldPosition = prevItem_Pos 
		self.List_Cook.TweenLineComponent:RestartFromCurrentPosition()
	end

	@ExecSpace("ClientOnly")
	method void ChangeCategory(string filter)
		-- 식재료 / 요리 카테고리를 변경합니다.
		
		self.Filter = filter
		
		if self.Filter == "Ingredient" then
			self.List.Enable = true
			self.List_Owner_Cook.Enable = false
			
			self.Button_Category_Cook_Inner.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1) 
			self.Button_Category_Ingredient_Inner.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1) 
			
			self.Button_Category_Cook_Inner.ButtonComponent.Enable = true
			self.Button_Category_Cook.ButtonComponent.Enable = true
			
			self.Button_Category_Ingredient_Inner.ButtonComponent.Enable = false
			self.Button_Category_Ingredient.ButtonComponent.Enable = false
			
		elseif self.Filter == "Cook" then
			self.List.Enable = false
			self.List_Owner_Cook.Enable = true
			
			self.Button_Category_Cook_Inner.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1)  
			self.Button_Category_Ingredient_Inner.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1) 
			
			self.Button_Category_Cook_Inner.ButtonComponent.Enable = false
			self.Button_Category_Cook.ButtonComponent.Enable = false
			
			self.Button_Category_Ingredient_Inner.ButtonComponent.Enable = true
			self.Button_Category_Ingredient.ButtonComponent.Enable = true
		end
		
		-- 효과음을 재생합니다. -----------------------------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
		
		self:RefreshButtons()
		self:RefreshItems()
	end

	@ExecSpace("ClientOnly")
	method void RefreshTools()
		-- 플레이어가 착용한 장비를 UI에 갱신합니다. -------------------
		local player = _UserService.LocalPlayer 
		
		-- 플레이어의 현재 장비 레벨을 받아옵니다. ---------------------
		local potLevel = player.PlayerData.CurPotLevel
		local kitchenTool_Level = player.PlayerData.CurKitchenTool_Level
		local recipe_Level = player.PlayerData.CurRecipe_Level
		local suit_Level = player.PlayerData.CurSuit_Level
		
		-- 장비 데이터셋을 가져옵니다. ---------------------------------
		local pot_DataSetName = "CookDataSet_Pot"
		local tool_DataSetName = "CookDataSet_KitchenTool"
		local recipe_DataSetName = "CookDataSet_Recipe"
		local suit_DataSetName = "CookDataSet_Suit"
		
