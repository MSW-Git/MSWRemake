	@ExecSpace("ClientOnly")
	method void Open_UpgradeUI()
		self.Button_Category_Cook.Enable = false
		self.Button_Category_Ingredient.Enable = false
		
		self:Refresh_UpgradeUI()
		self.UpgradeUI.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Close_UpgradeUI()
		self.Button_Category_Cook.Enable = true
		self.Button_Category_Ingredient.Enable = true
		
		self:RefreshPotUI(nil)
		self.UpgradeUI.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void Refresh_UpgradeUI()
		local player = _UserService.LocalPlayer
		
		-- 경로 --------------------------------------------------------------------------------------------------------
		local item_Pot = _EntityService:GetEntityByPath("/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_Pot")
		local item_Suit = _EntityService:GetEntityByPath("/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_Suit")
		local item_KitchenTool = _EntityService:GetEntityByPath("/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_KitchenTool")
		local item_Recipe = _EntityService:GetEntityByPath("/ui/CookGroup/Upgrade_Background/Image_Background/List/Item_Recipe")
		
		
		-- 플레이어의 요리 장비 정보 -----------------------------------------------------------------------------------
		local curPot_Level = player.PlayerData.CurPotLevel
		local curSuit_Level = player.PlayerData.CurSuit_Level
		local curKitchenTool_Level = player.PlayerData.CurKitchenTool_Level
		local curRecipe_Level = player.PlayerData.CurRecipe_Level
		
		-- 플레이어의 장비 버프 가산치 ---------------------------------------------------------------------------------
		local curPot_Value = tonumber(_DataService:GetCell("CookDataSet_Pot", curPot_Level, "maxQuantity"))
		local curSuit_Value = tonumber(_DataService:GetCell("CookDataSet_Suit", curSuit_Level, "ReduceGaugeBuff"))
		local curKitchenTool_Value = tonumber(_DataService:GetCell("CookDataSet_KitchenTool", curKitchenTool_Level, "ReduceTimeBuff"))
		local curRecipe_Value = tonumber(_DataService:GetCell("CookDataSet_Recipe", curRecipe_Level, "UpgradeValueBuff"))
		
		-- 제목, 설명 초기화 -------------------------------------------------------------------------------------------
		local curPot_Image = _DataService:GetCell("CookDataSet_Pot", curPot_Level, "ruid")
		local curPot_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("CookDataSet_Pot", curPot_Level, "name"))
		
		local unlockText = _LocalizationService.LocalTranslator:GetText("Cook_unlock")
		local maxGaugeText = _LocalizationService.LocalTranslator:GetText("Cook_maxGauge")
		local potDescription = unlockText.." : ".._DataService:GetCell("CookDataSet_Pot", curPot_Level, "description").."\n"..maxGaugeText.." : "..tostring(curPot_Value).."%"
		local curPot_Description = potDescription
		
		local curPot_Upgrade_Item_ID = tonumber(_DataService:GetCell("CookDataSet_Pot", curPot_Level, "required_ItemID")) - 20000
		local curPot_Upgrade_Item_Quantity = tonumber(_DataService:GetCell("CookDataSet_Pot", curPot_Level , "required_Quantity"))
		
		local curSuit_Image = _DataService:GetCell("CookDataSet_Suit", curSuit_Level, "ruid")
		local curSuit_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("CookDataSet_Suit", curSuit_Level, "name"))
		local curSuit_Description = _LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell("CookDataSet_Suit", curSuit_Level, "description"), curSuit_Value)
		
		local curSuit_Upgrade_Item_ID = tonumber(_DataService:GetCell("CookDataSet_Suit", curSuit_Level, "required_ItemID")) - 20000
		local curSuit_Upgrade_Item_Quantity = tonumber(_DataService:GetCell("CookDataSet_Suit", curSuit_Level, "required_Quantity"))
		
		local curKitchenTool_Image = _DataService:GetCell("CookDataSet_KitchenTool", curKitchenTool_Level, "ruid")
		local curKitchenTool_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("CookDataSet_KitchenTool", curKitchenTool_Level, "name"))
		local curKitchenTool_Description = _LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell("CookDataSet_KitchenTool", curKitchenTool_Level, "description"), curKitchenTool_Value)
		
		local curKitchenTool_Upgrade_Item_ID = tonumber(_DataService:GetCell("CookDataSet_KitchenTool", curKitchenTool_Level, "required_ItemID")) - 20000
		local curKitchenTool_Upgrade_Item_Quantity = tonumber(_DataService:GetCell("CookDataSet_KitchenTool", curKitchenTool_Level, "required_Quantity"))
		
		local curRecipe_Image = _DataService:GetCell("CookDataSet_Recipe", curRecipe_Level, "ruid")
		local curRecipe_Title = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("CookDataSet_Recipe", curRecipe_Level, "name"))
		local curRecipe_Description = _LocalizationService.LocalTranslator:GetTextFormat(_DataService:GetCell("CookDataSet_Recipe", curRecipe_Level, "description"), curRecipe_Value)
		local curRecipe_Upgrade_Item_ID = tonumber(_DataService:GetCell("CookDataSet_Recipe", curRecipe_Level, "required_ItemID")) - 20000
		local curRecipe_Upgrade_Item_Quantity = tonumber(_DataService:GetCell("CookDataSet_Recipe", curRecipe_Level, "required_Quantity"))
		
		self:Refresh_UpgradeUI_Item(item_Pot, curPot_Image, curPot_Title, curPot_Description, curPot_Upgrade_Item_ID, curPot_Upgrade_Item_Quantity, curPot_Level)
		
		self:Refresh_UpgradeUI_Item(item_Suit, curSuit_Image, curSuit_Title, curSuit_Description, curSuit_Upgrade_Item_ID, curSuit_Upgrade_Item_Quantity, curSuit_Level)
		
		self:Refresh_UpgradeUI_Item(item_KitchenTool, curKitchenTool_Image, curKitchenTool_Title, curKitchenTool_Description, curKitchenTool_Upgrade_Item_ID, curKitchenTool_Upgrade_Item_Quantity, curKitchenTool_Level)
		
		self:Refresh_UpgradeUI_Item(item_Recipe, curRecipe_Image, curRecipe_Title, curRecipe_Description, curRecipe_Upgrade_Item_ID, curRecipe_Upgrade_Item_Quantity, curRecipe_Level)
	end

	@ExecSpace("ClientOnly")
	method void Refresh_UpgradeUI_Item(Entity item, string ruid, string title, string description, number itemID, number itemQuantity, number level)
		local player = _UserService.LocalPlayer
		
		-- 이미지 경로 -----------------------------------------------------------------------------------------------
		local image_Ingredient = _EntityService:GetEntityByPath(item.Path.."/UI_Bottom/Image_Ingredient")
		local image_Item = _EntityService:GetEntityByPath(item.Path.."/UI_Top/Image_Item")
		
		-- 텍스트 경로 -----------------------------------------------------------------------------------------------
		local text_Money = _EntityService:GetEntityByPath(item.Path.."/UI_Bottom/Text_Money")
		local text_Title = _EntityService:GetEntityByPath(item.Path.."/UI_Top/Text_Title")
		local text_Description = _EntityService:GetEntityByPath(item.Path.."/UI_Top/Text_Description")
		local text_Generation = _EntityService:GetEntityByPath(item.Path.."/UI_Top/Text_Generation")
		
		-- 버튼 경로 -------------------------------------------------------------------------------------------------
		local button_Condition = _EntityService:GetEntityByPath(item.Path.."/UI_Bottom")
		local button_Upgrade = _EntityService:GetEntityByPath(item.Path.."/Button_Upgrade") 
		
		image_Item.SpriteGUIRendererComponent.ImageRUID = ruid
		
		text_Title.TextComponent.Text = title
		text_Description.TextComponent.Text = description
		
		if level == 1 then
			text_Generation.TextComponent.Text = "<color=#ffe471>★</color>★★★★"
			
		elseif level == 2 then
			text_Generation.TextComponent.Text = "<color=#ffe471>★★</color>★★★"
			
		elseif level == 3 then
			text_Generation.TextComponent.Text = "<color=#ffe471>★★★</color>★★"
			
		elseif level == 4 then
			text_Generation.TextComponent.Text = "<color=#ffe471>★★★★</color>★"
			
		elseif level == 5 then
			text_Generation.TextComponent.Text = "<color=#ffe471>★★★★★</color>"
			
		end
		
		-- 해당 장비를 만렙까지 올렸다면 -----------------------------------------------------------------------------
		if  itemID == 0 or itemQuantity == 0 then
			button_Condition.SpriteGUIRendererComponent.Color = Color.FromHexCode("#444683")
			button_Upgrade.Enable = false
			image_Ingredient.Enable = false
			text_Money.Enable = false
		else
			button_Upgrade.Enable = true
			image_Ingredient.Enable = true
			text_Money.Enable = true
			text_Money.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(itemQuantity)
		end
		
		local levelUpText = _LocalizationService.LocalTranslator:GetText("UI_levelUP")
		local lackOfGoldText = _LocalizationService.LocalTranslator:GetText("UI_lackOfGold")
		
		
		if itemID ~= 0 and itemQuantity ~= 0 then
			
			image_Ingredient.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", itemID, "ruid")
			
			if itemID == _PlayerService.Gold_ID - 20000 then
				button_Condition.SpriteGUIRendererComponent.Color = player.PlayerData.Gold >= itemQuantity and Color.FromHexCode("#8683b1") or Color.FromHexCode("#a25757") 
				image_Ingredient.SpriteGUIRendererComponent.Color.a = player.PlayerData.Gold >= itemQuantity and 1 or 0.4
				text_Money.TextComponent.FontColor.a = player.PlayerData.Gold >= itemQuantity and 1 or 0.4 
				button_Upgrade.ButtonComponent.Enable = player.PlayerData.Gold >= itemQuantity
				
				button_Upgrade.SpriteGUIRendererComponent.ImageRUID = player.PlayerData.Gold >= itemQuantity and "b598cf22e48a4e4bb7a3c47cb719f679" or "92a7f54bc19c4447be0b4b6c60dfc6ff"
				button_Upgrade.ButtonComponent.Enable = player.PlayerData.Gold >= itemQuantity 
				
				button_Upgrade.TextComponent.Text = player.PlayerData.Gold >= itemQuantity and levelUpText or lackOfGoldText
				button_Upgrade.TextComponent.FontColor.a = player.PlayerData.Gold >= itemQuantity and 1 or 0.4 
				
			elseif itemID == _PlayerService.Berry_ID - 20000 then
				button_Condition.SpriteGUIRendererComponent.Color = player.PlayerData.Berry >= itemQuantity and Color.FromHexCode("#8683b1") or Color.FromHexCode("#a25757") 
				image_Ingredient.SpriteGUIRendererComponent.Color.a = player.PlayerData.Berry >= itemQuantity and 1 or 0.4
				text_Money.TextComponent.FontColor.a = player.PlayerData.Berry >= itemQuantity and 1 or 0.4
				
				button_Upgrade.SpriteGUIRendererComponent.ImageRUID = player.PlayerData.Berry >= itemQuantity and "b598cf22e48a4e4bb7a3c47cb719f679" or "92a7f54bc19c4447be0b4b6c60dfc6ff"
				button_Upgrade.ButtonComponent.Enable = player.PlayerData.Berry >= itemQuantity 
			
				button_Upgrade.TextComponent.Text = player.PlayerData.Gold >= itemQuantity and levelUpText or lackOfGoldText
				button_Upgrade.TextComponent.FontColor.a = player.PlayerData.Berry >= itemQuantity and 1 or 0.4
				
			elseif itemID == _PlayerService.Ruby_ID - 20000 then
				button_Condition.SpriteGUIRendererComponent.Color = player.PlayerData.Ruby >= itemQuantity and Color.FromHexCode("#8683b1") or Color.FromHexCode("#a25757") 
				image_Ingredient.SpriteGUIRendererComponent.Color.a = player.PlayerData.Ruby >= itemQuantity and 1 or 0.4
				text_Money.TextComponent.FontColor.a = player.PlayerData.Ruby >= itemQuantity and 1 or 0.4
				
				button_Upgrade.SpriteGUIRendererComponent.ImageRUID = player.PlayerData.Ruby >= itemQuantity and "b598cf22e48a4e4bb7a3c47cb719f679" or "92a7f54bc19c4447be0b4b6c60dfc6ff"
				button_Upgrade.ButtonComponent.Enable = player.PlayerData.Ruby >= itemQuantity 
				
				button_Upgrade.TextComponent.Text = player.PlayerData.Gold >= itemQuantity and levelUpText or lackOfGoldText
				button_Upgrade.TextComponent.FontColor.a = player.PlayerData.Ruby >= itemQuantity and 1 or 0.4
			end
		end
	end

end