@Component
script Cook_PutIngredient_Button extends Component

	property number Idx = 0

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		if self.Idx == 0 then
			self.Idx = self.Entity.Parent.Cook_Item.Idx
		end
		
		if not isvalid(player.PlayerData.Inventory_Quantity[self.Idx]) or player.PlayerData.Inventory_Quantity[self.Idx] <= 0 then
			return
		end
		
		if player.PlayerData.CurPotGauge >= _CookService.CurPotMaxGauge or player.PlayerData.IsCooked then
			return
		end
		
		local kitchenRecipe_Generation = player.PlayerData.CurRecipe_Level
		local kitchenRecipe_Buff = tonumber(_DataService:GetCell("CookDataSet_Recipe", kitchenRecipe_Generation, "UpgradeValueBuff")) * 0.01 
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		_CookService:PutIngredient(player, player.PlayerData.Inventory_Name[self.Idx], kitchenRecipe_Buff)
	end

end