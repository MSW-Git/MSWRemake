@Component
script Collection_SubMonster_Button extends Component

	property number Idx = 0

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		if player.PlayerSubData.GetMonsterList[self.Idx] then
			_BookService:OpenByCollectionUI(self.Idx)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end