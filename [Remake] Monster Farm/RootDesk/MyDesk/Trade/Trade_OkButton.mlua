@Component
script Trade_OkButton extends Component

	property Entity TradeUI = "fefd7c3f-2bfd-4bec-b58f-3fe3a8d4492a"

	@ExecSpace("ClientOnly")
	method void OnClick()
		local player = _UserService.LocalPlayer
		
		_TradeService:ClickButton(player)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		------------------------------------------------
		
		self:OnClick()
	end

end