@Logic
script MyConService extends Logic

	property Entity MyConUI = "5c5c5f55-3995-4240-aa3d-5a80041e8179"

	property Entity List = "9c19c112-8472-45c6-90af-1521f32e9376"

	property Entity Item = "56927e2c-13bb-43f8-bb22-904b42148276"

	property string DataSetName = "MyConDataSet"

	@ExecSpace("ClientOnly")
	method void Open()
		local player = _UserService.LocalPlayer
		
		player.PlayerMove.Type = "UI"
		
		self.MyConUI.Enable = true
		self:RefreshItems()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		local player = _UserService.LocalPlayer
		
		player.PlayerMove.Type = "none"
		
		self.MyConUI.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void RefreshItems()
		local player = _UserService.LocalPlayer
		
		
		-- MyCon Item을 List에 생성합니다. --------------------------------------------------------------------
		local list_Children = self.List.Children
		local list_length = #list_Children
		
		for i = list_length, _DataService:GetRowCount(self.DataSetName) do
			local item = self.Item:Clone("item_"..tostring(i))
			local itemButton = _EntityService:GetEntityByPath(item.Path.."/Icon_Button")
			itemButton.MyCon_ItemButton.idx = i
		end
		
		
		-- 생성된 Item를 갱신합니다. --------------------------------------------------------------------------
		list_Children = self.List.Children
		
		for i = 1, _DataService:GetRowCount(self.DataSetName) do
			local item = list_Children[i + 1]
			local icon_Image = _EntityService:GetEntityByPath(item.Path.."/Image_Icon")
			local icon_Button = _EntityService:GetEntityByPath(item.Path.."/Icon_Button")
			
			icon_Image.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(self.DataSetName, i, "ruid")
			
			-- 임시로 모든 마이콘을 획득 상태로 돌립니다. --
			icon_Button.ButtonComponent.Enable = not player.PlayerData.MyCons[i]
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnClick(number idx)
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player_ = _UserService.LocalPlayer
		
		if player_.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		_PlayerService:EquipMyCon(player_, idx)
	end

end