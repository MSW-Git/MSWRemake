@Component
script Store_Helper_Buy_Button extends Component

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		local idx = 0
		 
		
		idx = self.Entity.Parent.Store_Helper_Item.Idx
		
		
		-- 예외 처리 --------------------------------
		
		if not isvalid(player.PlayerData.Hinventory_Level[idx]) then
			return
		end
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		-- 구매 로직을 실행합니다. ------------------
		_PlayerService:GetHelper(player, idx, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end