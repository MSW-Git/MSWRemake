@Component
script Store extends Component

	@HideFromInspector
	property number ShowItemId = 1

	property SyncTable<number> RequiredItemId

	property SyncTable<number> RequiredItemQuantity

	@HideFromInspector
	property Entity List = "acd7f3e1-aeff-4714-9ece-ff5e78778680"

	@HideFromInspector
	property Entity List_RequiredItem = "47ea1b75-5f02-4fa1-b6f6-408dcacdd933"

	@HideFromInspector
	property Entity Image_Item = "40aad675-987c-4704-9a25-4fe849115239"

	@HideFromInspector
	property TextComponent Text_Name = "32a0c4c0-fd9e-4b1c-8bc0-717db1485b27"

	@HideFromInspector
	property TextComponent Text_Contents = "6f0d9326-0bf3-4a67-a216-45fb87132031"

	@HideFromInspector
	property TextComponent Text_Effect = "15231f08-222e-4e7a-b2ac-340ccc96d219"

	@HideFromInspector
	property Store_BuyButton Button_ItemBuy = "bf996089-fdf6-4efc-bbad-6ef6d9ba74f2"

	property Entity Item = "19f5b336-aa0c-48cf-b536-ff7670ac8ca1"

	property Entity UI_NotLoaded = "42b76a41-7f85-45f6-a3ad-38afec572dd9"

	property Entity UI_Helper = "9f252ff8-7106-4abe-b561-9477d739d1f8"

	property Entity List_Helper = "2bd08612-f04b-43b3-b62f-d4b2358f5c49"

	property Entity Item_Helper = "c7862b65-dcc5-4c02-8dc1-49c78d7ecf86"

	@ExecSpace("ClientOnly")
	method void Open()
		self:CreateItems()
		
		-- UI를 갱신합니다. ----------------------------------------------------------------------------
		self:RefreshSortButtonStatus(1)
		self:RefreshItemButtonStatus(2)
		
		-- 푸리를 기본 아이템으로 보여줍니다. ----------------------------------------------------------
		self.ShowItemId = 1
		
		self:RefreshInfo()
		
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.UI_NotLoaded.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void RefreshInfo()
		-- 필요한 아이템, 개수 테이블을 초기화합니다. --------------------------------------------------
		self:ResetData()
		------------------------------------------------------------------------------------------------
		
		
		-- 선택한 상점 아이템의 정보를 보여줍니다. -----------------------------------------------------
		local DataSetName = "ItemDataSet_Store"
		
		local itemType = _DataService:GetCell(DataSetName, self.ShowItemId, "store_type")
		
		
		-- 텍스트 / 이미지 반영 ------------------------
		
		local stuffName = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(DataSetName, self.ShowItemId, "name"))
		self.Text_Name.Text = stuffName
		
		local stuffDescription = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(DataSetName, self.ShowItemId, "description"))
		self.Text_Contents.Text = stuffDescription
		
		local typeName =  _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(DataSetName, self.ShowItemId, "name_type"))
		self.Text_Effect.Text = "["..typeName.."] ".._DataService:GetCell(DataSetName, self.ShowItemId, "effect")
				
		self.Image_Item.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(DataSetName, self.ShowItemId, "ruid")
					
		-- 구매 시 필요한 아이템의 정보를 가져옵니다. --	
		self:FindRequiredItem(self.ShowItemId)
		
		
		-- 해당 Item의 Image Scale을 적용합니다. -------------------------------------------------------
		if itemType == "몬스터" then
			
			local monsterId = tonumber(_DataService:GetCell("ItemDataSet_Store", self.ShowItemId, "itemId"))
			local mon_x = tonumber(_DataService:GetCell("MonsterDataSet_UI", monsterId, "Thumbnail_x")) 
			local mon_y = tonumber(_DataService:GetCell("MonsterDataSet_UI", monsterId, "Thumbnail_y"))
			
			self.Image_Item.SpriteGUIRendererComponent.EndFrameIndex = 0
			self.Image_Item.SpriteGUIRendererComponent.LocalScale = Vector2(mon_x, mon_y)
		
		else
			self.Image_Item.UITransformComponent.RectSize = Vector2(140, 140)
		end
	end

	@ExecSpace("ClientOnly")
	method void FindRequiredItem(number i)
		local player = _UserService.LocalPlayer
		
		local DataSetName = "ItemDataSet_Store"
		
		-- 구매 시 필요한 아이템에 대한 정보를 받아와서 Table로 만듭니다. ------------------------------
		for x = 1, 4 do
		
			local getItem_Name = tonumber(_DataService:GetCell(DataSetName, i, "ing"..tostring(x)))
			local getItem_Quantity = tonumber(_DataService:GetCell(DataSetName, i, "ing"..tostring(x).."_num"))
		
			if getItem_Name == "" or getItem_Name == ' ' or not isvalid(getItem_Name) then
				-- 예외 처리
			elseif getItem_Quantity == "" or getItem_Quantity == ' ' or not isvalid(getItem_Quantity) then
				-- 예외 처리
			else
				table.insert(self.RequiredItemId, getItem_Name)
				table.insert(self.RequiredItemQuantity, getItem_Quantity)
			end
			
			if x == 4 then
				self:RefreshRequireItem()
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshRequireItem()
		-- Required Table을 불러와서 필요한 아이템의 외형 / 개수를 표시합니다. --------------------------------------
		local player = _UserService.LocalPlayer
		
		local list = self.List_RequiredItem.Children
		
		local DataSetName = "ItemDataSet_Store"
		
		for i = 1, 4 do
			
			-- 빈 슬롯 생성 ------------------
			if i > #self.RequiredItemId then
				list[i].SpriteGUIRendererComponent.Color = Color(0, 0, 0, 0.4)
		
				list[i].Enable = false
		
				
			-- ItemDataSet을 참조하여 필요한 아이템의 정보를 반영합니다. --
			elseif i <= #self.RequiredItemId then
		
						list[i].Enable = true
				
						-- 아이템의 개수를 반영합니다. --
						local text_Quantity = _EntityService:GetEntityByPath(list[i].Path.."/Text_Item_Quantity")
						text_Quantity.TextComponent.Text = tostring(math.floor(self.RequiredItemQuantity[i]))
						text_Quantity.Enable = true
								
						
						-- 아이템의 이미지를 반영합니다. --
						local image_Item = _EntityService:GetEntityByPath(list[i].Path.."/Image_Item")
						image_Item.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", (self.RequiredItemId[i] - 20000), "ruid")
						image_Item.Enable = true
						
						-- 플레이어가 해당 아이템을 필요한 만큼 가지고 있는지 여부에 따라 UI를 다르게 표시합니다. --
						local requiredQuantity = 0 
						
							
						-- 필요한 아이템을 플레이어가 얼만큼 보유하고 있는지 받아옵니다. --------------
						if self.RequiredItemId[i] == _PlayerService.Gold_ID then
							requiredQuantity = player.PlayerData.Gold
						else
							for z = 1, #player.PlayerData.Inventory_Name do
								if self.RequiredItemId[i] == player.PlayerData.Inventory_Name[z] then
									requiredQuantity = player.PlayerData.Inventory_Quantity[z]
								end
							end
						end
						
						if isvalid(requiredQuantity) and isvalid(self.RequiredItemQuantity[i]) and requiredQuantity >= self.RequiredItemQuantity[i]  then
						-- 필요한 아이템의 보유 상태에 따라 Item을 다르게 표시합니다. ----------------
							list[i].SpriteGUIRendererComponent.Color = Color(0, 0, 0, 0.4)
						else
							list[i].SpriteGUIRendererComponent.Color = Color(229/255, 65/255, 65/255, 0.4)
						end
					end
				end
		
		
		self.Button_ItemBuy:CheckIsBuyPossible()
	end

	@ExecSpace("ClientOnly")
	method void FilteringItem(string filter)
		-- 도우미 필터라면 ------------------------------------------------
		if filter == "일꾼" then
			self.UI_Helper.Enable = true
			self:RefreshHelperList()
		-- 다른 필터라면 --------------------------------------------------
		else 
			self.UI_Helper.Enable = false
			
			-- 필터링을 적용합니다. ---------------------------------------
			local children = self.List.Children
			
			for i = 2, #children do
			
				if filter == "all" then
					children[i].Enable = true
			
				elseif children[i].Store_Item.StoreItemType == filter then
					children[i].Enable = true
				
				else
					children[i].Enable = false
				end
				
				-- 필터링을 적용한 아이템의 정보를 갱신합니다. -----------
				if children[i].Enable then
					children[i].Store_Item:RefreshItem(filter)
				end
			end
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshSortButtonStatus(number idx)
		-- 선택한 Sort Button을 강조 표시합니다. ----------------------------------------
		local sortButtonList = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/Image_Board_Buy/UI_Buttons")
		
		for i = 1, #sortButtonList.Children do
			local buttonEntity = sortButtonList.Children[i]
			local innerButton = _EntityService:GetEntityByPath(buttonEntity.Path.."/Button")
			
			if i ~= idx then
				buttonEntity.ButtonComponent.Enable = true
				
				innerButton.ButtonComponent.Enable = true
				innerButton.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1)
			else
				buttonEntity.ButtonComponent.Enable = false
				
				innerButton.ButtonComponent.Enable = false
				innerButton.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshItemButtonStatus(number idx)
		-- 선택한 Store Item을 강조 표시합니다. ----------------------------------------
		local list_Children = self.List.Children
		
		for i = 2, #list_Children do
			local buttonEntity = list_Children[i]
			buttonEntity.ButtonComponent.Enable = i ~= idx
		end
	end

	@ExecSpace("ClientOnly")
	method void ResetData()
		-- 필요한 아이템, 개수 테이블을 초기화합니다. -------
		table.clear(self.RequiredItemId)
		table.clear(self.RequiredItemQuantity)
	end

	@ExecSpace("ClientOnly")
	method void RefreshAllItems()
		-- 선택한 Store Item을 강조 표시합니다. ----------------------------------------
		local list_Children = self.List.Children
		
		for i = 2, #list_Children do
			if list_Children[i].Enable then 
				list_Children[i].Store_Item:RefreshItem(nil)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void CreateItems()
		local list_Children = self.List.Children
		
		local dataSetName = "ItemDataSet_Store"
		local length = _DataService:GetRowCount(dataSetName)
		
		for i = #list_Children, length do
			local newItem = self.Item:Clone("newItem_"..tostring(i))
			newItem.Store_Item.StoreItemType = _DataService:GetCell(dataSetName, i, "store_type")
			newItem.Store_Item.IDX = i
			newItem.Enable = false
		end
		
		-- 전체 필터링을 적용합니다. -------------------------------------------------------------------
		self:FilteringItem("몬스터")
		
		self:RefreshAllItems()
		
		if self.UI_NotLoaded.Enable then
			self.UI_NotLoaded.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshHelperList()
		local dataSetName = "HelperDataSet"
		local dataSetName_Length = _DataService:GetRowCount(dataSetName)
		
		local list_Children = self.List_Helper.Children
		
		-- 도우미 아이템을 생성합니다. ---------------------------------
		for i = #list_Children, dataSetName_Length do
			local newItem = self.Item_Helper:Clone("Item_"..tostring(i))
			local store_DataSetName = "ItemDataSet_Store_Helper"
			newItem.Store_Helper_Item.Idx = i
		end
		
		list_Children = self.List_Helper.Children
		
		-- 도우미 아이템을 갱신합니다. ---------------------------------
		for i = 2, #list_Children do 
			list_Children[i].Store_Helper_Item:RefreshItem()
		end
	end

end