@Component
script Store_Summon_Button extends Component

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		local idx = self.Entity.Parent.Parent.Store_Helper_Item.Idx
		
		
		-- 예외 처리 --------------------------------
		if not isvalid(player.PlayerData.Hinventory_Level[idx]) then
			return
		end
		
		if not isvalid(player.PlayerData.Hinventory_Summoned[idx]) then
			return
		end
		
		if not isvalid(player.PlayerData.Hinventory_Entity[idx]) then
			return
		end
		
		-- 이미 구매했다면 --------------------------
		if player.PlayerData.Hinventory_Level[idx] == 0 then
			return
		end
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		-- 소환된 상태라면 --------------------------
		if player.PlayerData.Hinventory_Summoned[idx] then
			_HelperService:DestroyHelper(player, idx)
		-- 소환된 상태가 아니라면 -------------------
		else
			--_HelperService:SummonHelper(player, idx, true)
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end