          "SyncDirection": 0,
          "Attributes": [
            {
              "$type": "MOD.Core.Script.HideFromInspectorScriptAttribute, MOD.Core"
            }
          ],
          "Name": "Text_Effect"
        },
        {
          "Type": "Component",
          "DefaultValue": "bf996089-fdf6-4efc-bbad-6ef6d9ba74f2:Store_BuyButton",
          "SyncDirection": 0,
          "Attributes": [
            {
              "$type": "MOD.Core.Script.HideFromInspectorScriptAttribute, MOD.Core"
