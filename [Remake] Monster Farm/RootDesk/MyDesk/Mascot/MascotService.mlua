@Logic
script MascotService extends Logic

	@ExecSpace("Server")
	method void CreateMascotMonster(Entity player)
		---------------------------------------------------------------------------------------------
		-- 마스코트 몬스터를 소환합니다.
		---------------------------------------------------------------------------------------------
		if player.CurrentMapName == "farm" and player.PlayerData.Owner then
			return
		end
		local mascotID = player.PlayerData.MInventory_MascotPet_Id
		
		if player.PlayerData.MInventory_MascotPet_Id == 0 or not isvalid(player.PlayerData.Minventory_Id[mascotID])then
			return
		end
		
		local dummy_MascotMonster = _EntityService:GetEntityByPath(player.CurrentMap.Path.."/Dummy_MascotMonster")
		
		local clonedMonster = dummy_MascotMonster:Clone(player.PlayerComponent.Nickname.."_Pet")
		
		clonedMonster.Mascot_MonsterComponent.monsterID = player.PlayerData.Minventory_Id[mascotID]
		clonedMonster.Mascot_MonsterComponent.ownerName = player.PlayerComponent.Nickname
		
		player.PlayerData.MascotPet = clonedMonster
		
		---------------------------------------------------------------------------------------------
		-- 몬스터의 외형을 변경합니다. 
		---------------------------------------------------------------------------------------------
		local uiDataSetName = "MonsterDataSet_UI"
		
		local idleRUID = _DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[mascotID], "idle_ruid")
		local walkRUID = _DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[mascotID], "walk_ruid")
		clonedMonster.Mascot_MonsterComponent.Idle_RUID = idleRUID
		clonedMonster.Mascot_MonsterComponent.Walk_RUID = walkRUID
		
		
		clonedMonster.SpriteRendererComponent.SpriteRUID = walkRUID
		
		if player.CurrentMapName == "lobby" or player.CurrentMapName == "farm"  then
			local shadow = _EntityService:GetEntityByPath(clonedMonster.Path.."/shadow")
			
			local shadow_x = 0
			local shadow_y = 0.01
			local shadow_xscale = tonumber(_DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[mascotID], "shadow_x_scale"))
			local shadow_yscale = tonumber(_DataService:GetCell(uiDataSetName, player.PlayerData.Minventory_Id[mascotID], "shadow_y_scale")) 
		
			shadow.TransformComponent.Position = Vector3(shadow_x, shadow_y, 0)
			shadow.TransformComponent.Scale = Vector3(shadow_xscale, shadow_yscale, 1)
		
		end
		
		---------------------------------------------------------------------------------------------
		-- 몬스터를 플레이어 위치로 이동시킵니다.
		---------------------------------------------------------------------------------------------
		if isvalid(clonedMonster) then
			if player.CurrentMapName == "lobby" or player.CurrentMapName == "farm" then
				clonedMonster.Mascot_MonsterComponent.target = player
				wait(0.5)
				clonedMonster.TransformComponent.Position = player.TransformComponent.Position
			else
				clonedMonster.Mascot_MonsterComponent.target = player
				clonedMonster.AIChaseComponent:SetTarget(player)
				wait(0.5)
				clonedMonster.MovementComponent:SetPosition(Vector2(player.TransformComponent.Position.x, player.TransformComponent.Position.y))
			end
		end
		
	end

	@ExecSpace("Server")
	method void DeleteMascotMonster(Entity monster)
		if not isvalid(monster) then
			return
		end
		
		monster:Destroy()
	end

	@ExecSpace("Server")
	method void SetMascot(Entity player, number id, boolean isTransferType, boolean isMessageType)
		player.PlayerData.MInventory_MascotPet_Id = id
		
		if id == 0 then
			if isMessageType then
				_LocalizationToastService:ShowMessage("Popup_disableMascot", player.Name)
			end
		else
			if isMessageType then
				_LocalizationToastService:ShowMessage("Popup_enableMascot", player.Name)
		
				if player.PlayerSubData.MainQuest == 9 then
				player.PlayerSubData.GetMascotCount = player.PlayerSubData.GetMascotCount + 1
				end
		
			end
		end
		
		
		if isTransferType then
			-- 통신 종료 ================================
			_TransferService:Transfer("out", player.Name)
			-- ==========================================
		end
	end

end