@Component
script MoveCrop extends Component

	@Sync
	property boolean CanMove = true

	@Sync
	property number Stamina = 0

	@ExecSpace("Server")
	method void SetMove()
		self.Entity.TweenLineComponent.Enable = true 
		self.Entity.TweenLineComponent:RestartFromCurrentPosition()
		
		local setdown = function()
		self.Entity.TweenLineComponent.Enable = false
		self.Entity.TweenLineComponent:Stop(nil)
		self:SetDown()
		 self.Stamina = 100
		end
		_TimerService:SetTimerOnce(setdown,3)
		
	end

	@ExecSpace("Multicast")
	method void SetStamina(string order)
		if self.CanMove == true then 
		if order == "sub" then 
		self.Stamina = self.Stamina - 30
		self.Entity.TransformComponent.WorldPosition.y = self.Entity.TransformComponent.WorldPosition.y + 0.1
		
		end
		
		
		if self.Stamina <= 0 then 
			self.Stamina = 0
			self.CanMove = false 
		self:SetMove()
		end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		self.Stamina = 100
		self.CanMove = true 
		self.Entity.TweenLineComponent.Enable = false
		self.Entity.TweenLineComponent:Stop(nil)
	end

	@ExecSpace("Multicast")
	method void SetDown()
		local timer = 0 
		
		local setdown = function()
		
		self.Entity.TransformComponent.WorldPosition.y = self.Entity.TransformComponent.WorldPosition.y - 0.1
		
		
		if self.Entity.TransformComponent.WorldPosition.y <= -1.527756 then 
				self.Entity.TransformComponent.WorldPosition.y = -1.527756
			_TimerService:ClearTimer(timer)
			self.CanMove = true
		end
		
		end
		
		timer = _TimerService:SetTimerRepeat(setdown,0.3)
		
	end

end