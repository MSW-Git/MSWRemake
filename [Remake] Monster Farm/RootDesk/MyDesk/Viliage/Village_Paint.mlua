@Component
script Village_Paint extends Component

	@ExecSpace("Server")
	method void ChangeColor(Entity player)
		log("color")
		if self.Entity.Name == "RedPaint" then 
		player.AvatarRendererComponent:SetColor(0.5,0,0,1,player.Id) 
		log("red")
		player.Player_Interaction.Color = Color(0.5,0,0,1)
		
		elseif self.Entity.Name == "BluePaint" then 
		player.AvatarRendererComponent:SetColor(0,0,0.5,1,player.Id) 
		player.Player_Interaction.Color = Color(0,0,0.5,1) 
		
		elseif self.Entity.Name == "NonePaint" then 
		player.AvatarRendererComponent:SetColor(1,1,1,1,player.Id)
		
		player.Player_Interaction.Color = Color(1,1,1,1) 
				
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- Parameters
		local triggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if not isvalid(triggerBodyEntity.PlayerComponent) then 
			return 
		end
		
		self:ChangeColor(triggerBodyEntity)
	end

end