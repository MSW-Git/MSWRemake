@Component
script RestaurantNPC extends Component

	@Sync
	property boolean Food1 = false

	@Sync
	property boolean Food2 = false

	@Sync
	property boolean Food3 = false

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		self.Food1 = true 
		self.Food2 = true 
		self.Food3 = true 
		
	end

	@ExecSpace("Server")
	method void SetFoods()
		--음식을 세개 한 번에 생산한다. 
		
		
	end

end