@Component
script HelperEntity extends Component

	property Entity TargetEntity = nil

	property number RefreshTime = 0

	property number RefreshTimeMAX = 1

	@Sync
	property number idx = 0

	@Sync
	property string OwnerId = ""

	property number HelperIDX = 0

	@Sync
	property number Speed = 0

	@Sync
	property number CollectDelay = 0

	property number CollectTimer = 0

	property boolean isReachedToTarget = false

	property boolean IsOutOfRange = false

	property number MoveTimer = 0

	property boolean IsMovingToBack = false

	property number HoldTimer = 0

	property MapInfo MapInfo = "cf0fe12f-db97-4a6d-b975-ebdff5e64181"

	property number direction = 0

	property number Level = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		local player = _UserService.LocalPlayer
		
		-- 타겟이 존재할 때 해당 타겟으로 이동합니다. ------------------------------------------
		if player.Name == self.OwnerId then
		 	if isvalid(self.TargetEntity) then
				
				self:CheckIsReachedToMonster(self.TargetEntity)
				
				-- 타겟 몬스터에게 도달하지 못했다면
				if not self.isReachedToTarget then
					self:MoveToTarget(delta, self.TargetEntity.TransformComponent.Position)
				
				-- 타겟 몬스터에게 도달했다면 
				else
					if self.Entity.StateComponent.CurrentStateName ~= "IDLE" then
						self:ChangeAnimation("IDLE")
					end
				end
			end
		end
		
		-- 도우미가 타겟 몬스터에 도달했을 때 회수 타이머를 켭니다. ----------------------------
		if player.Name == self.OwnerId  then
			
			if isvalid(self.TargetEntity) and self.isReachedToTarget and not self.TargetEntity.MonsterComponent.IsDragged then
				if self.CollectTimer <= self.CollectDelay then
					self.CollectTimer = self.CollectTimer + delta
					
				-- 회수 딜레이가 끝났다면 ----------------------
				else
					self.TargetEntity.MonsterComponent:IsClickByHelper()
					self:EntityRandomTalk("finish")
					self:ChangeEmotion("finish")
					self.CollectTimer = 0
					self.TargetEntity = nil
					self.isReachedToTarget = false
				end
				
			else
				self.CollectTimer = 0
			end
			
		end
		
		
		-- 타겟이 없을 경우 혼자 IDLE 하게 합니다. ------------------------------
		if not isvalid(self.TargetEntity) and player.Name == self.OwnerId and self.direction ~= 0 then
			self:EntityMoveIdle(self.direction, delta)
		end
		
		
		if self.RefreshTime >= self.RefreshTimeMAX then
			self.RefreshTime = 0
		else
			self.RefreshTime = self.RefreshTime + delta
			return
		end
		
		
		
		-- 2초 마다 랜덤으로 방향을 바꾸며 움직입니다. -------------------------
		if not isvalid(self.TargetEntity) and player.Name == self.OwnerId then
			if self.MoveTimer >= 2 then
				self.direction = math.random(-1, 1)
				self.IsMovingToBack = false
				self.MoveTimer = 0
				
				if self.direction == 0 then
					self:ChangeAnimation("IDLE")
				end
				
			else
				self.MoveTimer = self.MoveTimer + self.RefreshTimeMAX
			end
		end
		
		
		-- 엔티티의 이동 관련 로직 ----------------------------------------------
		if player.Name == self.OwnerId then
			self.IsOutOfRange = self:EntityRangeOutCheck(player) -- 몬스터가 지역 범위를 나갔는지 확인
			self:EntityMoveRestrict(player) -- 몬스터가 농장 밖으로 이동할 수 없게 설정
		end
		
		
		-- 엔티티의 Layer Depth를 설정합니다. -----------------------------------
		self:EntityLayerSetting()
		
		-- 엔티티의 Status를 매 틱마다 확인합니다. ------------------------------
		if player.Name == self.OwnerId then
			self:ChangeEntityStatus()
		end
		
		local helper_Level = player.PlayerData.Hinventory_Level[self.idx] 
		if isvalid(helper_Level) and helper_Level ~= 0 then
			if self.Level ~= helper_Level then
				self.Level = helper_Level
				self:RefreshHelperStat(player, helper_Level)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void ChangeEntityStatus()
		local player = _UserService.LocalPlayer
		
		self:FindMonsterBeingTarget()
		
		
		if not self:CheckMonsterIsValid() then
			self.CollectTimer = 0
			self.isReachedToTarget = false
			self.TargetEntity = nil
		end
		
		local playerCapacity = _PlayerService:Check_Inventory(player)
		if playerCapacity >= player.PlayerData.MaxCapacity then
			
			self:EntityRandomTalk("full")
			self:ChangeEmotion("full")
			self.CollectTimer = 0
			self.isReachedToTarget = false
			self.TargetEntity = nil
		end
		
	end

	@ExecSpace("ClientOnly")
	method void FindMonsterBeingTarget()
		if isvalid(self.TargetEntity) then
			return
		end
		
		-- 타겟이 될 수 있는 몬스터를 탐색합니다. -----------------------------------
		local monsters = _EntityService:GetEntitiesByTag("Monster")
		local findMonsters = {}
		if not isvalid(monsters) then
			return
		end
		
		for i = 1, #monsters do
			if monsters[i].MonsterComponent.IsFinished and not monsters[i].MonsterComponent.IsHelperTarget and monsters[i].Enable then
				table.insert(findMonsters, monsters[i])
			end
		end
		
		----------------------------------------
		-- 유효한 몬스터가 없다면 Return 합니다.
		----------------------------------------
		if #findMonsters <=0 then
			return
		end
		
		local targetMonster = self:FindNearestMonster(findMonsters)
		
		targetMonster.MonsterComponent.IsHelperTarget = true
		self.TargetEntity = targetMonster
		
	end

	@ExecSpace("ClientOnly")
	method boolean CheckMonsterIsValid()
		-- 타겟으로 삼은 몬스터가 유효한 상태인지 확인합니다. ------------------------
		
		
		----------------------------------------------------------
		-- 유효한지 확인합니다.
		----------------------------------------------------------
		if not isvalid(self.TargetEntity) then
			return false
		end
		
		
		----------------------------------------------------------
		-- 타겟으로 삼은 몬스터가 회수 가능한 상태인지 확인합니다.
		----------------------------------------------------------
		if not self.TargetEntity.MonsterComponent.IsFinished then
			return false
		end
		
		
		----------------------------------------------------------
		-- '도우미 추적' 상태가 적용이 안 됐는지 확인합니다. 
		----------------------------------------------------------
		if not self.TargetEntity.MonsterComponent.IsHelperTarget then
			return false
		end
		
		----------------------------------------------------------
		-- 모든 예외처리에 해당하지 않았다면 true를 반환합니다.
		----------------------------------------------------------
		return true
	end

	@ExecSpace("ClientOnly")
	method Entity FindNearestMonster(SyncTable<Entity> monsters)
		-- 가장 가까이에 있는 몬스터를 찾는 알고리즘입니다. -----------------------------------------------
		local myPos = self.Entity.TransformComponent.Position
		
		local nearestMonster_IDX = 1
		local nearestMonster_Position_Gap_X = math.abs(myPos.x - monsters[1].TransformComponent.Position.x) 
		local nearestMonster_Position_Gap_Y = math.abs(myPos.y - monsters[1].TransformComponent.Position.y)
		
		local nearestMonster_Position_Gap = nearestMonster_Position_Gap_X + nearestMonster_Position_Gap_Y
		
		for i = 1, #monsters do
			local target_Pos_Gap_x = math.abs(myPos.x - monsters[i].TransformComponent.Position.x)
			local target_Pos_Gap_y = math.abs(myPos.y - monsters[i].TransformComponent.Position.y)
			local target_Pos_Gap = target_Pos_Gap_x + target_Pos_Gap_y
			
			if target_Pos_Gap < nearestMonster_Position_Gap then
				nearestMonster_Position_Gap = target_Pos_Gap
				nearestMonster_IDX = i
			end
		end
		
		self:ChangeEmotion("follow")
		
		return monsters[nearestMonster_IDX]
	end

	@ExecSpace("Server")
	method void MoveToTarget(number delta, Vector3 targetPos)
		-- 도우미가 타겟 몬스터를 향해 걸어갑니다. ---------------------------------
		self:ChangeAnimation("MOVE")
		
		local tranform = self.Entity.TransformComponent
		local myPos = tranform.Position
		
		local xPos = math.abs(myPos.x - targetPos.x)
		local yPos = math.abs(myPos.y - targetPos.y)
		
		local basePos = xPos + yPos
		
		local xSpeed = (xPos / basePos) * 2
		
		local ySpeed = (yPos / basePos) * 2
		
		---------------
		-- X축 이동 
		---------------
		
		local isOutRange = false
		if targetPos.x < _PlayerService.Range_X.x then
			isOutRange = true
			
		elseif targetPos.x > _PlayerService.Range_X.y then
			isOutRange = true
		
		elseif targetPos.y < _PlayerService.Range_Y.x then
			isOutRange = true
			
		elseif targetPos.y > _PlayerService.Range_Y.y then
			isOutRange = true
		end
		
		if not isOutRange then
			if myPos.x > targetPos.x + 0.1 then
				tranform.Position.x = tranform.Position.x - (delta * xSpeed * self.Speed)
				if tranform.Scale.x ~= 1 then
					tranform.Scale.x = 1
				end
			elseif myPos.x < targetPos.x - 0.1 then
				tranform.Position.x = tranform.Position.x + (delta * xSpeed * self.Speed)
				if tranform.Scale.x ~= -1 then
					tranform.Scale.x = -1
				end
			end
			
			---------------
			-- Y축 이동
			---------------
			if myPos.y > targetPos.y + 0.1 then
				tranform.Position.y = tranform.Position.y - (delta * ySpeed * self.Speed)
				
			elseif myPos.y < targetPos.y - 0.1 then
				tranform.Position.y = tranform.Position.y + (delta * ySpeed * self.Speed)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void CheckIsReachedToMonster(Entity target)
		-- 해당 도우미가 타겟 몬스터에게 도달한 상태인지 확인합니다. -------
		if not isvalid(target) then
			return
		end
		
		if not target.MonsterComponent.IsHelperTarget then
			return
		end
		
		local myPos = self.Entity.TransformComponent.Position
		
		
		local xPos = math.abs(myPos.x - target.TransformComponent.Position.x)
		local yPos = math.abs(myPos.y - target.TransformComponent.Position.y)
		
		
		if xPos + yPos <= 0.5 then
			self.isReachedToTarget = true	
		else
			if self.isReachedToTarget then
				self.Entity.ChatBalloonComponent.Message = _LocalizationService.LocalTranslator:GetText("Npc_chat_stop")
			end
			self.isReachedToTarget = false
		end
	end

	@ExecSpace("Client")
	method void EntityLayerSetting()
		-- Entity의 Layer를 갱신합니다. ---------------------------------------------------------------------------
		self.Entity.AvatarRendererComponent.OrderInLayer = -(self.Entity.TransformComponent.Position.y * 200) + 800
		
		local shadow = _EntityService:GetEntityByPath(self.Entity.Path.."/shadow")
		shadow.SpriteRendererComponent.OrderInLayer = self.Entity.AvatarRendererComponent.OrderInLayer - 1
	end

	@ExecSpace("ClientOnly")
	method void EntityMoveRestrict(Entity player)
		-- 몬스터가 농장 밖으로 벗어났을 경우 이동 제한을 겁니다. ------------------------------
		if math.abs(self.direction) > 0 and self.IsMovingToBack ~= true and self.IsOutOfRange then
			if self.Entity.TransformComponent.Position.x >= _PlayerService.Range_X.y then
				self.direction = -math.abs(self.direction)
				
			elseif self.Entity.TransformComponent.Position.x <= _PlayerService.Range_X.x then
				self.direction = math.abs(self.direction)
			end
			
			self.MoveTimer = 0
			self.IsMovingToBack = true
		end
	end

	@ExecSpace("ClientOnly")
	method boolean EntityRangeOutCheck(Entity player)
		-- 농장 범위를 벗어났다면 true를, 아니라면 false를 반환합니다.
		local position = self.Entity.TransformComponent.Position
		
		if position.x > _PlayerService.Range_X.y then -- 오른쪽 범위 아웃
			return true
		elseif position.x < _PlayerService.Range_X.x then -- 왼쪽 범위 아웃
			return true
		elseif position.y > _PlayerService.Range_Y.y then -- 상단 범위 아웃
			return true
		elseif position.y < _PlayerService.Range_Y.x then -- 하단 범위 아웃
			return true
		end
		
		return false
	end

	@ExecSpace("ClientOnly")
	method void EntityRandomTalk(string situation)
		-- 상황에 맞게 랜덤으로 텍스트를 띄웁니다. -------------------------------
		local dataSetName = "HelperDataSet_RandomTalk"
		
		local randTable = {}
		
		for i = 1, _DataService:GetRowCount(dataSetName) do
			if _DataService:GetCell(dataSetName, i, "situation") == situation then
				table.insert(randTable, i)
			end	
		end
		
		local randText = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(dataSetName, randTable[math.random(1, #randTable)], "message"))
		
		self.Entity.ChatBalloonComponent.Message = randText
	end

	method void OnBeginPlay()
		if self:IsClient() then return end
		self.Entity.StateComponent:AddState("MOVE")
	end

	@ExecSpace("Server")
	method void ChangeEmotion(string emotion)
		if string.len(emotion) == 0 then
			return
		end
		
		if emotion == "finish" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Love, 1.5)
			
		elseif emotion == "full" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Bowing, 1.5)
			
		elseif emotion == "follow" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Shine, 3)
		end
	end

	@ExecSpace("Server")
	method void ChangeAnimation(string type)
		self.Entity.StateComponent:ChangeState(type)
	end

	@ExecSpace("Server")
	method void EntityMoveIdle(number direction, number delta)
		local speed = 2 * direction
		local tranform = self.Entity.TransformComponent
		
		if math.abs(speed) > 0 then -- Walk 상태일 경우
		
			tranform.Position.x = tranform.Position.x + (speed/10 * delta)
		
			self.Entity.StateComponent:ChangeState("MOVE")
		
			if speed < 0 then -- 오른쪽을 바라봅니다.
				
				if tranform.Scale.x ~= 1 then
					tranform.Scale.x = 1
				end
			elseif speed > 0 then -- 왼쪽을 바라봅니다.
				
				if tranform.Scale.x ~= -1 then
				tranform.Scale.x = -1
				end
			end
		end
	end

	@ExecSpace("Server")
	method void RefreshHelperStat(Entity player, number id)
		-- 일꾼의 능력치를 레벨에 비례해서 설정해줍니다. -----------------------------------------------------
		
		local origin_Speed = tonumber(_DataService:GetCell("HelperDataSet", id, "speed"))
		local origin_CollectDelay = tonumber(_DataService:GetCell("HelperDataSet", id, "collectDelay"))
		local speed_Up_Ratio = tonumber(_DataService:GetCell("HelperDataSet", id, "speed_Up_Ratio"))
		local CollectDelay_Up_Ratio = tonumber(_DataService:GetCell("HelperDataSet", id, "collectDelay_Ratio"))
		
		local helperLevel = player.PlayerData.Hinventory_Level[self.idx]
		
		self.Speed = origin_Speed + (speed_Up_Ratio * helperLevel) 
		self.CollectDelay = origin_CollectDelay + (CollectDelay_Up_Ratio * helperLevel)
	end

end