@Component
script Book_ItemButton extends Component

	property boolean IsUnLocked = false

	property number Id = 0

	property number BookItemCode = 0

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 클릭한 아이템의 명세를 UI로 보여줍니다. ------------
		_BookService:ShowItemInfo(self.IsUnLocked, self.Id, self.BookItemCode)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonPressedEvent(ButtonPressedEvent event)
		self:OnClick()
	end

end