@Component
script CheatComponent extends Component

	property string Type = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonPressedEvent(ButtonPressedEvent event)
		local player = _UserService.LocalPlayer
		if self.Type == "Gold" then
			_CheatLogic:GetGold(player, 100000000)
			_UIToast:ShowMessage("골드 1억 획득")
			
		elseif self.Type == "Ruby" then
			_CheatLogic:GetRuby(player, 1, 100000000)
			_UIToast:ShowMessage("루비 1억 획득")
			
		elseif self.Type == "Candy" then
			_CheatLogic:GetBerry(player, 100000000)
			_UIToast:ShowMessage("캔디 1억 획득")
			
		elseif self.Type == "DB" then
			_CheatLogic:ResetDB(player)
			_UIToast:ShowMessage("몬스터 인벤토리 초기화 (마을로 나갔다가 들어와야 적용됩니다.)")
			
		elseif self.Type == "Monster" then
			_CheatLogic:GetAllMonster(player)
			
		elseif self.Type == "Single" then
			_PlayerService:GetMonster(player, _UtilLogic:RandomIntegerRange(1,130), _MonsterService.Grade_0_Name)
			_UIToast:ShowMessage("몬스터 획득!")
		
		elseif self.Type == "Ingredient" then
			for i = 20010, 20044 do
				_PlayerService:GetItem(player, i, 1, true)
			end
			for i = 20220, 20349 do
				_PlayerService:GetItem(player, i, 1, true)
			end
			_UIToast:ShowMessage("재료 획득!")
			
		elseif self.Type == "ChatBalloon" then
			
			local monsters = _EntityService:GetEntitiesByTag("Monster")
		
			local message = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("MonsterDataSet_RandomTalk", _MonsterService.ChatCount, "message"))
		
			local length = _DataService:GetRowCount("MonsterDataSet_RandomTalk")	
			for i = 1, #monsters do	
				monsters[i].ChatBalloonComponent.Message = message
			end
			_MonsterService.ChatCount += 1
			if _MonsterService.ChatCount > length then
				_MonsterService.ChatCount = 1
			end
		elseif self.Type == "ChatBalloonNPC" then
				local monsters = _EntityService:GetEntitiesByTag("Helper")
		
				local message = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("HelperDataSet_RandomTalk", _MonsterService.HelperCount, "message"))	
				local length = _DataService:GetRowCount("HelperDataSet_RandomTalk")	
			
				for i = 1, #monsters do	
					monsters[i].ChatBalloonComponent.Message = message
				end
				_MonsterService.HelperCount += 1
				if _MonsterService.HelperCount > length then
					_MonsterService.HelperCount = 1
				end
			
		elseif self.Type == "Event" then
			_CheatLogic:GetEvent()
		end
	end

end