@Logic
script CheatLogic extends Logic

	property number Gold_ID = 20001

	property number Berry_ID = 20002

	property number Ruby_ID = 20003

	property SyncTable<number> EventTable_Main

	property SyncTable<number> EventTable_Sub

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		local eventDataSet = _DataService:GetTable("EventDataSet")
		local length = eventDataSet:GetRowCount()
		
		for i = 1, length do
			local eventType = eventDataSet:GetCell(i, "EventType")
			if eventType == "surprise" then
				table.insert(self.EventTable_Sub, i)
			elseif eventType == "main" then
				table.insert(self.EventTable_Main, i)
			end
		end
	end

	@ExecSpace("Server")
	method void GetGold(Entity player, number value)
		-- 재화를 얻습니다. -------------------------------------
		player.PlayerData.Gold = player.PlayerData.Gold + value
		
		if player.PlayerData.Gold < 0 then
			player.PlayerData.Gold = 0 
		end
	end

	@ExecSpace("Server")
	method void GetBerry(Entity player, number value)
		-- 베리를 얻습니다. -------------------------------------
		player.PlayerData.Berry = player.PlayerData.Berry + value
		
		if value > 0 then 
		player.PlayerSubData.GetBerryCount = player.PlayerSubData.GetBerryCount + value --퀘스트 조건 
		
		end
		
		if player.PlayerData.Berry < 0 then
			player.PlayerData.Berry = 0
		end
		
		_GetPopupService:ShowMessage(player, self.Berry_ID, value, nil, nil, nil, player.Name)
	end

	@ExecSpace("Server")
	method void GetRuby(Entity player, number count, number valuePerItem)
		player.PlayerData.Ruby = player.PlayerData.Ruby + (valuePerItem * count)
		
		player.PlayerSubData.GetRubyCount = player.PlayerSubData.GetRubyCount + (valuePerItem * count) -- 퀘스트 조건 
		
		
		_GetPopupService:ShowMessage(player, self.Ruby_ID, valuePerItem * count, nil, nil, nil, player.Name)
		
		if player.PlayerData.Ruby < 0 then
			player.PlayerData.Ruby = 0
		end
	end

	@ExecSpace("Server")
	method void ResetDB(Entity player)
		table.clear(player.PlayerData.Minventory_Entity)
		table.clear(player.PlayerData.Minventory_Exp)
		table.clear(player.PlayerData.Minventory_Grade)
		table.clear(player.PlayerData.Minventory_Id)
		table.clear(player.PlayerData.Minventory_Level)
		table.clear(player.PlayerData.Minventory_Mexp)
		table.clear(player.PlayerData.Minventory_Personality)
		table.clear(player.PlayerData.Minventory_Skill_Id)
		table.clear(player.PlayerData.Minventory_Summoned)
		table.clear(player.PlayerData.Minventory_Time)
		table.clear(player.PlayerData.Minventory_UniqueID)
		
		_UIToast:ShowMessage("몬스터 DB 초기화", player.Name)
	end

	@ExecSpace("Server")
	method void GetAllMonster(Entity player)
		for i = 1, 130 do
			_PlayerService:GetMonster(player, i, _MonsterService.Grade_0_Name)
		end
		
		_UIToast:ShowMessage("모든 몬스터 획득!", player.Name)
	end

	@ExecSpace("ClientOnly")
	method void GetEvent()
		-- 선택지 알림 UI를 엽니다. ------------
		local eventNotification = _EntityService:GetEntityByPath("/ui/DefaultGroup/Event_Notification")
		eventNotification.Enable = true
		
		
		local inputTextEntity = _EntityService:GetEntity("cbc917e9-25a1-4fd1-8219-089773e131ca") -- /ui/DefaultGroup/Model_CheatBoard/UIEmpty
		local strText = inputTextEntity.TextComponent.Text
		
		local strType = string.sub(strText, 1, 6)
		local strIndex = string.sub(strText, 7, #strText)
		
		local numIndex = tonumber(strIndex)
		
		if strType == "메인" or strType == "매인" or strType == "Main" then
			_EventService.CurEventID = self.EventTable_Main[numIndex]
		
		elseif strType == "서브" or strType == "Sub" then
			_EventService.CurEventID = self.EventTable_Sub[numIndex]
			
		end
		
		_EventService:EntityLayerSetting()
		_EventService:OnClick()
		
		local test = function() 
			if strType == "메인" or strType == "매인" or strType == "Main" then
				if strText == "메인"..tostring(math.floor(#self.EventTable_Main)) or strText == "매인"..tostring(math.floor(#self.EventTable_Main)) or strText == "Main"..tostring(math.floor(#self.EventTable_Main)) then
					if strText == "Main"..tostring(math.floor(#self.EventTable_Main)) then
						inputTextEntity.TextComponent.Text = "Sub1"
					else
						inputTextEntity.TextComponent.Text = "서브1"
					end
				else
					inputTextEntity.TextComponent.Text = strType..tostring(math.floor(numIndex) + 1)
				end
			elseif strType == "서브" or strType == "Sub" then
				if strText == "서브"..tostring(math.floor(#self.EventTable_Sub)) or strText == "서브"..tostring(math.floor(#self.EventTable_Sub)) or strText == "Sub"..tostring(math.floor(#self.EventTable_Sub)) then
					if strText == "Sub"..tostring(math.floor(#self.EventTable_Sub)) then
						inputTextEntity.TextComponent.Text = "Main1"
					else
						inputTextEntity.TextComponent.Text = "메인1"
					end
				else
					inputTextEntity.TextComponent.Text = strType..tostring(math.floor(numIndex) + 1)
				end
			end
		end
		
		log(#self.EventTable_Main, "메인")
		log(#self.EventTable_Sub)
		_TimerService:SetTimerOnce(test, 1)
	end

	@ExecSpace("ClientOnly")
	method void ShowItemName(number itemID)
		-- 요리 아이템의 이름을 보여줍니다. -----------
		local player = _UserService.LocalPlayer
		local itemDataSet = _DataService:GetTable("ItemDataSet_Base")
		_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText(itemDataSet:GetCell(itemID - 20000, "name")))
	end

end