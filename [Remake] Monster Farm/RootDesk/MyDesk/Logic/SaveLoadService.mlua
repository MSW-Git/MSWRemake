						else
							table.insert(player.PlayerSubData.GetMonsterReward, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
						
				else -- 저장된 값이 없을 경우
					for i = 1, _DataService:GetRowCount(dataSetName) do
						table.insert(player.PlayerSubData.GetMonsterReward, false) -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "GetFusionMonDate_Secret" then -- 비밀 컬렉션 날짜 리스트
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, fusionDataSet_Secret_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.GetFusionMonDate_Secret, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerSubData.GetFusionMonDate_Secret, " ") -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
