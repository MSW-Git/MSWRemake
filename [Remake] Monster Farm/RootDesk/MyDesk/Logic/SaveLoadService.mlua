						end
					end
						
				else -- 저장된 값이 없을 경우
					for i = 1, fusionDataSet_Secret_Length do
						table.insert(player.PlayerSubData.GetFusionMonList_Secret, false) -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "GetFusionMonReward_Secret" then -- 비밀 컬렉션 보상 리스트
		
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, fusionDataSet_Secret_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.GetFusionMonReward_Secret, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerSubData.GetFusionMonReward_Secret, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
						
				else -- 저장된 값이 없을 경우
					for i = 1, fusionDataSet_Secret_Length do
						table.insert(player.PlayerSubData.GetFusionMonReward_Secret, false) -- 초기 데이터를 생성합니다.	
					end
				end
						
			end
			
		end
		
		playerData:GetAsync("FusionCollection", callback)
		playerData:GetAsync("FusionCollectionDate", callback)
		playerData:GetAsync("FusionCollectionReward", callback)
		playerData:GetAsync("GetFusionMonDate_Secret", callback)
		playerData:GetAsync("GetFusionMonList_Secret", callback)
		playerData:GetAsync("GetFusionMonReward_Secret", callback)
		playerData:GetAsync("monsterBook_Reward", callback)
	end

end