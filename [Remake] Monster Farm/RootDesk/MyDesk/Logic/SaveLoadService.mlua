@Logic
script SaveLoadService extends Logic

	property SyncTable<number> tempMonsterX

	property SyncTable<number> tempMonsterY

	@ExecSpace("ServerOnly")
	method void Save_Data(Entity player, boolean isIntervalSave)
		local playerName = player.PlayerComponent.UserId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		-- ==============================================================
		-- 소환된 마스코트 몬스터 파괴
		-- ==============================================================
		if not isIntervalSave then
			if isvalid(player.PlayerData.MascotPet) then
				player.PlayerData.MascotPet:Destroy()
			end
		end
		-- 플레이어의 기본 데이터를 저장합니다. -------------------------
		local keyTable = {}
		
		--- 플레이어의 레벨
		keyTable["Level"] = tostring(player.PlayerData.Level)
		
		--- 플레이어의 골드
		keyTable["Gold"] = tostring(player.PlayerData.Gold)
		
		--- 플레이어의 베리
		keyTable["Berry"] = tostring(player.PlayerData.Berry)
		
		--- 플레이어의 루비
		keyTable["Ruby"] = tostring(player.PlayerData.Ruby)
		
		--- 플레이어의 인기도
		keyTable["Heart"] = tostring(player.PlayerData.Heart)
		
		--- 플레이어의 몬스터 IDX
		keyTable["MonsterIDX"] = tostring(player.PlayerData.MonsterIDX)
		
		--- 플레이어의 인벤토리 최대 확장 레벨
		keyTable["MaxCapacity_Upgrade_Level"] = tostring(player.PlayerData.MaxCapacity_Upgrade_Level)
		
		--- 플레이어가 장착한 마이콘 IDX 
		keyTable["EquippedMyConID"] = tostring(player.PlayerData.EquippedMyConID)
		
		--- 플레이어의 마스코트 몬스터 IDX
		keyTable["M_mascotID"] = tostring(player.PlayerData.MInventory_MascotPet_Id)
		
		--- 플레이어가 수집한 몬스터 리스트
		keyTable["Q_gottenMonsters"] = _UtilLogic:TableToString(player.PlayerSubData.GetMonsterList)
		
		--- 플레이어의 솥 레벨
		keyTable["CurPotLevel"] = tostring(player.PlayerData.CurPotLevel)
		
		--- 플레이어의 솥 게이지
		keyTable["CurPotGauge"] = tostring(player.PlayerData.CurPotGauge)
		
		--- 플레이어의 솥 타이머
		keyTable["CurPotTimer"] = tostring(player.PlayerData.CurPotTimer)
		
		--- 플레이어의 요리 중 유무
		keyTable["IsCooked"] = tostring(player.PlayerData.IsCooked)
		
		--- 플레이어의 요리 툴 레벨
		keyTable["CurKitchenTool_Level"] = tostring(player.PlayerData.CurKitchenTool_Level)
		
		--- 플레이어의 요리 복장 레벨
		keyTable["CurSuit_Level"] = tostring(player.PlayerData.CurSuit_Level)
		
		--- 플레이어의 요리 레시피 레벨
		keyTable["CurRecipe_Level"] = tostring(player.PlayerData.CurRecipe_Level)
		
		--- 플레이어의 농장 방문 횟수
		keyTable["GetVisitFarm"] = tostring(player.PlayerSubData.GetVisitFarm)
		
		--- 플레이어가 인기도를 준 횟수
		keyTable["GetPopularityCount"] = tostring(player.PlayerSubData.GetPopularityCount)
		
		--- 상점에서 몬스터 구매 시, 자동 배치 여부
		keyTable["IsAutoPlaceOnStore"] = tostring(player.PlayerData.IsAutoPlaceOnStore)
		
		-- ==============================================================
		-- KeyTable 저장
		-- ==============================================================
		playerData:BatchSetAndWait(keyTable)
	end

