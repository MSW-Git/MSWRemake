				else -- 저장된 값이 없을 경우
					for i = 1, fusionDataSet_Secret_Length do
						table.insert(player.PlayerSubData.GetFusionMonDate_Secret, " ") -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "GetFusionMonList_Secret" then -- 비밀 컬렉션 리스트
		
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, fusionDataSet_Secret_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.GetFusionMonList_Secret, Table[i]) -- 저장된 값을 가져옵니다.
