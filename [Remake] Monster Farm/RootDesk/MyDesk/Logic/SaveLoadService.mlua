				elseif key == "GetCookCount" then
					player.PlayerSubData.GetCookCount = callback(key, item.Value, player.PlayerSubData.GetCookCount)
					
				elseif key == "GetCookGrade1" then
					player.PlayerSubData.GetCookGrade1 = callback(key, item.Value, player.PlayerSubData.GetCookGrade1)
					
				elseif key == "GetCookGrade2" then
					player.PlayerSubData.GetCookGrade2 = callback(key, item.Value, player.PlayerSubData.GetCookGrade2)
					
