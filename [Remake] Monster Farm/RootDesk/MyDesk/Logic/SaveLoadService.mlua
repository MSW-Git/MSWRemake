				-- ============================
			
		    pages:MoveToNextPageAndWait()
		end
	end

	@ExecSpace("ServerOnly")
	method void Load_DailyGiveHeartList(Entity player, number dayGap)
		local playerName = player.PlayerComponent.UserId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		-- 저장된 값이 없을 때 초기 값을 nil로 받아오는 이슈를 처리합니다. ---------------------------------
		local errorCode, DailyGiveHeartList_Table = playerData:GetAndWait("DailyGiveHeartList")
		
		if not isvalid(DailyGiveHeartList_Table) then
			return
		end
		
		-- 인기도 정보를 불러옵니다. ----------------------------------------------------------------------
		if dayGap == 0 then
			local DailyGiveHeartList = _UtilLogic:StringToTable(DailyGiveHeartList_Table)
			
			for i = 1, #DailyGiveHeartList do
				table.insert(player.PlayerSubData.DailyGiveHeartList, DailyGiveHeartList[i])
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void Load_Helper(Entity player)
		local playerName = player.PlayerComponent.UserId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		-- 저장된 값이 없을 때 초기 값을 nil로 받아오는 이슈를 처리합니다. ---------------------------------
		local HelperDataSet_Length = _DataService:GetRowCount("HelperDataSet")
		local Load_Table = function(key, value)
			if key == "Hinventory_Level" then -- 도우미의 레벨을 가져옵니다.
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, HelperDataSet_Length do
						if i <= #Table then
							table.insert(player.PlayerData.Hinventory_Level, tonumber(Table[i])) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerData.Hinventory_Level, 0) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
					
				else -- 저장된 값이 없을 경우
					for i = 1, HelperDataSet_Length do
						table.insert(player.PlayerData.Hinventory_Level, 0) -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "Hinventory_Summoned" then -- 도우미의 소환 상태를 가져옵니다.
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, HelperDataSet_Length do
						if i <= #Table then
							table.insert(player.PlayerData.Hinventory_Summoned, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerData.Hinventory_Summoned, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
		
				else -- 저장된 값이 없을 경우
					for i = 1, HelperDataSet_Length do
						table.insert(player.PlayerData.Hinventory_Summoned, false) -- 초기 데이터를 생성합니다.	
					end
				end
			end
			
		end
		
		-- 도우미 데이터를 불러옵니다. ------------------------------------------------------
		
		
		local error, Hinventory_Level_Table = playerData:GetAndWait("Hinventory_Level")
		local error1, Hinventory_Summoned_Table = playerData:GetAndWait("Hinventory_Summoned")
		
		Load_Table("Hinventory_Level", Hinventory_Level_Table)
		Load_Table("Hinventory_Summoned", Hinventory_Summoned_Table)
		
		for i = 1, HelperDataSet_Length do
			table.insert(player.PlayerData.Hinventory_Entity, " ")
		end
		
		if player.CurrentMapName == "farm" then
			_HelperService:SummonHelperByLoad(player)
		end
	end

	@ExecSpace("ServerOnly")
	method void Load_Achievement(Entity player)
		-- 불러오기 코드 입니다. 아래 코드를 그대로 사용해주세요. --------------------
		
		local playerName = player.PlayerComponent.UserId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		local achiDataSet = _AchievementService.AchiDataSet
		local achiDataSet_Length = _DataService:GetRowCount(achiDataSet) -- 업적DataSet의 행 길이를 가져옵니다.
		
		
		local callback = function(errorCode, key, value)
				
			if key == "AchieveComplete" then -- 업적 상태를 가져옵니다. 
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, achiDataSet_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.AcheivementComplete, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerSubData.AcheivementComplete, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
					
				else -- 저장된 값이 없을 경우
					for i = 1, achiDataSet_Length do
						table.insert(player.PlayerSubData.AcheivementComplete, false) -- 초기 데이터를 생성합니다.	
					end
				end
			end
			
		end
		
		playerData:GetAsync("AchieveComplete", callback)
	end

	@ExecSpace("ServerOnly")
	method void Load_Collection_And_Book(Entity player)
		-- 조합 컬렉션을 불러옵니다. -------------------------------------------------
		
		local playerName = player.PlayerComponent.UserId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		local fusionDataSet = "MonsterDataSet_Fusion"
		local fusionDataSet_Length = _DataService:GetRowCount(fusionDataSet) -- FusionDataSet의 행 길이를 가져옵니다.
		
		local fusionDataSet_Secret = "MonsterDataSet_RandFusion_Base"
		local fusionDataSet_Secret_Length = _DataService:GetRowCount(fusionDataSet_Secret) -- FusionDataSet의 행 길이를 가져옵니다.
		
		local callback = function(errorCode, key, value)
			
			if key == "FusionCollectionDate" then
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, fusionDataSet_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.GetFusionMonDate, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerSubData.GetFusionMonDate, " ") -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
					
				else -- 저장된 값이 없을 경우
					for i = 1, fusionDataSet_Length do
						table.insert(player.PlayerSubData.GetFusionMonDate, " ")  -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "FusionCollection" then -- 조합 컬렉션
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, fusionDataSet_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.GetFusionMonList, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerSubData.GetFusionMonList, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
					
				else -- 저장된 값이 없을 경우
					for i = 1, fusionDataSet_Length do
						table.insert(player.PlayerSubData.GetFusionMonList, false) -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "FusionCollectionReward" then -- 컬렉션 보상 리스트
					
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, fusionDataSet_Length do
						if i <= #Table then
							table.insert(player.PlayerSubData.GetFusionMonReward, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(player.PlayerSubData.GetFusionMonReward, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
						
				else -- 저장된 값이 없을 경우
					for i = 1, fusionDataSet_Length do
						table.insert(player.PlayerSubData.GetFusionMonReward, false) -- 초기 데이터를 생성합니다.	
					end
				end
				
			elseif key == "monsterBook_Reward" then -- 몬스터 도감 보상 리스트
				
				local dataSetName = "MonsterDataSet_Base"
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, _DataService:GetRowCount(dataSetName) do
						if i <= #Table then
