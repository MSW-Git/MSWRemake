@Logic
script SubDataService extends Logic

	@ExecSpace("Server")
	method void playerBuyItemCountUp(Entity player)
		-- 아이템 구매 횟수 카운트 증가
		player.PlayerSubData.BuyItemCount = player.PlayerSubData.BuyItemCount + 1
	end

	@ExecSpace("Server")
	method void playerDoFusionCountUp(Entity player)
		-- 조합 완료 카운트 증가 
		player.PlayerSubData.DoFusionCount = player.PlayerSubData.DoFusionCount + 1
	end

	@ExecSpace("Server")
	method void playerBuyEggCountUp(Entity player)
		-- 알 구매 횟수 카운트 증가 
		player.PlayerSubData.BuyMonsterEggCount = player.PlayerSubData.BuyMonsterEggCount + 1 
	end

	@ExecSpace("Server")
	method void SetBookBlink(Entity player, boolean status)
		player.PlayerSubData.IsBookComplete = status
	end

	@ExecSpace("Server")
	method void SetCollectionBlink(Entity player, boolean status)
		player.PlayerSubData.IsCollectionComplete = status
	end

	@ExecSpace("Server")
	method void playerCookCountUp(Entity player, number questID)
		if questID == 17 then 
		player.PlayerSubData.GetCookGrade1 = player.PlayerSubData.GetCookGrade1 + 1 
		elseif 	questID == 19 then 
		player.PlayerSubData.GetCookGrade2 = player.PlayerSubData.GetCookGrade2 + 1 
		elseif 	questID == 23 then 
		player.PlayerSubData.GetCookGrade3 = player.PlayerSubData.GetCookGrade3 + 1 
		
		end	
		
	end

	@ExecSpace("Server")
	method void playerFusionCountUp(Entity player, number questID)
		if questID == 6 then 
			player.PlayerSubData.GetFusionCount1 = player.PlayerSubData.GetFusionCount1 + 1
		elseif questID == 15 then 
			player.PlayerSubData.GetFusionCount2 = player.PlayerSubData.GetFusionCount2 + 1
		elseif questID == 24 then 
			player.PlayerSubData.GetFusionCount3 = player.PlayerSubData.GetFusionCount3 + 1
		end
	end

end