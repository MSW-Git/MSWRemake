@Logic
script StoreService extends Logic

	property Entity StoreUI = "8fbf4e87-75a8-484e-98d6-3004de2ca380"

	@ExecSpace("Server")
	method void Buy_MonsterItem(Entity player, SyncTable<number> requiredItemId, SyncTable<number> requiredItemNum, number rewardItemId)
		-- 재료 아이템 소모 예외 처리 --------------------------------------------------------
		local isBuyFail = false
		
		for i = 1, #requiredItemId do
			if requiredItemId[i] == _PlayerService.Gold_ID then -- '골드'
				
				-- 골드가 부족하다면 ---------------------------
				if player.PlayerData.Gold < requiredItemNum[i] then
					isBuyFail = true
				end
				
			elseif requiredItemId[i] == _PlayerService.Berry_ID then -- '별사탕'
				-- 별사탕이 부족하다면 -------------------------
				if player.PlayerData.Berry < requiredItemNum[i] then
					isBuyFail = true
				end
				
			elseif requiredItemId[i] == _PlayerService.Ruby_ID then -- '루비'
				-- 루비가 부족하다면 ---------------------------
				if player.PlayerData.Ruby < requiredItemNum[i] then
					isBuyFail = true
				end
			end
		end
		
		if not isBuyFail then
			-- 재료 아이템을 소모합니다. ---------------------------------------------------------
			for i = 1, #requiredItemId do
				if requiredItemId[i] == _PlayerService.Gold_ID then -- '골드'
					_PlayerService:GetGold(player, -requiredItemNum[i])
					_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -requiredItemNum[i], nil, nil, nil, player.Name)
					
				elseif requiredItemId[i] == _PlayerService.Berry_ID then -- '캔디'
					_PlayerService:GetBerry(player, -requiredItemNum[i])
					
				elseif requiredItemId[i] == _PlayerService.Ruby_ID then -- '루비'
					_PlayerService:GetRuby(player, 1, -requiredItemNum[i])
				end
			end
			--------------------------------------------------------------------------------------
			
			
			-- 아이템을 획득합니다. --------------------------------------------------------------
			_PlayerService:GetMonster(player, rewardItemId, _MonsterService.Grade_0_Name)
			
			
			-- 자동 배치 기능이 켜져있다면 -------------------------------------------------------
			-- 소환할 공간이 있다면
			local playerSummoned = _PlayerService:Check_Monster_Summoned(player)
			if playerSummoned < player.PlayerData.MaxSummon then	
				if player.PlayerData.IsAutoPlaceOnStore then
					_MonsterService:SummonMonster(player, 1, false, Vector3(0,0,0), true)
				end
			end
			
			-- 효과음을 재생합니다. --------------------------------------------------------------
			_SoundService:PlaySound("6d8fe3cedcf0434883bb4469c1697d7e", 0.7, player.Name)
				
			
			-- 팝업을 재생합니다. ----------------------------------------------------------------
			_LocalizationToastService:ShowMessage("Popup_succeedInBuyItem", player.Name)
			
			
			-- 아이템 일감 -----------------------------------------------------------------------
			if _QuestService:CheckHaveQuest(player, 2) then -- 아이템 구매하기 10회
				_SubDataService:playerBuyItemCountUp(player)
			end
		else
			-- 팝업을 재생합니다. ----------------------------------------------------------------
			_LocalizationToastService:ShowMessage("Popup_lackOfIngredient", player.Name)
		end
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

	@ExecSpace("Server")
	method void Buy_Item(Entity player, SyncTable<number> requiredItemId, SyncTable<number> requiredItemNum, number rewardItemId)
		-- 재료 아이템 소모 예외 처리 --------------------------------------------------------
		local isBuyFail = false
		
		for i = 1, #requiredItemId do
			if requiredItemId[i] == _PlayerService.Gold_ID then -- '골드'
				
				-- 골드가 부족하다면 ---------------------------
				if player.PlayerData.Gold < requiredItemNum[i] then
					isBuyFail = true
				end
				
			elseif requiredItemId[i] == _PlayerService.Berry_ID then -- '별사탕'
				-- 별사탕이 부족하다면 -------------------------
				if player.PlayerData.Berry < requiredItemNum[i] then
					isBuyFail = true
				end
				
			elseif requiredItemId[i] == _PlayerService.Ruby_ID then -- '루비'
				-- 루비가 부족하다면 ---------------------------
				if player.PlayerData.Ruby < requiredItemNum[i] then
					isBuyFail = true
				end
			end
		end
		
		if not isBuyFail then
			-- 재료 아이템을 소모합니다. ---------------------------------------------------------
			for i = 1, #requiredItemId do
				if requiredItemId[i] == _PlayerService.Gold_ID then -- '골드'
					_PlayerService:GetGold(player, -requiredItemNum[i])
					_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -requiredItemNum[i], nil, nil, nil, player.Name)
					
				elseif requiredItemId[i] == _PlayerService.Berry_ID then -- '별사탕'
					_PlayerService:GetBerry(player, -requiredItemNum[i])
					
				elseif requiredItemId[i] == _PlayerService.Ruby_ID then -- '루비'
					_PlayerService:GetRuby(player, 1, -requiredItemNum[i])
				end
			end
			--------------------------------------------------------------------------------------
			
			
			-- 아이템을 획득합니다. --------------------------------------------------------------
			_PlayerService:GetItem(player, rewardItemId, 1, true)
				
			
			-- 효과음을 재생합니다. --------------------------------------------------------------
			_SoundService:PlaySound("6d8fe3cedcf0434883bb4469c1697d7e", 0.7, player.Name)
				
			
			-- 팝업을 재생합니다. ----------------------------------------------------------------
			_LocalizationToastService:ShowMessage("Popup_succeedInBuyItem", player.Name)
			
			
			-- 아이템 일감 -----------------------------------------------------------------------
			if _QuestService:CheckHaveQuest(player, 2) then -- 아이템 구매하기 10회
				_SubDataService:playerBuyItemCountUp(player)
			end
		else
			-- 팝업을 재생합니다. ----------------------------------------------------------------
			_LocalizationToastService:ShowMessage("Popup_lackOfIngredient", player.Name)
		end
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

	@ExecSpace("Server")
	method void Buy_Helper(Entity player, SyncTable<number> requiredItemId, SyncTable<number> requiredItemNum, number rewardItemId)
		-- 재료 아이템 소모 예외 처리 --------------------------------------------------------
		local isBuyFail = false
		
		for i = 1, #requiredItemId do
			if requiredItemId[i] == _PlayerService.Gold_ID then -- '골드'
				
				-- 골드가 부족하다면 ---------------------------
				if player.PlayerData.Gold < requiredItemNum[i] then
					isBuyFail = true
				end
				
			elseif requiredItemId[i] == _PlayerService.Berry_ID then -- '별사탕'
				-- 별사탕이 부족하다면 -------------------------
				if player.PlayerData.Berry < requiredItemNum[i] then
					isBuyFail = true
				end
				
			elseif requiredItemId[i] == _PlayerService.Ruby_ID then -- '루비'
				-- 루비가 부족하다면 ---------------------------
				if player.PlayerData.Ruby < requiredItemNum[i] then
					isBuyFail = true
				end
			end
		end
		
		if not isBuyFail then
			-- 재료 아이템을 소모합니다. ---------------------------------------------------------
			for i = 1, #requiredItemId do
				if requiredItemId[i] == _PlayerService.Gold_ID then -- '골드'
					_PlayerService:GetGold(player, -requiredItemNum[i])
					_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -requiredItemNum[i], nil, nil, nil, player.Name)
					
				elseif requiredItemId[i] == _PlayerService.Berry_ID then -- '캔디'
					_PlayerService:GetBerry(player, -requiredItemNum[i])
					
				elseif requiredItemId[i] == _PlayerService.Ruby_ID then -- '루비'
					_PlayerService:GetRuby(player, 1, -requiredItemNum[i])
					
				else
					_PlayerService:DestroyItem(player, requiredItemId[i], requiredItemNum[i])
					_GetPopupService:ShowMessage(player, requiredItemId[i], -requiredItemNum[i], nil, nil, nil, player.Name)
				end
			end
			--------------------------------------------------------------------------------------
			
			
			-- 아이템을 획득합니다. --------------------------------------------------------------
			_PlayerService:GetHelper(player, rewardItemId, nil)
			
			
			-- 효과음을 재생합니다. --------------------------------------------------------------
			_SoundService:PlaySound("6d8fe3cedcf0434883bb4469c1697d7e", 0.7, player.Name)
				
			
			-- 팝업을 재생합니다. ----------------------------------------------------------------
			_LocalizationToastService:ShowMessage("Popup_succeedInBuyItem", player.Name)
			
			
			-- 아이템 일감 -----------------------------------------------------------------------
			if _QuestService:CheckHaveQuest(player, 2) then -- 아이템 구매하기 10회
				_SubDataService:playerBuyItemCountUp(player)
			end
			
		else
			-- 팝업을 재생합니다. ----------------------------------------------------------------
			_LocalizationToastService:ShowMessage("Popup_lackOfIngredient", player.Name)
		end
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

end