@Logic
script HelperService extends Logic

	@ExecSpace("Server")
	method void SummonHelperByLoad(Entity player)
		-- 농장에 진입할 때, 도우미 엔티티를 소환합니다. ------------------------------------------
		
		for i = 1, #player.PlayerData.Hinventory_Summoned do
			if player.PlayerData.Hinventory_Level[i] > 0 then -- 구매한 일꾼만 소환
				self:SummonHelper(player, i, false)
			end
		end
	end

	@ExecSpace("Server")
	method void SummonHelper(Entity player, number idx, boolean is_Buy_Summon)
		if #player.PlayerData.Hinventory_Entity[idx] >= 3 then -- 이미 소환된 일꾼이라면
			return
		end
		
		-- 도우미 엔티티를 필드에 생성합니다. -----------------------------------------------------
		local helperEntity = _EntityService:GetEntityByPath("/maps/farm/HelperEntity")
		
		local cloned_helperEntity = helperEntity:Clone("helperEntity_"..tostring(math.floor(idx)))
		
		local costume_ID = tonumber(_DataService:GetCell("HelperDataSet", idx, "originAvatarID"))
		
		
		-- 엔티티 스텟을 대입합니다. --------------------------------------------------------------
		cloned_helperEntity.HelperEntity.OwnerId = player.Name
		cloned_helperEntity.HelperEntity.idx = idx
		cloned_helperEntity.HelperEntity.Speed = tonumber(_DataService:GetCell("HelperDataSet", idx, "speed"))
		cloned_helperEntity.HelperEntity.CollectDelay = tonumber(_DataService:GetCell("HelperDataSet", idx, "collectDelay"))
		
		
		-- 엔티티 위치를 대입합니다. --------------------------------------------------------------
		local randPos = Vector3(math.random(-280,200) / 100, math.random(100, 260) / 100, 0)
		
		cloned_helperEntity.TransformComponent.Position = Vector3(randPos.x, randPos.y, 0)
		
		
		-- 엔티티 정보를 대입합니다. --------------------------------------------------------------
		player.PlayerData.Hinventory_Entity[idx] = cloned_helperEntity.Id
		player.PlayerData.Hinventory_Summoned[idx] = true
		
		
		-- 도우미 엔티티의 코스튬을 변경합니다. ---------------------------------------------------
		self:SetHelperCostume(player, costume_ID, cloned_helperEntity)
		
		if is_Buy_Summon then
			_LocalizationToastService:ShowMessage("Popup_buyHelper", player.Name)
		end
	end

	@ExecSpace("Server")
	method void SetHelperCostume(Entity player, number idx, Entity target)
		if not isvalid(idx) then
			-- 통신 종료 ================================
			_TransferService:Transfer("out", player.Name)
			-- ==========================================
			return
		end
		
		-- 도우미 엔티티의 외형을 코스튬에 맞게 최신화합니다. --------------------------------------
		local dataSetName = "HelperDataSet_Costume"
		local dataSet = _DataService:GetTable(dataSetName)
		
		local helperEntity = target
		
		local helperCostume = helperEntity.CostumeManagerComponent
		
		helperCostume.Enable = false
		
		wait(0.1)
		
		helperCostume.CustomBodyEquip = dataSet:GetCell(idx, "body")
		helperCostume.CustomCapEquip = dataSet:GetCell(idx, "cap")
		helperCostume.CustomCapeEquip = dataSet:GetCell(idx, "cape")
		helperCostume.CustomCoatEquip = dataSet:GetCell(idx, "coat")
		helperCostume.CustomEarAccessoryEquip = dataSet:GetCell(idx, "earAccessory")
		helperCostume.CustomEarEquip = dataSet:GetCell(idx, "ear")
		helperCostume.CustomEyeAccessoryEquip = dataSet:GetCell(idx, "eyeAccessory")
		helperCostume.CustomFaceAccessoryEquip = dataSet:GetCell(idx, "faceAccessory")
		helperCostume.CustomFaceEquip = dataSet:GetCell(idx, "face")
		helperCostume.CustomGloveEquip = dataSet:GetCell(idx, "glove")
		helperCostume.CustomHairEquip = dataSet:GetCell(idx, "hair")
		helperCostume.CustomLongcoatEquip = dataSet:GetCell(idx, "longCoat")
		helperCostume.CustomOneHandedWeaponEquip = dataSet:GetCell(idx, "oneHandedWeapon")
		helperCostume.CustomPantsEquip = dataSet:GetCell(idx, "pants")
		helperCostume.CustomShoesEquip = dataSet:GetCell(idx, "shoes")
		helperCostume.CustomSubWeaponEquip = dataSet:GetCell(idx, "subWeapon")
		helperCostume.CustomTwoHandedWeaponEquip = dataSet:GetCell(idx, "twoHandedWeapon")
		
		wait(0.1)
		
		helperCostume.Enable = true
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

	@ExecSpace("Server")
	method void DestroyHelper(Entity player, number idx)
		-- 필드에 소환된 몬스터 제거 --
		
		local entity_idx = player.PlayerData.Hinventory_Entity[idx] 
		
		if not isvalid(entity_idx) then
			-- 통신 종료 ================================
			_TransferService:Transfer("out", player.Name)
			-- ==========================================
			return
		end
		
		player.PlayerData.Hinventory_Entity[idx] = " "
		player.PlayerData.Hinventory_Summoned[idx] = false
		
		_EntityService:GetEntity(entity_idx):Destroy()
		
		_LocalizationToastService:ShowMessage("Popup_bringBackHelper", player.Name)
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

end