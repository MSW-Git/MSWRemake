          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\n-- 몬스터 데이터를 저장합니다. ----------------------------------\nlocal keyTable = {}\n\n--- 플레이어의 몬스터 인벤토리 ID\nkeyTable[\"M_id\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Id)\n\n--- 플레이어의 몬스터 인벤토리 EXP\nkeyTable[\"M_exp\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Exp)\n\n--- 플레이어의 몬스터 인벤토리 MEXP\nkeyTable[\"M_mexp\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Mexp)\n\n--- 플레이어의 몬스터 인벤토리 LEVEL\nkeyTable[\"M_lv\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Level)\n\n--- 플레이어의 몬스터 인벤토리 GRADE\nkeyTable[\"M_grade\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Grade)\n\n--- 플레이어의 몬스터 인벤토리 SUMMONED\nkeyTable[\"M_summoned\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Summoned)\n\n--- 플레이어의 몬스터 인벤토리 PERSONALITY\nkeyTable[\"M_personality\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Personality)\n\n--- 플레이어의 몬스터 인벤토리 SKILL ID\nkeyTable[\"M_skill_id\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_Skill_Id)\n\n--- 플레이어의 몬스터 인벤토리 UNIQUE ID\nkeyTable[\"M_uniqueID\"] = _UtilLogic:TableToString(player.PlayerData.Minventory_UniqueID)\n\n\n-- ==============================================================\n-- KeyTable 저장\n-- ==============================================================\nplayerData:BatchSetAndWait(keyTable)",
