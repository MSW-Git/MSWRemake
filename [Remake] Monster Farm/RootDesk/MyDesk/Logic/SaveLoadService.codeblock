          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\n-- 저장된 값이 없을 때 초기 값을 nil로 받아오는 이슈를 처리합니다. ---------------------------------\nlocal errorCode, DailyGiveHeartList_Table = playerData:GetAndWait(\"DailyGiveHeartList\")\n\nif not isvalid(DailyGiveHeartList_Table) then\n\treturn\nend\n\n-- 인기도 정보를 불러옵니다. ----------------------------------------------------------------------\nif dayGap == 0 then\n\tlocal DailyGiveHeartList = _UtilLogic:StringToTable(DailyGiveHeartList_Table)\n\t\n\tfor i = 1, #DailyGiveHeartList do\n\t\ttable.insert(player.PlayerSubData.DailyGiveHeartList, DailyGiveHeartList[i])\n\tend\nend",
