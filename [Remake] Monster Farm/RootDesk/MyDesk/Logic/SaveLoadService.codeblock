          "Code": "-- 조합 컬렉션을 불러옵니다. -------------------------------------------------\n\nlocal playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal fusionDataSet = \"MonsterDataSet_Fusion\"\nlocal fusionDataSet_Length = _DataService:GetRowCount(fusionDataSet) -- FusionDataSet의 행 길이를 가져옵니다.\n\nlocal fusionDataSet_Secret = \"MonsterDataSet_RandFusion_Base\"\nlocal fusionDataSet_Secret_Length = _DataService:GetRowCount(fusionDataSet_Secret) -- FusionDataSet의 행 길이를 가져옵니다.\n\nlocal callback = function(errorCode, key, value)\n\t\n\tif key == \"FusionCollectionDate\" then\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, fusionDataSet_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonDate, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonDate, \" \") -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, fusionDataSet_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonDate, \" \")  -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"FusionCollection\" then -- 조합 컬렉션\n\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, fusionDataSet_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonList, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonList, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, fusionDataSet_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonList, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"FusionCollectionReward\" then -- 컬렉션 보상 리스트\n\t\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, fusionDataSet_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonReward, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonReward, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, fusionDataSet_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonReward, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"monsterBook_Reward\" then -- 몬스터 도감 보상 리스트\n\t\t\n\t\tlocal dataSetName = \"MonsterDataSet_Base\"\n\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, _DataService:GetRowCount(dataSetName) do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetMonsterReward, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetMonsterReward, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, _DataService:GetRowCount(dataSetName) do\n\t\t\t\ttable.insert(player.PlayerSubData.GetMonsterReward, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"GetFusionMonDate_Secret\" then -- 비밀 컬렉션 날짜 리스트\n\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, fusionDataSet_Secret_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonDate_Secret, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonDate_Secret, \" \") -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, fusionDataSet_Secret_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonDate_Secret, \" \") -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"GetFusionMonList_Secret\" then -- 비밀 컬렉션 리스트\n\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, fusionDataSet_Secret_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonList_Secret, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonList_Secret, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, fusionDataSet_Secret_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonList_Secret, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"GetFusionMonReward_Secret\" then -- 비밀 컬렉션 보상 리스트\n\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, fusionDataSet_Secret_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonReward_Secret, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonReward_Secret, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, fusionDataSet_Secret_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.GetFusionMonReward_Secret, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\t\t\n\tend\n\t\nend\n\nplayerData:GetAsync(\"FusionCollection\", callback)\nplayerData:GetAsync(\"FusionCollectionDate\", callback)\nplayerData:GetAsync(\"FusionCollectionReward\", callback)\nplayerData:GetAsync(\"GetFusionMonDate_Secret\", callback)\nplayerData:GetAsync(\"GetFusionMonList_Secret\", callback)\nplayerData:GetAsync(\"GetFusionMonReward_Secret\", callback)\nplayerData:GetAsync(\"monsterBook_Reward\", callback)",
