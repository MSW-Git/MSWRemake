          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal keyTable = {}\ntable.insert(keyTable, \"M_id\")\ntable.insert(keyTable, \"M_exp\")\ntable.insert(keyTable, \"M_mexp\")\ntable.insert(keyTable, \"M_lv\")\ntable.insert(keyTable, \"M_grade\")\ntable.insert(keyTable, \"M_summoned\")\ntable.insert(keyTable, \"M_personality\")\ntable.insert(keyTable, \"M_skill_id\")\ntable.insert(keyTable, \"M_uniqueID\")\n\n\n-- 플레이어의 불러올 데이터를 예외처리 합니다. -----------------\nlocal callback = function(key, value)\n\t\n\tif isvalid(value) then -- 저장된 값이 있다면\n\t\tvalue = _UtilLogic:StringToTable(value)\n\t\tif key == \"M_id\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Id[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_exp\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Exp[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_mexp\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Mexp[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_lv\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Level[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_grade\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Grade[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_summoned\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Summoned[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_personality\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Personality[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_skill_id\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_Skill_Id[i] = value[i]\n\t\t\tend\n\t\telseif key == \"M_uniqueID\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Minventory_UniqueID[i] = value[i]\n\t\t\tend\n\t\tend\n\tend\n\t\nend\n\n-- ==============================================================\n-- 플레이어의 데이터를 불러옵니다.\n-- ==============================================================\nlocal errorCode, pages = playerData:BatchGetAndWait(keyTable) \nlocal requestCount = 3\nwhile errorCode ~= 0 do\n\trequestCount = requestCount - 1\n\tif requestCount <= 0 then\n\t\t-- Kick User\n\t\t_UserService:KickUser(playerName, KickReason.ETC)\n\t\treturn\n\telse\n\t\t-- Request\n\t\terrorCode, pages = playerData:BatchGetAndWait(keyTable) \n\tend\nend\n-- ===============================================================\n\nwhile true do\n    local items = pages:GetCurrentPageDatas()\n    for _, item in pairs(items) do\n\t\t\n\t\tlocal key = item.KeyInfo.Key\n\t\t\n\t\tcallback(key, item.Value)\n    end\n \n\t-- ============================\n\t-- 마지막 페이지면 리턴\n\t-- ============================\n    if pages.IsLastPage then\n        break\n    end\n\t-- ============================\n\t\n    pages:MoveToNextPageAndWait()\nend\n\n\nfor i = 1, #player.PlayerData.Minventory_Id do\n\tplayer.PlayerData.Minventory_Entity[i] = \" \"\n\tplayer.PlayerData.Minventory_Time[i] = 0\nend\n\n-- =============================================================\n-- 마스코트 몬스터를 생성합니다.\n-- =============================================================\nif player.CurrentMapName == \"farm\" then\n\tif player.PlayerData.Owner then\n\t\t_MonsterService:SummonMonsterByLoad(player)\t\n\telse\n\t\t_MascotService:CreateMascotMonster(player)\n\tend\t\t\nelse\n\t_MascotService:CreateMascotMonster(player)\nend\t",
