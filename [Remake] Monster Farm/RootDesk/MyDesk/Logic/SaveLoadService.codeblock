          "Code": "-- 불러오기 코드 입니다. 아래 코드를 그대로 사용해주세요. --------------------\n\nlocal playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal achiDataSet = _AchievementService.AchiDataSet\nlocal achiDataSet_Length = _DataService:GetRowCount(achiDataSet) -- 업적DataSet의 행 길이를 가져옵니다.\n\n\nlocal callback = function(errorCode, key, value)\n\t\t\n\tif key == \"AchieveComplete\" then -- 업적 상태를 가져옵니다. \n\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, achiDataSet_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerSubData.AcheivementComplete, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerSubData.AcheivementComplete, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, achiDataSet_Length do\n\t\t\t\ttable.insert(player.PlayerSubData.AcheivementComplete, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\tend\n\t\nend\n\nplayerData:GetAsync(\"AchieveComplete\", callback)",
