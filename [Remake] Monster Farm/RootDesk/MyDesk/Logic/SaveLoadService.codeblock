          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\n-- 플레이어의 퀘스트 데이터를 저장합니다.  ----------------------\t\nlocal keyTable = {}\n\n--- 플레이어의 핵심 일감 진행도\nkeyTable[\"Q_mainQuest\"] = tostring(player.PlayerSubData.MainQuest)\n\n--- 플레이어의 보조 일감 테이블\nkeyTable[\"Q_normalQuests\"] = _UtilLogic:TableToString(player.PlayerSubData.NormalQuests)\n\n--- 플레이어의 대기 중 일감 테이블\nkeyTable[\"Q_waitingQuests\"] = _UtilLogic:TableToString(player.PlayerSubData.WaitingQuests)\n\n--- 플레이어의 완료 일감 테이블\nkeyTable[\"Q_doneQuests\"] = _UtilLogic:TableToString(player.PlayerSubData.DoneQuests)\n\n--- 플레이어의 불릿 표시\nkeyTable[\"noti_fusion\"] = tostring(player.PlayerSubData.Noti_Fusion)\nkeyTable[\"noti_inv\"] = tostring(player.PlayerSubData.Noti_Inv)\nkeyTable[\"noti_minv\"] = tostring(player.PlayerSubData.Noti_MInv)\nkeyTable[\"noti_cook\"] = tostring(player.PlayerSubData.Noti_Cook)\n\n--- 플레이어의 일감 진행도 \nkeyTable[\"getItemCount\"] = tostring(player.PlayerSubData.GetItemCount)\nkeyTable[\"getItemCount1\"] = tostring(player.PlayerSubData.GetItemCount1)\nkeyTable[\"getItemCount2\"] = tostring(player.PlayerSubData.GetItemCount2)\nkeyTable[\"getItemCount3\"] = tostring(player.PlayerSubData.GetItemCount3)\nkeyTable[\"getItemCount4\"] = tostring(player.PlayerSubData.GetItemCount4)\nkeyTable[\"feedCount\"] = tostring(player.PlayerSubData.FeedCount)\nkeyTable[\"getNormalMonCount\"] = tostring(player.PlayerSubData.GetNormalMonCount)\nkeyTable[\"buyItemCount\"] = tostring(player.PlayerSubData.BuyItemCount)\nkeyTable[\"doFusionCount\"] = tostring(player.PlayerSubData.DoFusionCount)\nkeyTable[\"buyMonsterEggCount\"] = tostring(player.PlayerSubData.BuyMonsterEggCount)\nkeyTable[\"findItemCount\"] = tostring(player.PlayerSubData.FindItemCount)\nkeyTable[\"upgradeMonsterCount\"] = tostring(player.PlayerSubData.UpgradeMonsterCount)\nkeyTable[\"IsQuestComplete\"] = tostring(player.PlayerSubData.IsQuestComplete)\nkeyTable[\"IsBookComplete\"] = tostring(player.PlayerSubData.IsBookComplete)\nkeyTable[\"IsCollectionComplete\"] = tostring(player.PlayerSubData.IsCollectionComplete)\nkeyTable[\"GetBerryCount\"] = tostring(player.PlayerSubData.GetBerryCount)\nkeyTable[\"GetRubyCount\"] = tostring(player.PlayerSubData.GetRubyCount)\nkeyTable[\"GetMascotCount\"] = tostring(player.PlayerSubData.GetMascotCount)\nkeyTable[\"GetGrade5Monster\"] = tostring(player.PlayerSubData.GetGrade5Monster)\nkeyTable[\"GetMonsterGeneration\"] = tostring(player.PlayerSubData.GetMonsterGeneration)\nkeyTable[\"GetFusionCount1\"] = tostring(player.PlayerSubData.GetFusionCount1)\nkeyTable[\"GetFusionCount2\"] = tostring(player.PlayerSubData.GetFusionCount2)\nkeyTable[\"GetFusionCount3\"] = tostring(player.PlayerSubData.GetFusionCount3)\nkeyTable[\"GetFusionSlot\"] = tostring(player.PlayerSubData.GetFusionSlot)\nkeyTable[\"GetCookCount\"] = tostring(player.PlayerSubData.GetCookCount)\nkeyTable[\"GetCookGrade1\"] = tostring(player.PlayerSubData.GetCookGrade1)\nkeyTable[\"GetCookGrade2\"] = tostring(player.PlayerSubData.GetCookGrade2)\nkeyTable[\"GetCookGrade3\"] = tostring(player.PlayerSubData.GetCookGrade3)\nkeyTable[\"GetCookingEquipment\"] = tostring(player.PlayerSubData.GetCookingEquipment)\nkeyTable[\"GetIngredient\"] = tostring(player.PlayerSubData.GetIngredient)\nkeyTable[\"GetFeedCount\"] = tostring(player.PlayerSubData.GetFeedCount)\nkeyTable[\"GetGradeChange\"] = tostring(player.PlayerSubData.GetGradeChange)\nkeyTable[\"GetSkillChange\"] = tostring(player.PlayerSubData.GetSkillChange)\nkeyTable[\"GetLabSkillCount\"] = tostring(player.PlayerSubData.GetLabSkillCount)\nkeyTable[\"GetHelperCount\"] = tostring(player.PlayerSubData.GetHelperCount)\nkeyTable[\"GetHelperUpgrade\"] = tostring(player.PlayerSubData.GetHelperUpgrade)\n\n\n-- ==============================================================\n-- KeyTable 저장\n-- ==============================================================\nplayerData:BatchSetAndWait(keyTable)",
