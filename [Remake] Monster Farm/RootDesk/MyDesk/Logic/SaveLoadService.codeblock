          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\n-- 저장된 값이 없을 때 초기 값을 nil로 받아오는 이슈를 처리합니다. ---------------------------------\nlocal HelperDataSet_Length = _DataService:GetRowCount(\"HelperDataSet\")\nlocal Load_Table = function(key, value)\n\tif key == \"Hinventory_Level\" then -- 도우미의 레벨을 가져옵니다.\n\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, HelperDataSet_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerData.Hinventory_Level, tonumber(Table[i])) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerData.Hinventory_Level, 0) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\t\t\t\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, HelperDataSet_Length do\n\t\t\t\ttable.insert(player.PlayerData.Hinventory_Level, 0) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\t\t\n\telseif key == \"Hinventory_Summoned\" then -- 도우미의 소환 상태를 가져옵니다.\n\t\t\n\t\tif isvalid(value) then -- 저장된 값이 있을 경우\n\t\t\tlocal Table = _UtilLogic:StringToTable(value)\n\t\t\tfor i = 1, HelperDataSet_Length do\n\t\t\t\tif i <= #Table then\n\t\t\t\t\ttable.insert(player.PlayerData.Hinventory_Summoned, Table[i]) -- 저장된 값을 가져옵니다.\n\t\t\t\telse\n\t\t\t\t\ttable.insert(player.PlayerData.Hinventory_Summoned, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)\n\t\t\t\tend\n\t\t\tend\n\n\t\telse -- 저장된 값이 없을 경우\n\t\t\tfor i = 1, HelperDataSet_Length do\n\t\t\t\ttable.insert(player.PlayerData.Hinventory_Summoned, false) -- 초기 데이터를 생성합니다.\t\n\t\t\tend\n\t\tend\n\tend\n\t\nend\n\n-- 도우미 데이터를 불러옵니다. ------------------------------------------------------\n\n\nlocal error, Hinventory_Level_Table = playerData:GetAndWait(\"Hinventory_Level\")\nlocal error1, Hinventory_Summoned_Table = playerData:GetAndWait(\"Hinventory_Summoned\")\n\nLoad_Table(\"Hinventory_Level\", Hinventory_Level_Table)\nLoad_Table(\"Hinventory_Summoned\", Hinventory_Summoned_Table)\n\nfor i = 1, HelperDataSet_Length do\n\ttable.insert(player.PlayerData.Hinventory_Entity, \" \")\nend\n\nif player.CurrentMapName == \"farm\" then\n\t_HelperService:SummonHelperByLoad(player)\nend",
