          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal keyTable = {}\ntable.insert(keyTable, \"Iv_id\")\ntable.insert(keyTable, \"Iv_quantity\")\n\n-- 플레이어의 불러올 데이터를 예외처리 합니다. -----------------\nlocal callback = function(key, value)\n\t\n\tif isvalid(value) then -- 저장된 값이 있다면\n\t\tvalue = _UtilLogic:StringToTable(value)\n\t\tif key == \"Iv_id\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Inventory_Name[i] = value[i]\n\t\t\t\t\n\t\t\t\t-- 타입 추가 --\n\t\t\t\tlocal type = _DataService:GetCell(\"ItemDataSet_Base\", value[i] - 20000, \"type\")\n\t\t\t\tplayer.PlayerData.Inventory_Type[i] = type\n\t\t\tend\n\n\t\telseif key == \"Iv_quantity\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Inventory_Quantity[i] = value[i]\n\t\t\tend\n\t\tend\n\tend\n\t\nend\n\n-- ==============================================================\n-- 플레이어의 데이터를 불러옵니다.\n-- ==============================================================\nlocal errorCode, pages = playerData:BatchGetAndWait(keyTable) \nlocal requestCount = 3\nwhile errorCode ~= 0 do\n\trequestCount = requestCount - 1\n\tif requestCount <= 0 then\n\t\t-- Kick User\n\t\t_UserService:KickUser(playerName, KickReason.ETC)\n\t\treturn\n\telse\n\t\t-- Request\n\t\terrorCode, pages = playerData:BatchGetAndWait(keyTable) \n\tend\nend\n-- ===============================================================\n\nwhile true do\n    local items = pages:GetCurrentPageDatas()\n    for _, item in pairs(items) do\n\n\t\tlocal key = item.KeyInfo.Key\n\t\n\t\tcallback(key, item.Value)\n    end\n \n\t-- ============================\n\t-- 마지막 페이지면 리턴\n\t-- ============================\n    if pages.IsLastPage then\n        break\n    end\n\t-- ============================\n\t\n    pages:MoveToNextPageAndWait()\nend\n\n",
