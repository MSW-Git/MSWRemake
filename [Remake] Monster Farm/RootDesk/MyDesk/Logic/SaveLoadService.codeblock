          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal keyTable = {}\ntable.insert(keyTable, \"Level\")\ntable.insert(keyTable, \"Gold\")\ntable.insert(keyTable, \"MaxCapacity_Upgrade_Level\")\ntable.insert(keyTable, \"MonsterIDX\")\ntable.insert(keyTable, \"Heart\")\ntable.insert(keyTable, \"EquippedMyConID\")\ntable.insert(keyTable, \"Ruby\")\ntable.insert(keyTable, \"Berry\")\ntable.insert(keyTable, \"M_mascotID\")\ntable.insert(keyTable, \"CurPotLevel\")\ntable.insert(keyTable, \"CurPotGauge\")\ntable.insert(keyTable, \"CurPotTimer\")\ntable.insert(keyTable, \"IsCooked\")\ntable.insert(keyTable, \"CurKitchenTool_Level\")\ntable.insert(keyTable, \"CurSuit_Level\")\ntable.insert(keyTable, \"CurRecipe_Level\")\ntable.insert(keyTable, \"GetVisitFarm\")\ntable.insert(keyTable, \"GetPopularityCount\")\ntable.insert(keyTable, \"IsAutoPlaceOnStore\")\n\n\n-- ==============================================================\n-- 플레이어의 기본 데이터를 불러옵니다.\n-- ==============================================================\nlocal errorCode, pages = playerData:BatchGetAndWait(keyTable) \nlocal requestCount = 3\n\nwhile errorCode ~= 0 do\n\trequestCount = requestCount - 1\n\tif requestCount <= 0 then\n\t\t-- Kick User\n\t\t_UserService:KickUser(playerName, KickReason.ETC)\n\t\treturn\n\telse\n\t\t-- Request\n\t\terrorCode, pages = playerData:BatchGetAndWait(keyTable) \n\tend\nend\n-- ==============================================================\n\nwhile true do\n\tlocal items = pages:GetCurrentPageDatas()\n\t\n\tfor _, item in pairs(items) do\n\t\n\t\tlocal key = item.KeyInfo.Key\n\t\t\t\t\n\t\tif isvalid(item.Value) and item.Value ~= \"0\" then\n\t\t\tif key == \"Level\" then\n\t\t\t\tlocal level_Value = tonumber(item.Value) \n\t\t\t\tplayer.PlayerData.Level = level_Value\n\t\t\t\t-- ==============================================\n\t\t\t\t-- 몬스터 소환 가능 수 갱신\n\t\t\t\t-- ==============================================\n\t\t\t\tplayer.PlayerData.MaxSummon = tonumber(_DataService:GetCell(\"FarmLevelDataSet\", level_Value, \"maxSummon\"))\n\t\t\t\t\n\t\t\telseif key == \"Gold\" then\n\t\t\t\tplayer.PlayerData.Gold = tonumber(item.Value)\n\t\t\telseif key == \"Ruby\" then\n\t\t\t\tplayer.PlayerData.Ruby = tonumber(item.Value)\n\t\t\telseif key == \"Berry\" then\n\t\t\t\tplayer.PlayerData.Berry = tonumber(item.Value)\n\t\t\telseif key == \"Heart\" then\n\t\t\t\tplayer.PlayerData.Heart = tonumber(item.Value)\n\t\t\telseif key == \"MaxCapacity_Upgrade_Level\" then\n\t\t\t\tlocal level_Value = tonumber(item.Value)\n\t\t\t\tplayer.PlayerData.MaxCapacity_Upgrade_Level = level_Value\n\t\t\t\t-- ===============================================\n\t\t\t\t-- 창고 최대 보유 개수 갱신\n\t\t\t\t-- ===============================================\n\t\t\t\tif level_Value >= 2 then\n\t\t\t\t\tplayer.PlayerData.MaxCapacity = tonumber(_DataService:GetCell(\"ItemDataSet_CapaUpCost\", level_Value - 1, \"maxCapacity\"))\n\t\t\t\tend\n\t\t\t\t\n\t\t\telseif key == \"MonsterIDX\" then\n\t\t\t\tplayer.PlayerData.MonsterIDX = tonumber(item.Value)\n\t\t\telseif key == \"EquippedMyConID\" then\n\t\t\t\tplayer.PlayerData.EquippedMyConID = tonumber(item.Value)\n\t\t\telseif key == \"M_mascotID\" then\n\t\t\t\tplayer.PlayerData.MInventory_MascotPet_Id = tonumber(item.Value)\n\t\t\telseif key == \"CurPotLevel\" then\n\t\t\t\tplayer.PlayerData.CurPotLevel = tonumber(item.Value)\n\t\t\telseif key == \"CurPotTimer\" then\n\t\t\t\tplayer.PlayerData.CurPotTimer = tonumber(item.Value)\n\t\t\telseif key == \"CurPotGauge\" then\n\t\t\t\tplayer.PlayerData.CurPotGauge = tonumber(item.Value)\n\t\t\telseif key == \"CurKitchenTool_Level\" then\n\t\t\t\tplayer.PlayerData.CurKitchenTool_Level = tonumber(item.Value)\n\t\t\telseif key == \"CurSuit_Level\" then\n\t\t\t\tplayer.PlayerData.CurSuit_Level = tonumber(item.Value)\n\t\t\telseif key == \"CurRecipe_Level\" then\n\t\t\t\tplayer.PlayerData.CurRecipe_Level = tonumber(item.Value)\n\t\t\telseif key == \"IsCooked\" then\n\t\t\t\tplayer.PlayerData.IsCooked = (item.Value == \"true\" and true or false)\n\t\t\telseif key == \"GetVisitFarm\" then\n\t\t\t\tplayer.PlayerSubData.GetVisitFarm = tonumber(item.Value)\n\t\t\telseif key == \"GetPopularityCount\" then\n\t\t\t\tplayer.PlayerSubData.GetPopularityCount = tonumber(item.Value)\n\t\t\telseif key == \"IsAutoPlaceOnStore\" then\n\t\t\t\tplayer.PlayerData.IsAutoPlaceOnStore = (item.Value == \"true\" and true or false)\n\t\t\tend\n\t\tend\n\t end\n\t\t-- ============================\n\t\t-- 마지막 페이지면 리턴\n\t\t-- ============================\n\t    if pages.IsLastPage then\n\t        break\n\t    end\n\t\t-- ============================\n\t\t\n\t    pages:MoveToNextPageAndWait()\n\tend\n\n\n-- =================================================\n-- 다른 플레이어의 농장 방문시 카운트 업 합니다.\n-- =================================================\nif player.CurrentMapName == \"farm\" then\n\tif not owner then\n\t\tplayer.PlayerSubData.GetVisitFarm = player.PlayerSubData.GetVisitFarm + 1\n\tend\nend\n\nif player.PlayerData.IsCooked then\n\tif owner then\n\t\tplayer.PlayerData.CurPotTimer = player.PlayerData.CurPotTimer + gapTime\n\tend\nelse\n\tplayer.PlayerData.CurPotTimer = 0\nend\n\n-- =================================================\n-- 수집한 몬스터 명단을 가져옵니다.\n-- =================================================\nlocal error, Q_gottenMonsters_Table = playerData:GetAndWait(\"Q_gottenMonsters\")\n\nif isvalid(Q_gottenMonsters_Table) then\n\tQ_gottenMonsters_Table = _UtilLogic:StringToTable(Q_gottenMonsters_Table)\t\n\t\n\tfor i = 1, _DataService:GetRowCount(\"MonsterDataSet_Base\") do\n\t\tif i <= #Q_gottenMonsters_Table then\n\t\t\ttable.insert(player.PlayerSubData.GetMonsterList, Q_gottenMonsters_Table[i])\n\t\telse\n\t\t\ttable.insert(player.PlayerSubData.GetMonsterList, false)\n\t\tend\n\tend\nelse\n\tfor i = 1, _DataService:GetRowCount(\"MonsterDataSet_Base\") do\n\t\ttable.insert(player.PlayerSubData.GetMonsterList, false) -- 초기 데이터를 생성합니다.\t\n\tend\nend\n\n-- =================================================\n-- 랭킹에 반영합니다.\n-- =================================================\nself:Save_Rank(player, false)",
          "Scope": 2,
