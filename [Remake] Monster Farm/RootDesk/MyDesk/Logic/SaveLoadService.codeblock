          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal keyTable = {}\ntable.insert(keyTable, \"F_unlock\")\ntable.insert(keyTable, \"F_first_id\")\ntable.insert(keyTable, \"F_first_grade\")\ntable.insert(keyTable, \"F_second_id\")\ntable.insert(keyTable, \"F_second_grade\")\ntable.insert(keyTable, \"F_remaining_time\")\ntable.insert(keyTable, \"F_reward_monster_id\")\ntable.insert(keyTable, \"F_reward_monster_grade\")\n\nlocal length = player.PlayerData.Finventory_Slot_Quantity\n\n-- 플레이어의 불러올 데이터를 예외처리 합니다. -----------------\nlocal callback = function(key, value)\n\n\tif isvalid(value) then -- 저장된 값이 있다면\n\t\tvalue = _UtilLogic:StringToTable(value)\n\t\tif key == \"F_unlock\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_Slot_Unlock[i] = value[i]\n\t\t\tend\n\t\telseif key == \"F_first_id\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_First_Id[i] = value[i]\n\t\t\tend\n\t\telseif key == \"F_first_grade\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_First_Grade[i] = value[i]\n\t\t\tend\n\t\telseif key == \"F_second_id\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_Second_Id[i] = value[i]\n\t\t\tend\n\t\telseif key == \"F_second_grade\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_Second_Grade[i] = value[i]\n\t\t\tend\n\t\telseif key == \"F_remaining_time\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tif isvalid(gapTime) then\n\t\t\t\t\tplayer.PlayerData.Finventory_Remaining_Time[i] = value[i] - gapTime\n\t\t\t\telse\n\t\t\t\t\tplayer.PlayerData.Finventory_Remaining_Time[i] = value[i]\n\t\t\t\tend\n\t\t\tend\n\t\telseif key == \"F_reward_monster_id\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_Reward_Monster_Id[i] = value[i]\n\t\t\tend\n\t\telseif key == \"F_reward_monster_grade\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerData.Finventory_Reward_Monster_Grade[i] = value[i]\n\t\t\tend\n\t\tend\n\t\t\n\tend\nend\n\n-- ==============================================================\n-- 플레이어의 데이터를 불러옵니다.\n-- ==============================================================\nlocal errorCode, pages = playerData:BatchGetAndWait(keyTable) \nlocal requestCount = 3\nwhile errorCode ~= 0 do\n\trequestCount = requestCount - 1\n\tif requestCount <= 0 then\n\t\t-- Kick User\n\t\t_UserService:KickUser(playerName, KickReason.ETC)\n\t\treturn\n\telse\n\t\t-- Request\n\t\terrorCode, pages = playerData:BatchGetAndWait(keyTable) \n\tend\nend\n-- ===============================================================\n\nlocal dataIsValid = false\n\nwhile true do\n    local items = pages:GetCurrentPageDatas()\n\n    for _, item in pairs(items) do\n\t\tif isvalid(item.Value) and item.Value ~= \"0\" then\n\t\t\tdataIsValid = true\n\t\t\tlocal key = item.KeyInfo.Key\n\t\t\tcallback(key, item.Value)\n\t\tend\n    end\n \n\t-- ============================\n\t-- 마지막 페이지면 리턴\n\t-- ============================\n    if pages.IsLastPage then\n        break\n    end\n\t-- ============================\n\t\n    pages:MoveToNextPageAndWait()\nend\n\nif not dataIsValid then\n\tfor i = 1, length do\n\t\tplayer.PlayerData.Finventory_Slot_Unlock[i] = (i == 1)\n\t\tplayer.PlayerData.Finventory_First_Id[i] = 0\n\t\tplayer.PlayerData.Finventory_First_Grade[i] = \" \"\n\t\tplayer.PlayerData.Finventory_Second_Id[i] = 0\n\t\tplayer.PlayerData.Finventory_Second_Grade[i] = \" \"\n\t\tplayer.PlayerData.Finventory_Remaining_Time[i] = 0\n\t\tplayer.PlayerData.Finventory_Reward_Monster_Id[i] = 0\n\t\tplayer.PlayerData.Finventory_Reward_Monster_Grade[i] = \" \"\n\tend\nend",
