          "Code": "local playerName = player.PlayerComponent.UserId\nlocal playerData = _DataStorageService:GetUserDataStorage(playerName)\n\nlocal keyTable = {}\ntable.insert(keyTable, \"noti_fusion\")\ntable.insert(keyTable, \"noti_inv\")\ntable.insert(keyTable, \"noti_minv\")\ntable.insert(keyTable, \"noti_cook\")\ntable.insert(keyTable, \"getItemCount\")\ntable.insert(keyTable, \"getItemCount1\")\ntable.insert(keyTable, \"getItemCount2\")\ntable.insert(keyTable, \"getItemCount3\")\ntable.insert(keyTable, \"getItemCount4\")\ntable.insert(keyTable, \"feedCount\")\ntable.insert(keyTable, \"getNormalMonCount\")\ntable.insert(keyTable, \"buyItemCount\")\ntable.insert(keyTable, \"doFusionCount\")\ntable.insert(keyTable, \"buyMonsterEggCount\")\ntable.insert(keyTable, \"findItemCount\")\ntable.insert(keyTable, \"upgradeMonsterCount\")\ntable.insert(keyTable, \"IsQuestComplete\")\ntable.insert(keyTable, \"IsBookComplete\")\ntable.insert(keyTable, \"IsCollectionComplete\")\ntable.insert(keyTable, \"GetBerryCount\")\ntable.insert(keyTable, \"GetRubyCount\")\ntable.insert(keyTable, \"GetMascotCount\")\ntable.insert(keyTable, \"GetGrade5Monster\")\ntable.insert(keyTable, \"GetMonsterGeneration\")\ntable.insert(keyTable, \"GetFusionCount1\")\ntable.insert(keyTable, \"GetFusionCount2\")\ntable.insert(keyTable, \"GetFusionCount3\")\ntable.insert(keyTable, \"GetFusionSlot\")\ntable.insert(keyTable, \"GetCookCount\")\ntable.insert(keyTable, \"GetCookGrade1\")\ntable.insert(keyTable, \"GetCookGrade2\")\ntable.insert(keyTable, \"GetCookGrade3\")\ntable.insert(keyTable, \"GetCookingEquipment\")\ntable.insert(keyTable, \"GetIngredient\")\ntable.insert(keyTable, \"GetFeedCount\")\ntable.insert(keyTable, \"GetGradeChange\")\ntable.insert(keyTable, \"GetSkillChange\")\ntable.insert(keyTable, \"GetLabSkillCount\")\ntable.insert(keyTable, \"GetHelperCount\")\ntable.insert(keyTable, \"GetHelperUpgrade\")\n\n\nlocal keyTable_Table = {}\ntable.insert(keyTable_Table, \"Q_normalQuests\")\ntable.insert(keyTable_Table, \"Q_waitingQuests\")\ntable.insert(keyTable_Table, \"Q_doneQuests\")\n\n-- ==============================================================\n-- 플레이어의 데이터를 불러옵니다.\n-- ==============================================================\nlocal errorCode, pages = playerData:BatchGetAndWait(keyTable) \nlocal requestCount = 3\nwhile errorCode ~= 0 do\n\trequestCount = requestCount - 1\n\tif requestCount <= 0 then\n\t\t-- Kick User\n\t\t_UserService:KickUser(playerName, KickReason.ETC)\n\t\treturn\n\telse\n\t\t-- Request\n\t\terrorCode, pages = playerData:BatchGetAndWait(keyTable)  \n\tend\nend\n-- ==============================================================\n\n-- ==============================================================\n-- 플레이어의 데이터를 불러옵니다.\n-- ==============================================================\nlocal errorCode_Table, pages_Table = playerData:BatchGetAndWait(keyTable_Table) \n\nwhile errorCode ~= 0 do\n\trequestCount = requestCount - 1\n\tif requestCount <= 0 then\n\t\t-- Kick User\n\t\t_UserService:KickUser(playerName, KickReason.ETC)\n\t\treturn\n\telse\n\t\t-- Request\n\t\terrorCode, pages_Table = playerData:BatchGetAndWait(keyTable_Table) \n\tend\nend\n-- ===============================================================\n\n-- =============================================================\n-- 처음 접속한 유저일 때, 보조 일감을 지급합니다.\n-- =============================================================\nlocal error, Q_mainQuest_Temp = playerData:GetAndWait(\"Q_mainQuest\")\n\nif not isvalid(Q_mainQuest_Temp) then\n\ttable.insert(player.PlayerSubData.WaitingQuests, 1)\n\ttable.insert(player.PlayerSubData.WaitingQuests, 2)\n\treturn\nelse\n\tplayer.PlayerSubData.MainQuest = tonumber(Q_mainQuest_Temp)\nend\n\n\n-- 플레이어의 불러올 데이터를 예외처리 합니다. -----------------\nlocal callback = function(key, value, origin_Value)\n\n\tif isvalid(value) then -- 저장된 값이 있다면\n\t\treturn value\n\telse\n\t\treturn origin_Value\n\tend\nend\n\n-- 플레이어의 불러올 데이터를 예외처리 합니다. -----------------\nlocal callback_Table = function(key, value)\n\n\tif isvalid(value) then -- 저장된 값이 있다면\n\t\tvalue = _UtilLogic:StringToTable(value)\n\t\tif key == \"Q_normalQuests\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerSubData.NormalQuests[i] = value[i]\n\t\t\tend\n\t\telseif key == \"Q_waitingQuests\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerSubData.WaitingQuests[i] = value[i]\n\t\t\tend\n\t\telseif key == \"Q_doneQuests\" then\n\t\t\tfor i = 1, #value do\n\t\t\t\tplayer.PlayerSubData.DoneQuests[i] = value[i]\n\t\t\tend\n\t\tend\n\tend\nend\n\n\n-- 플레이어의 퀘스트 테이블을 불러옵니다. -----------------------\n\nwhile true do\n    local items = pages_Table:GetCurrentPageDatas()\n\n    for _, item in pairs(items) do\n\t\tlocal key = item.KeyInfo.Key\n\t\tcallback_Table(key, item.Value)\n    end\n \n\t-- ============================\n\t-- 마지막 페이지면 리턴\n\t-- ============================\n    if pages_Table.IsLastPage then\n        break\n    end\n\t-- ============================\n\t\n    pages_Table:MoveToNextPageAndWait()\nend\n\n\n\n-- 플레이어의 기본 데이터를 불러옵니다. ------------------------ \n\nwhile true do\n    local items = pages:GetCurrentPageDatas()\n    for _, item in pairs(items) do\n\n\t\tlocal key = item.KeyInfo.Key\n\t\t\n\t\tif key == \"noti_fusion\" then\n\t\t\tplayer.PlayerSubData.Noti_Fusion = callback(key, item.Value, player.PlayerSubData.Noti_Fusion)\n\t\t\t\n\t\telseif key == \"noti_inv\" then\n\t\t\tplayer.PlayerSubData.Noti_Inv = callback(key, item.Value, player.PlayerSubData.Noti_Inv)\n\t\t\t\t\t\n\t\telseif key == \"noti_minv\" then\n\t\t\tplayer.PlayerSubData.Noti_MInv = callback(key, item.Value, player.PlayerSubData.Noti_MInv)\n\t\t\t\n\t\telseif key == \"noti_cook\" then\n\t\t\tplayer.PlayerSubData.Noti_Cook = callback(key, item.Value, player.PlayerSubData.Noti_Cook)\n\t\t\t\n\t\telseif key == \"getItemCount\" then\n\t\t\tplayer.PlayerSubData.GetItemCount = callback(key, item.Value, player.PlayerSubData.GetItemCount)\n\t\t\t\n\t\telseif key == \"getItemCount1\" then\n\t\t\tplayer.PlayerSubData.GetItemCount1 = callback(key, item.Value, player.PlayerSubData.GetItemCount1)\n\t\t\t\n\t\telseif key == \"getItemCount2\" then\n\t\t\tplayer.PlayerSubData.GetItemCount2 = callback(key, item.Value, player.PlayerSubData.GetItemCount2)\n\t\t\t\n\t\telseif key == \"getItemCount3\" then\n\t\t\tplayer.PlayerSubData.GetItemCount3 = callback(key, item.Value, player.PlayerSubData.GetItemCount3)\n\t\t\t\n\t\telseif key == \"getItemCount4\" then\n\t\t\tplayer.PlayerSubData.GetItemCount4 = callback(key, item.Value,player.PlayerSubData.GetItemCount4)\n\t\t\t\t\n\t\telseif key == \"feedCount\" then\n\t\t\tplayer.PlayerSubData.FeedCount = callback(key, item.Value, player.PlayerSubData.FeedCount)\n\t\t\t\t\n\t\telseif key == \"getNormalMonCount\" then\n\t\t\tplayer.PlayerSubData.GetNormalMonCount = callback(key, item.Value, player.PlayerSubData.GetNormalMonCount)\n\t\t\t\t\t\t\n\t\telseif key == \"buyItemCount\" then\n\t\t\tplayer.PlayerSubData.BuyItemCount = callback(key, item.Value, player.PlayerSubData.BuyItemCount)\n\t\t\t\t\n\t\telseif key == \"doFusionCount\" then\n\t\t\tplayer.PlayerSubData.DoFusionCount = callback(key, item.Value, player.PlayerSubData.DoFusionCount)\n\t\t\t\n\t\telseif key == \"buyMonsterEggCount\" then\n\t\t\tplayer.PlayerSubData.BuyMonsterEggCount = callback(key, item.Value, player.PlayerSubData.BuyMonsterEggCount)\n\t\t\t\n\t\telseif key == \"findItemCount\" then\n\t\t\tplayer.PlayerSubData.FindItemCount = callback(key, item.Value, player.PlayerSubData.FindItemCount)\n\t\t\t\n\t\telseif key == \"upgradeMonsterCount\" then\n\t\t\tplayer.PlayerSubData.UpgradeMonsterCount = callback(key, item.Value, player.PlayerSubData.UpgradeMonsterCount)\n\t\t\t\n\t\telseif key == \"IsQuestComplete\" then\n\t\t\tplayer.PlayerSubData.IsQuestComplete = callback(key, item.Value, player.PlayerSubData.IsQuestComplete)\n\t\t\t\n\t\telseif key == \"IsBookComplete\" then\n\t\t\tplayer.PlayerSubData.IsBookComplete = callback(key, item.Value, player.PlayerSubData.IsBookComplete)\n\t\t\t\n\t\telseif key == \"IsCollectionComplete\" then\n\t\t\tplayer.PlayerSubData.IsCollectionComplete = callback(key, item.Value, player.PlayerSubData.IsCollectionComplete)\n\t\t\t\n\t\telseif key == \"GetBerryCount\" then\n\t\t\tplayer.PlayerSubData.GetBerryCount = callback(key, item.Value, player.PlayerSubData.GetBerryCount)\n\t\t\t\n\t\telseif key == \"GetRubyCount\" then\n\t\t\tplayer.PlayerSubData.GetRubyCount = callback(key, item.Value, player.PlayerSubData.GetRubyCount)\n\t\t\t\n\t\telseif key == \"GetMascotCount\" then\n\t\t\tplayer.PlayerSubData.GetMascotCount = callback(key, item.Value, player.PlayerSubData.GetMascotCount)\n\t\t\n\t\telseif key == \"GetGrade5Monster\" then\n\t\t\tplayer.PlayerSubData.GetGrade5Monster = callback(key, item.Value, player.PlayerSubData.GetGrade5Monster)\n\t\t\t\n\t\telseif key == \"GetMonsterGeneration\" then\n\t\t\tplayer.PlayerSubData.GetMonsterGeneration = callback(key, item.Value, player.PlayerSubData.GetMonsterGeneration)\n\t\t\t\n\t\telseif key == \"GetFusionCount1\" then\n\t\t\tplayer.PlayerSubData.GetFusionCount1 = callback(key, item.Value, player.PlayerSubData.GetFusionCount1)\n\t\t\t\n\t\telseif key == \"GetFusionCount2\" then\n\t\t\tplayer.PlayerSubData.GetFusionCount2 = callback(key, item.Value, player.PlayerSubData.GetFusionCount2)\n\t\t\t\n\t\telseif key == \"GetFusionCount3\" then\n\t\t\tplayer.PlayerSubData.GetFusionCount3 = callback(key, item.Value, player.PlayerSubData.GetFusionCount3)\n\t\t\t\n\t\telseif key == \"GetFusionSlot\" then\n\t\t\tplayer.PlayerSubData.GetFusionSlot = callback(key, item.Value, player.PlayerSubData.GetFusionSlot)\n\t\t\n\t\telseif key == \"GetCookCount\" then\n\t\t\tplayer.PlayerSubData.GetCookCount = callback(key, item.Value, player.PlayerSubData.GetCookCount)\n\t\t\t\n\t\telseif key == \"GetCookGrade1\" then\n\t\t\tplayer.PlayerSubData.GetCookGrade1 = callback(key, item.Value, player.PlayerSubData.GetCookGrade1)\n\t\t\t\n\t\telseif key == \"GetCookGrade2\" then\n\t\t\tplayer.PlayerSubData.GetCookGrade2 = callback(key, item.Value, player.PlayerSubData.GetCookGrade2)\n\t\t\t\n\t\telseif key == \"GetCookGrade3\" then\n\t\t\tplayer.PlayerSubData.GetCookGrade3 = callback(key, item.Value, player.PlayerSubData.GetCookGrade3)\n\t\t\t\n\t\telseif key == \"GetCookingEquipment\" then\n\t\t\tplayer.PlayerSubData.GetCookingEquipment = callback(key, item.Value, player.PlayerSubData.GetCookingEquipment)\n\t\t\t\n\t\telseif key == \"GetIngredient\" then\n\t\t\tplayer.PlayerSubData.GetIngredient = callback(key, item.Value, player.PlayerSubData.GetIngredient)\n\t\t\t\n\t\telseif key == \"GetFeedCount\" then\n\t\t\tplayer.PlayerSubData.GetFeedCount = callback(key, item.Value, player.PlayerSubData.GetFeedCount)\n\t\t\t\n\t\telseif key == \"GetGradeChange\" then\n\t\t\tplayer.PlayerSubData.GetGradeChange = callback(key, item.Value, player.PlayerSubData.GetGradeChange)\n\t\n\t\telseif key == \"GetSkillChange\" then\n\t\t\tplayer.PlayerSubData.GetSkillChange = callback(key, item.Value, player.PlayerSubData.GetSkillChange)\n\t\t\t\n\t\telseif key == \"GetLabSkillCount\" then\n\t\t\tplayer.PlayerSubData.GetLabSkillCount = callback(key, item.Value, player.PlayerSubData.GetLabSkillCount)\n\t\t\t\n\t\telseif key == \"GetHelperCount\" then\n\t\t\tplayer.PlayerSubData.GetHelperCount = callback(key, item.Value, player.PlayerSubData.GetHelperCount)\n\t\t\t\n\t\telseif key == \"GetHelperUpgrade\" then\n\t\t\tplayer.PlayerSubData.GetHelperUpgrade = callback(key, item.Value, player.PlayerSubData.GetHelperUpgrade)\n\t    end\n \tend\n\t\t-- ============================\n\t\t-- 마지막 페이지면 리턴\n\t\t-- ============================\n\t    if pages.IsLastPage then\n\t        break\n\t    end\n\t\t-- ============================\n\t\n    pages:MoveToNextPageAndWait()\nend",
