              "Attributes": [],
              "Name": "id"
            }
          ],
          "Code": "for i = 1, #player.PlayerSubData.NormalQuests do\n\tif player.PlayerSubData.NormalQuests[i] == id then\n\t\treturn true\n\tend\nend\n-------------------------------------------------------------\nreturn false",
          "Scope": 2,
          "ExecSpace": 0,
          "Attributes": [],
          "Name": "CheckHaveQuest"
        },
        {
          "Return": {
            "Type": "number",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [],
          "Code": "-- 몬스터 수집 진행도를 Return합니다. -------------\nlocal collectedMonsters = 0\n\nlocal player = _UserService.LocalPlayer\n\nfor i = 1, #player.PlayerSubData.GetMonsterList do\n\tif player.PlayerSubData.GetMonsterList[i] then\n\t\tcollectedMonsters = collectedMonsters + 1\n\tend\nend\n\nreturn collectedMonsters",
          "Scope": 2,
          "ExecSpace": 2,
          "Attributes": [],
          "Name": "GetMonsterProgress"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "number",
              "DefaultValue": null,
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "rewardMonster_Generation"
            }
          ],
          "Code": "if player.PlayerSubData.MainQuest == 5 then\n\tif rewardMonster_Generation >= 3 then -- 3세대 이상 몬스터\n\t\tplayer.PlayerSubData.GetMonsterGeneration = rewardMonster_Generation --획득한 몬스터가 몇 세대인지 \n\tend\n    \nelseif player.PlayerSubData.MainQuest == 12 then\n    \n\tif rewardMonster_Generation>= 4 then -- 4세대 이상 몬스터\n\t\tplayer.PlayerSubData.GetMonsterGeneration = rewardMonster_Generation\n\tend\n    \nelseif player.PlayerSubData.MainQuest == 13 then\n    \n\tif rewardMonster_Generation >= 5 then -- 5세대 이상 몬스터\n\t\tplayer.PlayerSubData.GetMonsterGeneration = rewardMonster_Generation\n\tend\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "SetQuestFusionValue"
        }
      ],
      "EntityEventHandlers": [],
      "worldCoreVersion": "1.25.0.0",
      "worldStudioVersion": "0.1.0.0",
      "useService": 0
    }
  }
