              "SyncDirection": 0,
              "Attributes": [],
              "Name": "status"
            }
          ],
          "Code": "-- 퀘스트 버튼을 반짝거리게 설정합니다. -----\nplayer.PlayerSubData.IsQuestComplete = status",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "SetQuestButtonBlink"
        },
        {
