		_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_alert_Trade")..maxMonster, nil, nil, nil)
	end

	@ExecSpace("Server")
	method void GetGoldByEvent(Entity player, number eventID)
		-- 이벤트를 통해 재화를 얻습니다. ------------------------------
		local rewardDataSetName = "EventDataSet_Reward"
		
		local rewardRatio = _DataService:GetCell("EventDataSet", eventID, "reward_Ratio")
		local rewardQuantity = _DataService:GetCell(rewardDataSetName, player.PlayerData.Level, "reward_Quantity")
		
		if not isvalid(rewardRatio) or rewardRatio == '' or rewardRatio == ' ' then
			return
		end
		
		if not isvalid(rewardQuantity) then
			return
		end
		
		rewardQuantity = tonumber(rewardQuantity) * (rewardRatio * 0.01)
		
		-- 재화를 얻습니다. -------------------------------------
		player.PlayerData.Gold = player.PlayerData.Gold + rewardQuantity
		
		if player.PlayerData.Gold < 0 then
			player.PlayerData.Gold = 0 
		end
		
		
		_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, rewardQuantity, nil, nil, nil, player.Name)
		
	end

	@ExecSpace("Server")
	method void CapacityUP(Entity player)
		local maxLevel = _DataService:GetRowCount("ItemDataSet_CapaUpCost")
		
		local capacityLevel = player.PlayerData.MaxCapacity_Upgrade_Level
		
		-- 창고를 최대 레벨까지 확장했다면 더 이상 레벨 업 못하게 합니다. --------
		if capacityLevel > maxLevel then
			_LocalizationToastService:ShowMessage("Popup_imPossibleToExpand", player.Name)
			-- 통신 종료 ================================
			_TransferService:Transfer("out", player.Name)
			-- ==========================================
			return
		end
		
		
		-- 금액을 제대로 받아오지 못했다면 리턴합니다. ---------------------------
		local cost = tonumber(_DataService:GetCell("ItemDataSet_CapaUpCost", capacityLevel, "cost"))
		
		if not isvalid(cost) then
			_LocalizationToastService:ShowMessage("Popup_faitToExpandCapacity", player.Name)
			-- 통신 종료 ================================
			_TransferService:Transfer("out", player.Name)
			-- ==========================================
			return
		end
		
		if player.PlayerData.Gold < cost then
			_LocalizationToastService:ShowMessage("Popup_lackOfGold", player.Name)
			-- 통신 종료 ================================
			_TransferService:Transfer("out", player.Name)
			-- ==========================================
			return
		end
		
		
		-- 재화를 뻅니다. --------------------------------------------------------
		player.PlayerData.Gold = player.PlayerData.Gold - cost
		_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, -cost, nil, nil, nil, player.Name)
		
		
		
		-- 창고 최대 보유량을 늘립니다 -------------------------------------------
		player.PlayerData.MaxCapacity = tonumber(_DataService:GetCell("ItemDataSet_CapaUpCost", capacityLevel, "maxCapacity"))
		player.PlayerData.MaxCapacity_Upgrade_Level = capacityLevel + 1
		
		_GetPopupService:ShowMessage(player, nil, 9, "GetPopup_capacity", true, "34f706c703cc44a39ae631384accc136", player.Name)
		
		
		-- 이펙트 재생 -----------------------------------------------------------
		_LocalizationToastService:ShowMessage("Popup_capacityUp", player.Name)
		_SoundService:PlaySound("74222ba4b41d48dd97175fd691124a67", 0.75, player.Name)
			
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
		
	end

	method number Check_Inventory(Entity player)
		local capacity = 0
		
		for i = 1, #player.PlayerData.Inventory_Quantity do
			capacity = capacity + player.PlayerData.Inventory_Quantity[i]
		end
		
		return capacity
	end

	method number Check_Monster_Summoned(Entity player)
		local summoned = 0
		local playerData = player.PlayerData 
		
		for i = 1, #playerData.Minventory_Id do
			if playerData.Minventory_Summoned[i] then
				summoned = summoned + 1
			end
		end
		
		return summoned
	end

	@ExecSpace("Server")
	method void Set_Auto_Place_Status(Entity player)
		player.PlayerData.IsAutoPlaceOnStore = not player.PlayerData.IsAutoPlaceOnStore
		
		if player.PlayerData.IsAutoPlaceOnStore then
			_LocalizationToastService:ShowMessage("Popup_enableAutoPlace", player.Name)
		else
			_LocalizationToastService:ShowMessage("Popup_disableAutoPlace", player.Name)
		end
		
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

end