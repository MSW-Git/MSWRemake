              "Name": "destination"
            }
          ],
          "Code": "-- 각 플레이어의 농장으로 이동합니다. ---------------------------------\nif not isvalid(player) then\n\treturn\nend\n\nif not isvalid(player.PlayerData) then\n\treturn\nend\n\n----------------------------------------------------------------------\n-- 농장이 최대 플레이어 수 이상 생성되었을 경우 예외 처리합니다.\n----------------------------------------------------------------------\nlocal dataSetName = \"PortalDataSet\"\nlocal maxPlayers = _DataService:GetRowCount(dataSetName)\nlocal instanceMaps = _InstanceMapService.InstanceMaps.Keys\n\nif #instanceMaps >= maxPlayers then\n\t_LocalizationToastService:ShowMessage(\"Popup_failToGoFarm\", player.Name)\n\tself:SetMovingToFarm_False(player, player.Name)\n\treturn\nend\n----------------------------------------------------------------------\n\nlocal map = self:CreateMap(destination)\n\n-- 생성된 마스코트 펫을 제거합니다. -----------------------------------\nif isvalid(player.PlayerData.MascotPet) then\n\tplayer.PlayerData.MascotPet:Destroy()\nend\n\nif isvalid(map) then\n\t_InstanceMapService:MoveUserToInstanceMap(map.InstanceKey, player.Name)\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "MoveToOwnFarm"
        },
        {
          "Return": {
            "Type": "void",
            "DefaultValue": null,
            "SyncDirection": 0,
            "Attributes": [],
            "Name": null
          },
          "Arguments": [
            {
              "Type": "Entity",
              "DefaultValue": "nil",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            },
            {
              "Type": "string",
              "DefaultValue": "\"\"",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "destination"
            }
          ],
          "Code": "-- 각 플레이어의 농장으로 이동합니다. ---------------------------------\n\nif not isvalid(player) then\n\treturn\nend\n\nif not isvalid(player.PlayerData) then\n\treturn\nend\n\nlocal map = self:CreateMap(destination)\n\n-- 생성된 마스코트 펫을 제거합니다. -----------------------------------\nif isvalid(player.PlayerData.MascotPet) then\n\tplayer.PlayerData.MascotPet:Destroy()\nend\n\nif isvalid(map) then\n\t_InstanceMapService:MoveUserToInstanceMap(map.InstanceKey, player.Name)\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "MoveToFarmFromLobby"
        },
