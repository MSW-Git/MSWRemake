@Logic
script GachaService extends Logic

	property Entity PopupGroup = "0e991b2e-5775-43ef-bcf1-419582467183"

	property Entity Popup = "25be4344-fdb7-4119-b00b-0c8b7e365477"

	property number Duration = 0.15

	property number From = 0.5

	property number To = 1

	property boolean IsOpen = false

	property boolean IsTweenPlaying = false

	property number TweenEventId = 0

	@ExecSpace("ClientOnly")
	method void Open(number itemId, string itemRUID)
		local player = _UserService.LocalPlayer
		
		-- 가차 뽑기 ------------------------------------------
		
		if self.IsOpen then -- 이미 켜진 팝업이 있을 때 리턴시킴
			return
		end
		
		-- 기본 설정 -----
		player.PlayerMove.Type ="UI"
		self.IsOpen = true
		self.PopupGroup.Enable = true
		self.PopupGroup.Gacha:OpenByRandomItem(itemId, itemRUID)
		
		-- 애니메이션 ----
		self:StartTween(true)
		
		-- 사운드 재생 ---
		_SoundService:PlaySound("0cae201e10d5468ead5e6ecd1cd747e9", 1)
	end

	@ExecSpace("ClientOnly")
	method void DecisionOpen(number itemId, string itemType, string itemRUID, any etc1, any etc2, string destination)
		local player = _UserService.LocalPlayer
		
		-- 확정 뽑기 ---------------------------------------------------------------------
		
		if self.IsOpen then -- 이미 켜진 팝업이 있을 때 리턴시킴
			return
		end
		
		-- 기본 설정 ---------------------------------------------------------------------
		player.PlayerMove.Type ="UI"
		self.IsOpen = true
		self.PopupGroup.Enable = true
		
		-- 가챠 UI가 닫힌 후, 어떤 UI를 열지 선택합니다. ---------------------------------
		if isvalid(destination) then
			self.PopupGroup.Gacha.Destination_Type = destination	
		end
		----------------------------------------------------------------------------------
		
		self.PopupGroup.Gacha:OpenByNormalItem(itemId, itemType, itemRUID, etc1, etc2)
		
		-- 애니메이션 ----
		self:StartTween(true)
		
		-- 사운드 재생 ---
		_SoundService:PlaySound("0cae201e10d5468ead5e6ecd1cd747e9", 1)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self:StartTween(false)
	end

	@ExecSpace("ClientOnly")
	method void StartTween(boolean open)
		local canvasGroup = self.PopupGroup.CanvasGroupComponent 
		if open == true then
			canvasGroup.GroupAlpha = 0
		end
		self.IsTweenPlaying = true
		local time = 0
		
		
		local preTime = _UtilLogic.ElapsedSeconds
		
		local tween = function()
			
			local delta = _UtilLogic.ElapsedSeconds - preTime
			time = time + delta
			local timeValue = time	
			preTime = _UtilLogic.ElapsedSeconds
		
			if time >= self.Duration then
				timeValue = self.Duration
				if open == false then
					self.PopupGroup.Enable = false
					self.IsOpen = false
				end
				self.IsTweenPlaying = false
				_TimerService:ClearTimer(self.TweenEventId)
		
			end
			if open == false then
				timeValue = self.Duration - timeValue
			end
			local tweenValue = _MODTweenLogic.Ease(EaseType.SineEaseIn,self.From,
			self.To - self.From,timeValue,self.Duration)
			canvasGroup.GroupAlpha = timeValue / self.Duration
		end
		self.TweenEventId = _TimerService:SetTimerRepeat(tween,1/60)	
	end

	@ExecSpace("Server")
	method void GachaEnd(Entity player)
		-- 통신 종료 ================================
		_TransferService:Transfer("out", player.Name)
		-- ==========================================
	end

end