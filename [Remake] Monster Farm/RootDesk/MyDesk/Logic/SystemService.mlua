@Logic
script SystemService extends Logic

	method string ThousandsSeparator(number inputValue)
		local prevString = string.format("%d", math.floor(inputValue))
		local pos = string.len(prevString) % 3
		
		local cur_string = 0
			
		if pos == 0 then 
			pos = 3 
		end
		
		if inputValue < 99999999 then	
			local newString = string.sub(prevString, 1, pos)..string.gsub(string.sub(prevString, pos + 1), "(...)", ",%1")
			return newString
		else
			-- 한국인 경우 4자리 표기법 사용
			if _LocalizationService.CurrentLocaleId == "ko" then
			    local numeric = 0
			    local prefix = ""
			    
			    if inputValue >= 10^12 then
			        numeric = inputValue / (10^12)
			        prefix = "조"
			    elseif inputValue >= 10^8 then
			        numeric = inputValue / (10^8)
			        prefix = "억"
			    elseif inputValue >= 10^4 then
			        numeric = inputValue / (10^4)
			        prefix = "만"
			    else
			        return string.format("%d", inputValue)
			    end
			    
			    -- 정수부분 표기가 3자리 이상이면 소수점은 표기 안함 (108k 처럼)
			    if numeric >= 100 then
			        return tostring(math.floor(numeric))..prefix
			    -- 정수부분 표기가 2자리 이하면 소수점 표기함 (15.4k 처럼)
			    else 
			        numeric = math.ceil(numeric*10)
			        return tostring(numeric/10)..prefix
			    end
			
			    
			-- 그 외의 경우 3자리 표기법 사용
			else 
			    local numeric = 0
			    local prefix = ""
			    
			    if inputValue >= 10^9 then
			        numeric = inputValue / (10^9)
			        prefix = "G"
			    elseif inputValue >= 10^6 then
			        numeric = inputValue / (10^6)
			        prefix = "M"
			    elseif inputValue >= 10^3 then
			        numeric = inputValue / (10^3)
			        prefix = "K"
			    else
			        return string.format("%d", inputValue)
			    end
			    
			    -- 정수부분 표기가 3자리 이상이면 소수점은 표기 안함 (108k 처럼)
			    if numeric >= 100 then
			        return math.ceil(numeric)..prefix
			        
			    -- 정수부분 표기가 2자리 이하면 소수점 표기함 (15.4k 처럼)    
			    else 
			        numeric = math.ceil(numeric*10)
			        return tostring(numeric/10)..prefix
			    end
			    
			end
				
		end	
	end

	method SyncTable<number> UTCtimeToTable(string time)
		if not isvalid(time) then
			return
		end
		
		-- 받은 날짜를 환산하여 배열로 만듭니다. --------
		local year = tonumber(string.sub(time, 7, 10))
		local month = tonumber(string.sub(time, 1, 2))
		local day = tonumber(string.sub(time, 4, 5))
		local hour = tonumber(string.sub(time, 12, 13))
		local minute = tonumber(string.sub(time, 15, 16))
		local second = tonumber(string.sub(time, 18, 19))
		
		local getTime = {}
		
		table.insert(getTime, year)
		table.insert(getTime, month)
		table.insert(getTime, day)
		table.insert(getTime, hour)
		table.insert(getTime, minute)
		table.insert(getTime, second)
		
		return getTime
	end

	method number GapTimeToDays(SyncTable<number> curTime, SyncTable<number> prevTime)
		if not isvalid(curTime) or not isvalid(prevTime) then
			return 0
		end
		
		-- 저장된 날짜와 현재 시간을 빼서 일 기준으로 반환합니다. --------
		local monthData = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
		
		-- 년을 일로 환산 -------------------------------
		local curTimeYear = curTime[1] * 365
		local prevTimeYear = prevTime[1] * 365
		
		local curTimeMonth = 0 
		local prevTimeMonth = 0 
		
		-- 달을 일로 환산 -------------------------------
		for i = 1, curTime[2] -1, 1 do
			curTimeMonth = curTimeMonth + monthData[i]
		end
		
		for i = 1, prevTime[2] -1, 1 do
			prevTimeMonth = prevTimeMonth + monthData[i]
		end
		
		local resultCurTime = curTimeYear + curTimeMonth + curTime[3]
		local resultPrevTime = prevTimeYear + prevTimeMonth + prevTime[3]
		
		local dayGap = resultCurTime - resultPrevTime
		
		return dayGap
	end

	method number GapTimeToSeconds(SyncTable<number> curTime, SyncTable<number> prevTime)
		if not isvalid(curTime) or not isvalid(prevTime) then
			return 0
		end
		
		local monthData = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
		
		-- 년을 일로 환산 -------------------------------
		local curTimeYear = curTime[1] * 365
		local prevTimeYear = prevTime[1] * 365
		
		local curTimeMonth = 0 
		local prevTimeMonth = 0 
		
		-- 달을 일로 환산 -------------------------------
		for i = 1, curTime[2] -1, 1 do
			curTimeMonth = curTimeMonth + monthData[i]
		end
		
		for i = 1, prevTime[2] -1, 1 do
			prevTimeMonth = prevTimeMonth + monthData[i]
		end
		
		-- 분으로 환산 ----------------------------------
		curTimeYear = (curTimeYear * 24) * 60 
		curTimeMonth = ((curTimeMonth + curTime[3]) * 24) * 60
		
		prevTimeYear = (prevTimeYear * 24) * 60 
		prevTimeMonth = ((prevTimeMonth + prevTime[3])* 24) * 60
		
		local totalCurTime = curTimeYear + curTimeMonth + (curTime[4] * 60) + curTime[5]
		local totalPrevTime = prevTimeYear + prevTimeMonth + (prevTime[4] * 60) + prevTime[5]
		-------------------------------------------------
		
		local result = ((totalCurTime - totalPrevTime) * 60) + (curTime[6] - prevTime[6])
		return result
	end

	method string ConvertNumberToPrefixString(number inputValue)
		-- 한국인 경우 4자리 표기법 사용
		if _LocalizationService.CurrentLocaleId == "ko" then
		    local numeric = 0
		    local prefix = ""
		    
		    if inputValue >= 10^12 then
		        numeric = inputValue / (10^12)
		        prefix = "조"
		    elseif inputValue >= 10^8 then
		        numeric = inputValue / (10^8)
		        prefix = "억"
		    elseif inputValue >= 10^4 then
		        numeric = inputValue / (10^4)
		        prefix = "만"
		    else
		        return string.format("%d", inputValue)
		    end
		    
		    -- 정수부분 표기가 3자리 이상이면 소수점은 표기 안함 (108k 처럼)
		    if numeric >= 100 then
		        return tostring(math.floor(numeric))..prefix
		    -- 정수부분 표기가 2자리 이하면 소수점 표기함 (15.4k 처럼)
		    else 
		        numeric = math.ceil(numeric*10)
		        return tostring(numeric/10)..prefix
		    end
		
		    
		-- 그 외의 경우 3자리 표기법 사용
		else 
		    local numeric = 0
		    local prefix = ""
		    
		    if inputValue >= 10^9 then
		        numeric = inputValue / (10^9)
		        prefix = "G"
		    elseif inputValue >= 10^6 then
		        numeric = inputValue / (10^6)
		        prefix = "M"
		    elseif inputValue >= 10^3 then
		        numeric = inputValue / (10^3)
		        prefix = "K"
		    else
		        return string.format("%d", inputValue)
		    end
		    
		    -- 정수부분 표기가 3자리 이상이면 소수점은 표기 안함 (108k 처럼)
		    if numeric >= 100 then
		        return math.ceil(numeric)..prefix
		        
		    -- 정수부분 표기가 2자리 이하면 소수점 표기함 (15.4k 처럼)    
		    else 
		        numeric = math.ceil(numeric*10)
		        return tostring(numeric/10)..prefix
		    end
		    
		end
		
	end

	method string StringTrimmer(string inputValue, number maxString)
		-- 최대 글자 수에 해당하거나 아래라면
		if #inputValue <= maxString then
			return inputValue
		end
		
		local trimmedString = string.sub(inputValue, 1, maxString)..".."
		
		return trimmedString
	end

end