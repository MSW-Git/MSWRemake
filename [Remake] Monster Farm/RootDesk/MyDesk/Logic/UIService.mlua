@Logic
script UIService extends Logic

	@ExecSpace("Client")
	method void Open(Entity ui, Entity player, string type)
		ui.Enable = true
		player.PlayerMove.Type ="UI"
		
		-- UI를 열 때 타입에 따라 초기 설정을 다르게 줍니다.
		if type == "Kiosk" then
			ui.Kiosk:Open()
			self:CloseNotify(type, _UserService.LocalPlayer)
			
		elseif type == "Store" then
			ui.Store:Open()
			
		elseif type == "Monster" then
			ui.Monstery:Open()
			self:CloseNotify(type, _UserService.LocalPlayer)
			
		elseif type == "Inventory" then
			ui.Inventory:Open()
			self:CloseNotify(type, player)
			
		elseif type == "Fusion" then
			ui.Fusion:Open()
			
		elseif type == "Quest" then
			ui.Quest:Open()
			
			-- 퀘스트 UI가 깜빡거리고 있을 경우 효과를 끕니다. ---------------------------------
			if player.PlayerSubData.IsQuestComplete then
				_QuestService:SetQuestButtonBlink(player, false)
			end
		
		elseif type == "Tutorial" then
			_UIService:CloseNotify(type, player)
		end
		
		-- 효과음 재생 -----------------------------------------------------------
		_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
	end

	@ExecSpace("Client")
	method void Close(Entity ui, Entity player, string type)
		-- UI를 닫을 때 타입에 따라 초기 설정을 다르게 줍니다.
		if type == "Kiosk" then
			ui.Kiosk:Close()
			
		elseif type == "Fusion" then
			
		elseif type == "Monster" then
			ui.Monstery:Close()
			
		elseif type == "Inventory" then
			ui.Inventory:Close()
		
		end
		
		_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
		
		ui.Enable = false
		
		player.PlayerMove.Type ="none"
		
		if type == "Book" then
			local collectionUI = _EntityService:GetEntityByPath("/ui/CollectionGroup")
			
			if not collectionUI.Enable then
				player.PlayerMove.Type = "none"
			else
				player.PlayerMove.Type = "UI"
			end
		end
	end

	@ExecSpace("Server")
	method void CloseNotify(string type, Entity player)
		-- 노티 표시를 끕니다 -----------------
		if type == "Inventory" then
			player.PlayerSubData.Noti_Inv = 0
			
		elseif type == "Monster" then
			player.PlayerSubData.Noti_MInv = 0
			
		elseif type == "Cook" then
			player.PlayerSubData.Noti_Cook = 0
		elseif type == "Kiosk" then
			player.PlayerSubData.Noti_Inv = 0
		end
	end

end