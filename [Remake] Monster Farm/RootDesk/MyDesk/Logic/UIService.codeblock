              "Name": "type"
            },
            {
              "Type": "Entity",
              "DefaultValue": "nil",
              "SyncDirection": 0,
              "Attributes": [],
              "Name": "player"
            }
          ],
          "Code": "-- 노티 표시를 끕니다 -----------------\nif type == \"Inventory\" then\n\tplayer.PlayerSubData.Noti_Inv = 0\n\t\nelseif type == \"Monster\" then\n\tplayer.PlayerSubData.Noti_MInv = 0\n\t\nelseif type == \"Cook\" then\n\tplayer.PlayerSubData.Noti_Cook = 0\nelseif type == \"Kiosk\" then\n\tplayer.PlayerSubData.Noti_Inv = 0\nend",
          "Scope": 2,
          "ExecSpace": 5,
          "Attributes": [],
          "Name": "CloseNotify"
        }
