@Logic
script FloatingTextService extends Logic

	property Entity DummyText = "943a3afc-d9d0-4960-a856-ec4afa6ba67d"

	@ExecSpace("Client")
	method void SummonText(Entity target, number num)
		local targetPosition = target.TransformComponent.WorldPosition
		
		local clonedText = self.DummyText:Clone("clonedText")
		
		-- 생성된 플로팅 텍스트의 목적지를 설정합니다. -------------------------------------------
		clonedText.TweenLineComponent.Positions[1] = Vector2(targetPosition.x, targetPosition.y) 
		clonedText.TweenLineComponent.Positions[2] = Vector2(targetPosition.x, targetPosition.y + 0.3)
		
		-- 얻은 골드를 표시합니다. -----------------------------------------
		clonedText.TextComponent.Text = "+ "..tostring(math.floor(num)).."G"
		
		clonedText.UITransformComponent.WorldPosition = targetPosition
		clonedText.TweenLineComponent:RestartFromCurrentPosition()
	end

end