@Logic
script TransferService extends Logic

	@ExecSpace("Client")
	method void Transfer(string state)
		local player = _UserService.LocalPlayer
		
		-- 서버 함수 시작 --------------------------
		if state == "in" then
			player.PlayerData.IsTransferring = true
			
		-- 서버 함수 아웃 --------------------------
		elseif state == "out" then
			player.PlayerData.IsTransferring = false
		end
	end

end