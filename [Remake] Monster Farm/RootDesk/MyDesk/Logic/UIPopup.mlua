@Logic
script UIPopup extends Logic

	property TextComponent message = "3606e39d-32de-427e-8d23-b38af810a3b4"

	property ButtonComponent two_btnOk = "94a274e4-4111-40f1-924d-c95a3a1f14d5"

	property ButtonComponent two_btnCancel = "0f5de49b-2adc-409a-816d-15aa43df8e0d"

	property ButtonComponent one_btnOk = "2fc7bcc6-ba28-4605-8b28-3ca55fe93592"

	property Entity popupGroup = "fb7a3b06-7026-4590-8efe-bb33416dd8f9"

	property Entity popup = "aa954759-0e39-430f-85fa-80bf2e5fe31d"

	property any onOk = nil

	property any onCancel = nil

	property number duration = 0.15

	property number from = 0.5

	property number to = 1

	property boolean isOpen = false

	property boolean isTweenPlaying = false

	property number tweenEventId = 0

	property any okHandler = nil

	property any cancelHandler = nil

	property Entity One_Btns = "2fc7bcc6-ba28-4605-8b28-3ca55fe93592"

	property Entity Two_Btns = "4603f066-4d04-4c35-92d7-94e0aec627ef"

	property SpriteGUIRendererComponent item_ruid = "b3fec2b0-0746-40f1-8f32-60d817b86c35"

	property Entity item = "801ffe84-c363-4630-8cb8-dcfc7f45ce7e"

	@ExecSpace("Client")
	method void Open(string message, any onOk, any onCancel, string ruid)
		
		if self.isOpen == true then -- 이미 켜진 팝업이 있을 때 리턴시킴
			return
		end
		
		-- 이미지를 같이 팝업에 띄울 수 있게 합니다. --
		if ruid == nil then
			self.item.Enable = false
		else
			self.item.Enable = true
			self.item_ruid.ImageRUID = ruid	
		end
		-----------------------------------------------
		
		if onCancel == nil then -- 원 버튼 팝업일 경우
			self.One_Btns.Enable = true
			self.Two_Btns.Enable = false
		else -- 투 버튼 팝업일 경우
			self.One_Btns.Enable = false
			self.Two_Btns.Enable = true
		end
		
		_SoundService:PlaySound("0cae201e10d5468ead5e6ecd1cd747e9", 1)
		
		self.isOpen = true
		self.popupGroup.Enable = true
		self.message.Text = message
		self.onOk = onOk
		self.onCancel = onCancel
		
		if onCancel == nil then -- 원 버튼 팝업일 경우
			self.okHandler = self.one_btnOk.Entity:ConnectEvent(ButtonClickEvent,self.OnClickOk)
		else -- 투 버튼 팝업일 경우
			self.okHandler = self.two_btnOk.Entity:ConnectEvent(ButtonClickEvent,self.OnClickOk)
			self.cancelHandler = self.two_btnCancel.Entity:ConnectEvent(ButtonClickEvent,self.OnClickCancel)
		end
		
		
		self:StartTween(true)
	end

	method void OnClickOk()
		if self.isTweenPlaying == true then
			return
		end
		if self.onOk ~= nil then
			self.onOk()
			self.onOk = nil
		end
		self:Close()
	end

	method void OnClickCancel()
		if self.isTweenPlaying == true then
			return
		end
		if self.onCancel ~= nil and self.onCancel ~= "" then
			self.onCancel()
			self.onCancel = nil
		end
		self:Close()
	end

	method void Close()
		
		self.two_btnOk.Entity:DisconnectEvent(ButtonClickEvent,self.okHandler)
		self.two_btnCancel.Entity:DisconnectEvent(ButtonClickEvent,self.cancelHandler)
		
		self.one_btnOk.Entity:DisconnectEvent(ButtonClickEvent,self.okHandler)
		self:StartTween(false)
	end

	method void StartTween(boolean open)
		
		local transform = self.popup.UITransformComponent
		local canvasGroup = self.popupGroup.CanvasGroupComponent 
		if open == true then
			canvasGroup.GroupAlpha = 0
			transform.UIScale = Vector3(self.from,self.from,1)
		else
			transform.UIScale = Vector3(self.to,self.to,1)
		end
		self.isTweenPlaying = true
		local time = 0
		
		
		local preTime = _UtilLogic.ElapsedSeconds
		
		local tween = function()
			
			local delta = _UtilLogic.ElapsedSeconds - preTime
			time = time + delta
			local timeValue = time	
			preTime = _UtilLogic.ElapsedSeconds
		
			if time >= self.duration then
				timeValue = self.duration
				if open == false then
					self.popupGroup.Enable = false
					self.isOpen = false
				end
				self.isTweenPlaying = false
				_TimerService:ClearTimer(self.tweenEventId)
		
			end
			if open == false then
				timeValue = self.duration - timeValue
			end
			local tweenValue = _MODTweenLogic.Ease(EaseType.SineEaseIn,self.from,
				self.to - self.from,timeValue,self.duration)
			transform.UIScale = Vector3(tweenValue,tweenValue,1)
			canvasGroup.GroupAlpha = timeValue / self.duration
		end
		self.tweenEventId = _TimerService:SetTimerRepeat(tween,1/60)
		
	end

end