@Logic
script KioskService extends Logic

	@ExecSpace("Server")
	method void SellItem(Entity player, SyncTable<number> sell_inv_name, SyncTable<number> sell_inv_quantity)
		-- 인벤토리에 있는지 확인합니다. ------------------
		local isFail = false
		
		for i = 1, #sell_inv_name do
			local itemQuantity = 0
			for x = 1, #player.PlayerData.Inventory_Name do
				if sell_inv_name[i] == player.PlayerData.Inventory_Name[x] then
					itemQuantity = itemQuantity + player.PlayerData.Inventory_Quantity[x]
				end
			end
			
			-- 보유한 수량보다 판매하려는 수량이 많다면 --
			if sell_inv_quantity[i] > itemQuantity then
				isFail = true
				break
			end
		end
		
		if isFail then
			_LocalizationToastService:ShowMessage("Popup_imPossibleToSellLotItem", player.Name)
			_TransferService:Transfer("out", player.Name)
			return
		end
		
		-- 아이템 판매 시, 획득할 금액을 계산합니다. -----
		local totalSum = 0
		local dataSetName = "ItemDataSet_Base"
		
		for i = 1, #sell_inv_name do
			for x = 1, _DataService:GetRowCount(dataSetName) do
				local cost = tonumber(_DataService:GetCell(dataSetName, (sell_inv_name[i] - 20000), "cost")) * sell_inv_quantity[i]
				totalSum = totalSum + cost
				break
			end
		end
		
		-- 판매할 아이템을 플레이어의 인벤토리에서 뺍니다.
		for i = 1, #sell_inv_name do
			_PlayerService:DestroyItem(player, sell_inv_name[i], sell_inv_quantity[i])
		end
		
		-- 재화를 얻습니다. ------------------------------
		_PlayerService:GetGold(player, totalSum)
		
		_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, totalSum, nil, nil, nil, player.Name)
		
		self:ResetKiosk(player.Name)
		
		_TransferService:Transfer("out", player.Name)
	end

	@ExecSpace("Client")
	method void ResetKiosk()
		-- 가판대 UI를 초기화합니다. ----------------------
		local kioskUI = _EntityService:GetEntityByPath("/ui/KioskGroup")
		kioskUI.Kiosk:ResetKioskData()
	end

end