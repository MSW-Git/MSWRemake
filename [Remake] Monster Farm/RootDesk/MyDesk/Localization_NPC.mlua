@Component
script Localization_NPC extends Component

	property string keyType_Name = ""

	property string keyType_Chat = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self.Entity.NameTagComponent.Name = _LocalizationService.LocalTranslator:GetText(self.keyType_Name)
		self.Entity.ChatBalloonComponent.Message = _LocalizationService.LocalTranslator:GetText(self.keyType_Chat)
	end

end