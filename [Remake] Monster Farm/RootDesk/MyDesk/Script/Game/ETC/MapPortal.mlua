@Component
script MapPortal extends Component

	@Sync
	property string Destination = ""

	@Sync
	property number idx = 0

	@ExecSpace("ClientOnly")
	method void MoveToFarm(Entity user)
		-- 농장으로 이동시킵니다. -----------------------------------
		if not user.PlayerData.IsLoaded then
			user.PlayerData.IsMovingToFarm = false
			return
		end
		
		_MapService:MoveToFarmFromLobby(user, self.Destination)
	end

end