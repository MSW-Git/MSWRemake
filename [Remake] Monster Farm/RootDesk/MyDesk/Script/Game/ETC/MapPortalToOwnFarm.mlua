@Component
script MapPortalToOwnFarm extends Component

	@ExecSpace("ClientOnly")
	method void MoveToOwnFarm(Entity user)
		if not user.PlayerData.IsLoaded then
			user.PlayerData.IsMovingToFarm = false
			return
		end
		
		_MapService:MoveToOwnFarm(user, user.PlayerComponent.Nickname.._MapService.PlayerID_Seperator..user.PlayerComponent.UserId)
	end

end