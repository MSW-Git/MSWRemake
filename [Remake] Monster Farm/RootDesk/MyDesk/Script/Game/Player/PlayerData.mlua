	@ExecSpace("ClientOnly")
	method void Sync_Monster_By_Summon()
		local Summoned = 0
			
		for i = 1, #self.Minventory_Summoned do
			if self.Minventory_Summoned[i] then
				Summoned = Summoned + 1
			end
		end
			
		
		-- UI 반영 ---------------
		local summon_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_SummonedMonster")
		local summon_UI_MonsterWindow = _EntityService:GetEntityByPath("/ui/MonsterGroup/Text_Summoned_Monster")
			
		if Summoned >= self.MaxSummon then -- 최대 소환량에 도달한 상태라면
			summon_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
			summon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
		else
			summon_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)	
			summon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)	
		end
			
		summon_UI.TextComponent.Text = tostring(math.floor(Summoned)).. " / "..tostring(math.floor(self.MaxSummon))
		summon_UI_MonsterWindow.TextComponent.Text = tostring(math.floor(Summoned)).. " / "..tostring(math.floor(self.MaxSummon))
		
		
		-- Monster UI에 반영 ---
		local monsteryUI = _EntityService:GetEntityByPath("/ui/MonsterGroup")
		
		if monsteryUI.Enable then
			monsteryUI.Monstery:RefreshItem()
			monsteryUI.Monstery:RefreshShowMonsterInfo()
		end
	end

