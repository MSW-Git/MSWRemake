	@ExecSpace("ClientOnly")
	method void UnLock_Contents_ByLevel(Entity player)
		-- 플레이어의 레벨에 따라 기능을 잠금해제 합니다. ------
		local level = player.PlayerData.Level
		
		local fusion_Lock = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Buttons/Button_Fusion/Image_lock")
		local cook_Lock = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Buttons/Button_Cook/Image_lock")
		
		fusion_Lock.Enable = not (level >= 3)
		cook_Lock.Enable = not (level >= 4)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 랜덤 주기로 저장합니다. ----------------------------------------
		self.FarmEventTimer = _UtilLogic:RandomIntegerRange(240, 480) 
		
		if self.Entity.Enable then
			local function_Layer = function() self:LayerSettingInFarm(self.Entity) end
			_TimerService:SetTimerRepeat(function_Layer, 1, 1)
		end
	end

end