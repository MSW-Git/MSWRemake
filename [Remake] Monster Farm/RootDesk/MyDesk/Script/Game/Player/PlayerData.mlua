	@Sync
	property SyncTable<boolean> Hinventory_Summoned

	@Sync
	property SyncTable<boolean> MyCons

	property Entity InteractedPlayer = nil

	property number FarmEventTimer = 480

	property number FarmEventUITimer = 0

	@Sync
	property number EquippedMyConID = 1

	property boolean IsHideUI = false

	property boolean Inventory_Sync = false

	property boolean Monster_Sync = false

	property boolean Fusion_Sync = false

	property boolean Helper_Sync = false

	property boolean Monster_ID_Sync = false

	property boolean Monster_Summon_Sync = false

	@Sync
	property number CurPotLevel = 1

	@Sync
	property number CurPotGauge = 0

	@Sync
	property number CurPotTimer = 0

	@Sync
	property boolean IsCooked = false

	@Sync
	property number CurKitchenTool_Level = 1

	@Sync
	property number CurSuit_Level = 1

	@Sync
	property number CurRecipe_Level = 1

	property SliderComponent Gauge_Lab_Grade = "7ec0de10-19a0-4e45-949e-67b985bfd935"

	property SliderComponent Gauge_Lab_Personality = "ee7ded1d-f3cc-4a25-94ee-06ec4fc976d0"

	property SliderComponent Gauge_Lab_Skill = "d41129d2-5b77-40b6-8b85-06282ea1adb8"

	property boolean IsHold_Gauge_Grade = false

	property boolean IsHold_Gauge_Personality = false

	property boolean IsHold_Gauge_Skill = false

	property number Gauge_Grade_Temp = 0

	property number Gauge_Personality_Temp = 0

	property number Gauge_Skill_Temp = 0

	@Sync
	property number Interval_SaveTimer = 0

	@Sync
	property number Interval_SaveMaxTimer = 240

	property boolean IsMovingToFarm = false

	@Sync
	property boolean IsAutoPlaceOnStore = true

	property number TransferKick_Timer = 0

	property number TransferKick_TimerMAX = 10

	@ExecSpace("ServerOnly")
	method void OnMapEnter(any enteredMap)
		-- 플레이어가 위치한 장소가 Lobby 라면 --------------------------------------------------------
		if self.Entity.CurrentMapName ~= "farm" then
		
			self.Entity.PlayerMove.Enable = false
		
			if self.IsLoaded then
				_MascotService:DeleteMascotMonster(self.MascotPet)
				_MascotService:CreateMascotMonster(self.Entity)
			end
			
		-- 플레이어가 위치한 장소가 farm 이라면 -------------------------------------------------------
			
			
		
			
		elseif self.Entity.CurrentMapName == "farm" then
			
			local farm = self.Entity.CurrentMap
		
			if #farm.MapInfo.MapOwnerName <= 1 then
				
				farm.MapInfo.MapOwnerName = self.Entity.Name
				farm.MapInfo.MapOwnerEntityID = self.Entity.Id
			end
		
			
			wait(0.5)
		
			-- 해당 농장의 owner라면 -----------------------------------------------------------------
			self.Owner = (farm.MapInfo.MapOwnerName == self.Entity.Name)
			self.Entity.PlayerMove.Enable = self.Owner
		
			
			-- 농장의 주인이라면 ----------------------------------------------------------------------
			if self.Owner then
				local camera = _EntityService:GetEntityByPath("/maps/farm/Camera")
				_CameraService:SwitchCameraTo(camera.CameraComponent, self.Entity.Name)
				
				self.Entity.CameraComponent.Enable = false
				self.Entity.PlayerControllerComponent.Enable = false
		
				local balloonUI = _EntityService:GetEntityByPath("/maps/farm/UI_Balloon") 
				local balloon = balloonUI:Clone("UI_Balloon")
				balloon:AttachTo(self.Entity)
				balloon.TransformComponent.Position = Vector3(0, 1, 0)
				balloon.Enable = false
				
				self.Entity:AddComponent("OwnerEntity")
				
				self.NickName = self.Entity.PlayerComponent.Nickname
				
		
			-- 농장의 방문객이라면 --------------------------------------------------------------------
				
			else
		
				
				-- GuestUI를 갱신합니다. --
				self:RefreshGuestUI()	
				
				-- 농장의 플레이어들에게 알림 메세지를 보냅니다. --
				_LocalizationToastService:VisitFarm(self.Entity.PlayerComponent.Nickname)
				self.Entity.PlayerControllerComponent.Enable = true
			end
			
		
		end
		
	end

	@ExecSpace("ServerOnly")
	method void OnMapLeave(any leftMap)
		-- 농장을 떠날 때 토스트 메세지를 띄웁니다.
		if leftMap.Name == "farm" then
			if self.Owner then
				
			else
				_LocalizationToastService:LeaveFarm(self.Entity.PlayerComponent.Nickname)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		local player = _UserService.LocalPlayer
		
		-- 주인이 아닐 경우 -----------------------------------------------
		if player ~= self.Entity then
			return
		end
		
		if self.Owner then
		
			if self.IsHold_Gauge_Grade then
				self.Gauge_Grade_Temp = self.Gauge_Grade_Temp + delta
				self.Gauge_Lab_Grade.Value = self.Gauge_Grade_Temp * 2
				
				if self.Gauge_Lab_Grade.Value >= self.Gauge_Lab_Grade.MaxValue then
					local button_Grade = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Board/UI_Grade/Button_Upgrade")
					button_Grade.Monstery_Button_Upgrade:OnClick()
					self.Gauge_Grade_Temp = 0
					self.Gauge_Lab_Grade.Value = 0
					self.IsHold_Gauge_Grade = false
				end
			end
			
			if self.IsHold_Gauge_Personality then
		
				self.Gauge_Personality_Temp = self.Gauge_Personality_Temp + delta
				self.Gauge_Lab_Personality.Value = self.Gauge_Personality_Temp * 2
				
				if self.Gauge_Lab_Personality.Value >= self.Gauge_Lab_Personality.MaxValue then
					local button_Personality = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Board/UI_Personality/Button_Upgrade")
					button_Personality.Monstery_Button_Upgrade:OnClick()
					self.Gauge_Personality_Temp = 0
					self.Gauge_Lab_Personality.Value = 0
					self.IsHold_Gauge_Personality = false
				end
			end
			
			if self.IsHold_Gauge_Skill then
		
				self.Gauge_Skill_Temp = self.Gauge_Skill_Temp + delta
				self.Gauge_Lab_Skill.Value = self.Gauge_Skill_Temp * 2
				if self.Gauge_Lab_Skill.Value >= self.Gauge_Lab_Skill.MaxValue then
					local button_Skill = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Board/UI_Skill/Button_Upgrade")
					button_Skill.Monstery_Button_Upgrade:OnClick()
					self.Gauge_Skill_Temp = 0
					self.Gauge_Lab_Skill.Value = 0
					self.IsHold_Gauge_Skill = false
				end
			end
			
		end
		
		if self.Inventory_Sync then
			self:Sync_Inventory()
			self.Inventory_Sync = false
		end
		
		if self.Monster_Sync then
			self:Sync_Monster_By_Info()
			self.Monster_Sync = false
		end
		
		if self.Fusion_Sync then
			self:Sync_Fusion()
			self.Fusion_Sync = false
		end
		
		if self.Helper_Sync then
			self:Sync_Helepr()
			self.Helper_Sync = false
		end
		
		if self.Monster_ID_Sync then
			self:Sync_Monster_By_ID()
			self.Monster_ID_Sync = false
		end
		
		if self.Monster_Summon_Sync then
			self:Sync_Monster_By_Summon()
			self.Monster_Summon_Sync = false
		end
		
		if self.Entity.PlayerSubData.NormalQuests_Sync then
			self.Entity.PlayerSubData:Sync_NormalQuest()
			self.Entity.PlayerSubData.NormalQuests_Sync = false
		end
		
		if self.Entity.PlayerSubData.WaitingQuests_Sync then
			self.Entity.PlayerSubData:Sync_WaitingQuest()
			self.Entity.PlayerSubData.WaitingQuests_Sync = false
		end
		
		if self.Entity.PlayerSubData.DoneQuests_Sync then
			self.Entity.PlayerSubData:Sync_DoneQuest()
			self.Entity.PlayerSubData.DoneQuests_Sync = false
		end
		
		if self.Entity.PlayerSubData.DailyGiveHeartList_Sync then
			self.Entity.PlayerSubData:Sync_DailyGiveHeartList()
			self.Entity.PlayerSubData.DailyGiveHeartList_Sync = false
		end
		
		if self.Entity.PlayerSubData.AchievementComplete_Sync then
			self.Entity.PlayerSubData:Sync_Achievement()
			self.Entity.PlayerSubData.AchievementComplete_Sync = false
		end
		
		
		--- 최적화 --------------------------------------------------------
		if self.RefreshTime >= self.RefreshTimeMAX then
			self.RefreshTime = 0
		else
			self.RefreshTime = self.RefreshTime + delta
			return
		end
		
		-- ================================================================
		-- Transfer 오류가 날 시, 대기 후 추방합니다. 
		-- ================================================================
		if self.IsTransferring then
			
			local gachaUI = _EntityService:GetEntity("0e991b2e-5775-43ef-bcf1-419582467183") -- /ui/GachaGroup
			if not gachaUI.Enable then
				self.TransferKick_Timer = self.TransferKick_Timer + self.RefreshTimeMAX
			end
			if self.TransferKick_Timer >= self.TransferKick_TimerMAX then
				local yes = function() _MapService:MoveToLobbyFromFarm(player) end
				
				if self.Entity.CurrentMapName == "farm" then
					_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_failToConnect"), yes, nil, nil)
				else
					_UserService:KickUser(player.PlayerComponent.UserId, KickReason.ETC)
				end
				
				self.TransferKick_Timer = 0
			end
			
		else
			self.TransferKick_Timer = 0
		end
			
		-- 싱크 로직을 실행합니다. ----------------------------------------
		if self.Owner then
			self:AlwaysSyncData(self.IsPossibleWalk)
			_QuestService:QuestCompleteNotify() -- 퀘스트 진행도를 실시간으로 받아옵니다.
		end
		
		-- 이벤트 타이머를 실행합니다. ------------------------------------
		if self.Owner then
			if self.FarmEventTimer > 0 then
				if self.FarmEventUITimer <= 0 then
					self.FarmEventTimer = self.FarmEventTimer - self.RefreshTimeMAX
				end
			else
				self.FarmEventTimer = _UtilLogic:RandomIntegerRange(240, 480)
				self.FarmEventUITimer = 60
				_EventService:Open()
			end 
			
			local eventNotification = _EntityService:GetEntityByPath("/ui/DefaultGroup/Event_Notification")
			local eventUI = _EntityService:GetEntityByPath("/ui/FarmEventGroup")
		
			eventNotification.Visible = not self.IsPossibleWalk
			
			if self.FarmEventUITimer > 0 then
				if not eventUI.Enable then
					self.FarmEventUITimer = self.FarmEventUITimer - self.RefreshTimeMAX
				end
			else
				local eventPoint = _EntityService:GetEntityByPath("/maps/farm/Event_Point")
				
				if eventPoint.Enable then
					eventPoint.Enable = false
				end
				
				if eventNotification.Enable then
					eventNotification.Enable = false
				end
				
			end
		
		end
		
		-- 플레이어의 상태(owner,guest)에 따라 다르게 UI를 표시합니다. ----
		
		if self.Owner then
			self:ChangeStatusByRole("owner")
		else
			self:ChangeStatusByRole("guest")
		end
		
		self:CameraSetting(self.Entity.CurrentMapName)
		if self.Entity.CurrentMapName ~= "farm" then
			if self.Entity.CurrentMapName == "lobby" then
				--self:CameraZoom()
			end
			self:ShowTradeUI()
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void ChangeStatusByRole(string role)
		if self.Entity.CurrentMapName == "farm" then
			if string.len(self.Entity.CurrentMap.MapInfo.MapOwnerName) <= 1 then
				return
			end
		else
			return
		end
		
		-- 해당 플레이어 엔티티의 OrderInLayer를 갱신합니다. -------------
		
		local defaultUI = _EntityService:GetEntityByPath("/ui/DefaultGroup")
		local guestUI = _EntityService:GetEntityByPath("/ui/GuestGroup")
		local LobbyGroup = _EntityService:GetEntityByPath("/ui/LobbyGroup")
		
		local stat_UI = _EntityService:GetEntityByPath(defaultUI.Path.."/UI_Stat")
		local player_Stat_UI = _EntityService:GetEntityByPath(defaultUI.Path.."/UI_Player_Stat") 
		local buttons_UI = _EntityService:GetEntityByPath(defaultUI.Path.."/UI_Buttons")
		local left_UI = _EntityService:GetEntityByPath(defaultUI.Path.."/Left_Buttons")
		local joyStick = _EntityService:GetEntityByPath(defaultUI.Path.."/JoyStick")
		local jumpButton = _EntityService:GetEntityByPath(defaultUI.Path.."/JumpButton")
		 
		-- 해당 플레이어가 농장의 소유주라면 ------------------------------
		if role == "owner" then
			
			if isvalid(self.Entity.OwnerEntity) then
				self.Entity.OwnerEntity.Enable = false
			end
		
			if self.IsPossibleWalk then -- '투어 모드'라면
				stat_UI.Visible = false
				buttons_UI.Visible = false
				left_UI.Visible = false
				
				player_Stat_UI.UITransformComponent.AlignmentOption = AlignmentType.BottomCenter
				player_Stat_UI.UITransformComponent.anchoredPosition.x = 0
				
				if isvalid(self.Entity.OwnerEntity) then
					self.Entity.OwnerEntity.Enable = false
				end
					
				local camera = _EntityService:GetEntityByPath("/maps/farm/Camera")
				if camera.CameraComponent.Enable then
					camera.CameraComponent.Enable = false	
					self.Entity.CameraComponent.Enable = true
					
					_CameraService:SwitchCameraTo(self.Entity.CameraComponent)
				end
				
				self.Entity.StateComponent.Enable = true
				self.Entity.PlayerControllerComponent.Enable = true
				
				if Environment:IsMobilePlatform() then
					joyStick.Enable = true
					jumpButton.Enable = true
				end
				
			else -- '관리모드'라면
				stat_UI.Visible = true
				buttons_UI.Visible = true
				left_UI.Visible = true
				
				player_Stat_UI.UITransformComponent.AlignmentOption = AlignmentType.BottomLeft
				player_Stat_UI.UITransformComponent.anchoredPosition.x = 360
				
				if isvalid(self.Entity.OwnerEntity) then
					self.Entity.OwnerEntity.Enable = true
				end
		
				if self.Entity.CameraComponent.Enable then
					local camera = _EntityService:GetEntityByPath("/maps/farm/Camera")
					
					if camera.CameraComponent.Enable then
						_CameraService:SwitchCameraTo(camera.CameraComponent)
					end
					
					self.Entity.CameraComponent.Enable = false
					camera.CameraComponent.Enable = true
				end
				
				self.Entity.PlayerControllerComponent.Enable = false
				
				if Environment:IsMobilePlatform() then
					joyStick.Enable = false
					jumpButton.Enable = false
				end
			end
			
			-- UI 숨기기 모드라면
			if self.IsHideUI then
				defaultUI.Enable = false
			else
				defaultUI.Enable = true
			end
			
			guestUI.Enable = false
		
			
		-- 해당 플레이어가 농장의 방문자라면 ------------------------------
		elseif role == "guest" then
			defaultUI.Enable = false
			guestUI.Enable = true
			
			self.Entity.PlayerControllerComponent.Enable = true
		end
		
		LobbyGroup.Enable = false
	end

	@ExecSpace("Server")
	method void AlwaysSyncData(boolean isPossibleWalk)
		-- 시간 체크 로직 ------------------------------
		local curTime = DateTime.UtcNow
		local diffTimeMs = 0
		local isFail = false
		
		if not isvalid(self._T.lastRequestedTime) then
			self._T.lastRequestedTime = DateTime.UtcNow
			diffTimeMs = 1000
		else
			diffTimeMs = curTime.Elapsed - self._T.lastRequestedTime.Elapsed
		end
		
		-- 너무 빠른 속도로 재호출되었다면 -------------
		if diffTimeMs < 1000 then
			isFail = true
		end
			
		if not isFail then
			
			-- 주기적인 저장 로직 ------------------------------------------------------------------------------
			self.Interval_SaveTimer = self.Interval_SaveTimer + 1
			
			if self.Interval_SaveTimer >= self.Interval_SaveMaxTimer then
				self.Interval_SaveTimer = 0
				self.Interval_SaveMaxTimer = _UtilLogic:RandomIntegerRange(240,360)
				self.Entity.Save_System:Save(true)
			end
		
			
			-- 몬스터 조합 처리 로직 ---------------------------------------------------------------------------
			local finishedFusionFlag = false
			
				for i = 1, self.Finventory_Slot_Quantity do
					
					if self.Finventory_Slot_Unlock[i] then -- 해당 슬롯을 오픈한 상태라면 ---------------
						
						if self.Finventory_Remaining_Time[i] > 0 then -- 남은 시간이 있다면 -------------
							self.Finventory_Remaining_Time[i] = self.Finventory_Remaining_Time[i] - 1
								
							-- 최초 한 번만 Toast Message를 띄우기 위함 -----------
							if self.Finventory_Remaining_Time[i] <= 0 then
							
								_LocalizationToastService:ShowMessage("Popup_completeFusion", self.Entity.Name)
							end
							
						else -- 남은 시간이 없다면 ------------------------------------------------------
							if isvalid(self.Finventory_First_Grade[i]) and isvalid(self.Finventory_Second_Grade[i]) then
								if string.len(self.Finventory_First_Grade[i]) >= 2 and string.len(self.Finventory_Second_Grade[i]) >= 2 then
									finishedFusionFlag = true
								end
							end
						end
					end
					
				end
			
			-- 조합 완료된 몬스터가 1개 이상이면 노티를 띄움
			if finishedFusionFlag then
				self.Entity.PlayerSubData.Noti_Fusion = 1 
			else
				self.Entity.PlayerSubData.Noti_Fusion = 0
			end
			-----------------------------------------------------------------------------------------------------
			
			
			-- 요리 중이면 타이머를 실행합니다. -----------------------------------------------------------------
			local kitchenTool_Generation = self.CurKitchenTool_Level
			local kitchenTool_Buff = tonumber(_DataService:GetCell("CookDataSet_KitchenTool", kitchenTool_Generation, "ReduceTimeBuff")) * 0.01 
			local cookMaxTimer = _CookService.Origin_CookMaxTimer - math.floor(_CookService.Origin_CookMaxTimer * kitchenTool_Buff)
			
			if self.IsCooked then
				if self.CurPotTimer < cookMaxTimer then
					self.CurPotTimer = self.CurPotTimer + 1
					
					if self.CurPotTimer >= cookMaxTimer then
						_LocalizationToastService:ShowMessage("Popup_completeCook", self.Entity.Name)
					end
					
					self.Entity.PlayerSubData.Noti_Cook = 0
				else
					self.Entity.PlayerSubData.Noti_Cook = 1
				end
			else
				self.Entity.PlayerSubData.Noti_Cook = 0
			end
			
			
			-- 플레이어 엔티티 줍기 로직 ------------------------------------------------------------------------
			if not isPossibleWalk then
				if not self.IsFindItem then
					if self.ItemTimer > 0 then
						self.ItemTimer = self.ItemTimer - 1
					else
						-- 플레이어 엔티티에 반영 ---------------------------------
						self.Entity.OwnerEntity:FindSettingItem(self.Entity.Name)
						
						self.IsFindItem = true
						self.ItemTimer = _UtilLogic:RandomIntegerRange(15, 30)
						
						-- 일감 ---------------------------------------------------		
						if _QuestService:CheckHaveQuest(self.Entity, 6) then -- 아이템 발견 10회 [일감]
							self.Entity.PlayerSubData.FindItemCount = self.Entity.PlayerSubData.FindItemCount + 1
						end
						
					end
				end
			end
		end
		
		self._T.lastRequestedTime = DateTime.UtcNow
	end

	@ExecSpace("Client")
	method void OpenLvUI(number lv)
		_LevelUpService:Open(lv)
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		local player = _UserService.LocalPlayer
		if player ~= self.Entity then
			return
		end
		
		if name == "IsLoaded" then
			wait(1)
			local loadingUI = _EntityService:GetEntityByPath("/ui/LoadingGroup")
			loadingUI.Enable = not value
			return
		end
		
		if self.Entity.CurrentMapName == "farm" and self.Owner then
		
		-- 플레이어의 인벤토리 수량 갱신 ----------------------------------------------
		if name == "Heart" then
			local text_Like = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Player_Stat/Text_Like") 
			text_Like.TextComponent.Text = _SystemService:ThousandsSeparator(value)
				
		elseif name == "Inventory_Quantity" then -- Table
			self.Inventory_Sync = true
			
		elseif name == "Inventory_Type" then
			self.Inventory_Sync = true
		
		elseif name == "Inventory_Name" then
			self.Inventory_Sync = true
				
		elseif name == "Hinventory_Level" then
			self.Helper_Sync = true
				
		elseif name == "Hinventory_Summoned" then
			self.Helper_Sync = true
				
			-- MyCon의 이미지를 갱신합니다. --
		elseif name == "EquippedMyConID" then 
			local playerLogo = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Player_Stat/UI_Player_Logo/Image_Icon")
			playerLogo.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("MyConDataSet", value, "ruid")
			
		elseif name == "Minventory_Id" then
			self.Monster_ID_Sync = true
				
		elseif name == "Minventory_Grade" then
			self.Monster_Sync = true
				
		elseif name == "Minventory_Exp" then
			self.Monster_Sync = true
			
		elseif name == "Minventory_Mexp" then
			self.Monster_Sync = true
			
		elseif name == "Minventory_Level" then
			self.Monster_Sync = true
				
		elseif name == "MInventory_MascotPet_Id" then
			self.Monster_Sync = true
				
		elseif name == "Minventory_Personality" then
			self.Monster_Sync = true
				
		elseif name == "Minventory_Skill_Id" then
			self.Monster_Sync = true
				
		elseif name == "IsAutoPlaceOnStore" then
		
			local auto_Place_Button = _EntityService:GetEntityByPath("/ui/StoreGroup/Image_Board/Image_Board_Buy/UI_ItemInfo/UI_Bottom_Bar/Auto_Place_Button")
			
			if value then
				auto_Place_Button.SpriteGUIRendererComponent.Color = Color(135/255, 131/255, 78/255, 1)
				auto_Place_Button.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_autoPlaceOn")
					
				auto_Place_Button.TextComponent.FontColor.a = 1
			else
				auto_Place_Button.SpriteGUIRendererComponent.Color = Color(70/255, 70/255, 70/255, 1)
				auto_Place_Button.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_autoPlaceOff")
				auto_Place_Button.TextComponent.FontColor.a = 0.3
			end
		
				
		elseif name == "CurPotGauge" then
		
			local cookGroup = _EntityService:GetEntityByPath("/ui/CookGroup")
		
			if cookGroup.Enable then
				_CookService:RefreshPotUI(false)		
			end 
				
		elseif name == "IsCooked" then
			local cookGroup = _EntityService:GetEntityByPath("/ui/CookGroup")
		
			if cookGroup.Enable then
				_CookService:RefreshButtons()
				_CookService:RefreshItems()
			end 
				
		elseif name == "CurPotTimer" then	
			local cookGroup = _EntityService:GetEntityByPath("/ui/CookGroup")
				
			if cookGroup.Enable then
				_CookService:RefreshTimer(value)
			end
				
		elseif name == "CurPotLevel" or name == "CurKitchenTool_Level" or name == "CurSuit_Level" or name == "CurRecipe_Level" then
			local upgradeGroup = _EntityService:GetEntityByPath("/ui/CookGroup/Upgrade_Background")
		
			if upgradeGroup.Enable then
				_CookService:RefreshTools()
				_CookService:Refresh_UpgradeUI()	
			end
					
		-- 플레이어가 소환한 몬스터 수 갱신 -------------------------------------------
		elseif name == "MaxSummon" then
				
			-- UI 반영 ---------------
			local summon_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_SummonedMonster")
			local summon_UI_MonsterWindow = _EntityService:GetEntityByPath("/ui/MonsterGroup/Text_Summoned_Monster")
			
			local playerSummoned = _PlayerService:Check_Monster_Summoned(player)
			if playerSummoned >= value then -- 최대 소환량에 도달한 상태라면
				summon_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
				summon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
			else
				summon_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)	
				summon_UI_MonsterWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)	
			end
			
			summon_UI.TextComponent.Text = tostring(math.floor(playerSummoned)).. " / "..tostring(math.floor(self.MaxSummon))
			summon_UI_MonsterWindow.TextComponent.Text = tostring(math.floor(playerSummoned)).. " / "..tostring(math.floor(self.MaxSummon))
		
				
		elseif name == "Minventory_Summoned" then
			self.Monster_Summon_Sync = true
			
		-- 플레이어의 레벨 반영 -------------------------------------------------------
		elseif name == "Level" then	
			local DefaultUI_Level = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Player_Stat/UI_Player_Logo/Text_Level")
			DefaultUI_Level.TextComponent.Text = tostring(math.floor(value))
		
			-- 닉네임 반영 --
			local nickName = _SystemService:StringTrimmer(self.Entity.PlayerComponent.Nickname, 24)
			local nickName_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Player_Stat/Text_PlayerName")
			nickName_UI.TextComponent.Text = nickName
		
			self:UnLock_Contents_ByLevel(player)
			
		-- 플레이어의 재화 반영 -------------------------------------------------------
		elseif name == "Gold" then
		
		   	local newString = _SystemService:ThousandsSeparator(value)
		
			local DefaultUI_Gold = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Gold")
			DefaultUI_Gold.TextComponent.Text = newString
			
			local StoreUI = _EntityService:GetEntityByPath("/ui/StoreGroup")
			if StoreUI.Enable then
				StoreUI.Store:RefreshInfo()
			end
			
			local StoreGroup_Gold = _EntityService:GetEntityByPath("/ui/StoreGroup/Image_Board/UI_StateBar/Text_Coin")
			StoreGroup_Gold.TextComponent.Text = newString
			
			local KioskGroup_Gold = _EntityService:GetEntityByPath("/ui/KioskGroup/Image_Board/UI_StateBar/Text_Coin")
			KioskGroup_Gold.TextComponent.Text = newString
			
			local FusionGroup_Gold = _EntityService:GetEntityByPath("/ui/MonsterFusionGroup/UI_set_fusion/UI_StateBar/Text_Coin")
			FusionGroup_Gold.TextComponent.Text = newString
			
			local UI_Gold_Effect_White = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Gold/Effect_white")
			UI_Gold_Effect_White.EffectUI:whiteEffect()
				
			local cookUpgrade_Gold = _EntityService:GetEntityByPath("/ui/CookGroup/Upgrade_Background/Image_Background/Upgrade_Title/UI_StateBar/Text_Coin")
			cookUpgrade_Gold.TextComponent.Text = newString
				
			local MonsterUI = _EntityService:GetEntityByPath("/ui/MonsterGroup")
			local LabUI = _EntityService:GetEntityByPath(MonsterUI.Path.."/UI_Monster_Left/UI_Lab")
			
			if LabUI.Enable then
				MonsterUI.Monstery:RefreshLaboratory_Info()
			end
				
		-- 플레이어의 루비 반영 -------------------------------------------------------
		elseif name == "Ruby" then
			
		   	local newString = _SystemService:ThousandsSeparator(value)
		
			local DefaultUI_Ruby = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Ruby")
			DefaultUI_Ruby.TextComponent.Text = newString
				
			local UI_Ruby_Effect_White = _EntityService:GetEntityByPath(DefaultUI_Ruby.Path.."/Effect_white")
			UI_Ruby_Effect_White.EffectUI:whiteEffect()
				
			local MonsterUI = _EntityService:GetEntityByPath("/ui/MonsterGroup")
			local LabUI = _EntityService:GetEntityByPath(MonsterUI.Path.."/UI_Monster_Left/UI_Lab")
			
			local Store_Ruby = _EntityService:GetEntityByPath("/ui/StoreGroup/Image_Board/UI_StateBar_Ruby/Text_Ruby")
			Store_Ruby.TextComponent.Text = newString
				
			if LabUI.Enable then
				MonsterUI.Monstery:RefreshLaboratory_Info()
			end
				
		elseif name == "Berry" then
			
		   	local newString = _SystemService:ThousandsSeparator(value)
		
			local DefaultUI_Berry = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Berry")
			DefaultUI_Berry.TextComponent.Text = newString
				
			local UI_Berry_Effect_White = _EntityService:GetEntityByPath(DefaultUI_Berry.Path.."/Effect_white")
			UI_Berry_Effect_White.EffectUI:whiteEffect()
		
			local MonsterUI = _EntityService:GetEntityByPath("/ui/MonsterGroup")
			local LabUI = _EntityService:GetEntityByPath(MonsterUI.Path.."/UI_Monster_Left/UI_Lab")
			
			if LabUI.Enable then
				MonsterUI.Monstery:RefreshLaboratory_Info()
			end
				
		-- 플레이어의 인벤토리 최대 보유량 반영 ---------------------------------------
		elseif name == "MaxCapacity" then
			
			local prev_capacity = _EntityService:GetEntityByPath("/ui/KioskGroup/Upgrade_Background/UI_Upgrade/Center_Bar/Text_Prev_Upgrade")
			local next_capacity = _EntityService:GetEntityByPath("/ui/KioskGroup/Upgrade_Background/UI_Upgrade/Center_Bar/Text_Next_Upgrade") 
			
			prev_capacity.TextComponent.Text = tostring(math.floor(value))
			next_capacity.TextComponent.Text = tostring(math.floor(value + 8))
		
		
			-- UI 반영 ---------------
			local capacity_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Inv_Capacity") 
			local capacity_UI_InvWindow = _EntityService:GetEntityByPath("/ui/KioskGroup/UI_StateBar_Capacity")
			
			local playerCapacity = _PlayerService:Check_Inventory(self.Entity)
			if playerCapacity >= self.MaxCapacity then -- 최대 수용랑에 도달한 상태라면
				capacity_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
				capacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
			else
				capacity_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)	
				capacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)
			end
		
			capacity_UI.TextComponent.Text = tostring(math.floor(playerCapacity)).." / "..tostring(math.floor(self.MaxCapacity))
			capacity_UI_InvWindow.TextComponent.Text = tostring(math.floor(playerCapacity)).." / "..tostring(math.floor(self.MaxCapacity))
			
		
				
		-- 플레이어의 '조합하기 기능' 해제 반영 ---------------------------------------
		elseif name == "Finventory_Unlock" then
			self.Fusion_Sync = true
			
		elseif name == "Finventory_Slot_Unlock" then
			self.Fusion_Sync = true
				
				
		elseif name == "Finventory_Remaining_Time" then
			self.Fusion_Sync = true
				
		elseif name == "Finventory_Reward_Monster_Id" then
			self.Fusion_Sync = true
				
		-- 플레이어의 최대 아이템 보유량이 변경되었다면 -------------------------------
		elseif name == "MaxCapacity_Upgrade_Level" then
			local kioskUI = _EntityService:GetEntityByPath("/ui/KioskGroup")
			kioskUI.Kiosk:RefreshUpgradeUI(player)
			local Capacity = 0
			
			for i = 1, #self.Inventory_Quantity do
				Capacity = Capacity + self.Inventory_Quantity[i]
			end
			
			-- UI 반영 ---------------
			local capacity_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Inv_Capacity") 
			local capacity_UI_InvWindow = _EntityService:GetEntityByPath("/ui/KioskGroup/UI_StateBar_Capacity")
		
			capacity_UI.TextComponent.Text = tostring(math.floor(Capacity)).." / "..tostring(math.floor(self.MaxCapacity))
			capacity_UI_InvWindow.TextComponent.Text = tostring(math.floor(Capacity)).." / "..tostring(math.floor(self.MaxCapacity))
				
				
		-- 첫 농장 진입시 닉네임을 UI에 반영합니다. ----------------------------------
		elseif name == "NickName" then
			local nickName = _SystemService:StringTrimmer(value, 24)
			local nickName_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Player_Stat/Text_PlayerName")
			nickName_UI.TextComponent.Text = nickName
		end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void LayerSettingInFarm(Entity player)
		-- Entity의 Layer를 갱신합니다. ---------------------------------------------------------------------------
		self.Entity.AvatarRendererComponent.OrderInLayer = -(self.Entity.TransformComponent.Position.y * 200) + 800
	end

	@ExecSpace("Client")
	method void RefreshGuestUI()
		-- GuestUI를 농장 주인의 정보에 맞게 갱신합니다. ---------------------------------------------------------------
		local guestUI = _EntityService:GetEntityByPath("/ui/GuestGroup")
		local textOwnerName = _EntityService:GetEntityByPath(guestUI.Path.."/UI_Player_Stat/Text_PlayerName")
		local textOwnerLike = _EntityService:GetEntityByPath(guestUI.Path.."/UI_Player_Stat/Text_Like")
		local textOwnerLevel = _EntityService:GetEntityByPath(guestUI.Path.."/UI_Player_Stat/UI_Player_Logo/Text_Level")
		local playerLogo = _EntityService:GetEntityByPath(guestUI.Path.."/UI_Player_Stat/UI_Player_Logo/Image_Icon")
		
		local owner = _EntityService:GetEntity(self.Entity.CurrentMap.MapInfo.MapOwnerEntityID)
		
		local nickName = _SystemService:StringTrimmer(owner.PlayerComponent.Nickname, 24)
		textOwnerName.TextComponent.Text = nickName
		textOwnerLike.TextComponent.Text = _SystemService:ThousandsSeparator(owner.PlayerData.Heart)
		textOwnerLevel.TextComponent.Text = tostring(math.floor(owner.PlayerData.Level))
		
		playerLogo.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("MyConDataSet", owner.PlayerData.EquippedMyConID, "ruid")
		----------------------------------------------------------------------------------------------------------------
	end

	@ExecSpace("ClientOnly")
	method void ShowTradeUI()
		-- 가장 가까운 플레이어와 거래할 수 있게 UI를 띄웁니다. ---------------------
		
		local players = _UserService.UserEntities.Values
		
		local playerPos = self.Entity.TransformComponent.Position
		
		---@type Entity
		local nearestPlayer = nil
		
		-- 맵에 혼자 있다면 Return합니다. -------------------------------------------
		if #players == 1 then
			local tradeUI = _EntityService:GetEntityByPath("/ui/LobbyGroup/UI_Trade")
			tradeUI.Enable = false
			return
			
		-- 맵에 둘 이상 있다면 가장 가까운 플레이어를 찾습니다. ---------------------
		elseif #players >= 2 then
			if players[1] == self.Entity then
				nearestPlayer = players[2]
			else
				nearestPlayer = players[1]
			end
		end
		
		
		local nearestPlayerGap = math.abs(playerPos.x - nearestPlayer.TransformComponent.Position.x) + math.abs(playerPos.y - nearestPlayer.TransformComponent.Position.y)
		
		-- 가장 가까운 플레이어를 찾습니다. -----------------------------------------
		for i = 1, #players do
			
			if players[i] == self.Entity or not isvalid(players[i]) then
				-- 자기 자신일 경우를 제외시킵니다. 
			else
				local xGap = math.abs(playerPos.x - players[i].TransformComponent.Position.x)
				local yGap = math.abs(playerPos.y - players[i].TransformComponent.Position.y)
				
				if nearestPlayerGap > xGap + yGap then
					nearestPlayerGap = xGap + yGap
					nearestPlayer = players[i]
				end
			end
		end
		
		
		local range = 1.5
		local tradeUI = _EntityService:GetEntityByPath("/ui/LobbyGroup/UI_Trade")
		
		-- 최소 범위 내에 있을 때만 상호작용이 가능하게 합니다. -----------------------------
		if nearestPlayerGap >= range then
			tradeUI.Enable = false
			self.InteractedPlayer = nil
		else
			tradeUI.Enable = true
			local nickName = _SystemService:StringTrimmer(nearestPlayer.PlayerComponent.Nickname, 24)
			local nameText = _EntityService:GetEntityByPath(tradeUI.Path.."/Text_Name")
			nameText.TextComponent.Text = nickName
			
			-- 해당 플레이어가 상호작용 중이라면 '교환' 버튼을 비활성화합니다. --------------
			
			local button_Trade = _EntityService:GetEntityByPath("/ui/LobbyGroup/UI_Trade/UI_Trade/Button_Trade")
		
			button_Trade.ButtonComponent.Enable = not isvalid(nearestPlayer.PlayerTradeComponent.TraderID)
			
			-- 가장 가까운 엔티티와 상호작용 행동을 할 수 있게 설정합니다. --
			self.InteractedPlayer = nearestPlayer
		end
	end

	@ExecSpace("Client")
	method void CameraZoom()
		self.Entity.CameraComponent:SetZoomTo(65, 0)
	end

	@ExecSpace("Client")
	method void CameraSetting(string mapName)
		if mapName == "farm" then
				
			-- 카메라 설정 ----------------------------------------------
			self.Entity.CameraComponent.ConfineCameraArea = true
			self.Entity.CameraComponent.LeftBottom = Vector2(-10.3, -3.5)
			self.Entity.CameraComponent.RightTop = Vector2(9.8, 8.3)
			-------------------------------------------------------------
			
			-- 이동속도 --------------------------------
			self.Entity.MovementComponent.InputSpeed = 3
			
		
		elseif mapName == "lobby" then
			-- 카메라 설정 ----------------------------------------------
			self.Entity.CameraComponent.ConfineCameraArea = true
			self.Entity.CameraComponent.LeftBottom = Vector2(-28.9, -9.8)
			self.Entity.CameraComponent.RightTop = Vector2(-3.2, 7.3)
			-------------------------------------------------------------
			
			-- 이동속도 --------------------------------
			self.Entity.MovementComponent.InputSpeed = 3
		
			
		else
			-- 카메라 설정 ----------------------------------------------
			self.Entity.CameraComponent.ConfineCameraArea = false
			------------------------------------------------------------
		
			-- 이동속도 --------------------------------
			self.Entity.MovementComponent.InputSpeed = 1
		end
	end

	@ExecSpace("ClientOnly")
	method void Sync_Inventory()
		-- Inventory UI에 반영 ---
		local playerCapacity = _PlayerService:Check_Inventory(self.Entity)
		
		-- UI 반영 ---------------
		local capacity_UI = _EntityService:GetEntityByPath("/ui/DefaultGroup/UI_Stat/UI_Inv_Capacity") 
		local capacity_UI_InvWindow = _EntityService:GetEntityByPath("/ui/KioskGroup/UI_StateBar_Capacity")
			
		if playerCapacity >= self.MaxCapacity then -- 최대 수용랑에 도달한 상태라면
			capacity_UI.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
			capacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(196/255, 42/255, 42/255, 0.3)
		else
			capacity_UI.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)	
			capacity_UI_InvWindow.SpriteGUIRendererComponent.Color = Color(0/255, 0/255, 0/255, 0.3)
		end
		
		capacity_UI.TextComponent.Text = tostring(math.floor(playerCapacity)).." / "..tostring(math.floor(self.MaxCapacity))
		capacity_UI_InvWindow.TextComponent.Text = tostring(math.floor(playerCapacity)).." / "..tostring(math.floor(self.MaxCapacity))
			
		
		-- 상점 refresh --
		local StoreUI = _EntityService:GetEntityByPath("/ui/StoreGroup")
		if StoreUI.Enable then
			StoreUI.Store:RefreshInfo()
		end
		
		-- 요리 refresh --
		local cookUI = _EntityService:GetEntityByPath("/ui/CookGroup")
		if cookUI.Enable then
			_CookService:RefreshItems()
		end
	end

