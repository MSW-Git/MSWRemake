@Component
script Save_System extends Component

	@ExecSpace("ServerOnly")
	method void OnMapEnter(any enteredMap)
		self:Load()
	end

	@ExecSpace("ServerOnly")
	method void OnEndPlay()
		self:Save(false)
	end

	@ExecSpace("ServerOnly")
	method void Farm_SaveForOwner(boolean isIntervalSave)
		-------------------------------------------------------------------------------------------------
		--log("[Owner - "..self.Entity.PlayerComponent.Nickname.."] Saving..")
		-------------------------------------------------------------------------------------------------
		
		local player = self.Entity
		local playerName = player.OwnerId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		
		-- 데이터를 저장합니다. --------------------------------------------------------------------------
		playerData:SetAndWait("time", _UtilLogic:GetUTCNow())
		
		----------------------------------------------
		-- 기본 데이터를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Data(player, isIntervalSave)
		
		
		----------------------------------------------
		-- 인벤토리를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Inventory(player)
		
		
		----------------------------------------------
		-- 몬스터를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Monster(player)
		
		
		----------------------------------------------
		-- 조합 정보를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Fusion(player)
		
		
		----------------------------------------------
		-- 조합 컬렉션을 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Collection_And_Book(player)
		
		
		----------------------------------------------
		-- 퀘스트를 저장합니다. 
		----------------------------------------------
		_SaveLoadService:Save_Quest(player)
		
		
		----------------------------------------------
		-- 도우미를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Helper(player)
		
		
		----------------------------------------------
		-- 업적을 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Achievememt(player)
		
		
		----------------------------------------------
		-- 저장된 데이터가 있는 상태로 바꿉니다.		
		----------------------------------------------
		playerData:SetAndWait("saveFile_Owner", "O")
		
		
		-------------------------------------------------------------------------------------------------
		--log("[Owner - "..self.Entity.PlayerComponent.Nickname.."] Saved.")
		-------------------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void Farm_SaveForGuest(boolean isIntervalSave)
		-------------------------------------------------------------------------------------------------
		--log("[Guest - "..self.Entity.PlayerComponent.Nickname.."] Saving..")
		-------------------------------------------------------------------------------------------------
		
		local player = self.Entity
		local playerName = player.OwnerId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		-- 데이터를 저장합니다. --------------------------------------------------------------------------
		
		----------------------------------------------
		-- 기본 데이터를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Data(player, isIntervalSave)
		
		------------------------------------------------
		-- 오늘 준 인기도 리스트를 저장합니다.
		------------------------------------------------
		_SaveLoadService:Save_DailyGiveHeartList(player)
		
		------------------------------------------------
		-- 저장된 데이터가 있는 상태로 바꿉니다.
		------------------------------------------------
		playerData:SetAndWait("saveFile_Guest", "O")
		
		-------------------------------------------------------------------------------------------------
		--log("[Guest - "..self.Entity.PlayerComponent.Nickname.."] Saved.")
		-------------------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void Farm_LoadForOwner(boolean owner)
		local player = self.Entity
		local playerName = player.OwnerId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		if player.PlayerData.IsLoaded then
			return
		end
		-------------------------------------------------------------------------------------------------
		--log("[Owner - "..self.Entity.PlayerComponent.Nickname.."] Try Loading..")
		-------------------------------------------------------------------------------------------------
		
		-- 데이터를 불러옵니다. -------------------------------------------------------------------------
		   
		local error, time = playerData:GetAndWait("time")
		local prevTime = _SystemService:UTCtimeToTable(time)
		
		local curTime = 0
		
		if isvalid(prevTime) then
			curTime = _SystemService:UTCtimeToTable(_UtilLogic:GetUTCNow())				
		end
		
		
		----------------------------------------------
		-- 기본 데이터를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Data(player, _SystemService:GapTimeToSeconds(curTime, prevTime), owner)
			
			
		----------------------------------------------
		-- 인벤토리를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Inventory(player)
			
			
		----------------------------------------------
		-- 퀘스트를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Quest(player)
			
			
		----------------------------------------------
		-- 조합 정보를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Fusion(player, _SystemService:GapTimeToSeconds(curTime, prevTime))	
			
		
		----------------------------------------------
		-- 조합 컬렉션을 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Collection_And_Book(player)
		
		
		----------------------------------------------
		-- 몬스터를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Monster(player)
				
			
		----------------------------------------------
		-- 도우미를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Helper(player)
			
		
		----------------------------------------------
		-- 업적을 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Achievement(player)
		
		
		player.PlayerData.IsLoaded = true
		
		--log("[Owner - "..self.Entity.PlayerComponent.Nickname.."] Loaded.")
	end

	@ExecSpace("ServerOnly")
	method void Farm_LoadForGuest(boolean owner)
		local player = self.Entity
		local playerName = player.OwnerId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		if player.PlayerData.IsLoaded then
			return
		end
		
		-------------------------------------------------------------------------------------------------
		--log("[Guest - "..self.Entity.PlayerComponent.Nickname.."] Try Loading..")
		-------------------------------------------------------------------------------------------------
		
		----------------------------------------------
		-- 기본 데이터를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Data(player, 0, owner)
		
		-- 데이터를 불러옵니다. ----------------------
		
		local error, time = playerData:GetAndWait("time")
		local prevTime = _SystemService:UTCtimeToTable(time)
		local curTime = _SystemService:UTCtimeToTable(_UtilLogic:GetUTCNow())
			
		----------------------------------------------
		--DailyGiveHeartList를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_DailyGiveHeartList(player, _SystemService:GapTimeToDays(curTime, prevTime))
		
		----------------------------------------------
		-- 몬스터를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Monster(player)
		
		player.PlayerData.IsLoaded = true
		
		-------------------------------------------------------------------------------------------------
		--log("[Guest - "..self.Entity.PlayerComponent.Nickname.."] Loaded.")
		-------------------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void Lobby_Load()
		local player = self.Entity
		local playerName = player.OwnerId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		if player.PlayerData.IsLoaded then
			return
		end
		
		-------------------------------------------------------------------------------------------------
		--log("[Lobby - "..self.Entity.PlayerComponent.Nickname.."] Try Loading..")
		-------------------------------------------------------------------------------------------------
		
		-- 데이터를 불러옵니다. -------------------------------------------------------------------------
		 
		local error, time = playerData:GetAndWait("time")
		local prevTime = _SystemService:UTCtimeToTable(time)
		
		local curTime = 0
		
		if isvalid(prevTime) then
			curTime = _SystemService:UTCtimeToTable(_UtilLogic:GetUTCNow())				
		end
		
		
		----------------------------------------------
		-- 기본 데이터를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Data(player, _SystemService:GapTimeToSeconds(curTime, prevTime), nil)
			
			
		----------------------------------------------
		-- 인벤토리를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Inventory(player)
			
			
		----------------------------------------------
		-- 몬스터를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_Monster(player)
		
		 
		----------------------------------------------
		-- DailyGiveHeartList를 불러옵니다.
		----------------------------------------------
		_SaveLoadService:Load_DailyGiveHeartList(player, _SystemService:GapTimeToDays(curTime, prevTime))
			
		
		----------------------------------------------------------------------------------------------
		--log("[Lobby] - "..self.Entity.PlayerComponent.Nickname.."] Loaded.")
		----------------------------------------------------------------------------------------------
		
		player.PlayerData.IsLoaded = true
	end

	@ExecSpace("ServerOnly")
	method void Lobby_Save(boolean isIntervalSave)
		-------------------------------------------------------------------------------------------------
		--log("[Lobby - "..self.Entity.PlayerComponent.Nickname.."] Saving..")
		-------------------------------------------------------------------------------------------------
		
		local player = self.Entity
		local playerName = player.OwnerId
		local playerData = _DataStorageService:GetUserDataStorage(playerName)
		
		-- 데이터를 저장합니다. -------------------------------------------------------------------------
		
		----------------------------------------------
		-- 기본 데이터를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Data(player, isIntervalSave)
		
		
		----------------------------------------------
		-- 인벤토리를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Inventory(player)
		
		
		----------------------------------------------
		-- 몬스터를 저장합니다.
		----------------------------------------------
		_SaveLoadService:Save_Monster(player)
		
		
		----------------------------------------------
		-- 저장된 데이터가 있는 상태로 바꿉니다.		
		----------------------------------------------
		
		local error, time = playerData:GetAndWait("time")
		
		if not isvalid(time) then
			playerData:SetAndWait("time", _UtilLogic:GetUTCNow())
		end
		
		------------------------------------------------
		-- 오늘 준 인기도 리스트를 저장합니다.
		------------------------------------------------
		_SaveLoadService:Save_DailyGiveHeartList(player)
		
		
		-------------------------------------------------------------------------------------------------
		--log("[Lobby - "..self.Entity.PlayerComponent.Nickname.."] Saved.")
		-------------------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void Save(boolean isIntervalSave)
		-- 정상적으로 불러오지 못한 상황일 때는 저장하지 않습니다. ----------------
		if not self.Entity.PlayerData.IsLoaded then
			log('Save Error : IsLoaded')
			return
		end
		
		if self.Entity.CurrentMapName == "farm" then
		
			-- 농장의 주인이라면 ------------------------------------------------------
			if self.Entity.PlayerData.Owner then
				self:Farm_SaveForOwner(isIntervalSave)
				
			-- 농장의 방문객이라면 ----------------------------------------------------
			elseif not self.Entity.PlayerData.Owner then
				self:Farm_SaveForGuest(isIntervalSave)
			end
			
		else
			self:Lobby_Save(isIntervalSave)
		end
	end

	@ExecSpace("ServerOnly")
	method void Load()
		wait(6)
		
		if self.Entity.CurrentMapName == "farm" then
			local ownerType = self.Entity.PlayerData.Owner
			-- 농장의 주인이라면 ------------------------------------------------------
		
			if ownerType then
		
				self:Farm_LoadForOwner(true)
				
			-- 농장의 방문객이라면 ----------------------------------------------------
			elseif not ownerType then
				self:Farm_LoadForGuest(false)
			end
			
		else
			self:Lobby_Load()
		end
	end

end