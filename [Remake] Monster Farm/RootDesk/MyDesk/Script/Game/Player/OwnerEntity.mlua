@Component
script OwnerEntity extends Component

	property number Refreshtime = 0

	property number RefreshtimeMax = 1

	property boolean IsDragged = false

	property boolean IsBackMoving = false

	property boolean IsRangeOut = false

	property number Speed = 0

	property number MoveTimer = 0

	property number HoldTimer = 0

	property string FindEmotion = ""

	property MapInfo MapInfo = "cf0fe12f-db97-4a6d-b975-ebdff5e64181"

	property number LayerRefreshTime = 0

	property number TargetX_Pos = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		local player = _UserService.LocalPlayer
		
		
		if player.Name ~= self.MapInfo.MapOwnerName then
			return
		end
		
		
		self:EntityMoveIdle(self.Speed, delta) -- 엔티티를 랜덤으로 이동하게 설정
		
		
		if self.IsDragged then
			self:EntityDragSetting(player)
			self.IsRangeOut = self:EntityRangeOutCheck(player) -- 엔티티가 설정 범위를 나갔는지 확인
			self:EntityMoveRestrict(player) -- 엔티티가 농장 밖으로 이동할 수 없게 설정
		end
		
		
		-- 최적화 -------------------------------------
		if self.Refreshtime >= self.RefreshtimeMax then
			self.Refreshtime = 0
		else
			self.Refreshtime = self.Refreshtime + delta
			return
		end
		
		self:EntityLayerSetting()
		
		self:EntityMoveRandSelectSetting(player, self.RefreshtimeMax)
		
		-- 엔티티 이동 관련 로직 -------------
		self.IsRangeOut = self:EntityRangeOutCheck(player) -- 엔티티가 설정 범위를 나갔는지 확인
		self:EntityMoveRestrict(player) -- 엔티티가 농장 밖으로 이동할 수 없게 설정
			
		-- 엔티티 감정 표현 -------------------
		self:FindChangeEmotion(self.FindEmotion)
			
		-- 엔티티 아이템 회수 관련 로직 ------- 
		self:GetUiBalloonSet(player)
		
		-- 엔티티 동시 드래그 방지 ------------
		if player.PlayerMove.ClickedEntity ~= self.Entity then
			self.HoldTimer = 0
		end
	end

	@ExecSpace("ClientOnly")
	method void EntityMoveClient(Vector2 targetPos)
		self.Entity.PlayerComponent:SetPosition(Vector3(targetPos.x, targetPos.y, 0))
	end

	@ExecSpace("Server")
	method void EntityMoveServer(Vector2 targetPos)
		self.Entity.PlayerComponent:SetPosition(Vector3(targetPos.x, targetPos.y, 0))
	end

	@ExecSpace("Server")
	method void EntityMoveIdle(number speed, number delta)
		if math.abs(speed) > 0 then -- Walk 상태일 경우
			self.Entity.PlayerComponent:SetPosition(Vector3(self.Entity.TransformComponent.Position.x + (speed/10 * delta),self.Entity.TransformComponent.Position.y, 0))
		
			self.Entity.StateComponent:ChangeState("MOVE")
			self.Entity.StateComponent.Enable = false
			
			if speed > 0 then -- 오른쪽을 바라봅니다.
				self.Entity.PlayerControllerComponent.LookDirectionX = 1
				
			elseif speed < 0 then -- 왼쪽을 바라봅니다.
				self.Entity.PlayerControllerComponent.LookDirectionX = -1
			end
			
		else -- Idle 상태일 경우
			self.Entity.StateComponent:ChangeState("IDLE")
			self.Entity.StateComponent.Enable = true
		end
		
	end

	@ExecSpace("ClientOnly")
	method void EntityMoveRestrict(Entity player)
		-- 몬스터가 농장 밖으로 벗어났을 경우 이동 제한을 겁니다.
		if math.abs(self.Speed) > 0 and not self.IsBackMoving and self.IsRangeOut then
			if self.Entity.TransformComponent.Position.x >= _PlayerService.Range_X.y then -- 우측으로 농장 벗어남
				self.Speed = -math.abs(self.Speed) -- 좌측으로 이동합니다.
				
			elseif self.Entity.TransformComponent.Position.x <= _PlayerService.Range_X.x then -- 좌측으로 농장 벗어남
				self.Speed = math.abs(self.Speed) -- 우측으로 이동합니다.
			end
			
			self.MoveTimer = 0
			self.IsBackMoving = true
		end
	end

	@ExecSpace("ClientOnly")
	method void EntityMoveRandSelect()
		self.IsBackMoving = false
		
		-- 일반 이동일 경우 -------------
		local randNum = math.random(1,3)
		if randNum == 1 then
			self.Speed = -3 -- left move
			
		elseif randNum == 2 then 
			self.Speed = 3 -- right move
		else
			self.Speed = 0 -- stand 
		end
		
		self.MoveTimer = 0
	end

	@ExecSpace("ClientOnly")
	method boolean EntityRangeOutCheck(Entity player)
		-- 농장 범위를 벗어났다면 true를, 아니라면 false를 반환합니다.
		
		local position = self.Entity.TransformComponent.Position
		
		if position.x > _PlayerService.Range_X.y then -- 오른쪽 범위 아웃
			return true
		elseif position.x < _PlayerService.Range_X.x then -- 왼쪽 범위 아웃
			return true
		elseif position.y > _PlayerService.Range_Y.y then -- 상단 범위 아웃
			return true
		elseif position.y < _PlayerService.Range_Y.x then -- 하단 범위 아웃
			return true
		end
		
		return false -- 농장을 벗어나지 않았을 경우
	end

	@ExecSpace("Client")
	method void EntityLayerSetting()
		-- Entity의 ItemLayer를 갱신합니다. ---------------------------------------------------------------------------
		self.Entity.AvatarRendererComponent.OrderInLayer = -(self.Entity.TransformComponent.Position.y * 200) + 800
		
		local entityLayer = self.Entity.AvatarRendererComponent.OrderInLayer
		local UI_Balloon = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon")
		local UI_Item = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon/UI_Item")
			
		UI_Balloon.SpriteRendererComponent.OrderInLayer = entityLayer + 1
		UI_Item.SpriteRendererComponent.OrderInLayer = entityLayer + 2
	end

	@ExecSpace("ClientOnly")
	method void EntityDragSetting(Entity player)
		-- 드래그가 끝날 경우 되돌리기 -----------------------------------------------------------
		if self.IsDragged and not player.PlayerMove.IsHold then
			
			self:EntityDragDrop(player, self.IsRangeOut, player.PlayerMove.MousePos)
			
			-- 색 설정 --------------------------------------------------------------------------
			local body = _EntityService:GetEntityByPath(self.Entity.Path.."/AvatarRoot/Body")
			local face =  _EntityService:GetEntityByPath(self.Entity.Path.."/AvatarRoot/Face")
		
			body.SpriteRendererComponent.Color = Color(1, 1, 1, 1)
			face.SpriteRendererComponent.Color = Color(1, 1, 1, 1)
		
			-------------------------------------------------------------------------------------
			
			self.HoldTimer = 0
			self.IsDragged = false
			player.PlayerMove.ClickedEntity = nil
			
			_SoundService:PlaySound("da48a979d2464d4ebe45c95818d04128", 1)
		
			
			
			
		-- 드래그 중일 경우 마우스 좌표로 이동 ---------------------------------------------------
		elseif self.IsDragged then
			
			self.Speed = 0 -- 들었을 때 IDLE 상태로 유지
			self.MoveTimer = 0 -- 들었을 때 무작위 이동 로직 멈춤
			
			
			-- 색 설정 --------------------------------------------------------------------------
			local body = _EntityService:GetEntityByPath(self.Entity.Path.."/AvatarRoot/Body")
			local face =  _EntityService:GetEntityByPath(self.Entity.Path.."/AvatarRoot/Face")
		
			if self.IsRangeOut then		
				body.SpriteRendererComponent.Color = Color(1, 100/255, 100/255, 0.4)
				face.SpriteRendererComponent.Color = Color(1, 100/255, 100/255, 0.4)
			else		
				body.SpriteRendererComponent.Color = Color(1, 1, 1, 0.4)
				face.SpriteRendererComponent.Color = Color(1, 1, 1, 0.4)
			end
			
			-------------------------------------------------------------------------------------
			
			self:EntityMoveClient(player.PlayerMove.MousePos)	
		end
	end

	@ExecSpace("ClientOnly")
	method void GetUiBalloonSet(Entity player)
		local UI_Item = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon/UI_Item")
		-- 회수 가능한 상태일 경우 --
		if player.PlayerData.IsFindItem and UI_Item.SpriteRendererComponent.SpriteRUID ~= '' then
			-- 아이템 풍선을 띄움
			local UI_Balloon = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon")
			UI_Balloon.Enable = true
			UI_Balloon.TransformComponent.Scale = Vector3(1,1,1)
		else
			-- 아이템 풍선을 가림
			local UI_Balloon = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon")
			UI_Balloon.Enable = false
			UI_Balloon.TransformComponent.Scale = Vector3(0,0,0)
		end
	end

	@ExecSpace("Server")
	method void GetProduct(Entity player, Entity UI_Balloon)
		if player.PlayerData.IsFindItem then
			-- 회수 횟수 + 1 ----------------------------------------------------------
				
			local lv = player.PlayerData.Level 
			local gold_quantity = tonumber(_DataService:GetCell("PlayerDataSet_Gold_Quantity", lv, "gold_Quantity"))
		
			-- Set ------------------
			_PlayerService:GetGold(player, gold_quantity)
			_GetPopupService:ShowMessage(player, _PlayerService.Gold_ID, gold_quantity, nil, nil, nil, player.Name)
				
			-- Effect ---------------
			_FloatingTextService:SummonText(UI_Balloon, gold_quantity, player.Name)
			_SoundService:PlaySound("acc1a8a1ba8e47728d9c4fcfe69d266c", 0.9, player.Name)
				
			-- Reset ----------------
			player.PlayerData.IsFindItem = false
			self:FindItemNameReset()
		end
	end

	@ExecSpace("Client")
	method void FindItemNameReset()
		self.FindEmotion = ""
		
		local UI_Balloon = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon")
		local UI_Item = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon/UI_Item")
			
		UI_Item.SpriteRendererComponent.SpriteRUID = ''
		UI_Balloon.TransformComponent.Scale = Vector3(0, 0, 0)
		UI_Balloon.Enable = false
	end

	@ExecSpace("Client")
	method void FindSettingItem()
		wait(1)
		
		-- 해당 인스턴스 맵의 주인이 아니면 조작을 막습니다. -----------------------------
		local player = _UserService.LocalPlayer
		
		if player.Name ~= self.MapInfo.MapOwnerName then
			return
		end
		
		local dust = _EntityService:GetEntityByPath(self.Entity.Parent.Path.."/dummy_dust")
		local dataSetName = "ItemDataSet_Base"
		
		local selectedItemID = _PlayerService.Gold_ID
		
		
		local item_name = _DataService:GetCell(dataSetName, (selectedItemID - 20000), "name")
		local item_ruid = _DataService:GetCell(dataSetName, (selectedItemID - 20000), "ruid")
		
		local UI_Item = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon/UI_Item")
		UI_Item.SpriteRendererComponent.SpriteRUID = item_ruid
		
		self.FindEmotion = "shine"
		
		local pt = self.Entity.TransformComponent
		local cloned_dust = dust:Clone("cloned_dust")
		local x_position = 0.5
		
		if self.Entity.PlayerControllerComponent.LookDirectionX < 0 then
			x_position = x_position * -1
		end
		
		cloned_dust.TransformComponent.Position = Vector3(pt.Position.x + x_position, pt.Position.y + 0.06, pt.Position.z)
		
		_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText("Popup_findSomething"))
		
		cloned_dust.DestroyEntity:wait(30)
	end

	@ExecSpace("Server")
	method void FindChangeEmotion(string findEmotion)
		if string.len(findEmotion) == 0 then
			return
		end
		
		if findEmotion == "love" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Love, 1.5)
			
		elseif findEmotion == "vomit" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Vomit, 1.5)
			
		elseif findEmotion == "shine" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Shine, 1.5)
			
		elseif findEmotion == "angry" then
			self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Angry, 1.5)
		end
	end

	@ExecSpace("ClientOnly")
	method void IsHold()
		local player = _UserService.LocalPlayer
		
		local delay = 0.5 -- 해당 시간 동안 MousePress를 유지하면 드래그가 됨
		
		if player.PlayerMove.Type == "none" then -- UI를 연 상태가 아닐 경우
			self.HoldTimer = self.HoldTimer + 0.02
		
			if self.HoldTimer >= delay then
				if player.PlayerMove.DraggedType == "none" then
					_SoundService:PlaySound("da48a979d2464d4ebe45c95818d04128", 1)
					player.PlayerMove.DraggedType = "entity"
				end
				
				self.HoldTimer = 0
				self.IsDragged = true
				
			end
			
		
		elseif player.PlayerMove.Type == "UI" then -- UI를 연 상태일 경우
			return
		end
		
	end

	@ExecSpace("ClientOnly")
	method void IsClick()
		local player = _UserService.LocalPlayer
		
		if player.PlayerMove.Type == "none"  then -- 아이템 회수 
			if not self.IsDragged and player.PlayerData.IsFindItem then
				local UI_Balloon = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Balloon")
				self:GetProduct(player, UI_Balloon)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void EntityMoveRandSelectSetting(Entity player, number timer)
		-- 랜덤 이동 로직 ---------------------
		self.MoveTimer = self.MoveTimer + timer
		if self.MoveTimer >= 3 then
			self:EntityMoveRandSelect() --엔티티를 무작위로 이동하게 설정
		end
		
		if player.PlayerData.IsFindItem then -- 무언가 발견한 상태일 경우 그 자리에서 멈추게 설정
			self.Speed = 0
		end
	end

	@ExecSpace("Server")
	method void EntityDragDrop(Entity player, boolean isOutOfRange, Vector2 targetPos)
		if not isOutOfRange then -- 농장 안이라면 ---------------
			self:EntityMoveServer(targetPos)
				
		else -- 농장 밖으로 나간 상태라면 ----------------------------
			local target_x = self.Entity.TransformComponent.Position.x
			local target_y = self.Entity.TransformComponent.Position.y
					
			
			if self.Entity.TransformComponent.Position.x <= _PlayerService.Range_X.x then
				target_x = _PlayerService.Range_X.x
				
			elseif self.Entity.TransformComponent.Position.x >= _PlayerService.Range_X.y then
				target_x = _PlayerService.Range_X.y
			end
					
			if self.Entity.TransformComponent.Position.y <= _PlayerService.Range_Y.x then
				target_y = _PlayerService.Range_Y.x
				
			elseif self.Entity.TransformComponent.Position.y >= _PlayerService.Range_Y.y then
				target_y = _PlayerService.Range_Y.y
			end
					
			self:EntityMoveServer(Vector2(target_x, target_y))
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchHoldEvent(TouchHoldEvent event)
		local player = _UserService.LocalPlayer
		
		-- 주인이 아닐 경우 --------
		if player.Name ~= self.MapInfo.MapOwnerName then
			return
		end
		
		if player.PlayerMove.ClickedEntity == self.Entity then
			self:IsHold()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		local player = _UserService.LocalPlayer
		
		-- 주인이 아닐 경우 --------
		if player.Name ~= self.MapInfo.MapOwnerName then
			return
		end
		
		player.PlayerMove.ClickedEntity = self.Entity
		self.HoldTimer = 0
	end

end