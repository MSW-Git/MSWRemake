@Component
script PlayerMove extends Component

	property Entity Camera = "5de1af8b-5fe6-49de-88df-f41fd5e94d5a"

	property Entity ClickedEntity = nil

	property number Speed = 0.3

	property number KeySpeed = 5

	property string Type = "none"

	property boolean IsHold = false

	property string DraggedType = "none"

	property Vector3 OldPos = Vector3(0,0,0)

	property Vector2 PanOrigin = Vector2(0,0)

	property Vector2 MousePos = Vector2(0,0)

	property Vector2 CameraPosX = Vector2(-5.5,5)

	property Vector2 CameraPosY = Vector2(0.5,4.5)

	property boolean LeftMove = false

	property boolean RightMove = false

	property boolean UpMove = false

	property boolean DownMove = false

	property boolean isClicking = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 화면 드래깅에 이동속도 차이를 줍니다
		if Environment:IsPCPlatform() then
			self.Speed = 1
			
		elseif Environment:IsMobilePlatform() then
			self.Speed = 1
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		local player = _UserService.LocalPlayer
		
		if self.Entity ~= player then
			return
		end
		
		if self.Entity.PlayerData.IsPossibleWalk then
			return	
		end
		
		-- 좌, 우 이동 ------------
		if self.LeftMove then
			
			if self.Camera.TransformComponent.Position.x > self.CameraPosX.x then
				self.Camera.TransformComponent.Position.x = self.Camera.TransformComponent.Position.x - (self.KeySpeed * delta)
			end
			
		elseif self.RightMove then
			
			if self.Camera.TransformComponent.Position.x < self.CameraPosX.y then
				self.Camera.TransformComponent.Position.x = self.Camera.TransformComponent.Position.x + (self.KeySpeed * delta)
			end
		end
		
		-- 업, 다운 이동 ---------
		if self.UpMove then
			
			if self.Camera.TransformComponent.Position.y < self.CameraPosY.y then
				self.Camera.TransformComponent.Position.y = self.Camera.TransformComponent.Position.y + (self.KeySpeed * delta)
			end
			
		elseif self.DownMove then
			
			if self.Camera.TransformComponent.Position.y > self.CameraPosY.x then
				self.Camera.TransformComponent.Position.y = self.Camera.TransformComponent.Position.y - (self.KeySpeed * delta)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchHoldEvent(ScreenTouchHoldEvent event)
		-- 컴포넌트가 비활성화된 상태면 TouchEvent를 실행하지 않습니다. ----
		if not self.Enable then
			return
		end
		
		-- Parameters
		local TouchPoint = event.TouchPoint
		--------------------------------------------------------
		self.MousePos = _UILogic:ScreenToWorldPosition(TouchPoint)
		
		self.IsHold = true
		
		if not isvalid(self.Camera.TransformComponent) then
			return
		end
		
		
		-- Screen Panning --
		if self.Type == "none" and self.DraggedType == "none" then -- 일반 상태
		
			local pos = Vector3(self.MousePos.x - self.PanOrigin.x, self.MousePos.y - self.PanOrigin.y, 0)
		
			if math.abs(pos.x) >= 0.2 or math.abs(pos.y) >= 0.2 then -- 터치 시 찔끔 이동하는 버그 수정용
				local x_sum = self.OldPos.x - pos.x
				local y_sum = self.OldPos.y - pos.y
		
				local x_power = x_sum * self.Speed
				local y_power = y_sum * self.Speed
		
				if x_power < self.CameraPosX.x then
					x_power = self.CameraPosX.x
					
				elseif x_power > self.CameraPosX.y then
					x_power = self.CameraPosX.y
				end
		
				if y_power < self.CameraPosY.x then
					y_power = self.CameraPosY.x
		
				elseif y_power > self.CameraPosY.y then
					y_power = self.CameraPosY.y
				end
		
				self.Camera.TransformComponent.Position = Vector3(x_power, y_power, 0)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchReleaseEvent(ScreenTouchReleaseEvent event)
		-- 컴포넌트가 비활성화된 상태면 TouchEvent를 실행하지 않습니다. ----
		if not self.Enable then
			return
		end
		
		if self.Type == "none" then -- 일반 상태 
		
			self.IsHold = false
			
			-- 드래그하는 엔티티를 드랍할 때 wait을 하지 않으면 엔티티의 좌표가 (0, 0)이 되는 이슈가 있어서
			-- 추가합니다.
			wait(0.1)
			
			self.DraggedType = "none"
			self.MousePos = Vector2(0, 0)
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		self.ClickedEntity = nil
		
		-- 컴포넌트가 비활성화된 상태면 TouchEvent를 실행하지 않습니다. ----
		if not self.Enable then
			return
		end
		
		if not isvalid(self.Camera.TransformComponent) then
			return
		end
		
		-- Parameters
		local TouchPoint = event.TouchPoint
		--------------------------------------------------------
		
		if self.Type == "none" then -- 일반 상태
			-- Screen Panning --
			self.OldPos = self.Camera.TransformComponent.Position
			self.PanOrigin = _UILogic:ScreenToWorldPosition(TouchPoint)
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		if self.Entity.CurrentMapName ~= "farm" then
			return
		end
		
		local key = tostring(event.key)
		
		if key == "A" or key == "LeftArrow" then
			self.LeftMove = true
			
		elseif key == "D" or key == "RightArrow" then
			self.RightMove = true
			
		elseif key == "W" or key == "UpArrow" then
			self.UpMove = true
			
		elseif key == "S" or key == "DownArrow" then
			self.DownMove = true
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyUpEvent(KeyUpEvent event)
		if self.Entity.CurrentMapName ~= "farm" then
			return
		end
		
		local key = tostring(event.key)
		
		if key == "A" or key == "LeftArrow" then
			self.LeftMove = false
			
		elseif key == "D" or key == "RightArrow" then
			self.RightMove = false
			
		elseif key == "W" or key == "UpArrow" then
			self.UpMove = false
			
		elseif key == "S" or key == "DownArrow" then
			self.DownMove = false
		end
	end

end