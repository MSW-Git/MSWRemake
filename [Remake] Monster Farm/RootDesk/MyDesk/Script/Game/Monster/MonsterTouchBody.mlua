@Component
script MonsterTouchBody extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchHoldEvent(TouchHoldEvent event)
		self.Entity.Parent.MonsterComponent:IsHold()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchReleaseEvent(TouchReleaseEvent event)
		self.Entity.Parent.MonsterComponent:IsRelease()
		self.Entity.Parent.MonsterComponent.HoldTimer = 0 
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		local player = _UserService.LocalPlayer
		player.PlayerMove.ClickedEntity = self.Entity.Parent
		self.Entity.Parent.ChatBalloonComponent.Message = ''
	end

end