@Component
script MonsterShowUI extends Component

	@HideFromInspector
	property number MonsterIDX = 0

	@HideFromInspector
	property number RefreshTime = 0.1

	@HideFromInspector
	property number RefreshTimeMAX = 0.1

	@HideFromInspector
	property number GapY = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		if self.RefreshTime >= self.RefreshTimeMAX then
			self.RefreshTime = 0
		else
			self.RefreshTime = self.RefreshTime + delta
			return
		end
		
		local player = _UserService.LocalPlayer
		
		local target_monster = _EntityService:GetEntity(player.PlayerData.Minventory_Entity[self.MonsterIDX])
		
		
		-- 타겟이 된 몬스터가 없으면 리턴 -----
		if not isvalid(target_monster) then
			self.Entity.Enable = false
			return
		end
		
		
		-- 몬스터가 아닌 다른 곳을 클릭하거나, 소환한 몬스터가 회수된 상태면 ---
		if not player.PlayerData.Minventory_Summoned[self.MonsterIDX] or player.PlayerMove.ClickedEntity ~= target_monster then
			target_monster.MonsterComponent.IsDisplayed = false
			self.Entity.Enable = false
			return
		end
		
		-- UI를 해당 몬스터의 머리 위에 표시합니다. -------------
		local monPos = target_monster.TransformComponent.Position
		local monScale = target_monster.TransformComponent.Scale.y * 0.9
		self.Entity.TransformComponent.Position = Vector3(monPos.x, monPos.y + (self.GapY* monScale), 1)
		
		
		
		
		
		
		-- UI 최신화 ---------------------------------------------------
		
		local Text_Lv =_EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/EXP_Background/Image_Text_Lv")
		local Text_Type = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/Grade_Type_Background/Text_Type")
		local Text_Grade = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/Grade_Type_Background/Image_Text_Grade")
		local Text_Remain_Time = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/Image_Gauge/Text_Remain_Time")
		
		local Gauge_Exp =  _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/EXP_Background")
		local Gauge_Time =  _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/Image_Gauge")
		
		local monster_lv = "Lv."..tostring(math.floor(player.PlayerData.Minventory_Level[self.MonsterIDX]))
		Text_Lv.TextComponent.Text = monster_lv
		
		Text_Type.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("MonsterDataSet_Base", player.PlayerData.Minventory_Id[self.MonsterIDX] , "name"))
		
		
		local Image_lv_max = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/EXP_Background/Image_Lv_Max")
		
		local Grade_logo = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/Grade_Type_Background/Image_Text_Grade")
		
		local text_Generation = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Background/UI_Generation")
		
		-- 레벨이 30 이상이면 MAX 로고 표시 ---------------------------
		Image_lv_max.Enable = player.PlayerData.Minventory_Level[self.MonsterIDX] >= _MonsterService.MonsterMaxLevel
		
		
		local levelPoint = player.PlayerData.Minventory_Level[self.MonsterIDX]
		
		-- Monster의 Grade를 반영합니다. --
		local monsterGrade = player.PlayerData.Minventory_Grade[self.MonsterIDX]
		
		if monsterGrade == _MonsterService.Grade_0_Name then
			Grade_logo.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
		
		elseif monsterGrade == _MonsterService.Grade_1_Name then
			Grade_logo.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)
		
		elseif monsterGrade == _MonsterService.Grade_2_Name then
			Grade_logo.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)
		
		elseif monsterGrade == _MonsterService.Grade_3_Name then
			Grade_logo.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)
		
		elseif monsterGrade == _MonsterService.Grade_4_Name then
			Grade_logo.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)
			
		elseif monsterGrade == _MonsterService.Grade_5_Name then
			Grade_logo.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)
		end
		
		
		-- Monster의 세대를 반영합니다. --
		local MonsterGeneration = tonumber(_DataService:GetCell("MonsterDataSet_Base",  player.PlayerData.Minventory_Id[self.MonsterIDX], "generation"))
		
		if MonsterGeneration == 1 then
			text_Generation.TextComponent.Text = "★<color=#c8c8c8>★★★★</color>"
			
		elseif MonsterGeneration == 2 then
			text_Generation.TextComponent.Text = "★★<color=#c8c8c8>★★★</color>"
			
		elseif MonsterGeneration == 3 then
			text_Generation.TextComponent.Text = "★★★<color=#c8c8c8>★★</color>"
			
		elseif MonsterGeneration == 4 then
			text_Generation.TextComponent.Text = "★★★★<color=#c8c8c8>★</color>"
			
		elseif MonsterGeneration == 5 then
			text_Generation.TextComponent.Text = "★★★★★"
		end
		
		-- 몬스터 등급을 텍스트로 표시 --------------------------------------------
		local monster_grade =  _LocalizationService.LocalTranslator:GetText(player.PlayerData.Minventory_Grade[self.MonsterIDX])
		Text_Grade.TextComponent.Text = monster_grade
		
		
		
		-- 몬스터의 생산 시간 표시 ------------------------------------------------
		local time = (_MonsterService.Origin_Product_Time) - player.PlayerData.Minventory_Time[self.MonsterIDX]  
		
		local time_text = self:remainTimeCalcul(time)
		Text_Remain_Time.TextComponent.Text = time_text
		
		-- 몬스터 게이지 표시 -----------------------------------------------------
		Gauge_Time.SliderComponent.Value = player.PlayerData.Minventory_Time[self.MonsterIDX] / _MonsterService.Origin_Product_Time
		Gauge_Exp.SliderComponent.Value = player.PlayerData.Minventory_Exp[self.MonsterIDX] / player.PlayerData.Minventory_Mexp[self.MonsterIDX]
		
	end

	@ExecSpace("ClientOnly")
	method string remainTimeCalcul(number time)
		
		local hour = 0
		local minute = 0 
		local second = 0
		local time_text = ""
		
		
		-- 생산량 이상으로 시간이 흘렀을 때 표시 버그 수정
		if time <= 0 then
			time = 0
		else
			hour = math.floor(time / 3600)
			time = time - hour * 3600
			
			minute = math.floor(time / 60)
			time = time - minute * 60
			
			second = time
		end
		 
		if time <= 0 then
			time_text = _LocalizationService.LocalTranslator:GetText("Show_production_complete")
			
		elseif hour >= 1 then
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("Show_production_hour", math.floor(hour), math.floor(minute), math.floor(second))
		elseif minute >= 1 then
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("Show_production_min", math.floor(minute), math.floor(second))
			
		else
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("Show_production_second", math.floor(second))
			
		end
		
		return time_text
	end

end