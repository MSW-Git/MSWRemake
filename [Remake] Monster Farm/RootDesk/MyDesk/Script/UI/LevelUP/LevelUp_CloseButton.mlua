@Component
script LevelUp_CloseButton extends Component

	@ExecSpace("ClientOnly")
	method void OnClick()
		_LevelUpService:Close()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end