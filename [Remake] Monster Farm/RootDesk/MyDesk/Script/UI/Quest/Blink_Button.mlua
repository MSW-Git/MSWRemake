@Component
script Blink_Button extends Component

	@HideFromInspector
	property number RefreshTime = 0

	property Entity Image_Light = "b7360b77-daf1-408a-a05b-171c44aff32f"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		if self.RefreshTime >= 0.5 then
			self.RefreshTime = 0
		else
			self.RefreshTime = self.RefreshTime + delta
			return
		end
		
		self.Image_Light.Enable = not self.Image_Light.Enable
	end

end