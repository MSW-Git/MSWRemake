@Component
script Quest_SortButton extends Component

	property string Type = ""

	@HideFromInspector
	property Quest QuestUI = "d892bdf0-c26a-4e10-966f-ef7b0e1d3b02"

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- Quest 카테고리를 변경합니다. ---------------------------------
		self.QuestUI:FilteringQuest(self.Type)
		
		-- 효과음을 재생합니다. -----------------------------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
		
		local parent_Children = self.Entity.Parent.Children
		
		for i = 1, #parent_Children do
			if parent_Children[i] == self.Entity then
				self.QuestUI:RefreshSortButtonStatus(i)
				break
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		-- 클릭한 아이템 표시
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end