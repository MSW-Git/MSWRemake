@Component
script Quest extends Component

	@HideFromInspector
	property Entity List = "e129c9a5-7d7f-4f8c-8a2e-0fe6f41246d8"

	@HideFromInspector
	property Entity Quest = "3987e1da-c656-45ea-8545-d5ff38f4f951"

	@HideFromInspector
	property Entity ShowedQuest = nil

	@HideFromInspector
	property string Filter = ""

	@HideFromInspector
	property Entity Right_Board = "26b67f89-2f2e-443c-b2f7-c082435f4b0e"

	property Entity Entity_MainQuest = "1b0aa8b2-147f-4d1c-a44f-05f8cc7fbcc7"

	@ExecSpace("ClientOnly")
	method void Open()
		local player = _UserService.LocalPlayer
		
		-----------------------------------------------
		-- Noti_Quest == 1, 새 일감을 얻었을 경우 
		-- Noti_Quest == 2, 완료한 퀘스트가 있을 경우
		-----------------------------------------------
		
		self:FilteringQuest("progress")
		self:RefreshSortButtonStatus(2)
		
	end

	@ExecSpace("ClientOnly")
	method void Close()
		local normalQuest_Children = self.List.Children
		
		-- 기존에 생성된 퀘스트 모두 삭제 ---
		for i = 2, #normalQuest_Children do
			normalQuest_Children[i]:Destroy()
		end
		
		-- Quest List를 비활성화합니다. -----
		self:SetListEnable(false)
	end

	@ExecSpace("ClientOnly")
	method void RefreshItem(string filter)
		local player = _UserService.LocalPlayer
		
		local normalQuest_Children = self.List.Children
		local mainQuest_List = _EntityService:GetEntityByPath("/ui/QuestGroup/Image_Board/List_Upper_Quest")
		
		-- 기존에 생성된 Item을 모두 삭제합니다. ---------------------------------------
		for i = 2, #normalQuest_Children do
			normalQuest_Children[i]:Destroy()
		end
		
		self.Entity_MainQuest.Quest_Item:RefreshQuestItemInfo()
		-- Item을 새로 생성합니다. -----------------------------------------------------
		
		local tableLength = 0
		
		if filter == "progress" then
			
			self.List.UITransformComponent.anchoredPosition.y = -176
			self.List.UITransformComponent.RectSize.y = 487
			mainQuest_List.Enable = true
			
			tableLength = #player.PlayerSubData.NormalQuests
			
		elseif filter == "wait" then
			
			self.List.UITransformComponent.anchoredPosition.y = -63
			self.List.UITransformComponent.RectSize.y = 710
			mainQuest_List.Enable = false
				
			tableLength = #player.PlayerSubData.WaitingQuests
			
		elseif filter == "done" then
			
			self.List.UITransformComponent.anchoredPosition.y = -63
			self.List.UITransformComponent.RectSize.y = 710
			mainQuest_List.Enable = false
				
			tableLength = #player.PlayerSubData.DoneQuests
			
		end
		
		
		for i = 1, tableLength do
			local cloned_item = self.Quest:Clone("clonedItem_"..tostring(i))
			
			if filter == "progress" then
				cloned_item.Quest_Item.Id = player.PlayerSubData.NormalQuests[i]
				
			elseif filter == "wait" then
				cloned_item.Quest_Item.Id = player.PlayerSubData.WaitingQuests[i]
				
			elseif filter == "done" then
				cloned_item.Quest_Item.Id = player.PlayerSubData.DoneQuests[i]
			end
			
			cloned_item.Quest_Item.ItemType = "Normal"
			cloned_item.Quest_Item.SortType = filter
			
			cloned_item.Quest_Item:RefreshQuestItemInfo()
		end
		
	end

	@ExecSpace("ClientOnly")
	method void FilteringQuest(string filter)
		-- Quest List를 비활성화합니다. -------------------------------------
		self:SetListEnable(false)
		
		-- Filter에 따라 다르게 Quest Interaction Button을 활성화합니다. ----
		local Buttons_etc = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/Image_Right_Board/Image_Background/Etc_Buttons")
		local Buttons_progress = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/Image_Right_Board/Image_Background/Progress_Buttons")
		
		if filter == "progress" then
			Buttons_etc.Enable = false
			Buttons_progress.Enable = true
		else
			Buttons_etc.Enable = true
			Buttons_progress.Enable = false
		end
		
		self.Filter = filter
		self:RefreshItem(filter)
	end

	@ExecSpace("ClientOnly")
	method void RefreshSortButtonStatus(number idx)
		-- 선택한 Sort Button을 강조 표시합니다. ------------------------------
		local sortButtonList = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Buttons")
		
		for i = 1, #sortButtonList.Children do
			local buttonEntity = sortButtonList.Children[i]
			local innerButton = _EntityService:GetEntityByPath(buttonEntity.Path.."/Button")
			
			if i ~= idx then
				buttonEntity.ButtonComponent.Enable = true
				
				innerButton.ButtonComponent.Enable = true
				innerButton.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1)
			else
				buttonEntity.ButtonComponent.Enable = false
				
				innerButton.ButtonComponent.Enable = false
				innerButton.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1)
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void SetListEnable(boolean status)
		-- Quest List를 비활성화합니다. -----
		self.Right_Board.Enable = status
	end

	@ExecSpace("ClientOnly")
	method void RefreshNormalQuestItemInfo()
		local list_Children = self.List.Children
		
		for i = 1, #list_Children do
			list_Children[i].Quest_Item:RefreshQuestItemInfo()
		end
	end

	@ExecSpace("ClientOnly")
	method void Hightlight_Item(Entity button)
		local list_Children = self.List.Children
		
		for i = 2, #list_Children do
			
			local button_Entity = list_Children[i]
			local text_Title = _EntityService:GetEntityByPath(list_Children[i].Path.."/Title_Logo")
			local text_Description = _EntityService:GetEntityByPath(list_Children[i].Path.."/Text_QuestInfo")
		
			button_Entity.SpriteGUIRendererComponent.Color.a = (button_Entity == button and 1 or  0)
			text_Title.SpriteGUIRendererComponent.Color =  (button_Entity == button and Color.FromHexCode("#888df1") or Color.FromHexCode("#929292"))
			text_Description.TextComponent.FontColor = (button_Entity == button and Color.FromHexCode("#3535e3") or Color.FromHexCode("#353535"))
		end
	end

end