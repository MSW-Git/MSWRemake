@Component
script Fusion_GetButton extends Component

	@HideFromInspector
	property Fusion MonsterFusion = "f83276c2-442e-43c2-808c-b09f35decc0c"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		local item = self.Entity.Parent.Parent
		local state = item.Fusion_ItemSlotMonster.Status
		local slot = item.Fusion_ItemSlotMonster.Idx
		
		-- 조합 슬롯이 비어있다면 --------------------------------------------------------------
		if state == "empty" then
			self.MonsterFusion:ChangeUIByType("set")
			self.MonsterFusion.SelectedSlot = slot
			
			
		-- 조합 슬롯이 완료되었다면 ------------------------------------------------------------
		elseif state == "done" then
		
			--=======================================================================
			-- 최대 몬스터 보유 숫자에 도달했다면
			--=======================================================================
			if #player.PlayerData.Minventory_Id >= _PlayerService.MaxHaveMonster then
				_PlayerService:MonsterSpaceFullAlert()
				return
			end
			--=======================================================================
			
			local rewardMonster = player.PlayerData.Finventory_Reward_Monster_Id[slot]
			local rewardMonster_grade = player.PlayerData.Finventory_Reward_Monster_Grade[slot]
			
			
			-- 소환될 몬스터의 RUID를 가져옵니다. ---------------
			local eggName = _DataService:GetCell("MonsterDataSet_Base", rewardMonster, "egg")
			local eggRUID = _FusionService:GetEggRuidFromDataSet(eggName)
			
			
			-- Fusion UI를 닫습니다. ----------------------------
			_UIService:Close(_EntityService:GetEntityByPath("/ui/MonsterFusionGroup"), player, "Fusion")
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			-- 가챠 UI를 엽니다. --------------------------------
			_GachaService:DecisionOpen(rewardMonster, "몬스터", eggRUID, rewardMonster_grade, slot, "Monster")
			
			
			-- 퀘스트: 조합으로 몬스터 얻기 ---------------------------------------------
			_SubDataService:playerDoFusionCountUp(player)
				
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end