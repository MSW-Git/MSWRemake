@Component
script Fusion_SlotBuyButton extends Component

	@HideFromInspector
	property Fusion MonsterFusion = "f83276c2-442e-43c2-808c-b09f35decc0c"

	@ExecSpace("ClientOnly")
	method void OnClick()
		
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		local item = self.Entity.Parent.Parent
		local idx = item.Fusion_ItemSlotMonster.Idx
		
		-- Positive일 경우 -----------------------------
		local yes = function() 
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
		
			_FusionService:BuySlot(player, idx)
			
		end
		
		-- Negative일 경우 -----------------------------
		local no = function()
			
		end
		
		------------------------------------------------
		
		_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_notification_Slot"), yes, no, nil)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end