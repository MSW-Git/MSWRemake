@Component
script Fusion_ItemSlotMonster extends Component

	@HideFromInspector
	property number Idx = 0

	@HideFromInspector
	property string Status = ""

	@HideFromInspector
	property boolean IsFinishedToLoad = false

	@HideFromInspector
	property Fusion MonsterFusion = "f83276c2-442e-43c2-808c-b09f35decc0c"

	@ExecSpace("ClientOnly")
	method void RefreshInfo()
		self:RefreshStatus()
		self:RefreshByStatus()
		
		self:RefreshMonsterInfo()
	end

	@ExecSpace("ClientOnly")
	method void RefreshStatus()
		if self.Idx == 0 then
			return
		end
		
		-- 현재 슬롯의 정보를 확인해서 상태를 설정합니다. ------------------------
		local player = _UserService.LocalPlayer
			
		local remainingTime = player.PlayerData.Finventory_Remaining_Time[self.Idx]
		
		local rewardMonster = player.PlayerData.Finventory_Reward_Monster_Id[self.Idx]
			
		local itemContentUI = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents")
		local itemLockUI = _EntityService:GetEntityByPath(self.Entity.Path.."/Lock")
			
			
		-- 잠금 해제한 슬롯이라면 ------------------------------------------------
		if player.PlayerData.Finventory_Slot_Unlock[self.Idx] then
				
			if isvalid(rewardMonster) then
				-- 조합 중인 슬롯이라면 -------
				if rewardMonster ~= 0 then
					if remainingTime <= 0 then
						self.Status = 'done'
							
					elseif remainingTime > 0 then
						self.Status = 'progress'
					end
						
				-- 조합 중인 슬롯이 아니라면 --
				elseif rewardMonster == 0 then
					if remainingTime <= 0 then
						self.Status = 'empty'
					end
				end
				
				itemContentUI.Enable = true
				itemLockUI.Enable = false
			end
				
		else
				
		-- 잠금 상태인 슬롯이라면 ------------------------------------------------
			itemContentUI.Enable = false
			itemLockUI.Enable = true
			
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshByStatus()
		-- 슬롯의 상태에 따라 UI를 갱신합니다. -------------------------------------------------------
		local player = _UserService.LocalPlayer
		local UI_Info = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/UI_Info")
		local UI_Empty = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/UI_Empty")
		local Button_Check = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/Button_Check") 
		
		
		-- 슬롯이 비어있다면 --------------------------
		if self.Status == "empty" then
			UI_Info.Enable = false
			UI_Empty.Enable = true
			Button_Check.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_fusion_DoFusion")
			Button_Check.ButtonComponent.Enable = true
			
			
		-- 조합이 완료된 슬롯이라면 -------------------
		elseif self.Status == "done" then
			UI_Info.Enable = true
			UI_Empty.Enable = false
			Button_Check.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_fusion_Complete")
			Button_Check.ButtonComponent.Enable = true
			
			
		-- 조합이 진행 중인 슬롯이라면 ----------------
		elseif self.Status == "progress" then
			UI_Info.Enable = true
			UI_Empty.Enable = false
			local timeText = self:RemainingTimeCalculator(player.PlayerData.Finventory_Remaining_Time[self.Idx])
			Button_Check.TextComponent.Text = timeText
			Button_Check.ButtonComponent.Enable = false
		end 
	end

	@ExecSpace("ClientOnly")
	method void RefreshMonsterInfo()
		if self.Idx == 0 then
			return
		end
		
		local player = _UserService.LocalPlayer
		
		-- 해당 슬롯이 잠긴 상태면 실행하지 않습니다. -------------------------------
		if not player.PlayerData.Finventory_Slot_Unlock[self.Idx] then
			return
		end
		
		-- 슬롯에 담긴 첫 번째 몬스터의 정보를 받아옵니다. --------------------------
		local firstMonster_Grade = player.PlayerData.Finventory_First_Grade[self.Idx]
		local firstMonster_Id = player.PlayerData.Finventory_First_Id[self.Idx]
		
		if not isvalid(firstMonster_Id) or firstMonster_Id == 0 or firstMonster_Grade == ' ' or not isvalid(firstMonster_Grade) then
			return
		end
		
		-- 슬롯에 담긴 두 번째 몬스터의 정보를 받아옵니다. --------------------------
		local secondMonster_Grade = player.PlayerData.Finventory_Second_Grade[self.Idx]
		local secondMonster_Id = player.PlayerData.Finventory_Second_Id[self.Idx]
		
		if not isvalid(secondMonster_Id) or secondMonster_Id == 0 or secondMonster_Grade == ' ' or not isvalid(secondMonster_Grade) then
			return
		end
		
		
		
		-- 슬롯에 담긴 데이터에 맞게 UI를 최신화합니다. --------------------------------------------------
		
		local dataSetName = "MonsterDataSet_Base"
		local length = _DataService:GetRowCount(dataSetName)
		
		local firstMonster_Image =  _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/UI_Info/First_Monster/Image_Monster")
		local secondMonster_Image = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/UI_Info/Second_Monster/Image_Monster")
		local firstMonster_Grade_Image = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/UI_Info/First_Monster/UI_Number")  
		local secondMonster_Grade_Image = _EntityService:GetEntityByPath(self.Entity.Path.."/Contents/UI_Info/Second_Monster/UI_Number") 
		local firstMonster_Grade_Text = _EntityService:GetEntityByPath(firstMonster_Grade_Image.Path.."/Text_Number") 
		local secondMonster_Grade_Text = _EntityService:GetEntityByPath(secondMonster_Grade_Image.Path.."/Text_Number") 
		
		
		
		-- 첫 번째 칸에 위치한 몬스터 정보 최신화 --------------------------------------------------------
		
		firstMonster_Grade_Text.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(firstMonster_Grade)
		
		-- 등급 반영 ----------------------------------------------
		
		if firstMonster_Grade  == _MonsterService.Grade_0_Name then
			firstMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
			firstMonster_Grade_Text.Enable = true
		
		elseif firstMonster_Grade  == _MonsterService.Grade_1_Name then
			firstMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)
			firstMonster_Grade_Text.Enable = true
			
		elseif firstMonster_Grade == _MonsterService.Grade_2_Name then
			firstMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)
			firstMonster_Grade_Text.Enable = true
			
		elseif firstMonster_Grade == _MonsterService.Grade_3_Name then
			firstMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)
			firstMonster_Grade_Text.Enable = true
			
		elseif firstMonster_Grade == _MonsterService.Grade_4_Name then
			firstMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)
			firstMonster_Grade_Text.Enable = true
			
		elseif firstMonster_Grade == _MonsterService.Grade_5_Name then
			firstMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)
			firstMonster_Grade_Text.Enable = true
		end
			
		
		
		-- 이미지 반영 --
		firstMonster_Image.SpriteGUIRendererComponent.ImageRUID  = _DataService:GetCell(dataSetName, firstMonster_Id, "ruid")
		firstMonster_Image.SpriteGUIRendererComponent.EndFrameIndex = 0
		
		local x_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", firstMonster_Id, "Thumbnail_x"))
		local y_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", firstMonster_Id, "Thumbnail_y"))
		
		firstMonster_Image.SpriteGUIRendererComponent.LocalScale = Vector2(x_scale, y_scale)
				
		
		
		-- 두 번째 칸에 위치한 몬스터 정보 최신화 --------------------------------------------------------
		
		-- 등급 반영 ----
		secondMonster_Grade_Text.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(secondMonster_Grade)
		
		if secondMonster_Grade  == _MonsterService.Grade_0_Name then
			secondMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
			secondMonster_Grade_Text.Enable = true
			
		elseif secondMonster_Grade  == _MonsterService.Grade_1_Name then
			secondMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)
			secondMonster_Grade_Text.Enable = true
			
		elseif secondMonster_Grade == _MonsterService.Grade_2_Name then
			secondMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)
			secondMonster_Grade_Text.Enable = true
			
		elseif secondMonster_Grade == _MonsterService.Grade_3_Name then
			secondMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)
			secondMonster_Grade_Text.Enable = true
			
		elseif secondMonster_Grade == _MonsterService.Grade_4_Name then
			secondMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)
			secondMonster_Grade_Text.Enable = true
			
		elseif secondMonster_Grade == _MonsterService.Grade_5_Name then
			secondMonster_Grade_Image.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)
			secondMonster_Grade_Text.Enable = true
		end
		
		-- 이미지 반영 --
		secondMonster_Image.SpriteGUIRendererComponent.ImageRUID  = _DataService:GetCell(dataSetName, secondMonster_Id, "ruid")
		secondMonster_Image.SpriteGUIRendererComponent.EndFrameIndex = 0
		
		x_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", secondMonster_Id, "Thumbnail_x"))
		y_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", secondMonster_Id, "Thumbnail_y"))
		
		
		secondMonster_Image.SpriteGUIRendererComponent.LocalScale = Vector2(x_scale, y_scale)
		
	end

	@ExecSpace("ClientOnly")
	method string RemainingTimeCalculator(number time)
		-- 조합 완료까지 남은 시간을 계산해서 return합니다. ---------------
		local hour = 0
		local minute = 0 
		local second = 0
		local time_text = ''
		
		if time < 0 then
			time = 0
		else
			hour = math.floor(time / 3600)
			time = time - hour * 3600
			
			minute = math.floor(time / 60)
			time = time - minute * 60
			
			second = time
		end
		 
		
		if hour >= 1 then
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("UI_fusion_RemainingTime_Full", math.floor(hour), math.floor(minute), math.floor(second))
			
		elseif minute >= 1 then
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("UI_fusion_RemainingTime_Short", math.floor(minute), math.floor(second))
			
		elseif second <= 0 then
			time_text = _LocalizationService.LocalTranslator:GetText("UI_fusion_Complete")
		
		else
			time_text = _LocalizationService.LocalTranslator:GetTextFormat("UI_fusion_RemainingTime_VeryShort", math.floor(second))
			
		end
		
		return time_text
	end

end