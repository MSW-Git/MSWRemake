@Component
script Fusion_DeselectButton extends Component

	@HideFromInspector
	property number Idx = 0

	@HideFromInspector
	property Fusion MonsterFusion = "f83276c2-442e-43c2-808c-b09f35decc0c"

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 클릭한 몬스터를 조합 창에서 Deselect 처리합니다. --
		self.MonsterFusion:DeselectMonster(self.Idx, nil)
		------------------------------------------------------
		
		
		local list_Children = self.MonsterFusion.SetMonsterList.Children
		
		for i = 1, #list_Children do
			list_Children[i].Fusion_ItemListMonster:RefreshHighlightEffect()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end