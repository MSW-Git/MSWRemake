          "Type": "Entity",
          "DefaultValue": "0e991b2e-5775-43ef-bcf1-419582467183",
          "SyncDirection": 0,
          "Attributes": [
            {
              "$type": "MOD.Core.Script.HideFromInspectorScriptAttribute, MOD.Core"
