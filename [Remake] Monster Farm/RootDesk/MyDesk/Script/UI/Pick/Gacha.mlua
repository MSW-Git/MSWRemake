@Component
script Gacha extends Component

	@HideFromInspector
	property boolean IsNormalGet = false

	@HideFromInspector
	property number RandomItem_Id = 0

	@HideFromInspector
	property Entity Item = "8479e134-4794-4322-9ffe-8fbff1a86ac5"

	@HideFromInspector
	property Entity Image_Item = "89403fda-628f-42e4-9204-c4706758a968"

	@HideFromInspector
	property Entity Image_GetItemImage = "70528589-5142-43f7-bf22-39e08f6bad18"

	@HideFromInspector
	property number Progress = 0

	@HideFromInspector
	property Entity Slider_Progress = "b20559a1-22c1-40f2-b9bc-9f8a84278d54"

	@HideFromInspector
	property boolean IsOpen = false

	@HideFromInspector
	property Entity Text_GetItemType = "24f08405-f53f-4a18-baf2-6fb9cdc8c625"

	@HideFromInspector
	property Entity Text_GetItemName = "c27d06d2-0912-4cef-8275-81f6fccd2393"

	@HideFromInspector
	property Entity Text_GetItemCount = "dae78c05-0624-4c15-89b7-69500ce2ff01"

	@HideFromInspector
	property Entity Text_Info = "1148de57-f17b-48c1-892d-b6ae0a84557f"

	@HideFromInspector
	property Entity OpenItem = "70528589-5142-43f7-bf22-39e08f6bad18"

	@HideFromInspector
	property Entity Effect_OpenItem = "deb6e6f9-d99b-42fd-b22d-b369a99dfd9a"

	@HideFromInspector
	property Entity Effect_OpenItem_Children = "ff91dfcf-e864-450e-9da9-b242b3ae666b"

	@HideFromInspector
	property Entity Effect_Complete = "e7ed6d3d-d416-4345-b620-4e7488f63e52"

	@HideFromInspector
	property Entity Effect_Complete_Children = "f981c441-27b7-4e3b-95d2-f5f50db0891d"

	@HideFromInspector
	property Entity Button_Close = "29775919-f989-4987-80cf-123d17edf0ff"

	@HideFromInspector
	property number NormalItem_Id = 0

	@HideFromInspector
	property string NormalItem_Type = ""

	property any NormalItem_SubType1 = nil

	property any NormalItem_SubType2 = nil

	property string Destination_Type = ""

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 자연스럽게 '확인 버튼'을 뜨게하는 코드 입니다. --------------------------------------------
		if self.Button_Close.Enable and self.Button_Close.SpriteGUIRendererComponent.Color.a <= 1 then
			self.Button_Close.SpriteGUIRendererComponent.Color.a = self.Button_Close.SpriteGUIRendererComponent.Color.a + (1.3*delta) 
			self.Button_Close.TextComponent.FontColor.a = self.Button_Close.TextComponent.FontColor.a + (1.3*delta)
		end
		
		-- 파워 게이지를 Value 값으로 반영합니다. ----------------
		self.Slider_Progress.SliderComponent.Value = self.Progress / 150
		
		
		if not self.IsOpen then -- 아이템을 오픈하기 전에만 게이지가 보이게 합니다.
			if self.Progress > 0 then
				self.Progress = self.Progress - (delta * 35)
			end
			self.Slider_Progress.SliderComponent.FillRectColor.a = 0.6 
			self.Slider_Progress.SpriteGUIRendererComponent.Color.a = 0.6
		else
			if self.Slider_Progress.SliderComponent.FillRectColor.a > 0 then
				self.Slider_Progress.SliderComponent.FillRectColor.a = self.Slider_Progress.SliderComponent.FillRectColor.a - delta * 2
				self.Slider_Progress.SpriteGUIRendererComponent.Color.a  = self.Slider_Progress.SpriteGUIRendererComponent.Color.a - delta * 2
			end	
		end
		--------------------------------------------------------------------------
	end

	@ExecSpace("ClientOnly")
	method void OpenByRandomItem(number itemId, string itemRUID)
		-- 사용할 아이템과 Slider만 보여줍니다 ------------------------
		self.Item.Enable = true
		self.Slider_Progress.Enable = true
		---------------------------------------------------------------
		
		-- 사용할 아이템을 갱신합니다. --------------------------------
		self.RandomItem_Id = itemId
		
		-- 사용할 아이템의 외형을 UI에 반영합니다. --------------------
		self.Image_Item.SpriteGUIRendererComponent.ImageRUID = itemRUID
	end

	@ExecSpace("ClientOnly")
	method void OpenByNormalItem(number itemId, string itemType, string itemRUID, any etc1, any etc2)
		-- 사용할 아이템과 Slider만 보여줍니다 ------------------------
		self.Item.Enable = true
		self.Slider_Progress.Enable = true
		---------------------------------------------------------------
		
		-- 사용할 아이템을 갱신합니다. --------------------------------
		self.IsNormalGet = true
		self.NormalItem_Id = itemId
		self.NormalItem_Type = itemType
		self.NormalItem_SubType1 = etc1
		self.NormalItem_SubType2 = etc2
		
		-- 사용할 아이템의 외형을 UI에 반영합니다. --------------------
		self.Image_Item.SpriteGUIRendererComponent.ImageRUID = itemRUID
	end

	@ExecSpace("ClientOnly")
	method void Close()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		self.IsOpen = false
		
		
		-- UI를 닫습니다. ---------------------------------------------
		
		_GachaService:Close()
		
		if self.Destination_Type == "Cook" then
			_CookService:Open()
			
		elseif self.Destination_Type == "Monster" then
			_UIService:Open(_EntityService:GetEntityByPath("/ui/MonsterGroup"), player, "Monster")
			
		else
			player.PlayerMove.Type = "none"
		
		end
		
		-- 데이터를 초기화 합니다. ------------------------------------
		self:ResetData()
	end

	@ExecSpace("ClientOnly")
	method void SetRandomItem()
		-- 가챠 아이템 획득 로직입니다. ------------------------------------------------------------------
		
		-- 아이템이 오픈되는 이펙트를 재생합니다. --------------------------------------------------------
		self:ReachGaugeFullEffect()
		
		
		-- 데이터셋에서 무작위로 아이템 하나를 가져옵니다. -----------------------------------------------
		local player = _UserService.LocalPlayer
		
		
		-- 가챠 아이템마다 참조할 DataSet이 다르기 때문에 설정해줘야 합니다. -----------------------------
		local dataSetName = _DataService:GetCell("ItemDataSet_Base", (self.RandomItem_Id - 20000), "point")
		
		
		-- DataSet의 아이템 중 하나를 랜덤으로 받아옵니다. -----------------------------------------------
		local length = _DataService:GetRowCount(dataSetName)
		local randNum = _UtilLogic:RandomIntegerRange(1, length)
		
		local itemId = tonumber(_DataService:GetCell(dataSetName, randNum, "id")) -- 골라진 아이템의 이름
		local itemType = _DataService:GetCell(dataSetName, randNum, "type") -- 골라진 아이템의 타입
		local itemRUID = "" -- 골라진 아이템의 RUID
		
		local min = 0 
		local max = 0
		local itemQuantity = 0
		
		if itemType == "아이템" then
			min = tonumber(_DataService:GetCell(dataSetName, randNum, "min")) -- 골라진 아이템의 최소 값
			max = tonumber(_DataService:GetCell(dataSetName, randNum, "max")) -- 골라진 아이템의 최대 값
				
			itemQuantity = _UtilLogic:RandomIntegerRange(min, max)
		end
		--------------------------------------------------------------------------------------------------
		
		
		if itemType  == "아이템" then -- 아이템이 나왔을 경우
			
			-- 얻을 아이템의 RUID를 가져옵니다. ----------------------------------------------------------
			itemRUID = _DataService:GetCell("ItemDataSet_Base",(itemId - 20000), "ruid")
		
			-- 아이템의 타입을 UI에 반영합니다. ----------------------------------------------------------
			self.Text_GetItemType.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(itemType)
			self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color(36/255, 159/255, 199/255, 1)
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			-- 아이템을 얻습니다. ------------------------------------------------------------------------
			_PlayerService:GetItem(player, itemId, itemQuantity, true)
			
			
		elseif itemType == "몬스터" then -- 몬스터가 나왔을 경우
		
			-- 얻을 몬스터의 RUID를 가져옵니다. ----------------------------------------------------------
			itemRUID = _DataService:GetCell("MonsterDataSet_Base", itemId, "ruid") 
			
			-- 몬스터의 등급에 따라 UI에 다르게 반영합니다. ----------------------------------------------
			self.Text_GetItemType.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_0_Name)
			
			self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
		
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			-- 몬스터를 얻습니다. ------------------------------------------------------------------------
			_PlayerService:GetMonster(player, itemId, _MonsterService.Grade_0_Name)
		
		end
		
		
		
		-- UI에 아이템의 정보를 반영합니다. ---------------------------------------------------------------
		
		
		-- 몬스터 타입이면 ----
		if itemId <= 20000 then
			self.Text_GetItemName.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("MonsterDataSet_Base", itemId, "name")) -- 골라진 아이템의 이름 반영
		-- 아이템 타입이면 ----
		else
			self.Text_GetItemName.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("ItemDataSet_Base", (itemId - 20000), "name")) -- 골라진 아이템의 이름 반영
		end
		
		
		self.Image_GetItemImage.SpriteGUIRendererComponent.ImageRUID = itemRUID -- 골라진 아이템의 RUID 반영
		self.Image_GetItemImage.SpriteGUIRendererComponent.EndFrameIndex = 0
		self.Image_GetItemImage.SpriteGUIRendererComponent.FrameRate = 0
		
		
		-- 아이템을 얻었을 경우 획득한 아이템의 개수를 표시합니다. ----------------------------------------
		if itemType == "아이템" then
			self.Text_GetItemCount.TextComponent.Text = "x "..tostring(math.floor(itemQuantity))
			self.Text_GetItemCount.Enable = true
			
			-- 획득한 아이템의 이미지 Scale 수정 --
			self.Image_GetItemImage.UITransformComponent.RectSize = Vector2(350, 350)
			
			
		elseif itemType == "몬스터" then
			self.Text_GetItemCount.TextComponent.Text = ""
			self.Text_GetItemCount.Enable = false
			
			-- 획득한 아이템의 이미지 Scale 수정 --
			local x_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", itemId, "Thumbnail_x"))
			local y_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", itemId, "Thumbnail_y"))
		
			self.Image_GetItemImage.SpriteGUIRendererComponent.LocalScale = Vector2(x_scale, y_scale)
		end
		
		
		-- 해당 가챠 아이템을 소모합니다. ------------------------------------------------------------------
		_PlayerService:DestroyItem(player, self.RandomItem_Id, 1)
		
		_GachaService:GachaEnd(player)
		
		-- 확인 버튼을 띄웁니다. ---------------------------------------------------------------------------
		self:AppearCheckButton()
	end

	@ExecSpace("ClientOnly")
	method void SetNormalItem()
		-- 확정 아이템 획득 로직입니다. ------------------------------------------------------------------
		local player = _UserService.LocalPlayer
		
		-- 아이템이 오픈되는 이펙트를 재생합니다. --------------------------------------------------------
		self:ReachGaugeFullEffect() -- 아이템이 오픈되는 이펙트를 재생합니다.
		
		local itemRUID = ''
		
		-- 몬스터를 얻을 경우 ----------------------------------------------------------------------------
		if self.NormalItem_Type == "몬스터" then 
			
			itemRUID = _DataService:GetCell("MonsterDataSet_Base", self.NormalItem_Id, "ruid")
		
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			-- 몬스터를 획득합니다. --------------------------------------------------------------------- 
			_PlayerService:GetMonster(player, self.NormalItem_Id, self.NormalItem_SubType1)
			
		
			-- 해당 조합 컬렉션을 해금합니다. -----------------------------------------------------------
			_PlayerService:GetFusionCollection(player, self.NormalItem_Id)
			
			--메인 퀘스트 : x세대 이상의 몬스터 획득-----------------------------------------------------
			local rewardMonster_Generation = tonumber(_DataService:GetCell("MonsterDataSet_Base", self.NormalItem_Id, "generation"))
			_QuestService:SetQuestFusionValue(player, rewardMonster_Generation)
		
		    ---------------------------------------------------------------------------------------------
			
			---------------------------------------------------------------------------------------------
			-- NormalItem_SubType1 = 몬스터의 등급, NormalItem_SubType2 = 몬스터가 위치한 조합 슬롯
			---------------------------------------------------------------------------------------------
			
			self.Text_GetItemName.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("MonsterDataSet_Base", self.NormalItem_Id, "name")) -- 골라진 아이템의 이름 반영
			
			
			-- 등급에 따라 텍스트 및 색 설정 ------------------------------------------------------------
			self.Text_GetItemType.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(self.NormalItem_SubType1)
		
			if self.NormalItem_SubType1 == _MonsterService.Grade_0_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
		
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_1_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_2_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_3_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_4_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_5_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)
			end
			
			-- 조합 Slot이 유효하다면 해당 슬롯을 비움 --------------------------------------------------
			if isvalid(self.NormalItem_SubType2) then
				_FusionService:ClearFusionSlot(player, self.NormalItem_SubType2)
			end
		
			
		
		-- 아이템을 얻을 경우 ----------------------------------------------------------------------------
		elseif self.NormalItem_Type == "아이템" then
			
			itemRUID = _DataService:GetCell("ItemDataSet_Base", self.NormalItem_Id - 20000, "ruid")
			
			self.Text_GetItemName.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell("ItemDataSet_Base", self.NormalItem_Id - 20000, "name")) -- 골라진 아이템의 이름 반영
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			-- 아이템을 얻습니다. ------------------------------------------------------------------------
			_PlayerService:GetItem(player, self.NormalItem_Id, self.NormalItem_SubType1, true)
		end
		
		
		-- 획득한 몬스터 or 아이템의 정보를 UI에 반영합니다. ---------------------------------------------
		self.Image_GetItemImage.SpriteGUIRendererComponent.ImageRUID = itemRUID -- 골라진 아이템의 RUID 반영
		self.Image_GetItemImage.SpriteGUIRendererComponent.EndFrameIndex = 0
		self.Image_GetItemImage.SpriteGUIRendererComponent.FrameRate = 0
		
		
		if self.NormalItem_Type == "아이템" then -- 아이템을 얻었을 경우
			self.Text_GetItemCount.Enable = true
			self.Text_GetItemCount.TextComponent.Text = "x "..tostring(math.floor(self.NormalItem_SubType1))
			
			-- 획득한 아이템의 이미지 Scale 수정 --
			self.Image_GetItemImage.SpriteGUIRendererComponent.LocalScale = Vector2(1, 1)
			
			self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode("#9d9d9d")
			
		elseif self.NormalItem_Type == "몬스터" then -- 몬스터를 얻었을 경우
			self.Text_GetItemCount.Enable = false
			self.Text_GetItemCount.TextComponent.Text = ""
			
			-- 획득한 아이템의 이미지 Scale 수정 --
			local x_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", self.NormalItem_Id, "Thumbnail_x"))
			local y_scale = tonumber(_DataService:GetCell("MonsterDataSet_UI", self.NormalItem_Id, "Thumbnail_y"))
			
			self.Image_GetItemImage.SpriteGUIRendererComponent.LocalScale = Vector2(x_scale, y_scale)
			
			if self.NormalItem_SubType1 == _MonsterService.Grade_0_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_1_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_2_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)
					
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_3_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)	
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_4_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)	
				
			elseif self.NormalItem_SubType1 == _MonsterService.Grade_5_Name then
				self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)	
			end
			
		
		end
		
		self.Text_GetItemType.TextComponent.Text = _LocalizationService.LocalTranslator:GetText(self.NormalItem_Type)
		
		_GachaService:GachaEnd(player)
				
		-- 확인 버튼을 띄웁니다. ---------------------------------------------------------------------------
		self:AppearCheckButton()
	end

	@ExecSpace("ClientOnly")
	method void ReachGaugeFullEffect()
		-- 파워 게이지가 가득찼을 때, 아이템이 등장합니다. ---------------------------
		local player = _UserService.LocalPlayer
		
		local effectComplete_Children = self.Effect_Complete_Children.Children
		
		for i = 1, #effectComplete_Children do
			effectComplete_Children[i]:Destroy()
		end
		
		-- 게이지 상단에 반짝이는 이펙트를 소환합니다. -------------------------------
		local clonedGaugeEffect = self.Effect_Complete:Clone("clonedEffect")
		clonedGaugeEffect:AttachTo(self.Effect_Complete_Children)
		
		-- 효과음을 재생합니다. ------------------------------------------------------
		_SoundService:PlaySound("3f01fdd951dc4f668a7b54ed8b3bdb0a", 0.75)
		
		
		wait(1)
		
		
		
		-- 획득한 아이템을 보여줍니다. -----------------------------------------------
		
		self.Text_GetItemName.Enable = false
		self.Item.Enable = false
		self.Text_Info.Enable = false
		self.OpenItem.Enable = true
		
		-- 등장 이펙트를 재생합니다. -------------------------------------------------
		
		local Effect_Children = self.Effect_OpenItem_Children.Children
		
		for i = 1, #Effect_Children do
			Effect_Children[i]:Destroy()
		end
		
		local cloned_effect = self.Effect_OpenItem:Clone("clonedEffect")
		cloned_effect:AttachTo(self.Effect_OpenItem_Children)
		
		--cloned_effect.SpriteGUIRendererComponent.Enable = false
		cloned_effect.SpriteGUIRendererComponent.Enable = true
		
		
		-- 효과음을 재생합니다. ------------------------------------------------------
		_SoundService:PlaySound("123888f05940460cb5ab3011c6693741", 1)
	end

	@ExecSpace("ClientOnly")
	method void AppearCheckButton()
		self.RandomItem_Id= 0
		
		wait(1)
		
		
		self.IsNormalGet = false
		self.NormalItem_Type = ""
		self.NormalItem_Id = 0
		self.NormalItem_SubType1 = ""
		self.NormalItem_SubType2 = ""
		self.Button_Close.SpriteGUIRendererComponent.Color.a = 0
		self.Button_Close.TextComponent.FontColor.a = 0
		self.Button_Close.Enable = true
		self.Text_GetItemName.Enable = true
		self.Slider_Progress.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void ResetData()
		-- 기존 설정 값 초기화 ----------------
		self.Text_GetItemCount.TextComponent.Text = ''
		self.Text_GetItemName.TextComponent.Text = ''
		self.Text_GetItemType.TextComponent.Text = ''
		self.Image_GetItemImage.SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9" 
		self.Text_GetItemType.SpriteGUIRendererComponent.Color = Color(0, 0, 0 , 0)
		
		self.OpenItem.Enable = false
		self.Text_GetItemName.Enable = false
		self.Button_Close.Enable = false
		
		self.Destination_Type = ""
		self.Progress = 0
		
		wait(1)
		self.Text_Info.Enable = true
	end

end