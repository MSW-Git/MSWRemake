@Component
script Tutorial_MenuButton extends Component

	@HideFromInspector
	property Entity TutorialUI = "f2e14033-6abb-4d85-a835-0a608a06d50e"

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 해당 버튼의 IDX를 가져옵니다. ------------------------------------------
		local idx = tonumber(self.Entity.Parent.Name)
		
		-- 해당하는 Tutorial Chapter로 진입합니다. --------------------------------
		self.TutorialUI.Tutorial:RefreshChapter(idx)
		
		-- 효과음을 재생합니다. ---------------------------------------------------
		_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end