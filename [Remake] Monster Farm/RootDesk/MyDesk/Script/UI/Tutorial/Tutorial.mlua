@Component
script Tutorial extends Component

	@HideFromInspector
	property number ChapterIDX = 0

	@HideFromInspector
	property number PageIDX = 0

	@HideFromInspector
	property number MaxPage = 0

	@HideFromInspector
	property Entity List_TutorialMenu = "92daa59a-2ff4-4d3a-9272-587dbd559892"

	@HideFromInspector
	property Entity List_TutorialChapter = "7c56b16a-ae7c-4c4f-8946-aad6884ad432"

	@HideFromInspector
	property Entity Button_X = "de3a1bc6-40a4-4dcf-a5b0-7fe4683fccf6"

	@HideFromInspector
	property Entity Button_Return = "aedcad87-90d3-4f4f-baa9-2db40e956b17"

	@HideFromInspector
	property Entity Button_LeftPage = "50f37819-537e-4841-ba55-90048bfa1981"

	@HideFromInspector
	property Entity Button_RightPage = "a52ce1ec-b5d7-49c8-9c70-cf4d8c4d23ad"

	@HideFromInspector
	property Entity Text_Upper_Info = "cd72e24a-ca80-4be5-ad90-fc2ec83cefc6"

	@ExecSpace("ClientOnly")
	method void ReturnToMenu()
		-- 챕터 선택 화면으로 돌아갑니다. ------
		self.Button_X.Enable = true
		self.Button_Return.Enable = false
		self.Text_Upper_Info.Enable = true
		self.Button_LeftPage.Enable = false
		self.List_TutorialMenu.Enable = true
		self.Button_RightPage.Enable = false
		self.List_TutorialChapter.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void RefreshChapter(number idx)
		-- 챕터에 진입합니다. ---------------------------------------
		local list_children = self.List_TutorialChapter.Children
		
		
		-- 해당 챕터 외에 다른 챕터를 비활성화 --
		for i = 1, #list_children do
			list_children[i].Enable = (i == idx)
		end
		
		self.ChapterIDX = idx
		self:RefreshPage(1)
		
		self.Button_X.Enable = false
		self.Button_Return.Enable = true
		self.Text_Upper_Info.Enable = false
		self.List_TutorialMenu.Enable = false
		self.List_TutorialChapter.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void RefreshPage(number idx)
		-- 해당 챕터의 페이지를 넘깁니다. ---------------------------
		
		local list_children = self.List_TutorialChapter.Children
		local page_children = list_children[self.ChapterIDX].Children
		
		
		-- 해당 페이지 외에 다른 페이지를 비활성화 --
		for i = 1, #page_children do
			page_children[i].Enable = (i == idx)
		end
		
		self.PageIDX = idx
		self.MaxPage = #page_children
		self.Button_LeftPage.Enable = true
		self.Button_RightPage.Enable = true
		
		self:RefreshPageButton()
	end

	@ExecSpace("ClientOnly")
	method void RefreshPageButton()
		self.Button_LeftPage.Tutorial_PageButton:RefreshButton()
		self.Button_RightPage.Tutorial_PageButton:RefreshButton()
	end

end