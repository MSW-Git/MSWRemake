@Component
script Tutorial_PageButton extends Component

	@HideFromInspector
	property Entity TutorialUI = "f2e14033-6abb-4d85-a835-0a608a06d50e"

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		local pageIDX = self.TutorialUI.Tutorial.PageIDX
		local maxPageIDX = self.TutorialUI.Tutorial.MaxPage
		
		-- 페이지를 왼쪽으로 넘깁니다. ----------------------------------------
		if self.Type == 'l' then
			if pageIDX > 1 then
				self.TutorialUI.Tutorial:RefreshPage(pageIDX - 1)
				_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
			end
			
		-- 페이지를 오른쪽으로 넘깁니다. --------------------------------------
		elseif self.Type == 'r' then
			if pageIDX < maxPageIDX then
				self.TutorialUI.Tutorial:RefreshPage(pageIDX + 1)
				_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshButton()
		local pageIDX = self.TutorialUI.Tutorial.PageIDX
		local maxPageIDX = self.TutorialUI.Tutorial.MaxPage
		
		if self.Type == 'l' then
			self.Entity.Visible = (pageIDX > 1)
			self.Entity.ButtonComponent.Enable =  (pageIDX > 1) 
			
		elseif self.Type == 'r' then
			self.Entity.Visible = (pageIDX < maxPageIDX)
			self.Entity.ButtonComponent.Enable = (pageIDX < maxPageIDX)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end