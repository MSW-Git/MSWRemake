@Component
script Kiosk_SellItem extends Component

	property number Idx = 0

	@HideFromInspector
	property Kiosk KioskUI = "23851c63-3b13-434a-9fcd-9bc6dd20ef5b"

	@ExecSpace("ClientOnly")
	method void RefreshInfo()
		if not isvalid(self.KioskUI.Inventory_Sell_Type[self.Idx]) or not isvalid(self.KioskUI.Inventory_Sell_Name[self.Idx]) or not isvalid(self.KioskUI.Inventory_Sell_Quantity[self.Idx]) then
			self.Entity.Enable = false
			return
		else
			self.Entity.Enable = true
		end
		
		-- 해당 아이템의 정보를 갱신합니다. ------------------------------------------------------------------
		local Text_Quantity = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_item_info/Text_Item_Count")
		local Image_Item = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/Image_item")
		
		
		-- 아이템의 타입에 맞게 강조 표시를 합니다. ----------------------------------------------------------
		local itemType = self.KioskUI.Inventory_Sell_Type[self.Idx]
		local newItemBody = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board")
		
		if itemType == "부산물" then
			newItemBody.SpriteGUIRendererComponent.Color = Color(154/255, 158/255, 181/255, 1) 		
		
		elseif itemType == "식재료" then
			newItemBody.SpriteGUIRendererComponent.Color = Color(234/255, 198/255, 134/255, 1) 
		end
		------------------------------------------------------------------------------------------------------
		
		
		-- 텍스트 갱신 ---------------------------------------------------------------------------------------
		Text_Quantity.TextComponent.Text = tostring(math.floor(self.KioskUI.Inventory_Sell_Quantity[self.Idx]))
		
		
		-- 이미지 갱신 ---------------------------------------------------------------------------------------
		Image_Item.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", (self.KioskUI.Inventory_Sell_Name[self.Idx] - 20000), "ruid")
		Image_Item.SpriteGUIRendererComponent.EndFrameIndex = 0
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 이 아이템을 다시 인벤토리로 옮깁니다. -------------------------------------------------------
		self.KioskUI:ReturnItemToInventory(self.Idx)
		
		-- 효과음을 재생합니다. ------------------------------------------------------------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end