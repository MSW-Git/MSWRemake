@Component
script Kiosk extends Component

	property SyncTable<number> Inventory_Name

	property SyncTable<string> Inventory_Type

	property SyncTable<number> Inventory_Quantity

	property SyncTable<number> Inventory_Sell_Name

	property SyncTable<string> Inventory_Sell_Type

	property SyncTable<number> Inventory_Sell_Quantity

	property Entity Inventory_Item = "afdec0c0-34b8-4bca-aa6e-baa5b909a5ed"

	property Entity Sell_Item = "10dc1d1e-e05c-4cff-89cd-e3f19759d455"

	property Entity Sell_Button = "dcad178b-31b4-4be5-8c0e-4b509414d441"

	property number TotalCost = 0

	property TextComponent TotalCost_Text = "0172d967-2f2e-438f-b326-a4fc7830ad10"

	property string CurrentFilter = "몬스터"

	property Entity Background_Image = "857dcbac-435f-4c46-a98a-ddc39548a979"

	property SpriteGUIRendererComponent Caption_Item_Image = "f474e132-0042-44d0-a411-e23e15764ca8"

	property Entity Caption_Background_Image = "857dcbac-435f-4c46-a98a-ddc39548a979"

	property TextComponent Caption_Name_Text = "096584bf-5353-4dad-b80d-6e0acbc8c329"

	property TextComponent Caption_Type_Text = "69cb044f-bbca-4537-8aa9-0926b3f327ba"

	property number Caption_Sell_Quantity = 0

	property TextComponent Caption_Sell_Quantity_Text = "17ee0d3c-2aff-4960-a20c-c645ea2ad113"

	property SliderComponent Caption_Slider = "c24aebce-b079-43bf-95a1-e958a4d29d8e"

	property number Caption_IDX = 0

	property boolean PieceSell = true

	property Entity List = "c73975d9-6473-4a77-8c04-0518e47355ef"

	property Entity UI_Unlock = "f20ad5f6-aef0-41dc-8e13-32e2464298fd"

	property Entity UI_CapacityUp = "67ed416b-1acd-4031-953d-6db9e6ff6be8"

	property Entity Text_Upgrade_Cost = "0c8ab608-1e98-41fd-9ad3-1c52b8b4b32f"

	property Entity Button_Capacity_Up = "e5319b21-5c87-4b67-b416-85f17a6b4c3c"

	property Entity Text_Next_Capacity = "b5028420-c474-44b8-99f3-8f73c9f011a9"

	property Entity Text_Prev_Capacity = "70802395-fa9a-4ae0-9b4c-be7450a48ccb"

	property SpriteGUIRendererComponent Kiosk_Cost_Image = "e0cb2589-a927-415d-a0e6-72c13d1361d0"

	@ExecSpace("ClientOnly")
	method void refresh()
		-- 화면을 새로 갱신합니다
		local inv_list =  #_EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_KioskRight/UI_Scroll").Children 
		local sell_list = #_EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_KioskLeft/UI_Bottom_Bar/List").Children
		
		if #self.Inventory_Name ~= inv_list - 1 then
			self:RefreshInventoryItem()
		end
		
		if #self.Inventory_Sell_Name ~= sell_list - 1 then
			self:RefreshSellItem()
		end
		
	end

	@ExecSpace("ClientOnly")
	method void Open()
		local player = _UserService.LocalPlayer
		
		self:ChangeSellButtonStatus()
		
		-- 인벤토리 테이블을 생성합니다. ------------
		self:CreateInventoryTable()
		---------------------------------------------
		self.CurrentFilter = "부산물"
		self:FilteringInventoryItem(self.CurrentFilter)
		
		if self.UI_Unlock.Enable then
			self.UI_Unlock.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self:ResetAllData()
		
		self.UI_Unlock.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void OpenCaption(number idx)
		-- 클릭한 아이템의 수량이 한 개 이상이라면 Caption UI를 엽니다. ------------------------------
		if self.Inventory_Quantity[idx] > 1 then
			
			-- Caption UI를 갱신합니다. ------------------------------------------
			self.Caption_IDX = idx
			self.Caption_Background_Image.Enable = true
			
			
			-- Slider 값을 갱신합니다. ---
			self.Caption_Slider.MinValue = 1
			self.Caption_Slider.MaxValue = self.Inventory_Quantity[idx]
			
				
			-- 기본적으로 최대 수량 판매로 표시되게 합니다. ------
			self.Caption_Sell_Quantity = self.Inventory_Quantity[idx]
			self.Caption_Slider.Value = self.Caption_Sell_Quantity
			
			
			-- 판매할 수량을 텍스트로 보여줍니다. ----------------
			self.Caption_Sell_Quantity_Text.Text = tostring(math.floor(self.Caption_Sell_Quantity))
			
		
			-- 판매할 아이템의 정보를 텍스트로 보여줍니다. -------
			local dataSetName = "ItemDataSet_Base"
		
			self.Caption_Item_Image.ImageRUID = _DataService:GetCell(dataSetName, (self.Inventory_Name[idx] - 20000), "ruid")
			self.Caption_Name_Text.Text = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(dataSetName, (self.Inventory_Name[idx] - 20000), "name"))
			self.Caption_Type_Text.Text = "[".._LocalizationService.LocalTranslator:GetText(_DataService:GetCell(dataSetName, (self.Inventory_Name[idx] - 20000), "type")).."]" 
			
			
		-- 클릭한 아이템의 수량이 한 개라면 바로 가판대로 옮깁니다. -----------------------------------
		elseif self.Inventory_Quantity[idx] == 1 then -- 판매할 슬롯의 아이템이 단 한개일 경우
			
			self:PutSingleItemToKiosk(idx)
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void CloseCaption()
		-- Caption UI를 닫습니다. ------------------
		self.Caption_Background_Image.Enable = false
		
		-- 효과음을 재생합니다. --------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 1)
	end

	@ExecSpace("ClientOnly")
	method void CreateInventoryTable()
		local player = _UserService.LocalPlayer
		
		-- 인벤토리 테이블을 생성합니다. ------------------------------------------------------
		for i = 1, #player.PlayerData.Inventory_Name do
			table.insert(self.Inventory_Name, player.PlayerData.Inventory_Name[i])
			table.insert(self.Inventory_Type, player.PlayerData.Inventory_Type[i])
			table.insert(self.Inventory_Quantity, player.PlayerData.Inventory_Quantity[i])
		end
		
		self:RefreshInventoryItem()
		self:RefreshSellItem()
	end

	@ExecSpace("ClientOnly")
	method void RefreshInventoryItem()
		-- 인벤토리에 있는 Item을 갱신합니다. --------------------------
		local list =  _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_KioskRight/UI_Scroll")
		local list_Children = list.Children
		
		
		for x = #list_Children, #self.Inventory_Name do
			local clonedItem = self.Inventory_Item:Clone("item"..tostring(x))
		end
		
		
		list_Children = list.Children
		
		-- 인벤토리 테이블을 순회하며 갱신합니다. ----------------------
		for i = 2 , #list_Children do
			list_Children[i].Kiosk_InventoryItem.Idx = i - 1
			list_Children[i].Kiosk_InventoryItem:RefreshInfo(self.CurrentFilter)
		end
	end

	@ExecSpace("ClientOnly")
	method void FilteringInventoryItem(string filter)
		local filterType = 0
		
		if filter == "부산물" then
			filterType = 1
			
		elseif filter == "식재료" then
			filterType = 2
			
		elseif filter == "요리" then
			filterType = 3
			
		elseif filter == "에그" then
			filterType = 4
		end
		
		self:RefreshSortButtonStatus(filterType)	
		
		local list =  _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_KioskRight/UI_Scroll")
		local list_Children = list.Children
		
		local filteredItem_Num = 0
		
		for i = 2, #list_Children do
			list_Children[i].Kiosk_InventoryItem:RefreshInfo(filter)
			
			if list_Children[i].Enable then
				filteredItem_Num = filteredItem_Num + 1
			end
		end
		
		-- 효과음을 재생합니다. -----------------------------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
		
		local button_AllPut = _EntityService:GetEntityByPath("/ui/KioskGroup/Image_Board/Button_all_put")
		button_AllPut.ButtonComponent.Enable = (filteredItem_Num > 0)
		
		if filteredItem_Num > 0 then
			button_AllPut.TextComponent.FontColor.a = 1
		else
		 	button_AllPut.TextComponent.FontColor.a = 0.3
		end
		
		self.CurrentFilter = filter
	end

	@ExecSpace("ClientOnly")
	method void PutItemToKiosk()
		-- 판매할 목록에 이 아이템을 이동시킵니다. ---------------------------------------
		table.insert(self.Inventory_Sell_Quantity, self.Caption_Sell_Quantity)
		table.insert(self.Inventory_Sell_Name, self.Inventory_Name[self.Caption_IDX])
		table.insert(self.Inventory_Sell_Type, self.Inventory_Type[self.Caption_IDX])
		
		local curNum = self.Inventory_Quantity[self.Caption_IDX] - self.Caption_Sell_Quantity  --판매하고 나서의 수량을 체크해서 테이블에서 삭제할지 말지 결정
		
		
		-- 아이템 이동 후 수량이 0 이하라면 테이블에서 삭제 ------------
		if curNum <= 0 then
			table.remove(self.Inventory_Quantity, self.Caption_IDX)
			table.remove(self.Inventory_Name, self.Caption_IDX)
			table.remove(self.Inventory_Type, self.Caption_IDX)
		else
			self.Inventory_Quantity[self.Caption_IDX] = curNum
		end
		
		
		-- 캡션 닫기 ---------------
		self:CloseCaption()
		
		-- 버튼 상태 변경 ----------
		self:ChangeSellButtonStatus()
		
		-- 인벤토리 상태 변경 ------
		if isvalid(self.Inventory_Quantity[self.Caption_IDX]) and self.Inventory_Quantity[self.Caption_IDX] >= 1 then
			self:RefreshInventoryItem()
		end
	end

	@ExecSpace("ClientOnly")
	method void PutAllItemsToKiosk()
		-- 해당 카테고리의 아이템 모두 팔기 ----
		
		local length = #self.Inventory_Type
		
		local temp_inventory_name = {}
		local temp_inventory_type = {}
		local temp_inventory_quantity = {}
		
		if #self.Inventory_Type >= 1 then		
		
			for i = 1, #self.Inventory_Type do
				if self.Inventory_Type[i] == self.CurrentFilter then
					table.insert(self.Inventory_Sell_Name, self.Inventory_Name[i])
					table.insert(self.Inventory_Sell_Type, self.Inventory_Type[i])
					table.insert(self.Inventory_Sell_Quantity, self.Inventory_Quantity[i])
				else
					table.insert(temp_inventory_name, self.Inventory_Name[i])
					table.insert(temp_inventory_type, self.Inventory_Type[i])
					table.insert(temp_inventory_quantity, self.Inventory_Quantity[i])
				end
			end
					
			table.clear(self.Inventory_Name)
			table.clear(self.Inventory_Quantity)
			table.clear(self.Inventory_Type)
					
			for i = 1, #temp_inventory_name do
				table.insert(self.Inventory_Name, temp_inventory_name[i])
				table.insert(self.Inventory_Type, temp_inventory_type[i])
				table.insert(self.Inventory_Quantity, temp_inventory_quantity[i])
			end
		end
		
		-- 버튼 상태 변경 ----------
		self:ChangeSellButtonStatus()
	end

	@ExecSpace("ClientOnly")
	method void RefreshSellItem()
		-- 가판대에 올린 Item을 갱신합니다. -------------------
		local sellList =  _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_KioskLeft/UI_Bottom_Bar/List")
		local sellList_Children = sellList.Children
		
		for x = #sellList_Children, #self.Inventory_Name do
			local clonedItem = self.Sell_Item:Clone("item"..tostring(x))
		end
		
		sellList_Children = sellList.Children
		
		-- 판매 테이블을 순회하며 Item을 생성합니다. ----------
		for i = 2, #sellList_Children do
			sellList_Children[i].Kiosk_SellItem.Idx = i - 1
			
			-- 해당 아이템 정보를 UI에 갱신합니다. ------------
			sellList_Children[i].Kiosk_SellItem:RefreshInfo()
		end
		
	end

	@ExecSpace("ClientOnly")
	method void ReturnItemToInventory(number idx)
		-- 가판대 Item을 Inventory로 되돌립니다. -----------------------------------
		local dataSetName = "ItemDataSet_Base"
		
		local maxQuantity = tonumber(_DataService:GetCell(dataSetName, (self.Inventory_Sell_Name[idx] - 20000), "max_quantity")) 
		
		for i =1, #self.Inventory_Name do
			
			-- 동일한 아이템이 인벤토리에 있고 스택이 가능하다면 -------------------
			if self.Inventory_Sell_Name[idx] == self.Inventory_Name[i] and self.Inventory_Quantity[i] ~= maxQuantity then
				local totalValue = self.Inventory_Sell_Quantity[idx] + self.Inventory_Quantity[i]
			
				-- 여분의 스택 공간이 남아있다면 ------------------
				if maxQuantity >= totalValue then
					self.Inventory_Quantity[i] = totalValue
					
					table.remove(self.Inventory_Sell_Name, idx)
					table.remove(self.Inventory_Sell_Quantity, idx)
					table.remove(self.Inventory_Sell_Type, idx)
					
					self:RefreshInventoryItem()
					self:ChangeSellButtonStatus()
					return
					
				-- 여분의 스택 공간이 없다면 ----------------------
				else 
					local exceedValue = math.abs(totalValue-maxQuantity)
					self.Inventory_Quantity[i] = maxQuantity
					self.Inventory_Sell_Quantity[idx] = exceedValue
					
					self:ReturnItemToInventory(idx)
				end
			end
		end
		
		-- 인벤토리에 해당 아이템이 없다면 ------------------------------------------
		table.insert(self.Inventory_Name, self.Inventory_Sell_Name[idx])
		table.insert(self.Inventory_Quantity, self.Inventory_Sell_Quantity[idx])
		table.insert(self.Inventory_Type, self.Inventory_Sell_Type[idx])
		
		table.remove(self.Inventory_Sell_Name, idx)
		table.remove(self.Inventory_Sell_Quantity, idx)
		table.remove(self.Inventory_Sell_Type, idx)
		
		
		-- 버튼 상태 변경 ----------
		self:ChangeSellButtonStatus()
	end

	@ExecSpace("ClientOnly")
	method void PutSingleItemToKiosk(number idx)
		-- 해당 단일 아이템을 가판대에 올립니다. ------------------------------------
		table.insert(self.Inventory_Sell_Name, self.Inventory_Name[idx])
		table.insert(self.Inventory_Sell_Type, self.Inventory_Type[idx])
		table.insert(self.Inventory_Sell_Quantity, self.Inventory_Quantity[idx])
		table.remove(self.Inventory_Name, idx)
		table.remove(self.Inventory_Type, idx)
		table.remove(self.Inventory_Quantity, idx)
		
		-- 효과음을 재생합니다. -----------------------------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
		
		-- 버튼 상태 변경 ----------
		self:ChangeSellButtonStatus()
		
	end

	@ExecSpace("ClientOnly")
	method void ResetAllData()
		-- 기존 임시 테이블을 모두 초기화합니다. ------------------------------------------------
		table.clear(self.Inventory_Name)
		table.clear(self.Inventory_Quantity)
		table.clear(self.Inventory_Type)
		
		table.clear(self.Inventory_Sell_Name)
		table.clear(self.Inventory_Sell_Quantity)
		table.clear(self.Inventory_Sell_Type)
		
		-- 정산 금액을 초기화 합니다. -----------------------------------------------------------
		self.TotalCost = 0
		self.TotalCost_Text.Text = "0"
	end

	@ExecSpace("Client")
	method void ResetKioskData()
		-- 가판대 정보를 초기화 합니다. ---------
		table.clear(self.Inventory_Sell_Name)
		table.clear(self.Inventory_Sell_Quantity)
		table.clear(self.Inventory_Sell_Type)
		
		self.TotalCost = 0
		self.TotalCost_Text.Text = "0"
		
		-- 버튼 상태 변경 ----------
		self:ChangeSellButtonStatus()
	end

	@ExecSpace("ClientOnly")
	method void ChangeSellButtonStatus()
		-- 물건이 하나라도 올려져 있을 때만 버튼이 활성화되게 합니다. -----
		if #self.Inventory_Sell_Name >= 1 then
			self.TotalCost_Text.FontColor.a = 1
			self.Kiosk_Cost_Image.Color.a = 1
			self.Sell_Button.ButtonComponent.Enable = true
			self.Sell_Button.TextComponent.FontColor = Color(1, 1, 1, 1)
		else	
			self.TotalCost_Text.FontColor.a = 0.3
			self.Kiosk_Cost_Image.Color.a = 0.3
			self.Sell_Button.ButtonComponent.Enable = false
			self.Sell_Button.TextComponent.FontColor = Color(1, 1, 1, 0.25)
		end
		
		self:RefreshInventoryItem()
		self:RefreshSellItem()
		
		self:TotalCostCalculator()
	end

	@ExecSpace("ClientOnly")
	method void RefreshSortButtonStatus(number idx)
		-- 선택한 Sort Button을 강조 표시합니다. ------------------------------
		local sortButtonList = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_Buttons")
		
		for i = 1, #sortButtonList.Children do
			local buttonEntity = sortButtonList.Children[i]
			local innerButton = _EntityService:GetEntityByPath(buttonEntity.Path.."/Button")
			
			if i ~= idx then
				buttonEntity.ButtonComponent.Enable = true
				
				innerButton.ButtonComponent.Enable = true
				innerButton.TextComponent.FontColor = Color(159/255, 167/255, 173/255, 1)
			else
				buttonEntity.ButtonComponent.Enable = false
				
				innerButton.ButtonComponent.Enable = false
				innerButton.TextComponent.FontColor = Color(227/255, 227/255, 227/255, 1)
			end
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void TotalCostCalculator()
		-- 가판대에 올라간 아이템의 총 가격을 계산합니다. -------------------
		
		local totalSum = 0 -- 정산될 합계 금액입니다.
		local dataSetName = "ItemDataSet_Base"
		
		for i = 1, #self.Inventory_Sell_Name do
			for x = 1, _DataService:GetRowCount(dataSetName) do
				local cost = tonumber(_DataService:GetCell(dataSetName, (self.Inventory_Sell_Name[i] - 20000), "cost")) * self.Inventory_Sell_Quantity[i]
				totalSum = totalSum + cost
				break
			end
		end
		
		self.TotalCost = totalSum
		self.TotalCost_Text.Text = _SystemService:ThousandsSeparator(self.TotalCost)
	end

	@ExecSpace("ClientOnly")
	method void OpenUpgradeUI()
		local player = _UserService.LocalPlayer
		
		-- 보유량 확장 UI를 엽니다. -----------
		self.UI_CapacityUp.Enable = true
		
		self:RefreshUpgradeUI(player)
		---------------------------------------
	end

	@ExecSpace("ClientOnly")
	method void RefreshUpgradeUI(Entity player)
		-- 업그레이드 UI를 갱신합니다. -----------------------------------------------------------------------------------
		
		if not self.UI_CapacityUp.Enable then
			return
		end 
		
		local maxCapacity_Level = _DataService:GetRowCount("ItemDataSet_CapaUpCost")
		
		-- 최대 레벨에 도달했다면 ---------------------------------------------
		if player.PlayerData.MaxCapacity_Upgrade_Level > maxCapacity_Level then
			local hammer = _EntityService:GetEntityByPath("/ui/KioskGroup/Upgrade_Background/UI_Upgrade/Image_Hammer")
			hammer.Enable = false
			
			self.Text_Upgrade_Cost.TextComponent.Text = "X"
			self.Text_Prev_Capacity.TextComponent.Text = tostring(math.floor(player.PlayerData.MaxCapacity))
			self.Text_Next_Capacity.TextComponent.Text = tostring(math.floor(player.PlayerData.MaxCapacity))
			
			self.Button_Capacity_Up.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_notExpandCapacity")
			self.Button_Capacity_Up.ButtonComponent.Enable = false
			
			_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText("Popup_imPossibleToExpand"))
			return	
		end
		
		local Cost = tonumber(_DataService:GetCell("ItemDataSet_CapaUpCost", player.PlayerData.MaxCapacity_Upgrade_Level, "cost"))
		
		-- 업그레이드 비용을 갱신합니다. ---------------------------------------------------------------------------------
		self.Text_Upgrade_Cost.TextComponent.Text = _SystemService:ThousandsSeparator(Cost)
		
		self.Text_Prev_Capacity.TextComponent.Text = tostring(math.floor(player.PlayerData.MaxCapacity))
		self.Text_Next_Capacity.TextComponent.Text = tostring(math.floor(player.PlayerData.MaxCapacity + 9))
		
		local hammer = _EntityService:GetEntityByPath("/ui/KioskGroup/Upgrade_Background/UI_Upgrade/Image_Hammer")
		
		-- 재화가 충분히 있다면 ------------------------------------------------------------------------------------------
		if player.PlayerData.Gold >= Cost then
			
			self.Text_Upgrade_Cost.ButtonComponent.Enable = true
			self.Button_Capacity_Up.ButtonComponent.Enable = true
			
			-- UI를 갱신합니다. ---------------------------
			hammer.Enable = true
			
			self.Text_Upgrade_Cost.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 0.8)
			self.Button_Capacity_Up.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 1)
			
		-- 재화가 부족하다면 ---------------------------------------------------------------------------------------------
		else
			
			self.Text_Upgrade_Cost.ButtonComponent.Enable = false
			self.Button_Capacity_Up.ButtonComponent.Enable = false
			
			-- UI를 갱신합니다. ---------------------------
			hammer.Enable = false
			
			self.Text_Upgrade_Cost.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 0.2)
			self.Button_Capacity_Up.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 0.2)
			
		end
	end

end