@Component
script Kiosk_SellButton extends Component

	@HideFromInspector
	property Kiosk KioskUI = "23851c63-3b13-434a-9fcd-9bc6dd20ef5b"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		-- 클릭하면 아이템을 판매합니다. ------------
		
		-- 통신합니다. ================
		_TransferService:Transfer("in")
		--=============================
		
		-- 아이템 판매 -------
		_KioskService:SellItem(player,self.KioskUI.Inventory_Sell_Name, self.KioskUI.Inventory_Sell_Quantity)
		
		-- 이펙트 재생 -------
		_SoundService:PlaySound("6d8fe3cedcf0434883bb4469c1697d7e", 0.9)
		
		_UIToast:ShowMessage(_LocalizationService.LocalTranslator:GetText("Popup_sellClear"))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end