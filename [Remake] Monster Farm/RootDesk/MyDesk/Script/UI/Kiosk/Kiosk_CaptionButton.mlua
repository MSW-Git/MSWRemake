@Component
script Kiosk_CaptionButton extends Component

	@HideFromInspector
	property Kiosk UI_Kiosk = "23851c63-3b13-434a-9fcd-9bc6dd20ef5b"

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		-- 수량을 확정한 아이템을 판매합니다. ----------------
		if tostring(state) == "Clicked" then
			self.UI_Kiosk:PutItemToKiosk()
		end
	end

end