@Component
script Kiosk_SortButton extends Component

	property string Type = ""

	@HideFromInspector
	property Kiosk KioskUI = "23851c63-3b13-434a-9fcd-9bc6dd20ef5b"

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 가판대에 필터링을 적용합니다. --------------
		self.KioskUI:FilteringInventoryItem(self.Type)
		-----------------------------------------------
		
		
		-- 해당 정렬 버튼을 강조합니다. ---------------
		local List = self.Entity.Parent.Children
			
		for i = 1, #List do
			if List[i] == self.Entity then
				self.KioskUI:RefreshSortButtonStatus(i)
				break
			end
		end
		-----------------------------------------------
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		-- 클릭한 아이템 표시
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end