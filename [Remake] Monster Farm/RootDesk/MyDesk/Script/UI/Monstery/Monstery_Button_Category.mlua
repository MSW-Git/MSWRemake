@Component
script Monstery_Button_Category extends Component

	@HideFromInspector
	property Entity MonsterUI = "079e91cb-df36-4888-98d3-949740870887"

	property string Type = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		
		self.MonsterUI.Monstery:SwitchCategory(self.Type)
	end

end