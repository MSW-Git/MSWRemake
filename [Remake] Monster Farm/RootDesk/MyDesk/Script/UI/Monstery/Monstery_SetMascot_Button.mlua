@Component
script Monstery_SetMascot_Button extends Component

	property Entity MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		-- 버튼의 타입에 따라 몬스터와 다른 상호작용을 합니다. ------------------------------------
		local idx = self.MonsteryUI.Monstery.ShowMonsterIDX
		
		if player.PlayerData.MInventory_MascotPet_Id == idx then
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
		
			_MascotService:SetMascot(player, 0, true, true)
			
		else
			
			local yes = function()
					
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
				
			_MascotService:SetMascot(player, idx, true, true)
				
			end
			
			local no = function() end
			
			local Popup_mascot = _LocalizationService.LocalTranslator:GetText("Popup_mascot")
			local Popup_mascot_Detail = "\n\n <color=#8285ad> ".._LocalizationService.LocalTranslator:GetText("Popup_mascot_Detail").."</color>"
			_UIPopup:Open(Popup_mascot..Popup_mascot_Detail, yes, no, nil)
			
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end