@Component
script Monstery_InteractionButton extends Component

	property string Type = ""

	@HideFromInspector
	property Entity MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		 
		
		-- 버튼의 타입에 따라 몬스터와 다른 상호작용을 합니다. ------------------------------------
		local idx = self.MonsteryUI.Monstery.ShowMonsterIDX
		
		
		-- 몬스터를 소환 / 회수합니다. ------------------------------------------------------------
		if self.Type == "summon" then
			
			-- 몬스터를 회수합니다. --
			if player.PlayerData.Minventory_Summoned[idx] then
				
				-- 통신합니다. ================
				_TransferService:Transfer("in")
				--=============================
				
				_MonsterService:DestroyMonster(player, idx)
				_SoundService:PlaySound("029be48569da47e99012b93a23f1b64d", 1)
				
			-- 몬스터를 소환합니다. --
			else
			
				-- 소환할 공간이 있다면
				local playerSummoned = _PlayerService:Check_Monster_Summoned(player)
				if playerSummoned < player.PlayerData.MaxSummon then
					
					-- 통신합니다. ================
					_TransferService:Transfer("in")
					--=============================
				
					_MonsterService:SummonMonster(player, idx, false, Vector3(0,0,0), true)
					_SoundService:PlaySound("029be48569da47e99012b93a23f1b64d", 1)
				-- 소환할 공간이 없다면
				else
					_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_alert_Summon_Capacity"), nil, nil, nil)
				end
				
			end
			
			
			
		-- 몬스터와 작별합니다. -------------------------------------------------------------------
		elseif self.Type =="release" then
			
			local monster = _EntityService:GetEntity(player.PlayerData.Minventory_Entity[idx])
			
			local yes = function() 
				
				-- 통신합니다. ================
				_TransferService:Transfer("in")
				--=============================
				
				_MonsterService:ClearMonster(player, player.PlayerData.Minventory_UniqueID[idx], monster)
				
				-- 마지막 IDX의 몬스터와 작별한 경우라면 ------------------------
				if idx == #player.PlayerData.Minventory_Id then
					self.MonsteryUI.Monstery.ShowMonsterIDX = idx - 1
				end
			end
			
			local no = function()
			
			end
			
			_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_notification_Farewell"), yes, no, nil)	
			
			
		-- 간식 주기 UI를 엽니다.  -----------------------------------------------------------------
		elseif self.Type == "feed" then
			--self.MonsteryUI.Monstery:OpenFeedUI()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end