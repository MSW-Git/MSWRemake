@Component
script MonsteryItem extends Component

	property number Idx = 0

	property Monstery MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	@ExecSpace("ClientOnly")
	method void RefreshInfo()
		local player = _UserService.LocalPlayer
		
		local highLight_Image = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Highlight")
		
		highLight_Image.Enable = (self.MonsteryUI.ShowMonsterIDX == self.Idx)
		
		local mascotUI = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Mascot")
		mascotUI.Enable = (player.PlayerData.MInventory_MascotPet_Id == self.Idx)
		
		local monsterGrade = player.PlayerData.Minventory_Grade[self.Idx]
		if not isvalid(monsterGrade) then
			self.Entity:Destroy()
			return
		end
		
		local monster_ID = player.PlayerData.Minventory_Id[self.Idx] 
		if not isvalid(monster_ID) then
			self.Entity:Destroy()
			return
		end
		
		-- ŪēīŽčĻ MonsteržĚė ž†ēŽ≥īŽ•ľ ÍįĪžč†Ūē©ŽčąŽč§. ---------------------------------------------------------------------
		
		local text_Level = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Grade/UI_Level")
		
		local image_Monster = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Mask/Image_Monster")
		local image_Grade = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Grade")
		local text_Generation = _EntityService:GetEntityByPath(self.Entity.Path.."/UI_Generation")
		
		
		-- MonsteržĚė LevelžĚĄ ŽįėžėĀŪē©ŽčąŽč§. --
		
		local monster_Level = math.floor(player.PlayerData.Minventory_Level[self.Idx])
		
		
		if player.PlayerData.Minventory_Summoned[self.Idx] then
			local summonText = _LocalizationService.LocalTranslator:GetText("UI_summoned")
			text_Level.TextComponent.Text = "Lv."..tostring(monster_Level).." <color=#bcbec5>"..summonText.."</color>"
		else
			text_Level.TextComponent.Text = "Lv."..tostring(monster_Level)
		end
		
		-- MonsteržĚė GradeŽ•ľ ŽįėžėĀŪē©ŽčąŽč§. --
		
		if monsterGrade == _MonsterService.Grade_0_Name then
			image_Grade.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_0_Color)
		
		elseif monsterGrade == _MonsterService.Grade_1_Name then
			image_Grade.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_1_Color)
		
		elseif monsterGrade == _MonsterService.Grade_2_Name then
			image_Grade.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_2_Color)
		
		elseif monsterGrade == _MonsterService.Grade_3_Name then
			image_Grade.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_3_Color)
		
		elseif monsterGrade == _MonsterService.Grade_4_Name then
			image_Grade.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_4_Color)
			
		elseif monsterGrade == _MonsterService.Grade_5_Name then
			image_Grade.SpriteGUIRendererComponent.Color = Color.FromHexCode(_MonsterService.Grade_5_Color)
		end
			
		-- MonsteržĚė žĄłŽĆÄŽ•ľ ŽįėžėĀŪē©ŽčąŽč§. --
		local MonsterGeneration = tonumber(_DataService:GetCell("MonsterDataSet_Base", monster_ID, "generation"))
		
		if MonsterGeneration == 1 then
			text_Generation.TextComponent.Text = "‚ėÖ<color=#c8c8c8>‚ėÖ‚ėÖ‚ėÖ‚ėÖ</color>"
			
		elseif MonsterGeneration == 2 then
			text_Generation.TextComponent.Text = "‚ėÖ‚ėÖ<color=#c8c8c8>‚ėÖ‚ėÖ‚ėÖ</color>"
			
		elseif MonsterGeneration == 3 then
			text_Generation.TextComponent.Text = "‚ėÖ‚ėÖ‚ėÖ<color=#c8c8c8>‚ėÖ‚ėÖ</color>"
			
		elseif MonsterGeneration == 4 then
			text_Generation.TextComponent.Text = "‚ėÖ‚ėÖ‚ėÖ‚ėÖ<color=#c8c8c8>‚ėÖ</color>"
			
		elseif MonsterGeneration == 5 then
			text_Generation.TextComponent.Text = "‚ėÖ‚ėÖ‚ėÖ‚ėÖ‚ėÖ"
		end
		
		
		-- MonsteržĚė RUIDŽ•ľ ŽįėžėĀŪē©ŽčąŽč§. --
		local dataSetName = "MonsterDataSet_Base"
		
		image_Monster.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(dataSetName, monster_ID, "ruid")
		image_Monster.SpriteGUIRendererComponent.EndFrameIndex = 0
		
		
		local mon_x = tonumber(_DataService:GetCell("MonsterDataSet_UI", monster_ID, "Thumbnail_x"))
		local mon_y = tonumber(_DataService:GetCell("MonsterDataSet_UI", monster_ID, "Thumbnail_y"))
		
		image_Monster.SpriteGUIRendererComponent.LocalScale = Vector2(mon_x, mon_y)
		
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		local UI_Lab = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Monster_Left/UI_Lab")
		
		self.MonsteryUI.ShowMonsterIDX = self.Idx
		
		self.MonsteryUI:RefreshShowMonsterInfo()
		
		if UI_Lab.Enable then
			self.MonsteryUI:RefreshLaboratory_Info()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end