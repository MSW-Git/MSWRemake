@Component
script Monstery extends Component

	property Entity Image_ShowUI_LevelMax = "3213ec38-9982-48ba-b1cb-a7fdacc122e1"

	property number ShowMonsterIDX = 1

	property Entity Item = "a498192e-178f-4e03-a7e3-fe42001d4859"

	property Entity List = "33815764-ee03-4e49-a42a-4a65a771d1cf"

	property Entity UI_ShowUI_Contents = "1652b5fd-05c7-4a5b-bfc6-870114238e57"

	property Entity UI_ShowUI_MonsterProfile = "018ce89e-7b6d-43ae-bfa9-82552d6c7344"

	property Entity ShowUI_Monster = "de243630-d5f7-4e46-9619-76620ef7cb3e"

	property SliderComponent Gauge_ShowUI_Level = "f5b5d559-5f67-428f-ab10-61b222536db0"

	property Entity Button_ShowUI_Summon = "6333b610-227b-48c2-9c6b-f1c7d5ffad42"

	property Entity Button_ShowUI_Release = "6d57749a-9583-4598-a5d6-751c68ab1fec"

	property Entity Button_ShowUI_SetMascot = "dd981f37-6e46-4bd3-aef1-33dda3890f1f"

	property Entity Image_Title = "b5dcf169-e951-4f76-a395-82177dc77235"

	property Entity Text_Personality = "be14e07a-5696-43c0-bf63-b31bc486491f"

	property Entity Text_Skill = "2f7c89b4-dd01-41ce-a3eb-84c9a457fb51"

	property Entity Text_Skill_Info = "820e7884-c5f4-418f-ba5a-a3af4a30d530"

	property Entity Text_Skill_Icon = "0b440d98-6c79-4a67-b5ab-c4ab95de9e28"

	property Entity Image_MonsterItem = "cb19ac81-7654-4af8-93ca-62f1e6820414"

	property Entity Text_Item_Percent = "a1df9690-3e23-4c6e-b587-1aee492e1435"

	property Entity Text_Gold_Percent = "e67b51dd-6f59-4779-bd4f-1cdda217046d"

	property Entity Text_Berry_Percent = "455da881-f21f-4dea-b061-6a6f1cc593a3"

	property Entity Text_Ruby_Percent = "f5dafc4d-96d3-42b1-a4ed-54b652a4af63"

	property Entity Text_Gold_Quantity = "182e01ea-19e2-419d-8d69-0bd5366ed2c4"

	property Entity Text_Item_Quantity = "7ca36b90-ea40-44d8-83c7-7f61e8163ebd"

	property Entity Text_Berry_Quantity = "b45061d4-7ab2-45d3-83b5-bad9e0a0b73b"

	property Entity Text_Ruby_Quantity = "ac03c21f-8e2b-4500-8fe2-60bdb7eca66c"

	property number Grade_Gold_Item_Quantity_Buff = 0

	property number Grade_Item_Chance_Buff = 0

	property number Skill_Gold_QuantityBuff = 0

	property number Skill_Berry_Chance_Buff = 0

	property number Skill_Berry_Quantity_Buff = 0

	property number Skill_Ruby_Chance_Buff = 0

	property number Skill_Ruby_Quantity_Buff = 0

	property number Gold_Quantity = 0

	property Entity Text_Gold_Quantity_Detail = "fc310bd9-48c4-47d1-aae2-13edfde94346"

	property Entity Text_Gold_Bonus_Quantity_Detail = "99d04951-d3ee-4b8f-9ae2-0b114c78fff7"

	property Entity Text_Item_Quantity_Detail = "8843dc8d-824f-4ee1-8f65-fc07f027e43c"

	property Entity Text_Item_Percent_Detail = "fce07587-f2f6-4700-ad67-9d8ced353021"

	property Entity Text_Item_Bonus_Quantity_Detail = "3ba69c56-fb53-4279-ae8c-64c2fa4b7e53"

	property Entity Text_Item_Bonus_Percent_Detail = "48561be6-e6a4-49c8-b88c-494903357daf"

	property Entity Text_Berry_Quantity_Detail = "ac9059eb-efb3-413c-a4ba-c3ef224f7e05"

	property Entity Text_Berry_Percent_Detail = "92794304-384b-43ff-9213-8787343f4ba2"

	property Entity Text_Berry_Bonus_Quantity_Detail = "7d288812-0fb1-4a67-919a-d12942d22b0c"

	property Entity Text_Berry_Bonus_Percent_Detail = "eed42403-7e3f-458d-aa49-52771d2dd7ad"

	property Entity Text_Ruby_Quantity_Detail = "e755641e-5fbe-46c7-8d1d-570d8c3ef475"

	property Entity Text_Ruby_Percent_Detail = "013788f6-40c3-488b-b7d8-c8fb8046a785"

	property Entity Text_Ruby_Bonus_Quantity_Detail = "e81d3646-caf1-448e-ba41-e7ee44bd6601"

	property Entity Text_Ruby_Bonus_Percent_Detail = "004e5998-d492-4cb2-a379-5824f1eecc98"

	property Entity Text_ProductTime = "4b61bcbe-8ccd-4e2f-9d15-a35825ffe7e2"

	property number base_Gold_Quantity = 0

	property Entity UI_Basic_Info = "4be9abf7-3819-4c6d-b62f-45bf8e65710d"

	property Entity UI_Detail_Info = "a5c427fc-a868-4736-94f0-838a722ecb34"

	property Entity UI_Basic_Info_Button = "6644681a-d1a2-4617-95a0-b3fd2475e641"

	property Entity UI_Detail_Info_Button = "9d0611e0-6890-43bf-bcf7-5cb65339ea36"

	property number Skill_GoldQuantity = 0

	property Entity UI_Berry = "53cbadf1-0e17-49da-8b03-7f9877a0c99e"

	property Entity UI_Ruby = "14f3939e-87b1-46f8-a642-ccc258c3ed8b"

	property Entity UI_Detail_Berry = "1f997fc6-9a77-4ff1-b300-aeebe409f2ed"

	property Entity UI_Detail_Ruby = "d95ef22c-7a17-4484-b24f-101b3375faca"

	property Entity Image_Item_Detail = "4d5c183d-59c0-4c9b-b44e-ab32bca6583b"

	property number base_Gold_Quantity_Only_Generation = 0

	property Entity UI_Lock = "5630d8e0-ce13-4501-ac1b-0253e798b37d"

	property Entity UI_Normal = "2e7f3229-3f1b-4b98-b3e3-1b807f6e4c5a"

	property Entity UI_Lab = "754fded4-9ce8-40d9-8d91-1325364f3ff9"

	property TextComponent Text_Progress_Lab = "3549d6cc-88cd-4ed8-a5f9-b03610202767"

	property TextComponent Text_Cur_Filtering = "877a3110-fdb2-4040-bd63-3a3b393916f8"

	property Entity List_Filter = "b72bd68d-0203-40fa-bc43-da6d3ddff035"

	property string Cur_Filter = "Recent_Get"

	property Entity Image_Filter_Block_Background = "aebd1726-168f-4b20-a1c0-99e728271a59"

	@ExecSpace("ClientOnly")
	method void Open()
		self:SwitchContents("Monster")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.ShowMonsterIDX = 1
		self.Text_Progress_Lab.Text = ""
		self.UI_Lock.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void RefreshItem()
		local player = _UserService.LocalPlayer
		local list_Children = self.List.Children
		
		-- Item을 생성합니다. --------------------------------------
		for x = #list_Children, #player.PlayerData.Minventory_Id do
			local clonedItem = self.Item:Clone("item"..tostring(x))
		
		end
		
		list_Children = self.List.Children
		
		for i = 2, #self.List.Children do
			if list_Children[i].MonsteryItem.Idx == 0 then
				list_Children[i].MonsteryItem.Idx = i - 1
			end
		end
		
		
		-- 보유한 몬스터가 있을 때만 UI를 갱신합니다. --------------
		if #player.PlayerData.Minventory_Id > 0 then
				
			self.UI_ShowUI_MonsterProfile.Enable = true
			self.UI_ShowUI_Contents.Enable = true
			
			-- 몬스터의 정보를 보여줍니다. ----------
			self:RefreshShowMonsterInfo()
			-----------------------------------------
		else
			self.UI_ShowUI_MonsterProfile.Enable = false
			self.UI_ShowUI_Contents.Enable = false
		end
		
		self:Set_Filter(self.Cur_Filter)
		
		if self.UI_Lock.Enable then
			self.UI_Lock.Enable = false
		end
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshShowMonsterInfo()
		local player = _UserService.LocalPlayer
		
		if #player.PlayerData.Minventory_Id == 0 then
			return
		end
		
		local dataSetName = "MonsterDataSet_Base"
		
		local Normal_UI = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Monster_Left/UI_Normal")
		
		-- 해당 IDX에 몬스터 정보가 없을 경우 --------------------------------------
		if not isvalid(player.PlayerData.Minventory_Id[self.ShowMonsterIDX]) then
			log("Monster IDX Error.")
			self.ShowMonsterIDX = 1
			return
		end
		
		-- 해당 몬스터 아이템을 강조 표시 합니다. ----------------------------------
		self:HightLightItem()
		
		
		local monsterGrade = player.PlayerData.Minventory_Grade[self.ShowMonsterIDX]
		local monsterPersonality = player.PlayerData.Minventory_Personality[self.ShowMonsterIDX]
		local monsterSkill = player.PlayerData.Minventory_Skill_Id[self.ShowMonsterIDX]
		local monsterGeneration = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "generation"))
		local monsterLevel = player.PlayerData.Minventory_Level[self.ShowMonsterIDX]
		
		-- 몬스터 등급 / 스킬 공식을 가져옵니다. ----------------------------------
		self:Give_Stat_ByGrade(monsterGrade)
		self:Give_Stat_BySkill(player, monsterSkill, self.ShowMonsterIDX)
		self.Gold_Quantity = self:Get_Money_By_Type(monsterLevel, monsterGrade, monsterGeneration)
		
		-- 몬스터의 정보를 표시합니다. ---------------------------------------------
		local monsterName = _LocalizationService.LocalTranslator:GetText(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "name"))
		local monsterName_Text = monsterName
		
		-- 몬스터의 세대를 표시합니다. ---------------------------------------------
		local generationText = _LocalizationService.LocalTranslator:GetTextFormat("UI_generation", monsterGeneration)
		local monsterGenerationText = "<color=#adf7ff>"..generationText.."</color>"
		
		-- 몬스터의 등급을 표시합니다. ---------------------------------------------
		
		local monsterGrade_Color = ""
		
		if monsterGrade == _MonsterService.Grade_0_Name then
			monsterGrade_Color = _MonsterService.Grade_0_Color
			
		elseif monsterGrade == _MonsterService.Grade_1_Name then
			monsterGrade_Color = _MonsterService.Grade_1_Color
			
		elseif monsterGrade == _MonsterService.Grade_2_Name then
			monsterGrade_Color = _MonsterService.Grade_2_Color
			
		elseif monsterGrade == _MonsterService.Grade_3_Name then
			monsterGrade_Color = _MonsterService.Grade_3_Color
			
		elseif monsterGrade == _MonsterService.Grade_4_Name then
			monsterGrade_Color = _MonsterService.Grade_4_Color
			
		elseif monsterGrade == _MonsterService.Grade_5_Name then
			monsterGrade_Color = _MonsterService.Grade_5_Color
		end
		
		local monsterGradeName = _LocalizationService.LocalTranslator:GetText(monsterGrade)
		local monsterGradeText = "<color="..monsterGrade_Color..">"..monsterGradeName.."</color>"
		
		-- 몬스터의 레벨을 표시합니다. ---------------------------------------------
		local monsterLevelText = "<color=#adf7ff>Lv."..tostring(math.floor(monsterLevel)).."</color>"
		
		local text_Name = _EntityService:GetEntity("d9b6165a-8331-420a-87ff-45440c082dbf") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Name
		local text_Generation = _EntityService:GetEntity("c4eaf16a-71f1-46e2-87e5-af21b92d3c94") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Generation
		local text_Grade = _EntityService:GetEntity("971d514f-bfa2-4557-9b66-106bd7da3309") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Grade
		local text_Level = _EntityService:GetEntity("be999df5-f1bb-4dc0-91b2-65eea90873e6") -- /ui/MonsterGroup/UI_Monster_Left/Text_Status/Button_Level
		
		text_Name.TextComponent.Text = monsterName_Text
		text_Generation.TextComponent.Text = monsterGenerationText
		text_Grade.TextComponent.Text = monsterGradeText
		text_Level.TextComponent.Text = monsterLevelText
		
		-- 만렙이면 MAX 이미지를 표시합니다. ---------------------------------------
		self.Image_ShowUI_LevelMax.ButtonComponent.Enable = (monsterLevel >= _MonsterService.MonsterMaxLevel) 
		
		-- Exp 게이지를 표시합니다. -----------------------------------------------
		local exp = player.PlayerData.Minventory_Exp[self.ShowMonsterIDX]
		local mexp = player.PlayerData.Minventory_Mexp[self.ShowMonsterIDX]
		
		if player.PlayerData.Minventory_Level[self.ShowMonsterIDX] >= _MonsterService.MonsterMaxLevel then
			self.Gauge_ShowUI_Level.Value = 0
		else
			self.Gauge_ShowUI_Level.Value = exp/mexp
		end
		
		
		-- 몬스터의 이미지를 표시합니다. ------------------------------------------
		self.ShowUI_Monster.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "ruid")
		
		
		-- 몬스터의 Scale을 반영합니다. -------------------------------------------
		
		local mon_x = tonumber(_DataService:GetCell("MonsterDataSet_UI", player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "Thumbnail_x"))
		local mon_y = tonumber(_DataService:GetCell("MonsterDataSet_UI", player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "Thumbnail_y"))
		
		self.ShowUI_Monster.SpriteGUIRendererComponent.LocalScale = Vector2(mon_x, mon_y)
		
		self.ShowUI_Monster.SpriteGUIRendererComponent.EndFrameIndex = 0
		
		
		if not Normal_UI.Enable then
			return
		end
		
		-- 몬스터의 성격을 표시합니다. ---------------------------------------------
		
		local personalityName = ""
		
		if monsterPersonality == 0 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_0_Name)
			
		elseif monsterPersonality == 1 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_1_Name)
			
		elseif monsterPersonality == 2 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_2_Name)
			
		elseif monsterPersonality == 3 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_3_Name)
			
		elseif monsterPersonality == 4 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_4_Name)
			
		elseif monsterPersonality == 5 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_5_Name)
			
		elseif monsterPersonality == 6 then
			personalityName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Personality_6_Name)
		end 
		
		self.Text_Personality.TextComponent.Text = personalityName
		
		-- 몬스터의 스킬을 표시합니다. ---------------------------------------------
		
		local monsterSkillName = ""
		local monsterSkillInfo = ""
		local monsterSkillRUID = ""
		local monsterSkill_Grade = _LocalizationService.LocalTranslator:GetText(player.PlayerData.Minventory_Grade[self.ShowMonsterIDX])
		
		if monsterSkill == 0 then
			monsterSkillName = _LocalizationService.LocalTranslator:GetText("Stat_skill_none")
			monsterSkillInfo = _LocalizationService.LocalTranslator:GetText("Stat_skill_none_info")
			monsterSkillRUID = "9020e3c8b9f346b09d244b01cfe30a59"
			
		elseif monsterSkill == 1 then
			monsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_1_Name)
			monsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_1_Info, math.floor(self.Skill_Berry_Chance_Buff))
			monsterSkillRUID = _MonsterService.Skill_1_RUID
			
		elseif monsterSkill == 2 then
			monsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_2_Name)
			monsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_2_Info, math.floor(self.Skill_Berry_Quantity_Buff))
			monsterSkillRUID = _MonsterService.Skill_2_RUID
			
		elseif monsterSkill == 3 then
			monsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_3_Name)
			monsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_3_Info, math.floor(self.Skill_Ruby_Chance_Buff))
			monsterSkillRUID = _MonsterService.Skill_3_RUID
			
		elseif monsterSkill == 4 then
			monsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_4_Name)
			monsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_4_Info, math.floor(self.Skill_Ruby_Quantity_Buff))
			monsterSkillRUID = _MonsterService.Skill_4_RUID
			
		elseif monsterSkill == 5 then
			monsterSkillName = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_5_Name)
			monsterSkillInfo = _LocalizationService.LocalTranslator:GetTextFormat(_MonsterService.Skill_5_Info, math.floor(self.Skill_Gold_QuantityBuff))
			monsterSkillRUID = _MonsterService.Skill_5_RUID
		end
		
		if monsterSkill ~= 0 then 
			self.Text_Skill.TextComponent.Text = monsterSkillName.." ["..monsterSkill_Grade.."]"
			self.Text_Skill_Info.TextComponent.Text = monsterSkillInfo
		else
			self.Text_Skill.TextComponent.Text = monsterSkillName
			self.Text_Skill_Info.TextComponent.Text = monsterSkillInfo
		end
		
		self.Text_Skill_Icon.SpriteGUIRendererComponent.ImageRUID = monsterSkillRUID
		
		-- 해당 몬스터가 '마스코트' 상태인지 확인합니다. ---------------------------
		if player.PlayerData.MInventory_MascotPet_Id == self.ShowMonsterIDX then
			self.Button_ShowUI_SetMascot.TextComponent.FontColor = Color.FromHexCode("#d88080")
		else
			self.Button_ShowUI_SetMascot.TextComponent.FontColor = Color(0, 0, 0, 0.2)
		end
		
		-- 소환 상태에 따라 버튼 상태를 다르게 설정합니다. -------------------------
		
		-- 농장에서만 버튼이 활성화되게 합니다.
		self.Button_ShowUI_Summon.Enable = (player.CurrentMapName == "farm") 
		self.Button_ShowUI_Release.Enable = (self.Cur_Filter == "Recent_Get") 
		self.Image_Title.Enable = (player.CurrentMapName == "farm")
		 
		if player.PlayerData.Minventory_Summoned[self.ShowMonsterIDX] then
			local bringBackText = _LocalizationService.LocalTranslator:GetText("UI_bringBack")
			self.Button_ShowUI_Summon.TextComponent.Text = bringBackText
			self.Button_ShowUI_Summon.SpriteGUIRendererComponent.Color = Color(147/255, 54/255, 77/255, 1)
		else
			local summonText = _LocalizationService.LocalTranslator:GetText("UI_summon")
			self.Button_ShowUI_Summon.TextComponent.Text = summonText
			self.Button_ShowUI_Summon.SpriteGUIRendererComponent.Color = Color(132/255, 136/255, 51/255, 1)
		end
		
		
		
		-- 골드 확률 공식 ----------------------------------------------------------------------------------
		local monsterGoldText_Percent = _LocalizationService.LocalTranslator:GetTextFormat("UI_percent", math.floor(_MonsterService.Origin_Gold_Chance))
		
		-- 생산품 확률 공식 --------------------------------------------------------------------------------
		local origin_Item_Chance = _MonsterService.Origin_Item_Chance 
		local grade_Item_Chance = _MonsterService.Origin_Item_Chance * (self.Grade_Item_Chance_Buff * 0.01)
		local monsterItemText_Percent = _LocalizationService.LocalTranslator:GetTextFormat("UI_percent", math.ceil(origin_Item_Chance + grade_Item_Chance)) 
		----------------------------------------------------------------------------------------------------
		
		
		-- 베리 확률 공식 ----------------------------------------------------------------------------------
		local origin_Berry_Chance = _MonsterService.Origin_Berry_Chance -- 10 
		local skill_Berry_Chance = _MonsterService.Origin_Berry_Chance * (self.Skill_Berry_Chance_Buff * 0.01)
		local monsterBerryText_Percent = _LocalizationService.LocalTranslator:GetTextFormat("UI_percent", math.ceil(origin_Berry_Chance + skill_Berry_Chance))
		----------------------------------------------------------------------------------------------------
		
		
		-- 루비 생산 확률 공식 -----------------------------------------------------------------------------
		local origin_Ruby_Chance = _MonsterService.Origin_Ruby_Chance 
		local skill_Ruby_Chance = _MonsterService.Origin_Ruby_Chance * (self.Skill_Ruby_Chance_Buff * 0.01)
		local monsterRubyText_Percent =  _LocalizationService.LocalTranslator:GetTextFormat("UI_percent", math.ceil(origin_Ruby_Chance + skill_Ruby_Chance))
		----------------------------------------------------------------------------------------------------
		
		-- 텍스트 반영 ------------------------------------------------------
		self.Text_Gold_Percent.TextComponent.Text = monsterGoldText_Percent
		self.Text_Item_Percent.TextComponent.Text = monsterItemText_Percent
		self.Text_Berry_Percent.TextComponent.Text = monsterBerryText_Percent
		self.Text_Ruby_Percent.TextComponent.Text = monsterRubyText_Percent
		---------------------------------------------------------------------
		
		-- 생산품 이미지 반영 -----------------------------------------------
		local item_ID = tonumber(_DataService:GetCell(dataSetName, player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "product"))
		self.Image_MonsterItem.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", item_ID - 20000, "ruid")
		self.Image_Item_Detail.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", item_ID - 20000, "ruid") 
		---------------------------------------------------------------------
		
		
		local monsterRubyQuantity = math.ceil(self.base_Gold_Quantity / (_MonsterService.Origin_ExpQuantity_Ruby * 0.1)) 
		
		local monsterberryQuantity = math.ceil(self.base_Gold_Quantity / (_MonsterService.Origin_ExpQuantity_Berry * 0.1))
		
		local berrySkillQuantity =  math.ceil((monsterberryQuantity * self.Skill_Berry_Quantity_Buff * 0.01))
		
		local berryQuantity = monsterberryQuantity + berrySkillQuantity
		
		local rubySkillQuantity = math.ceil((monsterRubyQuantity * self.Skill_Ruby_Quantity_Buff * 0.01))
		local rubyQuantity = monsterRubyQuantity + rubySkillQuantity
		
		-- 몬스터의 생산량 반영 ---------------------------------------------
		self.Text_Gold_Quantity.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(self.Gold_Quantity)
		self.Text_Item_Quantity.TextComponent.Text = "x 1"
		self.Text_Berry_Quantity.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(berryQuantity)
		self.Text_Ruby_Quantity.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(rubyQuantity)
		---------------------------------------------------------------------
		
		self.UI_Berry.Enable = (monsterGeneration >= 2)
		self.UI_Detail_Berry.Enable = (monsterGeneration >= 2)
		
		self.UI_Ruby.Enable = (monsterGeneration >= 3)
		self.UI_Detail_Ruby.Enable = (monsterGeneration >= 3)
		
		
		---------------------------------------------------------------------
		-- 세부 정보를 갱신합니다.
		---------------------------------------------------------------------
		
		self.Text_ProductTime.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_speedForProducing", math.floor(_MonsterService.Origin_Product_Time))
		
		-- 골드 --
		self.Text_Gold_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalQuantity", _SystemService:ThousandsSeparator(self.base_Gold_Quantity))
		self.Text_Gold_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusQuantity", _SystemService:ThousandsSeparator(self.Gold_Quantity - self.base_Gold_Quantity))
		
		-- 아이템 --
		self.Text_Item_Quantity_Detail.TextComponent.Text =  _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalQuantity", "1")
		self.Text_Item_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalPercent", math.floor(_MonsterService.Origin_Item_Chance))
		self.Text_Item_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusQuantity", "0")
		self.Text_Item_Bonus_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusPercent", math.floor(self.Grade_Item_Chance_Buff))
		
		-- 베리 --
		local base_berry = self.base_Gold_Quantity_Only_Generation / (_MonsterService.Origin_ExpQuantity_Berry * 0.1)
		self.Text_Berry_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalQuantity", _SystemService:ThousandsSeparator(base_berry))
		self.Text_Berry_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusQuantity", _SystemService:ThousandsSeparator(berryQuantity - base_berry))
		
		self.Text_Berry_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalPercent", math.floor(origin_Berry_Chance))
		self.Text_Berry_Bonus_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusPercent", math.floor(self.Skill_Berry_Chance_Buff))
		
		
		-- 루비 --
		local base_ruby = self.base_Gold_Quantity_Only_Generation / (_MonsterService.Origin_ExpQuantity_Ruby * 0.1)
		self.Text_Ruby_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalQuantity", _SystemService:ThousandsSeparator(base_ruby))
		self.Text_Ruby_Bonus_Quantity_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusQuantity", _SystemService:ThousandsSeparator(rubyQuantity - base_ruby))
		
		self.Text_Ruby_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productNormalPercent", math.floor(origin_Ruby_Chance))
		self.Text_Ruby_Bonus_Percent_Detail.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_productBonusPercent", math.floor(self.Skill_Ruby_Chance_Buff))
	end

	@ExecSpace("ClientOnly")
	method void HightLightItem()
		local list_Children = self.List.Children
		
		for i = 2, #list_Children do
			list_Children[i].MonsteryItem:RefreshInfo()
		end
	end

	@ExecSpace("ClientOnly")
	method void Give_Stat_ByGrade(string grade)
		local monsterGrade_To_Number = 0
		
		if grade == _MonsterService.Grade_0_Name then
			monsterGrade_To_Number = 0
			
		elseif grade == _MonsterService.Grade_1_Name then
			monsterGrade_To_Number = 1
		
		elseif grade == _MonsterService.Grade_2_Name then
			monsterGrade_To_Number = 2
			
		elseif grade == _MonsterService.Grade_3_Name then
			monsterGrade_To_Number = 3
			
		elseif grade == _MonsterService.Grade_4_Name then
			monsterGrade_To_Number = 4
			
		elseif grade == _MonsterService.Grade_5_Name then
			monsterGrade_To_Number = 5
		end
		
		self.Grade_Gold_Item_Quantity_Buff = tonumber(_DataService:GetCell("MonsterDataSet_Grade_Passive", monsterGrade_To_Number + 1, "gold_Item_QuantityBuff"))
		self.Grade_Item_Chance_Buff = tonumber(_DataService:GetCell("MonsterDataSet_Grade_Passive", monsterGrade_To_Number + 1, "itemChanceBuff"))
		
	end

	@ExecSpace("ClientOnly")
	method void Give_Stat_BySkill(Entity player, number skill_ID, number idx)
		if skill_ID == 0 then
			self.Skill_Gold_QuantityBuff = 0
			self.Skill_Berry_Chance_Buff = 0
			self.Skill_Berry_Quantity_Buff = 0 
			self.Skill_Ruby_Chance_Buff = 0
			self.Skill_Ruby_Quantity_Buff = 0
			return
		end
		
		local effectValue = 1
		if player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_1_Name then
			effectValue = _MonsterService.Skill_Grade_1_Effect
			
		elseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_2_Name then 
			effectValue = _MonsterService.Skill_Grade_2_Effect
			
		elseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_3_Name then 
			effectValue = _MonsterService.Skill_Grade_3_Effect
			
		elseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_4_Name then 
			effectValue = _MonsterService.Skill_Grade_4_Effect
			
		elseif player.PlayerData.Minventory_Grade[idx] == _MonsterService.Grade_5_Name then 
			effectValue = _MonsterService.Skill_Grade_5_Effect
		end
		
		self.Skill_Gold_QuantityBuff = tonumber(_DataService:GetCell("MonsterDataSet_Skill_Passive", skill_ID, "goldQuantityBuff")) * effectValue
		self.Skill_Berry_Chance_Buff = tonumber(_DataService:GetCell("MonsterDataSet_Skill_Passive", skill_ID, "berryChanceBuff")) * effectValue 
		self.Skill_Berry_Quantity_Buff = tonumber(_DataService:GetCell("MonsterDataSet_Skill_Passive", skill_ID, "berryQuantityBuff"))  * effectValue
		self.Skill_Ruby_Chance_Buff = tonumber(_DataService:GetCell("MonsterDataSet_Skill_Passive", skill_ID, "rubyChanceBuff")) * effectValue
		self.Skill_Ruby_Quantity_Buff = tonumber(_DataService:GetCell("MonsterDataSet_Skill_Passive", skill_ID, "rubyQuantityBuff")) * effectValue
	end

	@ExecSpace("ClientOnly")
	method number Get_Money_By_Type(number monLv_arg, string monGrade_arg, number monGeneration_arg)
		--------------------------------------------------------------------------
		-- 자원 기본 생산량과 생산량 증가 비율 
		--------------------------------------------------------------------------
		local origin_GoldQuantity = _MonsterService.Origin_GoldQuantity_Starting
		local origin_GoldQuantity_Ratio = _MonsterService.Origin_GoldQuantity_Ratio
		
		local monsterGeneration = monGeneration_arg - 1
		local monsterLv = monLv_arg - 1
		local PercentByClass = 0
		
		--------------------------------------------------------------------------
		-- 몬스터 등급에 따른 '숨렙'을 가져옵니다.
		--------------------------------------------------------------------------
		if monGrade_arg == _MonsterService.Grade_0_Name then -- 없음 (0)
			PercentByClass = _MonsterService.Grade_0_Hide_Class 
			
		elseif monGrade_arg == _MonsterService.Grade_1_Name then -- 일반 (0)
			PercentByClass = _MonsterService.Grade_1_Hide_Class 
			
		elseif monGrade_arg == _MonsterService.Grade_2_Name then -- 고급 (5)
			PercentByClass = _MonsterService.Grade_2_Hide_Class
			 
		elseif monGrade_arg == _MonsterService.Grade_3_Name then -- 희귀 (10)
			PercentByClass = _MonsterService.Grade_3_Hide_Class 
			
		elseif monGrade_arg == _MonsterService.Grade_4_Name then -- 전설 (15)
			PercentByClass = _MonsterService.Grade_4_Hide_Class
			 
		elseif monGrade_arg == _MonsterService.Grade_5_Name then -- 유일 (20)
			PercentByClass = _MonsterService.Grade_5_Hide_Class 
		end
		
		
		local base_Quantity = origin_GoldQuantity
		local base_Quantity_By_Class = 0
		---------------------------------------------------------------------------
		-- '숨렙'과 '세대 보너스'를 적용합니다.
		---------------------------------------------------------------------------
		for i = 1, monsterGeneration do
			base_Quantity = base_Quantity * _MonsterService.Origin_GoldQuantity_Multiple_By_Generation
		end
		---------------------------------------------------------------------------
		
		self.base_Gold_Quantity_Only_Generation = base_Quantity
		
		base_Quantity_By_Class = base_Quantity * (PercentByClass * 0.01)
		base_Quantity = base_Quantity + base_Quantity_By_Class
		
		---------------------------------------------------------------------------
		-- 골드 생산량 공식을 적용합니다.
		---------------------------------------------------------------------------
		local monLv_Quantity = base_Quantity * (monsterLv * origin_GoldQuantity_Ratio * 0.01)
		
		local resultValue = base_Quantity + monLv_Quantity
		
		
		self.base_Gold_Quantity = resultValue
		
		self.Skill_GoldQuantity = resultValue * (self.Skill_Gold_QuantityBuff * 0.01) 
		
		return (resultValue + self.Skill_GoldQuantity)
	end

	@ExecSpace("ClientOnly")
	method void SwitchCategory(string type)
		if type == "basic" then
			self.UI_Basic_Info.Enable = true
			self.UI_Detail_Info.Enable = false
			self.UI_Basic_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#7072c9")
			self.UI_Detail_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#5a5a7d")
			
		elseif type == "detail" then
			self.UI_Basic_Info.Enable = false
			self.UI_Detail_Info.Enable = true
			self.UI_Basic_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#5a5a7d")
			self.UI_Detail_Info_Button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#7072c9")
		end
	end

	@ExecSpace("ClientOnly")
	method void SwitchContents(string filter)
		if filter == "Monster" then
			self.UI_Normal.Enable = true
			self.UI_Lab.Enable = false
			
			self:RefreshItem()
			self:SwitchCategory("basic")
			self:RefreshCategoryButtons(filter)
		
			
		elseif filter == "Lab" then
			self.UI_Normal.Enable = false
			self.UI_Lab.Enable = true
			
			self:RefreshLaboratory_Info()
			self:RefreshCategoryButtons(filter)
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshLaboratory_Info()
		-- 연구 UI를 Refresh합니다. -----------------
		
		local player = _UserService.LocalPlayer
		
		if #player.PlayerData.Minventory_Id == 0 then
			return
		end
		
		-- 해당 몬스터 아이템을 강조 표시 합니다. ----------------------------------
		self:HightLightItem()
		
		local generation = tonumber(_DataService:GetCell("MonsterDataSet_Base", player.PlayerData.Minventory_Id[self.ShowMonsterIDX], "generation"))
		
		local dataSetName_Grade = "LabDataSet_Grade"
		local dataSetName_Personality = "LabDataSet_Personality"
		local dataSetName_Skill = "LabDataSet_Skill"
		local dataSetName_Script = "LabDataSet_Script"
		
		local lab_Text_Info = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Monster_Left/UI_Lab/UI_Lab_Grade_Info/Text_Grade_Info")
		local ui_Grade = _EntityService:GetEntityByPath(self.UI_Lab.Path.."/UI_Board/UI_Grade")
		local ui_Grade_Text_Info = _EntityService:GetEntityByPath(ui_Grade.Path.."/Text_Info")
		local ui_Grade_Text_Percent = _EntityService:GetEntityByPath(ui_Grade.Path.."/Text_Percent")
		local ui_Grade_Image_Money = _EntityService:GetEntityByPath(ui_Grade.Path.."/Image_Money")
		local ui_Grade_Text_Money = _EntityService:GetEntityByPath(ui_Grade.Path.."/Text_Money") 
		local ui_Grade_Button_Upgrade = _EntityService:GetEntityByPath(ui_Grade.Path.."/Button_Upgrade") 
		 
		local ui_Personality = _EntityService:GetEntityByPath(self.UI_Lab.Path.."/UI_Board/UI_Personality")
		local ui_Personality_Text_Info = _EntityService:GetEntityByPath(ui_Personality.Path.."/Text_Info")
		local ui_Personality_Image_Money = _EntityService:GetEntityByPath(ui_Personality.Path.."/Image_Money")
		local ui_Personality_Text_Money = _EntityService:GetEntityByPath(ui_Personality.Path.."/Text_Money") 
		local ui_Personality_Button_Upgrade = _EntityService:GetEntityByPath(ui_Personality.Path.."/Button_Upgrade") 
		 
		local ui_Skill = _EntityService:GetEntityByPath(self.UI_Lab.Path.."/UI_Board/UI_Skill")
		local ui_Skill_Text_Info = _EntityService:GetEntityByPath(ui_Skill.Path.."/Text_Info")
		local ui_Skill_Image_Money = _EntityService:GetEntityByPath(ui_Skill.Path.."/Image_Money")
		local ui_Skill_Text_Money = _EntityService:GetEntityByPath(ui_Skill.Path.."/Text_Money") 
		local ui_Skill_Button_Upgrade = _EntityService:GetEntityByPath(ui_Skill.Path.."/Button_Upgrade") 
		
		local ui_Lock_Grade = _EntityService:GetEntityByPath(ui_Grade.Path.."/UI_Lock")
		local ui_Lock_Personality = _EntityService:GetEntityByPath(ui_Personality.Path.."/UI_Lock")
		local ui_Lock_Skill = _EntityService:GetEntityByPath(ui_Skill.Path.."/UI_Lock")
		
		--=====================================
		-- 등급 연구 경고 메세지 갱신
		--=====================================
		local grade_1_Text = "<color=".._MonsterService.Grade_1_Color..">".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_1_Name).."</color>"
		local grade_2_Text = "<color=".._MonsterService.Grade_2_Color..">".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_2_Name).."</color>"
		local grade_3_Text = "<color=".._MonsterService.Grade_3_Color..">".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_3_Name).."</color>"
		local grade_4_Text = "<color=".._MonsterService.Grade_4_Color..">".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_4_Name).."</color>"
		local grade_5_Text = "<color=".._MonsterService.Grade_5_Color..">".._LocalizationService.LocalTranslator:GetText(_MonsterService.Grade_5_Name).."</color>"
		
		local info1_Text = _LocalizationService.LocalTranslator:GetTextFormat("UI_lab_info_1", grade_1_Text, grade_2_Text, grade_3_Text, grade_4_Text, grade_5_Text)
		local info2_Text = _LocalizationService.LocalTranslator:GetText("UI_lab_info_2")
		lab_Text_Info.TextComponent.Text = "- "..info1_Text.."\n\n- "..info2_Text
		
		--=====================================
		-- 등급 UI 갱신
		--=====================================
		local grade = player.PlayerData.Minventory_Grade[self.ShowMonsterIDX]
		local grade_HexCode = ""
		local grade_Number = 0 
		if grade == _MonsterService.Grade_0_Name then
			grade_HexCode = _MonsterService.Grade_0_Color
		
		elseif grade == _MonsterService.Grade_1_Name then
			grade_HexCode = _MonsterService.Grade_1_Color
			grade_Number = 1
		elseif grade == _MonsterService.Grade_2_Name then
			grade_HexCode = _MonsterService.Grade_2_Color
			grade_Number = 2
		elseif grade == _MonsterService.Grade_3_Name then
			grade_HexCode = _MonsterService.Grade_3_Color
			grade_Number = 3
		elseif grade == _MonsterService.Grade_4_Name then
			grade_HexCode = _MonsterService.Grade_4_Color
			grade_Number = 4
		elseif grade == _MonsterService.Grade_5_Name then
			grade_HexCode = _MonsterService.Grade_5_Color
			grade_Number = 5
		end
		
		local grade_ID = tonumber(_DataService:GetCell(dataSetName_Grade, generation, "ID"))
		local grade_Quantity = tonumber(_DataService:GetCell(dataSetName_Grade, generation, "Quantity"))
		local grade_Percent = 0
		
		if grade_Number == 5 or generation == 1 then -- 5세대는 연구 불가
			ui_Grade_Text_Percent.Enable = false
		else
			grade_Percent = tonumber(_DataService:GetCell("LabDataSet_Grade_Percent", grade_Number + 1, "percent"))
			ui_Grade_Text_Percent.Enable = true
		end
		
		
		ui_Grade_Text_Percent.TextComponent.Text =  _LocalizationService.LocalTranslator:GetTextFormat("UI_lab_percent", grade_Percent)
		ui_Grade_Text_Info.TextComponent.Text = "<color="..grade_HexCode..">".._LocalizationService.LocalTranslator:GetText(player.PlayerData.Minventory_Grade[self.ShowMonsterIDX]).."</color>"
		ui_Grade_Text_Money.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(grade_Quantity)
		ui_Grade_Image_Money.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", grade_ID - 20000, "ruid")
		
		local grade_isPossible = false
		
		if grade_ID == _PlayerService.Gold_ID then
			if player.PlayerData.Gold >= grade_Quantity then
				grade_isPossible = true
			end	
		elseif grade_ID == _PlayerService.Berry_ID then
			if player.PlayerData.Berry >= grade_Quantity then
				grade_isPossible = true
			end
		elseif grade_ID == _PlayerService.Ruby_ID then
			if player.PlayerData.Ruby >= grade_Quantity then
				grade_isPossible = true
			end
		end
		
		ui_Grade_Text_Money.TextComponent.FontColor = grade_isPossible and Color(1, 1, 1, 0.8) or Color(193/255, 117/255, 117/255, 0.8)
		
		ui_Lock_Grade.Enable = not (generation >= 3)
		
		if grade ~= _MonsterService.Grade_5_Name and grade_isPossible and generation >= 3 then
			ui_Grade_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_lab_enable")
			ui_Grade_Button_Upgrade.ButtonComponent.Enable = true
			ui_Grade_Button_Upgrade.TextComponent.FontColor.a = 1
		else
			ui_Grade_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_lab_disable")
			ui_Grade_Button_Upgrade.ButtonComponent.Enable = false
			ui_Grade_Button_Upgrade.TextComponent.FontColor.a = 0.5
			player.PlayerData.IsHold_Gauge_Grade = false
		end
		
		--=====================================
		-- 성격 UI 갱신
		--=====================================
		local personality = player.PlayerData.Minventory_Personality[self.ShowMonsterIDX]
		local personality_Name = ''
		
		if personality == 0 then
			personality_Name = _MonsterService.Personality_0_Name
			
		elseif personality == 1 then
			personality_Name = _MonsterService.Personality_1_Name
			
		elseif personality == 2 then
			personality_Name = _MonsterService.Personality_2_Name
			
		elseif personality == 3 then
			personality_Name = _MonsterService.Personality_3_Name
			
		elseif personality == 4 then
			personality_Name = _MonsterService.Personality_4_Name
			
		elseif personality == 5 then
			personality_Name = _MonsterService.Personality_5_Name
			
		elseif personality == 6 then
			personality_Name = _MonsterService.Personality_6_Name
		end
		
		local personality_ID = tonumber(_DataService:GetCell(dataSetName_Personality, generation, "ID"))
		local personality_Quantity = tonumber(_DataService:GetCell(dataSetName_Personality, generation, "Quantity"))
		
		ui_Personality_Text_Info.TextComponent.Text = personality_Name
		ui_Personality_Text_Money.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(personality_Quantity)
		ui_Personality_Image_Money.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", personality_ID - 20000, "ruid")
		
		local personality_isPossible = false
		
		if personality_ID == _PlayerService.Gold_ID then
			if player.PlayerData.Gold >= personality_Quantity then
				personality_isPossible = true
			end	
		elseif personality_ID == _PlayerService.Berry_ID then
			if player.PlayerData.Berry >= personality_Quantity then
				personality_isPossible = true
			end
		elseif personality_ID == _PlayerService.Ruby_ID then
			if player.PlayerData.Ruby >= personality_Quantity then
				personality_isPossible = true
			end
		end
		
		ui_Personality_Text_Money.TextComponent.FontColor = personality_isPossible and Color(1, 1, 1, 0.8) or Color(193/255, 117/255, 117/255, 0.8)
		
		ui_Lock_Personality.Enable = not (generation >= 3)
		
		if personality_isPossible and generation >= 3 then
			ui_Personality_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_lab_enable")
			ui_Personality_Button_Upgrade.ButtonComponent.Enable = true
			ui_Personality_Button_Upgrade.TextComponent.FontColor.a = 1
		else
			ui_Personality_Button_Upgrade.TextComponent.Text =  _LocalizationService.LocalTranslator:GetText("UI_lab_disable")
			ui_Personality_Button_Upgrade.ButtonComponent.Enable = false
			ui_Personality_Button_Upgrade.TextComponent.FontColor.a = 0.5
			player.PlayerData.IsHold_Gauge_Personality = false
		end
		
		--=====================================
		-- 스킬 UI 갱신
		--=====================================
		local skill = player.PlayerData.Minventory_Skill_Id[self.ShowMonsterIDX]
		local skill_Name = ''
		local translatedGrade = _LocalizationService.LocalTranslator:GetText(grade)
		if skill == 0 then
			skill_Name = _LocalizationService.LocalTranslator:GetText("Stat_skill_none")
			
		elseif skill == 1 then
			skill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_1_Name).."<color="..grade_HexCode.."> ["..translatedGrade.."]</color>"
			
		elseif skill == 2 then
			skill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_2_Name).."<color="..grade_HexCode.."> ["..translatedGrade.."]</color>"
			
		elseif skill == 3 then
			skill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_3_Name).."<color="..grade_HexCode.."> ["..translatedGrade.."]</color>"
			
		elseif skill == 4 then
			skill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_4_Name).."<color="..grade_HexCode.."> ["..translatedGrade.."]</color>"
			
		elseif skill == 5 then
			skill_Name = _LocalizationService.LocalTranslator:GetText(_MonsterService.Skill_5_Name).."<color="..grade_HexCode.."> ["..translatedGrade.."]</color>"
		end
		
		local skill_ID = tonumber(_DataService:GetCell(dataSetName_Skill, generation, "ID"))
		local skill_Quantity = tonumber(_DataService:GetCell(dataSetName_Skill, generation, "Quantity"))
		
		ui_Skill_Text_Info.TextComponent.Text = skill_Name
		ui_Skill_Text_Money.TextComponent.Text = "x ".._SystemService:ThousandsSeparator(skill_Quantity)
		ui_Skill_Image_Money.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("ItemDataSet_Base", skill_ID - 20000, "ruid")
		
		local skill_isPossible = false
		
		if skill_ID == _PlayerService.Gold_ID then
			if player.PlayerData.Gold >= skill_Quantity then
				skill_isPossible = true
			end	
		elseif skill_ID == _PlayerService.Berry_ID then
			if player.PlayerData.Berry >= skill_Quantity then
				skill_isPossible = true
			end
		elseif skill_ID == _PlayerService.Ruby_ID then
			if player.PlayerData.Ruby >= skill_Quantity then
				skill_isPossible = true
			end
		end
		
		ui_Skill_Text_Money.TextComponent.FontColor = skill_isPossible and Color(1, 1, 1, 0.8) or Color(193/255, 117/255, 117/255, 0.8)
		
		ui_Lock_Skill.Enable = not (generation >= 5)
		if skill_isPossible and generation >= 5 then
			ui_Skill_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_lab_enable")
			ui_Skill_Button_Upgrade.ButtonComponent.Enable = true
			ui_Skill_Button_Upgrade.TextComponent.FontColor.a = 1
		else
			ui_Skill_Button_Upgrade.TextComponent.Text = _LocalizationService.LocalTranslator:GetText("UI_lab_disable")
			ui_Skill_Button_Upgrade.ButtonComponent.Enable = false
			ui_Skill_Button_Upgrade.TextComponent.FontColor.a = 0.5
			player.PlayerData.IsHold_Gauge_Skill = false
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshCategoryButtons(string filter)
		local button_Monster = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Buttons/Button_Monster")
		local button_Monster_Inner = _EntityService:GetEntityByPath(button_Monster.Path.."/Button")
		
		local button_Lab = _EntityService:GetEntityByPath("/ui/MonsterGroup/UI_Buttons/Button_Lab") 
		local button_Lab_Inner = _EntityService:GetEntityByPath(button_Lab.Path.."/Button")
		
		button_Monster.ButtonComponent.Enable = not (filter == "Monster")
		button_Monster_Inner.ButtonComponent.Enable = not (filter == "Monster")
		button_Monster_Inner.TextComponent.FontColor = (filter == "Monster") and Color(227/255, 227/255, 227/255, 1) or Color(159/255, 167/255, 173/255, 1) 
		
		button_Lab.ButtonComponent.Enable = not (filter == "Lab")
		button_Lab_Inner.ButtonComponent.Enable = not (filter == "Lab")
		button_Lab_Inner.TextComponent.FontColor = (filter == "Lab") and Color(227/255, 227/255, 227/255, 1) or Color(159/255, 167/255, 173/255, 1) 
	end

	@ExecSpace("ClientOnly")
	method void Open_FilterUI()
		if self.List_Filter.Enable then
			return
		end
		
		self.Image_Filter_Block_Background.Enable = true
		self.List_Filter.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Close_FilterUI()
		self.Image_Filter_Block_Background.Enable = false
		self.List_Filter.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void Set_Filter(string Filter)
		-- Filter Item을 클릭했을 때, 필터를 적용합니다. ----------------------
		
		local list_Children = self.List_Filter.Children
		
		-- 선택된 상태인 Filter Item만 강조 표시합니다. -----------------------
		for i = 1, #list_Children do
			local item_Filter = list_Children[i].Monstery_Filter_Monster.Type
			if item_Filter == Filter then
				list_Children[i].ButtonComponent.Enable = false
				
				-- 현재 설정된 필터를 텍스트 UI에 반영합니다. ----------------
				self.Text_Cur_Filtering.Text = list_Children[i].TextComponent.Text
		
			else
				list_Children[i].ButtonComponent.Enable = true
				
		
			end
		end
		
		-- 필터링을 적용하고 갱신합니다. --------------------------------------
		
		
		-- 세대 오름차 순 정렬
		if Filter == "Generation_Up" then
			self:Filtering_Monster_By_Generation(Filter, true)
		-- 세대 내림차 순 정렬	
		elseif Filter == "Generation_Down" then
			self:Filtering_Monster_By_Generation(Filter, false)
		-- 등급 오름차 순 정렬
		elseif Filter == "Grade_Up" then
			self:Filtering_Monster_By_Grade(Filter, true)
		-- 등급 내림차 순 정렬
		elseif Filter == "Grade_Down" then
			self:Filtering_Monster_By_Grade(Filter, false)
		-- 소환한 몬스터만 보여주기
		elseif Filter == "Summoned_Monster" then
			self:Filtering_Monster_By_Summoned(Filter)
		-- 대기 중인 몬스터만 보여주기
		elseif Filter == "Waiting_Monster" then
			self:Filtering_Monster_By_Waiting(Filter)
		-- 최근에 획득한 순으로 정렬
		elseif Filter == "Recent_Get" then
			self:Filtering_Monster_By_Recent_Get(Filter)
		end
		
		self.Cur_Filter = Filter
		
		self.Button_ShowUI_Release.Enable = (self.Cur_Filter == "Recent_Get") 
	end

	@ExecSpace("ClientOnly")
	method void Filtering_Monster_By_Grade(string filter, boolean status)
		-- ==================================================
		-- status == true, 내림차 순 정렬
		-- status == false, 오름차 순 정렬
		-- ==================================================
		local player = _UserService.LocalPlayer
		
		local list_Children = self.List.Children
		
		local monsterIDX = {}
		local sortPoint = {}
		
		-- 등급 정렬을 위해 사전에 테이블을 생성합니다. -----
		for i = 2, #list_Children do
			
			local itemIDX = list_Children[i].MonsteryItem.Idx 
			local itemGrade = player.PlayerData.Minventory_Grade[itemIDX]
			
			if itemGrade == _MonsterService.Grade_0_Name then
				itemGrade = 0
			elseif itemGrade == _MonsterService.Grade_1_Name then
				itemGrade = 1
			elseif itemGrade == _MonsterService.Grade_2_Name then
				itemGrade = 2
			elseif itemGrade == _MonsterService.Grade_3_Name then
				itemGrade = 3
			elseif itemGrade == _MonsterService.Grade_4_Name then
				itemGrade = 4
			elseif itemGrade == _MonsterService.Grade_5_Name then
				itemGrade = 5
			else
				itemGrade = 0
			end
			
			table.insert(monsterIDX, itemIDX)
			table.insert(sortPoint, itemGrade)
		end
		------------------------------------------------------
		
		
		-- 내림차 순 등급 정렬 -------------------------------
		if status then
			for i = 1, #monsterIDX do
				for x = 1, #monsterIDX - 1 do
					if sortPoint[x] < sortPoint[x+1] then
						monsterIDX[x], monsterIDX[x+1] = monsterIDX[x+1], monsterIDX[x]
						sortPoint[x], sortPoint[x+1] = sortPoint[x+1], sortPoint[x]
					end
				end
			end
			
		-- 오름차 순 등급 정렬 ------------------------------
		else
			for i = 1, #monsterIDX do
				for x = 1, #monsterIDX - 1 do
					if sortPoint[x] > sortPoint[x+1] then
						monsterIDX[x], monsterIDX[x+1] = monsterIDX[x+1], monsterIDX[x]
						sortPoint[x], sortPoint[x+1] = sortPoint[x+1], sortPoint[x]
					end
				end
			end
		end
		
		for i = 2, #list_Children do
			list_Children[i].Enable = true
			list_Children[i].MonsteryItem.Idx = monsterIDX[i-1]
			list_Children[i].MonsteryItem:RefreshInfo()
		end
		
		-- =================================================
		-- 최상단 몬스터를 보여줍니다.
		-- =================================================
		if #list_Children >= 2 and isvalid(list_Children[2]) then
			
			if filter ~= self.Cur_Filter then
				self.ShowMonsterIDX = list_Children[2].MonsteryItem.Idx
				self:RefreshShowMonsterInfo()
			end
			self.UI_ShowUI_MonsterProfile.Enable = true
			self.UI_ShowUI_Contents.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void Filtering_Monster_By_Generation(string filter, boolean status)
		-- ==================================================
		-- status == true, 내림차 순 정렬
		-- status == false, 오름차 순 정렬
		-- ==================================================
		local player = _UserService.LocalPlayer
		
		local list_Children = self.List.Children
		
		local monsterIDX = {}
		local sortPoint = {}
		
		-- 등급 정렬을 위해 사전에 테이블을 생성합니다. -----
		for i = 2, #list_Children do
			
			local itemIDX = list_Children[i].MonsteryItem.Idx 
			local itemGeneration = tonumber(_DataService:GetCell("MonsterDataSet_Base", player.PlayerData.Minventory_Id[itemIDX], "generation"))
			
			table.insert(monsterIDX, itemIDX)
			table.insert(sortPoint, itemGeneration)
		end
		------------------------------------------------------
		
		
		-- 내림차 순 등급 정렬 -------------------------------
		if status then
			for i = 1, #monsterIDX do
				for x = 1, #monsterIDX - 1 do
					if sortPoint[x] < sortPoint[x+1] then
						monsterIDX[x], monsterIDX[x+1] = monsterIDX[x+1], monsterIDX[x]
						sortPoint[x], sortPoint[x+1] = sortPoint[x+1], sortPoint[x]
					end
				end
			end
			
		-- 오름차 순 등급 정렬 ------------------------------
		else
			for i = 1, #monsterIDX do
				for x = 1, #monsterIDX - 1 do
					if sortPoint[x] > sortPoint[x+1] then
						monsterIDX[x], monsterIDX[x+1] = monsterIDX[x+1], monsterIDX[x]
						sortPoint[x], sortPoint[x+1] = sortPoint[x+1], sortPoint[x]
					end
				end
			end
		end
		
		for i = 2, #list_Children do
			list_Children[i].Enable = true
			list_Children[i].MonsteryItem.Idx = monsterIDX[i-1]
			list_Children[i].MonsteryItem:RefreshInfo()
		end
		
		-- =================================================
		-- 최상단 몬스터를 보여줍니다.
		-- =================================================
		if #list_Children >= 2 and isvalid(list_Children[2]) then
			
			if filter ~= self.Cur_Filter then
				self.ShowMonsterIDX = list_Children[2].MonsteryItem.Idx
				self:RefreshShowMonsterInfo()
			end
			self.UI_ShowUI_MonsterProfile.Enable = true
			self.UI_ShowUI_Contents.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void Filtering_Monster_By_Recent_Get(string filter)
		local player = _UserService.LocalPlayer
		
		local list_Children = self.List.Children
		
		for i = 2, #list_Children do
			list_Children[i].Enable = true
			list_Children[i].MonsteryItem.Idx = i - 1
			list_Children[i].MonsteryItem:RefreshInfo()
		end
		
		-- =================================================
		-- 최상단 몬스터를 보여줍니다.
		-- =================================================
		if #list_Children >= 2 and isvalid(list_Children[2]) then
			
			if filter ~= self.Cur_Filter then
				self.ShowMonsterIDX = list_Children[2].MonsteryItem.Idx
				self:RefreshShowMonsterInfo()
			end
			self.UI_ShowUI_MonsterProfile.Enable = true
			self.UI_ShowUI_Contents.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void Filtering_Monster_By_Summoned(string filter)
		local list_Children = self.List.Children
		local player = _UserService.LocalPlayer
		
		local isFind_FirstMonster = false
		
		for i = 2, #list_Children do
			local idx = list_Children[i].MonsteryItem.Idx
		
			list_Children[i].Enable = player.PlayerData.Minventory_Summoned[idx] 
			
			if not isFind_FirstMonster then
				if list_Children[i].Enable then
					self.ShowMonsterIDX = idx
					self:RefreshShowMonsterInfo()
					isFind_FirstMonster = true
				end
			end
		end
		
		-- =================================================
		-- 최상단 몬스터를 보여줍니다.
		-- =================================================
		
		if not isFind_FirstMonster then
			self.UI_ShowUI_MonsterProfile.Enable = false
			self.UI_ShowUI_Contents.Enable = false
		else
			self.UI_ShowUI_MonsterProfile.Enable = true
			self.UI_ShowUI_Contents.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void Filtering_Monster_By_Waiting(string filter)
		local list_Children = self.List.Children
		local player = _UserService.LocalPlayer
		
		local isFind_FirstMonster = false
		
		for i = 2, #list_Children do
			local idx = list_Children[i].MonsteryItem.Idx
		
			list_Children[i].Enable = not player.PlayerData.Minventory_Summoned[idx] 
			
			if not isFind_FirstMonster then
				if list_Children[i].Enable then
					self.ShowMonsterIDX = idx
					self:RefreshShowMonsterInfo()
					isFind_FirstMonster = true
				end
			end
		end
		
		-- =================================================
		-- 최상단 몬스터를 보여줍니다.
		-- =================================================
		
		if not isFind_FirstMonster then
			self.UI_ShowUI_MonsterProfile.Enable = false
			self.UI_ShowUI_Contents.Enable = false
		else
			self.UI_ShowUI_MonsterProfile.Enable = true
			self.UI_ShowUI_Contents.Enable = true
		end
	end

end