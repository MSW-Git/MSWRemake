@Component
script MonsteryFeedItem extends Component

	@HideFromInspector
	property number Idx = 0

	@HideFromInspector
	property Entity MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	@ExecSpace("Client")
	method void RefreshInfo()
		if self.Idx == 0 then
			return
		end
		
		local player = _UserService.LocalPlayer
			
		if not isvalid(player.PlayerData.Inventory_Quantity[self.Idx]) then
			self.Entity:Destroy()
			return
		end
		
		-- 간식주기 UI의 아이템의 정보를 갱신합니다. ----------------------------------------------------------------
		local quantity_Text = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_item_info/Text_Item_Count")
		local quantity = tostring(math.floor(player.PlayerData.Inventory_Quantity[self.Idx]))
		
		quantity_Text.TextComponent.Text = quantity
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		local monsterIDX = self.MonsteryUI.Monstery.ShowMonsterIDX
		
		
		if not isvalid(player.PlayerData.Inventory_Quantity[self.Idx]) then
			self.Entity:Destroy()
			return
		end
		
		if not isvalid(player.PlayerData.Inventory_Type[self.Idx]) then
			self.Entity:Destroy()
			return
		end
		
		if not isvalid(player.PlayerData.Inventory_Name[self.Idx]) then
			self.Entity:Destroy()
			return
		end
		
		-- Item을 클릭하면 몬스터에게 간식을 먹입니다. -------------------------------------------------
		
		-- 몬스터가 최고 레벨에 도달하지 않았다면
		if player.PlayerData.Minventory_Level[monsterIDX] < 30 then
			
			local dataSetName = "ItemDataSet_Base"
		
			local itemPoint =  tonumber(_DataService:GetCell(dataSetName, (player.PlayerData.Inventory_Name[self.Idx] - 20000), "point"))
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			_PlayerService:DestroyItem(player, player.PlayerData.Inventory_Name[self.Idx], 1)
			
		
			
		-- 몬스터가 최고 레벨에 도달한 상태라면
		else
			_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_alert_monsterLevel"), nil, nil, nil)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end