@Component
script UI_ToolTip extends Component

	@HideFromInspector
	property string DataSetName = "ToolTipDataSet"

	@HideFromInspector
	property Entity ToolTip = "84b54313-282c-4a19-b19b-5e850453161f"

	@HideFromInspector
	property TextComponent Text_ToolTip = "b50af27f-98a3-4228-905c-08eb59ae01cd"

	@HideFromInspector
	property SpriteGUIRendererComponent Image_ToolTip = "b50af27f-98a3-4228-905c-08eb59ae01cd"

	property string Key = ""

	property Vector2 Padding = Vector2(0,0)

	@ExecSpace("Client")
	method void SetHoverUI(boolean status)
		-- DataSet에서 해당 툴팁 정보를 받아와서 갱신합니다. ---------------------------------------------
		local text_Title = _LocalizationService.LocalTranslator:GetText(self.Key)
		local text_Description = _LocalizationService.LocalTranslator:GetText(self.Key.."_dsc")
		
		
		self.Text_ToolTip.Text = text_Title.."\n".."<color=#fffff>"..text_Description.."</color>"
		
		-- 해당 툴팁을 엔티티 위에 표시합니다. -----------------------------------------------------------
		self.ToolTip:AttachTo(self.Entity)
		
		self.ToolTip.UITransformComponent.anchoredPosition = Vector2(self.Padding.x, self.Padding.y)
		
		
		self.ToolTip.Enable = status
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters ------------------------------------------
		local state = tostring(event.state)
		--------------------------------------------------------
		
		--======================================================
		-- 마우스가 해당 엔티티 위에 올라간 상태라면
		--======================================================
		if state == "Hover" or state == "Click" then
		    self:SetHoverUI(true)
		end
		
		--======================================================
		-- 마우스가 해당 엔티티 위에서 벗어난 상태라면
		--======================================================
		if state == "Normal" or state == "Released" then
		    self:SetHoverUI(false)
		end
	end

end