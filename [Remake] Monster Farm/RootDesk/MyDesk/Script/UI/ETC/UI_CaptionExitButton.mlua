@Component
script UI_CaptionExitButton extends Component

	@HideFromInspector
	property Entity UI_Caption = "f2336b62-aa00-4439-a10d-723e1a72df02"

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		-- UI 위에 띄운 캡션을 닫습니다. --------------
		self.UI_Caption.Enable = false
		self.Entity.Enable = false
		-----------------------------------------------
	end

end