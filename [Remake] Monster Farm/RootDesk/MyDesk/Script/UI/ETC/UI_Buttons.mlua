@Component
script UI_Buttons extends Component

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OpenMonster(Entity player)
		-- 몬스터 UI를 엽니다. ----------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/MonsterGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void OpenInventory(Entity player)
		-- 인벤토리를 엽니다. ----------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/InventoryGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void OpenStore(Entity player)
		-- 상점을 엽니다. ---------------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/StoreGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void OpenKiosk(Entity player)
		-- 가판대를 엽니다. -------------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/KioskGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void OpenFusion(Entity player)
		-- 조합 창을 엽니다. ------------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/MonsterFusionGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void OpenTutorial(Entity player)
		-- 튜토리얼을 엽니다. -----------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/TutorialGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void OpenQuest(Entity player)
		-- 퀘스트를 엽니다. -------------------------------------------------------------------------
		_UIService:Open(_EntityService:GetEntityByPath("/ui/QuestGroup"), player, self.Type)
	end

	@ExecSpace("ClientOnly")
	method void MoveToFarm(Entity player)
		-- 수락시 마을로 이동합니다. --------------------
		local yes = function()
			_MapService:MoveToLobbyFromFarm(player)
		end
		
		local no = function()
				
		end
		
		-- DB 작업이 끝난 상태라면 --
		if player.PlayerData.IsLoaded then
			_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_moveToLobby"), yes, no, nil)
		end
	end

	@ExecSpace("ClientOnly")
	method void OpenAchievement(Entity player)
		_AchievementService:Open()
	end

	@ExecSpace("ClientOnly")
	method void OpenMyCons(Entity player)
		_MyConService:Open()
	end

	@ExecSpace("ClientOnly")
	method void OpenBook(Entity player)
		_BookService:Open()
	end

	@ExecSpace("ClientOnly")
	method void SwitchTourMode(Entity player)
		-- 투어 모드를 전환합니다. -----
		_PlayerService:SetWalkPossible()
	end

	@ExecSpace("ClientOnly")
	method void HideUI(Entity player)
		player.PlayerData.IsHideUI = not player.PlayerData.IsHideUI
	end

	@ExecSpace("ClientOnly")
	method void OpenLevelUP(Entity player)
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		_PlayerService:LevelUP(player)
	end

	@ExecSpace("ClientOnly")
	method void OpenCook(Entity player)
		_CookService:Open()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		if self.Type == "Monster" then -- Monster UI
			self:OpenMonster(player)
			
		elseif self.Type == "Inventory" then -- Inventory UI
			self:OpenInventory(player)
		
		elseif self.Type == "Store" then -- Store UI
			self:OpenStore(player)
			
		elseif self.Type == "Kiosk" then -- Kiosk UI
			self:OpenKiosk(player)
			
		elseif self.Type == "Fusion" then -- Fusion UI
			self:OpenFusion(player)
			
		elseif self.Type == "Tutorial" then -- Tutorial UI
			self:OpenTutorial(player)
		
		elseif self.Type == "Quest" then -- Quest UI
			self:OpenQuest(player)
		
		elseif self.Type == "Achievement" then -- Achievement UI
			self:OpenAchievement(player)
			
		elseif self.Type == "Cook" then -- Cook UI
			self:OpenCook(player)
			
		elseif self.Type == "MyCons" then -- Achievement UI
			self:OpenMyCons(player)
		
		elseif self.Type == "MoveToFarm" then
			self:MoveToFarm(player)
			
		elseif self.Type == "Book" then
			self:OpenBook(player)
				
		elseif self.Type == "LevelUP" then
			self:OpenLevelUP(player)
		
		elseif self.Type == "TourMode" then
			self:SwitchTourMode(player)
			
		-- 테스트 로직 ------------------------------------
			
		elseif self.Type == "HideUI" then
			self:HideUI(player)
		end
	end

end