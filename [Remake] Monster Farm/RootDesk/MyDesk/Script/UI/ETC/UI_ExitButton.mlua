@Component
script UI_ExitButton extends Component

	property Entity popup = "079e91cb-df36-4888-98d3-949740870887"

	property string type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		-- 해당 팝업을 닫습니다. ---------------------------------
		_UIService:Close(self.popup, player, self.type)
		
		
		-- 타입에 따라 다르게 갱신합니다. ------------------------
		if self.type == "Quest" then
			self.popup.Quest:Close()
			
		elseif self.type == "Inventory" then
			self.popup.Inventory:Close()
			
		elseif self.type == "Achievement" then
			_AchievementService:Close()
		
		elseif self.type == "Trade" then
			_TradeService:Close(player)
			_TradeService:ExitTrade(player, player.PlayerTradeComponent.TraderID)
		
		elseif self.type == "Book" then
			_BookService:Close()
			
		elseif self.type == "Cook" then
			_CookService:Close()
			
		elseif self.type == "Store" then
			self.popup.Store:Close()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end