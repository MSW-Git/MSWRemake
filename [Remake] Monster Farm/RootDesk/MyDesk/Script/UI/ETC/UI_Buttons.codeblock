      "EntityEventHandlers": [
        {
          "Name": "HandleButtonClickEvent",
          "EventName": "ButtonClickEvent",
          "ParameterName": "event",
          "Target": "self",
          "Code": "--===========================================\n-- 서버 지연 대응 로직\n--===========================================\nlocal player = _UserService.LocalPlayer\n\nif player.PlayerData.IsTransferring then\n\treturn\nend\n--===========================================\n\nif self.Type == \"Monster\" then -- Monster UI\n\tself:OpenMonster(player)\n\t\nelseif self.Type == \"Inventory\" then -- Inventory UI\n\tself:OpenInventory(player)\n\nelseif self.Type == \"Store\" then -- Store UI\n\tself:OpenStore(player)\n\t\nelseif self.Type == \"Kiosk\" then -- Kiosk UI\n\tself:OpenKiosk(player)\n\t\nelseif self.Type == \"Fusion\" then -- Fusion UI\n\tself:OpenFusion(player)\n\t\nelseif self.Type == \"Tutorial\" then -- Tutorial UI\n\tself:OpenTutorial(player)\n\nelseif self.Type == \"Quest\" then -- Quest UI\n\tself:OpenQuest(player)\n\nelseif self.Type == \"Achievement\" then -- Achievement UI\n\tself:OpenAchievement(player)\n\t\nelseif self.Type == \"Cook\" then -- Cook UI\n\tself:OpenCook(player)\n\t\nelseif self.Type == \"MyCons\" then -- Achievement UI\n\tself:OpenMyCons(player)\n\nelseif self.Type == \"MoveToFarm\" then\n\tself:MoveToFarm(player)\n\t\nelseif self.Type == \"Book\" then\n\tself:OpenBook(player)\n\t\t\nelseif self.Type == \"LevelUP\" then\n\tself:OpenLevelUP(player)\n\nelseif self.Type == \"TourMode\" then\n\tself:SwitchTourMode(player)\n\t\n-- 테스트 로직 ------------------------------------\n\t\nelseif self.Type == \"HideUI\" then\n\tself:HideUI(player)\nend",
          "Scope": 2,
          "ExecSpace": 2
        }
      ],
      "worldCoreVersion": "1.25.0.0",
      "worldStudioVersion": "0.1.0.0",
      "useService": 0
    }
