          "Code": "-- 수락시 마을로 이동합니다. --------------------\nlocal yes = function()\n\t_MapService:MoveToLobbyFromFarm(player)\nend\n\nlocal no = function()\n\t\t\nend\n\n-- DB 작업이 끝난 상태라면 --\nif player.PlayerData.IsLoaded then\n\t_UIPopup:Open(_LocalizationService.LocalTranslator:GetText(\"Popup_moveToLobby\"), yes, no, nil)\nend",
