@Component
script Kiosk_CapaUpButton extends Component

	@HideFromInspector
	property TextComponent Text_CapacityCost = "0c8ab608-1e98-41fd-9ad3-1c52b8b4b32f"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		local yes = function() 
			_TransferService:Transfer("in")
			_PlayerService:CapacityUP(player)
		end
		
		
		local no = function()  
		
		end
		
		_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_notification_Expand"), yes, no, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end