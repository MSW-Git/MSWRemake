@Component
script Inventory_SortButton extends Component

	property string Type = ""

	@HideFromInspector
	property Entity InventoryUI = "22096d2c-a2dc-42a0-98f4-42c85c893e09"

	@ExecSpace("ClientOnly")
	method void OnClick()
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
		
		if self.InventoryUI.Inventory.Filter ~= self.Type then
			-- 필터를 적용합니다. --------------------------------------------------------------------------
			self.InventoryUI.Inventory:RefreshItem(self.Type)
			
			local List = self.Entity.Parent.Children
			
			for i = 1, #List do
				if List[i] == self.Entity then
					self.InventoryUI.Inventory:RefreshSortButtonStatus(i)
					break
				end
			end
			------------------------------------------------------------------------------------------------
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end