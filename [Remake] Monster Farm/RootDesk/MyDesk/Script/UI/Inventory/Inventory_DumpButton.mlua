@Component
script Inventory_DumpButton extends Component

	@HideFromInspector
	property Entity UI_Caption = "f2336b62-aa00-4439-a10d-723e1a72df02"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		local yes = function() 
			-- 해당 슬롯의 아이템을 삭제합니다. -----------------------------------
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			
			--_PlayerService:ClearItem(player, self.UI_Caption.Inventory_Caption.Idx)
			self.UI_Caption.Parent.Inventory:CloseCaption()	
		end
		
		--_UIPopup:Open(_LocalizationService.LocalTranslator:GetText("Popup_notification_Dump"), yes, "", self.UI_Caption.Inventory_Caption.ruid)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end