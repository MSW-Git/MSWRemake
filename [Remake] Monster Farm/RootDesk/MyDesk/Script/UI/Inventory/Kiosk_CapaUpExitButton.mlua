@Component
script Kiosk_CapaUpExitButton extends Component

	@HideFromInspector
	property Entity CapaUpgradeUI = "67ed416b-1acd-4031-953d-6db9e6ff6be8"

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 인벤토리 확장 UI를 닫습니다. ----
		self.CapaUpgradeUI.Enable = false
		------------------------------------
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end