@Component
script Inventory_Item extends Component

	property number Idx = 0

	property Inventory InventoryUI = "22096d2c-a2dc-42a0-98f4-42c85c893e09"

	@ExecSpace("ClientOnly")
	method void RefreshInfo()
		local player = _UserService.LocalPlayer
		
		-- 잘못된 IDX라면 이 Item을 Destroy합니다. ---------------------------
		if not isvalid(player.PlayerData.Inventory_Type[self.Idx]) then
			self.Entity:Destroy()
			return
		end
		
		
		-- 해당 Item의 정보를 플레이어의 Inventory에 맞게 갱신합니다. --------
		local Text_Quantity = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/UI_item_info/Text_Item_Count")
		Text_Quantity.TextComponent.Text = tostring(math.floor(player.PlayerData.Inventory_Quantity[self.Idx]))
		
		local dataSetName = "ItemDataSet_Base"
		
		
		-- 해당 Item의 정보에 맞게 RUID를 적용합니다. ------------------------
		local Image_Item = _EntityService:GetEntityByPath(self.Entity.Path.."/Image_Board/Image_item")
		
		Image_Item.SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell(dataSetName, (player.PlayerData.Inventory_Name[self.Idx] - 20000), "ruid") 
		Image_Item.SpriteGUIRendererComponent.EndFrameIndex = 0
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		local player = _UserService.LocalPlayer
		
		-- Item을 클릭하면 캡션 UI를 엽니다. -------------------------------------
		self.InventoryUI:OpenCaption(self.Idx, self.Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end