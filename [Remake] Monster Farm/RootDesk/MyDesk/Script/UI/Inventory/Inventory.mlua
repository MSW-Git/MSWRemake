@Component
script Inventory extends Component

	@HideFromInspector
	property string Filter = "all"

	@HideFromInspector
	property Entity List = "46c86fef-e1ef-46bf-81d4-d4dd8c301c9b"

	@HideFromInspector
	property Entity Item = "f5ddbe26-6dfa-4656-8455-9c59c563bdc2"

	@HideFromInspector
	property Entity UI_Caption = "f2336b62-aa00-4439-a10d-723e1a72df02"

	@HideFromInspector
	property Entity Image_Caption_Background = "1c91f356-e805-47a1-9cf2-c3a63d56d0d9"

	@HideFromInspector
	property TextComponent Text_Caption_Name = "e769522b-0a13-4b13-9847-5ccdbffbfd4b"

	@HideFromInspector
	property TextComponent Text_Caption_Type = "79dd841f-0e3a-4d0c-9ea2-8a97d5f5e5d9"

	@HideFromInspector
	property Entity Button_Caption_Use = "b85088df-1ff3-4632-bdde-aab229991177"

	@HideFromInspector
	property Entity Button_Caption_Dump = "11955575-e89c-4989-9380-318ad1c4c916"

	@HideFromInspector
	property Entity UI_CapacityUp = "67ed416b-1acd-4031-953d-6db9e6ff6be8"

	@HideFromInspector
	property Entity Text_Upgrade_Cost = "0c8ab608-1e98-41fd-9ad3-1c52b8b4b32f"

	@HideFromInspector
	property Entity Button_Capacity_Up = "e5319b21-5c87-4b67-b416-85f17a6b4c3c"

	@HideFromInspector
	property number ReadyPoint = 0

	@ExecSpace("ClientOnly")
	method void Open()
		-- Item을 생성합니다. -------------
		self:RefreshItem("all")
		
		-- All 버튼을 강조 표시 합니다. ---
		self:RefreshSortButtonStatus(1)
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 기존에 생성된 Item을 모두 제거합니다. --
		self:ResetItem()
	end

	@ExecSpace("ClientOnly")
	method void RefreshItem(string filter)
		-- 리스트에 Item을 생성합니다. -----------------------------------
		
		if not self.Entity.Enable then
			return
		end
		
		local player = _UserService.LocalPlayer
		
		-- 기존에 갱신된 아이템을 삭제합니다. -----------------------------
		self:ResetItem()
		
		-- 리스트에 아이템을 생성합니다. ----------------------------------
		
		if filter == "all" then
			for i = 1, #player.PlayerData.Inventory_Type do
				
				local newItem	 = self.Item:Clone("item"..tostring(i))
				
				-- 아이템 타입에 따라 다르게 강조 표시를 합니다. -------------------------------------
				local type = player.PlayerData.Inventory_Type[i]
				local newItemBody = _EntityService:GetEntityByPath(newItem.Path.."/Image_Board")
		
				if type == "요리" then
					newItemBody.SpriteGUIRendererComponent.Color = Color(200/255, 223/255, 162/255, 1) 
				elseif type == "재료" then
					newItemBody.SpriteGUIRendererComponent.Color = Color(154/255, 158/255, 181/255, 1) 		
				elseif type == "에그" then
					newItemBody.SpriteGUIRendererComponent.Color = Color(134/255, 179/255, 234/255, 1) 	
				end
		
				newItem.Inventory_Item.Idx = i
				newItem.Inventory_Item:RefreshInfo()
			end
			
		else
			for i = 1, #player.PlayerData.Inventory_Type do
				if player.PlayerData.Inventory_Type[i] == filter then
					
					local newItem	 = self.Item:Clone("item"..tostring(i))
					
					-- 아이템 타입에 따라 다르게 강조 표시를 합니다. -------------------------------------
					local type = player.PlayerData.Inventory_Type[i]
					local newItemBody = _EntityService:GetEntityByPath(newItem.Path.."/Image_Board")
			
					if type == "요리" then
						newItemBody.SpriteGUIRendererComponent.Color = Color(200/255, 223/255, 162/255, 1) 
					elseif type == "재료" then
						newItemBody.SpriteGUIRendererComponent.Color = Color(154/255, 158/255, 181/255, 1) 		
					elseif type == "에그" then
						newItemBody.SpriteGUIRendererComponent.Color = Color(134/255, 179/255, 234/255, 1) 	
					end
		
					newItem.Inventory_Item.Idx = i
					newItem.Inventory_Item:RefreshInfo()
				end
			end
		end
		
		self.Filter = filter
	end

	@ExecSpace("ClientOnly")
	method void ResetItem()
		-- 기존에 생성된 Item을 모두 제거합니다. --------------
		local List_Children = self.List.Children
		
		for i = 2, #List_Children do
			List_Children[i]:Destroy()
		end
	end

	@ExecSpace("ClientOnly")
	method void OpenCaption(number idx, Entity clickedButton)
		-- Caption UI를 엽니다. -------------------------------------------------------------------------
		local player = _UserService.LocalPlayer
		
		local dataSetName = "ItemDataSet_Base"
		
		
		-- ItemDataSet을 확인해서 정보를 가져옵니다. -----------------------------------------------------
		
		if not isvalid(player.PlayerData.Inventory_Name[idx]) then
			return
		end
		
		local itemCode = player.PlayerData.Inventory_Name[idx] - 20000
		local name = _DataService:GetCell(dataSetName, itemCode, "name")
		local type = _DataService:GetCell(dataSetName, itemCode, "type")
		local usePossible = _DataService:GetCell(dataSetName, itemCode, "usePossible") == "o"
		
		-- 사용 가능한 아이템이라면 -----------------------------------------------------------------------
		self.Button_Caption_Use.ButtonComponent.Enable = usePossible
		if usePossible then
			self.Button_Caption_Use.TextComponent.FontColor = Color(1, 1, 1, 1)
		else
			self.Button_Caption_Use.TextComponent.FontColor = Color(1, 1, 1, 0.2)
		end
		
		
		
		-- Caption 정보를 갱신합니다. ---------------------------------------------------------------------
		self.Text_Caption_Name.Text = name
		self.Text_Caption_Type.Text = "["..type.."]"
		
		local captionPos = clickedButton.UITransformComponent.anchoredPosition
		self.UI_Caption.UITransformComponent.anchoredPosition = Vector2(captionPos.x-350, captionPos.y+180)
		
		self.Image_Caption_Background.Enable = true
		self.UI_Caption.Inventory_Caption.Idx = idx
		self.UI_Caption.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void CloseCaption()
		-- Caption UI를 닫습니다. ------------------
		self.Image_Caption_Background.Enable = false
		
		self.UI_Caption.Inventory_Caption.Idx = 0
		self.UI_Caption.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OpenUpgradeUI()
		local player = _UserService.LocalPlayer
		
		-- 보유량 확장 UI를 엽니다. -----------
		self.UI_CapacityUp.Enable = true
		self:RefreshUpgradeUI(player)
		---------------------------------------
	end

	@ExecSpace("ClientOnly")
	method void RefreshUpgradeUI(Entity player)
		-- 업그레이드 UI를 갱신합니다. -----------------------------------------------------------------------------------
		
		if not self.UI_CapacityUp.Enable then
			return
		end 
		
		local Cost = tonumber(_DataService:GetCell("ItemDataSet_CapaUpCost", player.PlayerData.MaxCapacity_Upgrade_Level, "Cost"))
		
		
		-- 업그레이드 비용을 갱신합니다. ---------------------------------------------------------------------------------
		self.Text_Upgrade_Cost.TextComponent.Text = _SystemService:ThousandsSeparator(Cost)
		
		
		-- 재화가 충분히 있다면 ------------------------------------------------------------------------------------------
		if player.PlayerData.Gold >= Cost then
			
			self.Text_Upgrade_Cost.ButtonComponent.Enable = true
			self.Button_Capacity_Up.ButtonComponent.Enable = true
			
			-- UI를 갱신합니다. ---------------------------
			local hammer = _EntityService:GetEntityByPath("/ui/InventoryGroup/Upgrade_Background/UI_Upgrade/Image_Hammer")
			hammer.Enable = true
			
			self.Text_Upgrade_Cost.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 0.8)
			self.Button_Capacity_Up.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 1)
			
		-- 재화가 부족하다면 ---------------------------------------------------------------------------------------------
		else
			
			self.Text_Upgrade_Cost.ButtonComponent.Enable = false
			self.Button_Capacity_Up.ButtonComponent.Enable = false
			
			-- UI를 갱신합니다. ---------------------------
			local hammer = _EntityService:GetEntityByPath("/ui/InventoryGroup/Upgrade_Background/UI_Upgrade/Image_Hammer")
			hammer.Enable = false
			
			self.Text_Upgrade_Cost.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 0.2)
			self.Button_Capacity_Up.TextComponent.FontColor = Color(235/255, 235/255, 255/255, 0.2)
			
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshSortButtonStatus(number idx)
		local sortButtonList = _EntityService:GetEntityByPath("/ui/InventoryGroup/Image_Board/UI_Up/UI_Down")
		
		for i = 1, #sortButtonList.Children do
			local buttonEntity = sortButtonList.Children[i]
				
			if i ~= idx then
				buttonEntity.SpriteGUIRendererComponent.Color = Color(54/255, 56/255, 86/255, 1) 
				buttonEntity.TextComponent.FontColor = Color(81/255, 81/255, 132/255, 1)
			else
				buttonEntity.SpriteGUIRendererComponent.Color = Color(108/255, 112/255, 197/255, 1) 
				buttonEntity.TextComponent.FontColor = Color(237/255, 237/255, 255/255, 1)
			end
			
		end
	end

end