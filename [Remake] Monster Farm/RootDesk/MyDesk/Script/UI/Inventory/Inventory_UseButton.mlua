@Component
script Inventory_UseButton extends Component

	@HideFromInspector
	property Entity UI_Caption = "f2336b62-aa00-4439-a10d-723e1a72df02"

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		local idx = self.UI_Caption.Inventory_Caption.Idx
		
		-- 사용할 아이템의 타입을 가져옵니다. ----------------------------------------------------------------------------------
		local itemType = _DataService:GetCell("ItemDataSet_Base", (player.PlayerData.Inventory_Name[idx] - 20000), "etc")
		
		
		-- Inventory UI를 닫습니다. -------------------------------------------------
		local inv = _EntityService:GetEntityByPath("/ui/InventoryGroup")
		
		inv.Inventory:CloseCaption()
		_UIService:Close(inv, player, "Inventory")
		
		
		-- 아이템의 타입에 따라 다르게 설정합니다. -----------------------------------------------------------------------------
		if itemType == "요리" then
			
			-- Monster UI를 엽니다. ------------------------------------------------
			local monsterGroup = _EntityService:GetEntityByPath("/ui/MonsterGroup")
			_UIService:Open(monsterGroup, player, "Monster")
			
		
			
		elseif itemType == "가챠" then
			
			local itemRUID = _DataService:GetCell("ItemDataSet_Base", (player.PlayerData.Inventory_Name[idx] - 20000), "ruid")
			
			-- 통신합니다. ================
			_TransferService:Transfer("in")
			--=============================
			_GachaService:Open(player.PlayerData.Inventory_Name[idx], itemRUID)
		
		end
		
		
		-- 효과음을 재생합니다. -----------------------------------------------------
		_SoundService:PlaySound("3060a8c8180a423faacb3f8d29200b85", 1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Clicked" then
			self:OnClick()
		end
	end

end