@Component
script Event_Buttons extends Component

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		-- 버튼을 클릭하면 이벤트를 실행합니다. ----------------------------------
		player.PlayerData.FarmEventUITimer = 0
		
		local eventUI = _EntityService:GetEntityByPath("/ui/DefaultGroup/EventUI") 
		eventUI.Enable = false
		
		if self.Type == "Yes" then
			_EventService:Open()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end