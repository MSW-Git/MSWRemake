@Component
script EventPopUp extends Component

	property number EventID = 0

	property number Stage = 0

	property CanvasGroupComponent CanvasGroup = "2cab3b0c-4544-4ce7-a995-ce7de8edc023"

	property TextComponent Text_Quest_Number = "de5413a7-f957-4195-aa14-a6ff917f9153"

	property TextComponent Text_Description = "d138c0ff-57ca-4a33-92a6-d69f3fb3d768"

	property SpriteGUIRendererComponent Image_Light = "7edd0e5a-4a3d-412e-85d7-21a9f24d5668"

	property SpriteGUIRendererComponent Image_Icon = "c0f807aa-0fba-451c-9dff-7a4609d125e6"

	property string RUID_MainEvent = "6f092504c1094122aa0d2a7537422245"

	property string RUID_SubEvent = "c811855df2da4deeb0082d607cf70d27"

	property CanvasGroupComponent CanvasGroup_Contents = "aec38223-5726-4c50-884e-d32c33c1a950"

	property number Timer = 0

	property Entity UI_Event = "f295ddbe-b85b-480b-a213-507ba4d5f44c"

	property UITransformComponent Entity_Light = "7edd0e5a-4a3d-412e-85d7-21a9f24d5668"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		if self.Stage == 0 then
			return
		
		-- background를 서서히 어두워지게 합니다. --------------------------------
		elseif self.Stage == 1 then
			
			if self.CanvasGroup.GroupAlpha < 1 then
				self.CanvasGroup.GroupAlpha = self.CanvasGroup.GroupAlpha + (delta * 2)
			else
				self.Stage = 2 
			end
			
		-- 해당 이벤트 정보를 대입합니다. ----------------------------------------
		elseif self.Stage == 2 then
			local eventType = _DataService:GetCell("EventDataSet", self.EventID, "EventType")
		
			if isvalid(eventType) then 
				
				-- 메인 이벤트라면 --
				if eventType == "main" or eventType == "Main" or eventType == "MAIN" then
					self.Text_Quest_Number.Text = "MAIN EVENT"
					self.Text_Description.Text = "'".._LocalizationService.LocalTranslator:GetText(_DataService:GetCell("EventDataSet", self.EventID, "Title")).."'"
					self.Image_Light.Color = Color.FromHexCode("#fffc80")
					self.Image_Icon.ImageRUID = self.RUID_MainEvent
					
				-- 서브 이벤트라면 --
				else
					self.Text_Quest_Number.Text = "SUB EVENT"
					self.Text_Description.Text = "'".._LocalizationService.LocalTranslator:GetText(_DataService:GetCell("EventDataSet", self.EventID, "Title")).."'"
					self.Image_Light.Color = Color.FromHexCode("#ffffff")
					self.Image_Icon.ImageRUID = self.RUID_SubEvent
				end
			end
			
			self.Stage = 3
			
		-- 스크롤이 펼쳐지는 애니메이션입니다. -----------------------------------
		elseif self.Stage == 3 then
			if not self.UI_Event.Enable then
				self.UI_Event.Enable = true
			end
		
			self.Timer = self.Timer + delta
			if self.Timer < 0.35 then
				self.Stage = 4
				self.Timer = 0
			end
			
		-- 텍스트가 점점 불투명해집니다. -----------------------------------------
		elseif self.Stage == 4 then
			self.CanvasGroup_Contents.GroupAlpha = self.CanvasGroup_Contents.GroupAlpha + (delta * 2.5)
			self.Entity_Light.ZRotation = self.Entity_Light.ZRotation + (delta * -20)
			
			if self.CanvasGroup_Contents.GroupAlpha >= 1 then
				self.Stage = 5
			end
			
		-- 이벤트가 뜬 상태로 멈춰서 대기합니다. ---------------------------------
		elseif self.Stage == 5 then
			
			self.Entity_Light.ZRotation = self.Entity_Light.ZRotation + (delta * -20)
			
			if self.Timer < 1 then
				self.Timer = self.Timer + delta
			end
			
		--  UI를 점점 투명하게 만듭니다. --  -------------------------------------
		elseif self.Stage == 6 then
			
			self.Entity_Light.ZRotation = self.Entity_Light.ZRotation + (delta * -20)
			self.CanvasGroup.GroupAlpha = self.CanvasGroup.GroupAlpha - (delta * 2)
			
			if self.CanvasGroup.GroupAlpha <= 0 then
				self.UI_Event.SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
				self.UI_Event.SpriteGUIRendererComponent.StartFrameIndex = 0
				self.Stage = 7
			end
			
		-- 1초 대기 후, 이벤트 UI를 엽니다. --------------------------------------
		elseif self.Stage == 7 then
			
			if self.Timer < 0.8 then
				self.Timer = self.Timer + delta
			else
				_EventService:ChangeEvent(self.EventID)
				self.Entity.Enable = false
				
				self.UI_Event.SpriteGUIRendererComponent.ImageRUID = "c278379beaef4e939bc89978ff2ccc83"
				_EventService.FarmEventUI.Enable = true
				self.CanvasGroup_Contents.GroupAlpha = 0
				
				self.Timer = 0
				self.Stage = 0
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchReleaseEvent(ScreenTouchReleaseEvent event)
		if not self.Entity.Enable then
			return
		end
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		if self.Stage == 5 then
			if self.Timer >= 1 then
				self.Stage = 6
				self.Timer = 0
			end
		end
	end

end