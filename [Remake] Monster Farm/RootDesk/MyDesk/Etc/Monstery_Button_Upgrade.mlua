@Component
script Monstery_Button_Upgrade extends Component

	property Monstery MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	property SliderComponent Guage_Component = nil

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		local idx = self.MonsteryUI.ShowMonsterIDX
		
		if self.Type == "Grade" then
			_MonsterService:Change_MonsterGrade(player, idx)
			
		elseif self.Type == "Skill" then
			_MonsterService:Change_MonsterSkill(player, idx)
			
		elseif self.Type == "Personality" then
			_MonsterService:Change_MonsterPersonality(player, idx)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnRelease()
		local player = _UserService.LocalPlayer
		
		if self.Type == "Grade" then
			player.PlayerData.IsHold_Gauge_Grade = false
			player.PlayerData.Gauge_Grade_Temp = 0
			
		elseif self.Type == "Personality" then
			player.PlayerData.IsHold_Gauge_Personality = false
			player.PlayerData.Gauge_Personality_Temp = 0
			
		elseif self.Type == "Skill" then
			player.PlayerData.IsHold_Gauge_Skill = false
			player.PlayerData.Gauge_Personality_Temp = 0
		end
		
		self.Guage_Component.Value = 0
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonPressedEvent(ButtonPressedEvent event)
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		if self.Type == "Grade" then
			player.PlayerData.IsHold_Gauge_Grade = true
		
		elseif self.Type == "Personality" then
			player.PlayerData.IsHold_Gauge_Personality = true
			
		elseif self.Type == "Skill" then
			player.PlayerData.IsHold_Gauge_Skill = true
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnRelease()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- Parameters
		local state = event.state
		--------------------------------------------------------
		
		if tostring(state) == "Released" then
			self:OnRelease()
		end
	end

end