@Component
script LeaderBoard_Zone extends Component

	property Entity LeaderBoard_Camera = "97e7dd5d-adb4-41b2-96a5-ee099b25cff6"

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if not isvalid(TriggerBodyEntity.PlayerData) then
			return
		end
		
		local player = _UserService.LocalPlayer
		
		if TriggerBodyEntity ~= player then
			return
		end
		
		_CameraService:SwitchCameraTo(self.LeaderBoard_Camera.CameraComponent)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if not isvalid(TriggerBodyEntity.PlayerData) then
			return
		end
		
		local player = _UserService.LocalPlayer
		
		if TriggerBodyEntity ~= player then
			return
		end
		
		_CameraService:SwitchCameraTo(TriggerBodyEntity.CameraComponent)
	end

end