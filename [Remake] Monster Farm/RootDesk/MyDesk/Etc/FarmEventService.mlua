@Logic
script FarmEventService extends Logic

	property number CurEventID = 0

	property Entity FarmEventUI = "8302987d-55e3-4df2-b0e7-e92807ad2f77"

	property Entity Text_Title = "692a5076-1061-4bd2-b0e9-b56a1020cba8"

	property Entity Text_Description = "fab07d11-6e50-483e-8d8c-f2f3558ec7db"

	property Entity List_Buttons = "9296ffe3-1a5c-4cb8-afe7-4f9938c14ec3"

	property Entity Image_Scene = "f85b27ae-91c0-466b-8ea4-dffbf7340655"

	property string dataSetName = "EventDataSet"

	@ExecSpace("ClientOnly")
	method void Open()
		self.FarmEventUI.Enable = true
		self.CurEventID = self:SelectNewEvent()
		
		self:RefreshFarmEventUI()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.FarmEventUI.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void RefreshFarmEventUI()
		-----------------------------------------------------
		-- 텍스트를 갱신합니다. 
		-----------------------------------------------------
		
		self.Text_Title.TextComponent.Text = _DataService:GetCell(self.dataSetName, self.CurEventID, "Title")
		self.Text_Description.TextComponent.Text = _DataService:GetCell(self.dataSetName, self.CurEventID, "Description")
		
		local sceneRUID = _DataService:GetCell(self.dataSetName, self.CurEventID, "SceneRUID")
		
		if isvalid(sceneRUID) and sceneRUID ~= "" and sceneRUID ~= " " then
			self.Image_Scene.SpriteGUIRendererComponent.ImageRUID = sceneRUID 
		end
		
		-----------------------------------------------------
		-- 선택지 버튼을 생성합니다.
		-----------------------------------------------------
		
		local list_Children = self.List_Buttons.Children
		
		for i = 1, 4 do
			local curOptionID = _DataService:GetCell(self.dataSetName, self.CurEventID, "op"..tostring(math.floor(i)).."_ID")
			
			local optionButton = list_Children[i]
			
			-- 아무 것도 기입하지 않은 행이면 '나가기 버튼'을 자동으로 생성
		
			if i == 1 and (not isvalid(curOptionID) or curOptionID == '' or curOptionID == ' ')  then
		
				optionButton.TextComponent.Text = "나가기"
				optionButton.FarmEvent_OptionButton.TargetID = 0
				
				optionButton.ButtonComponent.Enable = true
				optionButton.SpriteGUIRendererComponent.DropShadow = true
			else
				
				if isvalid(curOptionID) and curOptionID ~= '' and curOptionID ~= ' ' then
					optionButton.FarmEvent_OptionButton.TargetID = tonumber(curOptionID)
					optionButton.TextComponent.Text = _DataService:GetCell(self.dataSetName, self.CurEventID, "op"..tostring(math.floor(i)).."_description")
					optionButton.ButtonComponent.Enable = true
					optionButton.SpriteGUIRendererComponent.DropShadow = true
				else
					optionButton.TextComponent.Text = ""
					optionButton.ButtonComponent.Enable = false
					optionButton.SpriteGUIRendererComponent.DropShadow = false
				end
				
			end
		end
		
		self:GiveReward()
	end

	@ExecSpace("ClientOnly")
	method number SelectNewEvent()
		local length = _DataService:GetRowCount(self.dataSetName)
		
		local randNum = _UtilLogic:RandomIntegerRange(1, length)
		
		while true do
			local curID = tonumber(_DataService:GetCell(self.dataSetName, randNum, "groupID"))
			local prevID = tonumber(_DataService:GetCell(self.dataSetName, randNum - 1, "groupID"))
			
			if isvalid(prevID) then
				if prevID == curID then
					randNum = randNum - 1
				else
					return randNum
				end
			else
				return randNum
			end
		end 
		
	end

	@ExecSpace("ClientOnly")
	method void ChangeEvent(number id)
		self.CurEventID = id
		self:RefreshFarmEventUI()
	end

	@ExecSpace("ClientOnly")
	method void GiveReward()
		self.Text_Description.TextComponent.Text = self.Text_Description.TextComponent.Text.."\n"
		
		-- 보상을 획득합니다. -------------------------------------------------------------------
		for i = 1, 2 do
			local rewardID = _DataService:GetCell(self.dataSetName, self.CurEventID, "reward"..tostring(math.floor(i)).."_ID")
			
			if isvalid(rewardID) and rewardID ~= '' and rewardID ~= ' ' then
				local rewardQuantity = _DataService:GetCell(self.dataSetName, self.CurEventID, "reward"..tostring(math.floor(i)).."_Quantity")
				
				local newString = ''
				if tonumber(rewardID) == _PlayerService.Gold_ID then -- 재화라면
					newString = "골드"
					
				elseif tonumber(rewardID) > 20001 then -- 아이템이라면
					
				elseif tonumber(rewardID) < 20001 then -- 몬스터라면
				else -- 일반 아이템이라면 
					newString = rewardID
				end
				
				if tonumber(rewardQuantity) > 0 then
					self.Text_Description.TextComponent.Text = self.Text_Description.TextComponent.Text.. "<color=#4eb654>".."\n+ "..newString.." "..rewardQuantity.."</color>"
				else
					self.Text_Description.TextComponent.Text = self.Text_Description.TextComponent.Text.."<color=#b64e4e>".."\n- "..newString.." "..rewardQuantity.."</color>"
				end
		
			end
		end
	end

end