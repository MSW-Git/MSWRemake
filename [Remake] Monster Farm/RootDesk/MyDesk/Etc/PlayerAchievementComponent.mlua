@Component
script PlayerAchievementComponent extends Component

	@Sync
	@HideFromInspector
	property number Refreshtime = 0

	@Sync
	@HideFromInspector
	property number RefreshtimeMAX = 0.5

	@Sync
	@HideFromInspector
	property number Gold = 0

	@Sync
	property SyncTable<number> AchieveProgress

	@Sync
	property SyncTable<boolean> AchieveComplete

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		if self.Refreshtime >= self.RefreshtimeMAX then
			self.Refreshtime = 0
		else
			self.Refreshtime = self.Refreshtime + delta
			return
		end
		
		
		-- 업적 UI가 활성화된 상태일 때, 업적 진행도를 매 텀(RefreshtimeMAX)마다 갱신합니다.
		local AchievementGroup = _EntityService:GetEntityByPath("/ui/AchievementGroup")
		if AchievementGroup.Enable then
		--	_AchievementService:RefreshAllItem()
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 불러오기 코드 입니다. 아래 코드를 그대로 사용해주세요. --------------------
		
		local player = self.Entity.OwnerId
		local playerData = _DataStorageService:GetDataStorage("Proto_"..player)
			
		local achiDataSet = _AchievementService.AchiDataSet
		local achiDataSet_Length = _DataService:GetRowCount(achiDataSet) -- 업적DataSet의 행 길이를 가져옵니다.
		
		
		local callback = function(errorCode, key, value)
			
			-- 단순 Log Check 용입니다. 이 부분은 지우셔도 무방합니다. --
			if isvalid(value) then
				log("불러오기 -", key)
			else
				log("새로 생성 -", key)
			end
			-------------------------------------------------------------
				
			
			if key == "AchieveProgress" then -- 업적 진행도를 가져옵니다.
			
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, achiDataSet_Length do
						if i <= #Table then
							table.insert(self.AchieveProgress, tonumber(Table[i])) -- 저장된 값을 가져옵니다.
						else
							table.insert(self.AchieveProgress, 0) -- 새로 만들어진 행 길이에 대응합니다. (예외 처리)
						end
					end
					
				else -- 저장된 값이 없을 경우
					for i = 1, achiDataSet_Length do
						table.insert(self.AchieveProgress, 0) -- 초기 데이터를 생성합니다.
					end
				end
				
				
			elseif key == "AchieveComplete" then -- 업적 상태를 가져옵니다. 
				
				if isvalid(value) then -- 저장된 값이 있을 경우
					local Table = _UtilLogic:StringToTable(value)
					for i = 1, achiDataSet_Length do
						if i <= #Table then
							table.insert(self.AchieveComplete, Table[i]) -- 저장된 값을 가져옵니다.
						else
							table.insert(self.AchieveComplete, false) -- 새로 만들어진 행 길이에 대응합니다 (예외 처리)
						end
					end
					
				else -- 저장된 값이 없을 경우
					for i = 1, achiDataSet_Length do
						table.insert(self.AchieveComplete, false) -- 초기 데이터를 생성합니다.	
					end
				end	
		
						
			elseif key == "Gold" then -- 메소를 저장합니다.
				if isvalid(value) then
					self.Gold = value
				end
			end
			
		end
		
		playerData:GetAsync("AchieveProgress", callback)
		playerData:GetAsync("AchieveComplete", callback)
		
		
		--이미 다른 시스템에서 메소(재화) 프로퍼티를 사용 중이라면 지우셔도 됩니다. (예제용) --
		playerData:GetAsync("Gold", callback)
		
	end

	@ExecSpace("ServerOnly")
	method void OnEndPlay()
		-- 저장 코드 입니다. 아래 코드를 그대로 사용해주세요. ---------------------
		
		local player = self.Entity.OwnerId
		local playerData = _DataStorageService:GetDataStorage("Proto_"..player)
		
		playerData:SetAndWait("AchieveProgress", _UtilLogic:TableToString(self.AchieveProgress))
		playerData:SetAndWait("AchieveComplete", _UtilLogic:TableToString(self.AchieveComplete))
		
		
		--이미 다른 시스템에서 메소(재화) 프로퍼티를 사용 중이라면 지우셔도 됩니다. (예제용) --
		 playerData:SetAndWait("Gold", tostring(self.Gold))
	end

end