@Logic
script UIGetLog extends Logic

	property Entity Panel = "11f5df46-3f9b-41da-8ddc-0894c55afbfc"

	property Entity Line = "e6babdb4-8b84-4656-8ad1-36d2b15ccc87"

	property number RemoveTimer = 15

	property boolean Init = false

	@ExecSpace("Client")
	method void ShowMessage(string message)
		local NewLog = self.Line:Clone("NewLog")
		
		if self.Init == false then
			NewLog.TransformComponent.Position.y = self.Line.TransformComponent.Position.y - 50
			self.Init = true
		end
		
			self:RenewLine()
			NewLog.TextComponent.Text = message
			local offTimer = 0	
			local offFunc = function()
				_TimerService:ClearTimer(offTimer)
			end
			_TimerService:SetTimerOnce(offFunc, 10)
		
		
			local callback = function ()
				NewLog.TextComponent.FontColor.a = NewLog.TextComponent.FontColor.a - 0.1
				NewLog.TextComponent.OutlineColor.a = NewLog.TextComponent.FontColor.a
			
			 	if NewLog.TextComponent.FontColor.a <= 0 then
					NewLog:Destroy()	
				end
			end
			offTimer = _TimerService:SetTimerRepeat(callback, 1)
	end

	@ExecSpace("Client")
	method void RenewLine()
		local children = self.Panel.Children
		
		for index, child in pairs(children) do
			if child.Name ~= "Line" then
				child.TransformComponent.Position.y = child.TransformComponent.Position.y + 50
			end
		end
	end

end