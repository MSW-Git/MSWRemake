@Component
script Book_SortButton extends Component

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		-- Quest 카테고리를 변경합니다. ---------------------------------
		--_BookService:ChangeCategory(self.Type)
		
		-- 효과음을 재생합니다. -----------------------------------------
		_SoundService:PlaySound("01368b4822a340c2a93ec088bdd81c07", 0.45)
		
		local parent_Children = self.Entity.Parent.Children
		
		for i = 1, #parent_Children do
			if parent_Children[i] == self.Entity then
				_BookService:RefreshSortButtonStatus(i)
				break
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		
		self:OnClick()
	end

end