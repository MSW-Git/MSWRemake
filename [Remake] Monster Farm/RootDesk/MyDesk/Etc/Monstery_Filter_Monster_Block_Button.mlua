@Component
script Monstery_Filter_Monster_Block_Button extends Component

	property Monstery MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	@ExecSpace("ClientOnly")
	method void OnClick()
		self.MonsteryUI:Close_FilterUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end