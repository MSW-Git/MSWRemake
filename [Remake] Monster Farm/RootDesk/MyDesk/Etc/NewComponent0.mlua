@Component
script NewComponent0 extends Component

	property GridViewComponent inventory = "dbf1c0b2-f9bd-42b4-9dd9-0a0345b3e6b5"

	property Entity inventorySlot = "5fe4b3f1-fb57-4cdd-80b2-df6c50176c88"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self.inventory.ItemEntity = self.inventorySlot
		self.inventory.OnRefresh = function(idx, entity)
		    log("OnRefresh"..tostring(idx))
		end
		 
		 
		self.inventory.TotalCount = 100
		self.inventory:Refresh()
	end

end