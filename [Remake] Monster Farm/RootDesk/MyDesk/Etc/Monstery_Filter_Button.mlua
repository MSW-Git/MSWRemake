@Component
script Monstery_Filter_Button extends Component

	property Monstery Monstery_UI = "079e91cb-df36-4888-98d3-949740870887"

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		self.Monstery_UI:SwitchContents(self.Type)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end