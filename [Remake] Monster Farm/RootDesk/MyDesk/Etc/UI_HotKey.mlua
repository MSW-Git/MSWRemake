@Component
script UI_HotKey extends Component

	property string PC_Key = ""

	property string Mobile_Key = ""

	property string Type = ""

	property boolean IsAlwaysVisible = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self:RefreshHotKey()
	end

	@ExecSpace("ClientOnly")
	method void Interaction(Entity player)
		-- 해당 엔티티와 상호작용합니다. ----------------------------------
		
		local self_Entity = self.Entity
		local self_Entity_Parent = self.Entity.Parent
		
		if not player.PlayerData.IsLoaded then
			return
		end
		
		if player.PlayerData.IsTransferring then
			return
		end
		
		if player.PlayerData.IsMovingToFarm then
			return
		end
		
		if not isvalid(self.Entity) or not isvalid(self_Entity_Parent) then
			return
		end
		
		if not self.Entity.Enable or not self_Entity_Parent.Enable then
			return	
		end
		
		player.PlayerData.IsMovingToFarm = true
		
		if self.Type == "PortalToMyFarm" then
			self_Entity_Parent.MapPortalToOwnFarm:MoveToOwnFarm(player)
			
		elseif self.Type == "PortalToFarm" then
			self_Entity_Parent.MapPortal:MoveToFarm(player)
			
		elseif self.Type == "PortalToRandomFarm" then
			self_Entity_Parent.MapPortalToRandomFarm:MoveToRandomFarm(player)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshHotKey()
		if not isvalid(self.Entity) then
			return
		end
		
		local text_HotKey = _EntityService:GetEntityByPath(self.Entity.Path.."/Text_HotKey")
		
		if not isvalid(text_HotKey) then
			return
		end
		
		text_HotKey.TextComponent.Text = Environment:IsPCPlatform() and self.PC_Key or self.Mobile_Key 
		
		if not self.IsAlwaysVisible then
			self.Entity.Visible = false
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-------------------------------------------------
		--트리거에 진입할 때
		-------------------------------------------------
		
		-- Parameters --
		local TriggerBodyEntity = event.InteractionEntity
		local player = _UserService.LocalPlayer
		-------------------------------------------------
		
		if not isvalid(TriggerBodyEntity) then
			return
		end
		
		if TriggerBodyEntity ~= player then
			return
		end
		
		if Environment:IsMobilePlatform() then
			local interactionButton = _EntityService:GetEntityByPath("/ui/LobbyGroup/Interaction_Button")
			interactionButton.Enable = true
		end
		
		if not self.IsAlwaysVisible then
			self.Entity.Visible = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-------------------------------------------------
		--트리거를 빠져나올 때
		-------------------------------------------------
		
		-- Parameters --
		local TriggerBodyEntity = event.InteractionEntity
		local player = _UserService.LocalPlayer
		-------------------------------------------------
		
		if not isvalid(TriggerBodyEntity) then
			return
		end
		
		if TriggerBodyEntity ~= player then
			return
		end
		
		if Environment:IsMobilePlatform() then
			local interactionButton = _EntityService:GetEntityByPath("/ui/LobbyGroup/Interaction_Button")
			interactionButton.Enable = false
		end
		
		if not self.IsAlwaysVisible then
			self.Entity.Visible = false
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-------------------------------------------------
		-- 상호작용 키를 눌렀을 때
		-------------------------------------------------
		
		-- Parameters --
		local TriggerBodyEntity = event.InteractionEntity
		local player = _UserService.LocalPlayer
		-------------------------------------------------
		
		if not isvalid(TriggerBodyEntity) then
			return
		end
		
		if TriggerBodyEntity ~= player then
			return
		end
		
		self:Interaction(player)
	end

end