@Component
script Trigger_Deco extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if not isvalid(TriggerBodyEntity.TagComponent) then
			return
		end
		
		if TriggerBodyEntity.TagComponent.Tags[1] == "Deco" then
			TriggerBodyEntity.DecoComponent.IsOutRange = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if not isvalid(TriggerBodyEntity.TagComponent) then
			return
		end
		
		
		if TriggerBodyEntity.TagComponent.Tags[1] == "Deco" then
			TriggerBodyEntity.DecoComponent.IsOutRange = false
		end
	end

end