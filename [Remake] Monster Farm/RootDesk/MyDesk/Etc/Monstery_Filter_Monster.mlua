@Component
script Monstery_Filter_Monster extends Component

	property Monstery MonsteryUI = "079e91cb-df36-4888-98d3-949740870887"

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		-- 필터를 적용합니다. -----------------------
		self.MonsteryUI:Set_Filter(self.Type)
		self.MonsteryUI:Close_FilterUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end