@Component
script FarmEvent_OptionButton extends Component

	@HideFromInspector
	property number TargetID = 0

	@ExecSpace("ClientOnly")
	method void OnClick()
		if self.TargetID == 0 then
			_EventService:Close()
		else
			_EventService:ChangeEvent(self.TargetID)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end