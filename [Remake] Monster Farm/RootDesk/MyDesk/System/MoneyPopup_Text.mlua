@Component
script MoneyPopup_Text extends Component

	property number Timer = 0

	property number TimerMAX = 5

	property boolean DeleteTrigger = false

	property Entity Image_Item = nil

	property Entity Text_Message = nil

	property Entity UI_Item = nil

	property number Origin_Background_Alpha = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		if not self.DeleteTrigger then
			self.Timer = self.Timer + delta
			
			if self.Timer >= self.TimerMAX then
				self.DeleteTrigger = true
				self.Timer = 0
			end
			
		else -- 사라지게 하기 스위치가 true라면	
			
		
			if isvalid(self.Entity) then
				self.Entity.SpriteGUIRendererComponent.Color.a = self.Entity.SpriteGUIRendererComponent.Color.a - (delta * self.Origin_Background_Alpha)
			end
			
			if isvalid(self.Text_Message) then
				self.Text_Message.TextComponent.FontColor.a = self.Text_Message.TextComponent.FontColor.a - delta
			end
			
		
			if isvalid(self.Image_Item) then
				self.Image_Item.SpriteGUIRendererComponent.Color.a = self.Image_Item.SpriteGUIRendererComponent.Color.a - delta
			end
		
			if isvalid(self.UI_Item) then
				self.UI_Item.SpriteGUIRendererComponent.Color.a = self.UI_Item.SpriteGUIRendererComponent.Color.a - delta 
			end
			
		
			if isvalid(self.Image_Item) and self.Image_Item.SpriteGUIRendererComponent.Color.a <= 0 then
				
				if isvalid(self.Entity) then
					self.Entity:Destroy()
					self.Enable = false
				end
			end
		end
	end

end