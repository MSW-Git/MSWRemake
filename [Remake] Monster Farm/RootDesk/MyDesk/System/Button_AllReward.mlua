@Component
script Button_AllReward extends Component

	property string Type = ""

	@ExecSpace("ClientOnly")
	method void StateChange(number rewardItemNumber)
		if rewardItemNumber > 0 then
			self.Entity.TextComponent.FontColor.a = 1
			self.Entity.ButtonComponent.Enable = true
		
		else
			self.Entity.TextComponent.FontColor.a = 0.2
			self.Entity.ButtonComponent.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		--===========================================
		-- 서버 지연 대응 로직
		--===========================================
		local player = _UserService.LocalPlayer
		
		if player.PlayerData.IsTransferring then
			return
		end
		--===========================================
		
		
		
		
		self:StateChange(0)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		self:OnClick()
	end

end