---@description "The parent component of all Components. Provides basic functions of Components."
@Component
script MapleParticleComponent extends Component

	---@sealed
	@Sync
	property boolean IgnoreMapLayerCheck = false

	---@sealed
	@Sync
	property int32 OrderInLayer = 0

	---@sealed
	@Sync
	property string ParticleRUID = ""

	---@sealed
	@Sync
	property string SortingLayer = "Default"

end