---@sealed
---@description "This is the superclass of all Services. Provides basic functions of Service."
@Service
script MobileCameraService extends Service

	---@sealed
	@ExecSpace("ClientOnly")
	method boolean IsHWSupported() end

	---@sealed
	@ExecSpace("ClientOnly")
	method MobileCameraStatus, RawImage TakePhotoAndWait(PhotoResolution resolution) end

end