@Logic
script UI_AchievementStep extends Logic

	property Entity AchievementStepUI = "0d50e703-4d02-40fe-a27f-a63600b68ef9"

	property string AchievementID = ""

	property integer AchievementMaxStep = 0

	@ExecSpace("ClientOnly")
	method void StepUIOpen(string achievementID)
		--------------------------------------------------------------
		-- func: 업적 단계 UI를 열고, 필요한 처리를 합니다. 
		--------------------------------------------------------------
		
		self.AchievementID = achievementID
		
		--커스텀 스크롤 개수 초기화
		local dataSet = _AchievementService:GetAchievementInfo(self.AchievementID)
		self.AchievementMaxStep = dataSet.MaxStep
		
		_UI_AchievementService.AchievementStepList.CustomScrollLayoutComponent:SetChildrenCount(self.AchievementMaxStep)
		self:StepUIInit(1,3)
		
		self.AchievementStepUI.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void StepUIClose()
		self.AchievementStepUI.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void StepUIInit(integer minIdx, integer maxIdx)
		-------------------------------------------------------------------------
		-- func: 업적 그룹 idx가 같은 모든 단계의 정보를 UI Cell에 출력하는 함수입니다. 
		-------------------------------------------------------------------------
		-- Parameters
		
		local player = _UserService.LocalPlayer
		local achievementManager = player.AchievementManager
		-------------------------------------------------------------------------
		-- 업적 목록 cell UI의 데이터 채우기 
		local playerachieveData =  achievementManager.PlayerAchievementData[self.AchievementID]
		
		local listCount = 1
		for i=minIdx, maxIdx do 
			local ui = _UI_AchievementService.AchievementStepList:GetChildByName("Model_AchievementCell_"..tostring(listCount))
		
			-- 업적 최고 단계를 넘을 수 없다 
			if i > self.AchievementMaxStep then 
				ui.Enable = false 
			else
				ui.Enable = true 
				ui.UI_AchievementInfo:Init(self.AchievementID,playerachieveData,i)
		
			end
			listCount += 1
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "468f8ff5-3081-4dee-b8c6-b3cfe8d656ad")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 업적 단계 UI의 닫기 버튼 클릭
		
		self:StepUIClose()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "69d1ca32-145a-4cdf-ae7a-8a54b62ad27d")
	handler HandleCustomScrollChangedEvent2(CustomScrollChangedEvent event)
		-- Parameters
		local MinIdx = event.MinIdx
		local MaxIdx = event.MaxIdx
		---------------------------------------------------------
		self:StepUIInit(MinIdx,MaxIdx)
	end

end