	method void AchieveDataSetLoad()
		-----------------------------------------------------------------------------------
		-- func: AchievementList데이터셋을 self.AchievementListData에 저장하는 함수입니다
		-----------------------------------------------------------------------------------
		
		
		-- 구분자가 한개인 스트링을 'int' 테이블로 바꿔주는 함수 선언 
		
		local stringToTableNumber = function(str)
			
			local resultTable = {}	
			
			for segment in string.gmatch(str, "[^;]+") do
			    -- 나눠진 서브 배열을 결과 배열에 추가하기
			    table.insert(resultTable, tonumber(segment))
			end
			
			return resultTable
		end
		
		-- 구분자가 한개인 스트링을 'string' 테이블로 바꿔주는 함수 선언 
		
		local stringToTableStr = function(str)
			
			local resultTable = {}	
			
			for segment in string.gmatch(str, "[^;]+") do
			    -- 나눠진 서브 배열을 결과 배열에 추가하기
			    table.insert(resultTable, segment)
		
			end
			
			return resultTable
		end
		
		
		---------------------------------------------------------------------
		-- 구분자가 2개인 스트링을 테이블로 바꿔주는 함수 선언 
		
		local stringToTableReward = function(str)
			
			local resultTable = {} 
			
			for segment in string.gmatch(str, "[^;]+") do
				
			    -- '_'를 기준으로 각 세그먼트를 나누기
				local formattedSegment = _UtilLogic:Split(segment,"_")
		
			    -- 나눠진 서브 배열을 결과 배열에 추가하기
			    table.insert(resultTable, formattedSegment)
		
			end
			
			return resultTable
			
		end
		
		----------------------------------------------------------------------
		-- AchievementList 데이터셋 불러온 후 self.AchievementListData에 담기 
		
		local curCategory = 0 
		
		local data = _DataService:GetTable("AchievementInfo")
		
		for i=1, data:GetRowCount() do 
			local row = data:GetRow(i)
			
			local achievementData = AchievementInfo() 
			achievementData.ID = row:GetItem("ID")
			achievementData.CategoryID = row:GetItem("CategoryID")
			achievementData.GroupIdx = tonumber(row:GetItem("GroupIdx"))
			achievementData.MaxStep = tonumber(row:GetItem("MaxStep"))	
			
			achievementData.Count = stringToTableNumber(row:GetItem("Count"))
			achievementData.Score = stringToTableNumber(row:GetItem("Score"))
		
			achievementData.RewardTable = stringToTableReward(row:GetItem("RewardTable")) --[형식] 단계_보상ID_보상개수;단계_보상ID_보상개수
			
			achievementData.NameKey = row:GetItem("NameKey")
			achievementData.DescKey = row:GetItem("DescKey")
			
			achievementData.ConditionType = stringToTableStr(row:GetItem("ConditionType"))
			achievementData.IsCumulative = row:GetItem("IsCumulative")
		
			
			self.AchievementInfo[achievementData.ID] = achievementData
		
			self.MaxTotalCompleteNum += achievementData.MaxStep
		
			if not isvalid(self.CategoryTotalNum[achievementData.CategoryID]) then 
				self.CategoryTotalNum[achievementData.CategoryID] = 0 
				self.CategoryGroupNum[achievementData.CategoryID] = 0
			end	
			
			self.CategoryTotalNum[achievementData.CategoryID] += achievementData.MaxStep
			self.CategoryGroupNum[achievementData.CategoryID] += 1
			
		
			-- 250326 추가 // RoundStackAchievements에 업적 추가
			if self:IsServer() then
				if row:GetItem("CategoryID") == "8" then -- 캐릭터 업적일 때 / isCumulative가 false이면 초기화 될 수 있도록 추가
					if achievementData.IsCumulative == "FALSE" then
						table.insert(self.RoundStackAchievements, row:GetItem("ID"))
					end
				end
			end
			-----------------------------------------------------
		end
		
		
		
	end

	@ExecSpace("ClientOnly")
	method void SetCharAchieveMaxNum(PlayerDataComponent playerData)
		local clearRecord = playerData.ClearLevelByMode
		
		local modes = table.keys(clearRecord)
		local season = {}
		
		-- key에서 싱글만 갖고오기
		for i=1, #modes do
			local mode = _UtilLogic:Split(modes[i], "_")
			
			if mode[1] == "Single" then
				table.insert(season, mode[2])
			end
		end
		-- season 넘버에 맞게 sort
		table.sort(season)
		
		-- 해금된 시즌 체크해서 입력 (기본 1.0)
		local openSeasons = {}
		
		-- season의 클리어 레벨 확인
		for i = 1, #season do
			local singleMode = "Single_"..season[i]
			if playerData.ClearLevelByMode[singleMode] < 8 then
				table.insert(openSeasons,season[i]) -- 해금된 시즌 입력
			else
				break
			end
		end
		
		-- 최초 실행 시, 아무 기록이 없어 들어가지 않으므로 1.0 따로 입력
		if #openSeasons == 0 then table.insert(openSeasons, "1.0") end
		
		-- 캐릭터 개수 확인
		local charData = _DictionaryDataManager.CharDataList
		local count = 0
		
		for id, data in pairs(charData) do
			for j=1, #openSeasons do
				if data.CollectionEnable == true and data.ContainedSeason[openSeasons[j]] == true then
					count += 1
					break
				end
			end
		end
		
		self.CategoryGroupNum["8"] = count
	end

	method AchievementInfo GetAchievementInfo(string id)
		return self.AchievementInfo[id]
	end

	@ExecSpace("Server")
	method void UpdateAchievement(string achievementID, integer value, Entity player)
		--log("@h",achievementID,value)
		
		--------------------------------------------------------------------------------
		-- 모드 플레이가 끝나면 초기화 되는 업적인 경우 
		
		for _,stackAchieveID in pairs(self.GameStackAchievements) do 
			
			if achievementID == stackAchieveID then 
				player.AchievementManager:Modify_AchieveStack(achievementID,value)
				return 
			end
			
		end
		
		
		--------------------------------------------------------------------------------
		
		player.AchievementManager:Modify_AchievementData(achievementID,value)
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_Graduate(string achieveID, number value, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '올스타리그 졸업생'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		local gameManager = player.GameManager
		local mode =  _UtilLogic:Split(gameManager.ModeType,"_")[1]
		local modeLevel = gameManager.ModeLevel
		
		local stage = gameManager.Stage
		local round = gameManager.Round
		------------------------------------------------------------------
		
		if  achieveID == "AC001004" or -- 변신 스킬 사용하기 
			achieveID == "AC001005" or -- 시즌1의 모든 캐릭터 도감 해금하기
			achieveID == "AC001006" or --  시즌1의 모든 캐릭터 도감 해금하기
			achieveID == "AC001007" then -- 칭호 획득하기
		
			_AchievementService:UpdateAchievement(achieveID,value,player)
			
		end
		
		------------------------------------------------------------------
		-- 로그인 N회 
		if achieveID == "AC001001" then 
			self:Request_Login(player) 
		end
		
		------------------------------------------------------------------
		
		-- 공통 조건: 4-1라운드 이상 플레이 
		if not (stage == 4 and round == 1) then 
			return
		end
		
		if  achieveID == "AC001002" then 
			if mode == "Single" then -- 싱글 모드 {0}회 플레이하기 
				_AchievementService:UpdateAchievement(achieveID,value,player)
			end
		end
		
		if  achieveID == "AC001003" then 
			if mode == "Rank" then -- 랭크 모드 {0}회 플레이하기 
				_AchievementService:UpdateAchievement(achieveID,value,player)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_SynergyVictory(Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 시너지 일반'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		-- param
		local teamManager = player.TeamManager
		local synergyInfo = _DataService:GetTable("SynergyInfo")
		
		--------------------------------------------------------------------
		
		for i,data in pairs(_AchievementService.AchievementInfo) do 
			
			---@type AchievementInfo
			local achievementInfo = data
		
			-- 업적카테고리가 '시즌1 시너지 일반'가 맞는가? 
			if achievementInfo.CategoryID ~= "2" then 
				continue
			end
			
			-- 업적의 ConditionType(시너지 아이디)를 받아옵니다.
			local synergyID = achievementInfo.ConditionType[1]
			-- 받아온 시너지의 활성화 인원 수를 OnFieldSynergy로 받아옵니다.
			local synergyCount = teamManager.OnFieldSynergy[synergyID]
			-- 최소 활성화 되는 요구 인원 수를 받아옵니다.
			local synergyConditionCount = tonumber(synergyInfo:FindRow("SynergyID", synergyID):GetItem("NeedCount_step1"))
			
			-- 시너지 활성화 카운트 받아오기
			for i=1, 5 do
				if synergyInfo:FindRow("SynergyID", synergyID):GetItem("NeedCount_step"..i) == "-" then
					continue
				else
					synergyConditionCount = tonumber(synergyInfo:FindRow("SynergyID", synergyID):GetItem("NeedCount_step"..i))
					break		
				end
			end
		
			-- 활성화된 시너지가 하나도 없는가? 
			if ( isvalid(synergyCount) == false) or (synergyCount == 0) or (isvalid(synergyConditionCount)==false) then 
				continue
			end
		
			-- 활성화 조건을 만족했는가? 
			if synergyCount < synergyConditionCount then
				continue
			end
			
			self:UpdateAchievement(achievementInfo.ID,1,player)
			
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_SynergyActivation(Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 시너지 전문가'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		-- param
		local teamManager = player.TeamManager
		local synergyInfo = _DataService:GetTable("SynergyInfo"):GetAllRow()
		
		--------------------------------------------------------------------
		-- 파라미터로 넘긴 룬카드를 세팅하여 전투했는지 반환 
		
		local hasRuneCard = function(findRune)
			for index, runeIDs in pairs(player.TeamManager.OwnRunes) do
				local runeID = _UtilLogic:Split(runeIDs, "_")[1] 
				if runeID == findRune then 
					return true
				end
			end
			return false
		end
		
		--------------------------------------------------------------------
		for i,data in pairs(_AchievementService.AchievementInfo) do 
			
			---@type AchievementInfo
			local achievementInfo = data
		
			-- 업적카테고리가 '시즌1 시너지 전문가'가 맞는가? 
			if achievementInfo.CategoryID ~= "3" then 
				continue
			end
			
			local synergyID = achievementInfo.ConditionType[1]
			local synergyCount = teamManager.OnFieldSynergy[synergyID]
			
			-- 활성화된 시너지가 하나도 없는가? 
			if not isvalid(synergyCount) then 
				continue
			end
			
			local runeCardID = achievementInfo.ConditionType[2]
			-- 룬카드 조건이 걸려있는 업적인가? 
			if isvalid(runeCardID) then 
				-- 룬카드를 보유한 상태로 전투했는가? 
				if hasRuneCard(runeCardID) then 
		
					self:UpdateAchievement(achievementInfo.ID,synergyCount,player)			
				end		
			else 
		
				self:UpdateAchievement(achievementInfo.ID,synergyCount,player)	
			end
			
		
			
		
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_RuneCard(string achieveID, number value, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 룬카드'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		local mode = _UtilLogic:Split(player.GameManager.ModeType,"_")[1]
		local modeLevel = player.GameManager.ModeLevel
		
		-- 조건을 만족했는가? 랭크 모드 또는 싱글 모드 5단계 이상 난이도 플레이 
		if mode ~= "Rank" and 
			mode == "Single" and modeLevel < 5 then  
			return
		end 
		
		if  achieveID == "AC004001" or -- -- 에픽 이상 등급의 룬카드를 5개 보유한 상태로 승리하기
			achieveID == "AC004002" or -- 룬카드 리롤 {0}회
			achieveID == "AC004003" or -- 룬카드 [바이킨]을 {0}골드로 판매하기 
			achieveID == "AC004004" or -- 룬카드 [토미] 효과로 {0} 코스트 캐릭터 얻기 
			achieveID == "AC004005" or -- 룬카드 [무라트] 효과로 완성 아이템 {0}번 얻기 
			achieveID == "AC004006" or -- 룬카드 [토푸]로 하트 차감 방어하기 
			achieveID == "AC004007" or -- 룬카드 [골드리치]효과로 룬 카드를 판매하여 {0}코인 획득하기  
			achieveID == "AC004008" or -- 룬카드 [마슈르] 효과로 모든 코인 잃기 
			achieveID == "AC004009" or -- 룬카드 [기억하고 있는자]로 {0}번 복사하기 
		
			achieveID == "AC004010" or -- 룬카드 [피그미]로 강력한 무작위 보상 얻기 
			achieveID == "AC004011" or -- 룬카드 [프란시스]로 3성 유닛 복사하기 
			achieveID == "AC004012" or -- 룬카드 [윈스턴]으로 조합 아이템 {0}개 획득하기
			achieveID == "AC004013" or -- 룬카드 [달리어]로 {0} 중첩 도달하기  
			achieveID == "AC004014" or -- 룬카드 [메르세데스] 사용하기 
			achieveID == "AC004015" or -- 룬카드 [아란]으로 333콤보 달성하기
			achieveID == "AC004016" or -- 룬카드 [팬텀]으로 룬카드 [무공]을 복사한 상태로 전투하기
			achieveID == "AC004017" or -- 룬카드 [루미너스] 사용하기
			achieveID == "AC004018" then -- 룬카드 [에반] 사용하기
			
			self:UpdateAchievement(achieveID,value,player) 
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_RuneCardBattle(boolean result, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 룬카드'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		local stage = player.GameManager.Stage
		local round = player.GameManager.Round
		
		local isallEpic = true
		for index, runeIDs in pairs(player.TeamManager.OwnRunes) do
			local runeID = _UtilLogic:Split(runeIDs, "_")[1]
			
			local grade = tonumber(string.sub(runeIDs,3,3))
			
			if grade < 3 then --룬카드 등급이 에픽 이상인가? 
				isallEpic = false 
			end
			
			-- 룬카드 [메르세데스] 사용하기 
			if runeID == "RC40001" then 
				self:UpdateProgress_RuneCard("AC004014",1,player)
			end
			
			-- 룬카드 [팬텀]으로 룬카드 [무공]을 복사한 상태로 전투하기
			if runeID == "RC40003" and index ~= 5 then
				if _UtilLogic:IsNilorEmptyString(player.TeamManager.OwnRunes[index+1]) == false then
					local nextRuneID = _UtilLogic:Split(player.TeamManager.OwnRunes[index+1], "_")[1]
					if nextRuneID == "RC30011" then 
						self:UpdateProgress_RuneCard("AC004016",1,player)		
					end
				end
				
			end
			
			-- 룬카드 [루미너스] 사용하기 
			if runeID == "RC40004" then 
				self:UpdateProgress_RuneCard("AC004017",1,player)
			end
			
			-- 룬카드 [에반] 사용하기 
			if runeID == "RC40005" then 
				self:UpdateProgress_RuneCard("AC004018",1,player)
			end
			
		end
		
		-- 에픽 이상 등급의 룬카드를 5개 보유한 상태로 승리하기
		if stage == 8 and round == 3 and result == true and 
			#table.keys(player.TeamManager.OwnRunes) >=5 and isallEpic then 
			self:UpdateProgress_RuneCard("AC004001",1,player)
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_Single(boolean result, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '싱글모드'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		local gameManager = player.GameManager
		local modeType =  _UtilLogic:Split(gameManager.ModeType,"_")[1]
		local modeLevel = gameManager.ModeLevel
		local stage = gameManager.Stage
		local round = gameManager.Round
		
		-- 싱글모드 업적 공통 조건: 라운드 8-3에서 승리했는가? 
		if not ( stage == 8 and round == 3 and result ) then 
			return
		end
		
		--------------------------------------------------------------------------------------
		
		
		-- 업적 AC005001: 싱글모드 n단계 8-3 승리
		self:UpdateAchievement("AC005001",modeLevel,player)
		
		-- 업적 AC005002: 싱글모드 1단계 하트를 4개 이상 남기고 8-3 승리 
		if modeLevel == 1 and player.TeamManager.HP >= 4 then 	
			_AchievementService:UpdateAchievement("AC005002",1,player) 
		end
		
		-- 업적 AC005003: 싱글모드 2단계 레벨 6이하로 8-3 승리
		if modeLevel == 2 and player.TeamManager.Level <= 6 then 	
			_AchievementService:UpdateAchievement("AC005003",1,player) 
		end
		
		-- 업적 AC005004: 싱글모드 3단계 8-3라운드에 3성 캐릭터가 1 이상인 상태로 8-3 승리 
		if modeLevel == 3 and self:ReturnLevel3UnitNum(player) >=1 then 	
			_AchievementService:UpdateAchievement("AC005004",1,player) 
		end
		
		-- 업적 AC005005: 싱글모드 4단계에서 활성화된 시너지가 6개 이상인 상태로 8-3 승리 
		local conditionCount = _AchievementService:GetAchievementInfo("AC005005").Count[1]
		if modeLevel == 4 and player.TeamManager:CheckActiveSynergy() >= conditionCount then 	
			_AchievementService:UpdateAchievement("AC005005",conditionCount,player) 
		end
		
		-- 업적 AC005006: 싱글모드 5단계에서 3성이 하나도 없는 상태로 8-3 승리 
		if modeLevel == 5 and self:ReturnLevel3UnitNum(player) == 0 then 	
			_AchievementService:UpdateAchievement("AC005006",1,player) 
		end
		
		-- 업적 AC005007: 싱글모드 6단계에서 아이템을 한번도 구매하지 않은 상태로 8-3 승리 
		if modeLevel == 6 and player.AchievementManager.PlayerAchievementData["AC005007"]['count'] < 1 then 	
			_AchievementService:UpdateAchievement("AC005007",1,player) 
		end
		
		-- 업적 AC005008: 싱글모드 7단계 전장에 배치된 캐릭터가 아이템을 1개 이상 착용한 상태로 8-3 승리 
		local itemCount = self:GetAchievementInfo("AC005008").Count[1]
		if modeLevel == 7 and self:ReturnAllUnitHasItem(player,itemCount) then 	
			_AchievementService:UpdateAchievement("AC005008",1,player) 
		end
		
		-- 업적 AC005009: 싱글모드 8단계에서 25분 내로 8-3 승리
		local playTime = player.GameManager.PlayTime
		local timeLimit = self:GetAchievementInfo("AC005009").Count[1] -- (25분)
		if modeLevel == 8 and playTime <= timeLimit * 60 then 	
			_AchievementService:UpdateAchievement("AC005009",timeLimit,player) 
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_Rank(boolean result, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 랭크모드'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		local gameManager = player.GameManager
		local modeLevel = gameManager.ModeLevel
		local stage = gameManager.Stage
		local round = gameManager.Round
		
		if not ( stage == 8 and round == 3 and result ) then 
		
			return 
		end
		
		-- 업적 AC006001: 랭크 모드 n 티어 달성
		_AchievementService:UpdateAchievement("AC006001",modeLevel,player) 
		
		-- 업적 AC006002: 랭크 모드에서 하트를 1개 남기고 8-3 승리
		if player.TeamManager.HP == 1 then 	
			_AchievementService:UpdateAchievement("AC006002",1,player) 
		end
		
		-- 업적 AC006003: 랭크 모드에서 레벨 10으로 8-3 승리하기
		if player.TeamManager.Level >= 10 then 	
			_AchievementService:UpdateAchievement("AC006003",1,player) 
		end
		
		-- 업적 AC006004: 랭크 모드에서 전투 종료 시 살아있는 캐릭터 7명으로 8-3 승리
		local survivorChar = self:ReturnSurvivorChar(player) 
		local conditionCount = _AchievementService:GetAchievementInfo("AC006004").Count[1]
		
		if survivorChar >= conditionCount then 
			_AchievementService:UpdateAchievement("AC006004",survivorChar,player) 
		end
		
		-- 업적 AC006006: 하트를 하나도 잃지 않고 8-3 승리
		if player.TeamManager.HP == 5 then 	
			_AchievementService:UpdateAchievement("AC006006",1,player) 
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_BattleMaster(boolean result, string roundKey, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '전투 달인'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		local gameManager = player.GameManager
		local mode =  _UtilLogic:Split(gameManager.ModeType,"_")[1]
		local modeLevel = gameManager.ModeLevel
		
		local stage = gameManager.Stage
		local round = gameManager.Round
		
		-- AC007002,AC007009,AC007004
		--------------------------------------------------------------------------
		
		-- 조건을 만족했는가? 랭크 모드 또는 싱글 모드 5단계 이상 난이도 플레이 
		if mode ~= "Rank" and 
			mode == "Single" and modeLevel < 5 then  
			return
		end 
		
		--------------------------------------------------------------------------
		
		-- 업적 AC007001: 아군 전장에 허수아비 {0} 세우기
		for charID,num in pairs(player.TeamManager.OnFieldUnitIDs) do 
			if charID == "C00000" then -- 허수아비
			self:UpdateAchievement("AC007001",num,player) 
			end
		end
		
		-- 업적 AC007007: 시너지 [마스코트]의 인기도 {0} 모으기
		if isvalid(player.TeamManager.OnFieldSynergy["S10001"]) then 
			--인기도
			local popularityScore = player.SynergyManager_New.SynergyStack["S10001"]  
			self:UpdateAchievement("AC007007",popularityScore,player) 	
		end
		
		-- 업적 AC007008: 시너지 [아케인 리버]의 4단계를 4-1 전에 달성하여 해당 라운드에서 승리하기 
		if isvalid(player.TeamManager.OnFieldSynergy["S10020"]) then 
			if player.TeamManager.OnFieldSynergy["S10020"] >= 4 then 
				if stage <=3 and round <=3 and result then 
					self:UpdateAchievement("AC007008",1,player) 
				end
			end
		end
			
		local unitStatistics = self:ReturnMaxStatus(roundKey,player)
		
		-- 업적 AC007011: 한 라운드에서 단일 캐릭터의 가한 피해 {0} 달성
		self:UpdateAchievement("AC007011",unitStatistics["DamageDealt"],player) 
		
		-- 업적 AC007012: 한 라운드에서 단일 캐릭터의 받은 피해 {0} 달성
		self:UpdateAchievement("AC007012",unitStatistics["DamageTaken"],player) 
		
		-- 업적 AC007013: 한 라운드에서 단일 캐릭터의 스킬 사용 횟수 {0} 달성
		self:UpdateAchievement("AC007013",unitStatistics["SkillCountUsed"],player) 
		
		-- 업적 AC007014: 한 라운드에서 단일 캐릭터의 최대 체력 {0} 달성
		self:UpdateAchievement("AC007014",unitStatistics["MaximumHP"],player) 
		
		-- 업적 AC007015: 한 라운드에서 단일 캐릭터의 최대 공격력 {0} 달성
		self:UpdateAchievement("AC007015",unitStatistics["MaximumPhysicalAttack"],player) 
		
		-- 업적 AC007016: 한 라운드에서 단일 캐릭터의 최대 마력 {0} 달성 
		self:UpdateAchievement("AC007016",unitStatistics["MaximumMagicalAttack"],player) 
		
		-- 업적 AC007017: 한 라운드에서 단일 캐릭터의 최고 공격 속도 {0} 달성 
		self:UpdateAchievement("AC007017",unitStatistics["MaximumAttackSpeed"],player) 
		
				
		--------------------------------------------------------------------------------
		-- 8-3에서 승리해야하는 조건이 있는 업적
		
		if not ( stage == 8 and round == 3 and result )then  
			return 
		end 
		
		--------------------------------------------------------------------------------
		
		-- 업적	AC007002:캐릭터 상점 새로 고침을 {0}회 이하로 사용하고 8-3 승리
		local rerollCount = _AchievementService:GetAchievementInfo("AC007002").Count[1]
		if player.AchievementManager.PlayerAchievementData["AC007002"]['count'] <= rerollCount then 
					log("AC007002",player.AchievementManager.PlayerAchievementData["AC007002"]['count'],rerollCount)
			self:UpdateAchievement("AC007002",1,player) 
		end	
		
		-- 업적 AC007003: 캐릭터가 착용한 상징 아이템이 {0}개 이상인 상태로 8-3 승리
		self:UpdateAchievement("AC007003",self:ReturnSynergyItemNum(player),player) 
			
		-- 업적 AC007004: 상자를 한번도 구매하지 않고 8-3 승리 
		local purchasedCount =  player.AchievementManager.PlayerAchievementData["AC007004"]['count']
		if purchasedCount < 1 then  	
			self:UpdateAchievement("AC007004",1,player) 	
		end	
		
		-- 업적 AC007005 : 아군 캐릭터 7명 모두 아이템을 {0}개씩 착용한 상태로 8-3 승리
		local itemCount = _AchievementService:GetAchievementInfo("AC007005").Count[1]
		if player.TeamManager.OnFieldUnitCount >= 7 and self:ReturnAllUnitHasItem(player,itemCount) then 
			self:UpdateAchievement("AC007005",itemCount,player) 		
		end
		
		-- 업적 AC007006: n골드를 남겨둔 상태로 8-3 승리 
		_AchievementService:UpdateAchievement("AC007006",player.TeamManager.Golds,player) 
		
		-- 업적 AC007018: 패널티 코치 4개 사용하여 8-3 승리하기
		local penaltyNum = 0 
		for _, coachID in pairs(player.CoachManager.PlayCoachesID) do 
			if string.sub(coachID,3,3) == "P" then 
				continue
			end 
			penaltyNum+=1 
		end
		
		if penaltyNum >= 4 then 
			_AchievementService:UpdateAchievement("AC007018",1,player) 
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_Char(UnitInfo unitInfo, any amount, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 캐릭터 도전과제'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		if not isvalid(unitInfo) then 
			log_error("unit 없음")
			return
		end
		
		-- 팀 타입이 유저인가? 
		if unitInfo.TeamType ~= "User" then 
			return
		end
		
		local charID = unitInfo.charID 
		
		--local conditionCount = _AchievementService:AchievementListGetData(achieveID).Count[1]
					
		if charID == "C10002"  then -- 주황버섯 : 스킬 사용으로 한 번에 {0}명의 적에게 피해 입히기
		 
			self:UpdateAchievement("AC008002",amount,player)
		
		elseif charID == "C10007"  then -- 스타픽시 : 스킬 사용으로 한번에 별 {0}개 생성하기 
		
			self:UpdateAchievement("AC008007",amount,player)
		
		
		elseif charID == "C20001" then -- 호크아이: 스킬 사용으로 3성 캐릭터 밀쳐내기 {0}회
			---@type Entity
			local targetUnit = amount
		
			if targetUnit.UnitInfo.level >= 3 then 	
				self:UpdateAchievement("AC008014",1,player) 		
			end	
			
		elseif charID == "C20009"  then -- 불독 : 스킬 1회 사용으로 적 캐릭터 {0}명에게 피해 입히기
			self:UpdateAchievement("AC008022",amount,player)
			
		elseif charID == "C20011"  then -- 사수 : 스킬 1회 사용으로 적 캐릭터 {0}명 관통하기
			self:UpdateAchievement("AC008024",#table.keys(amount),player)
										 			
		elseif charID == "C30006"  then -- 플레임위자드 : 스킬 1회 사용으로 화염구 {0}개 날리기
			self:UpdateAchievement("AC008032",amount,player)
			
		elseif charID == "C30011"  then -- 머쉬맘 : 스킬 1회 사용으로 적 캐릭터 {0}명에게 기절시키기	
			self:UpdateAchievement("AC008037",amount,player)
			
		elseif charID == "C30013"  then -- 카이린 : 스킬 1회 사용으로 적 캐릭터 {0}명 관통하기
			self:UpdateAchievement("AC008039",#table.keys(amount),player)
			
		elseif charID == "C40012" then -- 이리나: 스킬 1회 사용으로 발사하는 화살 개수 {0} 도달하기
			self:UpdateAchievement("AC008051",amount,player)
			
		elseif charID == "C40013" then -- 캡틴: 단일 라운드에서 스킬 사용으로 즉시 처치한 적 {0}명 도달하기 
			self:UpdateAchievement("AC008052",amount,player)
			
		elseif charID == "C50005" then -- 루시드: 고유 시너지 효과로 부활하기 {0}회
			self:UpdateAchievement("AC008057",amount,player)
		
		elseif charID == "C50008" then -- 파풀라투스: 고유 시너지 효과로 비상탈출 {0}회
			self:UpdateAchievement("AC008060",amount,player) 
			
		elseif charID == "C50010" then -- 프랑켄슈타인: 스킬로 한 번에 적 캐릭터 {0}명 기절시키기 (시즌 1.2)
			self:UpdateAchievement("AC008073",amount,player)
		end 
		
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_CharEffect(string type, string charID, Entity targetUnit, number amount, string userId)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 캐릭터 도전과제'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		if not isvalid(targetUnit) then 
			return
		end
		
		local player = _UserService:GetUserEntityByUserId(userId)
		
		if targetUnit.UnitInfo.TeamType == "User" then -- 아군에게 적용한 효과인가? 
			if type == "SE0001" then -- 무적 
				if charID == "C50002" then -- 자쿰: 스킬 사용으로 아군에게 무적 {0}회
					self:UpdateAchievement("AC008054",1,player)
				end
			elseif type == "SE000000" then 
				if charID == "C10014" then -- 월묘: 1라운드 내에 광분 버프 상태를 {0}초 유지하기 (시즌1.1) ====================== 수정예정
					self:UpdateAchievement("AC008061",1,player)
				end
			end
						 		
		else --적팀에게 적용한 효과인가? 
			
			if type == "Shield" then -- 방어막
				
				if charID == "C40006" then -- 주니어발록: 단일 라운드에서 파괴한 방어막 총합 {0} 도달하기 
					self:UpdateAchievement("AC008045",amount,player)
				end	
			
			elseif	type == "SE0004" then -- 기절
				
				if charID == "C10001" then -- 슬라임: 단일 라운드에서 적 캐릭터 {0}회 기절시키기
					self:UpdateAchievement("AC008001",1,player)
		
						
				elseif	charID == "C30004" then -- 타우로스피어: 단일 라운드에서 적 캐릭터 {0}회 기절시키기
					self:UpdateAchievement("AC008030",1,player)
					
				elseif	charID == "C50006" then -- 크림슨발록: 단일 라운드에서 적 캐릭터 {0}회 기절시키기
					self:UpdateAchievement("AC008058",1,player)
			
				elseif charID == "C50001" then --핑크빈: 단일 라운드에서 적 캐릭터 {0}회 기절시키기
					self:UpdateAchievement("AC008053",1,player)	
				end
				
			elseif type == "SE0005" then -- 속박
				
				if charID == "C20015" then -- 삼미호: 적 캐릭터 속박시키기 {0}회
					self:UpdateAchievement("AC008064",1,player)
				end
			
			elseif type == "SE0008" then -- 물리방어 약화 
			
				if charID == "C30009" then -- 나이트워커: 단일 라운드에서 적 캐릭터 {0}명 물리 방어 약화 상태로 만들기
					self:UpdateAchievement("AC008035",1,player)
				end
				
			elseif type == "SE0009" then -- 마법방어 약화
				
				if charID == "C30015" then -- 자동 경비 시스템: 1라운드 내에 적 캐릭터 {0}명 마법 방어 약화 상태로 만들기 
					self:UpdateAchievement("AC008071",1,player)
				end
					
			elseif type == "SE0015" then -- 낙인 새기기 
				
				if charID == "C40009" then --엘리쟈
					self:UpdateAchievement("AC008048",1,player)
				end
				
			elseif type == "SE0014" then -- 둔화
				if charID == "C20005" then -- 후회의 신관: 단일 라운드에서 스킬로 적 캐릭터에게 둔화 {0}회 
					self:UpdateAchievement("AC008018",1,player)
				elseif charID == "C40010" then -- 스노우맨: 단일 라운드에서 스킬로 적 캐릭터에게 둔화 {0}회 
					self:UpdateAchievement("AC008049",1,player)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_CharDamage(string attackType, number physicalDamage, number magicalDamage, number trueDamage, Entity unit)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 캐릭터 도전과제'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		--log("attackType:",attackType,"  unit:",unit.UnitInfo.charID,"physicalDamage: ",physicalDamage," magicalDamage: ",magicalDamage," trueDamage: ",trueDamage)	
		local charId = unit.UnitInfo.charID
		local player = _UserService:GetUserEntityByUserId(unit.UnitInfo.OwnerId)
		
		if attackType == "reflection" then 
				
			if charId == "C20004" then -- 주펴일: 자신이 받은 피해량 단일 반사 피해량 {0} 도달하기 
				self:UpdateAchievement("AC008017",physicalDamage,player)	
			end
		elseif attackType == "skill" then 
			
			if charId == "C10004" then --돌의 정령: 스킬 피해량 {0} 도달하기
		
				self:UpdateAchievement("AC008004",magicalDamage,player)
		
			elseif charId == "C10009" then -- 노블레스: 스킬 피해량 {0}도달하기 
				self:UpdateAchievement("AC008009",physicalDamage,player)
			
			elseif charId == "C10017" then -- 마루: 스킬로 한 번에 {0}만큼의 피해 입히기 (시즌 1.3)
				self:UpdateAchievement("AC008074",physicalDamage,player)	
		
			elseif charId == "C20007" then -- 이카르트: 스킬 피해량 {0} 도달하기
				self:UpdateAchievement("AC008020",physicalDamage,player)
		
			elseif charId == "C20013" then -- 몽키록: 스킬 피해량 {0} 도달하기
				self:UpdateAchievement("AC008026",magicalDamage,player)
				
			elseif charId == "C40014" then -- 구미호: 스킬 피해량 {0} 도달하기 (시즌 1.1)
				self:UpdateAchievement("AC008066",magicalDamage,player)
			
			elseif charId == "C50009" then -- 도깨비: 스킬 피해량 {0} 도달하기 (시즌 1.1)
				self:UpdateAchievement("AC008067",magicalDamage,player)
		
			end 
		
		elseif attackType == "defaultAttack" then 
			
			if charId == "C10003" then -- 변형된 달팽이: 기본 공격으로 입히는 물리 피해 {0}도달하기 
				self:UpdateAchievement("AC008003",physicalDamage,player)	
		
			elseif charId == "C10013" then -- 루팡: 기본 공격 피해량 {0} 도달하기 
				self:UpdateAchievement("AC008013",physicalDamage,player)	
			end
		
		end
	end

	@ExecSpace("ServerOnly")
	method void UpdateProgress_CharMaxStatus(string roundKey, Entity player)
		-------------------------------------------------------------------------------------------
		-- func: 업적 카테고리 중 '시즌1 캐릭터 도전과제'에 속하는 업적의 해금 조건을 충족했는지 확인합니다. 
		-------------------------------------------------------------------------------------------
		
		-- 플레이어 존재 여부 검사 
		if not isvalid(player) then 
			log_error("업적 전투 통계 참조 - 플레이어 없음")
			return
		end
		
		-- 배치된 유닛 정보 유효성 검사 
		local units = _UnitSetLogic_New.UnitsParentEntity[player.OwnerId]
		if not isvalid(units) then 
			log_error("업적 전투 통계 참조 - units 없음")
			return
		end
		
		----------------------------------------------------------------------------
		local hasStatistics = function(type)
			if not isvalid(type) then 
				return 0
			else 
				return type
			end
		end
		----------------------------------------------------------------------------
		
		-- 통계 정보 중 각 스탯의 최대값 기록 
		
		for i, unit in pairs(units.Children) do
		
		--	log(roundKey,unit.UnitInfo.TeamType,unit.UnitInfo.charID,unit.UnitInfo.use,unit.UnitInfo.IsOnetimeUnit,unit.UnitInfo:IsOnFieldUnit())
			if unit.UnitInfo.TeamType ~= "User" 
				or unit.UnitInfo.use == false  
				or unit.UnitInfo.IsOnetimeUnit == true then
				continue
			end	
			
			if not isvalid(unit.UnitBattleStatistics) then 
				log_error("업적 전투 통계 참조 - unit.UnitBattleStatistics 없음,",units.UnitInfo.charID)
				continue
			end
			
			local charId = unit.UnitInfo.charID
			local unitStatistics = unit.UnitBattleStatistics
		
			local maxAttackDamage = hasStatistics(unitStatistics.MaximumPhysicalAttack[roundKey]) -- 유닛이 도달한 최대 공격력
			local maxHp = hasStatistics(unitStatistics.MaximumHP[roundKey]) -- 유닛이 도달한 최대 체력
			local maxAttackSpeed = hasStatistics(unitStatistics.MaximumAttackSpeed[roundKey])
			local maxMagicalDamage = hasStatistics(unitStatistics.MaximumMagicalAttack[roundKey])
			local maxSkillUse = hasStatistics(unitStatistics.SkillCountUsed[roundKey])
			local hPAmountProvidedToHealing = hasStatistics(unitStatistics.HPAmountProvidedToHealing[roundKey])
			local hPAmountGainedByHealing = hasStatistics(unitStatistics.HPAmountGainedByHealing[roundKey])
			local shieldAmountGained = hasStatistics(unitStatistics.ShieldAmountGained[roundKey])
			
			-- 가한 피해량 총합 
			local maxMagicalDealt = hasStatistics(unit.UnitBattleStatistics.MagicalDamageDealt[roundKey])
			local maxphysicalDealt = hasStatistics(unit.UnitBattleStatistics.PhysicalDamageDealt[roundKey])
			local trueDamageDealt = hasStatistics(unit.UnitBattleStatistics.TrueDamageDealt[roundKey])
			
			local totalDealt = maxMagicalDealt + maxphysicalDealt + trueDamageDealt
			
			-- 입은 피해량 총합
			local PhysicalDamageTaken = hasStatistics(unit.UnitBattleStatistics.PhysicalDamageTaken[roundKey])
			local MagicalDamageTaken = hasStatistics(unit.UnitBattleStatistics.MagicalDamageTaken[roundKey])
			local TrueDamageTaken = hasStatistics(unit.UnitBattleStatistics.TrueDamageTaken[roundKey])
			
			local totalTaken = PhysicalDamageTaken + MagicalDamageTaken + TrueDamageTaken
			
			-- 피해 방어 총합 
			local physicalDamageAbsorbed = hasStatistics(unit.UnitBattleStatistics.PhysicalDamageAbsorbed[roundKey])
			local magicalDamageAbsorbed = hasStatistics(unit.UnitBattleStatistics.MagicalDamageAbsorbed[roundKey])   
			local trueDamageAbsorbed = hasStatistics(unit.UnitBattleStatistics.TrueDamageAbsorbed[roundKey])  
										
			local totalAbsorbed = physicalDamageAbsorbed + magicalDamageAbsorbed + trueDamageAbsorbed
			
			----------------------------------------------------------------------------
			
			if charId == "C10005" then -- 스톤골렘: 단일 라운드에서 누적 피해 방어량 {0} 도달하기		
				self:UpdateAchievement("AC008005",totalAbsorbed,player)
			elseif charId == "C10006" then -- 스톤볼: 공격력 {0} 도달하기 
				self:UpdateAchievement("AC008006",maxAttackDamage,player)
			elseif charId == "C10008" then -- 추억의 사제: 단일 라운드의 누적 피해량 {0} 도달
				self:UpdateAchievement("AC008008",totalDealt,player)		
			elseif charId == "C10010" then -- 초보자: 단일 라운드에서 가한 피해량 {0} 도달
				self:UpdateAchievement("AC008010",totalDealt,player)				
			elseif charId == "C10011" then -- 헥터: 단일 라운드에서 가한 피해량 {0} 도달
				self:UpdateAchievement("AC008011",totalDealt,player)				
			elseif charId == "C10012" then -- 네펜데스: 공격 범위 15를 달성하고, 가한 피해량 {0} 달성
				self:UpdateAchievement("AC008012",totalDealt,player)
			elseif charId == "C10015" then -- 호돌이: 최대 공격력 {0} 달성하기 (시즌 1.1)
				self:UpdateAchievement("AC008062",maxAttackDamage,player)
			elseif charId == "C10016" then -- 호문: 누적 입은 피해 {0} 도달하기 (시즌 1.2)
				self:UpdateAchievement("AC008068",totalTaken,player)
			elseif charId == "C10018" then -- 가루나비: 1라운드 내에 누적 스킬 사용 {0}회 (시즌 1.3)
				self:UpdateAchievement("AC008075",maxSkillUse,player)
			elseif charId == "C20002" then -- 페페: 단일 라운드에서 누적 보호막 {0} 도달하기
				self:UpdateAchievement("AC008015",shieldAmountGained,player) 					
			elseif charId == "C20003" then -- 망각의 수호병: 최대 체력 {0} 도달하기
				self:UpdateAchievement("AC008016",maxHp,player)
			elseif charId == "C20006" then -- M.소울테니: 1라운드 내에 누적 회복 {0} 달성하기
				self:UpdateAchievement("AC008019",hPAmountGainedByHealing,player)
			elseif charId == "C20008" then -- 라이오너: 단일 라운드에서 가한 피해량 {0} 도달
				self:UpdateAchievement("AC008021",totalDealt,player)
			elseif charId == "C20010" then -- 아이스 드레이크: 단일 라운드에서 가한 피해량 {0} 도달
				self:UpdateAchievement("AC008023",totalDealt,player)		
			elseif charId == "C20012" then -- 아잘린: 단일 라운드에서 가한 피해량 {0} 도달
				self:UpdateAchievement("AC008025",totalDealt,player)
			elseif charId == "C20014" then -- 깨비: 1라운드 내에 누적 체력 회복 {0} 달성하기 (시즌 1.1)
				self:UpdateAchievement("AC008063",hPAmountGainedByHealing,player)
			elseif charId == "C20016" then -- 디트와 로이: 1라운드 내에 누적 가한 피해 {0} 달성하기 (시즌 1.2)
				self:UpdateAchievement("AC008069",totalDealt,player)
			elseif charId == "C20017" then -- 호문스페큘러: 1라운드 내에 누적 가한 피해 {0} 달성하기 (시즌 1.2)
				self:UpdateAchievement("AC008070",totalDealt,player)
			elseif charId == "C20018" then -- 폼폼나무: 1라운드 내에 누적 체력 회복 {0} 달성하기 (시즌 1.3)
				self:UpdateAchievement("AC008076",hPAmountGainedByHealing,player)
			elseif charId == "C30001"then -- 예티: 단일 라운드에서 스킬 사용으로 누적 회복량 {0} 도달하기
					self:UpdateAchievement("AC008027",hPAmountGainedByHealing,player)
			elseif charId == "C30002" then -- C. 시간의 수호대장: 단일 라운드에서 누적 보호막 {0} 도달하기
				self:UpdateAchievement("AC008028",shieldAmountGained,player)
			elseif charId == "C30003" then -- 롬바드: 단일 라운드에서 누적 피해 방어량 {0} 도달하기		
				self:UpdateAchievement("AC008029",totalAbsorbed,player)
			elseif charId == "C30005" then -- 소울마스터: 단일 라운드에서 스킬 사용으로 누적 피해량 {0} 도달하기
				self:UpdateAchievement("AC008031",totalDealt,player)
			elseif charId == "C30007" then -- 프리스트: 스킬 회복량 {0} 도달하기
				self:UpdateAchievement("AC008033",hPAmountProvidedToHealing,player)
			elseif charId == "C30008" then -- 라이칸스로프: 단일 라운드에서 입힌 누적 피해량 {0} 도달하기 		
				self:UpdateAchievement("AC008034",totalDealt,player)
			elseif charId == "C30010" then -- 다크로드: 단일 라운드에서 가한 피해량 {0} 도달
				self:UpdateAchievement("AC008036",totalDealt,player)	
			elseif charId == "C30012" then -- 파우스트: 공격속도 {0} 도달하기
				self:UpdateAchievement("AC008038",maxAttackSpeed,player)
			elseif charId == "C30014" then -- 호걸: 누적 가한 피해 {0} 도달하기 (시즌 1.1)
				self:UpdateAchievement("AC008065",totalTaken,player)
			elseif charId == "C40001" then -- 팔라딘:  단일 라운드에서 누적 보호막 {0} 도달하기
					self:UpdateAchievement("AC008040",shieldAmountGained,player)
			elseif charId == "C40002" then -- 하인즈: 마력 {0} 도달하기
				self:UpdateAchievement("AC008041",maxMagicalDamage,player)
			elseif charId == "C40003" then -- 오즈: 마력 {0} 도달하기
				self:UpdateAchievement("AC008042",maxMagicalDamage,player)
			elseif charId == "C40004" then -- 타이머: 단일 라운드에서 누적 피해량 {0} 도달하기			
				self:UpdateAchievement("AC008043",totalDealt,player)
			elseif charId == "C40005" then -- 나인하트: 단일 라운드에서 가한 누적 피해량 {0} 도달하기
				self:UpdateAchievement("AC008044",totalDealt,player)	
			elseif charId == "C40007" then -- 윈드브레이커: 단일 라운드에서 누적 피해량 {0} 도달하기	
				self:UpdateAchievement("AC008046",totalDealt,player)	
			elseif charId == "C40008" then -- 섀도어: 단일 라운드에서 스킬 {0}회 사용하기 		
				self:UpdateAchievement("AC008047",maxSkillUse,player)
			elseif charId == "C40011" then -- 스트라이커: 단일 라운드에서 누적 피해량 {0} 도달하기 		
				self:UpdateAchievement("AC008050",totalDealt,player)
			elseif charId == "C40015" then -- 루루모: 누적 회복 {0} 도달하기 (시즌 1.2)
				self:UpdateAchievement("AC008072",hPAmountGainedByHealing,player)
			elseif charId == "C50003" then -- 미하일: 단일 라운드에서 누적 피해량 {0} 도달하기		
				self:UpdateAchievement("AC008055",totalDealt,player)
			elseif charId == "C50004" then -- 시그너스: 단일 라운드에서 스킬 사용으로 누적 회복량 {0} 도달하기
				self:UpdateAchievement("AC008056",hPAmountProvidedToHealing,player)
			elseif charId == "C50007" then -- 헬레나: 단일 라운드에서 누적 피해량 {0} 도달하기		
				self:UpdateAchievement("AC008059",totalDealt,player)
			end 	
		
		
		end
	end

	@ExecSpace("ServerOnly")
	method void BattleEnd(boolean result, string modeType, integer modeLevel, number stage, number round, number round8_3num, Entity player)
		----------------------------------------------------------------------------
		-- func: '전투 종료 후'라는 해금 조건을 가진 업적을 처리합니다.   
		----------------------------------------------------------------------------
		
		-- param 
		local roundKey = math.floor(stage) .. "-" .. math.floor(round)
		
		if stage == 8 then
			roundKey = math.floor(stage) .. "-" .. math.floor(round).."-"..math.floor(round8_3num)
		end
		
		local mode = _UtilLogic:Split(modeType, "_")[1]
		------------------------------------------------------------------------------
		
		-- 통계 업적 
		self:UpdateProgress_CharMaxStatus(roundKey,player)
		
		------------------------------------------------------------------------------
		-- 카테고리별 업적 분류 
		
		-- 카테고리: 올스타리그 졸업생 
		self:UpdateProgress_Graduate("AC001002",1,player)
		self:UpdateProgress_Graduate("AC001003",1,player)
		
		-- 카테고리: 싱글 모드 
		if mode == "Single" then 
			self:UpdateProgress_Single(result,player)
		end
		
		-- 카테고리: 랭크 모드
		if mode == "Rank" then 
			self:UpdateProgress_Rank(result,player)
		end
		
		-- 카테고리: 전투의 달인 
		self:UpdateProgress_BattleMaster(result,roundKey,player)
		
		-- 카테고리: 룬카드 
		self:UpdateProgress_RuneCardBattle(result,player)
		
		------------------------------------------------------------------------------
		-- 라운드가 끝났으므로 초기화
		player.AchievementManager:Init_AchieveStack("round")
		
	end

	@ExecSpace("ServerOnly")
	method integer ReturnLevel3UnitNum(Entity player)
		----------------------------------------------------------------------------
		-- func: 전장에 배치한 3성 유닛이 몇개 있는지 반환하는 함수 
		----------------------------------------------------------------------------
		
		local unitsParent = _UnitSetLogic_New.UnitsParentEntity[player.OwnerId]
		
		local level3unitNum = 0 -- 3성 유닛 수 
		
		for _, unit in pairs(unitsParent.Children) do
			local unitLevel = unit.UnitInfo.level 
			
			-- 유저의 유닛인지, 전장에 배치되었는 지 등의 조건 체크 
			if unit.UnitInfo.TeamType ~= "User" 
				or not unit.UnitInfo.use
				or unit.UnitInfo.IsOnetimeUnit
				or not unit.UnitInfo:IsOnFieldUnit() 
				or not unit.UnitInfo.IsResellable then
				continue
			end		
			
			-- 3성인가? 
			if unitLevel >= 3 then 
				level3unitNum += 1
				break
			end		
			
		end
		
		return level3unitNum
	end

	@ExecSpace("ServerOnly")
	method boolean ReturnAllUnitHasItem(Entity player, integer conditionCount)
		----------------------------------------------------------------------------
		-- func: 장착한 아이템 수량 체크
		----------------------------------------------------------------------------
		
		local unitsParent = _UnitSetLogic_New.UnitsParentEntity[player.OwnerId]
		
		local result = true
		
		for _, unit in pairs(unitsParent.Children) do
			
			-- 유저의 유닛인지, 전장에 배치되었는 지 등의 조건 체크 
			if unit.UnitInfo.TeamType ~= "User" 
				or not unit.UnitInfo.use
				or unit.UnitInfo.IsOnetimeUnit
				or not unit.UnitInfo:IsOnFieldUnit() 
				or not unit.UnitInfo.IsResellable then
				continue
			end		
		
			local itemNum = #unit.UnitStatus.EquippedItemIDList 
		
			-- 장착한 아이템 개수와 비교 
			if itemNum < conditionCount then 
				result = false
				break
			end		
			
		end
		
		return result
	end

	@ExecSpace("ServerOnly")
	method integer ReturnSynergyItemNum(Entity player)
		----------------------------------------------------------------------------
		-- func: 장착한 상징 아이템 수량 체크
		----------------------------------------------------------------------------
		
		local unitsParent = _UnitSetLogic_New.UnitsParentEntity[player.OwnerId]
		
		local result = 0
		
		for _, unit in pairs(unitsParent.Children) do
		
			-- 아군 유닛이면서 전장에 배치되었는가? 
			if unit.UnitInfo.TeamType ~= "User" or unit.UnitInfo.use == false then 
				continue
			end
			
			
			-- 장착한 아이템이 상징인가? 
			for _,itemID in pairs (unit.UnitStatus.EquippedItemIDList) do
				if string.sub(itemID,1,2) == "EI" then 
					result +=1 
				end
			end
			
		end
		
		return result
	end

	@ExecSpace("ServerOnly")
	method integer ReturnSurvivorChar(Entity player)
		----------------------------------------------------------------------------
		-- func: 생존한 아군 수 반환하는 함수
		----------------------------------------------------------------------------
		
		local unitsParent = _UnitSetLogic_New.UnitsParentEntity[player.OwnerId]
		
		local survivorCharNum = 0 
		for _, unit in pairs(unitsParent.Children) do
			local teamType = unit.UnitInfo.TeamType
			
			-- 아군 유닛인지, 생존했는지 등의 조건 체크 
			if teamType == "User" 
			and unit.UnitInfo.use
			and unit.UnitStatus.HP > 0
			and not unit.UnitInfo.IsOnetimeUnit
			and unit.UnitInfo:IsOnFieldUnit() 
			and unit.UnitInfo.IsResellable 
			then 
				survivorCharNum += 1 
			end
		
		end
		
		return survivorCharNum
	end

	@ExecSpace("ServerOnly")
	method table ReturnMaxStatus(string roundKey, Entity player)
		----------------------------------------------------------------------------
		-- func: 전투 통계 정보중 각 스탯의 최대값을 반환 
		----------------------------------------------------------------------------
		
		-- 플레이어 존재 여부 검사 
		if not isvalid(player) then 
			log_error("업적 전투 통계 참조 - 플레이어 없음")
			return
		end
		
		-- 배치된 유닛 정보 유효성 검사 
		local units = _UnitSetLogic_New.UnitsParentEntity[player.OwnerId]
		if not isvalid(units) then 
			log_error("업적 전투 통계 참조 - units 없음")
			return
		end
		
		----------------------------------------------------------------------------
		-- param 
		
		local statusTable = {}
		statusTable["DamageDealt"] = 0 -- 가한 피해
		statusTable["DamageTaken"] = 0 -- 받은 피해
		statusTable["SkillCountUsed"] = 0 -- 스킬 사용 횟수
		statusTable["MaximumHP"] = 0 -- 최대 체력
		statusTable["MaximumPhysicalAttack"] = 0 -- 최대 공격력
		statusTable["MaximumMagicalAttack"] = 0 -- 최대 마력
		statusTable["MaximumAttackSpeed"] = 0 -- 최고 공격 속도
		
		----------------------------------------------------------------------------
		
		-- 통계 정보 중 각 스탯의 최대값 기록 
		
		for i, unit in pairs(units.Children) do
		
			if unit.UnitInfo.TeamType ~= "User" 
				or unit.UnitInfo.use == false  
				or unit.UnitInfo.IsOnetimeUnit
				or not unit.UnitInfo:IsOnFieldUnit() then
				continue
			end	
		
			if not isvalid(unit) then 
				log_error("업적 전투 통계 참조 - unit 없음,")
				continue
			end
			
			if not isvalid(unit.UnitBattleStatistics) then 
				log_error("업적 전투 통계 참조 - unit.UnitBattleStatistics 없음,",units.UnitInfo.charID)
				continue
			end
			
			
			-- 가한 피해
			local unitBattleStatistics = unit.UnitBattleStatistics.PhysicalDamageDealt[roundKey] 
			local magicalBattleStatistics = unit.UnitBattleStatistics.MagicalDamageDealt[roundKey]
			local trueBattleStatistics = unit.UnitBattleStatistics.TrueDamageDealt[roundKey]
		
			if not isvalid(unitBattleStatistics) then 
				unitBattleStatistics = 0 
			end
			
			if not isvalid(magicalBattleStatistics) then 
				magicalBattleStatistics = 0 
			end
			
			if not isvalid(trueBattleStatistics) then 
				trueBattleStatistics = 0 
			end
			
			
			local damageDealt = unitBattleStatistics + magicalBattleStatistics + trueBattleStatistics
		 
			if damageDealt > statusTable["DamageDealt"] then 
				statusTable["DamageDealt"] = math.floor(damageDealt)
			end
		
		
		
			-- 받은 피해
			unitBattleStatistics = unit.UnitBattleStatistics.PhysicalDamageTaken[roundKey]
			magicalBattleStatistics = unit.UnitBattleStatistics.MagicalDamageTaken[roundKey]
			trueBattleStatistics = unit.UnitBattleStatistics.TrueDamageTaken[roundKey]
		
		
			if not isvalid(unitBattleStatistics) then 
				unitBattleStatistics = 0 
			end
			
			if not isvalid(magicalBattleStatistics) then 
				magicalBattleStatistics = 0 
			end
			
			if not isvalid(trueBattleStatistics) then 
				trueBattleStatistics = 0 
			end
			
			local damageTaken = unitBattleStatistics + magicalBattleStatistics  + trueBattleStatistics
		 
			if damageTaken > statusTable["DamageTaken"] then 
				statusTable["DamageTaken"] = math.floor(damageTaken)
			end
			
			
			-- 스킬 사용 횟수
			unitBattleStatistics = unit.UnitBattleStatistics.SkillCountUsed[roundKey] 
			if isvalid(unitBattleStatistics) then 
				if unitBattleStatistics > statusTable["SkillCountUsed"] then 
					statusTable["SkillCountUsed"] = math.floor(unitBattleStatistics)
				end
			end
			
			-- 최대 체력
			unitBattleStatistics = unit.UnitBattleStatistics.MaximumHP[roundKey] 
			if isvalid(unitBattleStatistics) then 
				if unitBattleStatistics > statusTable["MaximumHP"] then 
					statusTable["MaximumHP"] = math.floor(unitBattleStatistics)
				end
			end
			
			
			-- 최대 공격력
			unitBattleStatistics = unit.UnitBattleStatistics.MaximumPhysicalAttack[roundKey] 
			if isvalid(unitBattleStatistics) then 
				if unitBattleStatistics > statusTable["MaximumPhysicalAttack"] then 
					statusTable["MaximumPhysicalAttack"] = math.floor(unitBattleStatistics)
				end
			end
			
			-- 최대 마력
			unitBattleStatistics = unit.UnitBattleStatistics.MaximumMagicalAttack[roundKey] 
			if isvalid(unitBattleStatistics) then 
				if unitBattleStatistics > statusTable["MaximumMagicalAttack"] then 
					statusTable["MaximumMagicalAttack"] = math.floor(unitBattleStatistics)
				end
			end
			
			-- 최고 공격 속도
			unitBattleStatistics = unit.UnitBattleStatistics.MaximumAttackSpeed[roundKey] 
			if isvalid(unitBattleStatistics) then 
				if unitBattleStatistics > statusTable["MaximumAttackSpeed"] then 
					local multiplier = 10^2  -- 소수점 둘째 자리까지 표현	
					statusTable["MaximumAttackSpeed"] = math.floor(unitBattleStatistics * multiplier + 0.5) / multiplier
				end
			end
		
		end
		
		return statusTable
	end

	@ExecSpace("ServerOnly")
	method void Request_RankInit(string userID)
		----------------------------------------------------------------------------
		-- func: 랭크 티어 관련 업적 초기화를 진행할 것인지 설정하는 함수
		----------------------------------------------------------------------------
		
		local player = _UserService:GetUserEntityByUserId(userID)
		player.AchievementManager.IsResetAchieveRank = true 
	end

	@ExecSpace("ServerOnly")
	method void Request_Login(Entity player)
		----------------------------------------------------------------------
		-- func: 로그인 업적 조건 체크  
		----------------------------------------------------------------------
		
		if not isvalid(player) then 
			return
		end
		
		local curDate = DateTime.UtcNow
		-- 최근 접속 날짜 
		local lastLoginDate = _UtilLogic:Split(player.PlayerDataComponent.LastLoginDate, "_")
		
		local loginYear = tonumber(lastLoginDate[1])
		local loginMonth = tonumber(lastLoginDate[2])
		local loginday = tonumber(lastLoginDate[3])
		local loginHour = tonumber(lastLoginDate[4])
		 
		-- 로그인 횟수를 증가시킬 수 없는 조건 
		
		-- 처음 접속이 아니면 실행
		if loginYear ~= 0 then 
		
			-- 같은날 접속인가? 
			if curDate.Year == loginYear and curDate.Month == loginMonth and curDate.Day == loginday then 
				
				-- 접속 기록이 9시를 넘었거나 현재 시간이 9시를 넘지 않았다면  
				if loginHour >= 0 or curDate.Hour < 0  then 
					return 
				end
		
			end
			
		else
		
		end
		
		
		-- 접속 날짜 갱신 & db 저장 
		player.PlayerDataComponent.LastLoginDate = string.format("%04d_%02d_%02d_%02d", curDate.Year, curDate.Month,curDate.Day,curDate.Hour)
		_PlayerDataLogic:SetLastLoginDateData(player.PlayerComponent.UserId)
		
		
		
		-- 업적 로그인 횟수 증가 
		self:UpdateAchievement("AC001001",1,player)
		
		-- 일일 무료 패자부활권 지급
		if player.PlayerDataComponent.Repechage_Free < 1 then
			player.PlayerDataComponent:AddSyrup("Repechage_Free", 1, "Login")
			log("일일 무료 패자부활권 지급 (1개) (이후 보유 수량 = ", player.PlayerDataComponent.Repechage_Free,")")
		end
		
		-- 일일 챌린지 모드 횟수 충전
		player.PlayerDataComponent:SetChallengeModeTryCount(3)
		
		-- 데일리 미션 갱신
		player.DailyMissionComponent:InitDailyMission()
	end

	@ExecSpace("ServerOnly")
	method void SaveAchieveDB(Entity userEntity)
		---- 업적: 로그인 횟수 증가 / 강종했을때의 시간이 9시를 넘었을 수 있으므로 
		--self:Request_Login(userEntity)
		
		-- 전체 업적 저장 
		_PlayerDataLogic:SetPlayerAchievementData(userEntity)
		_PlayerDataLogic:SetPlayerAchievementCategoryData(userEntity)
	end

end