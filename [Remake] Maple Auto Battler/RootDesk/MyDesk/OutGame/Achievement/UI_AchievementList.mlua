@Component
script UI_AchievementList extends Component

	property Entity CategoryList = "9755c68e-4ed4-4146-a28b-ae361bea2aef"

	property Entity AchievementList = "4ebe77d9-be20-4c81-b7e7-779932811be9"

	property Entity AchievementStepUI = "0d50e703-4d02-40fe-a27f-a63600b68ef9"

	property string AchievementCategory = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		--업적 카테고리 Cell UI 생성하기 
		for i=1,8 do 
			local cell = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_AchievementCategoryCell"),tostring(i),Vector3.zero,self.CategoryList)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void AchievementUIClose()
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void UpdateAchievementData()
		-------------------------------------------------------------------------
		-- func: 개별 업적 데이터가 변경되었을 경우 UI를 갱신하는 함수입니다.  
		-------------------------------------------------------------------------
		
		self:RefreshAchieveInfo(1,3)
		
		if not self.AchievementStepUI.Enable then 
			return 
		else
			_UI_AchievementStep:StepUIInit(1,3)
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshAchieveInfo(integer min, integer max)
		-------------------------------------------------------------------------
		-- func: 개별 업적 진행 정보를 UI에 세팅하는 함수입니다. 
		-------------------------------------------------------------------------
		
		local player = _UserService.LocalPlayer
		local achievementManager = player.AchievementManager
		local cellMaxCount = self.AchievementList.CustomScrollLayoutComponent.SlotCountPerPage
		local categoryMaxCount = _AchievementService.CategoryGroupNum[self.AchievementCategory]
		
		-- 0403 시즌에 따라 캐릭터 업적 max 갯수 조절 --
		_AchievementService:SetCharAchieveMaxNum(player.PlayerDataComponent)
		------------------------------------------------
		
		-------------------------------------------------------------------------
		-- 진행중/완료 업적 정렬 
		
		local cellCount = 0
		local rewardAchieve = {} 
		local completeAchieve = {} 
		local achieveTable = {} 
		
		for i=1, categoryMaxCount do 
			local achievementID = string.format("AC%03d%03d", self.AchievementCategory, i)
			
			
			local maxStep = _AchievementService:GetAchievementInfo(achievementID).MaxStep --업적 최고 단계 	
			local playrData = _UserService.LocalPlayer.AchievementManager.PlayerAchievementData[achievementID] --플레이어 업적 데이터 
		
			local allComplete = true --모든 업적 단계 완료 여부 
		
		 
			for step= 1 ,maxStep do
				
				--완료하지 않은 업적이 있는가?
				if playrData['state'][step] == _AchievementStateEnum.RewardEarned then 
					rewardAchieve[#rewardAchieve + 1] = {achievementID,step}			
					allComplete = false	
					break
				elseif playrData['state'][step] ~= _AchievementStateEnum.Complete then 
					achieveTable[#achieveTable + 1] = {achievementID,step}
					allComplete = false	
					break
				end
				
			end
		
			--모든 업적 단계를 완료 했는가? 
			if allComplete then 
				completeAchieve[#completeAchieve + 1] = {achievementID,maxStep}	
			end
			
		end
		
		
		for i = 1 ,#completeAchieve do 
			
			achieveTable[#achieveTable + 1] = completeAchieve[i]
			
		end
		
		for i = 1 ,#achieveTable do 
			
			rewardAchieve[#rewardAchieve + 1] = achieveTable[i]
			
		end
		
		-------------------------------------------------------------------------
		-- 업적 목록 cell UI의 데이터 채우기 
		
		local listCount = 1
		for groupIdx=min, max do
			local achieveID = rewardAchieve[groupIdx][1]
			local achieveStep = rewardAchieve[groupIdx][2]
			local playrAchieveData = _UserService.LocalPlayer.AchievementManager.PlayerAchievementData[achieveID]
		
			local listUI = self.AchievementList:GetChildByName("Model_AchievementCell_"..tostring(listCount))
			listUI.UI_AchievementInfo:Init(achieveID,playrAchieveData,achieveStep)
			listCount += 1
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "e2e50b47-b636-4c1c-a001-af0b19abcf2c")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 업적 UI의 닫기 버튼 클릭 
		
		self:AchievementUIClose()
		-- 스크롤 초기화
		self.CategoryList.ScrollLayoutGroupComponent:ResetScrollPosition(UITransformAxis.Horizontal)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "4ebe77d9-be20-4c81-b7e7-779932811be9")
	handler HandleCustomScrollChangedEvent(CustomScrollChangedEvent event)
		-- Parameters
		local MinIdx = event.MinIdx
		local MaxIdx = event.MaxIdx
		---------------------------------------------------------
		-- 업적 목록 UI의 스크롤 변경
		
		self:RefreshAchieveInfo(MinIdx,MaxIdx)
	end

end