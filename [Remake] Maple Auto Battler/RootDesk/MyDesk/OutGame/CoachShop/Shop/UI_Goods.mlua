@Component
script UI_Goods extends Component

	property SpriteGUIRendererComponent sp_Background = nil

	property SpriteGUIRendererComponent sp_CoachImage = nil

	property TextComponent t_productName = nil

	property Entity masterCoachEffect = nil

	property TextComponent t_worldCoin = nil

	property TextComponent t_Syrup = nil

	property TextComponent t_RoyalSyrup = nil

	property Entity Unavailable = nil

	property Entity Lock = nil

	property string GoodsID = ""

	property string GoodsType = ""

	property integer GoodsNowType = 0

	property integer Price_Syrup = 0

	property integer Price_RoyalSyrup = 0

	property integer Price_WorldCoin = 0

	property Entity Tooltip = "6ec67337-e01e-4705-9263-538bfe2dc846"

	@ExecSpace("Client")
	method void InitializeGoods(string id, string type, integer nowCoachType)
		---------------------------------------------------------------------------------
		-- func: 상점의 개별 상품 UI 데이터 셋팅  
		---------------------------------------------------------------------------------
		
		self.GoodsID = id
		self.GoodsType = type
		self.GoodsNowType = nowCoachType
		--log(self.GoodsID,self.GoodsType)
		
		-- 데이터 가져옴
		local priceData = _CoachShopDataLogic:Get_CoachPriceById(self.GoodsType,self.GoodsID)
		self.Price_Syrup = priceData[1]
		self.Price_RoyalSyrup = priceData[2]
		self.Price_WorldCoin = priceData[3]
		
		---------------------------------------------------------------------------------
		-- 엔티티 입력
		if self.Unavailable == nil then
			self.sp_Background = self.Entity.SpriteGUIRendererComponent
			self.masterCoachEffect = self.Entity.Children[1]
			self.sp_CoachImage = self.Entity.Children[2].SpriteGUIRendererComponent
			self.t_productName = self.Entity.Children[3].TextComponent
			self.t_worldCoin = self.Entity.Children[4].Children[1].TextComponent
			self.t_Syrup = self.Entity.Children[4].Children[2].TextComponent
			self.t_RoyalSyrup = self.Entity.Children[4].Children[3].TextComponent
			self.Unavailable = self.Entity:GetChildByName("sp_unavailable")
			self.Lock = self.Unavailable:GetChildByName("Lock")
		end
		---------------------------------------------------------------------------------
		-- 타입 별 결제 수단 버튼
		
		self.t_worldCoin.Entity.Enable = false 
		self.t_Syrup.Entity.Enable = false 
		self.t_RoyalSyrup.Entity.Enable = false
		
		local keyHead = string.sub(self.GoodsID,1,2) 
		
		local data 
		if self.GoodsType == "Gacha" then -- 코치 영입권 
			data = _CoachShopDataLogic:Get_Gacha(self.GoodsID)
			self.t_Syrup.Entity.Enable = true 
		else
			data = _CoachService:GetCoachInfo(self.GoodsID)
			--self.t_worldCoin.Entity.Enable = true
			self.t_RoyalSyrup.Entity.Enable = true
			
			--[[if tonumber(_UtilLogic:SubString(self.Entity.Name, string.len(self.Entity.Name), 1)) >= 2 then
				if _UtilLogic:SubString(self.Entity.Name, string.len(self.Entity.Name)-1, 1) == "1" then
					self.t_RoyalSyrup.Entity.Parent.ScrollLayoutGroupComponent.Enable = false
				end
			end]]--
		end
		
		---------------------------------------------------------------------------------
		local curSyrup = _UserService.LocalPlayer.PlayerDataComponent.Syrup
		local curRoyalSyrup = _UserService.LocalPlayer.PlayerDataComponent.RoyalSyrup
		
		
		-- 가격 입력
		self.t_worldCoin.Text = tostring(self.Price_WorldCoin)
		self.t_Syrup.Text = tostring(self.Price_Syrup)
		self.t_RoyalSyrup.Text = tostring(self.Price_RoyalSyrup)
		
		-- 결제 수단 잔액에 따라 붉은색으로 표시
		if curSyrup <  self.Price_Syrup then self.t_Syrup.FontColor = Color.FromHexCode(_UI_CoachShopService.FontColor_noSyrup)
		else self.t_Syrup.FontColor = Color.FromHexCode(_UI_CoachShopService.FontColor_Price) end
		if curRoyalSyrup < self.Price_RoyalSyrup then self.t_RoyalSyrup.FontColor = Color.FromHexCode(_UI_CoachShopService.FontColor_noSyrup)
		else self.t_RoyalSyrup.FontColor = Color.FromHexCode(_UI_CoachShopService.FontColor_Price) end
		
		---------------------------------------------------------------------------------
		-- 상품 이름 세팅
		local nameText = _LocalizationService:GetText(self.GoodsType.."_"..self.GoodsID.."_Name")
		
		if self.GoodsType == "MasterCoach" then 
			nameText = data.Name
			local masterText = _LocalizationService:GetText("Master")
			nameText = string.format("%s %s",masterText,nameText) -- 마스터코치인 경우 '마스터'텍스트를 붙인다. 
		end
		
		self.t_productName.Text = nameText 
		self.Unavailable.Children[1].TextComponent.Text = self.t_productName.Text
		
		
		---------------------------------------------------------------------------------
			-- 이미지
		local resourceinfo = _LoadResourcesInfo:GetUILocalPositionScale(data.ProfileRUID)
		self.sp_CoachImage.ImageRUID = data.ProfileRUID
		self.sp_CoachImage.LocalPosition = resourceinfo["pos"]
		self.sp_CoachImage.LocalScale = resourceinfo["scale"]
		
		
		if self.GoodsType == "Coach" then
				self.masterCoachEffect.Enable = false
				self.Lock.Enable = false
			-- '코치' 보유 중일 때 (일반 코치 or 마스터 코치 보유)
			if self.GoodsNowType >= 1 then
				self.Unavailable.TextComponent.Text = _LocalizationService:GetText("Shop_Owned")
				self.Unavailable.Enable = true
			-- '코치' 미보유 중일 때
			else
				self.Unavailable.Enable = false
			end
			
		elseif self.GoodsType == "MasterCoach" then
			-- 마스터 코치 이펙트 추가
			local cost = _CoachService:GetCoachInfo(self.GoodsID).Cost
			_UI_CoachShopService:MasterEffectRenderer(self.masterCoachEffect,cost)
			
			-- '마스터 코치' 보유 중일 때
			if self.GoodsNowType == 2 then
				self.Unavailable.TextComponent.Text = _LocalizationService:GetText("Shop_Owned")
				self.Unavailable.Enable = true
				self.Lock.Enable = false
			-- '마스터 코치'를 구매할 수 있을 때 (일반 코치 보유)
			elseif self.GoodsNowType == 1 then
				self.Unavailable.Enable = false
				self.Lock.Enable = false
			else
			-- '마스터 코치'를 구매할 수 없을 때 (코치 미보유)
				self.Unavailable.TextComponent.Text = ""
				self.Unavailable.Enable = true
				self.Lock.Enable = true
			end
		
		else -- 코치/마스터코치 품목이 아닐 때
			self.masterCoachEffect.Enable = false
			self.Unavailable.Enable = false
			self.Lock.Enable = false
		end
		
	end

	@ExecSpace("Client")
	method void OnClick()
		--[[local hasCoach = _UserService.LocalPlayer.CoachManager:GetHasType(self.GoodsID) 
		-- 일반 코치를 보유하지 않은 상태에서 마스터 코치 구매 버튼을 클릭했다면 
		if self.GoodsType == "MasterCoach" and hasCoach == 0 then 
			_UIToast:ShowMessageByLocalizingKey("CoachShop_LockedMasterCoach")
			return
		end
		
		-- 이미 보유한 코치를 구매하려고 했다면 
		if (self.GoodsType == "MasterCoach" and hasCoach == 2 ) 
			or (self.GoodsType == "Coach" and hasCoach ~= 0) then 
			_UIToast:ShowMessageByLocalizingKey("CoachShop_HasCoach")
			return
		end
		
		_UI_CoachShopPopUp:PopupInitialize(self.GoodsID, self.GoodsType)
		_UI_CoachShopPopUp.Popup.Enable = true]]--
	end

	@ExecSpace("Client")
	method void ShowTooltip(boolean OnOff)
		-- 마우스 호버 시 코치 정보 툴팁을 표시하거나 숨기는 함수
		local data =  _CoachService:GetCoachInfo(self.GoodsID)
		
		if not isvalid(data) then
		
			return
		end
		
		if OnOff then
			-- 툴팁 켜기
			self.Tooltip:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(self.GoodsType.."_"..self.GoodsID.."_Name")
			self.Tooltip:GetChildByName("Desc").TextComponent.Text = data.Desc
			
			-- 코치 코스트
			local colorTable = _DataService:GetTable("GradeColor")
			local coachColor = Color.FromHexCode(colorTable:FindRow("Key", string.format("Coach_%d", data.Cost)):GetItem("Default"))
			self.Tooltip:GetChildByName("Name"):GetChildByName("Cost").SpriteGUIRendererComponent.Color = coachColor
			self.Tooltip:GetChildByName("Name"):GetChildByName("Cost").TextComponent.Text = tostring(data.Cost)
			
			self.Tooltip.UITransformComponent.anchoredPosition = _Util:ScreenPostoUIPos(_InputService:GetCursorPosition())
			
			-- 화면밖으로 넘어갈 경우를 대비해 조정
			if self.Tooltip.UITransformComponent.anchoredPosition.x < 130 then
				self.Tooltip.UITransformComponent.anchoredPosition.x = 169
			end
			
			if self.Tooltip.UITransformComponent.anchoredPosition.x > 1600 then
				self.Tooltip.UITransformComponent.anchoredPosition.x = 1595
			end
			
			if self.Tooltip.UITransformComponent.anchoredPosition.y < 280 then
				self.Tooltip.UITransformComponent.anchoredPosition.y = 330
			end
			
			if self.Tooltip.UITransformComponent.anchoredPosition.y > 1182 then
				self.Tooltip.UITransformComponent.anchoredPosition.y = 1150
			end
			
			self.Tooltip.Enable = true
			
		else
			-- 툴팁 끄기
			self.Tooltip.Enable = false
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 상품 클릭 시 구매 조건을 확인하고 구매 프로세스를 시작하는 핸들러
		--self:OnClick()
		
		local hasCoach = _UserService.LocalPlayer.CoachManager:GetHasType(self.GoodsID) 
		-- 일반 코치를 보유하지 않은 상태에서 마스터 코치 구매 버튼을 클릭했다면 
		if self.GoodsType == "MasterCoach" and hasCoach == 0 then 
			_UIToast:ShowMessageByLocalizingKey("CoachShop_LockedMasterCoach")
			return
		end
		
		-- 이미 보유한 코치를 구매하려고 했다면 
		if (self.GoodsType == "MasterCoach" and hasCoach == 2 ) 
			or (self.GoodsType == "Coach" and hasCoach ~= 0) then 
			_UIToast:ShowMessageByLocalizingKey("CoachShop_HasCoach")
			return
		end
		
		-- 시럽 보유량 검증
		_UI_CoachShopService:CheckHaveRoyalSyrup(self.GoodsID)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 상태 변화 시 툴팁 표시를 제어하는 핸들러
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local state = event.state
		---------------------------------------------------------
		if state == ButtonState.Hover then
			self:ShowTooltip(true)
			
		else
			self:ShowTooltip(false)
		end
	end

end