@Component
script UI_CharDictionaryInfo extends Component

	property string nowCharID = ""

	property SpriteGUIRendererComponent SpriteGUIRendererComponent_CharBG = "c43bf4d1-ca31-4644-9873-805077cf5d64"

	property SpriteGUIRendererComponent sp_CharIcon = "ac5140fe-9a76-4229-ba9c-e00586be7552"

	property TextComponent t_Name = "a6c18115-ae97-4e61-ba35-9916a82bea67"

	property Entity HP = "e99df8ba-c390-4fe1-a229-53d4215ba846"

	property TextComponent t_cost = "dacbb65c-945c-41a0-8385-7f23956209b2"

	property TextComponent Text_Role = "d7ef3ed9-0603-47f6-b6fd-055fa92bdd29"

	property SpriteGUIRendererComponent Sprite_Role = "e6def6e7-88d3-429f-8d2c-21f3f6d7b31e"

	property Entity UI_MainStatIconList = "bddfd919-53eb-4876-8b05-8b89cf2c012b"

	property TextComponent t_mainstats = "cff50cd6-4ffb-4553-a549-73309fe5a06f"

	property TextComponent t_attackRange = "9cd83176-177e-4f4e-9776-41ab40838672"

	property TextComponent TextComponent_MP = "a4f1100a-6790-486a-a182-0094edc4734a"

	property Entity t_atk_List = "90e13355-df39-418d-9b7d-db864dc1745d"

	property Entity t_magic_List = "19adc197-097e-4ddf-8d8c-b51675957818"

	property Entity t_atkDef = "3a22b879-d81b-40cd-88bc-3b2854be07b1"

	property Entity t_magicDef = "c746340e-fd3d-480a-b8d2-d8c121aff590"

	property Entity t_atkSpd = "44ceb6bb-b8f0-4742-96ce-c73a1c481cd7"

	property TextComponent t_passiveSkill = "744744de-5d2b-4dd5-8bab-2b41dcead33f"

	property TextComponent t_activeSkill = "14e1d154-8f06-4160-8c6e-16caa0c768af"

	property TextComponent t_skillDetail = "b8614e25-741b-412b-a013-b0cde115c629"

	property Entity synergy1 = "4002e120-bb9d-43ba-a99f-82c03ae97125"

	property Entity synergy2 = "3d9ee502-bce0-4cb4-a4f6-1fda7d8afa20"

	property Entity synergy3 = "a98ef709-0510-402d-9baf-212f7e4dfa6b"

	property Entity UI_PassiveTitle = "ddc64237-c606-44ff-be0f-92f5e327f837"

	property Entity UI_ActiveTitle = "b1bac607-23ca-46bb-9729-dfcf89b9859a"

	property Entity UI_SkillDetailTitle = "91d6fe0f-67c8-48ce-854d-586ac95374ff"

	@ExecSpace("ClientOnly")
	method void UpdateInfo(string charID)
		-- 캐릭터 상세 정보 UI 전체 업데이트 (스탯, 시너지, 스킬 등)
		-- 스크롤을 위로 올립니다.
		self.UI_PassiveTitle.Parent.UI_AutoScroll:InitScroll()
		
		-- 이미 보고있는 화면이면 갱신하지 않도록 return
		if self.nowCharID == charID then return end
		
		-- 현재 보고 있는 화면의 ID를 저장합니다.
		self.nowCharID = charID
		
		
		-- 데이터를 가져옵니다.
		---@type CharDictionaryData
		local data = _DictionaryDataManager.CharDataList[charID]
		----------------------------------------------------------------------------------------
		-- 위에서부터 정보를 갱신합니다.
		----------------------------------------------------------------------------------------
		-- 캐릭터 배경
		self.SpriteGUIRendererComponent_CharBG.Color = _UI_Color.CharCost[data.Cost]
		
		-- 캐릭터 이미지
		local resourceinfo = _LoadResourcesInfo:GetUILocalPositionScale(data.IdleRUID)
		self.sp_CharIcon.ImageRUID = data.IdleRUID
		self.sp_CharIcon.LocalScale = resourceinfo["scale"]
		self.sp_CharIcon.LocalPosition = resourceinfo["pos"]
		----------------------------------------------------------------------------------------
		-- 보유 시너지
		---@type table<Entity>
		local synergyEntites = {self.synergy1, self.synergy2, self.synergy3}
		local syCount = data.SynergyCount
		
		if syCount == 0 then
			for i=1, #synergyEntites do
				synergyEntites[i].Enable = false
			end
		else
			if syCount < 3 then
				self.synergy3.Enable = false
			end
			for i=1, syCount, 1 do
				local syID = data.Synergies[i]
				synergyEntites[i].SpriteGUIRendererComponent.ImageRUID = _DictionaryDataManager.SynergyDataList[syID].IconRUID
				synergyEntites[i].Children[1].TextComponent.Text = _LocalizationService:GetText(syID.."_Name")
				synergyEntites[i].Enable = true
			end
			
		end
		
		-- 이름/코스트
		self.t_Name.Text = _LocalizationService:GetText(charID.."_Name")
		self.t_cost.Text = string.format("%d", data.Cost)
		----------------------------------------------------------------------------------------
		-- 포지션 (없을 경우 '-'로 표시)
		if data.Role == "" then
			self.Text_Role.Text = "-"
			self.Sprite_Role.Entity.Enable = false
		else
			self.Text_Role.Text = _LocalizationService:GetText("CharacterRole_"..data.Role)
			
			local roleIconRUID = {
				["Tank"] = "71ed340be22f45f8809e3f5634b544bc",	-- 탱커
				["SRD"] = "07cb828da903446fbad9c61359f56aa9",	-- 근딜
				["LRD"] = "af00c0f7a9614007862a76d1613bb347",	-- 원딜
				["Support"] = "421e0e02bcc148e79437f562c0425fad",	-- 서폿
			}
			
			self.Sprite_Role.ImageRUID = roleIconRUID[data.Role]
			self.Sprite_Role.Entity.Enable = true
		end
		
		-- 주력 스탯
		local dataSet_Status = _DataService:GetTable("Status")
		if data.MainStats == "" then
			self.t_mainstats.Text = "-"
		else
			-- 주력 스탯 셀의 콤마(,)를 기준으로 구분하기
			local mainStats = _UtilLogic:Split(data.MainStats, ",")
			local mainStat_text = ""
			for i=1, #mainStats do
				if i ~= 1 then
					mainStat_text = mainStat_text..", "
				end
				mainStat_text = mainStat_text.._LocalizationService:GetText(mainStats[i])
				
				local key = string.sub(mainStats[i], 8, -1) -- "Status_" 제거
				local row = dataSet_Status:FindRow("Key", key)
				local spriteGUIRendererCompo_icon = self.UI_MainStatIconList:GetChildByName(string.format("Icon_%d", i)).SpriteGUIRendererComponent
				spriteGUIRendererCompo_icon.ImageRUID = row:GetItem("IconRUID")	-- 아이콘 갱신
				spriteGUIRendererCompo_icon.Color = Color.FromHexCode(row:GetItem("Color")) -- 컬러 적용
			end
			
			self.t_mainstats.Text = mainStat_text -- 텍스트 갱신
		end
		
		-- 기본 스탯
		self.TextComponent_MP.Text = string.format("%d / %d", data.Status_MP, data.Status_MaxMP) 	-- MP
		self.t_atkDef.Children[1].TextComponent.Text = data.Status_Defence	-- 물리 방어력
		self.t_magicDef.Children[1].TextComponent.Text = data.Status_MagicalResistance	-- 마법 방어력
		self.t_atkSpd.Children[1].TextComponent.Text = data.Status_AttackSpeed	-- 공격 속도
		self.t_attackRange.Text = data.Status_AttackRange	 -- 공격 사거리
		
		local maxLev = 3
		for i = 1, maxLev do	-- 체력, 공격력, 마력 (레벨에 따라 변동)
			self.HP.Children[i].TextComponent.Text = data.Status_MaxHP[i]
			self.t_atk_List.Children[i].TextComponent.Text = data.Status_PhysicalAttack[i]
			self.t_magic_List.Children[i].TextComponent.Text = data.Status_MagicalAttack[i]
		end
		----------------------------------------------------------------------------------------
		-- 스킬 내용 갱신
		local statusEffectList = _UnitSkillDescLogic:GetStatusEffectList(nil, charID)
		local passiveDesc = _UnitSkillDescLogic:GetDefaultDesc(nil, charID, "passive")
		local activeDesc = _UnitSkillDescLogic:GetDefaultDesc(nil, charID, "active")
		local detailDesc = _UnitSkillDescLogic:GetDetailDesc(nil, charID)
		
					-- 패시브
		if passiveDesc == "-" then
			self.t_passiveSkill.Text = ""
			self.t_passiveSkill.Entity.Enable = false
			self.UI_PassiveTitle.Enable = false
		else
			self.t_passiveSkill.Text = passiveDesc
			self.t_passiveSkill.Entity.Enable = true
			self.UI_PassiveTitle.Enable = true
		end
					-- 액티브
		if activeDesc == "-" then
			self.t_activeSkill.Text = ""
			self.t_activeSkill.Entity.Enable = false
			self.UI_ActiveTitle.Enable = false
		else
			self.t_activeSkill.Text = activeDesc
			
			self.t_activeSkill.Entity.Enable = true
			self.UI_ActiveTitle.Enable = true
		end
					-- 디테일
		self.t_skillDetail.Text = detailDesc
		if detailDesc == "" then
			self.UI_SkillDetailTitle.Enable = false
		else
			self.UI_SkillDetailTitle.Enable = true
		end
		
		--            -- 상태이상
		--    ---@type MODUserDataSet
		--local statusTable = _DictionaryDataManager.statusEffectData
		--    
		--    for i=1, 3 do
		--        if statusEffectList[i] == nil then
		--            break
		--        else
		--            --local row = statusTable:FindRow("ID", statusEffectList[i])
		--            local statusdata = _DictionaryDataManager.statusEffectData[statusEffectList[i]]
		--            local name_key = statusdata.Name_Key
		--            local desc_key = statusdata.Desc_Key
		--        end
		--    end
	end

end