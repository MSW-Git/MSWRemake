@Component
script UI_Dictionary_ItemBT extends Component

	property UI_ItemDictionaryInfo itemDic_Info = "1597e0c3-5911-4cff-9eb7-34ac2470da3f"

	property string itemID = ""

	property Entity UI_FavoriteMark = nil

	property Entity UI_Icon = nil

	@ExecSpace("ClientOnly")
	method void Initialize()
		-- 아이템 버튼 UI 컴포넌트 초기화
		self.itemID = ""
		self.UI_FavoriteMark = self.Entity:GetChildByName("sp_FavoriteMark")
		self.UI_Icon = self.Entity:GetChildByName("Icon")
	end

	@ExecSpace("ClientOnly")
	method void UpdateIcon(string itemID)
		-- 아이템 아이콘 및 배경 업데이트, 즐겨찾기 상태 반영
		if self.UI_FavoriteMark == nil then 
			self:Initialize() 
		end
		-------------------------------------------------
		self.itemID = itemID
		
		if itemID == "" then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "696b848aaaea4cecb750aa19feaecf73"
			self.UI_Icon.Enable = false
			self.UI_FavoriteMark.Enable = false
			return
		end
		-------------------------------------------------
		local itemData = _DictionaryDataManager.ItemDataList[itemID]
		
		if itemData == nil then
			log("아이템 데이터가 없습니다. ID: ",itemID, " 엔티티: ", self.Entity.Name)
			return
		end
		
		-------------------------------------------------
		-- Icon
		self.UI_Icon.Enable = true
		self.UI_Icon.SpriteGUIRendererComponent.ImageRUID = itemData.RUID
		--self.UI_Icon.SpriteGUIRendererComponent.LocalScale = itemData.RUID_LocalScale
		self.UI_Icon.SpriteGUIRendererComponent.LocalPosition = itemData.RUID_LocalPos
		
		-- Background
		self.Entity.SpriteGUIRendererComponent.ImageRUID = itemData.BackgroundRUID
		
		-- 즐겨찾기 마크 활성화
		if self.UI_FavoriteMark ~= nil then
			-- 아예 없으면 그냥 빼기..
			self.UI_FavoriteMark.Enable = _DictionaryFavoriteListManager:IsSettedFave_Item(itemID)
		end
	end

	@EventSender("Logic", "DictionaryManager")
	handler HandleDictionaryFavoriteEvent(DictionaryFavoriteEvent event)
		-- 아이템 즐겨찾기 변경 이벤트 수신 시 마크 상태 갱신
		-- Parameters
		local settedFaveItem = event.settedFaveItem
		---------------------------------------------------------
		
		if settedFaveItem == "" or settedFaveItem == nil then return end
		
		if self.itemID == nil or self.itemID == "" then return end
		
		self.UI_FavoriteMark = self.Entity:GetChildByName("sp_FavoriteMark")
		
		if self.UI_FavoriteMark ~= nil then
			-- 아예 없으면 그냥 빼기..
			self.UI_FavoriteMark.Enable = _DictionaryFavoriteListManager:IsSettedFave_Item(self.itemID)
		end
	end

	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 마우스 클릭 시 아이템 즐겨찾기 토글 처리
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------
		if TouchId == -1 then
			
			if self.itemID == nil or self.itemID == "" then return end
			
			_DictionaryManager:Item_Favorite(self.itemID)
			return
		end
		
		
		if TouchId == -2 then
		
			if self.itemID == nil or self.itemID == "" then return end
			
			_DictionaryManager:Item_Favorite(self.itemID)
			--	log("즐찾설정!")
		end
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스 호버 시 아이템 정보 패널 표시 및 아웃라인 활성화
		if self.itemID == nil or self.itemID == "" then return end
		
		self.itemDic_Info:UpdateUI(self.itemID)
		self.itemDic_Info.Entity.Enable = true
		self.Entity.SpriteGUIRendererComponent.Outline = true
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스 호버 해제 시 정보 패널 숨김 및 아웃라인 비활성화
		self.itemDic_Info.Entity.Enable = false
		self.Entity.SpriteGUIRendererComponent.Outline = false
	end

end