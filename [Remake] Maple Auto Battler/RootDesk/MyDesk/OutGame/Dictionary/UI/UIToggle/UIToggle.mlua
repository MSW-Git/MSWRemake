@Component
script UIToggle extends Component

	property SpriteGUIRendererComponent CheckMark = nil

	property any OnValueChanged = nil

	property UIToggleGroup ToggleGroup = nil

	property boolean IsOn = false

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 토글 버튼 클릭 시 상태를 반전시키는 핸들러
		log("토글 온클릭")
		self:SetIsOn(not self.IsOn)
	end

	@ExecSpace("ClientOnly")
	method void SetToggleGroup(UIToggleGroup newGroup)
		-- 토글이 속할 그룹을 설정하고 그룹에 등록
		if self.ToggleGroup ~= nil then
			self.ToggleGroup:UnRegisterToggle(self)
		end
		
		if self.ToggleGroup ~= newGroup then
			self.ToggleGroup = newGroup
		end
		
		if self.ToggleGroup ~= nil and self.Enable then
			self.ToggleGroup:RegisterToggle(self)
		end
		
		if self.ToggleGroup ~= nil and self.IsOn and self.Enable then
			self.ToggleGroup:NotifyToggleOn(self, true)
		end
	end

	@ExecSpace("ClientOnly")
	method void SetIsOn(boolean value)
		-- 토글 상태를 설정하고 콜백을 호출
		self:Set(value, true)
	end

	@ExecSpace("ClientOnly")
	method void Set(boolean value, boolean sendCallback)
		-- 토글 상태를 내부적으로 설정하고 그룹 및 콜백 처리
		if self.IsOn == value then
			return
		end
		
		self.IsOn = value
		if self.ToggleGroup ~= nil and self.ToggleGroup.EnableInHierarchy and self.EnableInHierarchy then
			if self.IsOn or (not self.ToggleGroup:AnyToggleOn() and not self.ToggleGroup.AllowSwitchOff) then
				self.IsOn = true
				self.ToggleGroup:NotifyToggleOn(self, sendCallback)
			end
		end
		
		self:PlayEffect()
		
		if sendCallback then
			if self.OnValueChanged ~= nil then
				self.OnValueChanged(self.IsOn)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetIsOnWithoutNotify(boolean value)
		-- 콜백 없이 토글 상태만 설정
		self:Set(value, false)
	end

	@ExecSpace("ClientOnly")
	method void OnInitialize()
		-- 토글 컬포넌트 초기화 및 버튼 이벤트 연결
		if self.Entity.ButtonComponent == nil then
			self.Entity:AddComponent(ButtonComponent)
		end
		self.Entity:ConnectEvent(ButtonClickEvent, self.OnClick)
		
		self:SetToggleGroup(self.ToggleGroup)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 토글의 시각적 효과를 초기화
		self:PlayEffect()
	end

	@ExecSpace("ClientOnly")
	method void PlayEffect()
		-- 토글 상태에 따른 시각적 효과를 적용
		if self.CheckMark ~= nil then
			self.CheckMark.Entity:SetEnable(self.IsOn)
		else
			if self.IsOn == true then
				self.Entity.SpriteGUIRendererComponent.Color = self.Entity.ButtonComponent.Colors.PressedColor
			else
				self.Entity.SpriteGUIRendererComponent.Color = self.Entity.ButtonComponent.Colors.NormalColor
			end
		end
	end

end