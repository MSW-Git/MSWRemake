@Logic
script UI_SynergyDictionaryList extends Logic

	property Entity panel_list = "d6b1ad71-c51d-4a31-b295-d58e29c105a7"

	property UI_SynergyDictionaryInfo panel_Info = "8d4f4962-1dde-4500-a966-31ae53746f76"

	@ExecSpace("ClientOnly")
	method void CreateSynergyList()
		-- 시너지 목록 GridView 생성 및 초기 정보 표시
		---@type MODUserDataSet
		local synergyData = _DictionaryDataManager.SynergyDataList
		
		local gridView = self.panel_list.GridViewComponent
		gridView.TotalCount = synergyData:GetRowCount()
		gridView.ItemEntity = self.panel_list.Children[1]
		
		local function onRefresh(index, slot)
			--log(index)
			index = index + 1
			slot.UI_dictionary_SynergyBT:SynergyButtonInitialize(synergyData:GetCell(index, "SynergyID"))
		end
		
		gridView.OnRefresh = onRefresh
		gridView:Refresh(true, true)
		
		-----------------------------기본 info 화면 초기화-------------------------------
		self.panel_Info:UpdateInfo(synergyData:GetCell(1, "SynergyID"))
	end

end