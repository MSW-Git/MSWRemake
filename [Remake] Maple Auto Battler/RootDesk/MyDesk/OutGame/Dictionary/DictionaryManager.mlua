	@EventSender("Entity", "f8c3fbc5-ef49-4092-b806-079e2c4f9277")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 사전 닫기 버튼 클릭 시 즐겨찾기 데이터 저장 후 UI 비활성화
		_PlayerDataLogic:SetPlayerFavoriteDicData(_UserService.LocalPlayer)
		
		self.UI_Dictionary.Enable = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "ef8d61dc-f22e-4461-a592-88d1d0fca794")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 시즌 변경 드롭다운을 (비)활성화 합니다.
		-------------------------------------------------
		local ui_buttonList = _EntityService:GetEntityByPath("/ui/Dictionary/Main/SeasonDropdown/ButtonList")
		ui_buttonList.Enable = not ui_buttonList.Enable
	end

	@EventSender("Entity", "68d7950c-feb5-49a9-9f1b-8afabd3f55b2")
	handler HandleTabChangedEvent3(TabChangedEvent event)
		-- 시즌 선택 변경 시 사전 내용 갱신 및 UI 업데이트
		-- Parameters
		local ChangedIdx = event.ChangedIdx
		---------------------------------------------------------
		local seasonInfo = _DataService:GetTable("SeasonInfo")
		local seasonRow = seasonInfo:GetRow(ChangedIdx)
		local seasonText = seasonRow:GetItem("Season")
		
		self.NowShowingSeason = seasonText
		self.UI_SelectSeasonList.Parent.TextComponent.Text = _LocalizationService:GetTextFormat("SeasonTitle", seasonText)
		
		-- 새로고침
		--[[local category_2nd = self.ShowingPageIndex["2"]
		self:OnSelectCategory_2nd(category_2nd)]]
		self:OnSelectCategory_1st(1)
		
		
		-- 드롭다운 버튼들의 폰트 컬러를 바꿉니다.
		local ui_seasonList = _EntityService:GetEntityByPath("/ui/Dictionary/Main/SeasonDropdown/ButtonList")
		for i=1, #self.SeasonList do
			local button = ui_seasonList:GetChildByName(string.format("Button_%d", i))
			
			if i == ChangedIdx then
				button.TextComponent.FontColor = Color.white
			else
				button.TextComponent.FontColor = Color.FromHexCode("#4666b8")
			end
		end
		
		ui_seasonList.Enable = false
	end

end