@Logic
script UI_CollectionManager extends Logic

	property SyncTable<string> SeasonList

	property string nowSeason = "1.0"

	property string openedSeason = "1.0"

	property Entity UI_SeasonDropdown = "f1b810c7-1062-4e88-ae7a-fc65f426a84b"

	property Entity collectionMainBG = "cb6c6793-c01f-48c8-ba8f-4929ce13f5ef"

	property Entity bt_CharCol = "b03ef754-3ace-441b-8ad0-c8443891ba8b"

	property boolean SelectedCharacterCol = true

	property Entity CharacterCardList = "494c7ce0-4431-4d08-984e-45ecc915e195"

	property UI_CollectionCharacterInfo CharacterCollectionInfo = "a1730d60-9be3-45c0-8e02-8c5bcd6fd3e5"

	property Entity SynergyCollectionList = "890fada1-9e75-4599-b062-a696af1f05b0"

	property Entity Button_Collection_RedDot = "4061cfde-2ed4-4d6a-bf5c-ebd7ec259b54"

	property TextComponent t_collectRate = "5448d9c5-28f3-4546-8dd8-b30b4601ac18"

	property SpriteGUIRendererComponent sp_collectRate = "58738d61-88f7-46fd-80dd-1455a83de8c0"

	property TextComponent t_RateTitle = "c99f4927-1023-473f-970c-6c450c9a5720"

	property SyncTable<integer, string> Level_BG_Material

	property boolean isFilterNow = false

	property boolean isFirstOpen = true

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컬렉션 배경 매테리얼 초기화 및 첫 오픈 상태 설정
		-- 이게 최적화가 될까요? 안 된다면 그냥 지우겠습니다.. 우선 어디다 하면 좋을지 모르겠어서 여기에 BeginPlay를 부득이하게 ,,, 추가해보았습니다.
		self.Level_BG_Material[0] = ""
		self.Level_BG_Material[1] = "material://9be0aad8-086c-4194-8a06-446aea41c585"
		self.Level_BG_Material[2] = "material://ab5e26aa-9511-4108-9756-f66777262db9"
		self.Level_BG_Material[3] = "material://bb6e31a7-6d3b-4a7b-95f6-ac0e800673da"
		self.Level_BG_Material[4] = "material://5bffe175-6104-4035-b641-097ec76270f5"
		
		--------------------------------------------------------------
		-- 해금된 확장시즌 별로 해금해주고 싶었는데 OnBeginPlay에서는 클리어 기록을 갖고올 수 없어서 주석처리 합니다.
		--self:InitSeasonDropdown()
		
		-- 이번 세션에서 도감을 첫 오픈 하는 상황인지 확인합니다
		self.isFirstOpen = true
	end

	@ExecSpace("ClientOnly")
	method void CreateCharColList_NewGrid(string season)
		-- 지정된 시즌의 캐릭터 컬렉션 목록을 GridView로 생성
		-- 캐릭터 UI 목록을 만드는 함수입니다. (GridView 사용 버전)
		
		-- openedseason은 지금 UI에 열려있는 시즌이고 nowSeason은 시스템 상 현재 시즌
		self.openedSeason = season
		
		-- 딕셔너리 데이터 구조체 부르기
		local cDataList = _DictionaryDataManager.CharDataList
		
		-- 키값만 빼서 소팅
		---@type table<string>
		local charIDs = {}
		
		for cID, grade in pairs(_UserService.LocalPlayer.PlayerCollectionDataComponent.CharacterCollection) do
			
			local cData = cDataList[cID]
			if cData.ContainedSeason[season] == true then
				table.insert(charIDs, cID)
			end
			
		end
		
		-- 아이디 소팅
		table.sort(charIDs)
		
		local gridView = self.CharacterCardList.GridViewComponent
		gridView.TotalCount = #charIDs
		gridView.ItemEntity = self.CharacterCardList.Children[1]
		
		local function onRefresh(index, slot)
			index = index + 1
			slot.UI_CollectionCharacterCard:Initialize(charIDs[index], _UserService.LocalPlayer.PlayerCollectionDataComponent.CharacterCollection[charIDs[index]])
		end
		
		gridView.OnRefresh = onRefresh
		gridView:Refresh(true, true)
		
		
		self:Set_RateUI("Character")
	end

	@ExecSpace("ClientOnly")
	method void CreateSynergyColList(string season)
		-- 지정된 시즌의 시너지 컬렉션 목록을 생성하고 UI에 표시
		---@type integer
		local count = 1
		
		-- 딕셔너리 데이터 구조체 부르기
		local sDataList = _DictionaryDataManager.SynergyDataList
		
		
		-- 키값만 빼서 소팅
		---@type table<string>
		local synergyIDs = {}
		
		for sID, grade in pairs(_UserService.LocalPlayer.PlayerCollectionDataComponent.SynergyCollection) do
			
			if sID == "" then continue end
			
			local sData = sDataList[sID]
			if sData.ContainedSeason[season] then
				table.insert(synergyIDs, sID)
			end
			
		end
		
		-- 아이디 소팅
		table.sort(synergyIDs)
		
		for i=1, self.SynergyCollectionList.Children.Count do
			self.SynergyCollectionList.Children[i].Enable = false
		end
		
		local originSlot = self.SynergyCollectionList:GetChildByName("SynergyCollection")
		
		for i=1, #synergyIDs do
			local ui_slot = self.SynergyCollectionList:GetChildByName(string.format("SynergyCollection_%d", i))
			if isvalid(ui_slot) == false then
				ui_slot = originSlot:Clone(string.format("SynergyCollection_%d", i))
			end
			
			ui_slot.UI_CollectionSynergyBC:Initialize(synergyIDs[i], _UserService.LocalPlayer.PlayerCollectionDataComponent.SynergyCollection[synergyIDs[i]])
			ui_slot.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void OnEnable()
		-- 카메라 줌인아웃
		
		if self.isFirstOpen then
			self:InitSeasonDropdown()
		else
			self:OpenNewSeasonTab()
		end
		
		self.isFirstOpen = false
		
		_UI_CameraZoomLogic:Zoom()
		
		
		local colOpenSeason = self.nowSeason
		if self.openedSeason ~= self.nowSeason then
			colOpenSeason = self.openedSeason
		end
		
		self:CreateCharColList_NewGrid(colOpenSeason)
		self:CreateSynergyColList(colOpenSeason)
		
		self.Button_Collection_RedDot.Enable = false
		
		
		-- 어떤 카테고리 화면이 켜져있는지 확인..
		
		if self.SynergyCollectionList.Parent.Enable == false then
			self:Set_RateUI("Character")
		elseif self.CharacterCardList.Parent.Enable == false then
			self:Set_RateUI("Synergy")
		end
	end

	@ExecSpace("ClientOnly")
	method void Set_RateUI(string type)
		-- 선택된 컬렉션 타입에 따라 수집률 UI를 설정하고 애니메이션 표시
		local tween = nil
		local amount = 0
		local tweenTime = 0.5
		self.sp_collectRate.FillAmount = 0
		
		if type == "Character" then
			-- 수집율 세팅
			local text = _LocalizationService:GetTextFormat("SeasonTitle", self.openedSeason).." ".._LocalizationService:GetText("Character")
			self.t_RateTitle.Text = text
			
		
			local collectCount = _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_nowCharCount(self.openedSeason)
			local maxCount = _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_CharMaxCount(self.openedSeason)
			self.t_collectRate.Text = string.format("%d / %d", collectCount, maxCount)
			
			if collectCount <= 0 or maxCount <= 0 then
				amount = 0
			else
				amount = collectCount / maxCount	
			end
			
			-- 아래는 사용하지 않아서 지움
			--amount = _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_nowCharCount(self.openedSeason) / _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_CharMaxCount(self.openedSeason)
			
		elseif type == "Synergy" then
			-- 수집율 세팅
			local text = _LocalizationService:GetTextFormat("SeasonTitle", self.openedSeason).." ".._LocalizationService:GetText("Synergy")
			self.t_RateTitle.Text = text
			
			local collectCount = _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_nowSynergyCount(self.openedSeason)
			local maxCount = _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_SynergyMaxCount(self.openedSeason) 
			self.t_collectRate.Text = string.format("%d / %d", collectCount, maxCount)
			
			if collectCount <= 0 or maxCount <= 0 then
				amount = 0
			else
				amount = collectCount / maxCount	
			end
			
			-- 아래는 사용하지 않아서 지움
			--amount = _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_nowSynergyCount(self.openedSeason) / _UserService.LocalPlayer.PlayerCollectionDataComponent:Get_SynergyMaxCount(self.openedSeason)
		end
		
		tween = _TweenLogic:MakeTween(0, amount, tweenTime, EaseType.QuadEaseOut, function(amount) self.sp_collectRate.FillAmount = amount end)
		tween.LoopCount = 1
		tween.AutoDestroy = true
		tween:Play()
	end

	@ExecSpace("ClientOnly")
	method void CloseUI()
		-- 컴렉션 UI를 닫고 카메라 줄 리셋
		local ui_collection = _EntityService:GetEntityByPath("/ui/CollectionBook")
		
		_UI_CameraZoomLogic:Zoom()
		ui_collection.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void CharList_OnFilter()
		-- 4단계 이상 캐릭터만 필터링하여 표시
		--local entity = event.Entity
		
		--[[---@type table<string, integer>
		local seasonData = _UserService.LocalPlayer.PlayerCollectionDataComponent.CharacterCollection[self.openedSeason]
		--]]
		
		-- 딕셔너리 데이터 구조체 부르기
		local cDataList = _DictionaryDataManager.CharDataList
		
		---@type table<string>
		local filterData = {}
		
		for cID, grade in pairs(_UserService.LocalPlayer.PlayerCollectionDataComponent.CharacterCollection) do
			
			local cData = cDataList[cID]
			if cData.ContainedSeason[tostring(self.openedSeason)] then
				if grade >= 4 then
					table.insert(filterData, cID)
				end
			end
			
		end
		
		-- 키값만 빼서 소팅
		---@type table<string>
		local charIDs = table.keys(filterData)
		table.sort(charIDs)
			
		local gridView = self.CharacterCardList.GridViewComponent
		gridView.TotalCount = #charIDs
		gridView.ItemEntity = self.CharacterCardList.Children[1]
			
		local function onRefresh(index, slot)
			--log(index)
			index = index + 1
			slot.UI_CollectionCharacterCard:Initialize(filterData[index], 4)
		end
		
		gridView.OnRefresh = onRefresh
		gridView:Refresh(true, true)
	end

	@ExecSpace("ClientOnly")
	method void ChangeSeason(string season)
		-- 선택된 시즌으로 컴렉션 목록을 변경하고 UI 갱신
		self.openedSeason = season
		
		local bt = self.collectionMainBG:GetChildByName("SeasonButton")
		
		bt.TextComponent.Text = _LocalizationService:GetTextFormat("SeasonTitle", season)
		
		self:CreateCharColList_NewGrid(season)
		self:CreateSynergyColList(season)
	end

	@ExecSpace("ClientOnly")
	method void InitSeasonDropdown()
		-- 시즌 드롭다운 Initialization
		-- 확장시즌 해금에 따라 변화하므로 도감을 열 때마다 실행합니다.
		-----------------------------------------------------------------
		self:OpenNewSeasonTab()
				
		-- 첫번째 버튼에 포커스 (Children[1]은 DefaultButton)
		self.UI_SeasonDropdown.Children[2].TextComponent.FontColor = Color.white
		
		self.UI_SeasonDropdown.Parent.TextComponent.Text = _LocalizationService:GetTextFormat("SeasonTitle", self.SeasonList[1])
		self.UI_SeasonDropdown.TabComponent:SetChildren()
		
		
	end

	@ExecSpace("ClientOnly")
	method void OpenNewSeasonTab()
		-- 해금된 시즌들을 확인하여 드롭다운에 시즌 버튼 생성
		-----------------------------------------------------------------
		local seasonInfo = _DataService:GetTable("SeasonInfo")
		local seasonDropdown = self.UI_SeasonDropdown
		local ui_originButton = seasonDropdown:GetChildByName("DefaultButton")
		
		local playerData = _UserService.LocalPlayer.PlayerDataComponent
		
		for i=1, seasonInfo:GetRowCount() do
			local row = seasonInfo:GetRow(i)
			local season = row:GetItem("Season")
			
			-- season의 클리어 레벨 확인
			local singleMode = "Single_"..season
			
			self.SeasonList[i] = season
			local ui_button = seasonDropdown:GetChildByName(string.format("Button_%d", i))
			if isvalid(ui_button) == false then
				ui_button = ui_originButton:Clone(string.format("Button_%d", i))
			end
			
			-- 홀/짝수번째 버튼에 따라 버튼 색상 변경
			if i%2 == 0 then
				ui_button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#142037")
			else
				ui_button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#111b2d")
			end
			
			-- 버튼 텍스트 내용 변경
			ui_button.TextComponent.Text = _LocalizationService:GetTextFormat("SeasonTitle", season)
			
			if not isvalid(playerData.ClearLevelByMode[singleMode]) or playerData.ClearLevelByMode[singleMode] < 8 then
				break
			end
		end
		
		seasonDropdown.TabComponent:SetChildren()
			
		-- 현재 시즌 / UI에서 활성화 한 시즌 체크
		local colOpenSeason = self.nowSeason
		if self.openedSeason ~= self.nowSeason then
			colOpenSeason = self.openedSeason
		end
		
		self.UI_SeasonDropdown.Parent.TextComponent.Text = _LocalizationService:GetTextFormat("SeasonTitle", colOpenSeason)
	end

	@EventSender("Entity", "b03ef754-3ace-441b-8ad0-c8443891ba8b")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐릭터 컴렉션 탭 버튼 클릭 처리
		if self.SelectedCharacterCol == true then
			return
		end
		
		self.SelectedCharacterCol = true
		
		
		self:Set_RateUI("Character")
		
		self.CharacterCardList.Parent.Enable = true
		self.SynergyCollectionList.Parent.Enable = false
		
	end

	@EventSender("Entity", "c334d63a-bb8d-44ec-be18-ee1948308ea1")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 시너지 컴렉션 탭 버튼 클릭 처리
		if self.SelectedCharacterCol == false then
			return
		end
		
		self.SelectedCharacterCol = false
		
		self:Set_RateUI("Synergy")
		
		self.SynergyCollectionList.Parent.Enable = true
		self.CharacterCardList.Parent.Enable = false
	end

	@EventSender("Entity", "abdca328-916f-4550-95a6-a94605a92544")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 닫기 버튼을 눌렀을 때 드롭다운을 (비)활성화합니다.
		self.UI_SeasonDropdown.Enable = not self.UI_SeasonDropdown.Enable
		
		self:CloseUI()
	end

	@EventSender("Entity", "91e57dae-3b79-4520-a906-4cfd4620ac83")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 컴렉션 새로고침 버튼 클릭 처리
		self:OnEnable()
	end

	@EventSender("Entity", "214795f5-3245-4f8f-8474-32cd75945ab2")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 4단계 이상 캐릭터 필터 체크박스 토글 처리
		self.isFilterNow = not self.isFilterNow
		event.Entity:GetChildByName("img_check").Enable = self.isFilterNow
		
		if not self.isFilterNow then
			self:CreateCharColList_NewGrid(self.openedSeason)
			return
		else
			self:CharList_OnFilter()
		end
	end

	@EventSender("Entity", "8d4dbcf6-b339-4a04-a1c9-dcf77896abbf")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 시즌 버튼을 눌렀을 때 드롭다운을 (비)활성화합니다.
		self.UI_SeasonDropdown.Enable = not self.UI_SeasonDropdown.Enable
	end

	@EventSender("Entity", "f1b810c7-1062-4e88-ae7a-fc65f426a84b")
	handler HandleTabChangedEvent(TabChangedEvent event)
		-- 시즌 드롭다운에서 시즌 변경 시 해당 시즌으로 컴렉션 바꿀 처리
		-- Parameters
		local ChangedIdx = event.ChangedIdx
		---------------------------------------------------------
		self:ChangeSeason(self.SeasonList[ChangedIdx])
		
		for i=1, #self.SeasonList do
			local button = self.UI_SeasonDropdown:GetChildByName(string.format("Button_%d", i))
			
			if i == ChangedIdx then
				button.TextComponent.FontColor = Color.white
			else
				button.TextComponent.FontColor = Color.FromHexCode("#4666b8")
			end
		end
		
		self.UI_SeasonDropdown.Enable = false
	end

end