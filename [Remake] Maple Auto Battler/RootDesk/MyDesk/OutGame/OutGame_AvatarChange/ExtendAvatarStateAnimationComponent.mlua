@Component
script ExtendAvatarStateAnimationComponent extends AvatarStateAnimationComponent

	method void ReceiveStateChangeEvent(IEventSender sender, StateChangeEvent stateEvent)
		-- 아바타 렌더러가 활성화된 경우에만 상태 변경 이벤트를 처리
		if self.Entity.AvatarRendererComponent.Enable then
			__base:ReceiveStateChangeEvent(sender,stateEvent)
		elseif stateEvent.CurrentStateName ~= "ATTACK" and stateEvent.CurrentStateName ~= "ATTACK_WAIT" and stateEvent.PrevStateName ~= "ATTACK" and stateEvent.PrevStateName ~= "ATTACK_WAIT" then
			__base:ReceiveStateChangeEvent(sender,stateEvent)
		end
	end

end