		    --    -- 프로퍼티
		    --local keywordBDataset = _DataService:GetTable("Title_KeyWordBackDataset")
		    --local keywordFDataset = _DataService:GetTable("Title_KeyWordFrontDataset")
		    --
		    --local titleFrontText = ""
		    --local titleBackText = ""
		    --
		    ---- 각 요소의 텍스트 추출하고 태그 플레이트 적용
		    --for titleMaterialNum = 1, 3 do
		    --    log("titleValueTable[titleMaterialNum] = ", titleValueTable[titleMaterialNum])
		    --    local titleTemp = _UtilLogic:Split(titleValueTable[titleMaterialNum], "_")
		    --    if titleTemp[1] == "KeyWordFront" then -- 프론트
		    --        if titleTemp[2] ~= "KWF10000" then -- 타이틀이 공백일 경우의 예외처리
		    --            for fTitleNum = 1, keywordFDataset:GetRowCount() do
		    --                if titleTemp[2] == keywordFDataset:GetCell(fTitleNum, "KeyWordID") then
		    --                    titleFrontText = _LocalizationService:GetText(keywordFDataset:GetCell(fTitleNum, "Name"))
		    --                    break
		    --                end
		    --            end
		    --        end
		    --        
		    --    elseif titleTemp[1] == "KeyWordBack" then -- 백
		    --        if titleTemp[2] ~= "KWB10000" then -- 타이틀이 공백일 경우의 예외처리
		    --            for bTitleNum = 1, keywordBDataset:GetRowCount() do
		    --                if titleTemp[2] == keywordBDataset:GetCell(bTitleNum, "KeyWordID") then
		    --                    titleBackText = _LocalizationService:GetText(keywordBDataset:GetCell(bTitleNum, "Name"))
		    --                    break
		    --                end
		    --            end
		    --        end
		    --    else
		    --        for tagNum = 1, nameTagDataset:GetRowCount() do -- 태그 플레이트 --는 적용 불가. 폰트 색상만 적용
		    --            if titleTemp[2] == nameTagDataset:GetCell(tagNum, "NameTagID") then
		    --                --titleEntity.SpriteGUIRendererComponent.ImageRUID = string.format("thumbnail://%s", nameTagDataset:GetCell(tagNum, "ImageRUID")) 
