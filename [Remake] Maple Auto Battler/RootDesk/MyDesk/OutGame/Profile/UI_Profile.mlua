	@EventSender("Entity", "b641447e-2a09-43dd-a3d0-457c7bcc50cb")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 내 프로필 보기 버튼 클릭 시 자신의 프로필 UI 열기
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
