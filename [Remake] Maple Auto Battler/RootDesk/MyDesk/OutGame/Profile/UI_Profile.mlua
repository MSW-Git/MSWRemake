		end
		
		self.UI_ProfileAccessButton.Enable = false
		self:OnOpenUI()
		self:RequestData(self.TargetUserID)
		
		-- 데이터 요청 쿨타임 적용
		self.IsCooltime_DataRequest = true
		_TimerService:SetTimerOnce(function()
			self.IsCooltime_DataRequest = false
		end, 10)
	end

	@EventSender("Entity", "545434b2-f0e5-474d-90f8-81005b905480")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 칭호 설정 버튼 클릭 시 칭호 설정 UI 열기
		local player = _UserService.LocalPlayer
		self.UI_Profile.Enable = false
		
		_UI_CameraZoomLogic:Zoom()
		
		if _UI_PlayerTitleSetting.itsOn == false then
			_UI_PlayerTitleSetting.itsOn = true
			_UI_PlayerTitleSetting:InitOwnedTable()
		end
				
		player.TitleManager.currentSelectedElements = "NameTag"
		player.TitleManager.titleSettingUI.UI_PlayerTitleButton:TitleSettingInit()
		player.TitleManager.titleSettingUI.UI_PlayerTitleButton.NameTagButton.UI_PlayerTitleButton:ActivateButton()
		player.TitleManager.titleSettingUI.Enable = true
	end

end