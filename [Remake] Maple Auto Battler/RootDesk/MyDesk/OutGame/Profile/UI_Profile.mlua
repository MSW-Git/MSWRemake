@Logic
script UI_Profile extends Logic

	property string TargetUserID = ""

	property Entity UI_ProfileAccessButton = "1a191d1f-e451-4541-922f-3487409278c8"

	property boolean IsCooltime_DataRequest = false

	property boolean Record_IsPublic = false

	property integer Record_HighestTier = 0

	property string Record_HighestTier_Season = ""

	property integer Record_HighestRank = 0

	property integer Record_HighestRankRate = 0

	property string Record_HighestRank_Season = ""

	property number Record_HighestRank_Ordinal = 0

	property SyncTable<string, number> Record_PlayRecords

	property boolean History_IsPublic = false

	property SyncTable<number, boolean> History_IsWin

	property SyncTable<number, string> History_ModeType

	property SyncTable<number, string> History_ModeSeason

	property SyncTable<number, number> History_ModeLevel

	property SyncTable<number, string> History_LastRound

	property SyncTable<number, string> History_UnitInfo

	property SyncTable<number, string> History_RuneList

	property SyncTable<number, string> History_CoachList

	property SyncTable<number, number> History_GetTeamHP

	property SyncTable<number, number> History_GetCoinAmount

	property SyncTable<number, string> History_EndTime

	property Entity UI_Profile = "98596403-c356-472f-abc5-5dc43917cbc2"

	property Entity UI_Panel_Loading = "2bf5153e-04ae-4e64-9e8a-ede5c8248993"

	property Entity UI_Avatar = "f0daaf0c-3ec2-47b3-8561-33e17009a62b"

	property Entity UI_Nickname = "2c7c80d2-7159-4215-9f9d-9d3820c0aec9"

	property Entity UI_Title = "48a6100b-1d7c-4d51-8744-afef2dea903a"

	property Entity UI_Level = "d3bb92a5-6ec5-4436-b190-a957dabc9aec"

	property number Record_HighestTier_Ordinal = 0

	property SyncTable<string, boolean> IsLoadComplete

	property Entity UI_TabList = "194993f0-e237-461d-a35d-ff117aa72be0"

	property Entity UI_Page_Record = "5de9bc81-a5bf-4b23-b653-49efe4251686"

	property Entity UI_Page_History = "2258507a-baa3-43d7-8ab3-b008bc1c813a"

	property boolean IsPublicChangeCooldown = false

	@ExecSpace("Server")
	method void RequestData(string userID)
		-- 지정된 사용자의 프로필 데이터를 요청하고 UI에 표시할 정보를 설정
		-- 데이터를 가져오고, UI를 초기화합니다.
		------------------------------------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		if isvalid(user) == false then
			return
		end
		
		local playerDataCompo = user.PlayerDataComponent
		------------------------------------------------------------------------------------------------------------
		-- 기본 정보
		local equipTitleValue = string.format("%s/%s", user.TitleManager.EquippedTitle["KeyWordFront"], user.TitleManager.EquippedTitle["KeyWordBack"])
		self:SetData_DefaultProfile(equipTitleValue, playerDataCompo.Level, senderUserId)
		------------------------------------------------------------------------------------------------------------
		-- 프로필 공개 여부
		self:SetData_IsPublic(playerDataCompo.Profile_Record_IsPublic, playerDataCompo.Profile_History_IsPublic, senderUserId)
		------------------------------------------------------------------------------------------------------------
		-- [기록] 탭의 데이터를 받아옵니다.
		if userID ~= senderUserId and playerDataCompo.Profile_Record_IsPublic == false then
			-- 비공개인 경우
			self:SetData_Record(nil, nil, nil, nil, nil, nil, nil, nil, nil, nil, senderUserId)
		else
			-- 최고 티어 / 최고 랭킹 / 플레이 게임 / 승리 수 / 
			local highestTier = playerDataCompo.HighClearLevelInfo -- "Level/SeasonNumber/OrdinalNumber"
			local highestRank = playerDataCompo.HighRankInfo -- "RankNum/RankPercent/SeasonNumber/OrdinalNumber"
			local playedGameCount = playerDataCompo.PlayGameCount
			local winGameCount = playerDataCompo.WinGameCount
			------------------------------------------------------------------------------
			-- 업적 점수 및 달성률
			local achi_score = 0
			local achi_maxCount = 0
			local achi_doneCount = 0
			
			for id, value in pairs(user.AchievementManager.PlayerAchievementData) do
				for i=1, #value["state"] do
					achi_maxCount += 1
					if value["state"][i] == _AchievementStateEnum.Complete then
						achi_doneCount += 1
						
						local achieveInfo = _AchievementService:GetAchievementInfo(id)
						achi_score += achieveInfo.Score[i]
					end
				end
			end
			
			log("maxCount = ", achi_maxCount, ", doneCount = ", achi_doneCount)
			
			-- 업적 달성률
			local achiRate = achi_doneCount / achi_maxCount
			------------------------------------------------------------------------------
			-- 칭호 수집률
			local totalTitleCount = 0
			local ownedTitleCount = 0
			for id, value in pairs(user.TitleManager.NameTagTable) do
				totalTitleCount += 1
				if value == true then
					ownedTitleCount += 1
				end
			end
			for id, value in pairs(user.TitleManager.KeyWordFrontTable) do
				totalTitleCount += 1
				if value == true then
					ownedTitleCount += 1
				end
			end
			for id, value in pairs(user.TitleManager.KeyWordBackTable) do
				totalTitleCount += 1
				if value == true then
					ownedTitleCount += 1
				end
			end
			local titleCollectRate = ownedTitleCount / totalTitleCount
			------------------------------------------------------------------------------
			-- 코치 수집률
			local totalCoachCount = #table.keys(_CoachService.CoachData)
			local ownedCoachCount = 0
			for key, value in pairs(user.CoachManager.PlayerOwnedCoachesID) do
				if value >= 1 then
					ownedCoachCount += 1
				end
			end
			local coachCollectRate = ownedCoachCount / totalCoachCount
			------------------------------------------------------------------------------
			local collectionCompo = user.PlayerCollectionDataComponent
			
			-- 캐릭터 도감 수집률
			local totalCharCollectionCount = 0
			local ownedCharCollectionCount = 0
			
			for charID, value in pairs(collectionCompo.CharacterCollection) do
				ownedCharCollectionCount += value
				totalCharCollectionCount += 3
			end
			
			local charCollectRate = ownedCharCollectionCount / totalCharCollectionCount
			------------------------------------------------------------------------------
			-- 시너지 도감 수집률
			local totalSynCollectionCount = 0
			local ownedSynCollectionCount = 0
			
			local synergyTable = _DataService:GetTable("SynergyInfo")
			for i=1, synergyTable:GetRowCount() do
				local row = synergyTable:GetRow(i)
				for j=1, 5 do
					local needStep = row:GetItem(string.format("NeedCount_step%d", j))
					if needStep ~= "-" then
						totalSynCollectionCount += 1
					end
				end
			end
			
			for synID, value in pairs(collectionCompo.SynergyCollection) do
				if value == 3 then
					ownedSynCollectionCount += 1 	-- 고유만 있는 경우
				elseif value > 3 then
					ownedSynCollectionCount += (value-1)	-- 고유가 아니고 그 이상을 수집한 경우, 고유 등급 뱃지를 제외하고 수집한 것으로 간주
				else
					ownedSynCollectionCount += value
				end
			end
			
			local synCollectRate = ownedSynCollectionCount / totalSynCollectionCount
			------------------------------------------------------------------------------
			self:SetData_Record(highestTier, highestRank, 
				playedGameCount, winGameCount, achi_score, achiRate, 
				titleCollectRate, coachCollectRate, charCollectRate, synCollectRate,
				senderUserId)
		end
		------------------------------------------------------------------------------------------------------------
		-- [전적] 탭의 데이터를 받아옵니다.
		if userID ~= senderUserId and playerDataCompo.Profile_History_IsPublic == false then
			self:SetData_History(nil, nil, nil, nil, nil, nil, nil, nil, nil, nil, nil, senderUserId)
		else
			self:SetData_History(
				_UtilLogic:TableToString(playerDataCompo.Profile_IsWin),
				_UtilLogic:TableToString(playerDataCompo.Profile_ModeType),
				_UtilLogic:TableToString(playerDataCompo.Profile_ModeSeason),
				_UtilLogic:TableToString(playerDataCompo.Profile_ModeLevel),
				_UtilLogic:TableToString(playerDataCompo.Profile_LastRound),
				
				_UtilLogic:TableToString(playerDataCompo.Profile_EndTime),
				_UtilLogic:TableToString(playerDataCompo.Profile_UnitInfo),	-- "유닛ID_별수_아이템-아이템-아이템"/"..."
				_UtilLogic:TableToString(playerDataCompo.Profile_RuneList),
				_UtilLogic:TableToString(playerDataCompo.Profile_CoachList),
				_UtilLogic:TableToString(playerDataCompo.Profile_GetTeamHP),
				
				_UtilLogic:TableToString(playerDataCompo.Profile_GetCoinAmount),
				
				senderUserId
			)
		end
	end

	@ExecSpace("Client")
	method void OnOpenUI()
		-- 프로필 UI를 열고 로딩 상태를 초기화하며 데이터 로딩 완료를 감시
		self.UI_Panel_Loading.Enable = true
		self.UI_Panel_Loading.CanvasGroupComponent.GroupAlpha = 1
		
		self.UI_Profile.Enable = true
		
		self.IsLoadComplete["Default"] = false
		self.IsLoadComplete["Public"] = false
		self.IsLoadComplete["Record"] = false
		self.IsLoadComplete["History"] = false
		
		-- 0.5초마다 로딩 완료 여부를 검사합니다.
		local timerID = 0
		local checkLoadComplete = function()
			for key, value in pairs(self.IsLoadComplete) do
				if value == false then
					return
				end
			end
			
			-- 로딩 완료
			self.UI_TabList.TabComponent:ChangeTab(1)	-- 기본으로 Record 페이지를 보여줍니다.
			local alpha = 1
			local setLoadingPanelAlpha = function()
				alpha -= 0.025
				self.UI_Panel_Loading.CanvasGroupComponent.GroupAlpha = alpha
			end
			for i=1, 40 do
				_TimerService:SetTimerOnce(setLoadingPanelAlpha, i/80)
			end
			_TimerService:SetTimerOnce(function()
				self.UI_Panel_Loading.Enable = false
			end, 0.5)
			
			
			_TimerService:ClearTimer(timerID)
		end
		timerID = _TimerService:SetTimerOnce(checkLoadComplete, 0.5)
	end

	@ExecSpace("Client")
	method void SetData_DefaultProfile(string title, integer level)
		-- 사용자의 기본 프로필 정보(칭호, 레벨, 닉네임, 아바타)를 UI에 설정
		local userEntity =  _UserService:GetUserEntityByUserId(self.TargetUserID)
		------------------------------------------------------------------------------------------------------
		-- 자기 자신의 정보라면
		if self.TargetUserID == _UserService.LocalPlayer.OwnerId then
			self.UI_Title:GetChildByName("TitleUIButton").Enable = true
