				magicalDamageTaken_Value = magicalDamageTaken_Value .. string.format("%s/%d,", key, value)
			end
			
			if magicalDamageTaken_Value == "" then
				magicalDamageTaken_Value = "NIL"
			else
				magicalDamageTaken_Value = string.sub(magicalDamageTaken_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("MagicalDamageTaken_%d", i)] = magicalDamageTaken_Value
			----------------------------------------------------------------------------------
