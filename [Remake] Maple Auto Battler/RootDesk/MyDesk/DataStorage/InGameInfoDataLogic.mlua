			dbKey = string.format("UnitBattleStatisticsInfo_%s", _PlayerDataLogic.SetVer)
		else
			dbKey = string.format("UnitBattleStatisticsInfo_%s_%d", _PlayerDataLogic.SetVer, dataNum)
		end
		
		local errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(dbKey, _UtilLogic:TableToString(unitBattleStatisticsTable))
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(dbKey, _UtilLogic:TableToString(unitBattleStatisticsTable))
			end
		end
		--------------------------------------------------------------------------------------
		
	end

	@ExecSpace("ServerOnly")
	method void LoadInGameUnitBattleStatisticsData(string userID)
		
		-- 유닛 통계를 불러오는 함수입니다.
		--------------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local teamManager = user.TeamManager
		--------------------------------------------------------------------------------------
		-- 1. 데이터 불러오기
		local errorCode, data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("UnitBattleStatisticsInfo_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Load 실패")
				return
			else
				errorCode, data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("UnitBattleStatisticsInfo_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		local unitBattleStatisticsTable = _UtilLogic:StringToTable(data)
		--------------------------------------------------------------------------------------
		-- 2. 유닛 통계 넣기
		local units = _UnitSetLogic_New.UnitsParentEntity[userID]
		for i, unit in pairs(units.Children) do
			local unitBattleStatistics = unit.UnitBattleStatistics
			----------------------------------------------------------------------------------
			-- SetCharID
			local setCharID_Value = unitBattleStatisticsTable[string.format("SetCharID_%d", i)]
			
			if setCharID_Value ~= "NIL" then
				local setCharIDList = _UtilLogic:Split(setCharID_Value, ",")
				for _, checkValue in pairs(setCharIDList) do
					local keyInfo = _UtilLogic:Split(checkValue, "/")
					
					local key = keyInfo[1]
					local value = keyInfo[2]
					
					unitBattleStatistics:SetPropertyWithKey("SetCharID", key, value)
				end
			end
			----------------------------------------------------------------------------------
			-- SetCharLevel
			local setCharLevel_Value = unitBattleStatisticsTable[string.format("SetCharLevel_%d", i)]
			
			if setCharLevel_Value ~= "NIL" then
				local setCharLevelList = _UtilLogic:Split(setCharLevel_Value, ",")
				for _, checkValue in pairs(setCharLevelList) do
					local keyInfo = _UtilLogic:Split(checkValue, "/")
					
					local key = keyInfo[1]
					local value = keyInfo[2]
					
					unitBattleStatistics:SetPropertyWithKey("SetCharLevel", key, value)
				end
			end
			----------------------------------------------------------------------------------
			-- SetItemList
			local setItemList_Value = unitBattleStatisticsTable[string.format("SetItemList_%d", i)]
			
			if setItemList_Value ~= "NIL" then
				local setItemLists = _UtilLogic:Split(setItemList_Value, ",")
				for _, checkValue in pairs(setItemLists) do
					local keyInfo = _UtilLogic:Split(checkValue, "/")
					
					local key = keyInfo[1]
					local value = keyInfo[2]
					
					unitBattleStatistics:SetPropertyWithKey("SetItemList", key, value)
				end
			end
			----------------------------------------------------------------------------------
			-- PhysicalDamageDealt
			local physicalDamageDealt_Value = unitBattleStatisticsTable[string.format("PhysicalDamageDealt_%d", i)]
			
			if physicalDamageDealt_Value ~= "NIL" then
				local physicalDamageDealtList = _UtilLogic:Split(physicalDamageDealt_Value, ",")
				for _, checkValue in pairs(physicalDamageDealtList) do
