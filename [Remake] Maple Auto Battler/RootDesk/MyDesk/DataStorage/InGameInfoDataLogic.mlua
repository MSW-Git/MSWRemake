			----------------------------------------------------------------------------------
			-- HPAmountGainedByHealing
			local hpAmountGainedByHealing_Value = ""
			for key, value in pairs(unitBattleStatistics.HPAmountGainedByHealing) do
				hpAmountGainedByHealing_Value = hpAmountGainedByHealing_Value .. string.format("%s/%d,", key, value)
			end
			
			if hpAmountGainedByHealing_Value == "" then
				hpAmountGainedByHealing_Value = "NIL"
			else
				hpAmountGainedByHealing_Value = string.sub(hpAmountGainedByHealing_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("HPAmountGainedByHealing_%d", i)] = hpAmountGainedByHealing_Value
			----------------------------------------------------------------------------------
			-- HPAmountGainedByBloodAbsorption
			local hpAmountGainedByBloodAbsorption_Value = ""
			for key, value in pairs(unitBattleStatistics.HPAmountGainedByBloodAbsorption) do
				hpAmountGainedByBloodAbsorption_Value = hpAmountGainedByBloodAbsorption_Value .. string.format("%s/%d,", key, value)
			end
			
			if hpAmountGainedByBloodAbsorption_Value == "" then
				hpAmountGainedByBloodAbsorption_Value = "NIL"
			else
				hpAmountGainedByBloodAbsorption_Value = string.sub(hpAmountGainedByBloodAbsorption_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("HPAmountGainedByBloodAbsorption_%d", i)] = hpAmountGainedByBloodAbsorption_Value
			----------------------------------------------------------------------------------
			-- ShieldAmountGained
			local shieldAmountGained_Value = ""
			for key, value in pairs(unitBattleStatistics.ShieldAmountGained) do
				shieldAmountGained_Value = shieldAmountGained_Value .. string.format("%s/%d,", key, value)
			end
			
			if shieldAmountGained_Value == "" then
				shieldAmountGained_Value = "NIL"
			else
				shieldAmountGained_Value = string.sub(shieldAmountGained_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("ShieldAmountGained_%d", i)] = shieldAmountGained_Value
			----------------------------------------------------------------------------------
			-- HPAmountProvidedToHealing
			local hpAmountProvidedToHealing_Value = ""
			for key, value in pairs(unitBattleStatistics.HPAmountProvidedToHealing) do
				hpAmountProvidedToHealing_Value = hpAmountProvidedToHealing_Value .. string.format("%s/%d,", key, value)
			end
			
			if hpAmountProvidedToHealing_Value == "" then
				hpAmountProvidedToHealing_Value = "NIL"
			else
