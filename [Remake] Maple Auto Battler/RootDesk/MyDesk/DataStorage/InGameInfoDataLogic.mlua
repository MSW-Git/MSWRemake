				trueDamageTaken_Value = trueDamageTaken_Value .. string.format("%s/%d,", key, value)
			end
			
			if trueDamageTaken_Value == "" then
				trueDamageTaken_Value = "NIL"
			else
				trueDamageTaken_Value = string.sub(trueDamageTaken_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("TrueDamageTaken_%d", i)] = trueDamageTaken_Value
			----------------------------------------------------------------------------------
			-- PhysicalDamageAbsorbed
			local physicalDamageAbsorbed_Value = ""
			for key, value in pairs(unitBattleStatistics.PhysicalDamageAbsorbed) do
				physicalDamageAbsorbed_Value = physicalDamageAbsorbed_Value .. string.format("%s/%d,", key, value)
			end
			
			if physicalDamageAbsorbed_Value == "" then
				physicalDamageAbsorbed_Value = "NIL"
			else
				physicalDamageAbsorbed_Value = string.sub(physicalDamageAbsorbed_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("PhysicalDamageAbsorbed_%d", i)] = physicalDamageAbsorbed_Value
			----------------------------------------------------------------------------------
			-- MagicalDamageAbsorbed
		
			local MagicalDamageAbsorbed_Value = ""
			for key, value in pairs(unitBattleStatistics.MagicalDamageAbsorbed) do
				MagicalDamageAbsorbed_Value = MagicalDamageAbsorbed_Value .. string.format("%s/%d,", key, value)
			end
			
			if MagicalDamageAbsorbed_Value == "" then
				MagicalDamageAbsorbed_Value = "NIL"
			else
				MagicalDamageAbsorbed_Value = string.sub(MagicalDamageAbsorbed_Value, 1, -2)
			end
			unitBattleStatisticsTable[string.format("MagicalDamageAbsorbed_%d", i)] = MagicalDamageAbsorbed_Value
			----------------------------------------------------------------------------------
			-- TrueDamageAbsorbed
			local trueDamageAbsorbed_Value = ""
			for key, value in pairs(unitBattleStatistics.TrueDamageAbsorbed) do
				trueDamageAbsorbed_Value = trueDamageAbsorbed_Value .. string.format("%s/%d,", key, value)
			end
			
			if trueDamageAbsorbed_Value == "" then
				trueDamageAbsorbed_Value = "NIL"
			else
				trueDamageAbsorbed_Value = string.sub(trueDamageAbsorbed_Value, 1, -2)
