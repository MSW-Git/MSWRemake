	@ExecSpace("ServerOnly")
	method void SaveGameTeamBattleStatisticsData(Entity user, number dataNum)
		-- 팀 내 통계를 저장하는 함수입니다.
		--------------------------------------------------------------------------------------
		local userID = user.OwnerId
		local teamManager = user.TeamManager
		local teamBattleStatistics = user.TeamBattleStatistics
		--------------------------------------------------------------------------------------
		-- 모든 변수를 저장해봅시다..
		---@type table<string,any>
		local teamBattleStatisticsTable = {}
		--------------------------------------------------------------------------------------
		-- SetRuneCard
		local setRuneCard_Value = ""
		for key, value in pairs(teamBattleStatistics.SetRuneCard) do
			setRuneCard_Value = setRuneCard_Value .. string.format("%s/%s,", key, value)
		end
		
		if setRuneCard_Value == "" then
			setRuneCard_Value = "NIL"
		else
			setRuneCard_Value = string.sub(setRuneCard_Value, 1, -2)
		end
		teamBattleStatisticsTable["SetRuneCard"] = setRuneCard_Value
		--------------------------------------------------------------------------------------
		-- EnemySetRuneCard
		local enemySetRuneCard_Value = ""
		for key, value in pairs(teamBattleStatistics.EnemySetRuneCard) do
			enemySetRuneCard_Value = enemySetRuneCard_Value .. string.format("%s/%s,", key, value)
		end
		
		if enemySetRuneCard_Value == "" then
			enemySetRuneCard_Value = "NIL"
		else
			enemySetRuneCard_Value = string.sub(enemySetRuneCard_Value, 1, -2)
		end
		teamBattleStatisticsTable["EnemySetRuneCard"] = enemySetRuneCard_Value
		--------------------------------------------------------------------------------------
		-- SetEnemyNameKey
		local setEnemyNameKey_Value = ""
		for key, value in pairs(teamBattleStatistics.SetEnemyNameKey) do
			setEnemyNameKey_Value = setEnemyNameKey_Value .. string.format("%s/%s,", key, value)
		end
		
		if setEnemyNameKey_Value == "" then
			setEnemyNameKey_Value = "NIL"
		else
			setEnemyNameKey_Value = string.sub(setEnemyNameKey_Value, 1, -2)
		end
		teamBattleStatisticsTable["SetEnemyNameKey"] = setEnemyNameKey_Value
		--------------------------------------------------------------------------------------
		-- SetMyCoaches
		local setMyCoach_Value = ""
		for _, coachID in pairs(teamBattleStatistics.SetMyCoaches) do
			setMyCoach_Value = string.format("%s%s,", setMyCoach_Value, coachID)
		end
		
		if setMyCoach_Value == "" then
			setMyCoach_Value = "NIL"
		else
			setMyCoach_Value = string.sub(setMyCoach_Value, 1, -2)
		end
		teamBattleStatisticsTable["SetMyCoaches"] = setMyCoach_Value
		--------------------------------------------------------------------------------------
		-- SetEnemyPresetID
		local epID_Value = ""
		for key, value in pairs(teamBattleStatistics.SetEnemyPresetID) do
			epID_Value = epID_Value .. string.format("%s/%s,", key, value)
		end
		
		if epID_Value == "" then
			epID_Value = "NIL"
		else
			epID_Value = string.sub(epID_Value, 1, -2)
		end
		teamBattleStatisticsTable["SetEnemyPresetID"] = epID_Value
		--------------------------------------------------------------------------------------
		-- SetRoundResult
		local rr_Value = ""
		for key, value in pairs(teamBattleStatistics.SetRoundResult) do
			rr_Value = rr_Value .. string.format("%s/%s,", key, value)
		end
		
		if rr_Value == "" then
			rr_Value = "NIL"
		else
			rr_Value = string.sub(rr_Value, 1, -2)
		end
		teamBattleStatisticsTable["SetRoundResult"] = rr_Value
		--------------------------------------------------------------------------------------
		-- SetRankAmount
		local ra_Value = ""
		for key, value in pairs(teamBattleStatistics.SetRankAmount) do
			ra_Value = ra_Value .. string.format("%s/%d,", key, value)
		end
		
		if ra_Value == "" then
			ra_Value = "NIL"
		else
			ra_Value = string.sub(ra_Value, 1, -2)
		end
		teamBattleStatisticsTable["SetRankAmount"] = ra_Value
		--------------------------------------------------------------------------------------
		-- 2. 데이터 저장
		local dbKey = string.format("TeamBattleStatisticsInfo_%s", _PlayerDataLogic.SetVer)
		if dataNum ~= 0 then
			dbKey = string.format("TeamBattleStatisticsInfo_%s_%d", _PlayerDataLogic.SetVer, dataNum)
		end
		local errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(dbKey, _UtilLogic:TableToString(teamBattleStatisticsTable))
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(dbKey, _UtilLogic:TableToString(teamBattleStatisticsTable))
			end
		end
		--------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void LoadInGameTeamBattleStatisticsData(string userID)
		-- 팀 내 통계를 불러오는 함수입니다.
		--------------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local teamManager = user.TeamManager
		local teamBattleStatistics = user.TeamBattleStatistics
		--------------------------------------------------------------------------------------
		-- 1. 데이터 불러오기
		local errorCode, data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("TeamBattleStatisticsInfo_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Load 실패")
				return
			else
				errorCode, data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("TeamBattleStatisticsInfo_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		local teamBattleStatisticsTable = _UtilLogic:StringToTable(data)
		--------------------------------------------------------------------------------------
		-- SetRuneCard
		if teamBattleStatisticsTable["SetRuneCard"] ~= "NIL" then
			local setRuneCard_Value = _UtilLogic:Split(teamBattleStatisticsTable["SetRuneCard"], ",")
			for _, checkValue in pairs(setRuneCard_Value) do
				local keyInfo = _UtilLogic:Split(checkValue, "/")
				
				local key = keyInfo[1]
				local value = keyInfo[2]
				
				teamBattleStatistics:SetPropertyWithKey("SetRuneCard", key, value)
			end
		end
		--------------------------------------------------------------------------------------
		-- EnemySetRuneCard
		if teamBattleStatisticsTable["EnemySetRuneCard"] ~= "NIL" then
			local enemySetRuneCard_Value = _UtilLogic:Split(teamBattleStatisticsTable["EnemySetRuneCard"], ",")
			for _, checkValue in pairs(enemySetRuneCard_Value) do
				local keyInfo = _UtilLogic:Split(checkValue, "/")
				
				local key = keyInfo[1]
				local value = keyInfo[2]
				
				teamBattleStatistics:SetPropertyWithKey("EnemySetRuneCard", key, value)
			end
		end
		--------------------------------------------------------------------------------------
		-- SetEnemyNameKey
		if teamBattleStatisticsTable["SetEnemyNameKey"] ~= "NIL" then
			local setEnemyNameKey_Value = _UtilLogic:Split(teamBattleStatisticsTable["SetEnemyNameKey"], ",")
			for _, checkValue in pairs(setEnemyNameKey_Value) do
				local keyInfo = _UtilLogic:Split(checkValue, "/")
				
				local key = keyInfo[1]
				local value = keyInfo[2]
				
				teamBattleStatistics:SetPropertyWithKey("SetEnemyNameKey", key, value)
			end
		end
		--------------------------------------------------------------------------------------
		-- SetMyCoaches
		if teamBattleStatisticsTable["SetMyCoaches"] ~= "NIL" then
			teamBattleStatistics:SetCoachesProperty(teamBattleStatisticsTable["SetMyCoaches"])
		end
		--------------------------------------------------------------------------------------
		-- SetEnemyPresetID
		if teamBattleStatisticsTable["SetEnemyPresetID"] ~= "NIL" then
			local epID_Value = _UtilLogic:Split(teamBattleStatisticsTable["SetEnemyPresetID"], ",")
			for _, checkValue in pairs(epID_Value) do
				local keyInfo = _UtilLogic:Split(checkValue, "/")
				
				local key = keyInfo[1]
				local value = keyInfo[2]
				
				teamBattleStatistics:SetPropertyWithKey("SetEnemyPresetID", key, value)
			end
		end
		--------------------------------------------------------------------------------------
		-- SetRoundResult
		if teamBattleStatisticsTable["SetRoundResult"] ~= "NIL" then
			local rr_Value = _UtilLogic:Split(teamBattleStatisticsTable["SetRoundResult"], ",")
			for _, checkValue in pairs(rr_Value) do
				local keyInfo = _UtilLogic:Split(checkValue, "/")
				
				local key = keyInfo[1]
				local value = keyInfo[2]
				
				teamBattleStatistics:SetPropertyWithKey("SetRoundResult", key, value)
			end
		end
		--------------------------------------------------------------------------------------
		-- SetRankAmount
		if teamBattleStatisticsTable["SetRankAmount"] ~= "NIL" then
			local rr_Value = _UtilLogic:Split(teamBattleStatisticsTable["SetRankAmount"], ",")
			for _, checkValue in pairs(rr_Value) do
				local keyInfo = _UtilLogic:Split(checkValue, "/")
				
				local key = keyInfo[1]
				local value = tonumber(keyInfo[2])
				
				teamBattleStatistics:SetRankCountProperty(key, value, "Set")
			end
		end
		--------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void SetSavedDataDB(boolean saved, Entity user)
		-- SetSavedData : 저장된 데이터가 있는지 확인할 수 있도록 체크하는 프로퍼티입니다.
		--------------------------------------------------------
		local userID = user.OwnerId
		local gameManager = user.GameManager
		local season = _ModeDataLogic:GetVersionInfo("season")
		local ordinalNumber = _ModeDataLogic:GetVersionInfo("ordinal")
		--------------------------------------------------------
		gameManager.SetSavedData = saved
		
		local mType = _UtilLogic:Split(gameManager.ModeType)
		
		local sValue = ""
		if saved then
			sValue = string.format("TRUE_%s_%s_%d", mType[1], season, ordinalNumber)
			self:LoadInGameInfoDataInLobby(user)
		else
			sValue = string.format("FALSE_%s_%s_%d", mType[1], season, ordinalNumber)
		end
		
		local errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("SavedData_%s", _PlayerDataLogic.SetVer), sValue)
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("SavedData_%s", _PlayerDataLogic.SetVer), sValue)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void GetSavedDataDB(string userID)
		-- SetSavedData : 저장된 데이터가 있는지 확인할 수 있도록 체크하는 프로퍼티입니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local gameManager = user.GameManager
		local season = _ModeDataLogic:GetVersionInfo("season")
		local ordinalNumber = _ModeDataLogic:GetVersionInfo("ordinal")
		--------------------------------------------------------
		-- 이어하기 데이터 확인
		local errorCode, checkedDataValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SavedData_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				errorCode, checkedDataValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SavedData_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		if isvalid(checkedDataValue) then
			local checkedData = _UtilLogic:Split(checkedDataValue, "_")
			log("checkedDataValue = ", checkedDataValue)
			if checkedData[1] == "TRUE" then
				if checkedData[2] ~= "Rank" then
					gameManager.SetSavedData = true
					self:LoadInGameInfoDataInLobby(user)
				elseif season == tonumber(checkedData[3]) and ordinalNumber == tonumber(checkedData[4]) then
					gameManager.SetSavedData = true
					self:LoadInGameInfoDataInLobby(user)
				end
			else
				gameManager.SetSavedData = false
			end
		else
			gameManager.SetSavedData = false
		end
		
	end

	@ExecSpace("ServerOnly")
	method void LoadInGameInfoDataInLobby(Entity user)
		-- 로비에서 GameInfo 중 필요한 데이터 일부만 불러오는 함수입니다.
		--------------------------------------------------------------------------------------
		local userID = user.OwnerId
		local gameManager = user.GameManager
		--------------------------------------------------------------------------------------
		-- 0. 데이터 불러오기
		local errorCode, gameInfo = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("GameInfo_%s", _PlayerDataLogic.SetVer))
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Load 실패")
				return
			else
				errorCode, gameInfo = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("GameInfo_%s", _PlayerDataLogic.SetVer))
			end
		end
		
		local gameInfoTable = _UtilLogic:StringToTable(gameInfo)
		
		if not isvalid(gameInfoTable) then
			return
		end
		
		--------------------------------------------------------------------------------------
		-- 1. 모드 타입 및 레벨, 퇴장 정보
		gameManager.NeedDataLoadVersion = gameInfoTable["ModeVersion"]
		gameManager.NeedDataLoadType = gameInfoTable["ModeType"]
		gameManager.NeedDataLoadLevel = gameInfoTable["ModeLevel"]
		gameManager.NeedDataLoadPhaseType = gameInfoTable["PhaseType"]
		--------------------------------------------------------------------------------------
		-- 2. 스테이지 및 라운드 정보
		gameManager.NeedDataLoadStage = gameInfoTable["Stage"]
		gameManager.NeedDataLoadRound = gameInfoTable["Round"]
		--------------------------------------------------------------------------------------
		-- 3. 현재 시즌, 분기 체크
		if gameManager.NeedDataLoadType == "Rank" then
			-- 해당 분기에 처음 접속 했는지 확인
			if gameManager.ChangeSeason then
				gameManager.ChangeSeason = false
				gameManager.SetSavedData = false
				self:SetSavedDataDB(false, user)
			end
		elseif gameManager.NeedDataLoadType == "Tutorial" then
			gameManager.SetSavedData = false
		end
		
		----------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void SaveGameEndData(Entity user, boolean win)
		-- 게임이 끝났을 때, 데이터를 저장하는 함수입니다.
		--------------------------------------------------------
		local userID = user.OwnerId
		local playerDataComponent = user.PlayerDataComponent
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		local coachManager = user.CoachManager
		--------------------------------------------------------
		--[[
			1. 전체 기록
				- 총 게임 횟수
			2. 게임 내 기록
				- 승패 여부
				- 게임 모드 및 도달 스테이지
				- 사용 유닛 및 장착 아이템
				- 최종 룬카드
				- 사용 코치
				- 최종 팀 체력
				- 지금까지 획득한 코인
				- 지금까지 사용한 코인
				- 게임 일시
		]]--
		--------------------------------------------------------
		-- 1. 전체 기록
		-- 총 게임 횟수 증가
		playerDataComponent.PlayGameCount += 1
		
		if win then
			playerDataComponent.WinGameCount += 1
		end
		
		local c_value = string.format("%d/%d/%d", playerDataComponent.StartGameCount, playerDataComponent.PlayGameCount, playerDataComponent.WinGameCount)
		local c_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("GameCountData_%s", _PlayerDataLogic.SetVer), c_value)
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				c_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("GameCountData_%s", _PlayerDataLogic.SetVer), c_value)
			end
		end
		
		--------------------------------------------------------
		-- 2. 게임 내 기록
		-- 기록 데이터 변환
		local egDataStringValue = ""
		
			-- 승패 여부
		if win then
			egDataStringValue = "win,"
		else
			egDataStringValue = "lose,"
		end
		
			-- 게임 모드 및 도달 스테이지
		local roundKey = string.format("%d-%d", gameManager.Stage, gameManager.Round)
		
		local modeType = gameManager.ModeType
		if modeType == "Rank" then
			modeType = string.format("%s_%d", modeType, _ModeDataLogic.Season)
		end
		egDataStringValue = string.format("%s%s_%d_%s,", egDataStringValue, modeType, gameManager.ModeLevel, roundKey)
		
		-- 8-3 반복 플레이 처리
		local setKey = roundKey
		if setKey == "8-3" then
			setKey = "8-3-1"
			for i = 1, 5 do
				local checkKey = string.format("%s-%d", roundKey, i)
				if isvalid(user.TeamBattleStatistics.SetRuneCard[checkKey]) then
					setKey = checkKey
				else
					break
				end
			end	
		end
		
			-- 사용 유닛 및 장착 아이템
		local ownUnitsStringValue = ""
		for _, unit in pairs(teamManager.OwnUnits) do
			local unitStringValue = ""
			
			if unit.UnitBattleStatistics.SetCharID[setKey] ~= nil then
				-- 캐릭터_별 개수_(아이템들)
				local unitCharID = unit.UnitInfo.charID
				local unitCharLevel = unit.UnitInfo.level
				unitStringValue = string.format("%s_%d_", unitCharID, unitCharLevel)
				
				
				
				local itemStringValue = ""
				-- 아이템-아이템-...
				for _, itemID in pairs(unit.UnitStatus.EquippedItemIDList) do
					itemStringValue = string.format("%s%s-", itemStringValue, itemID)
				end
				
				if itemStringValue == "" then
					itemStringValue = "NIL"
				else
					itemStringValue = string.sub(itemStringValue, 1, -2)
				end
				
				-- (캐릭터정보)/(캐릭터정보)/...
				ownUnitsStringValue = string.format("%s%s%s/", ownUnitsStringValue, unitStringValue, itemStringValue)
			end
		end
		
		if ownUnitsStringValue == "" then
			ownUnitsStringValue = "NIL"
		else
			ownUnitsStringValue = string.sub(ownUnitsStringValue, 1, -2)
		end
		
		egDataStringValue = string.format("%s%s,", egDataStringValue, ownUnitsStringValue)
		
			-- 최종 룬카드
		local runeStringValue = ""
		for _, runeUID in pairs(teamManager.OwnRunes) do
			local runeIDInfo = _UtilLogic:Split(runeUID, "_")
			runeStringValue = string.format("%s%s_", runeStringValue, runeIDInfo[1])
		end
		
		if runeStringValue == "" then
			runeStringValue = "NIL"
		else
			runeStringValue = string.sub(runeStringValue, 1, -2)
		end
		egDataStringValue = string.format("%s%s,", egDataStringValue, runeStringValue)
		
			-- 사용 코치
		local coachStringValue = ""
		for _, coachID in pairs(coachManager.PlayCoachesID) do
			coachStringValue = string.format("%s%s_", coachStringValue, coachID)
		end
		
		if coachStringValue == "" then
			coachStringValue = "NIL"
		else
			coachStringValue = string.sub(coachStringValue, 1, -2)
		end
		egDataStringValue = string.format("%s%s,", egDataStringValue, coachStringValue)
		
			-- 최종 팀 체력
		egDataStringValue = string.format("%s%d,", egDataStringValue, teamManager.HP)
		
			-- 지금까지 획득한 코인
		egDataStringValue = string.format("%s%d,", egDataStringValue, teamManager.GetGoldAmount)
		
			-- 지금까지 사용한 코인
		egDataStringValue = string.format("%s%d,", egDataStringValue, teamManager.UsedGoldAmount)
		
			-- 게임 일시
		local nowTime = (DateTime.UtcNow):ToFormattedString("MM/dd/yyyy HH:mm:ss")
		egDataStringValue = string.format("%s%s,", egDataStringValue, nowTime)
		
		-- DB에 기록 후
		local keyName = string.format("EndGameData_%s_%d", _PlayerDataLogic.SetVer, playerDataComponent.PlayGameCount)
		
		local eg_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(keyName, egDataStringValue)
		for i = 1, 10 do
			if eg_err == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				eg_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(keyName, egDataStringValue)
			end
		end
		
		-- 쌓인 통계 또한 DB에 기록
		---------------------------------------
		self:SaveGameUnitBattleStatisticsData(user, playerDataComponent.PlayGameCount)
		self:SaveGameTeamBattleStatisticsData(user, playerDataComponent.PlayGameCount)
		---------------------------------------
		
		-- 컴포넌트에 저장
		playerDataComponent:SetGameRecordProperty(nil)
	end

	@ExecSpace("ServerOnly")
	method void LoadEndInGameData(string userID)
		-- 로드가 완료되면, 이어하기 데이터를 더 불러오지 않도록 합니다.
		---------------------------------------------------------------------------------
		local errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("SavedData_%s", _PlayerDataLogic.SetVer), "FALSE")
		for i = 1, 10 do
			if errorCode == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				errorCode = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("SavedData_%s", _PlayerDataLogic.SetVer), "FALSE")
			end
		end
		---------------------------------------------------------------------------------
	end

end