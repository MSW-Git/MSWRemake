	@ExecSpace("ServerOnly")
	method void GetPlayerFavoriteDicData(string userID)
		-- 사전 즐겨찾기 데이터를 불러옵니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		
		-- Char
		local dc_err, dc_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DictionaryCharData_%s", self.SetVer))
		for i = 1, 10 do
			if dc_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				dc_err, dc_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DictionaryCharData_%s", self.SetVer))
			end
		end
		
		if not isvalid(dc_Value) then
			dc_Value = "NIL"
		end
		--------------------------------------------------------
		-- Rune
		local dr_err, dr_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DictionaryRuneData_%s", self.SetVer))
		for i = 1, 10 do
			if dr_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				dr_err, dr_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DictionaryRuneData_%s", self.SetVer))
			end
		end
		
		if not isvalid(dr_Value) then
			dr_Value = "NIL"
		end
		--------------------------------------------------------
		-- Item
		local di_err, di_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DictionaryItemData_%s", self.SetVer))
		for i = 1, 10 do
			if di_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				di_err, di_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DictionaryItemData_%s", self.SetVer))
			end
		end
		
		if not isvalid(di_Value) then
			di_Value = "NIL"
		end
		--------------------------------------------------------
		-- 클라에 저장
		self:GetPlayerFavoriteDicDataInClient(dc_Value, dr_Value, di_Value, userID)
	end

	@ExecSpace("Client")
	method void GetPlayerFavoriteDicDataInClient(string charValue, string runeValue, string itemValue)
		-- 클라이언트에 즐겨찾기를 저장합니다.
		--------------------------------------------------------
		-- char
		if charValue ~= "NIL" then
			
			-- 한 번 초기화 하고 들어가기
			_DictionaryFavoriteListManager:Initialize_CharList()
			
			local charIDList = _UtilLogic:Split(charValue, ",")
			for _, charID in pairs(charIDList) do
				_DictionaryManager:Character_Favorite(charID)
			end
		else
			_DictionaryFavoriteListManager:Initialize_CharList()
		end
		--------------------------------------------------------
		-- rune
		if runeValue ~= "NIL" then
			_DictionaryFavoriteListManager:Initialize_RuneList()	
			
			local runeIDList = _UtilLogic:Split(runeValue, ",")
			
			for _, runeID in pairs(runeIDList) do
				_DictionaryManager:RuneCard_Favorite(runeID)
			end
		else
			_DictionaryFavoriteListManager:Initialize_RuneList()
		end
		--------------------------------------------------------
		-- item
		if itemValue ~= "NIL" then
			_DictionaryFavoriteListManager:Initialize_ItemList()
			
			local itemIDList = _UtilLogic:Split(itemValue, ",")
			
			for _, itemID in pairs(itemIDList) do
				_DictionaryManager:Item_Favorite(itemID)
			end
		else
			_DictionaryFavoriteListManager:Initialize_ItemList()
		end
		--------------------------------------------------------
	end

	@ExecSpace("Server")
	method void SetPlayerFavoriteDicData(Entity user)
		-- 플레이어의 사전 내 즐겨찾기 정보를 저장합니다.
		--------------------------------------------------------
		--local user = _UserService:GetUserEntityByUserId(userID)
		local userID = user.OwnerId
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		
		-- 사전 내 즐겨찾기 정보를 string 값으로 변환합니다.
		-----------------------------------------------------------------
		local charValue = ""
		local runeValue = ""
		local itemValue = ""
		-----------------------------------------------------------------
		-- 1. Char 데이터 가공
		for _, charID in pairs(playerDataComponent.fave_Character_Dictionary) do
			charValue = string.format("%s%s,", charValue, charID)
		end
		
		if charValue == "" then
			charValue = "NIL"
		else
			charValue = string.sub(charValue, 1, -2)
		end
		-----------------------------------------------------------------
		-- 2. Rune 데이터 가공
		for _, runeID in pairs(playerDataComponent.fave_Rune_Dictionary) do
			runeValue = string.format("%s%s,", runeValue, runeID)
		end
		
		if runeValue == "" then
			runeValue = "NIL"
		else
			runeValue = string.sub(runeValue, 1, -2)
		end
		-----------------------------------------------------------------
		-- 3. Item 데이터 가공
		for _, itemID in pairs(playerDataComponent.fave_Item_Dictionary) do
			itemValue = string.format("%s%s,", itemValue, itemID)
		end
		
		if itemValue == "" then
			itemValue = "NIL"
		else
			itemValue = string.sub(itemValue, 1, -2)
		end
		------------------------------------------------------------------
		
		-- charValue 저장
		local c_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DictionaryCharData_%s", self.SetVer), charValue)
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				c_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DictionaryCharData_%s", self.SetVer), charValue)
			end
		end
		--------------------------------------------------------
		-- runeValue 저장
		local r_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DictionaryRuneData_%s", self.SetVer), runeValue)
		for i = 1, 10 do
			if r_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				r_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DictionaryRuneData_%s", self.SetVer), runeValue)
			end
		end
		--------------------------------------------------------
		-- itemValue 저장
		local i_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DictionaryItemData_%s", self.SetVer), itemValue)
		for i = 1, 10 do
			if i_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				i_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DictionaryItemData_%s", self.SetVer), itemValue)
			end
		end
		--------------------------------------------------------
	end

