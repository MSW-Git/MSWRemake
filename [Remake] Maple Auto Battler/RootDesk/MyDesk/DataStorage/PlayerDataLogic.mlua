		local cValue = ""
		
		for cID, grade in pairs(collectionComponent.CharacterCollection) do
			cValue = string.format("%s%s-%d_", cValue, cID, grade)
		end
		
		cValue = string.sub(cValue, 1, -2)
		
		-- 2. 데이터 저장하기
