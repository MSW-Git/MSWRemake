	@ExecSpace("ServerOnly")
	method void CheckPlayerHighRankData(string userID, number checkSeason, number checkOrdinalNum)
		-- 플레이어가 가진 데이터를 확인한 후, 더 높다면 기록
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		
		-- 1. 유저 하이스코어 불러오기
		local userDB = _DataStorageService:GetUserDataStorage(userID)
		local setKey = string.format("RankScore_%d_%d", checkSeason, checkOrdinalNum)
		--------------------------------------------------------
		local sethighScore = 0
		local geterr, sc_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(setKey)
		for i = 1, 10 do
			if geterr == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				geterr, sc_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(setKey)
			end
		end
		
		if isvalid(sc_Value) then
			sethighScore = tonumber(sc_Value)
		end
		
		-- 2. 현재 최고 도달 랭크 순위 불러오기
		local highRankInfo = "NIL/NIL/NIL/NIL"
		local hr_err, hr_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighRankInfo_%s", self.SetVer))
		for i = 1, 10 do
			if hr_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				hr_err, hr_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighRankInfo_%s", self.SetVer))
			end
		end
		
		if isvalid(hr_Value) then
			highRankInfo = hr_Value
			-- RankNum/RankPercent/SeasonNumber/OrdinalNumber
		end
		
		-- 3. 랭킹 데이터 마지막 순위보다 점수가 낮은지 확인
		------------------------------------------------------------------
		local dbKey = string.format("RankModeRanking_%d_%d", checkSeason, checkOrdinalNum)
		local rankingDB = _DataStorageService:GetSortableDataStorage(dbKey)
		------------------------------------------------------------------
		local err, rankPages = rankingDB:GetSortedAndWait(SortDirection.Descending, 1, math.maxinteger)
		for i = 1, 10 do
			if err ~= 0 then
				err, rankPages = rankingDB:GetSortedAndWait(SortDirection.Descending, 1, math.maxinteger)
			else
				break
			end
		end
		
		-- 3-1. 높다면 순위도 불러오기
		local playerCount = 0
		local checkCount = 0
		while true do
			local items = rankPages:GetCurrentPageDatas()
			
			if #items > 0 then
				for _, item in pairs(items) do
					playerCount += 1
					if item.KeyInfo.Key == userID then
						checkCount = playerCount
						log(string.format("Rank %d. %s = %d", playerCount,  item.KeyInfo.Tag, item.Value))
						break
					end
				end
				
				if checkCount ~= 0 then
					break
				elseif rankPages.IsLastPage == true then
					break
				elseif playerCount >= 200 then
					break
				else
					rankPages:MoveToNextPageAndWait()
				end
			else
				checkCount = -1
				log("#item = 0")
				break
			end
		end
		
		-- 3-2. 낮다면 퍼센티지만 불러오기
		local checkPercent = -1
		local checkTable = _ModeDataLogic:GetRankModeUserClearPercent(checkSeason, checkOrdinalNum, userID)
		log(checkTable)
		if checkCount == -1 then
			log("해당 시즌, 분기에 랭크 데이터가 없음")
			return
		elseif checkCount == 0 then
			-- 순위 밖인 경우
			checkPercent = checkTable["Percent"]
		else
			-- 순위 안쪽인 경우
			checkPercent = checkCount / checkTable["All"]
		end
		
		-- 4. 비교 후 저장
		local saveCheck = false
		
		-- 저장된 최고 랭크 정보 분리
		local setHighTable = _UtilLogic:Split(highRankInfo, "/")
		
		-- 순위 우선 데이터 저장
		---------------------------------------------------------------
		--[[
		-- 이전 데이터가 없으면
		if setHighTable[1] == "NIL" and setHighTable[2] == "NIL" then
			if checkCount ~= -1 then
				-- 무조건 저장
				saveCheck = true
			end
		-- 이전 데이터에 비율만 있으면
		elseif setHighTable[1] == "NIL" then
			if checkCount > 0 then
				-- 체크한 순위가 있다면 저장
				saveCheck = true
			elseif tonumber(setHighTable[2]) > checkPercent then
				-- 체크한 비율이 더 좋으면 저장
				saveCheck = true
			end
		-- 이전 데이터에 순위도 있으면
		else
			if tonumber(setHighTable[1]) == checkCount then
				-- 체크한 순위가 같으면 비율 비교
				if tonumber(setHighTable[2]) > checkPercent then
					-- 체크한 비율이 더 좋으면 저장
					saveCheck = true
				end
			elseif tonumber(setHighTable[1]) > checkCount and checkCount > 0 then
				-- 체크한 순위가 더 좋으면 저장
				saveCheck = true
			end
		end
		]]--
		
		-- 비율 우선 데이터 저장
		---------------------------------------------------------------
		-- 이전 데이터가 없으면
		if setHighTable[1] == "NIL" and setHighTable[2] == "NIL" then
			if checkCount ~= -1 then
				-- 무조건 저장
				saveCheck = true
			end
		-- 체크한 비율이 더 좋으면 저장
		elseif tonumber(setHighTable[2]) > checkPercent then
			saveCheck = true
		-- 체크한 비율이 같으면
		elseif tonumber(setHighTable[2]) == checkPercent then
			if tonumber(setHighTable[1]) > checkCount and checkCount > 0 then
				-- 체크한 순위가 더 좋으면 저장
				saveCheck = true
			end
		end
		
		log("Check = ", saveCheck, checkCount, checkPercent, setHighTable[2])
		
		-- 저장 시
		if saveCheck then
			local countStringValue = "NIL"
			if checkCount > 0 then
				countStringValue = string.format("%d", checkCount)
			end
			
			local save_Value = string.format("%s/%d/%d/%d", countStringValue, checkPercent, checkSeason, checkOrdinalNum)
			playerDataComponent.HighRankInfo = save_Value
			
			local save_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("HighRankInfo_%s", self.SetVer), save_Value)
			for i = 1, 10 do
				if save_err == 0 then
					break
				elseif i == 20 then
					log_error("Save 실패")
				else
					save_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("HighRankInfo_%s", self.SetVer), save_Value)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void GetPlayerLevelData(string userID)
		-- 플레이어 계정 레벨 상태를 불러옵니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		-- Level
		local l_err, l_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("LevelData_%s", self.SetVer))
		for i = 1, 10 do
			if l_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				l_err, l_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("LevelData_%s", self.SetVer))
			end
		end
		
		if isvalid(l_Value) then
			local lvInfo = _UtilLogic:Split(l_Value, "_")
			playerDataComponent.Level = tonumber(lvInfo[1])
			playerDataComponent.EXP = tonumber(lvInfo[2])
		else
			-- 데이터가 없을 때
			playerDataComponent.Level = _PlayerLevelLogic.Level_Min
			playerDataComponent.EXP = 0
			_UI_PlayerLevel:InitializeLobbyProfile(userID)
		end
	end

