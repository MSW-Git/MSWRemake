@Logic
script PlayerDataLogic extends Logic

	property string SetVer = "OpenBeta"

	@ExecSpace("ServerOnly")
	method void GetPlayerData(string userID)
		-- 유저가 게임에 접속하면 필요한 데이터를 불러오기 위해 호출하는 함수입니다.
		------------------------------------------------------------------------
		self:GetLastLoginDateData(userID)
		self:GetAchievementData(userID)
		self:GetCoachesData(userID)
		self:GetTitleData(userID)
		self:GetPlayerRecordData(userID)
		self:GetPlayerSyrupsData(userID, true)
		self:GetPlayerFavoriteDicData(userID)
		self:GetCollectionData(userID)
		self:GetPlayerCumulativeBoxPurchasesAmountData(userID)
		self:GetPlayerLevelData(userID)
		self:GetPlayerProfileIsPublicData(userID)
		self:GetPlayerTutorialData(userID)
		self:GetPlayerChallengeInfoData(userID)
		self:GetPlayerDailyMissionData(userID)
		------------------------------------------------------------------------
		self:SetPlayerInfoData(userID)
		
		
		------------------------------------------------------------------------
		-- 업적: 로그인 횟수 
		local userEntity = _UserService:GetUserEntityByUserId(userID)
		_AchievementService:UpdateProgress_Graduate("AC001001", 1, userEntity)
		
		------------------------------------------------------------------------
		
	end

	@ExecSpace("ServerOnly")
	method void GetAchievementData(string userID)
		-- 업적과 관련된 프로퍼티를 불러오는 함수입니다.
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local achievementManager = user.AchievementManager
		------------------------------------------------------------------------
		-- PlayerAchievementData
		
		-- 1. 데이터 불러오기
		local p_err, pachieve_Data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PlayerAchievementData_%s", self.SetVer))
		for i = 1, 10 do
			if p_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				p_err, pachieve_Data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PlayerAchievementData_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 확인 및 값이 필요한 지 체크
		-- (ID)_(state-state-state)_(count)_(date-date-date)
		if isvalid(pachieve_Data) then
			--log("pachieve_Data = ", pachieve_Data)
		
			local pAchievementData = _UtilLogic:Split(pachieve_Data, ",")
			
			for _, data in pairs(pAchievementData) do
				--log("Data = ", data)
				local aData = _UtilLogic:Split(data, "_")
				
				local aID = aData[1]
				local aStateTable = _UtilLogic:Split(aData[2], "-")
				local aCount = tonumber(aData[3])
				local aDateTable = _UtilLogic:Split(aData[4], "-")
				
				-- NIL 체크해서 데이터 값 바꾸기
				for i, state in pairs(aStateTable) do
					if state == "NIL" then
						aStateTable[i] = ""
					end
				end
				
				for i, date in pairs(aDateTable) do
					if date == "NIL" then
						aDateTable[i] = ""
					end
				end
				
				achievementManager.PlayerAchievementData[aID] = {["state"] = aStateTable, ["count"] = aCount, ["date"] = aDateTable }
			end
			
		else
			-- 데이터 초기 값 등록 함수 호출
			achievementManager:Init_AchieveData()
		end
		------------------------------------------------------------------------
		-- PlayerAchieveCategoryData
		-- 1. 데이터 불러오기
		local pc_err, pAchC_Data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PlayerAchieveCategoryData_%s", self.SetVer))
		for i = 1, 10 do
			if pc_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				pc_err, pAchC_Data = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PlayerAchieveCategoryData_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 확인 및 값이 필요한 지 체크
		-- (ID)_(Count)_(State)_(Date)
		if isvalid(pAchC_Data) then
			local pAchCData = _UtilLogic:Split(pAchC_Data, ",")
			
			for _, data in pairs(pAchCData) do
				local acData = _UtilLogic:Split(data, "_")
				
				local acID = acData[1]
				local acCount = tonumber(acData[2])
				local acState = acData[3]
				local acDate = acData[4]
				
				-- NIL 체크해서 데이터 값 바꾸기
				if acDate == "NIL" then
					acDate = ""
				end
				
				achievementManager.PlayerAchieveCategoryData[acID] = {["count"] = acCount, ["state"] = acState, ["date"] = acDate}
			end
			-- 업적 db 로드 이후 필요한 처리 
			achievementManager:OnDataLoadComplete()
		else
			
			-- 데이터 초기 값 등록 함수 호출
			achievementManager:Init_AchieveCategoryData()
			return 
		end
		
	end

	@ExecSpace("ServerOnly")
	method void SetPlayerAchievementData(Entity user)
		-- PlayerAchievementData 프로퍼티를 저장하는 함수입니다.
		------------------------------------------------------------------------
		local userID = user.OwnerId
		local achievementManager = user.AchievementManager
		------------------------------------------------------------------------
		-- (ID)_(state-state-state)_(count)_(date-date-date)
		-- 1. 데이터 가공
		local aStringValue = ""
		local achievementCount = 0
		for id, valueTable in pairs(achievementManager.PlayerAchievementData) do
			achievementCount += 1
			local stateTable = valueTable["state"]
			local count = valueTable["count"]
			local dateTable = valueTable["date"]
			
			-- id 입력
			aStringValue = string.format("%s%s_", aStringValue, id)
			
			-- state 입력
			local stateValue = ""
			for _, state in pairs(stateTable) do
				if state == "" then
					state = "NIL"
				end
				stateValue = string.format("%s%s-", stateValue, state)
			end
			stateValue = string.sub(stateValue, 1, -2)
			
			aStringValue = string.format("%s%s_", aStringValue, stateValue)
			
			-- count 입력
			aStringValue = string.format("%s%d_", aStringValue, count)
			
			-- date 입력
			local dateValue = ""
			for _, date in pairs(dateTable) do
				if date == "" then
					date = "NIL"
				end
				dateValue = string.format("%s%s-", dateValue, date)
			end
			dateValue = string.sub(dateValue, 1, -2)
			
			aStringValue = string.format("%s%s", aStringValue, dateValue)
			
			aStringValue = aStringValue .. ","
		end
		
		aStringValue = string.sub(aStringValue, 1, -2)
		
		--log("aStringValue.len = ", utf8.len(aStringValue))
		--log("achievementCount = ", achievementCount)
		--log("aStringValue = ", aStringValue)
		
		--log("aStringValue = ", aStringValue)
		-- 2. 데이터 저장하기
		local a_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("PlayerAchievementData_%s", self.SetVer), aStringValue)
		for i = 1, 10 do
			if a_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				a_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("PlayerAchievementData_%s", self.SetVer), aStringValue)
			end
		end
		------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void SetPlayerAchievementCategoryData(Entity user)
		-- PlayerAchieveCategoryData 프로퍼티를 저장하는 함수입니다.
		------------------------------------------------------------------------
		local userID = user.OwnerId
		local achievementManager = user.AchievementManager
		------------------------------------------------------------------------
		-- 1. 데이터 가공
		-- (ID)_(Count)_(State)_(Date)
		local acStringValue = ""
		for id, valueTable in pairs(achievementManager.PlayerAchieveCategoryData) do
			local count = valueTable["count"]
			local state = valueTable["state"]
		
			local date = valueTable["date"]
			
			-- id 입력
			acStringValue = string.format("%s%s_", acStringValue, id)
			
			-- count 입력
			acStringValue = string.format("%s%d_", acStringValue, count)
			
			-- state 입력
			acStringValue = string.format("%s%s_", acStringValue, state)
			
			-- date 입력
			if date == "" then
				date = "NIL"
			end
			acStringValue = string.format("%s%s", acStringValue, date)
			
			acStringValue = acStringValue .. ","
		end
		
		acStringValue = string.sub(acStringValue, 1, -2) 
		-- 2. 데이터 저장하기
		local ac_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("PlayerAchieveCategoryData_%s", self.SetVer), acStringValue)
		for i = 1, 10 do
			if ac_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				ac_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("PlayerAchieveCategoryData_%s", self.SetVer), acStringValue)
			end
		end
		------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void GetCoachesData(string userID)
		-- 코치 관련 프로퍼티를 불러오는 함수입니다.
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local coachManager = user.CoachManager
		local coachShopManager = user.CoachShopManager
		------------------------------------------------------------------------
		-- PlayerOwnedCoachesID
		-- 1. 데이터 불러오기
		local c_err, cValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PlayerOwnedCoachesID_%s", self.SetVer))
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				c_err, cValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PlayerOwnedCoachesID_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 저장
		if isvalid(cValue) then
			local cValueTable = _UtilLogic:Split(cValue, ",")
			for _, value in pairs(cValueTable) do
				local cInfo = _UtilLogic:Split(value, "_")
				local cID = cInfo[1]
				local c_Value = tonumber(cInfo[2])
				
				coachManager.PlayerOwnedCoachesID[cID] = c_Value
			end
		end
		------------------------------------------------------------------------
		-- SetCoachPresetInfo
		-- 1. 데이터 불러오기
		local cp_err, cpValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SetCoachPresetInfo_%s", self.SetVer))
		for i = 1, 10 do
			if cp_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				cp_err, cpValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SetCoachPresetInfo_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 저장
		if isvalid(cpValue) then
			local cValueTable = _UtilLogic:Split(cpValue, "/")
			for _, value in pairs(cValueTable) do
				local cInfo = _UtilLogic:Split(value, "_")
				local cpNum = tonumber(cInfo[1])
				local cp_Value = cInfo[2]
				
				coachManager.SetCoachPresetInfo[cpNum] = cp_Value
			end
		end
		coachManager:SetCoachPreset(1, "load")
		------------------------------------------------------------------------
		-- FollowingCoachID
		-- 1. 데이터 불러오기
		local fc_err, fcValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("FollowingCoachID_%s", self.SetVer))
		for i = 1, 10 do
			if fc_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				fc_err, fcValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("FollowingCoachID_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 저장
		if isvalid(fcValue) then
			coachManager.FollowingCoachID = fcValue
			_CoachService:DBLoacdComplete_FollowingCoach(userID)
		end
		------------------------------------------------------------------------
		-- PickAdjustmentCount
		-- 1. 데이터 불러오기
		local pa_err, paValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PickAdjustmentCount_%s", self.SetVer))
		for i = 1, 10 do
			if pa_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				pa_err, paValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("PickAdjustmentCount_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 저장
		if isvalid(paValue) then
			coachShopManager.PickAdjustmentCount = tonumber(paValue)
		else 
			coachShopManager.PickAdjustmentCount = coachShopManager.PickAdjustmentMax
		end
		------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void SetPlayerOwnedCoachesData(string userID)
		-- PlayerOwnedCoachesID 프로퍼티를 저장하는 함수입니다.
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local coachManager = user.CoachManager
		------------------------------------------------------------------------
		-- 1. 데이터 가공
		local cValue = ""
		for coachID, cNum in pairs(coachManager.PlayerOwnedCoachesID) do
			cValue = string.format("%s%s_%s,", cValue, coachID, tostring(math.floor(cNum)))
		end
		cValue = string.sub(cValue, 1, -2)
		
		-- 2. 데이터 저장하기
		local c_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("PlayerOwnedCoachesID_%s", self.SetVer), cValue)
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				c_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("PlayerOwnedCoachesID_%s", self.SetVer), cValue)
			end
		end
		------------------------------------------------------------------------
		
	end

