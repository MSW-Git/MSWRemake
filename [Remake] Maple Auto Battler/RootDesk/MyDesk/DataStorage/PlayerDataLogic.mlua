	@ExecSpace("ServerOnly")
	method void GetCollectionData(string userID)
		-- Collection 관련 프로퍼티를 저장하는 함수입니다.
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local collectionComponent = user.PlayerCollectionDataComponent
		------------------------------------------------------------------------
		-- CharacterCollection
		-- 1. 데이터 불러오기
		local c_err, cValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("CharacterCollection_%s", self.SetVer))
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				c_err, cValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("CharacterCollection_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(cValue) then
			-- (ID)-(Grade)_..._(ID)-(Grade)
			local cTableToSeason = _UtilLogic:Split(cValue, "_")
			
			for _, v in pairs(cTableToSeason) do
				local cInfo = _UtilLogic:Split(v, "-")
				local cID = cInfo[1]
				local grade = tonumber(cInfo[2])
				collectionComponent.CharacterCollection[cID] = grade
			end	
		
		else
			-- 초기 값 넣는 함수 호출
			collectionComponent:InitializeCharacterCollectionData()
		end
		------------------------------------------------------------------------
		-- SynergyCollection
		-- 1. 데이터 불러오기
		local s_err, sValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SynergyCollection_%s", self.SetVer))
		for i = 1, 10 do
			if s_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				s_err, sValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SynergyCollection_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(sValue) then
			-- (ID)-(Grade)_..._(ID)-(Grade)
			local sTableToSeason = _UtilLogic:Split(sValue, "_")
			
			for _, v in pairs(sTableToSeason) do
				local sInfo = _UtilLogic:Split(v, "-")
				local sID = sInfo[1]
				local grade = tonumber(sInfo[2])
				
				collectionComponent.SynergyCollection[sID] = grade
			end
		
		else
			-- 초기 값 넣는 함수 호출
			collectionComponent:InitializeSynergyCollectionData()
		end
	end

	@ExecSpace("ServerOnly")
	method void SetCharCollectionData(string userID)
		-- CharacterCollection 프로퍼티를 저장하는 함수입니다.
		
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local collectionComponent = user.PlayerCollectionDataComponent
