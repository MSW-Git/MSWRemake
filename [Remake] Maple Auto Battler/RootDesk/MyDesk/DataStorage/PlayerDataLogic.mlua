	@ExecSpace("ServerOnly")
	method void GetTitleData(string userID)
		-- TitleManager의 프로퍼티를 불러오는 함수입니다
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local titleManager = user.TitleManager
		------------------------------------------------------------------------
		-- NameTagTable
		-- 1. 데이터 불러오기
		local nt_err, nameTagValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("NameTagTable_%s", self.SetVer))
		for i = 1, 10 do
			if nt_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				nt_err, nameTagValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("NameTagTable_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(nameTagValue) then
			if nameTagValue ~= "NIL" then
				local nameTagTable = _UtilLogic:Split(nameTagValue, ",")
				
				for _, v in pairs(nameTagTable) do
					local keyInfo = _UtilLogic:Split(v, "_")
					
					local key = keyInfo[1]
					local value = (keyInfo[2] == "true")
					
					titleManager.NameTagTable[key] = value
				end
			end
		end
		------------------------------------------------------------------------
		-- KeyWordFrontTable
		-- 1. 데이터 불러오기
		local kwf_err, kwfValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("KeyWordFrontTable_%s", self.SetVer))
		for i = 1, 10 do
			if kwf_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				kwf_err, kwfValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("KeyWordFrontTable_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(kwfValue) then
			if kwfValue ~= "NIL" then
				local kwfTable = _UtilLogic:Split(kwfValue, ",")
				
				for _, v in pairs(kwfTable) do
					local keyInfo = _UtilLogic:Split(v, "_")
					
					local key = keyInfo[1]
					local value = (keyInfo[2] == "true")
					
					titleManager.KeyWordFrontTable[key] = value
				end
			end
		end
		------------------------------------------------------------------------
		-- KeyWordBackTable
		-- 1. 데이터 불러오기
		local kwb_err, kwbValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("KeyWordBackTable_%s", self.SetVer))
		for i = 1, 10 do
			if kwb_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				kwb_err, kwbValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("KeyWordBackTable_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(kwbValue) then
			if kwbValue ~= "NIL" then
				local kwbTable = _UtilLogic:Split(kwbValue, ",")
				
				for _, v in pairs(kwbTable) do
					local keyInfo = _UtilLogic:Split(v, "_")
					
					local key = keyInfo[1]
					local value = (keyInfo[2] == "true")
					
					titleManager.KeyWordBackTable[key] = value
				end
			end
		end
		------------------------------------------------------------------------
		-- EquippedTitle
		-- 1. 데이터 불러오기
		local eq_err, equipTitleValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("EquippedTitle_%s", self.SetVer))
		for i = 1, 10 do
			if eq_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				eq_err, equipTitleValue = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("EquippedTitle_%s", self.SetVer))
			end
		end
		
		-- 2. 데이터 적용
		if isvalid(equipTitleValue) then
			if equipTitleValue ~= "NIL" then
				local eqTable = _UtilLogic:Split(equipTitleValue, ",")
				
				for _, v in pairs(eqTable) do
					local keyInfo = _UtilLogic:Split(v, "_")
					
					local key = keyInfo[1]
					local value = keyInfo[2]
					
					titleManager.EquippedTitle[key] = value
				end
			end
		end
		------------------------------------------------------------------------
		
		titleManager:InitializeTitle()
	end

	@ExecSpace("ServerOnly")
	method void SetTitleData(string userID)
		-- TitleManager의 프로퍼티를 저장하는 함수입니다
		------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local titleManager = user.TitleManager
		------------------------------------------------------------------------
		-- NameTagTable
		-- 1. 데이터 가공
		local nameTagValue = ""
		for id, bool in pairs(titleManager.NameTagTable) do
			nameTagValue = string.format("%s%s_%s,", nameTagValue, id, tostring(bool))
		end
		
		if nameTagValue == "" then
			nameTagValue = "NIL"
		else
			nameTagValue = string.sub(nameTagValue, 1, -2)
		end
		
		-- 2. 데이터 저장하기
		local nt_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("NameTagTable_%s", self.SetVer), nameTagValue)
		for i = 1, 10 do
			if nt_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				nt_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("NameTagTable_%s", self.SetVer), nameTagValue)
			end
		end
		------------------------------------------------------------------------
		-- KeyWordFrontTable
		-- 1. 데이터 가공
		local kwfValue = ""
		for id, bool in pairs(titleManager.KeyWordFrontTable) do
			kwfValue = string.format("%s%s_%s,", kwfValue, id, tostring(bool))
		end
		
		if kwfValue == "" then
			kwfValue = "NIL"
		else
			kwfValue = string.sub(kwfValue, 1, -2)
		end
		
		-- 2. 데이터 저장하기
		local kwf_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("KeyWordFrontTable_%s", self.SetVer), kwfValue)
		for i = 1, 10 do
			if kwf_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				kwf_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("KeyWordFrontTable_%s", self.SetVer), kwfValue)
			end
		end
		------------------------------------------------------------------------
		-- KeyWordBackTable
		-- 1. 데이터 가공
		local kwbValue = ""
		for id, bool in pairs(titleManager.KeyWordBackTable) do
			kwbValue = string.format("%s%s_%s,", kwbValue, id, tostring(bool))
		end
		
		if kwbValue == "" then
			kwbValue = "NIL"
		else
			kwbValue = string.sub(kwbValue, 1, -2)
		end
		
		-- 2. 데이터 저장하기
		local kwb_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("KeyWordBackTable_%s", self.SetVer), kwbValue)
		for i = 1, 10 do
			if kwb_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				kwb_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("KeyWordBackTable_%s", self.SetVer), kwbValue)
			end
		end
		------------------------------------------------------------------------
		-- EquippedTitle
		-- 1. 데이터 가공
		local equipTitleValue = ""
		for type, id in pairs(titleManager.EquippedTitle) do
			equipTitleValue = string.format("%s%s_%s,", equipTitleValue, type, id)
		end
		
		if equipTitleValue == "" then
			equipTitleValue = "NIL"
		else
			equipTitleValue = string.sub(equipTitleValue, 1, -2)
		end
		
		-- 2. 데이터 저장하기
		local eq_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("EquippedTitle_%s", self.SetVer), equipTitleValue)
		for i = 1, 10 do
			if eq_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
		
			else
				eq_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("EquippedTitle_%s", self.SetVer), equipTitleValue)
			end
		end
		------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void GetPlayerRecordData(string userID)
		-- 플레이어 기록용 데이터를 불러옵니다.
		------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		------------------------------------------------------------------------------
		-- 1. 전체 기록
			-- 플레이어 최고 도달 랭크
			-- 플레이어 최고 도달 순위(%)
			-- 게임 횟수
				-- 시작한 게임 횟수
				-- 이긴 게임 횟수
				-- 총 게임 횟수
		------------------------------------------------------------------------------
		-- 플레이어 최고 도달 랭크
		local hl_err, hl_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighClearLevelInfo_%s", self.SetVer))
		for i = 1, 10 do
			if hl_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				hl_err, hl_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighClearLevelInfo_%s", self.SetVer))
			end
		end
		
		if isvalid(hl_Value) then
			playerDataComponent.HighClearLevelInfo = hl_Value
			-- Level/SeasonNumber/OrdinalNumber
		else
			playerDataComponent.HighClearLevelInfo = "0/NIL/NIL"
		end
		------------------------------------------------------------------------------
		-- 플레이어 최고 도달 순위(%)
		local hr_err, hr_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighRankInfo_%s", self.SetVer))
		for i = 1, 10 do
			if hr_err == 0 then
				break
			elseif i == 10 then
				_UserService:KickUser(userID, KickReason.WorldContent)
			else
				hr_err, hr_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("HighRankInfo_%s", self.SetVer))
			end
		end
		
		if isvalid(hr_Value) then
			playerDataComponent.HighRankInfo = hr_Value
			-- RankNum/RankPercent/SeasonNumber/OrdinalNumber
		else
			playerDataComponent.HighRankInfo = "NIL/NIL/NIL/NIL"
		end
		------------------------------------------------------------------------------
		-- 게임 횟수
		local c_err, c_value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("GameCountData_%s", self.SetVer))
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 10 then
				log_error("Save 실패")
			else
				c_err, c_value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("GameCountData_%s", self.SetVer))
			end
		end
		
		if isvalid(c_value) then
			-- Start/Play/Win
			local c_Table = _UtilLogic:Split(c_value, "/") 
			playerDataComponent.StartGameCount = tonumber(c_Table[1])
			playerDataComponent.PlayGameCount = tonumber(c_Table[2])
			playerDataComponent.WinGameCount = tonumber(c_Table[3])
			playerDataComponent:SetGameRecordProperty(nil)
		end
		
	end

	@ExecSpace("ServerOnly")
	method string GetPlayerSyrupsData(string userID, boolean upDate)
		-- 플레이어 아웃게임용 재화(시럽) 상태를 불러옵니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		-- Syrup
		local s_err, s_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SyrupData_%s", self.SetVer))
		for i = 1, 10 do
			if s_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				s_err, s_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("SyrupData_%s", self.SetVer))
			end
		end
		
		if isvalid(s_Value) then
			if upDate then
				playerDataComponent.Syrup = tonumber(s_Value)
			end
		else
			s_Value = "0"
		end
		
		--------------------------------------------------------
		-- RoyalSyrup
		local rs_err, rs_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("RoyalSyrupData_%s", self.SetVer))
		for i = 1, 10 do
			if rs_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				rs_err, rs_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("RoyalSyrupData_%s", self.SetVer))
			end
		end
		
		if isvalid(rs_Value) then
			if upDate then
				playerDataComponent.RoyalSyrup = tonumber(rs_Value)
			end
		else
			rs_Value = "0"
		end
		--------------------------------------------------------
		-- Repechage
		local rep_err, rep_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("RepechageData_%s", self.SetVer))
		for i = 1, 10 do
			if rs_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				rep_err, rep_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("RepechageData_%s", self.SetVer))
			end
		end
		
		if isvalid(rep_Value) then
			if upDate then
				playerDataComponent.Repechage = tonumber(rep_Value)
			end
		else
			rep_Value = "0"
		end
		--------------------------------------------------------
		-- Repechage_Free
		local repF_err, repF_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("FreeRepechageData_%s", self.SetVer))
		for i = 1, 10 do
			if rs_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				repF_err, repF_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("FreeRepechageData_%s", self.SetVer))
			end
		end
		
		if isvalid(repF_Value) then
			if upDate then
				playerDataComponent.Repechage_Free = tonumber(repF_Value)
			end
		else
			repF_Value = "0"
		end
		
		return string.format("%s_%s_%s_%s", s_Value, rs_Value, rep_Value, repF_Value)
	end

