	end

	@ExecSpace("ServerOnly")
	method void SetPlayerChallengeInfoData(string userID)
		-- 플레이어의 챌린지 관련 정보를 저장합니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		-- 데이터 가공
		local challengeInfoData = string.format("%d", playerDataComponent.ChallengeMode_LeftTryCount)
		--------------------------------------------------------
		-- Table 저장
		local n_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("ChallengeInfoData_%s", self.SetVer), challengeInfoData)
		for i = 1, 10 do
			if n_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				n_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("ChallengeInfoData_%s", self.SetVer), challengeInfoData)
			end
		end
		--------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void GetPlayerChallengeInfoData(string userID)
		-- 플레이어의 챌린지 관련 정보를 불러옵니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local playerDataComponent = user.PlayerDataComponent
		--------------------------------------------------------
		-- ChallengeInfo
		local c_err, c_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ChallengeInfoData_%s", self.SetVer))
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				c_err, c_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("ChallengeInfoData_%s", self.SetVer))
			end
		end
		--------------------------------------------------------
		if isvalid(c_Value) then
			local cInfo = _UtilLogic:Split(c_Value, "_")
			playerDataComponent.ChallengeMode_LeftTryCount = tonumber(cInfo[1])
		end
	end

	@ExecSpace("ServerOnly")
	method void SetPlayerDailyMissionData(string userID)
		-- 플레이어의 일일 미션 관련 정보를 저장합니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local dmCompo = user.DailyMissionComponent
		--------------------------------------------------------
		-- 데이터 가공 : "미션ID,미션진행도,미션상태"/"미션ID,미션진행도,미션상태"/...
		local data_before = {}
		for i=1, 3 do
			local missionData = dmCompo.MissionID[i]..","..dmCompo.MissionProgress[i]..","..dmCompo.MissionState[i]
			table.insert(data_before, missionData)
		end
		
		-- 보너스 데이터는 "보너스포인트,보너스보상수령상태"
		local bonusData = string.format("%d,%d", dmCompo.BonusPoint, dmCompo.BonusRewardReceiveState)
		local dailyMissionData = ""
		for i=1, 3 do
			if i ~= 1 then
				dailyMissionData = dailyMissionData.."/"
			end
			dailyMissionData = dailyMissionData..data_before[i]
		end
		
		dailyMissionData = dailyMissionData.."/"..bonusData
		--------------------------------------------------------
		-- Table 저장
		local n_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DailyMissionInfoData_%s", self.SetVer), dailyMissionData)
		for i = 1, 10 do
			if n_err == 0 then
				break
			elseif i == 20 then
				log_error("Save 실패")
			else
				n_err = _DataStorageService:GetUserDataStorage(userID):SetAndWait(string.format("DailyMissionInfoData_%s", self.SetVer), dailyMissionData)
			end
		end
		--------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void GetPlayerDailyMissionData(string userID)
		-- 플레이어의 일일 미션 관련 정보를 불러옵니다.
		--------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local dmCompo = user.DailyMissionComponent
		--------------------------------------------------------
		local c_err, c_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DailyMissionInfoData_%s", self.SetVer))
		for i = 1, 10 do
			if c_err == 0 then
				break
			elseif i == 20 then
				log_error("Load 실패")
			else
				c_err, c_Value = _DataStorageService:GetUserDataStorage(userID):GetAndWait(string.format("DailyMissionInfoData_%s", self.SetVer))
			end
		end
		--------------------------------------------------------
		dmCompo:OnLoadData(c_Value)
	end

