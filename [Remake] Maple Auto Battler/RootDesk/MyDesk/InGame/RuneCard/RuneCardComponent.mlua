@Component
script RuneCardComponent extends Component

	property boolean OnActive = true

	property string SetRuneID = ""

	property string SetTeamType = ""

	property number ResellCost = 0

	property boolean Copied = false

	property number RuneStack = 0

	property string RuneStringTypeValue = ""

	property string OwnerId = ""

	property boolean UsedRuneAbility = false

	property RuneCardComponent RC40003_Component = nil

	property RuneCardComponent CopiedComponent = nil

	property boolean IsDestructible = true

	property number IsRemovedCount = -3

	property number UID = 0

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		local startStageAct = function(event)
			if self.OnActive then
				self:StartStageHandler(event)
			end
		end
		local startRoundAct = function(event)
			self:CardRemoveCheck()
			if self.OnActive then
				self:StartRoundHandler(event)
			end
		end
		local buyUnitAct = function(event)
			if self.OnActive then
				self:BuyUnitHandler(event)
			end
		end
		local sellUnitAct = function(event)
			if self.OnActive then
				self:SellUnitHandler(event)
			end
		end
		local levelUpUnitAct = function(event)
			if self.OnActive then
				self:LevelUpUnitHandler(event)
			end
		end
		local buyExpAct = function(event)
			if self.OnActive then
				self:BuyEXPHandler(event)
			end
		end
		local levelUpTeamAct = function(event)
			if self.OnActive then
				self:LevelUpTeamHandler(event)
			end
		end
		local rerollCharacterAct = function(event)
			if self.OnActive then
				self:ReRollCharacterShopHandler(event)
			end
		end
		local setUnitOnTileAct = function(event)
			if self.OnActive then
				self:SetUnitOnTileHandler(event)
			end
		end
		local equipItemAct = function(event)
			if self.OnActive then
				self:EquipItemHandler(event)
			end
		end
		local combinationItemAct = function(event)
			if self.OnActive then
				self:CombinationItemHandler(event)
			end
		end
		local openItemBoxAct = function(event)
			if self.OnActive then
				self:OpenItemBoxHandler(event)
			end
		end
		local buyRuneCardAct = function(event)
			if self.OnActive then
				self:BuyRuneCardHandler(event)
			end
		end
		local sellRuneCardAct = function(event)
			if self.OnActive then
				self:SellRuneCardHandler(event)
			end
		end
		local endRoundAct = function(event)
			if self.OnActive then
				self:EndRoundHandler(event)
			end
		end
		local winBattleAct = function(event)
			if self.OnActive then
				self:WinBattleHandler(event)
			end
		end
		local loseBattleAct = function(event)
			if self.OnActive then
				self:LoseBattleHandler(event)
			end
		end
		local startBattleAct = function(event)
			if self.OnActive then
				self:StartBattleHandler(event)
			end
		end
		local setBattleAct = function(event)
			if self.OnActive then
				self:SetBattleHandler(event)
			end
		end
		local onSkillUseAct = function(event)
			if self.OnActive then
				self:OnSkillUseHandler(event)
			end
		end
		local onSkillHitAct = function(event)
			if self.OnActive then
				self:OnSkillHitHandler(event)
			end
		end
		local onDefaultAttackAct = function(event)
			if self.OnActive then
				self:OnDefaultAttackHandler(event)
			end
		end
		local onDefaultAttackHitAct = function(event)
			if self.OnActive then
				self:OnDefaultAttackHitHandler(event)
			end
		end
		local onAttackedAct = function(event)
			if self.OnActive then
				self:OnAttackedHandler(event)
			end
		end
		local deadUnitAct = function(event)
			if self.OnActive then
				self:DeadUnitHandler(event)
			end
		end
		local killUnitAct = function(event)
			if self.OnActive then
				self:KillUnitHandler(event)
			end
		end
		local useConsumableItemAct = function(event)
			if self.OnActive then
				self:UseConsumableItemHandler(event)
			end
		end
		local changeRuneCardOrderAct = function(event)
			if self.OnActive then
				self:ChangeRuneCardOrderHandler(event)
			end
		end
		local ingameDataLoadAct = function(event)
			if self.OnActive then
				self:InGameDataLoadHandler(event)
			end
		end
		local setActiveRuneAct = function(event)
			self:SetActiveHandler(event)
		end
		
		
		local userEntity = self.Entity.Parent.Parent
		
		userEntity:ConnectEvent(StageStart, startStageAct)
		userEntity:ConnectEvent(RoundStart, startRoundAct)
		userEntity:ConnectEvent(BuyUnit, buyUnitAct)
		userEntity:ConnectEvent(SellUnit, sellUnitAct)
		userEntity:ConnectEvent(LevelUpUnit, levelUpUnitAct)
		userEntity:ConnectEvent(BuyEXP, buyExpAct)
		userEntity:ConnectEvent(LevelUpTeam, levelUpTeamAct)
		userEntity:ConnectEvent(RerollCharacterShop, rerollCharacterAct)
		userEntity:ConnectEvent(SetUnitOnTile, setUnitOnTileAct)
		userEntity:ConnectEvent(EquipedItem, equipItemAct)
		userEntity:ConnectEvent(CombinationItem, combinationItemAct)
		userEntity:ConnectEvent(OpenItemBox, openItemBoxAct)
		userEntity:ConnectEvent(BuyRuneCard, buyRuneCardAct)
		userEntity:ConnectEvent(SellRuneCard, sellRuneCardAct)
		userEntity:ConnectEvent(RoundEnd, endRoundAct)
		userEntity:ConnectEvent(BattleWin, winBattleAct)
		userEntity:ConnectEvent(BattleLose, loseBattleAct)
		userEntity:ConnectEvent(BattleStart, startBattleAct)
		userEntity:ConnectEvent(BattleSet, setBattleAct)
		userEntity:ConnectEvent(SkillUse, onSkillUseAct)
		userEntity:ConnectEvent(SkillHit, onSkillHitAct)
		userEntity:ConnectEvent(DefaultAttack, onDefaultAttackAct)
		userEntity:ConnectEvent(DefaultAttackHit, onDefaultAttackHitAct)
		userEntity:ConnectEvent(Attacked, onAttackedAct)
		userEntity:ConnectEvent(UnitDead, deadUnitAct)
		userEntity:ConnectEvent(UnitDead, killUnitAct)
		userEntity:ConnectEvent(UseConsumableItem, useConsumableItemAct)
		userEntity:ConnectEvent(ChangeRuneCardOrder, changeRuneCardOrderAct)
		userEntity:ConnectEvent(InGameDataLoad, ingameDataLoadAct)
		
		self.Entity:ConnectEvent(SetActiveRune, setActiveRuneAct)
	end

