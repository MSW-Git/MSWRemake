	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		if not self.OnActive then
			self.Entity:SendEvent(SetActiveRune(not self.OnActive))	-- 에러 아님
			self.Entity:SendEvent(SetActiveRune(self.OnActive))	-- 에러 아님
		end
	end

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		local runeInfoTable = _DataService:GetTable("RuneInfo")
		local row = runeInfoTable:FindRow("RuneID", runeID)
		
		self:SetResellCostInfo(tonumber(row:GetItem("ResellCost")))
		
		self.SetRuneID = runeID
		
		if string.sub(self.Entity.Name, 1, 10) == "PlayerRune" then
			self.SetTeamType = "User"
		else
			self.SetTeamType = "Enemy"
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		self.Entity:RemoveComponent(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetRuneStackInfo(number stack)
		self.RuneStack = stack
		self:SetRuneStackInfo_OnClient(stack, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetRuneStackInfo_OnClient(number stack)
		self.RuneStack = stack
		
		_UI_Inventory:RefreshUI_RuneInventory()
		
		-- 전투 중 스택 변경 시, 룬 카드 리스트 새로고침
		local user = _UserService.LocalPlayer
		if user.GameManager.PhaseType ~= "Ready" then
			_UI_Inventory:RefreshUI_BattleRuneList()
		end
	end

	@ExecSpace("ServerOnly")
	method void SetResellCostInfo(number value)
		self.ResellCost = value
		self:SetResellCostInfo_OnClient(value, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetResellCostInfo_OnClient(number value)
		self.ResellCost = value
		_UI_Inventory:RefreshUI_RuneInventory()
	end

	@ExecSpace("ServerOnly")
	method void SetCopiedProperty(boolean isCopied)
		self.Copied = isCopied
		self:SetCopiedProperty_OnClient(isCopied, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetCopiedProperty_OnClient(boolean isCopied)
		self.Copied = isCopied
		_UI_Inventory:RefreshUI_RuneInventory()
	end

	@ExecSpace("ServerOnly")
	method void SetStringTypeValue(string value)
		self.RuneStringTypeValue = value
		self:SetStringTypeValue_OnClient(value, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetStringTypeValue_OnClient(string value)
		self.RuneStringTypeValue = value
		_UI_Inventory:RefreshUI_RuneInventory()
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		local active = event.active
		self.OnActive = active
		self:SetActive_OnClient(active, self.OwnerId)
	end

	@ExecSpace("ServerOnly")
	method void SetActive(boolean active)
		self.OnActive = active
		self:SetActive_OnClient(active, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetActive_OnClient(boolean active)
		self.OnActive = active
		
		_UI_Inventory:RefreshUI_RuneInventory()
	end

	@ExecSpace("ServerOnly")
	method void SetUsedRuneAbility(boolean value)
		self.UsedRuneAbility = value
		self:SetUsedRuneAbility_OnClient(value, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetUsedRuneAbility_OnClient(boolean value)
		self.UsedRuneAbility = value
	end

	@ExecSpace("ServerOnly")
	method void SetIsDestructible(boolean value)
		self.IsDestructible = value
		self:SetIsDestructible_OnClient(value, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetIsDestructible_OnClient(boolean value)
		self.IsDestructible = value
	end

	@ExecSpace("ServerOnly")
	method void AddIsRemovedCount(number addValue)
		self.IsRemovedCount += addValue
		self:AddIsRemovedCount_OnClient(addValue, self.OwnerId)
	end

	@ExecSpace("Client")
	method void AddIsRemovedCount_OnClient(number addValue)
		self.IsRemovedCount += addValue
	end

	@ExecSpace("ServerOnly")
	method void SetIsRemovedCount(number Value)
		self.IsRemovedCount = Value
		self:AddIsRemovedCount_OnClient(Value, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetIsRemovedCount_OnClient(number addValue)
		self.IsRemovedCount = addValue
	end

	@ExecSpace("ServerOnly")
	method void CardRemoveCheck()
		local user = self.Entity.Parent.Parent
		local specialShopManager = user.SpecialShopManager
		
		if self.IsRemovedCount == -3 then
			-- 소각하지 않는 룬카드
		elseif self.IsRemovedCount > 0 then
			-- 턴 Down
			self:AddIsRemovedCount(-1)
			
		elseif self.IsRemovedCount <= 0 then
			-- 0턴에 도달하면 룬카드 소각
			specialShopManager:RemoveRuneCard(self.SetRuneID, self.UID)
			
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
			_RuneCardDirector:DestroyRuneCard(index, true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void SetUID(number setNum)
		self.UID = setNum
		self:SetUID_OnClient(setNum, self.OwnerId)
	end

	@ExecSpace("Client")
	method void SetUID_OnClient(number setNum)
		self.UID = setNum
	end

end