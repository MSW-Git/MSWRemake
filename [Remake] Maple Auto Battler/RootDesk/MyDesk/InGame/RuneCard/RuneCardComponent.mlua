	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		
	end

	@ExecSpace("ServerOnly")
	method void SetBattleHandler(any event)
		
	end

	@ExecSpace("ServerOnly")
	method void OnSkillUseHandler(any event)
		
	end

	@ExecSpace("ServerOnly")
	method void OnSkillHitHandler(any event)
		
	end

	@ExecSpace("ServerOnly")
	method void OnDefaultAttackHandler(any event)
		
	end

	@ExecSpace("ServerOnly")
	method void OnDefaultAttackHitHandler(any event)
		
