@Component
script RC10004 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void EndRoundHandler(any event)
		__base:EndRoundHandler(event)
		
		-- 라운드 종료 시, 이 카드의 판매 가치가 2 증가합니다.
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		--------------------------------------------------------------------
		if self.Copied then
			self.RC40003_Component:SetResellCostInfo(self.RC40003_Component.ResellCost + 2)
		else
			self:SetResellCostInfo(self.ResellCost + 2)
		end
		
			
		_TimerService:SetTimerOnce(function() self:PlayEffect(self.ResellCost, user.PlayerComponent.UserId) end, 1.5)
	end

	@ExecSpace("Client")
	method void PlayEffect(integer resellcost)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		------------------------------------------------------------
		
		--룬 카드 발동 연출
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		_RuneCardDirector:ShakingCard_Ready(index)
		_RuneCardDirector:IconToastDirector_Ready(index, _RuneCardDirectEnum.Coin, "+2")
	end

end