@Component
script RC10039 extends RuneCardComponent

	property number SetAmount = 30

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 대기석이 가득 차있는 상태라면, 전투 시작 시 모든 아군이 MP를 30 획득합니다.
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local units = {}
		local enemy = {}
		------------------------------------------------------------
		
		if self.SetTeamType == "User" then
			local checked = true
			if userPControl.Tile_AvailableWaitingTile <= 0 then
				checked = true
			else
				for i = 1, userPControl.Tile_AvailableWaitingTile do
					local checkTile = user.GameManager.RoomTile[math.floor(i) .. ",0"]
					if not isvalid(teamManager.EntityOnTile[checkTile]) then
						checked = false
						break
					end
				end
			end
			
			
			if checked then
				for _, unit in pairs(teamManager.OwnUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:SetVariableStatus(unit, unit, "MP", self.SetAmount, "rune")
						table.insert(units, unit)
					end
				end
			end
		else
			-- 적은 대기석이 따로 없으므로 무조건 적용
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:SetVariableStatus(unit, unit, "MP", self.SetAmount, "rune")
					table.insert(enemy, unit)
				end
			end
		end
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		local stringValue = string.format("%d", self.SetAmount)
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MP}, {stringValue}, false)
		end
		
		if #enemy > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MP}, {stringValue}, true)
		end
		
	end

end