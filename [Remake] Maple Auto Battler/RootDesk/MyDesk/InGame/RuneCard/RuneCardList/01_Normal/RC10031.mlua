@Component
script RC10031 extends RuneCardComponent

	property number SetTime = 3

	@ExecSpace("ServerOnly")
	method void OnSkillHitHandler(any event)
		__base:OnSkillHitHandler(event)
		
		-- 아이템을 장착하지 않은 아군 유닛이 적을 공격하면 3초간 물리 방어 약화 및 마법 방어 약화 상태로 만듭니다.
		-----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		
		---@type Entity
		local attacker = event.Attacker
		
		---@type Entity
		local target = event.Target
		-----------------------------------------------------------------------
		if attacker.UnitInfo.TeamType == self.SetTeamType and #attacker.UnitStatus.EquippedItemIDList == 0 then
			_StatusChangeLogic:SetStatus(attacker, target, "SE0008", self.SetTime)
			_StatusChangeLogic:SetStatus(attacker, target, "SE0009", self.SetTime)
		end
	end

	@ExecSpace("ServerOnly")
	method void OnDefaultAttackHitHandler(any event)
		__base:OnDefaultAttackHitHandler(event)
		
		-- 아이템을 장착하지 않은 아군 유닛이 적을 공격하면 3초간 물리 방어 약화 및 마법 방어 약화 상태로 만듭니다.
		-----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		
		---@type Entity
		local attacker = event.Attacker
		
		---@type Entity
		local target = event.Target
		-----------------------------------------------------------------------
		if attacker.UnitInfo.TeamType == self.SetTeamType and #attacker.UnitStatus.EquippedItemIDList == 0 then
			_StatusChangeLogic:SetStatus(attacker, target, "SE0008", self.SetTime)
			_StatusChangeLogic:SetStatus(attacker, target, "SE0009", self.SetTime)
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 아이템을 장착하지 않은 아군 유닛이 적을 공격하면 3초간 물리 방어 약화 및 마법 방어 약화 상태로 만듭니다.
		-----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local units = {}
		local enemy = {}
		local teamManager = user.TeamManager
		-----------------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if #unit.UnitStatus.EquippedItemIDList == 0 then
						table.insert(units, unit)
					end
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if #unit.UnitStatus.EquippedItemIDList == 0 then
						table.insert(enemy, unit)
					end
				end
			end
		end
		
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
		end
		
		if #enemy>0 then
			local cardindex=_RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
		end
		
		--룬 카드 효과 연출
		for i=1,#units do
			_GeneralDirectorLogic:BattleBuffEffect(units[i], _RuneCardDirectEnum.Weakening)
		end
		
		for i=1,#enemy do
			_GeneralDirectorLogic:BattleBuffEffect(enemy[i], _RuneCardDirectEnum.Weakening)
		end
	end

end