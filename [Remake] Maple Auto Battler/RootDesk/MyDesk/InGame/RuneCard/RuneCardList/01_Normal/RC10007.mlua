@Component
script RC10007 extends RuneCardComponent

	property number SetAmount = 80

	property number SetTime = 8

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시 주변에 아군이 있는 유닛이 8초동안 80의 보호막을 얻습니다. 이 효과는 중첩됩니다.
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		------------------------------------------------------------
		
		if self.SetTeamType == "User" then
			local myTeams = teamManager.OwnUnits
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					local checkTile = unit.UnitInfo.setTile
					local checkTeams = _BTLogic_New:getEntities(myTeams, "Alive")
					checkTeams = _BTLogic_New:getTargets(checkTile, checkTeams, "Around_1_1")
					
					_StatusChangeLogic:SetShield(unit, unit, self.SetAmount * #checkTeams, self.SetTime, "RC10007")
					table.insert(units, unit)
				end
			end
		else
			local myTeams = teamManager.EnemyUnits
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					local checkTile = unit.UnitInfo.setTile
					local checkTeams = _BTLogic_New:getEntities(myTeams, "Alive")
					checkTeams = _BTLogic_New:getTargets(checkTile, checkTeams, "Around_1_1")
					
					_StatusChangeLogic:SetShield(unit, unit, self.SetAmount * #checkTeams, self.SetTime, "RC10007")
					table.insert(enemy, unit)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		--룬 카드 발동 연출
		local stringValue = string.format("%d", self.SetAmount)
		
		if #units > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.Shield}, {stringValue}, false)
		end
		
		if #enemy > 0 then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(index, true)
			_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.Shield}, {stringValue}, true)
		end
	end

end