@Component
script RC10020 extends RuneCardComponent

	property number SetPercent = 10

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시, 스택마다 모든 아군의 공격력, 마력 + 10%
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		local units={}
		local enemy={}
		------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetPercent * self.RuneStack, -1)
				_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetPercent * self.RuneStack, -1)
				table.insert(units,unit)
			end
		else
			local addStack = math.floor(gameManager.Stage / 2)
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetPercent * addStack, -1)
				_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetPercent * addStack, -1)
				table.insert(enemy,unit)
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		local stack = self.RuneStack
		self:PlayEffect(stack, units, enemy, true, user.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void LoseBattleHandler(any event)
		__base:LoseBattleHandler(event)
		-- 전투에서 패배할 때마다, +1 스택 증가
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		------------------------------------------------------------
		if self.SetTeamType == "User" then
			self:SetRuneStackInfo(self.RuneStack + 1)
			local stack = self.RuneStack
			self:PlayEffect(stack, "", "", false, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(number stack, string units, string enemy, boolean StartBattle)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		if stack < 0 then stack = 0 end
		
		if StartBattle then
			if stack == 0 then return end
			-- 룬 카드 발동 연출
			if #units > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
				_RuneCardDirector:ShakingCard_Battle(index, false)
				local value = stack
				_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.PhysicalAttack, _RuneCardDirectEnum.MagicalAttack}, {tostring(value*self.SetPercent).."%",tostring(value*self.SetPercent).."%"}, false)
			end
			
			if #enemy > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
				_RuneCardDirector:ShakingCard_Battle(index, true)
				local value = stack
				_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.PhysicalAttack, _RuneCardDirectEnum.MagicalAttack},{tostring(value*self.SetPercent).."%", tostring(value*self.SetPercent).."%"}, true)
			end
			
			
		else
			if _RuneCardDirector.RuneCardManagingValue["RC10020"][self.Entity.Id] < stack then
				
				--발동 연출
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
				_RuneCardDirector:ShakingCard_Battle(index, false)
				
				-- +1
				_RuneCardDirector:IconToastDirector_Battle(index, {0}, {"1"}, false)
				_RuneCardDirector.RuneCardManagingValue["RC10020"][self.Entity.Id] = stack
				_RuneCardDirector:CheckRuneCardManagingValue("RC10020", index)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector.RuneCardManagingValue["RC10020"][self.Entity.Id] = stack
		_RuneCardDirector:CheckRuneCardManagingValue("RC10020", runeindex)
	end

end