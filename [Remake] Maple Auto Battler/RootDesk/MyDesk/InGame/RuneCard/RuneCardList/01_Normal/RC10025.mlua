@Component
script RC10025 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 매 준비 단계 시작 시, 첫 상점 가장 왼쪽의 캐릭터를 무료로 얻습니다.
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local charShopManager = user.CharacterShopManager_New
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			
			for i = 1, 5 do
				if charShopManager.CurrentDisplayedUnits[i] ~= "" then
					-- 업적: 룬카드 [토미] 효과로 5 코스트 캐릭터 얻기 
					_AchievementService:UpdateProgress_RuneCard("AC004004",charShopManager.CurrentDisplayedUnitsCost[i],user)
		
					charShopManager.CurrentDisplayedUnitsCost[i] = 0
					_UnitSetLogic_New:SpawnUnit(user.OwnerId, charShopManager.CurrentDisplayedUnits[i], 1, "Force")
					charShopManager.CurrentDisplayedUnits[i] = ""
					_TimerService:SetTimerOnce(function() self:PlayEffect(user.PlayerComponent.UserId) end ,1.5)
					break
				end
			end
		end
	end

	@ExecSpace("Client")
	method void PlayEffect()
		_PlaySoundLogic:PlaySound("M0005")
		
		--발동 연출
		local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:ShakingCard_Ready(index)
		
	end

end