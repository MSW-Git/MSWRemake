@Component
script RC10008 extends RuneCardComponent

	property number SetHPAmount = 20

	property number SetPhysicalAttackAmount = 3

	property number SetMagicalAttackAmount = 3

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시 대기석의 유닛들이 영구적으로 30의 최대 체력과 3의 공격력, 3의 마력을 얻습니다.
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		------------------------------------------------------------
		
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if not unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:SetStack(unit, "Add_MaxHP", self.SetHPAmount)
					_StatusChangeLogic:SetStack(unit, "Add_PhysicalAttack", self.SetPhysicalAttackAmount)
					_StatusChangeLogic:SetStack(unit, "Add_MagicalAttack", self.SetMagicalAttackAmount)
					table.insert(units, unit)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		self:PlayEffect(units, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		------------------------------------------------------------
		--룬 카드 발동 연출
		local stringValue_setHP = string.format("%d", self.SetHPAmount) 
		local stringValue_setMagicalAttack = string.format("%d", self.SetMagicalAttackAmount)
		local stringValue_setPhysicalAttack = string.format("%d", self.SetPhysicalAttackAmount)
		
		if #units > 0 then
			local index=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
			_RuneCardDirector:ShakingCard_Battle(index, false)
			_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.MagicalAttack, _RuneCardDirectEnum.PhysicalAttack}, {stringValue_setHP, stringValue_setMagicalAttack, stringValue_setPhysicalAttack}, false)
		end
	end

end