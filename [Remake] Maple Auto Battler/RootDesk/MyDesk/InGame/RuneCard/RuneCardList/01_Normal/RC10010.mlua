@Component
script RC10010 extends RuneCardComponent

	property number GetCoins = 5

	@ExecSpace("ServerOnly")
	method void CombinationItemHandler(any event)
		__base:CombinationItemHandler(event)
		
		-- 완성 아이템을 제작할 때마다 5코인을 얻습니다. (라운드 당 1회 제한)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			if self.UsedRuneAbility then
				teamManager:AddGolds(self.GetCoins, "runeCard")
				self.UsedRuneAbility = false
				self:PlayEffect("Coin", user.PlayerComponent.UserId)
			end
		end
		
		
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 완성 아이템을 제작할 때마다 5코인을 얻습니다. (라운드 당 1회 제한)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = true
			self:PlayEffect("Init", user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 구매 직후 라운드에도 적용
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = true
			self:PlayEffect("Init", user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(string type)
		if type == "Coin" then
			_RuneCardDirector:RC10010Director(true, self.Entity)
			
		elseif type == "Init" then
			_RuneCardDirector:RC10010Director(false, self.Entity)
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.UsedRuneAbility,user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(boolean ability)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		if ability then
			_RuneCardDirector.RuneCardManagingValue["RC10010"][self.Entity.Id]=0
		else
			_RuneCardDirector.RuneCardManagingValue["RC10010"][self.Entity.Id]=1
		end
		_RuneCardDirector:CheckRuneCardManagingValue("RC10010",runeindex)
	end

end