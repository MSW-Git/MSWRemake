@Component
script RC10029 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void SellUnitHandler(any event)
		__base:SellUnitHandler(event)
		
		-- 2성 이상의 캐릭터를 판매하면 해당 캐릭터의 비용에 따라 보너스를 획득합니다. (라운드당 1회 제한)
		---------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local unit = event.Unit
		local charID = event.CharID
		local cost = event.UnitCost
		local level = event.UnitLevel
		local items=0
		local itemID=""
		---------------------------------------------------------------------
		if self.SetTeamType == "User" then
			if self.UsedRuneAbility then
				if level >= 2 then
					local teamManager = user.TeamManager
					if cost == 1 then
						teamManager:AddGolds(2, "runeCard")
					elseif cost == 2 then
						teamManager:AddGolds(5, "runeCard")
					elseif cost == 3 then
						_ItemSetLogic:GetConsumableItem(user.OwnerId, -1)
						items=#user.TeamManager.OwnItems
						itemID=user.TeamManager.OwnItems[items]
					elseif cost == 4 then
						_ItemSetLogic:GetItemBox(user.OwnerId, 4)
						items=#user.TeamManager.OwnItems
						itemID=user.TeamManager.OwnItems[items]
					elseif cost == 5 then
						teamManager:AddGolds(20, "runeCard")
					end
					self.UsedRuneAbility = false
					self:PlayEffect(cost, items, itemID, user.PlayerComponent.UserId)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 2성 이상의 캐릭터를 판매하면 해당 캐릭터의 비용에 따라 보너스를 획득합니다. (라운드당 1회 제한)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = true
			self:SetDirectorValue(true, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 2성 이상의 캐릭터를 판매하면 해당 캐릭터의 비용에 따라 보너스를 획득합니다. (라운드당 1회 제한)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		if self.SetTeamType == "User" then
			self.UsedRuneAbility = true
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.UsedRuneAbility,user.PlayerComponent.UserId)
		
	end

	@ExecSpace("Client")
	method void PlayEffect(integer cost, integer items, string ItemID)
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		if cost == 1 then
			_RuneCardDirector:RuneCardCoinDirector(index, 2)
		elseif cost == 2 then
			_RuneCardDirector:RuneCardCoinDirector(index, 5)
		elseif cost == 3 then
			_RuneCardDirector:RuneCardItemDirector_Ready(items, "RC10029", ItemID, index)
		elseif cost == 4 then
			_RuneCardDirector:RuneCardItemDirector_Ready(items, "RC10029", ItemID,index)
		elseif cost == 5 then
			_RuneCardDirector:RuneCardCoinDirector(index, 20)
		end
		
		self:SetDirectorValue(false)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(boolean OnOff)
		local stack = 0
		if OnOff == false then
			stack = 1
		end
		
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector.RuneCardManagingValue["RC10029"][self.Entity.Id] = stack/_RuneCardDirector.RuneCardMaxStack["RC10029"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC10029", runeindex)
	end

end