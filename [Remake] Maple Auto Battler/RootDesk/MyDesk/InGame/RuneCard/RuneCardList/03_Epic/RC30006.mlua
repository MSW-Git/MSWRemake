@Component
script RC30006 extends RuneCardComponent

	property number SetEXPAmount = 4

	property number SetCoinAmount = 4

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 더 이상 이자를 얻을 수 없습니다.
		--------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		--------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Golds_MaxInterestReward -= 100
		end
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 대신, 매 준비 단계 시작마다 4의 경험치와 4 코인을 얻습니다.
		--------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		--------------------------------------------------------
		if self.SetTeamType == "User" then
			_TimerService:SetTimerOnce(function() teamManager:AddEXP(self.SetEXPAmount) end , 1.5)
			_TimerService:SetTimerOnce(function() teamManager:AddGolds(self.SetCoinAmount, "runeCard") end , 1.5)
			_TimerService:SetTimerOnce(function() self:PlayEffect(user.PlayerComponent.UserId) end , 1.5)
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 더 이상 이자를 얻을 수 없습니다.
		--------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		--------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Golds_MaxInterestReward += 100
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				userPControl.Golds_MaxInterestReward -= 100
			else
				-- 비활성화 시
				userPControl.Golds_MaxInterestReward += 100
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

	@ExecSpace("Client")
	method void PlayEffect()
		local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		
		--룬 카드 발동 연출(경험치)
		_RuneCardDirector:ShakingCard_Ready(index)
		_RuneCardDirector:IconToastDirector_Ready(index,_RuneCardDirectEnum.Exp, string.format("EXP+%d", self.SetEXPAmount))
		
		--룬 카드 효과 연출(코인)
		_RuneCardDirector:RuneCardCoinDirector(index, self.SetCoinAmount)
	end

end