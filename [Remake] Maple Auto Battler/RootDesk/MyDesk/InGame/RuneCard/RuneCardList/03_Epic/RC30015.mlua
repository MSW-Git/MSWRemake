@Component
script RC30015 extends RuneCardComponent

	property number SetHPAmount = 50

	property number SetAttackAmount = 8

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시, 모든 아군이 활성화된 시너지 하나 당 최대 체력 80, 공격력 8, 마력 8을 얻습니다.
		-------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local units = {}
		local enemy = {}
		-------------------------------------------------------------------
		local synergyTable = _DataService:GetTable("SynergyInfo")
		local tableRowCount = synergyTable:GetRowCount()
		local activateConditionTable = {}
		local activeSynergyCount = 0
		
		-- 시너지 활성화 여부 체크를 위해 최소로 필요한 숫자 테이블 가져오기
		for i = 1, tableRowCount do
			local synergyRow = synergyTable:GetRow(i)
			local synergyID = synergyRow:GetItem("SynergyID")
			
			for j = 1, 5 do
				local count = synergyRow:GetItem(string.format("NeedCount_step%d", j))
				if isvalid(tonumber(count)) then
					activateConditionTable[i] = tonumber(count)
					break
				end
			end
		end
		
		-- 팀 당 버프 체크
		if self.SetTeamType == "User" then
			for i = 1, tableRowCount do
				local synergyRow = synergyTable:GetRow(i)
				local synergyID = synergyRow:GetItem("SynergyID")
				
				if isvalid(teamManager.OnFieldSynergy[synergyID]) then
					if teamManager.OnFieldSynergy[synergyID] >= activateConditionTable[i] then
						activeSynergyCount += 1
					end 
				end
			end
			
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetHPAmount * activeSynergyCount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAttackAmount * activeSynergyCount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAttackAmount * activeSynergyCount, -1)
						table.insert(units, unit)
				end
			end
		else
			for i = 1, tableRowCount do
				local synergyRow = synergyTable:GetRow(i)
				local synergyID = synergyRow:GetItem("SynergyID")
				
				if isvalid(teamManager.EnemyOwnedFieldSynergy[synergyID]) then
					if teamManager.EnemyOwnedFieldSynergy[synergyID] >= activateConditionTable[i] then
						activeSynergyCount += 1
					end 
				end
			end
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetHPAmount * activeSynergyCount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAttackAmount * activeSynergyCount, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAttackAmount * activeSynergyCount, -1)
					table.insert(enemy, unit)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, activeSynergyCount, user.PlayerComponent.UserId)
		
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy, integer activeSynergyCount)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.MagicalAttack, _RuneCardDirectEnum.PhysicalAttack},
																	{tostring(math.floor(activeSynergyCount*self.SetHPAmount)), tostring(math.floor(activeSynergyCount*self.SetAttackAmount)), tostring(math.floor(activeSynergyCount*self.SetAttackAmount))}, false)
		end
		
		if #enemy > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.MagicalAttack, _RuneCardDirectEnum.PhysicalAttack}, {tostring(math.floor(activeSynergyCount*self.SetHPAmount)), tostring(math.floor(activeSynergyCount*self.SetAttackAmount)), tostring(math.floor(activeSynergyCount*self.SetAttackAmount))}, true)
		end
	end

end