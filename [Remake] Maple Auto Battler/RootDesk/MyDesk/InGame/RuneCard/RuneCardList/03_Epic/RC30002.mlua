@Component
script RC30002 extends RuneCardComponent

	property number NeedCount = 12

	@ExecSpace("ServerOnly")
	method void ReRollCharacterShopHandler(any event)
		__base:ReRollCharacterShopHandler(event)
		
		-- 상점을 12번 새로고침 할 때마다 수상한 초대장을 획득합니다.
		---------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		---------------------------------------------------------------------
		if self.SetTeamType == "User" then
			--self.RuneStack += 1
			self:SetRuneStackInfo(self.RuneStack + 1)
			if self.RuneStack >= self.NeedCount then
				--self.RuneStack -= self.NeedCount
				self:SetRuneStackInfo(self.RuneStack - self.NeedCount)
				_ItemSetLogic:GetConsumableItem(user.OwnerId, 8)
			end
			
			local items=#user.TeamManager.OwnItems
			self:PlayEffect(self.RuneStack, items, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex=_RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		_RuneCardDirector.RuneCardManagingValue["RC30002"][self.Entity.Id]=stack/_RuneCardDirector.RuneCardMaxStack["RC30002"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC30002",runeindex)
	end

	@ExecSpace("Client")
	method void PlayEffect(number value, integer items)
		--발동 연출
		local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:ShakingCard_Ready(index)
		_RuneCardDirector:IconToastDirector_Ready(index, 0, "+1")
		
		--특수 연출
		_RuneCardDirector.RuneCardManagingValue["RC30002"][self.Entity.Id] = value / _RuneCardDirector.RuneCardMaxStack["RC30002"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC30002", index)
			
		--아이템 획득 연출
		if value == 0 then
			local user = self.Entity.Parent.Parent
			_RuneCardDirector:RuneCardItemDirector_Ready(items, "RC30002", "CI0008", index)
		end
		
	end

end