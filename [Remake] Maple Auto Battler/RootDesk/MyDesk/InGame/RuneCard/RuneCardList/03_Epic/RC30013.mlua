@Component
script RC30013 extends RuneCardComponent

	property number SetMPAmount = 30

	property number SetASPercent = 40

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투 시작 시, 맨 뒷열 아군이 30의 마나와 40%의 공격 속도를 얻습니다.
		-----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		-----------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable and unit.UnitInfo.setTileHorizontalNum == 1 then
					_StatusChangeLogic:SetVariableStatus(unit, unit, "MP", self.SetMPAmount, "rune")
					_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", self.SetASPercent, -1)
					table.insert(units, unit)
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable and unit.UnitInfo.setTileHorizontalNum + ( (unit.UnitInfo.setTileVerticalNum + 1)%2 ) >= 9 then
					_StatusChangeLogic:SetVariableStatus(unit, unit, "MP", self.SetMPAmount, "rune")
					_StatusChangeLogic:GetBuff(unit, "Multi_AttackSpeed", self.SetASPercent, -1)
					table.insert(enemy, unit)
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		local stringMPValue = string.format("%d", self.SetMPAmount)
		local stringASValue = string.format("%d%%", self.SetASPercent)
		
		--룬 카드 발동 연출
		if #units > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MP, _RuneCardDirectEnum.AttackSpeed}, {stringMPValue, stringASValue}, false)
		end
		
		if #enemy > 0 then
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.MP, _RuneCardDirectEnum.AttackSpeed}, {stringMPValue, stringASValue}, true)
		end
	end

end