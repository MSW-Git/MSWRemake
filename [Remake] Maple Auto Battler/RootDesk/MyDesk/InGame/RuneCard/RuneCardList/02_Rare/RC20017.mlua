@Component
script RC20017 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void KillUnitHandler(any event)
		__base:KillUnitHandler(event)
		
		-- 적 유닛을 처치하면 5%의 확률로 조합 아이템을 얻습니다.
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		
		---@type Entity
		local attacker = event.Attacker
		------------------------------------------------------------
		if isvalid(attacker) then
			if self.SetTeamType == attacker.UnitInfo.TeamType and self.SetTeamType == "User" then
				local per = _UtilLogic:RandomDouble()
				
				if per < 0.05 then
			--if per <= 1 then
					_ItemSetLogic:GetMaterialItem(user.OwnerId, 0)
					local items=#user.TeamManager.OwnItems
					local itemID=user.TeamManager.OwnItems[items]
					self:PlayEffect(true, items, itemID, user.PlayerComponent.UserId)
				end
			end
		end
		
		-- 적은 사용하지 못하는 룬 카드
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean Battle, integer items, string itemID)
		local index=_RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		----------------------------------------------------------------
		--발동 연출
		_RuneCardDirector:ShakingCard_Battle(index, false)
		_RuneCardDirector:RuneCardItemDirector_Battle(itemID, index)
	end

end