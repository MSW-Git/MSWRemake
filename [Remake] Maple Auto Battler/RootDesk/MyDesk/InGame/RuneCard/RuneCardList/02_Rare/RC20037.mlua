@Component
script RC20037 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void StartStageHandler(any event)
		__base:StartStageHandler(event)
		
		-- 매 스테이지를 시작할 때마다 랜덤한 노멀 룬카드를 2장 얻습니다.
		---------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		---------------------------------------------------------------
		
		if self.SetTeamType == "User" then
			local getNormalCards = function()
				local runeSlotCount = user.TM_PropertyControl.Rune_UseRuneSlotCount
				local getRuneCount = math.min(2, runeSlotCount - #teamManager.OwnRunes)
				
				-- 노말 등급의 룬 카드들을 목록에 넣습니다.
				local runeDataInfo = _DataService:GetTable("RuneInfo")
				local normalRuneTable = _RuneCardSetLogic:GetRuneCardList(user.OwnerId, "Normal", true, true)
				
				-- (획득할 수 있는 개수가 1개 이상이면) 이펙트 재생
				if getRuneCount > 0 then
					_TimerService:SetTimerOnce(function() self:PlayEffect(user.PlayerComponent.UserId) end , 1.8)
				end
				
				for i = 1, getRuneCount do
					local setRuneIdx = _UtilLogic:RandomIntegerRange(1, #normalRuneTable)
					local setRuneID = normalRuneTable[setRuneIdx]
					
					_TimerService:SetTimerOnce(function() specialShopManager:GetRuneCard_Check(setRuneID) end , 1.8)
					
					table.remove(normalRuneTable, setRuneIdx)
				end
			end
			
			_TimerService:SetTimerOnce(getNormalCards, 0.5)
		end
	end

	@ExecSpace("Client")
	method void PlayEffect()
		--발동연출
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector:ShakingCard_Ready(index)
		
		--효과 연출은 인벤토리 로직에서 자동 실행
	end

end