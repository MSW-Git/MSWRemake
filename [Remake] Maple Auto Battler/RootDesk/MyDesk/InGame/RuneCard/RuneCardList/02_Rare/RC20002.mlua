@Component
script RC20002 extends RuneCardComponent

	property number GetHPPerAmount = 0.12

	@ExecSpace("ServerOnly")
	method void DeadUnitHandler(any event)
		__base:DeadUnitHandler(event)
		
		-- 아군이 죽을 때마다, 모든 아군이 최대 체력의 12%만큼 회복합니다.
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		
		---@type Entity
		local deadUnit = event.Target
		--------------------------------------------------------------------
		if self.SetTeamType == deadUnit.UnitInfo.TeamType then
			if self.SetTeamType == "User" then
				for _, unit in pairs(teamManager.OwnUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:SetVariableStatus(unit, unit, "HP", unit.UnitStatus.MaxHP * self.GetHPPerAmount, "rune")
						table.insert(units,unit)
					end
				end
			else
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:SetVariableStatus(unit, unit, "HP", unit.UnitStatus.MaxHP * self.GetHPPerAmount, "rune")
						table.insert(enemy,unit)
					end
				end
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		local setString = string.format("%d%%", self.GetHPPerAmount * 100)
		
		
		--룬 카드 발동 연출
		if #units > 0 then
			if self.GetHPPerAmount <= 0 then return end
			
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			_RuneCardDirector:ShakingCard_Battle(cardindex, false)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.HP}, {setString}, false)
		end
		
		if #enemy > 0 then
			if self.GetHPPerAmount <= 0 then return end
			
			local cardindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
			_RuneCardDirector:ShakingCard_Battle(cardindex, true)
			_RuneCardDirector:IconToastDirector_Battle(cardindex, {_RuneCardDirectEnum.HP}, {setString}, true)
		end
	end

end