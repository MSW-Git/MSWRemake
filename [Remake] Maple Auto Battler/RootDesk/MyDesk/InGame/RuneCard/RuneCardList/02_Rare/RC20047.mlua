@Component
script RC20047 extends RuneCardComponent

	property number CheckUnitCount = 0

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 빅토리아 아일랜드 시너지 효과
		-- 가장 마지막까지 살아남은 빅토리아 아일랜드 유닛이 한 번 더 부활합니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10017"] += 1
		else
			synergyManager.Enemy_SynergyRuneOn["S10017"] += 1
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 빅토리아 아일랜드 시너지 효과
		-- 가장 마지막까지 살아남은 빅토리아 아일랜드 유닛이 한 번 더 부활합니다.
		--------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		--------------------------------------------------
		if self.SetTeamType == "User" then
			synergyManager.SynergyRuneOn["S10017"] -= 1
		else
			synergyManager.Enemy_SynergyRuneOn["S10017"] -= 1
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 빅토리아 아일랜드 유닛 체크
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		--------------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitInfo:DoesHaveSynergy("S10017") then
						self.CheckUnitCount += 1
					end
				end
			end
		else
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitAIWanderComponent.Enable then
					if unit.UnitInfo:DoesHaveSynergy("S10017") then
						self.CheckUnitCount += 1
					end
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void DeadUnitHandler(any event)
		__base:DeadUnitHandler(event)
		
		-- 빅토리아 아일랜드 유닛 체크
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		
		---@type Entity
		local target = event.Target
		--------------------------------------------------------------------
		if self.SetTeamType == target.UnitInfo.TeamType then
			self.CheckUnitCount -= 1
			
			if self.CheckUnitCount == 1 then
				if self.SetTeamType == "User" then
					for _, unit in pairs(teamManager.OwnUnits) do
						if unit.UnitAIWanderComponent.Enable then
							if unit.UnitInfo:DoesHaveSynergy("S10017") then
								unit.UnitSynergy.SynergyStack["S10017_Revive"] += 1
								break
							end
						end
					end
				else
					for _, unit in pairs(teamManager.EnemyUnits) do
						if unit.UnitAIWanderComponent.Enable then
							if unit.UnitInfo:DoesHaveSynergy("S10017") then
								unit.UnitSynergy.SynergyStack["S10017_Revive"] += 1
								break
							end
						end
					end
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void EndRoundHandler(any event)
		__base:EndRoundHandler(event)
		
		-- 스탯 초기화
		--------------------------------------------------------------------
		self.CheckUnitCount = 0
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local synergyManager = user.SynergyManager_New
		local synergyID = "S10017"
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				synergyManager.SynergyRuneOn[synergyID] += 1
			else
				-- 비활성화 시
				synergyManager.SynergyRuneOn[synergyID] -= 1
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end