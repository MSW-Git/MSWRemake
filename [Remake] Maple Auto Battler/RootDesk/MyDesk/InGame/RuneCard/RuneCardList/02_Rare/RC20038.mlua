@Component
script RC20038 extends RuneCardComponent

	property number SetMinusAmount = 1

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 경험치 구매에 필요한 비용이 3코인이 됩니다.
		-- 대신 경험치 구매를 통해 레벨 업을 할 수는 없습니다.
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		--------------------------------------------------------------------
		if self.SetTeamType == "User" and not self.Copied then
			userPControl.Exp_Cost -= self.SetMinusAmount
			userPControl.Exp_CanLevelUpThroughBuyExp = false
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 경험치 구매에 필요한 비용이 1코인 줄어듭니다.
		-- 대신 경험치 구매를 통해 레벨 업을 할 수는 없습니다.
		--------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		--------------------------------------------------------------------
		if self.SetTeamType == "User" and not self.Copied then
			userPControl.Exp_Cost += self.SetMinusAmount
			userPControl.Exp_CanLevelUpThroughBuyExp = true
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				if not self.Copied then
					userPControl.Exp_Cost -= self.SetMinusAmount
					userPControl.Exp_CanLevelUpThroughBuyExp = false
				end
			else
				-- 비활성화 시
				if not self.Copied then
					userPControl.Exp_Cost += self.SetMinusAmount
					userPControl.Exp_CanLevelUpThroughBuyExp = true
				end
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end