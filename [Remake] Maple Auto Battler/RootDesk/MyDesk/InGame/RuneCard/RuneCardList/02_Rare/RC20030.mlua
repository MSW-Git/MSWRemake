@Component
script RC20030 extends RuneCardComponent

	property number MaxCoin = 50

	property number SetCoinAmount = 20

	@ExecSpace("ServerOnly")
	method void StartStageHandler(any event)
		__base:StartStageHandler(event)
		
		-- 스테이지가 넘어갈 때마다 20코인씩 획득합니다.
		-- 이 때, 50코인을 넘으면 룬카드가 파괴되고 모든 코인을 잃습니다.
		-----------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		-----------------------------------------------------------------------
		local check = function()
			if self.SetTeamType == "User" then
				if teamManager.Golds > self.MaxCoin then
					self:PlayEffect(true, user.PlayerComponent.UserId)
						if not self.Copied then
							teamManager.Golds = 0
							
							local removecard = function()
								specialShopManager:RemoveRuneCard("RC20030", self.UID)
								if isvalid(self.CopiedComponent) then
									specialShopManager:RemoveRuneCard("RC40003", self.UID)
								end
							end
							_TimerService:SetTimerOnce(removecard, 2)
						else
							teamManager.Golds = 0
							local removecard = function()
								specialShopManager:RemoveRuneCard("RC20030", self.UID)
								specialShopManager:RemoveRuneCard("RC40003", self.UID)
							end
							_TimerService:SetTimerOnce(removecard, 2)
						end
		
						-- 업적: 룬카드 [마슈르] 효과로 모든 코인 잃기 
						_AchievementService:UpdateProgress_RuneCard("AC004008", 1, user)
					
				else
					self:PlayEffect(false, user.PlayerComponent.UserId)
				end
			end
		end
		
		_TimerService:SetTimerOnce(check, 1)
	end

	@ExecSpace("ServerOnly")
	method void EndRoundHandler(any event)
		__base:EndRoundHandler(event)
		
		-----------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		
		local roundNum = event.Round
		-----------------------------------------------------
		if self.SetTeamType == "User" and roundNum == 3 then
			teamManager:AddGolds(self.SetCoinAmount, "runeCard")
		end
	end

	@ExecSpace("Client")
	method void PlayEffect(boolean Destroy)
		--룬 카드 발동 연출 없음
		
		--룬 카드 효과 연출
		local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		_RuneCardDirector:RuneCardCoinDirector(index, self.SetCoinAmount)
		
		if Destroy then
			_TimerService:SetTimerOnce(function() _RuneCardDirector:RC20030Director(index) end , 1.5)
		end
		
		
	end

end