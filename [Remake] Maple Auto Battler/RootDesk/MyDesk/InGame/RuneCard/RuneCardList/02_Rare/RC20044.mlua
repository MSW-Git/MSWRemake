@Component
script RC20044 extends RuneCardComponent

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 현재 팀 레벨보다 한 단계 높은 상점 확률이 적용됩니다.
		-- 현재 팀 레벨이 스테이지 수보다 작거나 같다면, 두 단계 높은 상점 확률이 적용됩니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		----------------------------------------------------------------
		if self.SetTeamType == "User" then
			if gameManager.Stage >= teamManager.Level then
				userPControl.Level_ShopAddLevel += 2
				self:SetRuneStackInfo(2)
			else
				userPControl.Level_ShopAddLevel += 1
				self:SetRuneStackInfo(1)
			end
		end
	end

	@ExecSpace("Server")
	method void SellThisRuneCard(string runeID)
		-- 현재 팀 레벨보다 한 단계 높은 상점 확률이 적용됩니다.
		-- 현재 팀 레벨이 스테이지 수보다 작거나 같다면, 두 단계 높은 상점 확률이 적용됩니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		----------------------------------------------------------------
		if self.SetTeamType == "User" then
			userPControl.Level_ShopAddLevel -= self.RuneStack
		end
		
		__base:SellThisRuneCard(runeID)
	end

	@ExecSpace("ServerOnly")
	method void StartStageHandler(any event)
		__base:StartStageHandler(event)
		
		-- 현재 팀 레벨이 스테이지 수보다 작거나 같다면, 두 단계 높은 상점 확률이 적용됩니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		----------------------------------------------------------------
		if self.SetTeamType == "User" then
			if gameManager.Stage >= teamManager.Level and self.RuneStack == 1 then
				userPControl.Level_ShopAddLevel += 1
				self:SetRuneStackInfo(2)
			elseif gameManager.Stage < teamManager.Level and self.RuneStack == 2 then
				userPControl.Level_ShopAddLevel -= 1
				self:SetRuneStackInfo(1)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void LevelUpTeamHandler(any event)
		__base:LevelUpTeamHandler(event)
		
		-- 현재 팀 레벨이 스테이지 수보다 작거나 같다면, 두 단계 높은 상점 확률이 적용됩니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		----------------------------------------------------------------
		if self.SetTeamType == "User" then
			if gameManager.Stage >= teamManager.Level and self.RuneStack == 1 then
				userPControl.Level_ShopAddLevel += 1
				self:SetRuneStackInfo(2)
			elseif gameManager.Stage < teamManager.Level and self.RuneStack == 2 then
				userPControl.Level_ShopAddLevel -= 1
				self:SetRuneStackInfo(1)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SetActiveHandler(any event)
		-------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local userPControl = user.TM_PropertyControl
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		local active = event.active
		-------------------------------------------------------------
		if active ~= self.OnActive then
			if active then
				-- 활성화 시
				if gameManager.Stage >= teamManager.Level then
					userPControl.Level_ShopAddLevel += 2
					self:SetRuneStackInfo(2)
				else
					userPControl.Level_ShopAddLevel += 1
					self:SetRuneStackInfo(1)
				end
			else
				-- 비활성화 시
				userPControl.Level_ShopAddLevel -= self.RuneStack
			end
		end
		
		
		__base:SetActiveHandler(event)
	end

end