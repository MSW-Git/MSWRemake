@Component
script RC20007 extends RuneCardComponent

	property number SetHPAmount = 8

	property number SetAmount = 2

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 매 라운드가 시작될 때, 대기석에 있는 유닛들 중 가장 오른쪽 유닛이 제거되고, 해당 유닛의 판매 가치만큼 룬 카드에 스택이 쌓입니다.
		-----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		-----------------------------------------------------------------
		if self.SetTeamType == "User" then
			---@type Entity
			local checkedUnit = nil
			local checkTile = nil -- 연출용 변수
			
			for i = userPControl.Tile_AvailableWaitingTile , 1, -1 do
				checkTile = user.GameManager.RoomTile[math.floor(i) .. ",0"]
				if isvalid(teamManager.EntityOnTile[checkTile]) then
					checkedUnit = teamManager.EntityOnTile[checkTile]
					break
				end
			end
			
			if isvalid(checkedUnit) then
				if not self.Copied then
					if checkedUnit.UnitInfo.level == 1 then
						self:SetRuneStackInfo(self.RuneStack + checkedUnit.UnitInfo.cost)
					else
						self:SetRuneStackInfo(self.RuneStack + ( checkedUnit.UnitInfo.cost * (3)^(checkedUnit.UnitInfo.level - 1) ) - math.floor( (2 + checkedUnit.UnitInfo.cost) / 4 ))
					end
					
					-- 유닛 제거
					checkedUnit.UnitInfo.cost = 0
					_UnitSetLogic_New:SellUnit(user.OwnerId, checkedUnit)
					
					
					--연출
					_CustomizedBattleEffectService:PlayEffect("d1fd0a5ea7c54d88b3ca37bbb3312a9d", user.CurrentMap, checkTile.TransformComponent.WorldPosition:Clone(), 0, Vector3.one*0.8, false, user.PlayerComponent.UserId) -- 타이머돌지 않고 바로 재생
					
					local value = self.RuneStack
					_TimerService:SetTimerOnce(function() self:PlayEffect(value, false, "",  "", user.PlayerComponent.UserId) end , 1.5)
					
					if isvalid(self.CopiedComponent) then
						_TimerService:SetTimerOnce(function() 
							---@type RC20007
							local copiedCompo = self.CopiedComponent
							copiedCompo:PlayEffect(value, false, "", "", user.PlayerComponent.UserId) 
						end , 1.5)
					end
				else
					if checkedUnit.UnitInfo.level == 1 then
						local addRuneStack = self.CopiedComponent.RuneStack + checkedUnit.UnitInfo.cost
						
						self.CopiedComponent:SetRuneStackInfo(addRuneStack)
						self:SetRuneStackInfo(addRuneStack)
					else
						local addRuneStack = self.CopiedComponent.RuneStack + ( checkedUnit.UnitInfo.cost * (3)^(checkedUnit.UnitInfo.level - 1) ) - math.floor( (2 + checkedUnit.UnitInfo.cost) / 4 )
						
						self.CopiedComponent:SetRuneStackInfo(addRuneStack)
						self:SetRuneStackInfo(addRuneStack)
					end
					
					-- 유닛 제거
					checkedUnit.UnitInfo.cost = 0
					_UnitSetLogic_New:SellUnit(user.OwnerId, checkedUnit)
					
					--연출
					_CustomizedBattleEffectService:PlayEffect("d1fd0a5ea7c54d88b3ca37bbb3312a9d", user.CurrentMap, checkTile.TransformComponent.WorldPosition:Clone(), 0, Vector3.one*0.8, false, user.PlayerComponent.UserId) -- 타이머돌지 않고 바로 재생
					
					local value = self.RuneStack
					_TimerService:SetTimerOnce(function() self:PlayEffect(value, false, "", "", user.PlayerComponent.UserId) end , 1.5)
					
					if isvalid(self.CopiedComponent) then
						_TimerService:SetTimerOnce(function() 
							---@type RC20007
							local copiedCompo = self.CopiedComponent
							copiedCompo:PlayEffect(value, false, "", "", user.PlayerComponent.UserId) 
						end , 1.5)
					end
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 스택 당 모든 유닛의 최대 체력이 15, 공격력과 마력이 2씩 상승합니다.
		-----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local units = {}
		local enemy = {}
		-----------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetHPAmount * self.RuneStack, -1)
				_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAmount * self.RuneStack, -1)
				_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAmount * self.RuneStack, -1)
				table.insert(units, unit)
			end
		else
			-- 스택 임의로 넣어줘야 함 (스테이지 비례)
			local setStage = gameManager.Stage - 1
			self:SetRuneStackInfo(_UtilLogic:RandomIntegerRange(setStage * 6, setStage * 6 + gameManager.Round * 2))
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				_StatusChangeLogic:GetBuff(unit, "Add_MaxHP", self.SetHPAmount * self.RuneStack, -1)
				_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", self.SetAmount * self.RuneStack, -1)
				_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", self.SetAmount * self.RuneStack, -1)
				table.insert(enemy, unit)
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		self:PlayEffect(self.RuneStack, true, units, enemy, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void PlayEffect(integer value, boolean Battle, string units, string enemy)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units) -- 준비단계일 때는 타일을, 전투단계일 때는 유닛을 받아옴
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		if value == 0 then return end
		
		if Battle == false then
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
			-- 발동 연출
			_RuneCardDirector:ShakingCard_Ready(index)
			_RuneCardDirector:IconToastDirector_Ready(index,0,"+"..tostring(math.floor(value)))
			
			-- 특수 연출
			_RuneCardDirector.RuneCardManagingValue["RC20007"][self.Entity.Id] = value
			_RuneCardDirector:CheckRuneCardManagingValue("RC20007", index)
			
		else
			--룬 카드 발동 연출
			if #units > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
				_RuneCardDirector:ShakingCard_Battle(index, false)
				_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.PhysicalAttack, _RuneCardDirectEnum.MagicalAttack}, 
																	{tostring(math.floor(self.SetHPAmount*value)), tostring(math.floor(self.SetAmount*value)), tostring(math.floor(self.SetAmount*value))},false)
			end
			
			if #enemy > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
				_RuneCardDirector:ShakingCard_Battle(index, true)
				_RuneCardDirector:IconToastDirector_Battle(index,{_RuneCardDirectEnum.MaxHP, _RuneCardDirectEnum.PhysicalAttack, _RuneCardDirectEnum.MagicalAttack},
																	{tostring(math.floor(self.SetHPAmount*value)), tostring(math.floor(self.SetAmount*value)), tostring(math.floor(self.SetAmount*value))}, true)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity,false)
		_RuneCardDirector.RuneCardManagingValue["RC20007"][self.Entity.Id] = stack
		_RuneCardDirector:CheckRuneCardManagingValue("RC20007", runeindex)
	end

end