@Component
script RC20011 extends RuneCardComponent

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 전투가 시작되면 모든 아군이 50%의 가해량을 얻습니다.
		--------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local units = {}
		local enemy = {}
		--------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", self.RuneStack, -1)
				table.insert(units,unit)
			end
		else
			-- 스택 지정해줘야 함
			self:SetRuneStackInfo(_UtilLogic:RandomIntegerRange(1, 10) * 5)
			
			for _, unit in pairs(teamManager.EnemyUnits) do
				_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", self.RuneStack, -1)
				table.insert(enemy,unit)
			end
		end
		
		units = _UtilLogic:TableToString(units)
		enemy = _UtilLogic:TableToString(enemy)
		local value = self.RuneStack
		self:PlayEffect(units, enemy, value, true, user.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void BuyThisRuneCard(string runeID)
		__base:BuyThisRuneCard(runeID)
		
		-- 전투가 시작되면 모든 아군이 50%의 가해량을 얻습니다.
		--------------------------------------------------------------
		self:SetRuneStackInfo(50)
	end

	@ExecSpace("Client")
	method void PlayEffect(string units, string enemy, integer value, boolean Battle)
		------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		units = _UtilLogic:StringToTable(units)
		enemy = _UtilLogic:StringToTable(enemy)
		------------------------------------------------------------
		if value < 0  then return end
		
		if Battle then
			--룬 카드 발동 연출
			if #units > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
				_RuneCardDirector:ShakingCard_Battle(index, false)
				_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.DealingDamageRate}, {tostring(math.floor(value)).."%"}, false)
			end
			
			if #enemy > 0 then
				local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, true)
				_RuneCardDirector:ShakingCard_Battle(index, true)
				_RuneCardDirector:IconToastDirector_Battle(index, {_RuneCardDirectEnum.DealingDamageRate}, {tostring(math.floor(value)).."%"}, true)
			end
		
		else
			local index = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
			--특수 연출
			_RuneCardDirector.RuneCardManagingValue["RC20011"][self.Entity.Id] = value / 50
			_RuneCardDirector:IconToastDirector_Ready(index, 0, "-5")
			_RuneCardDirector:CheckRuneCardManagingValue("RC20011", index)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void InGameDataLoadHandler(any event)
		__base:InGameDataLoadHandler(event)
		----------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		----------------------------------------------------------
		self:SetDirectorValue(self.RuneStack, user.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SetDirectorValue(number stack)
		--DB에서 값을 불러왔을 떄 연출용 값들을 세팅하는 함수입니다.
		local runeindex = _RuneCardDirector:GetRuneCardIndex(self.Entity, false)
		_RuneCardDirector.RuneCardManagingValue["RC20011"][self.Entity.Id] = stack / _RuneCardDirector.RuneCardMaxStack["RC20011"]
		_RuneCardDirector:CheckRuneCardManagingValue("RC20011", runeindex)
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		
		-- 단, 라운드가 진행 될 때마다 가해량이 5%씩 줄어듭니다.
		----------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		if self.SetTeamType == "User" then
			if self.RuneStack > 0 then
				self:SetRuneStackInfo(self.RuneStack - 5)
				local value = self.RuneStack
				self:PlayEffect("", "", value, false, user.PlayerComponent.UserId)
			end
		end
	end

end