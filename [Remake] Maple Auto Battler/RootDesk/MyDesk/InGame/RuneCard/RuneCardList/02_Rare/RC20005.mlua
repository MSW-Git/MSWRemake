@Component
script RC20005 extends RuneCardComponent

	property number CheckCount = 0

	@ExecSpace("ServerOnly")
	method void StartBattleHandler(any event)
		__base:StartBattleHandler(event)
		
		-- 라운드가 끝날 때마다, 대기석의 1, 2코스트 캐릭터 2마리당 1원을 받습니다.
		---------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		---------------------------------------------------------------------------
		if self.SetTeamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if not unit.UnitInfo:IsOnFieldUnit() then
					if unit.UnitInfo.cost == 1 or unit.UnitInfo.cost == 2 then
						self.CheckCount += 1
					end
				end
			end
			
			userPControl.Golds_BattleReward += math.floor(self.CheckCount/2)
			
			-- 라운드 결과창 룬카드/코치 연출용 함수
			_GeneralDirectorLogic:SetResultCoinTable(true, "RC20005", math.floor(self.CheckCount/2), user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	method void StartRoundHandler(any event)
		__base:StartRoundHandler(event)
		---------------------------------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		---------------------------------------------------------------------------
		userPControl.Golds_BattleReward -= math.floor(self.CheckCount/2)
		-- 라운드 결과창 룬카드/코치 연출용 함수
		_GeneralDirectorLogic:SetResultCoinTable(false, "RC20005", math.floor(self.CheckCount/2), user.PlayerComponent.UserId)
		
		self.CheckCount = 0
	end

end