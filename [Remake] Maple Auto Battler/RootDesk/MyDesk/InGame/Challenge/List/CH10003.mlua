@Component
script CH10003 extends ChallengeComponent

	@ExecSpace("ServerOnly")
	method void StartGameHandler(any event)
		__base:StartGameHandler(event)
		
		-- 판매 및 파괴 불가능한 '기억하고 있는 자' 룬카드 2장 보유
		-- 캐릭터 상점 새로고침 불가
		---------------------------------------------------------
		local user = self.Entity.Parent
		local specialShopManager = user.SpecialShopManager
		local runeParent = user:GetChildByName("RuneCardParent")
		local userPControl = user.TM_PropertyControl
		local runeID = "RC30001"
		----------------------------------------------------------------
		userPControl.Shop_CanRerollCharacter = false
		
		for set = 1, 2 do
			specialShopManager:GetRuneCard_Check(runeID)
		end
		
		
		for i=1, #runeParent.Children do
			local cardEntity = runeParent.Children[i]
			
			---@type RuneCardComponent
			local rcCompo = cardEntity:GetComponent(runeID)
			
			if isvalid(rcCompo) then
				rcCompo:SetIsDestructible(false)
			end
		end
	end

end