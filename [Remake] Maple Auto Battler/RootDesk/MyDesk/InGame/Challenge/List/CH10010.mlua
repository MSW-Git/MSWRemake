@Component
script CH10010 extends ChallengeComponent

	@ExecSpace("ServerOnly")
	method void StartGameHandler(any event)
		__base:StartGameHandler(event)
		
		-- 룬 카드 슬롯이 4칸 줄어듭니다.
		---------------------------------------------------------
		local user = self.Entity.Parent
		local userPControl = user.TM_PropertyControl
		----------------------------------------------------------------
		userPControl.Rune_UseRuneSlotCount -= 4
	end

end