					end
					skl_proj.SkillShotCheckComponent:SetOwnerID(userId)
					skl_proj:SetEnable(false)
				else
					_UserService:GetUserEntityByUserId(userId).LoadingManager.LoadedCount["ProjectileSampleSpawn"] = 1
					break
				end
				projSetCount += 1
			end
			
		end
		_TimerService:SetTimerOnce(projSampleSpawnFnc, 0.01)]]
		
		local projSetCount = 0
		local projSetTimer = 0
		local user = _UserService:GetUserEntityByUserId(userId)
		local function projSampleSpawnFnc()
			projSetCount += 1
