@Logic
script UnitSetLogic_New extends Logic

	property Entity ArenaMap = "62628397-c22b-4657-876e-e8ddede416f3"

	property Entity UnitsSample = "9342d2fe-6d94-46d5-8942-219aaf25eb00"

	property Entity ProjectilesSample = "77203f00-2b9b-4f14-bca4-cb0a5e14b4c4"

	property SyncTable<string, Entity> UnitsParentEntity

	property SyncTable<string, Entity> ProjectilesParentEntity

	property SyncTable<string, Entity> RoomTile

	property Entity DragSample = "a7814a29-0745-436c-85b1-309bf0d3b2e9"

	property Entity SelectUnit = nil

	property Entity SelectTile = nil

	property any Handler = nil

	property integer UnitSampleDestroyTimerID = 0

	property integer ProjectileSampleDestroyTimerID = 0

	@ExecSpace("Server")
	method void SettingTile(Entity currentMap)
		-- 맵의 모든 타일에 컴포넌트를 초기화하고 설정하는 함수
		local user = _UserService:GetUserEntityByUserId(senderUserId)
		
		for i = 1, 7 do
			local tileLine = currentMap:GetChildByName("Line_" .. math.floor(i))
			local jMax = 8 + (i%2)
		
			for j = 1, jMax do
				local tile = tileLine:GetChildByName("Tile_" .. math.floor(j))
		
				local jNum = j * 2 - (i%2)
				--self.RoomTile[math.floor(jNum) .. "," .. math.floor(i)] = tile
				user.GameManager.RoomTile[math.floor(jNum) .. "," .. math.floor(i)] = tile
				-- 중립인 경우
				if jMax == 9 and j == 5 then
					tile.TileComponent_New:TileSet("Neutral", "Unit", j, i)
				elseif j <= 4 then
					tile.TileComponent_New:TileSet("User", "Unit", j, i)
				elseif j >= 5 then
					tile.TileComponent_New:TileSet("Enemy", "Unit", j, i)
				end
			end
		end
		
		local waitingTileLine = currentMap:GetChildByName("WaitLine")
		for i = 1, 9 do
			local tile = waitingTileLine:GetChildByName("Tile_" .. math.floor(i))
			user.GameManager.RoomTile[math.floor(i) .. ",0"] = tile
			tile.TileComponent_New:TileSet("Waiting", "Unit", i, 0)
		end
		
	end

	@ExecSpace("Client")
	method void DragUnit(Entity selectUnit, string selectUnitID)
		-- Unit Info
		local unitInfoDBrow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", selectUnitID)
		
		
		if isvalid(self.SelectUnit) then
			return	-- 무언가를 잡은 중에는 새로 잡기 불가
		else
			self.SelectUnit = selectUnit
		end
		
		selectUnit.Visible = false
		--self.DragSample.SpriteRendererComponent.SpriteRUID = unitInfoDBrow:GetItem("IdleRUID")
		
		if isvalid(self.DragSample) == false then
			self.DragSample = _UserService.LocalPlayer.CurrentMap:GetChildByName("DragSample") --_EntityService:GetEntityByPath("/maps/Arena/DragSample")
		end
		self.DragSample.SpriteRendererComponent.SpriteRUID = selectUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.SpriteRUID
		self.DragSample.SpriteRendererComponent.FlipX = selectUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		self.DragSample.TransformComponent.Scale = selectUnit.UnitInfo.spriteRenderer.TransformComponent.Scale
		--log("DragUnit: " .. selectUnitID)
		
		-- drag Move
		self.Handler = _InputService:ConnectEvent(ScreenTouchHoldEvent, self.Drag)
		
	end

	@ExecSpace("ClientOnly")
	method void Drag(any screenholdEvent)
		-- 유닛 드래그 중 화면 터치 이벤트를 처리하는 함수
		if isvalid(self.SelectUnit) then
			local touchId = screenholdEvent.TouchId
			local touchPoint = screenholdEvent.TouchPoint
			
			if isvalid(self.DragSample) == false then
				self.DragSample = _UserService.LocalPlayer.CurrentMap:GetChildByName("DragSample") --_EntityService:GetEntityByPath("/maps/Arena/DragSample")
			end
			
			self.DragSample.TransformComponent.WorldPosition = _UILogic:ScreenToWorldPosition(touchPoint):ToVector3()
			
			if not self.DragSample.Visible then
				self.DragSample.Visible = true
			end
		end
	end

	@ExecSpace("Client")
	method void DragOff(Entity selectUnit)
		_InputService:DisconnectEvent(ScreenTouchHoldEvent, self.Handler)
		self.Handler = nil
		
		if isvalid(selectUnit) == true then
			selectUnit.Visible = true
		end
		if isvalid(self.DragSample) == false then
			self.DragSample = _UserService.LocalPlayer.CurrentMap:GetChildByName("DragSample") --_EntityService:GetEntityByPath("/maps/Arena/DragSample")
		end
		
		self.DragSample.Visible = false
		self.SelectUnit = nil
		
		self.SelectTile = nil
		_UserService.LocalPlayer.CharacterShopManager_New:UI_ShowSellUI(true, 0)
		_UserService.LocalPlayer.CharacterShopManager_New:UI_ShowSellUI(false, 0)
		
		--타일 표시 삭제
		_GeneralDirectorLogic:SetTileDirection_Main("OnDragging",false)
		
		--유닛 놓을 연출
		_GeneralDirectorLogic:UnitOnTileDirector(selectUnit,true)
		
		--전장 유닛 초과표시 체크
		_GeneralDirectorLogic:ShowRedTile(_UserService.LocalPlayer.PlayerComponent.UserId)
		
	end

	@ExecSpace("Server")
	method void TouchRelease(string userID, Entity selectUnit, Entity selectTile)
		-- selectUnit을 selectTile로 옮기는 함수입니다.
		--------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local synergyManager = user.SynergyManager_New
		
		local function timer()
			if isvalid(selectUnit) then
				if isvalid(selectTile) then
					
					-- 예외 처리 1) 움직일 수 없는 유닛인 경우
					if selectUnit.UnitInfo.IsMovableByPlayer == false then
						log_warning("이 유닛은 대기석에 배치할 수 없습니다.")
						self:DragOff(selectUnit, userID)
						return
					end
					--------------------------------------------------------------------------------
					-- 예외 처리 2) 준비 단계가 아닌 경우
					if gameManager.PhaseType ~= "Ready" then
						_UIToast:ShowMessageByLocalizingKey("CannotDragUnit", userID)
						self:DragOff(selectUnit, userID)
						return
					end
					--------------------------------------------------------------------------------
					local onUnit = teamManager.EntityOnTile[selectTile]
					local setTile = selectUnit.UnitInfo.setTile
					--------------------------------------------------------------------------------
					-- 추가 예외 처리 _ setTile이 없는 경우
					-- a. 합쳐질 때 타이밍 맞춰 드래그 하면 버그가 있음
					if not isvalid(setTile) then
						self:DragOff(selectUnit, userID)
						log_warning("SetTile이 없대요")
						return
					end
					--------------------------------------------------------------------------------
					-- 예외 처리 3) 대기석에 놓을 수 없는 유닛을 대기석에 놓으려고 한 경우			 
					if selectUnit.UnitInfo.IsSettableOnWatingField == false then
						if selectTile.TileComponent_New.horizontalNum == 0 or selectTile.TileComponent_New.verticalNum == 0 then
							log_warning("이 유닛은 대기석에 배치할 수 없습니다.")
							self:DragOff(selectUnit, userID)
							return
						end
					end
					--------------------------------------------------------------------------------
					-- 예외 처리 4) 사용할 수 있는 대기석의 수를 제한한 상태에서 해당 대기석에 놓으려고 하는 경우
					if selectTile.TileComponent_New.verticalNum == 0 then
						-- 4.1. 사용 가능한 대기석 숫자보다 많은 인원 배치
						local UnitAmount = 0
						-- 현재 대기석에 있는 유닛 수 체크
						for i = 1, userPControl.Tile_AvailableWaitingTile do
							local checkTile = gameManager.RoomTile[math.floor(i) .. ",0"]
							if isvalid(teamManager.EntityOnTile[checkTile]) then
								UnitAmount += 1
								break
							end
						end
						if UnitAmount >= userPControl.Tile_AvailableWaitingTile then
							log_warning("대기석이 가득 찼습니다.")
							self:DragOff(selectUnit, userID)
							return
						end 
						
						-- 4.2. 막힌 대기석에 배치
						if selectTile.TileComponent_New.horizontalNum > userPControl.Tile_AvailableWaitingTile then
							self:DragOff(selectUnit, userID)
							return
						end
					end
					-- 예외 처리 5) 튜토리얼 진행 중일 때, 현재 튜토리얼에서 지정한 타일이 아닐 경우
					if gameManager.ModeType == "Tutorial" then
						if user.TutorialManager_New.AllowPlaceAllTile == false then
							if user.TutorialManager_New.CurrentTargetTile == nil then
							elseif selectTile ~= user.TutorialManager_New.CurrentTargetTile then
								_UIToast:ShowMessageByLocalizingKey("Toast_TargetTileError",userID)
								self:DragOff(selectUnit, userID)
								return
							end
						end
					end
					
					--------------------------------------------------------------------------------
					-- 온필드 유닛 수 체크
					local maxCount = teamManager.Level + user.TM_PropertyControl.Level_MaxUnitAdjustment
					local spawnCheck = true
					
					local setTileVerticalNum = setTile.TileComponent_New.verticalNum
					local selectTileVerticalNum = selectTile.TileComponent_New.verticalNum
					
					
					-- 온필드 유닛 / 오프필드 유닛 체크
					if (setTileVerticalNum == 0) ~= (selectTileVerticalNum == 0) then -- 둘 중 하나는 대기석, 하나는 필드인 경우
						-- 해당 타일에 이미 위치한 유닛이 있다면
						if isvalid(onUnit) then
							-- 예외 처리 2) 위치를 교환하려는 유닛을 대기석으로 넣으려고 한 경우
							if onUnit.UnitInfo.IsSettableOnWatingField == false then
								log_warning("대상 유닛은 대기석에 배치할 수 없습니다.")
								self:DragOff(selectUnit, userID)
								return
							end
							
							if setTileVerticalNum > 0 then	-- 대상 타일이 전장이라면
								self:OnFieldSet(teamManager, onUnit, true, true, true)
								self:OnFieldSet(teamManager, selectUnit, false, true, true)
								
								
							else							-- 대상 타일이 대기석이라면
								self:OnFieldSet(teamManager, onUnit, false, true, true)
								self:OnFieldSet(teamManager, selectUnit, true, true, true)
							end
							
						-- 유닛이 없는 타일에 놓으려고 했다면
						else
							-- 필드에 놓으려고 한 경우
							if selectTileVerticalNum > 0 then
								if maxCount <= teamManager.OnFieldUnitCount then
									spawnCheck = false
								else
									self:OnFieldSet(teamManager, selectUnit, true, true, true)
								end
							-- 대기석에 놓으려고 한 경우
							else
								self:OnFieldSet(teamManager, selectUnit, false, true, true)
							end
						end
					end
					
					
					-- 이동이 가능하다면
					if spawnCheck then
						if isvalid(onUnit) then
							-- 기존 유닛 이동
							local onUnitInfo = onUnit.UnitInfo
							onUnitInfo:SetPropertyToServer("setTile", setTile, "All", true)
								
							if setTile.TileComponent_New.Zone == "Enemy" then
								onUnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = false
							else
								onUnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = true
							end
		
							onUnit.UnitAnimationComponent:SetLayerOrder(setTileVerticalNum, userID)
							
							
							-- 예외 처리 (오르비스 마법석인 경우, 연출을 위함)
							if string.sub(onUnit.Name, 1, -2) == "BTUnit_OrbisStone" then
								
								local aroundCount = 1
								if 0 < synergyManager.SynergyRuneOn["S10021"] then
									aroundCount += synergyManager.SynergyRuneOn["S10021"]
								end
								local tiles = _BTLogic_New:getTiles(onUnit, onUnit.UnitInfo.setTile, nil, string.format("Around_%d", aroundCount) )
								_SynergyReadyDirectorLogic:Set10021TilesEffect(
									onUnit.Id, _UtilLogic:TableToString(tiles),	userID)
							end
						end
						
						-- 유닛 이동 및 이동한 타일 정보 변경
						local selectUnitInfo = selectUnit.UnitInfo
						selectUnitInfo:SetPropertyToServer("setTile", selectTile, "All", true)
					
						if selectTile.TileComponent_New.Zone == "Enemy" then
							selectUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = false
						else
							selectUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = true
						end
						
						-- 레이어 설정
						selectUnit.UnitAnimationComponent:SetLayerOrder(selectTileVerticalNum, userID)
						
						
						
						-- 예외 처리 (오르비스 마법석인 경우, 연출을 위함)
						if string.sub(selectUnit.Name, 1, -2) == "BTUnit_OrbisStone" then
							local aroundCount = 1
							if 0 < synergyManager.SynergyRuneOn["S10021"] then
								aroundCount += synergyManager.SynergyRuneOn["S10021"]
							end
							local tiles = _BTLogic_New:getTiles(selectUnit, selectUnit.UnitInfo.setTile, nil, string.format("Around_%d", math.floor(aroundCount) ) )
							
							_SynergyReadyDirectorLogic:Set10021TilesEffect(
								selectUnit.Id, _UtilLogic:TableToString(tiles),	userID)
						end
						
						-- 대기석에 놓은 경우
						if selectTileVerticalNum == 0 then -- 잡은 유닛을 대기석에 놓는 경우
							user.SynergyManager_New:S10011_WithdrawItem(selectUnit)
						elseif (isvalid(onUnit) == true and setTileVerticalNum == 0) then -- 위치 교환 대상이 대기석에 들어가야 하는 경우
							user.SynergyManager_New:S10011_WithdrawItem(onUnit)
						end
					end
				end
				self:DragOff(selectUnit, userID)
			end
		end
			
		_TimerService:SetTimerOnce(timer, 0.05)
	end

	@ExecSpace("Server")
	method void TouchReleaseByForce(string userID, Entity selectUnit, Entity selectTile)
		-- selectUnit을 selectTile로 옮기는 함수입니다.
		--------------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userID)
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local synergyManager = user.SynergyManager_New
		
		local function timer()
			if isvalid(selectUnit) then
				if isvalid(selectTile) then
					local onUnit = teamManager.EntityOnTile[selectTile]
					local setTile = selectUnit.UnitInfo.setTile
					--------------------------------------------------------------------------------
					-- 온필드 유닛 수 체크
					local maxCount = teamManager.Level + user.TM_PropertyControl.Level_MaxUnitAdjustment
					
					local setTileVerticalNum = setTile.TileComponent_New.verticalNum
					local selectTileVerticalNum = selectTile.TileComponent_New.verticalNum
					
					
					-- 온필드 유닛 / 오프필드 유닛 체크
					if (setTileVerticalNum == 0) ~= (selectTileVerticalNum == 0) then -- 둘 중 하나는 대기석, 하나는 필드인 경우
						-- 해당 타일에 이미 위치한 유닛이 있다면
						if isvalid(onUnit) then
							if setTileVerticalNum > 0 then	-- 대상 타일이 전장이라면
								self:OnFieldSet(teamManager, onUnit, true, onUnit.UnitInfo.IsSettableOnWatingField, true)
								self:OnFieldSet(teamManager, selectUnit, false, selectUnit.UnitInfo.IsSettableOnWatingField, true)
							else							-- 대상 타일이 대기석이라면
								self:OnFieldSet(teamManager, onUnit, false, onUnit.UnitInfo.IsSettableOnWatingField, true)
								self:OnFieldSet(teamManager, selectUnit, true, selectUnit.UnitInfo.IsSettableOnWatingField, true)
							end
						-- 유닛이 없는 타일에 놓으려고 했다면
						else
							-- 필드에 놓으려고 한 경우
							if selectTileVerticalNum > 0 then
								self:OnFieldSet(teamManager, selectUnit, true, selectUnit.UnitInfo.IsSettableOnWatingField, true)
							-- 대기석에 놓으려고 한 경우
							else
								self:OnFieldSet(teamManager, selectUnit, false, selectUnit.UnitInfo.IsSettableOnWatingField, true)
							end
						end
					end
					
					
					-- 이동이 가능하다면
					if isvalid(onUnit) then
						-- 기존 유닛 이동
						local onUnitInfo = onUnit.UnitInfo
						
						if not onUnitInfo.IsSettableOnWatingField and setTileVerticalNum == 0 then
							setTile = _BTLogic_New:getTile(onUnit, nil, "EmptyTileNearestToTheUnit_Team")[1]
							setTileVerticalNum = setTile.TileComponent_New.verticalNum
						end
						
						onUnitInfo:SetPropertyToServer("setTile", setTile, "All", true)
							
						if setTile.TileComponent_New.Zone == "Enemy" then
							onUnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = false
						else
							onUnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = true
						end
						
						onUnit.UnitAnimationComponent:SetLayerOrder(setTileVerticalNum, userID)
						
											
		
						-- 예외 처리 (오르비스 마법석인 경우, 연출을 위함)
						if string.sub(onUnit.Name, 1, -2) == "BTUnit_OrbisStone" then
							
							local aroundCount = 1
							if 0 < synergyManager.SynergyRuneOn["S10021"] then
								aroundCount += synergyManager.SynergyRuneOn["S10021"]
							end
							local tiles = _BTLogic_New:getTiles(onUnit, onUnit.UnitInfo.setTile, nil, string.format("Around_%d", aroundCount) )
							_SynergyReadyDirectorLogic:Set10021TilesEffect(
								onUnit.Id, _UtilLogic:TableToString(tiles),	userID)
						end
					end
					
					-- 유닛 이동 및 이동한 타일 정보 변경
					local selectUnitInfo = selectUnit.UnitInfo
					selectUnitInfo:SetPropertyToServer("setTile", selectTile, "All", true)
				
					if selectTile.TileComponent_New.Zone == "Enemy" then
						selectUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = false
					else
						selectUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = true
					end
					
					-- 레이어 설정
					selectUnit.UnitAnimationComponent:SetLayerOrder(selectTileVerticalNum, userID)
					-- 애니메이션 설정
					selectUnit.UnitAnimationComponent:PlayAnimation(1, "ForcedIdle", selectUnit.Parent, userID)
					
					-- 예외 처리 (오르비스 마법석인 경우, 연출을 위함)
					if string.sub(selectUnit.Name, 1, -2) == "BTUnit_OrbisStone" then
						local aroundCount = 1
						if 0 < synergyManager.SynergyRuneOn["S10021"] then
							aroundCount += synergyManager.SynergyRuneOn["S10021"]
						end
						local tiles = _BTLogic_New:getTiles(selectUnit, selectUnit.UnitInfo.setTile, nil, string.format("Around_%d", math.floor(aroundCount) ) )
						
						_SynergyReadyDirectorLogic:Set10021TilesEffect(
							selectUnit.Id, _UtilLogic:TableToString(tiles),	userID)
					end
				end
			end
		end
			
		_TimerService:SetTimerOnce(timer, 0.05)
	end

	@ExecSpace("Server")
	method Entity SpawnUnit(string userId, string unitID, number unitLevel, string spawnType)
		-- 새로운 유닛을 획득(구매, 이벤트 라운드 보상 등)하는 함수입니다.
		-- log(unitID, "의 스폰 정보", unitLevel, ", ", spawnType)
		-- 구매에 성공한 경우 true, 실패한 경우 false를 return 합니다.
		--------------------------------------------------------
		--[[ 
		1. 대기석에 자리가 있는가?
			1-1. 자리가 있다면, 해당 위치에 소환합니다. 소환 후 merge 관련 처리를 합니다.
			1-2. 자리가 없다면 :
				1-2-1. spawnType이 "Force"인 경우 : 필드 내 적절한 위치에 소환합니다. 소환 후 merge 관련 처리를 합니다.
				1-2-2. spawnType이 "Shop"인 경우 : 같은 ID와 레벨을 가진 유닛을 이미 2마리 가지고 있는지 검사합니다.
					1-2-2-1. 2마리 보유 --> field에 임시 소환
					1-2-2-2. 1마리 보유 --> 상점 내 같은 ID를 가진 유닛 조건을 검사합니다.
						+ 해당 유닛까지 구매할 돈을 갖고 있는지 검사합니다.
						--> 있다면, 둘 다 구매한 것으로 처리 + 둘 다 field에 임시 소환
						--> 없다면 return false
					1-2-2-3. 없다면 return false (구매 불가)
				1-2-3. spawnType이 "Sack"인 경우  : 같은 ID와 레벨을 가진 유닛을 이미 2마리 가지고 있는지 검사합니다.
					1-2-3-1. 2마리 보유 --> field에 임시 소환 후 merge, 아이템 소모 체크용 빈 깡통 유닛을 리턴 
					1-2-3-2. 1마리 보유 --> 소환 불가 return false
					
		2. 소환 처리 (skip 가능)
		3. merge 처리
		]]
		--------------------------------------------------------
		local setId = unitID .. math.floor(unitLevel)
		local userEntity = _UserService:GetUserEntityByUserId(userId) 
		local teamManager = userEntity.TeamManager
		local userPControl = userEntity.TM_PropertyControl
		local charInfoDB = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitID)
		local cost = math.floor(tonumber(charInfoDB:GetItem("Cost")))
		local shopIdx = 0
		local spawnType_split = _UtilLogic:Split(spawnType, "_")
		if spawnType_split[1] == "Shop" then
			shopIdx = tonumber(spawnType_split[2])
			spawnType = "Shop"
		end
		--------------------------------------------------------
		---@type Entity
		local setTile = nil -- 유닛을 소환하는 경우, 소환될 위치에 있는 타일 엔티티
		local isAutoBuying = false
		--------------------------------------------------------
		-- 1-1. 대기석에 자리가 있는 경우
		if spawnType ~= "OnField" then
			-- 일반적인 SpawnType
			local waitingTileLine = userEntity.CurrentMap:GetChildByName("WaitLine")
			local unitCount = 0
			for i = 1, 9 do
				local tile = waitingTileLine:GetChildByName("Tile_" .. math.floor(i))
				if isvalid(teamManager.EntityOnTile[tile]) then
					unitCount += 1
				end
			end
			if unitCount < userPControl.Tile_AvailableWaitingTile then
				for i = 1, userPControl.Tile_AvailableWaitingTile do
					local tile = waitingTileLine:GetChildByName("Tile_" .. math.floor(i))
					if isvalid(teamManager.EntityOnTile[tile]) == false then
						setTile = tile
						break
					end
				end
			end
		else
			-- OnField SpawnType
			for j = 1, 4 do
				for i = 1, 7 do
					local tileLine = userEntity.CurrentMap:GetChildByName("Line_" .. math.floor(i))
					local tile = tileLine:GetChildByName("Tile_" .. math.floor(j))
					if isvalid(teamManager.EntityOnTile[tile]) == false then
						setTile = tile
						break
					end
				end
				if isvalid(setTile) == true then
					break
				end
			end
		end
		--------------------------------------------------------
		
		
		-- 1-2. 대기석에 자리가 없는 경우
		if isvalid(setTile) == false then
			-- 1-2-1. 강제 소환(이벤트 라운드 등)인 경우, 필드에 소환합니다.
			if spawnType == "Force" or spawnType == "DataLoad" then
				-- 필드 중 소환될 위치를 체크합니다.
				for j = 1, 4 do
					for i = 7, 1, -1 do
						local tileLine = userEntity.CurrentMap:GetChildByName("Line_" .. math.floor(i))
						local tile = tileLine:GetChildByName("Tile_" .. math.floor(j))
						if isvalid(teamManager.EntityOnTile[tile]) == false then
							setTile = tile
							break
						end
					end
					if isvalid(setTile) == true then
						break
					end
				end
				
				-- 필드에 소환될 위치가 없다면 소환 실패로 처리합니다.
				if isvalid(setTile) == false then
					log("강제 소환에서 소환할 필드 위치가 없습니다.")
					return nil
				end
			--------------------------------------------------------	
			-- 1-2-2. 상점 구매인 경우
			elseif spawnType == "Shop" then
				-- 같은 ID와 레벨을 가진 유닛을 이미 2마리 가지고 있는지 검사합니다.
				local tileUnitCount = 0
				
				local setID = unitID..string.format("%d", unitLevel) 
				--teamManager.OwnUnitsBySetID[setId]
				
				local ownUnits = teamManager.OwnUnits 
				for i=1, #ownUnits do
					local unitInfo = ownUnits[i].UnitInfo
					if unitInfo.charID == unitID and unitInfo.level == unitLevel then
						tileUnitCount += 1
					end
					
					if tileUnitCount >= 2 then
		
						break
					end
				end
				
				-- (1) 2마리 있는 경우 --> 소환 없이 merge
				if tileUnitCount == 2 then
					-- log("tileUnitCount == 2")
				-- (2) 1마리 있는 경우 --> 상점에 동일 캐릭터가 있다면 자동 구매
				elseif tileUnitCount == 1 then
					local shopManager = teamManager.Entity.CharacterShopManager_New
					local shopUnitCount = 0
					
					local pairUnitIdxInShop = 0
					for i=1, #shopManager.CurrentDisplayedUnits do
						if i ~= shopIdx and shopManager.CurrentDisplayedUnits[i] == unitID then
							pairUnitIdxInShop = i
							break
						end 
					end
					
					-- 상점에 1마리 더 없다면, 구매할 수 없는 것으로 보고 종료
					if pairUnitIdxInShop == 0 then 
						log("상점 특수조건에서 상점 내 수량이 2개 미만")
						return nil
						
					else
						-- 보유 골드 조건을 체크 --> 충분한 경우 자동 구매
						if cost*2 > teamManager.Golds then
							log("상점 특수조건에서 골드 부족")
							return nil
						--
						else
							shopManager:BuyCharacter_Forced(pairUnitIdxInShop)
							isAutoBuying = true
						end
					end
		
					
				-- (3) 없는 경우 --> 구매 실패
				elseif tileUnitCount == 0 then
					return nil
				end
			--------------------------------------------------------	
			-- 1-2-3. 보따리 사용인 경우
			elseif spawnType == "Sack" then
				log_warning("Sack")
				-- 같은 ID와 레벨을 가진 유닛을 이미 2마리 가지고 있는지 검사합니다.
				local tileUnitCount = 0
				
				local setID = unitID..string.format("%d", unitLevel) 
				
				local ownUnits = teamManager.OwnUnits 
				for i=1, #ownUnits do
					local unitInfo = ownUnits[i].UnitInfo
					if unitInfo.charID == unitID and unitInfo.level == unitLevel then
						tileUnitCount += 1
					end
					if tileUnitCount >= 2 then
						break
					end
				end
				
				-- 둘 이하인 경우, 소환 실패로 처리 
				if tileUnitCount < 2 then
					return nil
				end
			else
				log("spawnType 에러")
				return nil
			end
		end
		--------------------------------------------------------
		
		
		-- 2단계. 유닛을 소환합니다. (실제로는 풀링하고 있으므로, 엔티티 활성화 및 프로퍼티를 변경)
		---@type Entity
		local unit = nil
		
		local spawnUnit = function()
			local units = self.UnitsParentEntity[userId]
			
			-- 2-1. 소환한 유닛을 적절한 타일에 배치합니다.
			if isvalid(setTile) then
				unit = self:GetEmptyPooledUnit(userId, "User") -- 풀링된 엔티티 중 하나를 가져옴
				local unitInfo = unit.UnitInfo
		
				-- 기본 변수 초기화
				unit.UnitInfo.use = true
				table.insert(teamManager.OwnUnits, unit)
				-- unit.UnitBattleStatistics:RoundPropertyInitialize(unitID)
				
				-- 필드에만 존재해야 하는 경우 (룬카드로 소환)
				if spawnType == "OnField" then
					unit.UnitInfo.IsResellable = false				-- 재판매 가능 여부
					unit.UnitInfo.IsOnetimeUnit = false				-- 1회성 유닛(소환된 유닛)인가
					unit.UnitInfo.IsMergableUnit = false			-- 머지 가능 여부
					unit.UnitInfo:SetPropertyToServer("IsItemEquippable", false, "", true)	-- 아이템 장착 가능 여부
					unit.UnitInfo.IsAppliableSynergy = false		-- 시너지 효과 적용 가능 여부
					unit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", false, "", true)	-- 대기석에 배치 가능 여부
					
					unit.UnitInfo.IsMovableByPlayer = true			-- 플레이어에 의해 배치 변경 가능 여부
					
				-- 일반적인 유닛
				else
					unit.UnitInfo.IsResellable = true
					unit.UnitInfo.IsOnetimeUnit = false
					unit.UnitInfo.IsMergableUnit = true
					unit.UnitInfo:SetPropertyToServer("IsItemEquippable", true, "", true)
					unit.UnitInfo.IsMovableByPlayer = true
					unit.UnitInfo.IsAppliableSynergy = true
					unit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", true, "", true)
				end
				
				-- 유닛 스테이터스 세팅
				unit.UnitInfo:SetCharInfo(unitID, unitLevel, cost)
				-- unit.UnitStatus:SetUnitStatus(false)
				
				-- 소환 위치 설정
				local verticalNum = setTile.TileComponent_New.verticalNum
				local horizontalNum = setTile.TileComponent_New.horizontalNum
				unitInfo:SetPropertyToServer("setTile", setTile, "All", true)
				if verticalNum > 0 then
					self:OnFieldSet(teamManager, unit, true, (spawnType ~= "OnField"), true)
				end
				
				unit.UnitAnimationComponent:SetLayerOrder(verticalNum, userId)
				unit.UnitAnimationComponent:PlayAnimation(1, "ForcedIdle", unit.Parent, userId)
				
			-- 2-2. 대기석은 없지만 합체가 가능해서 소환된 경우
			else 
				unit = self:GetEmptyPooledUnit(userId, "User")
				-- 소환은 하지 않습니다.
				-- 아무 정보도 없는 깡통 유닛을 리턴해, nil이 리턴되지 않게 합니다.
			end
			
			-- 유닛 수 체크
			if spawnType ~= "OnField" then
				if isvalid(teamManager.OwnUnitsBySetID[setId]) then
					teamManager.OwnUnitsBySetID[setId] += 1
				else
					teamManager.OwnUnitsBySetID[setId] = 1
				end
			end
			
			if spawnType ~= "DataLoad" then
				if isvalid(userEntity.CharacterShopManager_New.LeftUnitCount[unitID]) == true then
					userEntity.CharacterShopManager_New.LeftUnitCount[unitID] -= 1
					-- log(string.format("%s's Left Count is %d", unitID, userEntity.CharacterShopManager_New.LeftUnitCount[unitID])) 
				end
			end
			
			--유닛 소환 이펙트
			_GeneralDirectorLogic:UnitOnTileDirector(unit,false,userId)
		
		end
		
		spawnUnit()
		
		if isAutoBuying == true then
			spawnUnit() -- 자동 구매인 경우 구매를 두 번 수행
		end
		--------------------------------------------------------
		
		--------------------------------------------------------
		-- 3단계. 캐릭터 구매 이벤트 처리
		if spawnType == "Shop" then
			userEntity:SendEvent(BuyUnit(unit, unitID))	-- 에러 아님
		end
		
		
		-- 3단계. 캐릭터 Merge를 수행합니다.
		-- 레벨업 필요 체크
		local checkUnitMerge = function()
			self:CheckUnitMerging(userId)
		end
		_TimerService:SetTimerOnce(checkUnitMerge, 0.2)
		
		return unit
		
	end

	@ExecSpace("ServerOnly")
	method Entity SpawnOnetimeUnit(string userId, string unitID, Entity summonTile, number unitLevel, string teamType, boolean isApplyingSynergy)
		-- 해당 전투에만 참여하는 일회성 유닛을 소환합니다.
		-- teamType : "User" or "Enemy"
		------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local teamManager = user.TeamManager
		
		---@type Entity
		local summonedUnit = self:GetEmptyPooledUnit(userId, teamType) -- 풀링된 엔티티 중 하나를 고릅니다.
		
		local unitInfo = summonedUnit.UnitInfo
		if teamType == "User" then
			table.insert(teamManager.OwnUnits, summonedUnit)
			user.GameManager.MyUnitCount += 1
		elseif teamType == "Enemy" then
			table.insert(teamManager.EnemyUnits, summonedUnit)
			user.GameManager.EnemyCount += 1
		end
		
		_CustomizedBattleEffectService:SetEntityVisible(summonedUnit, true, userId)
		-- summonedUnit.UnitBattleStatistics:RoundPropertyInitialize(unitID)
		
		-- 소환될 타일
		local verticalNum = summonTile.TileComponent_New.verticalNum
		local horizontalNum = summonTile.TileComponent_New.horizontalNum
		
		-- 기본값 설정 및 예외 처리
		unitInfo:SetPropertyToServer("setTile", summonTile, "All", true)
		unitInfo.IsOnetimeUnit = true
		unitInfo.use = true
		unitInfo.IsAppliableSynergy = isApplyingSynergy
		
		-- 레이어 설정
		summonedUnit.UnitAnimationComponent:SetLayerOrder(verticalNum, userId)
		
		-- 유닛 스테이터스 세팅
		summonedUnit.UnitInfo:SetCharInfo(unitID, unitLevel, 0)
		
		if user.GameManager.PhaseType == "Battle" or user.GameManager.PhaseType == "Setting" then
			summonedUnit.UnitAIWanderComponent.Enable = true
			
			-- 팀 정보에 추가
			user.GameManager:RefreshUI_TeamHPInfo(teamType, true, summonedUnit.UnitStatus.MaxHP, userId)
			user.GameManager:RefreshUI_TeamHPInfo(teamType, false, summonedUnit.UnitStatus.MaxHP, userId)
			--log("일회성 유닛 소환하여 팀 체력 추가: ", teamType, summonedUnit.UnitStatus.MaxHP)
		end
		summonedUnit.UnitStatus.Target = nil
		------------------------------------------------------------------
		return summonedUnit
	end

	@ExecSpace("Server")
	method void OnFieldSet(TeamManager teamManager, Entity unit, boolean on, boolean countCheck, boolean emblemItemCheck)
		local charID = unit.UnitInfo.charID
		
		local sendOnFieldSynergyCountChangedEvent = function(synergyID, count)
			teamManager.Entity:SendEvent(OnFieldSynergyCountChanged("User", synergyID, teamManager.OnFieldSynergy[synergyID]))	-- 에러 아님
		end
		
		if isvalid(teamManager) then
			-- log("OnFieldSet")
			local charSynergyDBRow = _DataService:GetTable("CharacterSynergy"):FindRow("CharID", charID)
			
			log("OnFieldSet", on)
			-- 유닛이 필드에 올라온 경우
			if on then
				if countCheck then
					teamManager.OnFieldUnitCount += 1
				end
				
				teamManager.Entity.SynergyManager_New:OnFieldUnitCountChanged()
				
				-- 중복 체크
				
				if isvalid(teamManager.OnFieldUnitIDs[charID]) then
					teamManager.OnFieldUnitIDs[charID] += 1
				else
					teamManager.OnFieldUnitIDs[charID] = 1
					
					-- 시너지 On
					for i = 1, 3 do
						local synergyID = charSynergyDBRow:GetItem("Synergy_" .. math.floor(i))
						if synergyID ~= "" then
							teamManager:GetOnFieldSynergyCount(synergyID, 1)
							log("charID = ", charID, ", synID + = ", synergyID)
						end
					end
				end
				
				-- 상징을 장착한 경우
				if emblemItemCheck == true then
					local equippedItems = unit.UnitStatus.EquippedItemIDList
					for i=1, #equippedItems do
						local itemID = _UtilLogic:Split(equippedItems[i], "_")[1]
						local keyHead = string.sub(itemID, 1, 2)
						local keyTail = string.sub(itemID, 3, -1)
						if keyHead == "EI" then
							local synergyID = "S"..keyTail
							
							-- 예외처리: 동일한 id를 가진 캐릭터가 전장에 있고, 해당 캐릭터가 동일한 상징을 장착한 경우
							local hasSameCharWithSameEmblem = false
							local ownUnits = teamManager.OwnUnits
							for _, unitToCompare in pairs(ownUnits) do
								if unitToCompare ~= unit and unitToCompare.UnitInfo:IsOnFieldUnit() then	-- 전장 위 유닛이고
									if unitToCompare.UnitInfo.charID == charID then	-- 동일한 캐릭터이며
										local itemListToCompare = unitToCompare.UnitStatus.EquippedItemIDList
										for _, equippedItemIDtoCompare in pairs(itemListToCompare) do
											local itemIDtoCompare = _UtilLogic:Split(equippedItemIDtoCompare, "_")[1]
											
											if itemIDtoCompare == itemID then -- 동일한 상징 아이템을 장착했다면
												hasSameCharWithSameEmblem = true
											end
										end
									end
								end
							end
							
							if hasSameCharWithSameEmblem == false then
								teamManager:GetOnFieldSynergyCount(synergyID, 1)
								log(synergyID, " UP")
							else
								log("동일한 아이디를 가진 캐릭터가 동일한 메달을 장착한 상태이므로 시너지를 활성화하지 않습니다.")
							end
							
							
						end
					end
				end
			------------------------------------------------------------------------------
			else -- 유닛이 필드에서 내려간 경우
				if countCheck then
					teamManager.OnFieldUnitCount -= 1
				end
				-- log("OnFieldUnitCount = ", teamManager.OnFieldUnitCount)
				
				-- 중복 체크
				if isvalid(teamManager.OnFieldUnitIDs[charID]) then
					teamManager.OnFieldUnitIDs[charID] -= 1
					
					
					if teamManager.OnFieldUnitIDs[charID] == 0 then
						-- 시너지 Off
						for i = 1, 3 do
							local synergy = charSynergyDBRow:GetItem("Synergy_" .. math.floor(i))
							if synergy ~= "" then
								-- log(synergy .. " Minus")
								
								teamManager:GetOnFieldSynergyCount(synergy, -1)
								log("charID = ", charID, ", synID - = ", synergy)
							end
						end
						-- log(charID .. "/" .. teamManager.OnFieldUnitIDs[charID])
						teamManager.OnFieldUnitIDs[charID] = nil
					end
				else
					--log_error("teamManager.OnFieldUnitIDs = ", teamManager.OnFieldUnitIDs)
					--log_error(string.format("필드에 없는 CharID를 가진 유닛 내림 = %s", charID))
				end
				
				-- 상징을 장착한 경우
				if emblemItemCheck == true then
					local equippedItems = unit.UnitStatus.EquippedItemIDList
					for i=1, #equippedItems do
						local itemID = _UtilLogic:Split(equippedItems[i], "_")[1]
						local keyHead = string.sub(equippedItems[i], 1, 2)
						local keyTail = string.sub(equippedItems[i], 3, -1)
						if keyHead == "EI" then
							local synergyID = "S"..keyTail
							
							-- 예외처리: 동일한 id를 가진 캐릭터가 전장에 있고, 해당 캐릭터가 동일한 상징을 장착한 경우
							local hasSameCharWithSameEmblem = false
							local ownUnits = teamManager.OwnUnits
							for _, unitToCompare in pairs(ownUnits) do
								if unitToCompare ~= unit and unitToCompare.UnitInfo:IsOnFieldUnit() then	-- 전장 위 유닛이고
									if unitToCompare.UnitInfo.charID == charID then	-- 동일한 캐릭터이며
										local itemListToCompare = unitToCompare.UnitStatus.EquippedItemIDList
										for _, equippedItemIDtoCompare in pairs(itemListToCompare) do
											local itemIDtoCompare = _UtilLogic:Split(equippedItemIDtoCompare, "_")[1]
											
											if itemIDtoCompare == itemID then -- 동일한 상징 아이템을 장착했다면
												hasSameCharWithSameEmblem = true
											end
										end
									end
								end
							end
							
							if hasSameCharWithSameEmblem == false then
								teamManager:GetOnFieldSynergyCount(synergyID, -1)
							else
								log("동일한 아이디를 가진 캐릭터가 동일한 메달을 장착한 상태이므로 시너지를 제거하지 않습니다.")
							end
						end
					end
				end
				
			end
			local event = PlaceUnit()
			event.CharID = unit.UnitInfo.charID
			teamManager.Entity:SendEvent(event)
		end
	end

	@ExecSpace("ServerOnly")
	method void CheckUnitMerging(string userId)
		-- Merge 가능 여부를 체크하고, 가능하면 수행합니다.
		-- Merge를 한 번 수행한 경우 재귀호출로 다시 수행합니다. 수행이 불가하면 재귀를 종료합니다.
		--------------------------------------------------------------
		
		-- Merge 가능 여부를 체크합니다.
		local ownerEntity = _UserService:GetUserEntityByUserId(userId)
		local teamManager = ownerEntity.TeamManager
		local mergeTargetEntities = {}
		local mergedSetID = ""
		
		for setID, count in pairs(teamManager.OwnUnitsBySetID) do
			if count >= 3 then
				local targetCharID = string.sub(setID, 1, -2)
				local targetLevel = tonumber(string.sub(setID, -1, -1))
				mergedSetID = setID
				--log("mergedSetID = ", mergedSetID, ", count = ", count)
				if targetLevel ~= 3 then -- 3성 3마리인 경우는 합성 불가
					--log("#teamManager.OwnUnits = ", #teamManager.OwnUnits)
					for i=1, #teamManager.OwnUnits do
						local unit = teamManager.OwnUnits[i]
						local unitInfo = unit.UnitInfo
						--log("머지 검사... charID = ", unitInfo.charID, ", level = ", unitInfo.level)
						if unitInfo.charID == targetCharID and unitInfo.level == targetLevel then
							if unitInfo.IsMergableUnit == true then
								table.insert(mergeTargetEntities, unit)
							end
						end
					end
					--log("합성되는 실제 유닛의 수 = ", #mergeTargetEntities)
					break -- merge는 한 번에 하나씩 수행합니다.
				end
			end
		end
		--------------------------------------------------------------
		-- merge 가능한 상태라면 수행 및 재귀 호출
		local mergedCharID = string.sub(mergedSetID, 1, -2)
		if mergedSetID ~= "" and mergedCharID ~= "C00000" then
			self:MergeUnits(userId, mergeTargetEntities, mergedSetID)
			--사운드
			_PlaySoundLogic:PlaySound("M0002",userId)
			
			-- 0.75초 뒤 이 함수를 재귀 호출합니다.
			local reservateCheckingMerge = function()
				self:CheckUnitMerging(userId)
			end
			_TimerService:SetTimerOnce(reservateCheckingMerge, 1.8)
		else
			return
		end
	end

	@ExecSpace("ServerOnly")
	method Entity MergeUnits(string userId, SyncTable<Entity> unitTable, string setID)
		-- 오너가 userId인 unitTable의 유닛들을 합칩니다.
		-- 합치고 남은(=별 등급이 오른) 유닛을 return 합니다.
		------------------------------------------------------------
		-- 1. unitTable의 유닛들 중 merge 우선순위를 결정합니다. (타일 위치에 따라)
		-- 우선 순위는 다음과 같습니다.
			-- 1. HexaTile -> WatingTile : 필드 유닛으로 합쳐집니다.
			-- 	1-1. HextTile에서 : 뒷 열 -> 앞 열
			-- 	1-2. WatingTile에서 : 번호 순
		local user = _UserService:GetUserEntityByUserId(userId)
		local teamManager = user.TeamManager
		
		if not isvalid(self._T.DestroyEntity) then
			self._T.DestroyEntity={}
		end
		
		-- 유닛이 4기 이상인 경우
			-- 1. 유닛 위치/상황에 따라 3기만 합치기
			-- 2. 그 중 가장 우선 위치 유닛을 기준으로 합치기
		
		---@type table<Entity>
		local PriorityUnitTable = {}
		
		---@type table<number>
		local PriorityNumTable ={}
		
		for _, unit in pairs(unitTable) do
			local setTile = unit.UnitInfo.setTile
			
			-- setTile이 없는 경우
			if isvalid(setTile) == false then
				-- 타일 우선순위 체크
				local checkUnitId = unit.Id
				local tilePriority = 2000
				
				-- table에 아직 값이 없으면
				if PriorityUnitTable[1] == nil then
					PriorityUnitTable[1] = unit
					PriorityNumTable[1] = tilePriority
				-- 있으면
				else
					for i = 1, 3 do
						local checkUnit = _EntityService:GetEntity(checkUnitId)
						if not isvalid(checkUnit) then
							-- 더 이상 넣을 유닛이 없는 경우
						elseif not isvalid(PriorityNumTable[i]) then
							-- 빈 칸에 새로운 유닛을 넣는 경우
							PriorityUnitTable[i] = checkUnit
							PriorityNumTable[i] = tilePriority
							
							checkUnitId = ""
							tilePriority = nil
						elseif PriorityNumTable[i] < tilePriority then
							-- 뒤로 밀기 위해서 주체 변경
							local changeUnitId = PriorityUnitTable[i].Id
							local changeUnitPriority = PriorityNumTable[i]
							
							PriorityUnitTable[i] = checkUnit
							PriorityNumTable[i] = tilePriority
							
							checkUnitId = changeUnitId
							tilePriority = changeUnitPriority
						end
					end
				end
			
			
			-- 비전투인 경우
			elseif not unit.UnitAIWanderComponent.Enable then
				-- 타일 우선순위 체크
				local checkUnitId = unit.Id
				local tileInfo = setTile.TileComponent_New
				local tilePriority = 0
				
				local verticalNum = tileInfo.verticalNum
				local horizontalNum = tileInfo.horizontalNum
				
				local checkTileSplit =_UtilLogic:Split(setTile.Name, "_")
				
				-- 1. 전장/대기석
				if verticalNum > 0 then
					tilePriority += 100
				end
				
				-- 2. Column 순서
				tilePriority += 10 * verticalNum
				
				-- 3. Column 순서
				tilePriority += ( 10 - horizontalNum )
				
				-- table에 아직 값이 없으면
				if PriorityUnitTable[1] == nil then
					PriorityUnitTable[1] = unit
					PriorityNumTable[1] = tilePriority
				-- 있으면
				else
					for i = 1, 3 do
						local checkUnit = _EntityService:GetEntity(checkUnitId)
						if not isvalid(checkUnit) then
							-- 더 이상 넣을 유닛이 없는 경우
						elseif not isvalid(PriorityNumTable[i]) then
							-- 빈 칸에 새로운 유닛을 넣는 경우
							PriorityUnitTable[i] = checkUnit
							PriorityNumTable[i] = tilePriority
							
							checkUnitId = ""
							tilePriority = nil
						elseif PriorityNumTable[i] < tilePriority then
							-- 뒤로 밀기 위해서 주체 변경
							local changeUnitId = PriorityUnitTable[i].Id
							local changeUnitPriority = PriorityNumTable[i]
							
							PriorityUnitTable[i] = checkUnit
							PriorityNumTable[i] = tilePriority
							
							checkUnitId = changeUnitId
							tilePriority = changeUnitPriority
						end
					end
				end
			elseif not isvalid(setTile) then
				
			end
		end
		
		--log("merge 진행 중... PriotryUnitTable = ", PriorityUnitTable)
		--log("merge 진행 중... PriorityNumTable = ", PriorityNumTable)
		------------------------------------------------------
		-- 2. 유닛 제거 및 업그레이드
		local isSettedMainUnit = false
		local mainUnitId = ""
		---@type Entity
		local mainUnit = nil
		
		---@type table<string>
		local mergedEntities = {}
		local mergedPosList = {} -- 머지 연출을 위한 로컬변수
		local getUnitPos = function(unitEntity)
			---@type Entity
			local unit = unitEntity
			
			local hor = unit.UnitInfo.setTileHorizontalNum
			local ver = unit.UnitInfo.setTileVerticalNum
			
			return string.format("%d,%d",hor,ver) 
		end
		
		---@type table<string>
		local items = {}	-- 머지된 유닛들이 장착한 아이템 목록. 이 중 무작위로 3종을 장착.
		
		local stackAbilities = {} -- 머지된 유닛들의 영구 스택 합. 메인 유닛에게만 적용.
		local addStackAbilities = function(targetUnit)
			---@type Entity
			local unit = targetUnit
			for key, value in pairs(unit.UnitStatus.StackProperty) do
				if stackAbilities[key] == nil then
					stackAbilities[key] = 0
				end
				
				stackAbilities[key] += value
			end
		end
		
		
		local onFieldEmblemItemsID = {}	-- 필드에 있는 merge 대상 유닛들이 장착하고 있던 메달 아이템들입니다.
		
		for key = 1, 3 do
			local getUnit = PriorityUnitTable[key]
			
			if isvalid(getUnit) == true then
				local getUnitInfo = getUnit.UnitInfo
				
				-- (1) 일반 유닛의 경우 (타일 정보가 있음)
				if isvalid(getUnitInfo.setTile) then
					-- 메인 유닛인 경우
					if isSettedMainUnit == false then
						
						-- 이벤트 처리
						user:SendEvent(LevelUpUnit(getUnit, getUnitInfo.level + 1, getUnitInfo.cost, getUnitInfo.charID))	-- 에러 아님
						
						-- 레벨 올리고
						getUnitInfo:SetPropertyToServer("level", getUnitInfo.level + 1, nil, true)
						getUnit.UnitStatus:SetDefaultStatus()
						
						isSettedMainUnit = true
						mainUnit = getUnit
						mainUnitId = getUnit.Id
						
						table.insert(mergedEntities, 1, getUnit.Id)
						table.insert(mergedPosList, 1, getUnitPos(getUnit))
						
						-- 영구 스택 정보를 기록합니다.
						addStackAbilities(getUnit)
						
						-- 장착 중이던 아이템 정보를 기록하고, 제거합니다.
						local equippedItems = getUnit.UnitStatus.EquippedItemIDList
						for _, itemID in pairs(equippedItems) do
							-- 상징인 경우 장착 해제 처리합니다.
							local keyHead = string.sub(itemID, 1, 2)
							if keyHead == "EI" and getUnitInfo:IsOnFieldUnit() then
								if onFieldEmblemItemsID[itemID] == nil then
									onFieldEmblemItemsID[itemID] = 0
								else
									onFieldEmblemItemsID[itemID] += 1
								end
							end
							
							table.insert(items, itemID)
						end
						getUnit.UnitStatus:SetProperty("EquippedItemIDList", nil, "clear")
						
						-- 오른 레벨에 따라 material을 설정
						mainUnit.UnitInfo:SetOutlineMaterial(false, "", userId)
						
					------------------------	
					-- 메인 유닛이 이미 세팅된 경우 (= 합성 재료로 쓰인 유닛인 경우)
					else
						-- item 체크해서 빼낸다음 유닛 삭제 해야함 (구현중)
						local unit_Tile = getUnitInfo.setTile
						local tileInfo = unit_Tile.TileComponent_New
						
						for idx, unit in pairs(teamManager.OwnUnits) do
							if unit == getUnit then
								table.remove(teamManager.OwnUnits, idx)
		                        --for idx, unit in pairs(teamManager.OwnUnits) do
		                        --    log("Idx = ", idx, ", Unit = ", unit.UnitInfo.charID)
		                        --end
		                        --log("REMOVE_ #teamManager.OwnUnits = ", #teamManager.OwnUnits)
								break
							end
						end
						
						-- 전장에 있는 유닛이 합성된 경우, OnField 숫자 조정
						if tileInfo.verticalNum > 0 then
							self:OnFieldSet(teamManager, getUnit, false, true, false)
						end
						
						table.insert(mergedEntities, getUnit.Id)
						table.insert(mergedPosList, getUnitPos(getUnit))
						
						addStackAbilities(getUnit)
						
						-- 장착 중이던 아이템을 temp에 넣고, 장착 해제합니다.
						local equippedItems = getUnit.UnitStatus.EquippedItemIDList
						for _, itemID in pairs(equippedItems) do
							-- 상징인 경우 장착 해제 처리합니다.
							local keyHead = string.sub(itemID, 1, 2)
							if keyHead == "EI" and getUnit.UnitInfo:IsOnFieldUnit() then
								if onFieldEmblemItemsID[itemID] == nil then
									onFieldEmblemItemsID[itemID] = 0
								else
									onFieldEmblemItemsID[itemID] += 1
								end
							end
							
							table.insert(items, itemID)
						end
						getUnit.UnitStatus:SetProperty("EquippedItemIDList", nil, "clear")
						
						-- 드래그 해제
						if self.SelectUnit == getUnit then
							self:DragOff(getUnit, userId)
						end
						
						-- 삭제 대신 초기화 필요
						getUnitInfo:CleanCharInfo()
					end
				end
			end
		end
		
		-- merge 대상 필드 위 유닛들이 메달을 장착하고 있었다면, 상징 수를 감소시킵니다.
		for itemID, count in pairs(onFieldEmblemItemsID) do
		    local synergyID = string.sub(itemID, 3, -1)
		    teamManager:GetOnFieldSynergyCount("S"..synergyID, -1)
		end
		--------------------------------------------------------------------------------
		-- 메인 유닛한테 영구 스택 합침
		for key, value in pairs(stackAbilities) do
			mainUnit.UnitStatus.StackProperty[key] = value
		end
		mainUnit.UnitStatus:SetUnitStatus(false)
		--------------------------------------------------------------------------------
		-- 메인 유닛한테 무작위 3개 아이템 장착
		
		-- (1) 장착한 아이템이 오직 "산타 장갑"인 경우, 산타 장갑만 장착
		if #items == 1 and items[1] == "NI10033" then
			mainUnit.UnitStatus:SetProperty("EquippedItemIDList", "NI10033", "insert,-1")
			table.remove(items, 1)
		-- (2) 그 외의 경우
		else
		
			-- 재료 아이템을 가지고 있는가? 
			local materialIdx = {} 
			for idx,id in pairs(items) do 			
				if string.sub(id,1,2) == "MI" then 
					table.insert(materialIdx,idx)
				end 		
			end
		
			 -- 재료 아이템 2개를 완성 아이템으로 조합
			if #materialIdx == 2 then 
		
				local materialItem1 = items[materialIdx[1]]
				local materialItem2 = items[materialIdx[2]]
				
				-- 조합 아이템 장착
				local combineID = _ItemCombineService:GetNormalItemIDByMaterialItemIDs(materialItem1,materialItem2, user)
				table.insert(items,combineID)
				-- 재료 아이템 제거 
				table.remove(items,materialIdx[2]) 
				table.remove(items,materialIdx[1])
				
			end
		
			-- 일부 아이템은 장착 대상에서 제외
			for i=#items, 1, -1 do
				if items[i] == "NI10033" then	-- 산타 장갑인 경우
					table.remove(items, i)	-- 대상에게서 제거하고
					table.insert(teamManager.OwnItems, "NI10033")	-- 인벤토리로 회수
					
				elseif string.sub(items[i], 1, 2) == "EI" then -- 동일한 상징 아이템이 있는 경우
					for j=i-1, 1, -1 do
						if items[j] == items[i] then
							log("동일한 상징 아이템이 목록에 있으므로 제거합니다")
							table.insert(teamManager.OwnItems, items[i])	-- 인벤토리로 회수
							table.remove(items, i) -- 대상에서 제거
							break
						end
					end
				end
			end
			
			-- 남은 아이템 장착 
			for i=1, 3 do
				if #items < 1 then  -- 남은 아이템 수가 0개라면 종료
					break 
				end	
				----
				local randomIdx = _UtilLogic:RandomIntegerRange(1, #items)
				local itemID = items[randomIdx]	
				
				-- 장착한 아이템이 상징 아이템인 경우
				local keyHead = string.sub(itemID, 1, 2)
				local keyTail = string.sub(itemID, 3, -1)
				if keyHead == "EI" then
					if mainUnit.UnitInfo:IsOnFieldUnit() then
						-- 단, 전장에 해당 유닛과 동일한 ID를 가진 아군 유닛이 있고 동일한 메달을 장착한 경우는 예외처리
						local targetUnitCharID = mainUnit.UnitInfo.charID
						local ownUnits = user.TeamManager.OwnUnits
						local hasSameCharWithSameEmblem = false 
						for _, unit in pairs(ownUnits) do
							if unit.UnitInfo:IsOnFieldUnit() then	-- 전장 위 유닛이고
								if unit ~= mainUnit and unit.UnitInfo.charID == targetUnitCharID then	-- 동일한 캐릭터이며
									local itemListToCompare = unit.UnitStatus.EquippedItemIDList
									for _, equippedItemIDtoCompare in pairs(itemListToCompare) do
										local itemIDtoCompare = _UtilLogic:Split(equippedItemIDtoCompare, "_")[1]
										
										if itemIDtoCompare == itemID then -- 동일한 상징 아이템을 장착했다면
											hasSameCharWithSameEmblem = true
										end
									end
								end
							end
						end
						
						if hasSameCharWithSameEmblem == false then
							log("시너지 업 : ", "S"..keyTail)
							user.TeamManager:GetOnFieldSynergyCount("S"..keyTail, 1)
						else
							log("동일한 아이디를 가진 캐릭터가 동일한 메달을 장착한 상태이므로 시너지를 활성화하지 않습니다.")
						end
					end
					
				end
				
				mainUnit.UnitStatus:SetProperty("EquippedItemIDList", itemID, "insert,-1")
				table.remove(items, randomIdx)
				
				mainUnit.UnitStatus:SetUnitStatus(false)
			end
		end
		
		-- 남은 아이템은 수거
		for i=1, #items do
			local itemID = items[i]
			table.insert(teamManager.OwnItems, itemID)
		end
		--------------------------------------------------------------------------------
		-- teamManager에서 데이터 변경
		teamManager.OwnUnitsBySetID[setID] -= 3
		local targetCharID = string.sub(setID, 1, -2)
		local targetLevel = tonumber(string.sub(setID, -1, -1)) + 1
		local changedSetID = targetCharID..string.format("%d",targetLevel)
		
		if isvalid(teamManager.OwnUnitsBySetID[changedSetID]) == false then
			teamManager.OwnUnitsBySetID[changedSetID] = 1
		else 
			teamManager.OwnUnitsBySetID[changedSetID] += 1
		end
		
		-- 이벤트 생성
		local mergeUnitEvent = MergeUnit(mainUnit, targetLevel)	-- 에러 아님
		user:SendEvent(mergeUnitEvent)
		--------------------------------------------------------------------------------
		_UI_UnitInfoPopup:UI_Update_WhenMerged(_UtilLogic:TableToString(mergedEntities), userId)
		self:PlayMergeDirection(_UtilLogic:TableToString(mergedPosList), targetLevel, mainUnit,userId)
		
		--log("머지 이후, ownUnitsBySetID = \n")
		--log(_UserService:GetUserEntityByUserId(userId).TeamManager.OwnUnitsBySetID)
		
		
		if string.sub(user.GameManager.ModeType, 1, 6) == "Single" then
			-- 일일 미션 : 2성 캐릭터 만들기
			if mainUnit.UnitInfo.level == 2 then
				user.DailyMissionComponent:AddDailyMissionProgress("DM10008", user.GameManager.ModeLevel, 1)
			-- 일일 미션 : 3성 캐릭터 만들기	
			elseif mainUnit.UnitInfo.level == 3 then
				user.DailyMissionComponent:AddDailyMissionProgress("DM10009", user.GameManager.ModeLevel, 1)
			end
		end
		
		return mainUnit --_EntityService:GetEntity(mainUnitId)
	end

	@ExecSpace("Server")
	method void SellUnit(string userID, Entity unit)
		-- 유닛을 판매하는 함수입니다.
		------------------------------------------------------------
		-- 예외 처리
		if isvalid(userID) == false then
			return
		end
		if isvalid(unit) == false then
			self:DragOff(nil, userID)
			return
		end
		
		if unit.UnitInfo.IsResellable == false then
			_UIToast:ShowMessageByLocalizingKey("CannotSellUnit", userID)
			self:DragOff(unit, userID)
			return
		end
		
		-- 검증: 사용(대기석 or 전장) 중인 유닛이 아닌 경우
		if unit.UnitInfo.use == false then
			unit.UnitInfo:CleanCharInfo()
			return
		end
		
		self:DragOff(unit, userID)
		------------------------------------------------------------
		-- 검증
		local userEntity = _UserService:GetUserEntityByUserId(userID) 
		local gameManager = userEntity.GameManager
		if gameManager.PhaseType ~= "Ready" then
			return
		end
		------------------------------------------------------------
		-- 기본 프로퍼티
		local teamManager = userEntity.TeamManager
		local shopManager = userEntity.CharacterShopManager_New
		local userPControl = userEntity.TM_PropertyControl
		local unitInfo = unit.UnitInfo
		------------------------------------------------------------
		-- 유닛 판매 이벤트 처리
		userEntity:SendEvent(SellUnit(unit, unitInfo.charID, unitInfo.cost, unitInfo.level))	 -- 에러 아님
		------------------------------------------------------------
		-- 유닛의 별 등급에 따라 판매 금액을 계산합니다.
		local cost = unitInfo.cost
		local level = unitInfo.level
		
		local getMoney = 0
		if cost == 1 then
			getMoney = cost * (3^(level-1))
		elseif level > 1 then
			getMoney = cost * (3^(level-1)) - 1
		else
			getMoney = cost
		end
		
		getMoney = math.max(0, getMoney + userPControl.Unit_AddResellCost)
		
		_GeneralDirectorLogic:PlayCoinDirector_Sprite(getMoney,nil,"Shop",userEntity.PlayerComponent.UserId)
		--_GeneralDirectorLogic:InsertCoinDirectorData("Shop",nil,userEntity.PlayerComponent.UserId)
		teamManager:AddGolds(getMoney, "sellChar")
		------------------------------------------------------------
		-- 유닛 삭제
		local setTile = unitInfo.setTile
		local setId = unitInfo.charID .. string.format("%d", level)
		
		if unit.UnitInfo.IsMergableUnit == true then
			teamManager.OwnUnitsBySetID[setId] -= 1
		end
		
		if isvalid(shopManager.LeftUnitCount[unitInfo.charID]) then
			shopManager.LeftUnitCount[unitInfo.charID] += 3^(level-1)
			-- log(string.format("%s's Left Count is %d", unitInfo.charID, shopManager.LeftUnitCount[unitInfo.charID])) 
		end
		
		for idx, ownUnit in pairs(teamManager.OwnUnits) do
			if unit == ownUnit then
				table.remove(teamManager.OwnUnits, idx)
			end 
		end
		------------------------------------------------------------
		if setTile.TileComponent_New.verticalNum > 0 then
			self:OnFieldSet(teamManager, unit, false, unitInfo.IsSettableOnWatingField, true)
		end
		------------------------------------------------------------
		-- 유닛이 가지고 있던 아이템을 회수합니다.
		-- 단 OnField 유닛은 회수하지 않습니다.
		if unit.UnitInfo.IsSettableOnWatingField then
			_ItemSetLogic:WithdrawAllItems(unit, false)
		else
			unit.UnitStatus:SetProperty("EquippedItemIDList", nil, "clear")
		end
		------------------------------------------------------------
		-- 유닛 초기화 필요
		unit.UnitInfo:CleanCharInfo()
		
		-- 붉은 타일 켜져 있으면 끄기
		_GeneralDirectorLogic:SetClientRedTile(unit,false,userID)
		------------------------------------------------------------
		self:DragOff(nil, userID)
		_PlaySoundLogic:PlaySound("M0006",userID)
		
	end

	@ExecSpace("Server")
	method void BattleSetting_UnitSet(string userId, string phaseType)
		-- 전투 시작/종료 시 적 유닛을 생성 또는 제거하거나 관리하는 함수
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(user) then
			return
		end
		
		local units = self.UnitsParentEntity[userId]
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		
		local charStatusTable = _DataService:GetTable("CharacterStatus")
		local charInfoTable = _DataService:GetTable("CharacterInfo")
		
		local enemyUnitCount = 0
		---------------------------------------------------------
		-- (준비 => 전투)로 전환할 때
		if phaseType == "Setting" then
			---------------------------------------------------------
			-- 상대 유닛 정보를 받아와서 유닛 세팅해주기
			-- 상대 유닛 수, 우리팀 유닛 수를 확인하고 세팅
			---------------------------------------------------------
			-- 기본 라운드 별 상대팀
			enemyUnitCount = self:BattleSetting_EnemyUnit(userId, gameManager.ModeSetVersion, gameManager.ModeType, gameManager.UnitPresetType, gameManager.ModeLevel)
			---------------------------------------------------------
			-- 딜 체크용 허수아비
			-- enemyUnitCount = self:BattleSetting_EnemyUnit_New(userId)
			---------------------------------------------------------
			-- 적 시너지 체크 후 필요한 작업 세팅
			self:BattleSetting_EnemySynergyCheck(userId)
			---------------------------------------------------------
			-- 전장 내 유닛 수 세팅
			local eCount = 0
			local tCount = 0
			
			for _, unit in pairs(units.Children) do
				local unitInfo = unit.UnitInfo
				if unitInfo.use and unitInfo:IsOnFieldUnit() then
					if unitInfo.TeamType == "User" then
						tCount += 1
					elseif unitInfo.TeamType == "Enemy" then
						eCount += 1
					end
				end
			end
			
			user.GameManager.EnemyCount = eCount
			user.GameManager.MyUnitCount = tCount
			---------------------------------------------------------
			-- 유닛 기록값 초기화
			for _, unit in pairs(units.Children) do
				local unitInfo = unit.UnitInfo
				if unitInfo.use and unitInfo:IsOnFieldUnit() then
					-- unit.UnitBattleStatistics:RoundPropertyInitialize(unitInfo.charID)
					
		
					if isvalid(unitInfo.SkillComponent.SetBattle) then
						unitInfo.SkillComponent:SetBattle()
					end
				end
			end
		---------------------------------------------------------
		-- 전투 종료의 경우
		elseif phaseType == "Clean" then
			---------------------------------------------------------
		
			-- 모든 유닛의 전투 중 데이터를 제거합니다.
			for _, unit in pairs(units.Children) do
				local unitInfo = unit.UnitInfo
				if unitInfo.use then
					--log(unitInfo.unitName, unit.UnitStatus.HP, unit.UnitStatus.HP / unit.UnitStatus.MaxHP)
					_StatusChangeLogic:RemoveStatusEffect(unit, "All")
					_StatusChangeLogic:RemoveOneoffStats(unit)
					
					if unit.UnitAIWanderComponent.Enable then
						unit.UnitBattleStatistics:SetProperty("DeadTime", -1, true)
						unit.UnitAIWanderComponent:BattleEnd()
						unit.UnitAIWanderComponent.Enable = false
					end
				
					if isvalid(unitInfo.SkillComponent.Reset) then
						unitInfo.SkillComponent:Reset()
					end
					
					unit.UnitAnimationComponent:PlayAnimation(1, "Idle", nil, userId)
				end
				_GeneralDirectorLogic:RemoveHectorEffect(unit,"Clean",userId) --  헥터 위협
				_SynergyBattleDirectorLogic:S10017SurviveEffect(unit,false,"Clean",userId) -- 빅토리아 부활 초기화
				_SynergyBattleDirectorLogic:S10016ColdAir(unit,false,0,"Clean",userId)--엘나스 냉기 초기화
			end
			---------------------------------------------------------
			-- 모든 상대 유닛 정리
			table.clear(teamManager.EnemyUnits)
			table.clear(teamManager.EnemyOwnedFieldSynergy)
			---------------------------------------------------------
			-- 적 룬 제거
			for i = #teamManager.EnemyOwnedRunes, 1, -1 do
				user.SpecialShopManager:RemoveRCComponent(teamManager.EnemyOwnedRunes[i], 0, false, i)
				table.remove(teamManager.EnemyOwnedRunes, i)
			end
			
		---------------------------------------------------------
		-- 전투 준비 단계
		elseif phaseType == "Ready" then
		---------------------------------------------------------
		-- 유저 유닛 위치 원래대로 조정
		---------------------------------------------------------
			for _, unit in pairs(units.Children) do
				local unitInfo = unit.UnitInfo
				local unitStatus = unit.UnitStatus
				local animComponent = unit.UnitAnimationComponent
				if unitInfo.use then
					if unitInfo.TeamType == "Enemy" then
						unitStatus:SetProperty("state", "Idle", "")
					elseif unitInfo.TeamType == "User" then
						if isvalid(unitInfo.saveTile) == false then -- 특정 효과에 의해 이번 라운드에만 생성된 케이스 (그림자)
							unitInfo:SetPropertyToServer("setTile", nil, "All", true)
						else
							unitInfo:SetPropertyToServer("setTile", unitInfo.saveTile, "All", true)
							animComponent:SetLayerOrder(unitInfo.saveTile.TileComponent_New.verticalNum, unitInfo.OwnerId)
						end
						
						unitInfo.spriteRenderer.SpriteRendererComponent.FlipX = true
					end
				end
			end
			
			-- 각 유닛의 스탯을 리셋...
			for i, unit in pairs(units.Children) do
				_TimerService:SetTimerOnce(function() 
					
					if isvalid(unit) == false then
						return
					end
					
					local unitInfo = unit.UnitInfo
					local unitStatus = unit.UnitStatus
					local animComponent = unit.UnitAnimationComponent
					if unitInfo.use then
						_CustomizedBattleEffectService:SetEntityVisible(unit, true, userId)
						animComponent:PlayAnimation(1, "ForcedIdle", unit.Parent, unitInfo.OwnerId)
						
						if unitInfo.TeamType == "Enemy" then
							unitInfo:CleanCharInfo()
							unitStatus:SetProperty("EquippedItemIDList", nil, "clear")
						elseif unitInfo.TeamType == "User" then
							--unitInfo:SetCharInfo(unitInfo.charID, unitInfo.level, unitInfo.cost)
						end
						
						unit.UnitItem:ClearAllStacks()
						unit.UnitSynergy:ClearAllStackProperties()
						--unit.UnitAnimationComponent:SetDefaultColor(Color(1,1,1,1), userId)
						
						unitStatus:SetUnitStatus(false)
					end
				end, 0.03 * i)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void BattleSetting_OnSettingPhase(string userId)
		
		-- 준비 > 세팅 > 전투 단계 중 '세팅' 단계에서 수행하는 함수입니다.
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local units = self.UnitsParentEntity[userId]
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local specialShopManager = user.SpecialShopManager
		---------------------------------------------------------
		for _, unit in pairs(units.Children) do
			local unitInfo = unit.UnitInfo
			if unitInfo.use then
				unitInfo.saveTile = unitInfo.setTile
		
				unit.UnitItem:OnSettingPhase()
			end
		end
		
	end

	@ExecSpace("Server")
	method void BattleSetting_OnBattlePhase(string userId)
		-- 준비 > 세팅 > 전투 단계 중 '전투' 단계가 시작할 때 수행하는 함수입니다.
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local units = self.UnitsParentEntity[userId]
		local teamManager = user.TeamManager
		---------------------------------------------------------
		-- 전투하도록 AiWander 켜주기
		user.TeamBattleStatistics:RoundPropertyInitialize()
		---------------------------------------------------------
		-- 전투 유닛 활성화
		for _, unit in pairs(units.Children) do
			local unitInfo = unit.UnitInfo
			if unitInfo.use then
				unitInfo.OnTileNum["Vertical"] = unitInfo.setTileVerticalNum
				unitInfo.OnTileNum["Horizontal"] = unitInfo.setTileHorizontalNum
				
				if unitInfo:IsOnFieldUnit() then
					unit.UnitBattleStatistics:RoundPropertyInitialize(unitInfo.charID)
					unit.UnitStatus.Target = nil
					unit.UnitAIWanderComponent.Enable = true
					unit.UnitAIWanderComponent.setBattle = true
				elseif unitInfo.charID == "C00002" then
					unit.UnitBattleStatistics:RoundPropertyInitialize(unitInfo.charID)
					unit.UnitStatus.Target = nil
					unit.UnitAIWanderComponent.Enable = true
					unit.UnitAIWanderComponent.stopUnit = true
					unit.UnitAIWanderComponent.setBattle = true
				end
			end
		end
		---------------------------------------------------------
		-- 아이템 효과 적용
		for _, unit in pairs(units.Children) do
			local unitInfo = unit.UnitInfo
			if unitInfo.use then
				if unitInfo:IsOnFieldUnit() then
					unit.UnitItem:OnBattleStart()
				end
			end
		end
		---------------------------------------------------------
		-- 시너지 효과 적용
		for _, unit in pairs(units.Children) do
			local unitInfo = unit.UnitInfo
			if unitInfo.use then
				if unitInfo:IsOnFieldUnit() then
					unit.UnitSynergy:OnBattleStart()
				end
			end
		end
	end

