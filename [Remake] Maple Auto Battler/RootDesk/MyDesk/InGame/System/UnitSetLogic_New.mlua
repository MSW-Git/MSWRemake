					bUnit.UnitBattleStatistics:PropertyClear()	
					bUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
					bUnit.UnitInfo:SetPropertyToServer("TeamType", "User", nil, true)
					bUnit.UnitInfo.IsResellable = false
					bUnit.UnitInfo.IsMergableUnit = false
					bUnit.UnitInfo:SetPropertyToServer("IsItemEquippable", false, "", true)	-- 아이템 장착 가능 여부
					bUnit.UnitInfo.IsMovableByPlayer = true
					bUnit.UnitInfo:SetPropertyToServer("IsSettableOnWatingField", false, "", true)
					bUnit.UnitInfo.IsAppliableSynergy = false
					bUnit.UnitInfo:CleanCharInfo()
				end
			-- [오르비스] 시너지 - 적
			elseif unitSetCount <= 56 then
				for i=1, 3 do
					local eName = string.format("EnemyUnit_OrbisStone%d",i)
					local eUnit = units:GetChildByName(eName)
					if not isvalid(eUnit) then
						eUnit = _SpawnService:SpawnByModelId("model://9cc59355-72de-4dae-bba2-8805e5ca48f1", eName, Vector3(999,999,0), units)
					end
					eUnit.UnitBattleStatistics:PropertyClear()
					eUnit.UnitInfo:SetPropertyToServer("OwnerId", userId, nil, true)
					eUnit.UnitInfo:SetPropertyToServer("TeamType", "Enemy", nil, true)
					eUnit.UnitInfo:CleanCharInfo()
				end
			else
				if isvalid(_UserService:GetUserEntityByUserId(userId)) then
					_UserService:GetUserEntityByUserId(userId).LoadingManager.LoadedCount["UnitSampleSpawn"] = 1
				end
				_TimerService:ClearTimer(unitSetTimer)
			end
			
		end
		unitSetTimer = _TimerService:SetTimerRepeat(unitSampleSpawnFnc, 0.15, 0)
		
	end

	@ExecSpace("ServerOnly")
