				if not isvalid(atk_proj) then
					atk_proj = _SpawnService:SpawnByModelId("model://65ffab91-c0ff-4864-9b4f-ad3908c20cd2", ap_Name, Vector3(999,999,0), projectiles)
				end
				atk_proj.AProjectileInfo:SetOwnerID(userId)
				atk_proj:SetEnable(false)
			-- 스킬 공격용 투사체
			elseif projSetCount < 130 then
				local sp_Name = string.format("skl_Proj_%d", projSetCount)
				local skl_proj = projectiles:GetChildByName(sp_Name)
				if not isvalid(skl_proj) then
					skl_proj = _SpawnService:SpawnByModelId("model://80d32bc0-8fc8-4d3d-a672-8750b8dcb7ed", sp_Name, Vector3(999,999,0), projectiles)
				end
				skl_proj.SkillShotCheckComponent:SetOwnerID(userId)
				skl_proj:SetEnable(false)
			else
				if isvalid(_UserService:GetUserEntityByUserId(userId)) then
					_UserService:GetUserEntityByUserId(userId).LoadingManager.LoadedCount["ProjectileSampleSpawn"] = 1
				end
				_TimerService:ClearTimer(projSetTimer)
			end
			
		end
		
		projSetTimer = _TimerService:SetTimerRepeat(projSampleSpawnFnc, 0.1, 0)
	end

	@ExecSpace("ServerOnly")
	method void UnitSampleDestroy(string userId)
		-- 유저가 나가면 유닛 샘플 엔티티를 지우는 함수입니다.
		------------------------------------------------------------
		local units = self.UnitsParentEntity[userId]
		
		local unitSetTimer = 0
		local function unitSampleDestroyFnc()
			if isvalid(units) then
				local sampleEntities = units.Children
				if #sampleEntities > 0 then
					for _, sEntity in pairs(sampleEntities) do
						sEntity:Destroy()
						break
					end
				else
					-- 더 이상 지울 엔티티가 없으면
					units:Destroy()
					_TimerService:ClearTimer(unitSetTimer)
				end
			else
				-- units가 없으면
				_TimerService:ClearTimer(unitSetTimer)
			end
		end
		
		unitSetTimer = _TimerService:SetTimerRepeat(unitSampleDestroyFnc, 0.1, 0)
		self.UnitSampleDestroyTimerID = unitSetTimer
	end

	@ExecSpace("ServerOnly")
	method void ProjectileSampleDestroy(string userId)
		-- 유저가 나가면 투사체 샘플 엔티티를 지우는 함수입니다.
		------------------------------------------------------------
		local projectiles = self.ProjectilesParentEntity[userId]
		
		local projectileSetTimer = 0
		local function projectileSampleDestroyFnc()
			if isvalid(projectiles) then
				local sampleEntities = projectiles.Children
				if #sampleEntities > 0 then
					for _, sEntity in pairs(sampleEntities) do
						sEntity:Destroy()
						break
					end
				else
					-- 더 이상 지울 엔티티가 없으면
					projectiles:Destroy()
					_TimerService:ClearTimer(projectileSetTimer)
				end
			else
				-- projectiles가 없으면
				_TimerService:ClearTimer(projectileSetTimer)
			end
		end
		
		projectileSetTimer = _TimerService:SetTimerRepeat(projectileSampleDestroyFnc, 0.1, 0)
		
		self.ProjectileSampleDestroyTimerID = projectileSetTimer
	end

	@ExecSpace("Client")
	method void PlayMergeDirection(string mergedPosList_str, number targetStar, Entity MainUnit)
		-- Merge 연출을 재생하는 함수입니다.
		-- mergedPosList_str : merge 대상들의 tile 번호(= (h,v))를 저장한 테이블
		------------------------------------------------
		local playRate = 1
		------------------------------------------------
		local getWorldPos = function(tilePos_str)
			if _UtilLogic:IsNilorEmptyString(tilePos_str) then
				return nil
			end
			
			local split = _UtilLogic:Split(tilePos_str, ",")
			local tilePos_horizontal = tonumber(split[1])
			local tilePos_vertical = tonumber(split[2]) 
			
			local tileEntity = nil
			if tilePos_vertical > 0 then
				tileEntity =  
					_UserService.LocalPlayer.CurrentMap:GetChildByName(string.format("Line_%d", tilePos_vertical)):GetChildByName(string.format("Tile_%d", tilePos_horizontal))
				--[[
				_EntityService:GetEntityByPath(
					string.format(_UserService.LocalPlayer.CurrentMapName.."/maps/Arena/Line_%d/Tile_%d", tilePos_vertical, tilePos_horizontal))]]
			else
				if tilePos_horizontal == 0 then
					return nil
				end
				
				tileEntity = _UserService.LocalPlayer.CurrentMap:GetChildByName("WaitLine"):GetChildByName(string.format("Tile_%d", tilePos_horizontal))
				--[[ _EntityService:GetEntityByPath(
					string.format("/maps/Arena/WaitLine/Tile_%d", tilePos_horizontal))]]
			end 
			
			return tileEntity.TransformComponent.WorldPosition:ToVector2()
		end
		------------------------------------------------
		-- 테이블의 1번 항목은 레벨업한 유닛, 나머지는 사라진 유닛의 좌표입니다.
		local mergedPosList = _UtilLogic:StringToTable(mergedPosList_str)
		local destinationPos = getWorldPos(mergedPosList[1])
		------------------------------------------------
		-- 합성되는 위치에 충전 파티클을 재생합니다. 이 때 메인 유닛 visible과 터치리시브 컴포를 끕니다.
		local destPos3 = destinationPos:ToVector3()
		
		if MainUnit == _UnitSetLogic_New.SelectUnit then -- 만약 이미 드래그중이었던 유닛이라면 드래그 취소합니다.
			self:DragOff(_UnitSetLogic_New.SelectUnit)
		end
		
		MainUnit.Visible=false
		MainUnit.TouchReceiveComponent.Enable=false
		local chargingParticle = _SpawnService:SpawnByModelId(
			"model://ffce8fbb-8b9c-40b9-a60a-dc321024d658",
			"MergeParticle_Charge",
			destPos3 + Vector3(0, 0.25, 0),
			_UserService.LocalPlayer.CurrentMap)
		
		table.remove(mergedPosList, 1)
		------------------------------------------------
		-- 움직이는 파티클 create
		for i=1, 2 do
			local spawnPos = getWorldPos(mergedPosList[i])
			
			if spawnPos ~= nil then
				local movingParticle = _SpawnService:SpawnByModelId(
					"model://fddcacb1-164d-4ad7-8616-0a2a85ceb77e",
					"mergedParticle",
					spawnPos:ToVector3(),
					_UserService.LocalPlayer.CurrentMap
				)
				
				local dir = destinationPos - spawnPos -- 총 이동량
				local t = 0
				
				-- 움직임 예약
				local originPos = spawnPos:ToVector3()
				local setMovingParticlePos = function()
					t += 1/40
					local deltaX = _TweenLogic:Ease(0, dir.x, 1, EaseType.Linear, t)
					local deltaY = _TweenLogic:Ease(0, dir.y, 1, EaseType.Linear, t)
					movingParticle.TransformComponent.WorldPosition = originPos + Vector3(deltaX, deltaY, 0)
				end
				for j=1, 40 do
					_TimerService:SetTimerOnce(setMovingParticlePos, (0.5+ j/80)/playRate)
				end
				
				-- 파괴 예약
				movingParticle:Destroy(1.3)
			end
		end
		
		------------------------------------------------
		-- 합성되는 위치에 완성 파티클 및 별 이미지를 보여줍니다. 이 때 메인유닛 visible과 터치리시브 컴포를 킵니다.
		local playMergeFinishDirection = function()
			chargingParticle:Destroy()
			MainUnit.Visible=true
			MainUnit.TouchReceiveComponent.Enable=true
			local finishParticle = _SpawnService:SpawnByModelId(
				"model://43c3cbab-b3db-40f4-9f5a-beaf8919e18b",
				"MergeParticle_Finish",
				destPos3 + Vector3(0, 0.5, 0),
				_UserService.LocalPlayer.CurrentMap)
			finishParticle:Destroy(1)
			
			-- 합성되는 위치에 별 이미지
			local starImageModelID = "model://525825fe-8ccb-43c3-b015-e4a1e9a5bc8c"
			if targetStar == 3 then
				starImageModelID = "model://68c6a250-7921-478b-b92c-a57cd312ad97"
			end
			
			local starImage = _SpawnService:SpawnByModelId(
				starImageModelID,
				"MergeStarImage",
				destPos3 + Vector3(0, 1, 0),
				_UserService.LocalPlayer.CurrentMap)
			
			local alpha = 1
			local setAlpha = function()
				alpha -= 1/20
				if isvalid(starImage.CanvasGroupComponent) then
					starImage.CanvasGroupComponent.GroupAlpha = alpha
				else
					--log_error("컴포넌트가 없음")
				end
			end
			for i=1, 20 do
				_TimerService:SetTimerOnce(setAlpha, (1+i/40)*playRate)
			end
				
			starImage:Destroy(1)
		end
		_TimerService:SetTimerOnce(playMergeFinishDirection, 1.3/playRate)
		
	end

	@ExecSpace("ServerOnly")
	method boolean SpawnShadow(string userId, Entity originUnit, string teamType, string SpawnType, number shadowIdx)
		
		-- 그림자 캐릭터의 쉐도우 파트너를 소환/소환 해제 하는 함수입니다.
		--------------------------------------------------------
		local charID = "" 
		local level = ""
		local setId = ""
		local userEntity = _UserService:GetUserEntityByUserId(userId) 
		local teamManager = userEntity.TeamManager
		---@type UserDataRow
		local charInfoDB = nil
		
		if isvalid(originUnit) == true then
			charID = originUnit.UnitInfo.charID 
			level = originUnit.UnitInfo.level
			setId = charID .. string.format("%d", level)
			charInfoDB = _DataService:GetTable("CharacterInfo"):FindRow("CharID", charID)
		end
		-------------------------------------------------------
		-- 소환
		-------------------------------------------------------
		if SpawnType == "Spawn" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local setTile = nil
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				setTile = _BTLogic_New:getTile(originUnit, nil, "EmptyTileNearestToTheUnit_Team")[1]
				unit = units:GetChildByName(string.format("BTUnit_Shadow%d", shadowIdx))
				if unit.UnitInfo.use == false then
					table.insert(teamManager.OwnUnits, unit)
					for idx, unit in pairs(teamManager.OwnUnits) do
						log("Idx = ", idx, ", Unit = ", unit.UnitInfo.charID)
					end	
					log("INSERT_Shadow #teamManager.OwnUnits = ", #teamManager.OwnUnits)
				end
			elseif teamType == "Enemy" then
				setTile = _BTLogic_New:getTile(originUnit, nil, "EmptyTileNearestToTheUnit_Team")[1]
				unit = units:GetChildByName(string.format("EnemyUnit_Shadow%d", shadowIdx))
				if unit.UnitInfo.use == false then
					table.insert(teamManager.EnemyUnits, unit)
				end
			end
			
			-- unit.UnitBattleStatistics:RoundPropertyInitialize(charID)
			
			local unitInfo = unit.UnitInfo
			
			unitInfo.use = true
			if isvalid(unitInfo.setTile) == false then
				unitInfo:SetPropertyToServer("setTile", setTile, "All", true)
			end
			
			unitInfo:SetCharInfo(charID, level, 0)
			
			if teamType == "User" then
				_SynergyReadyDirectorLogic:S10007ShadowSpawnEffect(unit, true, userId)
			else
				_SynergyReadyDirectorLogic:S10007ShadowSpawnEffect(unit, false, userId)
				-- 원본 유닛이 장착한 아이템을 장착합니다.
				for _, equippedItemID in pairs(originUnit.UnitStatus.EquippedItemIDList) do
					local itemID = _UtilLogic:Split(equippedItemID, "_")[1]
					_ItemSetLogic:EquipItemThroughItemID(unit, itemID.."_copied")
				end
				-- 무적 및 은신 상태가 됩니다.
				_StatusChangeLogic:SetStatus(unit, unit, "SE0001", -1)
				_StatusChangeLogic:SetStatus(unit, unit, "SE0002", -1)
			end
			--[[_CustomizedBattleEffectService:PlayEffectAttached(
				"b6dbe98f30cd47b382d78af1665e60af",
				unit, Vector3.zero, 0, Vector3.one, false, nil, userId)]]--
			
			return true
		-------------------------------------------------------
		-- 배틀 진입
		-------------------------------------------------------
		elseif SpawnType == "InBattle" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				unit = units:GetChildByName(string.format("BTUnit_Shadow%d", shadowIdx))		
			elseif teamType == "Enemy" then
				unit = units:GetChildByName(string.format("EnemyUnit_Shadow%d", shadowIdx))
			end
			
			-- 원본 유닛이 장착한 아이템을 장착합니다.
			for _, equippedItemID in pairs(originUnit.UnitStatus.EquippedItemIDList) do
				local itemID = _UtilLogic:Split(equippedItemID, "_")[1]
				_ItemSetLogic:EquipItemThroughItemID(unit, itemID.."_copied")
			end
			
			-- 무적 및 은신 상태가 됩니다.
			_StatusChangeLogic:SetStatus(unit, unit, "SE0001", -1)
			_StatusChangeLogic:SetStatus(unit, unit, "SE0002", -1)
			
		-------------------------------------------------------
		-- 해제
		-------------------------------------------------------
		elseif SpawnType == "Clear" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				unit = units:GetChildByName(string.format("BTUnit_Shadow%d", shadowIdx))
				for idx, ownUnit in pairs(teamManager.OwnUnits) do
					if unit == ownUnit then
						table.remove(teamManager.OwnUnits, idx)
						for idx, unit in pairs(teamManager.OwnUnits) do
							log("Idx = ", idx, ", Unit = ", unit.UnitInfo.charID)
						end
						log("REMOVE_ #teamManager.OwnUnits = ", #teamManager.OwnUnits)
					end 
				end
			elseif teamType == "Enemy" then
				unit = units:GetChildByName(string.format("EnemyUnit_Shadow%d", shadowIdx))
			end
			
			_CustomizedBattleEffectService:PlayEffect(
				"ee242bec514848fea02f7ce3a8a5a537",
				unit, unit.TransformComponent.WorldPosition, 0, Vector3.one, false, userId)
				
			unit.UnitInfo:CleanCharInfo()
			
			return true
		end
		
	end

	@ExecSpace("ServerOnly")
	method boolean SpawnDoDo(string userId, string unitId, string teamType, string SpawnType, number level)
		-- 도도를 소환/소환 해제 하는 함수입니다.
		--------------------------------------------------------
		local setId = unitId .. "1"
		local userEntity = _UserService:GetUserEntityByUserId(userId) 
		local teamManager = userEntity.TeamManager
		local charInfoDB = _DataService:GetTable("CharacterInfo"):FindRow("CharID", "C00002")
		-------------------------------------------------------
		-- 소환
		-------------------------------------------------------
		
		if SpawnType == "Spawn" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local setTile = nil
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				setTile = userEntity.CurrentMap:GetChildByName("SpecialTile"):GetChildByName("DoDoTile_1")
				unit = units:GetChildByName("BTUnit_DoDo")
				if unit.UnitInfo.use == false then
					table.insert(teamManager.OwnUnits, unit)
				end
			elseif teamType == "Enemy" then
				setTile = userEntity.CurrentMap:GetChildByName("SpecialTile"):GetChildByName("DoDoTile_2")
				unit = units:GetChildByName("EnemyUnit_DoDo")
				if unit.UnitInfo.use == false then
					table.insert(teamManager.EnemyUnits, unit)
				end
			end
			
			local unitInfo = unit.UnitInfo
			
			-- unit.UnitBattleStatistics:RoundPropertyInitialize(unitId)
			
			if level == 3 then
				unitInfo:SetPropertyToServer("unitPhaseNumber", 2, nil, true)
			elseif level > 0 then
				unitInfo:SetPropertyToServer("unitPhaseNumber", 1, nil, true)
			end
			
			unitInfo.use = true
			unitInfo:SetPropertyToServer("setTile", setTile, "All", true)
			unitInfo:SetCharInfo(unitId, level, 0)
			unit.UnitAnimationComponent:PlayAnimation(1, "Idle", unit, userId)
			
			-- 1초 지연되어 보임
			_CustomizedBattleEffectService:SetEntityVisible(unit, false, userId)
			local reservateSetVisible = function()
				_CustomizedBattleEffectService:SetEntityVisible(unit, true, userId)
				unit.UnitAnimationComponent:PlayAnimation(1, "ForcedIdle", unit.Parent, unit.UnitInfo.OwnerId)
			end
			_TimerService:SetTimerOnce(reservateSetVisible, 0.4)
			
			return true
		-------------------------------------------------------
		-- 배틀 진입
		-------------------------------------------------------
		elseif SpawnType == "InBattle" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				unit = units:GetChildByName("BTUnit_DoDo")
			elseif teamType == "Enemy" then
				unit = units:GetChildByName("EnemyUnit_DoDo")
			end
			
			unit.UnitInfo.SkillComponent:StartBattle()
			unit.UnitAnimationComponent:PlayAnimation(1, "ForcedIdle", unit.Parent, unit.UnitInfo.OwnerId)
		-------------------------------------------------------
		-- 해제
		-------------------------------------------------------
		elseif SpawnType == "Clear" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				unit = units:GetChildByName("BTUnit_DoDo")
				for idx, ownUnit in pairs(teamManager.OwnUnits) do
					if unit == ownUnit then
						table.remove(teamManager.OwnUnits, idx)
					end 
				end
			elseif teamType == "Enemy" then
				unit = units:GetChildByName("EnemyUnit_DoDo")
			end
			
			unit.UnitInfo:CleanCharInfo()
			return true
		end
		
	end

	@ExecSpace("ServerOnly")
	method Entity SpawnOrbisStone(string userId, string teamType, string spawnType, number stoneIdx)
		-- 오르비스 소환석을 소환/소환 해제 하는 함수입니다.
		
		--------------------------------------------------------
		local charID = "C00003" 
		local setId = "C000031"
		local userEntity = _UserService:GetUserEntityByUserId(userId) 
		local teamManager = userEntity.TeamManager
		---@type UserDataRow
		local charInfoDB = nil
		-------------------------------------------------------
		-- 소환
		-------------------------------------------------------
		if spawnType == "Spawn" then
		
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local setTile = nil
			
			---@type Entity
			local unit = nil
			
			-- 아군이 가장 많이 모여있는 곳의 빈 칸에 소환
			if teamType == "User" then
				unit = units:GetChildByName(string.format("BTUnit_OrbisStone%d", stoneIdx))
				
				-- 이미 소환된 상태가 아니라면 소환 실행
				if unit.UnitInfo.setTile == nil then
					---@type Entity 
					local standardUnit = nil
					for i=1, #teamManager.OwnUnits do
						local targetUnit = teamManager.OwnUnits[i]
						if targetUnit.UnitInfo:IsOnFieldUnit() and targetUnit.UnitInfo:DoesHaveSynergy("S10021") then
							standardUnit = targetUnit
						end
					end
					
					local checkUnits = {}
					for _, unit in pairs(teamManager.OwnUnits) do
						if unit.UnitInfo:IsOnFieldUnit() then
							table.insert(checkUnits, unit)
						end
					end
					
					setTile = _BTLogic_New:getTile(standardUnit, checkUnits, "EmptyTileWithMostEnemies_Team_1")[1]
					
					if unit.UnitInfo.use == false then
						table.insert(teamManager.OwnUnits, unit)
					end
					
					local phaseType = userEntity.GameManager.PhaseType
					if phaseType ~= "Ready" then
						userEntity.GameManager.MyUnitCount += 1
					end
				-- 이미 소환된 상태라면 아무것도 하지 않아요
				else
					return nil
				end
				
			elseif teamType == "Enemy" then
				---@type Entity 
				local standardUnit = nil
				for i=1, #teamManager.EnemyUnits do
					local targetUnit = teamManager.EnemyUnits[i]
					if targetUnit.UnitInfo:IsOnFieldUnit() and targetUnit.UnitInfo:DoesHaveSynergy("S10021") then
						standardUnit = targetUnit
					end
				end
				
				local checkUnits = {}
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo:IsOnFieldUnit() then
						table.insert(checkUnits, unit)
					end
				end
				
				setTile = _BTLogic_New:getTile(standardUnit, checkUnits, "EmptyTileWithMostEnemies_Team_1")[1]
				
				unit = units:GetChildByName(string.format("EnemyUnit_OrbisStone%d", stoneIdx))
				if unit.UnitInfo.use == false then
					table.insert(teamManager.EnemyUnits, unit)
				end
			end
			
			-- unit.UnitBattleStatistics:RoundPropertyInitialize(charID)
			
			local unitInfo = unit.UnitInfo
			
			unitInfo.use = true
			unitInfo:SetPropertyToServer("setTile", setTile, "All", true)
			unitInfo:SetCharInfo(charID, 1, 0)
			
			
			-- Visible 처리 + 이펙트 재생
			_SynergyReadyDirectorLogic:S10021SpawnStone(unit, true, userId)
			
			return unit
		-------------------------------------------------------
		-- 배틀 진입
		-------------------------------------------------------
		elseif spawnType == "InBattle" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				unit = units:GetChildByName(string.format("BTUnit_OrbisStone%d", stoneIdx))
			elseif teamType == "Enemy" then
				unit = units:GetChildByName(string.format("EnemyUnit_OrbisStone%d", stoneIdx))
			end
			
			local unitInfo = unit.UnitInfo
			unitInfo.saveTile = unitInfo.setTile
			
			-- 데미지를 줍니다 (죽음에 이르도록)
			_StatusChangeLogic:KillUnitForce(nil, unit)
			return nil
		-------------------------------------------------------
		-- 해제
		-------------------------------------------------------
		elseif spawnType == "Clear" then
			local units = self.UnitsParentEntity[userId]
			
			---@type Entity
			local unit = nil
			
			if teamType == "User" then
				unit = units:GetChildByName(string.format("BTUnit_OrbisStone%d", stoneIdx))
				for idx, ownUnit in pairs(teamManager.OwnUnits) do
					if unit == ownUnit then
						table.remove(teamManager.OwnUnits, idx)
						for idx, unit in pairs(teamManager.OwnUnits) do
							log("Idx = ", idx, ", Unit = ", unit.UnitInfo.charID)
						end
						log("REMOVE_ #teamManager.OwnUnits = ", #teamManager.OwnUnits)
					end 
				end
			elseif teamType == "Enemy" then
				unit = units:GetChildByName(string.format("EnemyUnit_OrbisStone%d", stoneIdx))
			end
			
			-- 소환된 상태였다가 해제하는 경우
			if unit.UnitInfo.setTile ~= nil then
				_CustomizedBattleEffectService:PlayEffect(
					"ee242bec514848fea02f7ce3a8a5a537",
					unit, unit.TransformComponent.WorldPosition, 0, Vector3.one, false, userId)
					
				unit.UnitInfo:CleanCharInfo()
				
				return unit
				
		
			-- 중복 지우기 호출된 경우	
			else
				return nil
			end
		end
	end

	@ExecSpace("ServerOnly")
	method Entity GetEmptyPooledUnit(string userID, string teamType)
		-- 풀링한 엔티티 중 사용할 엔티티를 찾습니다.
		-----------------------------------------------------
		local units = self.UnitsParentEntity[userID]
		
		for _, unitSample in pairs(units.Children) do
			local unitSampleInfo = unitSample.UnitInfo
			
			if (not unitSampleInfo.use) and unitSampleInfo.TeamType == teamType then
				return unitSample
			end
		end
	end

	@ExecSpace("ServerOnly")
	method number BattleSetting_EnemyUnit(string userId, number modeVersion, string modeType, number modePresetNum, number modeLevel)
		-- 적 유닛을 소환하는 함수
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local teamBattleStatistics = user.TeamBattleStatistics
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local gameType = gameManager.ModeType
		local enemyUnitCount = 0
		---------------------------------------------------------
		local roundNum = gameManager.Round + (gameManager.Stage-1) * 3
		local specialShopManager = user.SpecialShopManager
		------------------------------------------------------------------------------------------------------------------
		--[[
			0. 기본 세팅
				0-a. 골드 계산
				0-b. 적 레벨 세팅
				0-c. 적 인원 수 및 1 스테이지 난이도 보정 작업
			1. 적 프리셋 선정
				1-a. 선택된 모드에 따라 맞는 프리셋 리스트 가져오기
				1-b. 유닛 수 체크해서 프리셋 필요한지 확인하기
			2. 룬카드 세팅 (프리셋 ID가 없으면 생략)
				2-a. 등급별 룬카드 리스트 불러오기
				2-b. 획득할 룬카드 등급 계산
				2-c. 룬카드 세팅 준비
				2-d. Forced, Synergy 등 테이블 내 다른 형태로 들어간 값을 룬카드 ID로 변환 후 세팅
			3. 아이템 사용 개수 체크
				3-a. 상징 아이템이 필요한지 체크
				3-b. 아이템 사용 개수 체크
			4. 캐릭터 세팅
				4-a. 프리셋 ID가 존재하는 경우, 유닛 ID 및 코스트 테이블 생성
				4-b. 유닛 생성에 드는 최소 비용 처리
				4-c. 유닛 레벨 세팅
				4-d. 유닛 소환
			5. 아이템 세팅
				5-a. 상징 아이템부터 세팅
				5-b. 아이템 세팅
			6. 적 유닛 스탯 갱신
		]]--
		------------------------------------------------------------------------------------------------------------------
		-- 0. 기본 세팅
		------------------------------------------------------------------------------------------------------------------
		-- 0-a. 골드 계산
		local singleSetRoundGoldsTable = {3, 4, 5, 6, 7, 8, 9, 10}
		local rankSetRoundGoldsTable = {5, 7, 9, 11, 13, 15}
		
		-- 기본금 + 전투 직후 보상 (난이도 별 조정)
		local GetGolds = 0
		if gameType == "Rank" then
			local goldSetIndex = 1
			local levelcut = {4, 7, 10, 13, 16}
			
			for _, cut in pairs(levelcut) do
				if modeLevel > cut then
					goldSetIndex += 1
				else
					break
				end
			end
			GetGolds = rankSetRoundGoldsTable[goldSetIndex] * roundNum
		else
			GetGolds = singleSetRoundGoldsTable[modeLevel] * roundNum
		end
		---------------------------------------------------------
		-- 0-b. 적 레벨 세팅
		local setLevel = math.min(math.floor(roundNum/3) + 3, 10)
		---------------------------------------------------------
		-- 0-c. 적 인원 수 및 1 스테이지 난이도 보정 작업
		local unitNum = setLevel
		
		--튜토리얼 난이도 보정
		if gameManager.ModeType == "Tutorial" then
			unitNum = setLevel-1
		end
		-- 1스테이지 난이도 보정
		if gameManager.Stage == 1 then
			unitNum = gameManager.Round
		end
		
		
		
		------------------------------------------------------------------------------------------------------------------
		-- 1. 적 프리셋 선정
		------------------------------------------------------------------------------------------------------------------
		-- 1-a. 선택된 모드에 따라 맞는 프리셋 리스트 가져오기
		local mType = _UtilLogic:Split(modeType, "_")
		if mType[1] == "Single" then
			-- 선택한 확장 버전 맞춰 진행
		elseif mType[1] == "Challenge" then
			-- 버전 데이터 가져와서 알맞은 Preset 데이터 넣어줘야 함
			local chNum = mType[2]
			local setSeason = _DataService:GetTable("ChallengeModeInfo"):FindRow("ChallengeID", string.format("CH%d", 10000 + chNum)):GetItem("SetSeason")
			modeVersion = tonumber(setSeason)
		elseif mType[1] == "Rank" then
			-- 버전 데이터 가져와서 알맞은 Preset 데이터 넣어줘야 함
			local chNum = mType[2]
			local setVersion = _DataService:GetTable("VersionInfo"):FindRow("SeasonID", string.format("%d.%d", _ModeDataLogic.Season, _ModeDataLogic.OrdinalNumber)):GetItem("RankSeason")
			modeVersion = tonumber(setVersion)
		elseif mType[1] == "Tutorial" then
			-- 튜토리얼은 확장버전 없이 진행
		end
		
		local enemyPresetDataSet = _DataService:GetTable(string.format("EnemyPreset_%d_%d", math.floor(gameManager.ModeSetVersion),  modePresetNum))
		
		-- 캐릭터 ID, Cost 테이블
		---@type table<string>
		local charIDTable = {}
		local charCostTable = {}
		
		local getEnemyPresetIDs = {}
		local getPresetID = ""
		
		---------------------------------------------------------
		-- 1-b. 유닛 수 체크해서 프리셋 필요한지 확인하기
		
		-- 필요한 유닛이 2기 이하인 경우에는 따로 프리셋 사용 없이 임의로 유닛 2기 아무렇게나 넣어줍니다.
		if unitNum <= 2 then
			local maxCharCost = math.floor( (modePresetNum+2)/3 )
			
			
			for i = 1, unitNum do
				local charID = ""
				local charCost = _UtilLogic:RandomIntegerRange(1, maxCharCost)
				local charIDNum = charCost * 10000 + _UtilLogic:RandomIntegerRange(1, 13)
			
				charID = string.format("C%d", charIDNum)
				table.insert(charIDTable, charID)
				table.insert(charCostTable, charCost)
			end
			
			teamBattleStatistics:SetProperty("SetEnemyPresetID", "-")
		else
			-- 사용 가능한 프리셋 ID 가져오기
			for i = 1, enemyPresetDataSet:GetRowCount() do
				local presetRow = enemyPresetDataSet:GetRow(i)
				local unitCount = tonumber( presetRow:GetItem("UnitCount") )
				local setSeason = tonumber( presetRow:GetItem("SetSeason") )
				
				-- 30%는 확장 시즌 프리셋, 70%는 기본 프리셋
				local per = _UtilLogic:RandomDouble()
				
				
				if per <= 0.3 and unitCount == unitNum and ( setSeason == modeVersion ) then
					table.insert(getEnemyPresetIDs, enemyPresetDataSet:GetRow(i):GetItem("PresetID"))
				elseif per > 0.3 and unitCount == unitNum and ( setSeason == math.floor(modeVersion) ) then
					table.insert(getEnemyPresetIDs, enemyPresetDataSet:GetRow(i):GetItem("PresetID"))
				end
			end
			
			-- 프리셋 선정
			getPresetID = getEnemyPresetIDs[_UtilLogic:RandomIntegerRange(1, #getEnemyPresetIDs)]
		
			teamBattleStatistics:SetProperty("SetEnemyPresetID", getPresetID)
		end
		
		
		------------------------------------------------------------------------------------------------------------------
		-- 2. 룬카드 세팅
		-- 프리셋 ID가 없으면 생략
		------------------------------------------------------------------------------------------------------------------
		local runeDataSet = _DataService:GetTable("RuneInfo")
		local setRuneTable = {}
		local needSynergyItemID = "-"
		if getPresetID ~= "" then
			-- 2-a. 등급별 룬카드 리스트 불러오기
			local normalRuneIDs = {}
			local rareRuneIDs = {}
			local epicRuneIDs = {}
			local legendRuneIDs = {}
			
			-- NeedSynergy 체크
			local preset = enemyPresetDataSet:FindRow("PresetID", getPresetID)
			local needSynergy = preset:GetItem("NeedSynergy")
			
			if needSynergy ~= "-" then
				local needtypes = _UtilLogic:Split(needSynergy, "_")
				
				if needtypes[2] == "Rune" then
					table.insert(normalRuneIDs, string.format("Forced_%s_Add", needtypes[1]))
				elseif needtypes[2] == "All" then
					table.insert(normalRuneIDs, string.format("Synergy_%s_Add", needtypes[1]))
				end
			end
			
			-- UseRuneType 체크
			local useRuneTypes = preset:GetItem("UseRuneType")
			if useRuneTypes ~= "-" then
				local types = _UtilLogic:Split(useRuneTypes, "/")
				for _, type in pairs(types) do
					if type ~= "Battle" then
						local typeInfo = _UtilLogic:Split(type, "_")
						
						if typeInfo[3] == "Add" then
							local setRuneID = runeDataSet:FindRow("EnemyUseType", string.format("Synergy_Add_%s", typeInfo[2])):GetItem("RuneID")
							table.insert(normalRuneIDs, setRuneID)
						elseif typeInfo[3] == "Normal" then
							local setRuneID = runeDataSet:FindRow("EnemyUseType", string.format("Synergy_%s", typeInfo[2])):GetItem("RuneID")
							table.insert(rareRuneIDs, setRuneID)
						end
					end
				end
			end
			
			-- 룬카드 리스트 테이블 작성
			for idx = 1, runeDataSet:GetRowCount() do
				local runeId = runeDataSet:GetRow(idx):GetItem("RuneID")
				local grade = runeDataSet:GetRow(idx):GetItem("Grade")
				local runeType = runeDataSet:GetRow(idx):GetItem("EnemyUseType")
				
				if runeType ~= "Ready" and runeType ~= "Battle_BlankUnit" and runeType ~= "Battle_AddUnit" then
					if grade == "Normal" and string.sub(runeType, 1, 11) ~= "Synergy_Add" then
						table.insert(normalRuneIDs, runeId)
					elseif grade == "Rare" and string.sub(runeType, 1, 8) ~= "Synergy_" then
						table.insert(rareRuneIDs, runeId)
					elseif grade == "Epic" then
						table.insert(epicRuneIDs, runeId)
					elseif grade == "Legendary" then
						table.insert(legendRuneIDs, runeId)
					end
				end
			end
			
			local runeIdTables = {normalRuneIDs, rareRuneIDs, epicRuneIDs, legendRuneIDs}
			---------------------------------------------------------
			-- 2-b. 획득할 룬카드 등급 계산
			local runeShopProbTableRow = _DataService:GetTable("RuneShopProb"):FindRow("Level", string.format("%d", unitNum))
			
			local gradeProbTable = {}
			local gradeTable = {
				"Normal",
				"Rare",
				"Epic",
				"Legendary"
			}
			
			local gradeCostTable = {4, 7, 12, 25}
			local singleGoldAmountTable = {32, 36, 40, 44, 48, 52, 56, 60}
			local rankGoldAmountTable = {45, 50, 55, 60, 65}
			
			-- 룬카드에 사용할 비용 계산
			local checkedGoldAmount = 0
			if gameType == "Rank" then
				checkedGoldAmount = math.floor( rankGoldAmountTable[modePresetNum] * roundNum / 24 )
			else
				checkedGoldAmount = math.floor( singleGoldAmountTable[modeLevel] * roundNum / 24 )
			end
			
			local gradeNumTable = {}
			local runeTotalCost = 0
			
			
			
			-- 룬 카드 등급 구분해서 계산하기
			for i = 1, 5 do
				local loop = true
				for j = 4, 1, -1 do
					if gradeCostTable[j] * 2 <= checkedGoldAmount then
						table.insert(gradeNumTable, 1, j)
						runeTotalCost += gradeCostTable[j]
						checkedGoldAmount -= gradeCostTable[j]
						break
					elseif j == 1 then
						loop = false
					end
				end
				
				if not loop then
					break
				end
			end
			
			GetGolds -= runeTotalCost
			---------------------------------------------------------
			-- 2-c. 룬카드 세팅 준비
			
			-- 시너지 더해주는 룬카드가 꼭 필요한 경우
			local forcedToSynergyAdd = false
			if string.sub(normalRuneIDs[1], 1, 6) == "Forced" then
				-- 상징으로도 해결이 불가능하다면
				forcedToSynergyAdd = true
			end
			
			-- 등급 내 룬 ID 랜덤하게 받아오기
			for idx, gradeNum in pairs(gradeNumTable) do
				--------------------------------------------------
				local runeIdx = _UtilLogic:RandomIntegerRange(1, #runeIdTables[gradeNum])
				local setRuneID = runeIdTables[gradeNum][runeIdx]
				--------------------------------------------------
				-- 강제 변경이 필요한지 체크
				if forcedToSynergyAdd then
					setRuneID = normalRuneIDs[1]
					gradeNumTable[idx] = 1
					gradeNum = 1
					runeIdx = 1
					forcedToSynergyAdd = false
				end
				--------------------------------------------------
				-- 룬 획득
				table.insert(setRuneTable, setRuneID)
				
				table.remove(runeIdTables[gradeNum], runeIdx)
			end
			
			-- 강제할 룬카드가 없던 경우, 추가
			if forcedToSynergyAdd then
				table.insert(setRuneTable, normalRuneIDs[1])
				
				-- 룬카드 4원 더 쓰는걸로
				GetGolds -= gradeCostTable[1]
			end
			
			---------------------------------------------------------
			-- 2-d. Forced, Synergy 등 테이블 내 다른 형태로 들어간 값을 룬카드 ID로 변환 후 세팅
			-- setRuneTable에 룬카드 ID 형태로 들어가지 않은 경우, 형태에 맞춰 ID로 변환 후 룬카드를 세팅합니다.
			
			-- ID 변환
			if needSynergy ~= "-" then
				-- synergy 해결이 안되어있으면 상징 아이템 추가
				local needSynergyType =_UtilLogic:Split(needSynergy, "_")
				
				if needSynergyType[2] == "Item" then
					-- 아이템으로 해결해야하는 프리셋은 무조건 상징 아이템 추가
					local itemID = string.format( "EI%s", string.sub(needSynergyType[1], 2, 6) )
					needSynergyItemID = itemID
					
				elseif needSynergyType[2] == "All" then
					-- 룬으로 해결이 되었는지 확인
					local checkedRuneType = string.format("Synergy_Add_%s", needSynergyType[1])
					local setType = string.format("Synergy_%s_Add", needSynergyType[1])
					local checked = false
						
					for idx, checkRuneID in pairs(setRuneTable) do
						if checkRuneID == setType then
							checked = true
							setRuneTable[idx] = runeDataSet:FindRow("EnemyUseType", checkedRuneType):GetItem("RuneID")
						end
					end
					
					-- 해당 룬을 가지고 있지 않다면 상징 아이템 추가
					if not checked then
						local itemID = string.format( "EI%s", string.sub(needSynergyType[1], 2, 6) )
						needSynergyItemID = itemID
					end
				elseif needSynergyType[2] == "Rune" then
					local checkedRuneType = string.format("Synergy_Add_%s", needSynergyType[1])
					local setType = string.format("Forced_%s_Add", needSynergyType[1])
					
					for idx, checkRuneID in pairs(setRuneTable) do
						if checkRuneID == setType then
							setRuneTable[idx] = runeDataSet:FindRow("EnemyUseType", checkedRuneType):GetItem("RuneID")
						end
					end
				end
			end
			
			-- 룬카드 세팅
			for _, runeID in pairs(setRuneTable) do
				specialShopManager:AddRCComponent(runeID, false, #teamManager.EnemyOwnedRunes, 0)
			end
		end
		
		
		------------------------------------------------------------------------------------------------------------------
		-- 3. 아이템 사용 개수 체크
		-- stage * 15골드를 남긴 채로 완성 아이템을 몇개나 소지할 수 있는지 체크
		------------------------------------------------------------------------------------------------------------------
		-- 3-a. 상징 아이템이 필요한지 체크
		-- 프리셋 아이디가 없으면 생략
		--------------------------------------------------
		-- 3-b. 아이템 사용 개수 체크
		local nItemPurchaseCost = 13				-- 완성 아이템 비용
		local sItemPurchaseCost = 15				-- 상징 아이템 비용
		
		local singleItemNumTable = {0.25, 0.35, 0.45, 0.55, 0.65, 0.75, 0.85, 0.95}
		local rankItemNumTable = {0.45, 0.65, 0.85, 1.05, 1.25}
		
		local itemStack = 0
		if gameType == "Rank" then
			itemStack = roundNum * rankItemNumTable[modePresetNum]
		else
			itemStack = roundNum * singleItemNumTable[modeLevel]
		end
		local nItemCount = math.floor(itemStack / 2)
		
		if needSynergyItemID ~= "-" then
			nItemCount = math.max(0, nItemCount-1)
			GetGolds -= sItemPurchaseCost
		end
		
		-- 남은 골드량 계산
		GetGolds -= nItemCount * nItemPurchaseCost
		------------------------------------------------------------------------------------------------------------------
		-- 4. 캐릭터 세팅
		-- 남은 골드 전부 소진
		-- charIDTable : 프리셋 내 유닛 ID 테이블
		-- charCostTable : 유닛 별 코스트 테이블
		------------------------------------------------------------------------------------------------------------------
		-- 4-a. 프리셋 ID가 존재하는 경우, 유닛 ID 및 코스트 테이블 생성
		if getPresetID ~= "" then
			local preset = enemyPresetDataSet:FindRow("PresetID", getPresetID)
			
			-- 캐릭터 구성 및 최소 비용 합 계산
			for i = 1, unitNum do
				local charID = preset:GetItem(string.format("CharID_%d", i))
				local charCost = tonumber( string.sub(charID, 2, 2) )
				
				table.insert(charIDTable, charID)
				table.insert(charCostTable, charCost)
			end
		end
		--------------------------------------------------
		-- 4-b. 유닛 생성에 드는 최소 비용 처리
		-- 캐릭터 레벨을 올릴 때마다 사용하는 골드 : 레벨을 올리는데 드는 기물 수의 총 비용 + 리롤 1번
		for i = 1, unitNum do
			GetGolds -= charCostTable[i] + 2
		end
		
		-- 만약 남은 돈이 음수라면, 아이템에 쓰일 돈을 다시 가져옴
		if GetGolds < 0 then
			for i = 1, math.floor(itemStack / 2) do
				if nItemCount > 0 and GetGolds < 0 then
					GetGolds += 13
					nItemCount -= 1
				else
					break
				end
			end
		end
		--------------------------------------------------
		-- 4-c. 유닛 레벨 세팅
		---@type table<number>
		local charLevelTable = {}
		
		for i = 1, unitNum do
			table.insert(charLevelTable, 1)
		end
		
		-- 골드가 다 떨어질 때까지 레벨 세팅
		local needCost = {2, 6, 18}
		while GetGolds > 2 do
			---@type table<number>
			local charIdxTable = {}
			local minLevel = 3
			local minCost = 5
			
			for i = 1, unitNum do
				-- 가장 낮은 레벨대 유닛들 체크
				if minLevel > charLevelTable[i] then
					table.clear(charIdxTable)
					table.insert(charIdxTable, i)
					minLevel = charLevelTable[i]
					minCost = charCostTable[i]
				elseif minLevel == charLevelTable[i] then
					-- 가장 낮은 코스트 유닛들 체크
					if minCost > charCostTable[i] then
						table.clear(charIdxTable)
						table.insert(charIdxTable, i)
						minCost = charCostTable[i]
					elseif minCost == charCostTable[i] then
						table.insert(charIdxTable, i)
					end
				end
			end
			
			-- 더 이상 올릴 유닛이 없다면
			if minLevel == 3 then
				break
			end
			
			-- 현재 남은 돈으로 올릴 수 있는 지 유닛 체크
			for idx = #charIdxTable, 1, -1 do
				if GetGolds < (charCostTable[charIdxTable[idx]] + 2) * needCost[minLevel] then
					table.remove(charIdxTable, idx)
				end
			end
			
			-- 마찬가지로 더 이상 올릴 유닛이 없다면
			if #charIdxTable <= 0 then
				break
			end
			
			-- 레벨 업 시킬 유닛 선정 및 적용
			local setIdxNum = charIdxTable[_UtilLogic:RandomIntegerRange(1, #charIdxTable)]
			
			charLevelTable[setIdxNum] += 1
			GetGolds -= ( (charCostTable[setIdxNum]+2) * needCost[minLevel])
		end
		--------------------------------------------------
		-- 4-d. 유닛 소환
		for i = 1, unitNum do
			-- 캐릭터 ID 받아오기
			local charCost = charCostTable[i]
			local charID = charIDTable[i]
			
			local enemy = self:SpawnEnemyUnit(userId, charID, charLevelTable[i], charCost)
			enemy.UnitAnimationComponent:PlayAnimation(1, "ForcedIdle", enemy.Parent, userId)
			enemyUnitCount += 1
		end
		
		------------------------------------------------------------------------------------------------------------------
		-- 5. 아이템 세팅
		------------------------------------------------------------------------------------------------------------------
		---@type table<Entity>
		local setUnits = {}
		local charMostItemTable = _DataService:GetTable("CharMostItemSet")
		
		for _, unit in pairs(teamManager.EnemyUnits) do
			local charID = unit.UnitInfo.charID
			local setItemRow = charMostItemTable:FindRow("CharID", charID)
			
			if isvalid(setItemRow) then
				table.insert(setUnits, unit)
				unit.UnitStatus:SetProperty("EquippedItemIDList", nil, "clear")
			end
		end
		--------------------------------------------------
		-- 5-a. 상징 아이템부터 세팅
		while #setUnits >= 1 do
			local unitIdx = _UtilLogic:RandomIntegerRange(1, #setUnits)
			local setUnit = setUnits[unitIdx]
			
			if needSynergyItemID == "-" then
				break
			else
				if not setUnit.UnitInfo:DoesHaveSynergy( string.format( "S%s", string.sub( needSynergyItemID, 3, 7 ) ) ) then
					_ItemSetLogic:EquipItemThroughItemID(setUnit, needSynergyItemID)
					break
				end
			end
			
			table.remove(setUnits, unitIdx)
		end
		--------------------------------------------------
		-- 5-b. 아이템 세팅
		
		-- 포지션에 따른 아이템 설정
		--------------------------------
		-- 아이템 장착 우선 순위는 다음과 같습니다.
		-- a. 레벨이 높은 순
		-- b. 코스트가 높은 순
		-- c. 그 외 다른 사항은 없습니다.
		--------------------------------
		
		-- 돈이 좀 남았다면 아이템 개수 추가
		nItemCount += math.floor(GetGolds/13)
		
		table.clear(setUnits)
		for _, unit in pairs(teamManager.EnemyUnits) do
			local charID = unit.UnitInfo.charID
			local setItemRow = charMostItemTable:FindRow("CharID", charID)
			
			if isvalid(setItemRow) then
				table.insert(setUnits, unit)
			end
			
			unit.UnitItem:ClearAllStacks()
		end
		
		for i = 1, nItemCount do
			-- 더 이상 장착할 유닛이 없는 경우
			if #setUnits <= 0 then
				break
			end
			
			local unitTable = {}
			local maxLevel = 1
			local maxCost = 1
			
			-- 우선순위 체크
			for _, unit in pairs(setUnits) do
				if maxLevel < unit.UnitInfo.level then
					table.clear(unitTable)
					table.insert(unitTable, unit)
					maxLevel = unit.UnitInfo.level
					maxCost = unit.UnitInfo.cost
				elseif maxLevel == unit.UnitInfo.level then
					if maxCost < unit.UnitInfo.cost then
						table.clear(unitTable)
						table.insert(unitTable, unit)
						maxCost = unit.UnitInfo.cost
					elseif maxCost == unit.UnitInfo.cost then
						table.insert(unitTable, unit)
					end
				end
			end 
			
			-- 더 이상 장착할 유닛이 없는 경우
			if #unitTable == 0 then
				break
			end
			
			-- 아이템 장착
			local setUnitIdx = _UtilLogic:RandomIntegerRange(1, #unitTable)
			local setUnit = unitTable[setUnitIdx]
			local charID = setUnit.UnitInfo.charID
			
			local setItemIdx = _UtilLogic:RandomIntegerRange(1, 8)
			local setItemRow = charMostItemTable:FindRow("CharID", charID)
			
			if isvalid(setItemRow) then
				local setItemId = setItemRow:GetItem(string.format("ItemID_%d", setItemIdx))
				_ItemSetLogic:EquipItemThroughItemID(setUnit, setItemId)
			else
				log_error(charID, "Can't Equip Item.")
			end
			
			-- 아이템 3개를 장착한 경우, 장착 가능 유닛 테이블에서 제외
			if #setUnit.UnitStatus.EquippedItemIDList >= 3 then
				for idx, checkUnit in pairs(setUnits) do
					if checkUnit == setUnit then
						table.remove(setUnits, idx)
						break
					end
				end
			end
		end
		
		------------------------------------------------------------------------------------------------------------------
		-- 6. 적 유닛 스탯 갱신
		------------------------------------------------------------------------------------------------------------------
		--[[
		for _, unit in pairs(teamManager.EnemyUnits) do
			unit.UnitItem:RefreshItemStatus()
			unit.UnitSynergy:InitAllProperties()
			unit.UnitStatus:SetUnitStatus(false)
		end
		]]--
		
		return enemyUnitCount
	end

	@ExecSpace("ServerOnly")
	method void BattleSetting_EnemySynergyCheck(string userId)
		-- 적 시너지를 체크해서 활성화된 시너지에 따라 추가 작업을 하는 코드
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local units = self.UnitsParentEntity[userId]
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		local synergyManager = user.SynergyManager_New
		
		local charStatusTable = _DataService:GetTable("CharacterStatus")
		local charInfoTable = _DataService:GetTable("CharacterInfo")
		---------------------------------------------------------
		-- 적 유닛에 따라 시너지 체크해서 넣어두기
		---@type table<string>
		local checkedCharIDs = {}
		local charSynergyDB = _DataService:GetTable("CharacterSynergy")
		
		---@type table<string, table<string, number>>
		local equippedEmblemItems = {} -- key:CharID, value:table<string, number> (charID 같은 캐릭터끼리 같은 상징 낀 경우 예방)
		
		for _, enemy in pairs(teamManager.EnemyUnits) do
			local charId = enemy.UnitInfo.charID
			
			-- 중복된 캐릭터인지 체크
			local checked = false
			for _, checkedId in pairs(checkedCharIDs) do
				if checkedId == charId then
					checked = true
					break
				end
			end
			
			-- 중복 아닌 경우, 기본 시너지 더함
			if not checked then
				table.insert(checkedCharIDs, charId)
				local charSynergyRow = charSynergyDB:FindRow("CharID", charId)
				local synergyCount = tonumber(charSynergyRow:GetItem("SynergyCount"))
				for i = 1, synergyCount do
					local synergyId = charSynergyRow:GetItem("Synergy_" .. math.floor(i))
					teamManager:GetEnemyOwnedFieldSynergyCount(synergyId, 1)
				end
			end
			
			-- 장착 아이템 검사
			for _, equippedItemID in pairs(enemy.UnitStatus.EquippedItemIDList) do
				local itemID = _UtilLogic:Split(equippedItemID, "_")[1]
				local itemID_head = string.sub(itemID, 1, 2)
				local itemID_tail = string.sub(itemID, 3, -1)
				if itemID_head == "EI" then
					if isvalid(equippedEmblemItems[charId]) == false then
						equippedEmblemItems[charId] = {}
					end
					equippedEmblemItems[charId]["S"..itemID_tail] = 1
				end
			end
		end
		
		-- 아이템에 의한 시너지 숫자 증가를 적용합니다.
		for charID, emblemSynergies in pairs(equippedEmblemItems) do
			for synergyID, count in pairs(emblemSynergies) do
				teamManager:GetEnemyOwnedFieldSynergyCount(synergyID, 1)
			end
		end
		---------------------------------------------------------
		--[[
			그림자 : shadow 소환
			방해꾼 : 가면 장착
			오르비스 : 마법석 소환
			기사단장 : 정해진 자리에 유닛 올리기
			아랫마을 : 아이템 장착
			마스코트 : 비율 계산해서, 그에 맞게 캐릭터 등급 올리거나 아이템 추가 등록
		]]--
		local synCount_Enemy_S10001 = teamManager.EnemyOwnedFieldSynergy["S10001"]
		local synCount_Enemy_S10007 = teamManager.EnemyOwnedFieldSynergy["S10007"]
		local synCount_Enemy_S10011 = teamManager.EnemyOwnedFieldSynergy["S10011"]
		local synCount_Enemy_S10021 = teamManager.EnemyOwnedFieldSynergy["S10021"]
		local synCount_Enemy_S10025 = teamManager.EnemyOwnedFieldSynergy["S10025"]
		local synCount_Enemy_S10031 = teamManager.EnemyOwnedFieldSynergy["S10031"]
		---------------------------------------------------------
		-- 그림자 Shadow 소환
		if isvalid(synCount_Enemy_S10007) then
			synergyManager:S10007_SpawnShadowReadyPhase(synCount_Enemy_S10007, "Enemy")
		end
		
		-- 방해꾼 가면 장착
		if isvalid(synCount_Enemy_S10011) then
			-- 가면을 장착할 수 있는 숫자인지 체크
			if synCount_Enemy_S10011 >= 3 then
				---@type table<Entity>
				local itemEquippableUnits = {}
				
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo:DoesHaveSynergy("S10011") and unit.UnitInfo.IsItemEquippable and #unit.UnitStatus.EquippedItemIDList < 3 then
						table.insert(itemEquippableUnits, unit)
					end
				end
				
				if #itemEquippableUnits > 0 then
					local setItemUnitIdx = _UtilLogic:RandomIntegerRange(1, #itemEquippableUnits)
					itemEquippableUnits[setItemUnitIdx].UnitStatus:SetProperty("EquippedItemIDList", "SI10001", "insert,-1")
				end
			end
		end
		
		if isvalid(synCount_Enemy_S10031) then
			-- 아랫마을 시너지 개수 체크
			local getItem = 0
			if synCount_Enemy_S10031 >= 10 then
				getItem = 7
			elseif synCount_Enemy_S10031 >= 8 then
				getItem = 6
			elseif synCount_Enemy_S10031 >= 5 then
				getItem = 3
			elseif synCount_Enemy_S10031 >= 3 then
				getItem = 1
			end
			
			-- 시너지가 활성화된 경우
			if getItem > 0 then
				local itemOrder = synergyManager.Enemy_SynergyStack["S10031_ItemOrder"]
				local itemSetTable = {}
				for i = 1, 7 do
					local itemNum = itemOrder % 10
					table.insert(itemSetTable, 1, string.format("SI1000%d", itemNum))
					
					itemOrder = math.floor(itemOrder / 10)
				end
				---@type table<Entity>
				local itemEquippableUnits = {}
				
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo.IsItemEquippable and #unit.UnitStatus.EquippedItemIDList < 3 then
						table.insert(itemEquippableUnits, unit)
					end
				end
				
				-- 아이템 장착
				for i = 1, getItem do
					if #itemEquippableUnits > 0 then
						local setItemUnitIdx = _UtilLogic:RandomIntegerRange(1, #itemEquippableUnits)
						local setUnit = itemEquippableUnits[setItemUnitIdx]
						
						setUnit.UnitStatus:SetProperty("EquippedItemIDList", itemSetTable[i], "insert,-1")
						
						-- 아이템 3개를 장착한 경우, 장착 가능 유닛 테이블에서 제외
						if #setUnit.UnitStatus.EquippedItemIDList >= 3 then
							for idx, checkUnit in pairs(itemEquippableUnits) do
								if checkUnit == setUnit then
									table.remove(itemEquippableUnits, idx)
									break
								end
							end
						end
					else
						break
					end
				end
			end
		end
		
		-- 오르비스 마법석 소환
		if isvalid(synCount_Enemy_S10021) then
			synergyManager:S10021_SpawnStoneReadyPhase(synCount_Enemy_S10021, "Enemy")
		end
		
		-- 기사단장 : 랜덤한 유닛 기사단장 자리로 이동
		if isvalid(synCount_Enemy_S10025) then
			-- 기사단장 효과가 활성화 되어있는지 체크
			if synCount_Enemy_S10025 >= 2 then
				
				local saintAreaPos = synergyManager.Enemy_SynergyStack["S10025_Pos"]
				local row = math.floor(saintAreaPos/1000)
				local col = math.floor(saintAreaPos - row*1000)
				
				local tilehorizonNode = col * 2 - (row%2)
				local tileverticalNum = row
				
				local saintTile = gameManager.RoomTile[math.floor(tilehorizonNode) .. "," .. math.floor(tileverticalNum)]
				
				---@type table<Entity>
				local ableUnits = {}
				
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo.charID ~= "C00000" and unit.UnitInfo.charID ~= "C00001" and unit.UnitInfo.charID ~= "C00002" and unit.UnitInfo.charID ~= "C00003" then
						table.insert(ableUnits, unit)
					end
				end
				
				if #ableUnits > 0 then
					local setUnitIdx = _UtilLogic:RandomIntegerRange(1, #ableUnits)
					ableUnits[setUnitIdx].UnitInfo:SetPropertyToServer("setTile", saintTile, "All", true)
				end
			end
		end
		
		-- 마스코트 : 비율 계산해서, 그에 맞게 캐릭터 등급 올리거나 아이템 추가 등록
		if isvalid(synCount_Enemy_S10001) then
			-- 라운드 체크
			local round = (gameManager.Stage - 1) * 3 + gameManager.Round
			local charMostItemTable = _DataService:GetTable("CharMostItemSet")
			
			-- 마스코트 시너지 개수 체크 (0.8만큼 값 보정)
			local ratio = 0
			if synCount_Enemy_S10001 >= 10 then
				ratio = 32
			elseif synCount_Enemy_S10001 >= 7 then
				ratio = 24
			elseif synCount_Enemy_S10001 >= 5 then
				ratio = 16
			elseif synCount_Enemy_S10001 >= 3 then
				ratio = 8
			end
			
			-- 시너지가 활성화된 경우
			if ratio > 0 then
				local stackedValue = ratio * round
				local convertedValue = math.floor((stackedValue ^ 1.25) * 0.1) -- 골드 가치로 환산
				
				-- 시너지 가진 유닛들
				---@type table<Entity>
				local s1UnitTable = {}
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo:DoesHaveSynergy("S10001") then
						table.insert(s1UnitTable, unit)
					end
				end
				
				-- 아이템 장착 가능한 유닛들
				---@type table<Entity>
				local itemEquippableUnits = {}
				
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo.IsItemEquippable and #unit.UnitStatus.EquippedItemIDList < 3 then
						table.insert(itemEquippableUnits, unit)
					end
				end
				
				while convertedValue < 7 do
					local per = _UtilLogic:RandomDouble()
					
					-- 25% : 아이템 / 75% : 캐릭터 레벨업
					if per <= 0.25 then
						-- 아이템
						if convertedValue < 7 then
							break
						else
							-- 캐릭터 선택
							local idx = _UtilLogic:RandomIntegerRange(1, #itemEquippableUnits)
							local setUnit = itemEquippableUnits[idx]
							local charID = setUnit.UnitInfo.charID
							
							if convertedValue < 10 then
								-- 재료 아이템 획득 : 7 Gold
								convertedValue -= 7
								log("convertedValue_GetMItem = ", convertedValue)
								
								-- 아이템 중 랜덤 선택
								local setItemIdx = _UtilLogic:RandomIntegerRange(1, 8)
								local setItemID = string.format("MI%d", 10000 + setItemIdx)
								
								_ItemSetLogic:EquipItemThroughItemID(setUnit, setItemID)
							else
								-- 완성 아이템 획득 : 10 Gold
								convertedValue -= 10
								log("convertedValue_GetNItem = ", convertedValue)
								
								-- 추천 아이템 중 랜덤 선택
								local setItemIdx = _UtilLogic:RandomIntegerRange(1, 8)
								local setItemRow = charMostItemTable:FindRow("CharID", charID)
								
								if isvalid(setItemRow) then
									local setItemId = setItemRow:GetItem(string.format("ItemID_%d", setItemIdx))
									_ItemSetLogic:EquipItemThroughItemID(setUnit, setItemId)
								else
									log_error(charID, "Can't Equip Item.")
									break
								end
							end
							
							-- 아이템 3개를 장착한 경우, 장착 가능 유닛 테이블에서 제외
							if #setUnit.UnitStatus.EquippedItemIDList >= 3 then
								for idx, checkUnit in pairs(itemEquippableUnits) do
									if checkUnit == setUnit then
										table.remove(itemEquippableUnits, idx)
										break
									end
								end
							end
						end
					else
						-- 캐릭터 레벨업
						local charLVupCostTable = {2, 8, 18, 32, 50}
						---@type table<Entity, number>
						local ableUnitsCostTable = {}
						local ableUnitsTable = {}
						for _, unit in pairs(s1UnitTable) do
							local unitCost = unit.UnitInfo.cost
							local unitLevel = unit.UnitInfo.level
							
							-- 레벨업이 가능한 유닛인가
							if unitLevel < 3 then
								local checkCost = charLVupCostTable[unitCost] * ( (unitLevel * 4) - 2 )
								
								-- 비용이 충분한가
								if convertedValue >= checkCost then
									ableUnitsCostTable[unit] = checkCost
									table.insert(ableUnitsTable, unit)
								end
							end
						end
						
						-- 레벨업 할 캐릭터가 있는지 확인
						if #ableUnitsTable > 0 then
							-- 캐릭터 선택
							local unitIdx = _UtilLogic:RandomIntegerRange(1, #ableUnitsTable)
							---@type Entity
							local unit = ableUnitsTable[unitIdx]
							
							-- 비용 지불 후 레벨업
							convertedValue -= ableUnitsCostTable[unit]
							log("convertedValue_LvUP = ", convertedValue, unit.UnitInfo.charID)
							
							unit.UnitInfo:SetCharInfo(unit.UnitInfo.charID, unit.UnitInfo.level + 1, unit.UnitInfo.cost)
						else
							break
						end
					end
				end
				--log("Last ConvertedValue = ", convertedValue)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method Entity SpawnEnemyUnit(string userId, string charID, number charLevel, number charCost)
		-- 적 유닛을 소환하는 함수
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local units = self.UnitsParentEntity[userId]
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		
		local charStatusTable = _DataService:GetTable("CharacterStatus")
		local charInfoTable = _DataService:GetTable("CharacterInfo")
		---------------------------------------------------------
		
		-- 안쓰는 유닛 엔티티 하나 가져오기
		---@type Entity
		local enemy = nil
		for _, unitSample in pairs(units.Children) do
			local unitSampleInfo = unitSample.UnitInfo
			
			if (not unitSampleInfo.use) and unitSampleInfo.TeamType == "Enemy" then
				enemy = unitSample
				unitSampleInfo.use = true
				break
			end
		end
		local enemyInfo = enemy.UnitInfo
		table.insert(teamManager.EnemyUnits, enemy)
		
		-- enemy.UnitBattleStatistics:RoundPropertyInitialize(charID)
		
		-- 위치 찾기
		local charRange = tonumber( charStatusTable:FindRow("SetID", charID .. "1"):GetItem("AttackRange") )
		
		-- 허수아비 맨 앞으로 예외처리
		if charID == "C00000" then
			charRange = 1
		end
		
		local range = { math.min(4, math.floor(charRange)) }
		range[2] = range[1] + ( (range[1]%2) * 2 - 1 )
		
		local setverticalNum = _UtilLogic:RandomIntegerRange(1, 7)
		local setKey = math.floor(8 + setverticalNum%2 + range[1]*2) .. "," .. math.floor(setverticalNum)
		
		for j = 1, 2 do
			local alreadySet = false
			for k = 1, 7 do
				alreadySet = false
				-- 이미 배치되어있는지 체크
				local setTile = gameManager.RoomTile[setKey]
				if isvalid(teamManager.EntityOnTile[setTile]) then
					alreadySet = true
				end
				
				if alreadySet then
					setverticalNum += 1
					setverticalNum = setverticalNum%8 + math.floor(setverticalNum/8)
					setKey = math.floor(8 + setverticalNum%2 + range[j]*2) .. "," .. math.floor(setverticalNum)
				else
					break
				end
			end
			if not alreadySet then
				break
			end
		end
		
		-- key Setting 이후
		local setTile = gameManager.RoomTile[setKey]
		if isvalid(setTile) then
			local verticalNum = setTile.TileComponent_New.verticalNum
			local horizontalNum = setTile.TileComponent_New.horizontalNum
				
			enemyInfo:SetPropertyToServer("setTile", setTile, "All", true)
				
			-- 레이어 설정
			enemy.UnitAnimationComponent:SetLayerOrder(verticalNum, userId)
		end
		
		enemy.UnitInfo:SetCharInfo(charID, charLevel, charCost)
		
		return enemy
	end

	@ExecSpace("Server")
	method void SetUnitsParentEntity(string userID, Entity pEntity)
		self.UnitsParentEntity[userID] = pEntity
		self:SetUnitsParentEntityInClient(userID, pEntity, userID)
	end

	@ExecSpace("Client")
	method void SetUnitsParentEntityInClient(string userID, Entity pEntity)
		self.UnitsParentEntity[userID] = pEntity
	end

	@ExecSpace("Server")
	method void SetProjectilesParentEntity(string userID, Entity pEntity)
		self.ProjectilesParentEntity[userID] = pEntity
		self:SetProjectilesParentEntityInClient(userID, pEntity, userID)
	end

	@ExecSpace("Client")
	method void SetProjectilesParentEntityInClient(string userID, Entity pEntity)
		self.ProjectilesParentEntity[userID] = pEntity
	end

	@ExecSpace("Server")
	method Entity GetProjectileEntity(string userId, string type)
		-- 적 유닛을 소환하는 함수
		---------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(userId)
		local projectiles = self.ProjectilesParentEntity[userId]
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		---------------------------------------------------------
		-- 안쓰는 투사체 하나 가져오기
		-- 기본 공격 투사체
		if type == "Attack" then
			for _, projSample in pairs(projectiles.Children) do
				if isvalid(projSample.AProjectileInfo) and not projSample.AProjectileInfo.Shots then
					return projSample
				end
			end
		-- 스킬 공격 투사체
		elseif type == "Skill" then
			for _, projSample in pairs(projectiles.Children) do
				if isvalid(projSample.SkillShotCheckComponent) and not projSample.SkillShotCheckComponent.Shots then
					return projSample
				end
			end
		else
			return nil
		end
		
		--[[
		---@type Entity
		local proj = nil
		---@type Entity
		local enemy = nil
		
		for _, unitSample in pairs(units.Children) do
			local unitSampleInfo = unitSample.UnitInfo
			
			if (not unitSampleInfo.use) and unitSampleInfo.TeamType == "Enemy" then
				enemy = unitSample
				unitSampleInfo.use = true
				break
			end
		end
		local enemyInfo = enemy.UnitInfo
		table.insert(teamManager.EnemyUnits, enemy)]]
	end

	@ExecSpace("ServerOnly")
	method void OnEndPlay()
		if Environment:IsMakerPlay() then
		
			_TimerService:ClearTimer(self.ProjectileSampleDestroyTimerID)
			_TimerService:ClearTimer(self.UnitSampleDestroyTimerID)
		end
	end

end