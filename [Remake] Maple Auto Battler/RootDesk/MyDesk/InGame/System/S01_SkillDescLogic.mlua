		-- C10003_변형된달팽이
		local c10003 = skillDescTable:FindRow("Key", "SkillDesc_Active_C10003")
		local c10003_active_shield_maxhpper = _UtilLogic:Split(c10003:GetItem("coef_1"), ",")[2]
		local c10003_active_attack_physic = _UtilLogic:Split(c10003:GetItem("coef_2"), ",")[2]
		
		self.C10003_Active_Shield_MaxHPPer = _UtilLogic:Split(c10003_active_shield_maxhpper, "/")
		self.C10003_Active_Attack_Physic = _UtilLogic:Split(c10003_active_attack_physic, "/")
		
		
		-- C10004_돌의정령
