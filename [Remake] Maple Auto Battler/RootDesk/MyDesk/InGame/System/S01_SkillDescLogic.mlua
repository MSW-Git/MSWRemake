	method void OnBeginPlay()
		-- 로직 시작 시 모든 스킬 설명 데이터를 초기화하는 함수
		self:SkillDescC1()
		self:SkillDescC2()
		self:SkillDescC3()
		self:SkillDescC4()
		self:SkillDescC5()
		self:SkillDescC0()
		
	end

	method void SkillDescC1()
		local skillDescTable = _DataService:GetTable("SkillDescCoefTable")
		
		
		-- C10001_슬라임
		local c10001 = skillDescTable:FindRow("Key", "SkillDesc_Active_C10001")
		local c10001_active_sdamage_magic = _UtilLogic:Split(c10001:GetItem("coef_1"), ",")[2]
		local c10001_active_stuntime_int = _UtilLogic:Split(c10001:GetItem("coef_2"), ",")[2]
		
		self.C10001_Active_SDamage_Magic = _UtilLogic:Split(c10001_active_sdamage_magic, "/")
		self.C10001_Active_StunTime_Int = _UtilLogic:Split(c10001_active_stuntime_int, "/")
		
		-- C10002_주황버섯
		local c10002 = skillDescTable:FindRow("Key", "SkillDesc_Active_C10002")
		local c10002_active_sdamage_physic = _UtilLogic:Split(c10002:GetItem("coef_2"), ",")[2]
		local c10002_active_sdamage_magic = _UtilLogic:Split(c10002:GetItem("coef_3"), ",")[2]
		local c10002_active_healingdecreasetime_int = _UtilLogic:Split(c10002:GetItem("coef_4"), ",")[2]
		
		self.C10002_Active_SDamage_Physic = _UtilLogic:Split(c10002_active_sdamage_physic, "/")
		self.C10002_Active_SDamage_Magic = _UtilLogic:Split(c10002_active_sdamage_magic, "/")
