		self.C10005_Passive_DamageDecrease_MaxHPPer = _UtilLogic:Split(c10005_passive_damagedecrease_maxhpper, "/")
		
		
		-- C10006_스톤볼
		local c10006 = skillDescTable:FindRow("Key", "SkillDesc_Active_C10006")
