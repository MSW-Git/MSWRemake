@Logic
script ItemStatusLogic extends Logic

	property table ItemStatus = {}

	method table GetItemStatusTypeTable()
		local statusType = {
			"MaxHP",
			"MaxMP",
			"MP",
			"PhysicalAttack",
			"MagicalAttack",
			"Defence",
			"MagicalResistance",
			"AttackSpeed",
			"AttackRange",
			"CriticalPercent",
			"CriticalDamagePercent",
			"BloodAbsorptionPercent",
			"MoveSpeed"
		}
		
		return statusType
	end

	method SyncTable<string, string> GetItemStatusCalculatingType()
		---@type table<string, string>
		local CalculatingType = {
			["MaxHP"] = "int",
			["MaxMP"] = "int",
			["MP"] = "int",
			["PhysicalAttack"] = "multi",
			["MagicalAttack"] = "multi",
			["Defence"] = "int",
			["MagicalResistance"] = "int",
			["AttackSpeed"] = "multi",
			["AttackRange"] = "int",
			["CriticalPercent"] = "int",
			["CriticalDamagePercent"] = "int",
			["BloodAbsorptionPercent"] = "int",
			["MoveSpeed"] = "multi",
		}
		
		return CalculatingType
	end

	method void OnBeginPlay()
		local statusType = self:GetItemStatusTypeTable()
		
		---@type MODUserDataSet
		local itemTable = _DataService:GetTable("ItemStatus")
		
		for i=1, itemTable:GetRowCount() do
			
			local row = itemTable:GetRow(i)
			
			local key = row:GetItem("ItemID")
			local valueTable = {}
			
			for j=1, #statusType do
				local status = row:GetItem(statusType[j])
				
				if status ~= "" then
					valueTable[statusType[j]] = tonumber(row:GetItem(statusType[j]))
				else
					valueTable[statusType[j]] = 0
				end
		
			end
			
			self.ItemStatus[key] = valueTable
		end
	end

	method table GetItemStatus(string ItemID)
		if self.ItemStatus[ItemID] ~= nil then
			return self.ItemStatus[ItemID]
		else
			log_error("'self.ItemStatus[ItemID]' is nil")
			return nil
		end
		
	end

end