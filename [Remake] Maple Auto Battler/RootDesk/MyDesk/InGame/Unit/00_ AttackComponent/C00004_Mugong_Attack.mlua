@Component
script C00004_Mugong_Attack extends Component

	@Sync
	property number playRate = 0

	@Sync
	property Entity projectile = nil

	property string attackProjectileRUID = "3787c01a86614999a5f6b3e3464a7a5b"

	property string hitEffectRUID = "132f487c737c428d8d00874305552cfa"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 1.68) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Attack", "")
		
		-- projectile Spwan
		local function ProjectileSpawn()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self.projectile = _UnitSetLogic_New:GetProjectileEntity(unitInfo.OwnerId, "Attack")
				
				self.projectile.SpriteRendererComponent.SpriteRUID = self.attackProjectileRUID
				self.projectile.TransformComponent.Scale = unitInfo.spriteRenderer.TransformComponent.Scale
				self.projectile.SpriteRendererComponent.FlipX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
				self.projectile.AProjectileInfo:SetProjectile(self.Entity, targetUnit, 1.2, 1.5, 0.3, 0.5)
				_GeneralDirectorLogic:SetEffectAlpha(self.projectile,unitInfo.OwnerId)
			end
		end
		
		_TimerService:SetTimerOnce(ProjectileSpawn, 1.14 / self.playRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0149",self.Entity.UnitInfo.OwnerId)
		
		--그림자
		self:SetShadow(1.68 / (unitStatus.AttackSpeed * _BTLogic_New.ASpeedValue), self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
		
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			-- hiteffect
			local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
			local options = {["FlipX"] = filpX}
			_CustomizedBattleEffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3(1.5, 1.5, 1.5), false, options, unitInfo.OwnerId)
			
			local damageInfo = _StatusChangeLogic:CheckDamage(unitStatus.PhysicalAttack, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "defaultAttack")
		end
	end

	@ExecSpace("Client")
	method void SetShadow(number time)
		--그림자가 이동합니다
		local pos=-0.4
		if self.Entity.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX then
			pos=0.4
		end
		
		local setpos=function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Position=Vector3(pos,0,0)
			
			if self.Entity.UnitAnimationComponent.SetAnimType~="Attack" then
				self.Entity:GetChildByName("Shadow").TransformComponent.Position=Vector3.zero 
			end
		end
		
		_TimerService:SetTimerOnce(setpos,time*4.5/10)
		
		--그림자 원상복구
		local init=function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Position=Vector3.zero
		end
		
		_TimerService:SetTimerOnce(init,time*5.5/10)
	end

end