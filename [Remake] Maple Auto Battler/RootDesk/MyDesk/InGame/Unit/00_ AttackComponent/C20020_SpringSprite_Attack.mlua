@Component
script C20020_SpringSprite_Attack extends Component

	@Sync
	property number playRate = 0

	property string HitEffectRUID = "0d074f80994b4d6194e509351b562a55"

	property string HitEffectRUID2 = "7d085a61fafd4e279335628fd03adbd1"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 1.5) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Attack", "")
		
		
		local function damage()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetDamage(targetUnit)
			end
		end
		_TimerService:SetTimerOnce(damage, 0.75 / self.playRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0046",self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			
			self:HitEffect(targetUnit, unitInfo.unitPhaseNumber, unitInfo.OwnerId)
			
			local addMagicalDamage = 0
			if unitInfo.unitPhaseNumber == 1 then
				-- 1초간 둔화 + 회복
				local debuffTime = tonumber(_S01_SkillDescLogic.C20020_Passive_DebuffTime_Int[unitInfo.level])
				_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0014", debuffTime)
				
				local getHPAmount = unitStatus.PhysicalAttack * _S01_SkillDescLogic.C20020_Passive_GetHP_Physic[unitInfo.level]
				
				_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "HP", getHPAmount, "defaultAttack")
			elseif unitInfo.unitPhaseNumber == 2 then
				-- 1초간 회복력 감소 + 추가 마법 피해
				local debuffTime = tonumber(_S01_SkillDescLogic.C20020_Passive_DebuffTime2_Int[unitInfo.level])
				_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0010", debuffTime)
				
				addMagicalDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C20020_Passive_Attack_Magic[unitInfo.level]
			end
			
			
			local damageInfo = _StatusChangeLogic:CheckDamage(unitStatus.PhysicalAttack, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], addMagicalDamage, damageInfo[2], "defaultAttack")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit, number phaseNum)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		local ruid = ""
		if phaseNum == 1 then
			ruid = self.HitEffectRUID
		elseif phaseNum == 2 then
			ruid = self.HitEffectRUID2
		end
		
		-- hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(ruid, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

end