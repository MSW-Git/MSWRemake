@Component
script C20014_Blin_Attack extends Component

	@Sync
	property number playRate = 0

	property string AttackEffectRUID = "41d45daed11f402db29b31983f2daf00"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 1.6) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		
		
		unitStatus:SetProperty("state", "Attack", "")
		
		local function attackEffectFnc()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetAttackEffect(targetUnit, self.playRate, unitInfo.OwnerId)
			end
		end
		
		_TimerService:SetTimerOnce(attackEffectFnc, 0.83 / self.playRate)
		
		local function damageFnc()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetDamage(targetUnit)
			end
		end
		
		_TimerService:SetTimerOnce(damageFnc, 1.6 / self.playRate)
		
		local function soundFnc()
			-- 사운드
			_PlaySoundLogic:PlaySound("M0219",self.Entity.UnitInfo.OwnerId)
		
		end
		
		_TimerService:SetTimerOnce(soundFnc, (1.6 / self.playRate)*0.8)
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
		
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			local damageInfo = _StatusChangeLogic:CheckDamage(unitStatus.PhysicalAttack, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "defaultAttack")
		end
	end

	@ExecSpace("Client")
	method void SetAttackEffect(Entity targetUnit, number playRate)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = 1, ["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.AttackEffectRUID, targetUnit, Vector3(0, 0, 0), 0, Vector3(1.5, 1.5, 1.5), false, options)
	end

end