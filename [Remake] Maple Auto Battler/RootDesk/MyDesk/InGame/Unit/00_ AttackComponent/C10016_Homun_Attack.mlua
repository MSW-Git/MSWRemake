@Component
script C10016_Homun_Attack extends Component

	property number playRate = 0

	property string hitEffectRUID = "a4fd7e48c98a4be882b6f8de0abf40b8"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 1.29) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		
		-- Set Damage
		local function damage()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetDamage(targetUnit)
			end
		end
		_TimerService:SetTimerOnce(damage, 0.6 / self.playRate)
		
		
		unitStatus:SetProperty("state", "Attack", "")
		
		-- 사운드
		_PlaySoundLogic:PlaySound("M0217",self.Entity.UnitInfo.OwnerId)
		
		-- 그림자
		self:SetShadow(1.29/(unitStatus.AttackSpeed * _BTLogic_New.ASpeedValue), self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
		
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local damageInfo = _StatusChangeLogic:CheckDamage(unitStatus.PhysicalAttack, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "defaultAttack")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3(1, 1, 1), false, options)
	end

	@ExecSpace("Client")
	method void SetShadow(number time)
		--그림자가 점점 작아집니다
		local scale=Vector3.one
		local setscale=function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Scale=scale 
			scale.x-=1/50
			scale.y-=1/50
			
			if self.Entity.UnitAnimationComponent.SetAnimType~="Attack" then
				self.Entity:GetChildByName("Shadow").TransformComponent.Scale=Vector3.one 
			end
		end
		
		for i=1,50 do
			_TimerService:SetTimerOnce(setscale,((i/time)/60)+time*0.7/10)
		end
		
		--그림자 원상복구
		local init=function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Scale=Vector3.one
		end
		
		_TimerService:SetTimerOnce(init,7*time/10)
	end

end