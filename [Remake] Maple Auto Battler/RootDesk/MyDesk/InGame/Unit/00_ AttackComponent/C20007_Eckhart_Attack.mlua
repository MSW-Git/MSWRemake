@Component
script C20007_Eckhart_Attack extends Component

	@Sync
	property number playRate = 0

	@Sync
	property Entity projectile = nil

	property string attackProjectileRUID = "db4f5195a03c4fca8080ce5cd47a8fb8"

	property string hitEffectRUID = "cebb7a2a693144a6adb57d47b40bad23"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 1.26) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Attack", "")
		
		-- projectile Spwan
		local function ProjectileSpawn()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				local unitPos = unitStatus.SetPos
				self.projectile = _UnitSetLogic_New:GetProjectileEntity(unitInfo.OwnerId, "Attack")
				
				self.projectile.SpriteRendererComponent.SpriteRUID = self.attackProjectileRUID
				self.projectile.TransformComponent.Scale = unitInfo.spriteRenderer.TransformComponent.Scale
				self.projectile.SpriteRendererComponent.FlipX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
				self.projectile.AProjectileInfo:SetProjectile(self.Entity, targetUnit, 1.2, 2, 0, 0.5)
				_GeneralDirectorLogic:SetEffectAlpha(self.projectile,unitInfo.OwnerId)
			end
		end
		
		_TimerService:SetTimerOnce(ProjectileSpawn, 0.32 / self.playRate)
		
		
		--사운드
		_PlaySoundLogic:PlaySound("M0066",self.Entity.UnitInfo.OwnerId)
		
		--그림자
		self:SetShadow(1.26/(unitStatus.AttackSpeed * _BTLogic_New.ASpeedValue),self.Entity.UnitInfo.OwnerId)
		
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
		
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local projectTileCount = 1
			local function damage()
				local setDamage = unitStatus.PhysicalAttack * 0.55 + unitStatus.MagicalAttack * 0.05
				local damageInfo = _StatusChangeLogic:CheckDamage(setDamage, myUnit, targetUnit, 0, "Physical")
				if projectTileCount == 1 then
					_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "defaultAttack")
				else
					_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], string.format("defaultAttack_%d", projectTileCount))
				end
				
				projectTileCount += 1
			end
			
			_TimerService:SetTimerOnce(damage, 0)
			_TimerService:SetTimerOnce(damage, 0.1)
			
		else
			--log("0")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void SetShadow(number time)
		--그림자가 이동합니다
		local pos=-0.4
		if self.Entity.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX then
			pos=0.4
		end
		
		local setpos=function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Position=Vector3(pos,0,0)
		end
		
		_TimerService:SetTimerOnce(setpos,time*2/10)
		
		--그림자 원상복구
		local init=function()
			self.Entity:GetChildByName("Shadow").TransformComponent.Position=Vector3.zero
		end
		
		_TimerService:SetTimerOnce(init,time*5/10)
	end

end