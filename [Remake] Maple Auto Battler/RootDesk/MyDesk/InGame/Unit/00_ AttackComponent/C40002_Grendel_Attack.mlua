@Component
script C40002_Grendel_Attack extends Component

	property number playRate = 0

	property number attackType = 1

	property string AttackEffectRUID = "562369739d5b48de95d9923630597989"

	property string hitEffectRUID = "a9196a3a66a94baabc50c35786a90c15"

	property string AttackEffect2RUID = "7d885d43ead54628970ea203c45924b8"

	property string hitEffect2RUID = "d5f9bec9efd34bf28353fa2e53cbd6a3"

	property string AttackEffect3RUID = "3d9f6581066a4295b06ed23a430b76cc"

	property string hitEffect3RUID = "0b59a6fb8ca44bc1931d9f73b364c6f1"

	@ExecSpace("Server")
	method void Attack(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- ATTACK RUID
		self.playRate = (unitStatus.AttackSpeed * 0.9) * _BTLogic_New.ASpeedValue
		animComponent:PlayAnimation(self.playRate, "Attack", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Attack", "")
		
		local function attackEffect()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetAttackEffect(self.playRate, self.attackType, unitInfo.OwnerId)
			end
		end
		_TimerService:SetTimerOnce(attackEffect, 0.2 / self.playRate)
			
		local function damage()
			if _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Attack") then
				self:SetDamage(targetUnit)
			end
		end
		_TimerService:SetTimerOnce(damage, 0.5 / self.playRate)
		
		--연출
		if self.attackType==1 then
			self:PlaySkillEffect(0.5 / self.playRate, targetInfo.setTile, unitInfo.OwnerId)
		end
		
	end

	@ExecSpace("Client")
	method void SetAttackEffect(number playRate, number attackType)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = playRate,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		local attackRUID = ""
		
		if attackType == 1 then
			attackRUID = self.AttackEffectRUID
			--사운드
			_PlaySoundLogic:PlaySound("M0103")
			
			--이펙트
			_EffectService:PlayEffectAttached(attackRUID, myUnit, Vector3(0, -0.3, 0), 0, Vector3.one*1.3, false, options)
		elseif attackType == 2 then
			attackRUID = self.AttackEffect2RUID
			--사운드
			_PlaySoundLogic:PlaySound("M0104")
			
			--이펙트
			_EffectService:PlayEffectAttached(attackRUID, myUnit, Vector3(0, -0.1, 0), 0, Vector3.one, false, options)
		elseif attackType == 3 then
			attackRUID = self.AttackEffect3RUID
			--사운드
			_PlaySoundLogic:PlaySound("M0105")
			
			--이펙트
			_EffectService:PlayEffectAttached(attackRUID, myUnit, Vector3(0, 0, 0), 0, Vector3.one, false, options)
		end
	end

	@ExecSpace("Server")
	method void SetDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			local unitLevel = unitInfo.level
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
			local teamManager = user.TeamManager
			
			
			
			
			
			---@type table
			local damageInfo
			
			local myTeams = {}
			local enemies = {}
			
			if unitInfo.TeamType == "User" then
				myTeams = teamManager.OwnUnits
				enemies = teamManager.EnemyUnits
			elseif unitInfo.TeamType == "Enemy" then
				myTeams = teamManager.EnemyUnits
				enemies = teamManager.OwnUnits
			end
			--------------------------------------------
			-- Type. 1 화염
			-- 광역 피해
			--------------------------------------------
			if self.attackType == 1 then
				local magicalDamage = _S01_SkillDescLogic.C40002_Passive_FireAttack_Magic[unitLevel] * unitStatus.MagicalAttack
				
				local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				local attackEnemies = _BTLogic_New:getTargets(targetInfo.setTile, checkEnemies, "Around_0_1")
				
				for _, enemy in pairs(attackEnemies) do
					damageInfo = _StatusChangeLogic:CheckDamage(magicalDamage, myUnit, enemy, 0, "Magical")
					_StatusChangeLogic:HitDamage(myUnit, enemy, 0, damageInfo[1], damageInfo[2], "defaultAttack")
					self:HitEffect(enemy, self.attackType, unitInfo.OwnerId)
				end
			--------------------------------------------
			-- Type. 2 냉각
			-- 둔화
			--------------------------------------------
			elseif self.attackType == 2 then
				local magicalDamage = _S01_SkillDescLogic.C40002_Passive_IceAttack_Magic[unitLevel] * unitStatus.MagicalAttack
				damageInfo = _StatusChangeLogic:CheckDamage(magicalDamage, myUnit, targetUnit, 0, "Magical")
				
				_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "defaultAttack")
				_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0014", 3)
				self:HitEffect(targetUnit, self.attackType, unitInfo.OwnerId)
			--------------------------------------------
			-- Type. 3 섬광
			-- 아군 공속 증가
			--------------------------------------------
			elseif self.attackType == 3 then
				local magicalDamage = _S01_SkillDescLogic.C40002_Passive_LightAttack_Magic[unitLevel] * unitStatus.MagicalAttack
				damageInfo = _StatusChangeLogic:CheckDamage(magicalDamage, myUnit, targetUnit, 0, "Magical")
				_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "defaultAttack")
				self:HitEffect(targetUnit, self.attackType, unitInfo.OwnerId)
				
				local checkMyTeams = _BTLogic_New:getEntities(myTeams, "Alive")
				checkMyTeams = _BTLogic_New:getTargets(unitInfo.setTile, checkMyTeams, "Around_1_10")
				local myTeamUnit = _BTLogic_New:getTarget(unitInfo.setTile, checkMyTeams, "Nearest")
				
				if not isvalid(myTeamUnit) then
					myTeamUnit = myUnit
				end
				
				_StatusChangeLogic:GetBuff(myTeamUnit, "Multi_AttackSpeed", _S01_SkillDescLogic.C40002_Passive_GetAttackSpeed_Per[unitLevel], 6)
				
				--버프연출
				-- _GeneralDirectorLogic:BattleBuffEffect(myTeamUnit,_RuneCardDirectEnum.AttackSpeed,unitInfo.OwnerId)
			end
			
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit, number attackType)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		local hitRUID = ""
		
		
		if attackType == 1 then
			hitRUID = self.hitEffectRUID
		elseif attackType == 2 then
			hitRUID = self.hitEffect2RUID
		elseif attackType == 3 then
			hitRUID = self.hitEffect3RUID
		end
		
		_EffectService:PlayEffectAttached(hitRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity Tile)
		--범위 표시
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Tile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
		
		--각 캐릭터별 범위 공격용 이펙트
		local destroyandparticle=function()
			_EffectService:PlayEffectAttached("ff046ea8281f4ed48430594340ddf6af",Tile,Vector3(0,0.3,0),0,Vector3(1,1,1),false,{["SortingLayer"]="Foreground",["OrderInLayer"]=5})
			
		end
		_TimerService:SetTimerOnce(destroyandparticle, time)
	end

end