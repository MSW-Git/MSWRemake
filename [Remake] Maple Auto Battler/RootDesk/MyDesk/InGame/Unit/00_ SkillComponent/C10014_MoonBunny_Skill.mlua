@Component
script C10014_MoonBunny_Skill extends Component

	property number stack = 0

	@ExecSpace("Server")
	method void SetBattle()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		self.stack = 0
	end

	@ExecSpace("Server")
	method void Reset()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local animComponent = myUnit.UnitAnimationComponent
		
		-- 페이즈 변경
		unitInfo:SetPropertyToServer("unitPhaseNumber", 1, nil, true)
		animComponent:PlayAnimation(1, "Idle", myUnit, unitInfo.OwnerId)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleAttacked(Attacked event)
		-- Parameters
		-- local Attacker = event.Attacker
		-- local Target = event.Target
		-- local InitialDamages = event.InitialDamages
		-- local FinalDamages = event.FinalDamages
		-- local IsCritical = event.IsCritical
		-- local AttackType = event.AttackType
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		---------------------------------------------------------
		if unitInfo.unitPhaseNumber == 1 then
			self.stack += 1
			
			if self.stack >= 30 then
				unitInfo:SetPropertyToServer("unitPhaseNumber", 2, nil, true)
				_StatusChangeLogic:GetBuff(myUnit, "Add_BloodAbsorptionPercent", _S01_SkillDescLogic.C10014_Passive_GetBloodAbsorption_Int[unitInfo.level], -1)
			else
				_StatusChangeLogic:GetBuff(myUnit, "Multi_AttackSpeed", _S01_SkillDescLogic.C10014_Passive_GetAttackSpeed_Int[unitInfo.level], -1)
			end
		end
	end

	@EventSender("Self")
	handler HandleDefaultAttack(DefaultAttack event)
		-- Parameters
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		--local attacker = event.attacker
		--local target = event.target
		---------------------------------------------------------
		if unitInfo.unitPhaseNumber == 1 then
			self.stack += 1
			
			if self.stack >= 30 then
				unitInfo:SetPropertyToServer("unitPhaseNumber", 2, nil, true)
				_StatusChangeLogic:GetBuff(myUnit, "Add_BloodAbsorptionPercent", _S01_SkillDescLogic.C10014_Passive_GetBloodAbsorption_Int[unitInfo.level], -1)
			else
				_StatusChangeLogic:GetBuff(myUnit, "Multi_AttackSpeed", _S01_SkillDescLogic.C10014_Passive_GetAttackSpeed_Int[unitInfo.level], -1)
			end
		end
	end

end