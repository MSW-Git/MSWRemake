@Component
script C10005_StoneGolem_Skill extends Component

	@ExecSpace("Server")
	method void SetBattle()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		_StatusChangeLogic:GetBuff(myUnit, "DamageDecrease_Magic", _S01_SkillDescLogic.C10005_Passive_DamageDecrease_Magic[unitInfo.level], -1)
		_StatusChangeLogic:GetBuff(myUnit, "DamageDecrease_MaxHP", _S01_SkillDescLogic.C10005_Passive_DamageDecrease_MaxHPPer[unitInfo.level], -1)
	end

end