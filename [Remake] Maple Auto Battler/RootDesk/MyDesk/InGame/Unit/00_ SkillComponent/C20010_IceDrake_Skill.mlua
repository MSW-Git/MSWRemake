@Component
script C20010_IceDrake_Skill extends Component

	property number skillAnimLength = 2.84

	property Entity projectile = nil

	property string attackProjectileRUID = "9a2d97d86ef940bca1c179b9e09f3218"

	property string hitEffectRUID = "ef3c477ef48641499c936618eb70bcbc"

	property string hitEffectRUID_2 = "ed6b69caed1c4f6d936008b4a57014d8"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		local enemies = {}
		
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		
		-- projectile Spwan
		local function ProjectileSpawn()
			if not _BTLogic_New:CheckAttackAble(myUnit, targetUnit, "Skill") then
				local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				targetUnit = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "Nearest")
			end
			
			if isvalid(targetUnit) and _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self.projectile = _UnitSetLogic_New:GetProjectileEntity(unitInfo.OwnerId, "Skill")
				self.projectile:AddComponent(SkillProjectileInfo)
				
				self.projectile.SpriteRendererComponent.SpriteRUID = self.attackProjectileRUID
				self.projectile.TransformComponent.Scale = unitInfo.spriteRenderer.TransformComponent.Scale
				self.projectile.SpriteRendererComponent.FlipX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
				self.projectile.SkillProjectileInfo:SetProjectile(self.Entity, targetUnit, 1.5, 3, 0)
			end
		end
		
		_TimerService:SetTimerOnce(ProjectileSpawn, 0.97 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0076",self.Entity.UnitInfo.OwnerId)
		
		--연출
		self:PlaySkillEffect(0.97 / skillRate,targetUnit,targetInfo.setTile,unitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local skillSetDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C20010_Active_SDamage_Magic[unitInfo.level]
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Magical")
			
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "skill")
			
			
			---@type Entity
			local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
			local teamManager = user.TeamManager
			
			
			---@type table<Entity>
			local enemies = {}
			if unitInfo.TeamType == "Enemy" then
				enemies = _BTLogic_New:getEntities(teamManager.OwnUnits, "AttackAble")
			elseif unitInfo.TeamType == "User" then
				enemies = _BTLogic_New:getEntities(teamManager.EnemyUnits, "AttackAble")
			end
			
			
			-- Around Random4
			local target2Units = _BTLogic_New:getTargets(targetInfo.setTile, enemies, "Around_1_3")
			target2Units = _BTLogic_New:getTargets(targetInfo.setTile, target2Units, "Random_4")
			
			-- projectile Spawn
			if isvalid(target2Units) then
				for _, enemy in pairs(target2Units) do
					if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
						self.projectile = _UnitSetLogic_New:GetProjectileEntity(unitInfo.OwnerId, "Skill")
						self.projectile:AddComponent(SkillProjectile2Info)
						
						self.projectile.SpriteRendererComponent.SpriteRUID = self.attackProjectileRUID
						self.projectile.TransformComponent.Scale = unitInfo.spriteRenderer.TransformComponent.Scale
						self.projectile.SpriteRendererComponent.FlipX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
						self.projectile.SkillProjectile2Info:SetProjectile(self.Entity, targetUnit, enemy, 1.2, 0.7, 0)
						_GeneralDirectorLogic:SetEffectAlpha(self.projectile,unitInfo.OwnerId)
					end
				end
			end
		end
	end

	@ExecSpace("Server")
	method void SetSkillDamage2(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect2(targetUnit, unitInfo.OwnerId)
		
			local skillSetDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C20010_Active_SDamage2_Magic[unitInfo.level]
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Magical")
				
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "skill")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0,0.3,0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void HitEffect2(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID_2, targetUnit, Vector3(0,0.3,0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity target, Entity Tile)
		--범위 표시
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 3, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 3, Tile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
	end

end