@Component
script C20009_BullDog_Skill extends Component

	@Sync
	property number skillAnimLength = 1.53

	property string hitEffectRUID = "03d93f3572a84e8bb897a57e6649673d"

	property boolean setMotion = false

	property number motionTime = 0

	property Vector2 setVec = Vector2(0,0)

	property Vector2 setVec2 = Vector2(0,0)

	property boolean setAttack = false

	property Entity target = nil

	property Vector2 setPos = Vector2(0,0)

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		---@type table<Entity>
		local enemies = {}
		
		if unitInfo.TeamType == "User" then
			enemies = teamManager.EnemyUnits
		elseif unitInfo.TeamType == "Enemy" then
			enemies = teamManager.OwnUnits
		end
		
		local checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
		local target = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "HP_High")
		
		local function SkillPlay()
			if not _BTLogic_New:CheckAttackAble(myUnit, target, "Skill") then
				checkEnemies = _BTLogic_New:getEntities(enemies, "AttackAble")
				target = _BTLogic_New:getTarget(unitInfo.setTile, checkEnemies, "HP_High")
			end
			
			if isvalid(target) and _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetSkillMotion(target)
			end
		end
		
		_TimerService:SetTimerOnce(SkillPlay, 0.2 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0061",self.Entity.UnitInfo.OwnerId)
		
		--연출
		self:PlaySkillEffect((0.2 / skillRate)+0.6,target,target.UnitInfo.setTile,unitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSkillMotion(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local unitSprite = unitInfo.spriteRenderer
		local setTile = unitInfo.setTile
		
		-- 타일 이동
		local moveTileInfo = _BTLogic_New:getTile(targetUnit, nil, "EmptyTileNearestToTheUnit_All")
		
		---@type Entity
		local moveTile = moveTileInfo[1]
		
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		
		-- Unit
		unitInfo:SetPropertyToServer("setTile", moveTile, "OnlySetTile", true)
		
		-- 레이어 설정
		myUnit.UnitAnimationComponent:SetLayerOrder(moveTileInfo[2], unitInfo.OwnerId)
		
		local selfVec2 = unitStatus.SetPos
		local targetVec2 = targetUnit.UnitStatus.SetPos + Vector2(0, 0.2)
		local moveVec2 = moveTile.TransformComponent.WorldPosition:ToVector2()
		
		self.setPos = selfVec2
		
		self.setVec = targetVec2 - selfVec2
		self.setVec2 = moveVec2 - targetVec2
		self:SetFlipX(targetUnit, unitInfo.OwnerId)
		self.setAttack = true
		self.target = targetUnit
		
		-- self.setMotion = true
		
		
		local callbackCount = 0
		local function ActionFnc()
			local posX = 0
			local posY = 0
			
			selfVec2 = self.setPos
			
			callbackCount += 0.01
			if callbackCount <= 0.36 then
				posX = selfVec2.x + self.setVec.x * 0.01 * (1 / 0.36)
				posY = selfVec2.y + self.setVec.y * 0.01 * (1 / 0.36)
			elseif callbackCount <= 0.51 then
				if self.setAttack then
					if _BTLogic_New:CheckAttackAble(myUnit, self.target, "Skill") then
						self:SetSkillDamage(self.target)
					end
					self.setAttack = false
				end
				posX = selfVec2.x
				posY = selfVec2.y
			elseif callbackCount <= 0.66 then
				posX = selfVec2.x + self.setVec2.x * 0.01 * (1 / 0.15)
				posY = selfVec2.y + self.setVec2.y * 0.01 * (1 / 0.15)
			else
				if isvalid(unitInfo.setTile) then
					local tilePos = unitInfo.setTile.TransformComponent.WorldPosition
					posX = tilePos.x
					posY = tilePos.y
				end
				if unitStatus.ActionType == "Bulldog_SkillMove" then
					unitStatus:SetActionType("Idle")
					_TimerService:ClearTimer(unitStatus.ActionTimer)
					unitStatus.ActionTimer = 0
				end
			end
			
			self.setPos = Vector2(posX, posY)
			unitStatus.SetPos = Vector2(posX, posY)
			
			self:SetPosition(posX, posY, 0, unitInfo.OwnerId)
		end
		
		_TimerService:ClearTimer(unitStatus.ActionTimer)
		unitStatus:SetActionType("Bulldog_SkillMove")
		unitStatus.ActionTimer = _TimerService:SetTimerRepeat(ActionFnc, 0.01 / skillRate, 0)
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local lv = unitInfo.level
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local physicalDamage = unitStatus.PhysicalAttack * _S01_SkillDescLogic.C20009_Active_SDamage_Physic[lv] +
								unitStatus.MaxHP * _S01_SkillDescLogic.C20009_Active_SDamage_MaxHPPer[lv]
		
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		
		local enemies = {}
		if unitInfo.TeamType == "Enemy" then
			enemies = _BTLogic_New:getEntities(teamManager.OwnUnits, "AttackAble")
		elseif unitInfo.TeamType == "User" then
			enemies = _BTLogic_New:getEntities(teamManager.EnemyUnits, "AttackAble")
		end
		
		local attackEnemies = _BTLogic_New:getTargets(targetInfo.setTile, enemies, "Around_0_1")
		
		-- 대상 단일 기절
		local stunTime = tonumber(_S01_SkillDescLogic.C20009_Active_StunTime_Int[lv])
		_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0004", stunTime)
		
		-- 광역 피해
		local hitCount = 0 
		if isvalid(attackEnemies) then
			for _, enemy in pairs(attackEnemies) do
				if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
					self:HitEffect(enemy, unitInfo.OwnerId)
				
					local damageInfo = _StatusChangeLogic:CheckDamage(physicalDamage, myUnit, enemy, 0, "Physical")
					_StatusChangeLogic:HitDamage(myUnit, enemy, damageInfo[1], 0, damageInfo[2], "skill")
					
					hitCount+=1 
				end
			end
		end
		
		-- 불독 도전과제
		_AchievementService:UpdateProgress_Char(unitInfo,hitCount,user)
	end

	@ExecSpace("Client")
	method void SetPosition(number x, number y, number zR)
		self.Entity.TransformComponent.WorldPosition = Vector3(x,y,0)
		self.Entity.TransformComponent.WorldZRotation = zR
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void SetFlipX(Entity targetUnit)
		local ownerUnit = self.Entity
		
		if ownerUnit.UnitStatus.SetPos.x < targetUnit.UnitStatus.SetPos.x then
			ownerUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = true
		elseif ownerUnit.UnitStatus.SetPos.x > targetUnit.UnitStatus.SetPos.x then
			ownerUnit.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX = false
		end
	end

	@ExecSpace("Client")
	method void PlaySkillEffect(number time, Entity target, Entity Tile)
		if not isvalid(target) then return end
		
		--범위 표시
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Tile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
		
		--각 캐릭터별 범위 공격용 이펙트
		if _ESCMenuService.skillEffectAlpha > 0 then
			local destroyandparticle = function()
				local particle = _ParticleService:PlayBasicParticleAttached(BasicParticleType.TinyExplosion, Tile, Vector3(0,0,0), 0, Vector3(1.2, 1, 1),false, 
								{["SortingLayer"] = "Layer1", ["OrderInLayer"] = -1, ["PlaySpeed"] = 0.8, ["ParticleSize"] = 0.5, ["ParticleSpeed"] = 1.5, ["ParticleCount"] = 0.5, ["ParticleLifeTime"]=0.1, ["Alpha"] = _ESCMenuService.skillEffectAlpha/100})
				
				_TimerService:SetTimerOnce(function() _ParticleService:RemoveParticle(particle) end, 0.5)
			end
			_TimerService:SetTimerOnce(destroyandparticle, time)
		end
	end

end