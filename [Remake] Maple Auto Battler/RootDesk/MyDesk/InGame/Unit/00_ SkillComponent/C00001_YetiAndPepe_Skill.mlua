@Component
script C00001_YetiAndPepe_Skill extends Component

	property number skillAnimLength = 3.95

	property string attackEffectRUID = "bee623021dc54be384ae5d60566e5b57"

	property string hitEffectRUID = "c9ed2256940d4f71a8e90dad2cc4c4f5"

	property number beforeTotalDamageTaken = 0

	property number SkillTime = 3.95

	property table Particletable = {}

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local unitStatistics = myUnit.UnitBattleStatistics
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		animComponent:PlayAnimation(1, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		--log(myUnit.Name .. " use Skill")
		
		_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0016", -1)
		
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		
		local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
			
		-- 8-3 반복 플레이 처리
		local setKey = roundKey
		if setKey == "8-3" then
			setKey = "8-3-1"
			for i = 1, 5 do
				local checkKey = string.format("%s-%d", roundKey, i)
				if isvalid(unitStatistics.SetCharID[checkKey]) then
					setKey = checkKey
				else
					break
				end
			end	
		end
		
		-- DamageTaken 계산
		self.beforeTotalDamageTaken = 0
		if isvalid(unitStatistics.PhysicalDamageTaken[setKey]) then
			self.beforeTotalDamageTaken += unitStatistics.PhysicalDamageTaken[setKey]
		end
		
		if isvalid(unitStatistics.MagicalDamageTaken[setKey]) then
			self.beforeTotalDamageTaken += unitStatistics.MagicalDamageTaken[setKey]
		end
		
		if isvalid(unitStatistics.TrueDamageTaken[setKey]) then
			self.beforeTotalDamageTaken += unitStatistics.TrueDamageTaken[setKey]
		end
		
		local function hitSkill()
			local enemies = {}
			if unitInfo.TeamType == "Enemy" then
				enemies = _BTLogic_New:getEntities(teamManager.OwnUnits, "AttackAble")
			elseif unitInfo.TeamType == "User" then
				enemies = _BTLogic_New:getEntities(teamManager.EnemyUnits, "AttackAble")
			end
			
			local attackEnemies = _BTLogic_New:getTargets(unitInfo.setTile, enemies, "Around_1_1")
				
			if isvalid(attackEnemies) then
				for _, enemy in pairs(attackEnemies) do
					if _BTLogic_New:CheckAttackAble(myUnit, enemy, "Skill") then
						self:SetSkillDamage(enemy)
					end
				end
			end
			
			_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0016", 0)
		end
		
		_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0018", 3.06)
		_TimerService:SetTimerOnce(hitSkill, 3.06)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0051", self.Entity.UnitInfo.OwnerId)
		
		--연출
		self:PlaySkillEffect_Range(3.06, unitInfo.setTile, unitInfo.OwnerId)
		self:PlaySkillEffect_Particle(3.06, unitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			local unitStatistics = myUnit.UnitBattleStatistics
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			---@type Entity
			local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
			local gameManager = user.GameManager
			
			local roundKey = math.floor(gameManager.Stage) .. "-" .. math.floor(gameManager.Round)
			
			-- 8-3 반복 플레이 처리
			local setKey = roundKey
			if setKey == "8-3" then
				setKey = "8-3-1"
				for i = 1, 5 do
					local checkKey = string.format("%s-%d", roundKey, i)
					if isvalid(unitStatistics.SetCharID[checkKey]) then
						setKey = checkKey
					else
						break
					end
				end	
			end
			
			-- DamageTaken 계산
			local nowTotalDamageTaken = 0
			if isvalid(unitStatistics.PhysicalDamageTaken[setKey]) then
				nowTotalDamageTaken += unitStatistics.PhysicalDamageTaken[setKey]
			end
			
			if isvalid(unitStatistics.MagicalDamageTaken[setKey]) then
				nowTotalDamageTaken += unitStatistics.MagicalDamageTaken[setKey]
			end
			
			if isvalid(unitStatistics.TrueDamageTaken[setKey]) then
				nowTotalDamageTaken += unitStatistics.TrueDamageTaken[setKey]
			end
			
			local skillSetDamage = unitStatus.MaxHP * _S01_SkillDescLogic.C00001_Active_SDamage_MaxHPPer[unitInfo.level] +
									unitStatus.MagicalAttack * _S01_SkillDescLogic.C00001_Active_SDamage_Magic[unitInfo.level] +
									(nowTotalDamageTaken - self.beforeTotalDamageTaken) * _S01_SkillDescLogic.C00001_Active_SDamage_DamageTaken[unitInfo.level] * 0.01
			
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Physical")
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, damageInfo[1], 0, damageInfo[2], "skill")
			
			local stunTime = tonumber(_S01_SkillDescLogic.C00001_Active_StunTime_Int[unitInfo.level])
			_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0004", stunTime)
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3.zero, 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void PlaySkillEffect_Range(number time, Entity Tile)
		--범위 표시
		
		local tiles = {}
		if self.Entity.UnitInfo.TeamType == "User" then
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("User_Skill", 1, Tile)
		else
			tiles = _GeneralDirectorLogic:ShowSkillRangeInBattle("Enemy_Skill", 1, Tile)
		end
		
		local removetile = function()
			for i = 1, #tiles do
				tiles[i].Enable = false
				_GeneralDirectorLogic:InsertRangeEntity(tiles[i])
			end
		end
		
		_TimerService:SetTimerOnce(removetile, time)
		
		
		--각 캐릭터별 범위 공격용 이펙트
		if _ESCMenuService.skillEffectAlpha > 0 then
			local destroyandparticle = function()
				local particle = _ParticleService:PlayBasicParticleAttached(BasicParticleType.TinyExplosion, self.Entity, Vector3(0,0,0), 0, Vector3(1.2,1,1), false,
																			{["SortingLayer"] = "Layer1", ["OrderInLayer"] = -1, ["PlaySpeed"] = 0.8, ["ParticleSize"] = 0.5, ["ParticleSpeed"] = 1.5 ,["ParticleCount"] = 0.5, ["ParticleLifeTime"] = 0.1})
				
				_TimerService:SetTimerOnce(function() _ParticleService:RemoveParticle(particle) end, 0.5)
			end
			
			self._T.timer = _TimerService:SetTimerOnce(destroyandparticle, time)
		end
	end

	@ExecSpace("Client")
	method void PlaySkillEffect_Particle(number time)
		--예티 손과 손사이에 힘 표시 : 파티클
		--빈 테이블이라면 먼저 자식 엔터티에 파티클 엔터티가 있는지 확인합니다.
		if #self.Particletable==0 then
			local children=self.Entity.Children
			
			for i=1,#children do
				if children[i].Name=="BasicParticleBattle" then
					table.insert(self.Particletable,children[i])
				end
			end
		end
		
		-- 테이블에 있는 엔터티 중 enable이 꺼져있는 것을 켜서 표시합니다.
		local particle=nil
		for i=1,#self.Particletable do
			if self.Particletable[i].Enable==false then
				particle=self.Particletable[i]
				break
			end
		end
		
		--만약 자식엔터티에 파티클이 없거나 파티클이 모두 켜져 있는 상태라면 새 엔터티 스폰합니다.
		if particle==nil then
			particle=_SpawnService:SpawnByModelId("model://02d2af27-0dd9-46bf-921c-7f094991054f","BasicParticleBattle",Vector3(0,0,0),self.Entity)
			particle.Enable=false
			table.insert(self.Particletable,particle)
		end
			
		--기본정보
		particle.BasicParticleComponent.ParticleType=BasicParticleType.ChargeOrb
		particle.BasicParticleComponent.Loop=true
		particle.BasicParticleComponent.Color=Color.FromHexCode("#ff9233")
		particle.BasicParticleComponent.Color.a=_ESCMenuService.skillEffectAlpha/100
		particle.TransformComponent.Scale=Vector3(0.5,0.5,1)
		
		--레벨과 flip여부에 따라 위치 다르게 설정
		local flip=1
		if self.Entity.UnitInfo.spriteRenderer.SpriteRendererComponent.FlipX==false then
			flip=-1
		end
		
		particle.TransformComponent.Position=Vector3(0.15*flip,1.73,1)
		if self.Entity.UnitInfo.level==2 then
			particle.TransformComponent.Position=Vector3(0.3*flip,2,1)
		elseif self.Entity.UnitInfo.level==3 then
			particle.TransformComponent.Position=Vector3(0.24*flip,2.42,1)
		end
		
		particle.Enable=true
			
		--예티와 페페는 시간에 따라 파티클 크기를 키웁니다.
		local setScale=function()
			local num=particle.TransformComponent.Scale.x+0.02
			particle.TransformComponent.Scale=Vector3(num,num,1)
		end
		
		for i=1,60 do
			_TimerService:SetTimerOnce(setScale,i/20)
		end
			
		_TimerService:SetTimerOnce(function() particle.Enable=false end , time)
		
	end

	@ExecSpace("Client")
	method void RemoveEffect()
		--파티클 삭제
		for i = 1, #self.Particletable do
			self.Particletable[i].Enable = false
		end
		
		--범위 삭제
		local range = self.Entity:GetChildByName("Range")
		if isvalid(range) then
			range:Destroy()
		end
		
		--타이머파티클 삭제
		_TimerService:ClearTimer(self._T.timer)
	end

end