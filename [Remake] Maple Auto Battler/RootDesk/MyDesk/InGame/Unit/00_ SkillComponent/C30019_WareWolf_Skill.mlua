@Component
script C30019_WareWolf_Skill extends Component

	property number skillAnimLength = 0.9

	property number skillCheck = 0

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		
		
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		--log(myUnit.Name .. " use Skill")
		
		local function GetBuff()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetBuff()
			end
		end
		
		_TimerService:SetTimerOnce(GetBuff, 0.95 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0097",self.Entity.UnitInfo.OwnerId)
	end

	@ExecSpace("Server")
	method void SetBuff()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		---@type Entity
		local user = _UserService:GetUserEntityByUserId(unitInfo.OwnerId)
		local teamManager = user.TeamManager
		
		local buffTime = tonumber(_S01_SkillDescLogic.C30019_Active_BuffTime_Int[unitInfo.level])
		local buffAmount = tonumber(_S01_SkillDescLogic.C30019_Active_GetAttackSpeed_Int[unitInfo.level])
		local buffAmount2 = tonumber(_S01_SkillDescLogic.C30019_Active_GetBloodAbsorption_Int[unitInfo.level])
		
		_StatusChangeLogic:GetBuff(myUnit, "Multi_AttackSpeed", buffAmount, buffTime)
		_StatusChangeLogic:GetBuff(myUnit, "Add_BloodAbsorptionPercent", buffAmount2, buffTime)
		
		_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0018", buffTime)
		
		self.skillCheck += 1
		
		local function sCheckFnc()
			self.skillCheck -= 1
		end
		
		_TimerService:SetTimerOnce(sCheckFnc, 5)
	end

	@ExecSpace("Server")
	method void SetBattle()
		self.skillCheck = 0
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleKillUnit(KillUnit event)
		-- Parameters
		-- local Attacker = event.Attacker
		-- local Target = event.Target
		-- local DeadTile = event.DeadTile
		---------------------------------------------------------
		if self.skillCheck > 0 then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			-- 스킬 활성화 중 킬하면 영구 공격력 증가
			_StatusChangeLogic:SetStack(myUnit, "Add_PhysicalAttack", _S01_SkillDescLogic.C30019_Passive_GetPhysicalAttack_Int[unitInfo.level])
		end
	end

end