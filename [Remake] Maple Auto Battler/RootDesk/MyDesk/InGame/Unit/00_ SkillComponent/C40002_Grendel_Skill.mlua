@Component
script C40002_Grendel_Skill extends Component

	property number skillAnimLength = 1.08

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		
		-- Skill Set
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		local function GetBuff()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self:SetBuff()
			end
		end
		
		_TimerService:SetTimerOnce(GetBuff, 0.5 / skillRate)
		
		--사운드 없음
	end

	@ExecSpace("Server")
	method void SetBuff()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local getMagicalAttack = _S01_SkillDescLogic.C40002_Active_GetMagicalAttack_Int[unitInfo.level]
		
		_StatusChangeLogic:GetBuff(myUnit, "Add_MagicalAttack", getMagicalAttack, -1)
		
		--연출
		--_GeneralDirectorLogic:BattleBuffEffect(self.Entity,_RuneCardDirectEnum.MagicalAttack,unitInfo.OwnerId)
		
		unitInfo.AttackComponent.attackType = (unitInfo.AttackComponent.attackType%3) + 1
	end

	@ExecSpace("Server")
	method void SetBattle()
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		unitInfo.AttackComponent.attackType = 1
	end

end