@Component
script C40016_SkyGuardian_Skill extends Component

	property number skillAnimLength = 1.17

	@Sync
	property Entity projectile = nil

	property string attackProjectileRUID = "a8a4451911374ea895ed74fdee10df3b"

	property string hitEffectRUID = "c5149997c8b1478f9ad4b9696d8f2678"

	@ExecSpace("Server")
	method void Skill(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		
		local targetInfo = targetUnit.UnitInfo
		local targetStatus = targetUnit.UnitStatus
		
		-- attack RUID
		local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		
		local animComponent = myUnit.UnitAnimationComponent
		local skillRate = self.skillAnimLength * _BTLogic_New.SSpeedValue
		animComponent:PlayAnimation(skillRate, "Skill", targetUnit, unitInfo.OwnerId)
		
		unitStatus:SetProperty("state", "Skill", "")
		_StatusChangeLogic:SetVariableStatus(myUnit, myUnit, "MP", -1000, "useskill")
		
		-- projectile Spwan
		local spawnTimer = 0
		local function ProjectileSpawn()
			if _BTLogic_New:CheckAttackAble(myUnit, myUnit, "Skill") then
				self.projectile = _UnitSetLogic_New:GetProjectileEntity(unitInfo.OwnerId, "Skill")
				self.projectile:AddComponent(C40016_SkyGuardian_SkillprojectileInfo)
				
				self.projectile.SpriteRendererComponent.SpriteRUID = self.attackProjectileRUID
				self.projectile.TransformComponent.Scale = unitInfo.spriteRenderer.TransformComponent.Scale
				self.projectile.SpriteRendererComponent.FlipX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
				
				self.projectile.C40016_SkyGuardian_SkillprojectileInfo:SetProjectile(self.Entity, targetUnit, 0.6, 2.2, 0.3, 0.2)
				_GeneralDirectorLogic:SetEffectAlpha(self.projectile,unitInfo.OwnerId)
			end
		end
		
		spawnTimer = _TimerService:SetTimerOnce(ProjectileSpawn, 0.5 / skillRate)
		
		--사운드
		_PlaySoundLogic:PlaySound("M0077",self.Entity.UnitInfo.OwnerId)
		
		--연출
		self:SkillLineEffect(targetUnit,0.45 / skillRate,self.Entity.UnitInfo.OwnerId)
		
	end

	@ExecSpace("Server")
	method void SetSkillDamage(Entity targetUnit)
		if isvalid(targetUnit) then
			local myUnit = self.Entity
			local unitInfo = myUnit.UnitInfo
			local unitStatus = myUnit.UnitStatus
			
			local targetInfo = targetUnit.UnitInfo
			local targetStatus = targetUnit.UnitStatus
			local charRUIDRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
			
			self:HitEffect(targetUnit, unitInfo.OwnerId)
			
			local debuffTime = tonumber(_S01_SkillDescLogic.C40016_Active_DebuffTime_Int[unitInfo.level])
			
			-- 침묵
			_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0003", debuffTime)
			
			-- 속박
			_StatusChangeLogic:SetStatus(myUnit, targetUnit, "SE0005", debuffTime)
			
			-- 스킬 데미지
			local skillSetDamage = unitStatus.MagicalAttack * _S01_SkillDescLogic.C40016_Active_SDamage_Magic[unitInfo.level]
			
			local damageInfo = _StatusChangeLogic:CheckDamage(skillSetDamage, myUnit, targetUnit, 0, "Magical")
			
			_StatusChangeLogic:HitDamage(myUnit, targetUnit, 0, damageInfo[1], damageInfo[2], "skill")
		end
	end

	@ExecSpace("Client")
	method void HitEffect(Entity targetUnit)
		local myUnit = self.Entity
		local unitInfo = myUnit.UnitInfo
		
		-- Skill hiteffect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached(self.hitEffectRUID, targetUnit, Vector3(0, 0.3, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("Client")
	method void SkillLineEffect(Entity targetUnit, number time)
		--자신과 적을 선으로 연결
		local line1=_SpawnService:SpawnByModelId("model://c37fb349-52e3-4fc5-bb13-848ca95d5b4a","Line1",Vector3(0,0,0),self.Entity.Parent)
		line1.LineEffectCompo.type="C20011"
		line1.LineEffectCompo.StartEntity=self.Entity
		line1.LineEffectCompo.TargetEntity_1=targetUnit
		
		local destoryline=function()
			line1:Destroy()
		end
		
		_TimerService:SetTimerOnce(destoryline,time)
	end

end