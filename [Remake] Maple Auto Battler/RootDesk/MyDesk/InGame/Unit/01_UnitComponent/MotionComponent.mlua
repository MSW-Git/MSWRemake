@Component
script MotionComponent extends Component

	@ExecSpace("Server")
	method void MotionChangeToIdle()
		-- 유닛의 모션을 Idle 상태로 변경하고 애니메이션을 재생
		local unit = self.Entity.Parent
		local unitInfo = unit.UnitInfo
		local unitStatus = unit.UnitStatus
		
		
		local animComponent = unit.UnitAnimationComponent
		animComponent:PlayAnimation(1, "Idle", nil, unitInfo.OwnerId)
		unitStatus:SetProperty("state", "Idle", "")
	end

	@ExecSpace("Server")
	method void Check()
		-- 유닛의 상태를 확인하고 필요시 모션을 변경
		local unit = self.Entity.Parent
		local unitStatus = unit.UnitStatus
		local unitInfo = unit.UnitInfo
		
		if senderUserId ~= unitInfo.OwnerId then
			return
		end
		
		if unitStatus.state == "Attack" or unitStatus.state == "Skill" then
			self:MotionChangeToIdle()
		elseif unitStatus.state == "Dead" then
			-- unitInfo:CleanPosition(senderUserId)
			_CustomizedBattleEffectService:SetEntityVisible(unit, false, senderUserId)
			unitStatus:SetProperty("state", "Idle", "")
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerEndFrameEvent(SpriteAnimPlayerEndFrameEvent event)
		-- 스프라이트 애니메이션 프레임 종료 이벤트 처리
		--------------- Native Event Sender Info ----------------
		-- Sender: ClimbableSpriteRendererComponent
		-- Space: Client
		---------------------------------------------------------
		-- Sender: SpriteRendererComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		local spriteRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		---------------------------------------------------------
		local unit = self.Entity.Parent
		local unitStatus = unit.UnitStatus
		local unitInfo = unit.UnitInfo
		local unitInfoDBRow = _DataService:GetTable("CharacterInfo"):FindRow("CharID", unitInfo.charID)
		---------------------------------------------------------
		if spriteRUID ~= unitInfoDBRow:GetItem("IdleRUID") and unitInfo.OwnerId == _UserService.LocalPlayer.OwnerId then
			self:Check()
		end
	end

end