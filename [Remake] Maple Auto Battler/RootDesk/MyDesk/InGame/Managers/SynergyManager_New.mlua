	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleOnFieldSynergyCountChanged(OnFieldSynergyCountChanged event)
		-- Parameters
		local TeamType = event.TeamType
		local SynergyID = event.SynergyID
		local ChangedAmount = event.ChangedAmount
		---------------------------------------------------------
		local callBack = function()
			self:OnActivatedSynergyCountChanged(SynergyID, ChangedAmount)
			_SynergyReadyDirectorLogic:ReceiveFieldSynergyCount(SynergyID,ChangedAmount,true,self.Entity.PlayerComponent.UserId) --연출
		end
		
		
		if TeamType == "User" then
			_TimerService:SetTimerOnce(callBack, 0.05)
		else
			_TimerService:SetTimerOnce(function() _SynergyReadyDirectorLogic:ReceiveFieldSynergyCount(SynergyID,ChangedAmount,false,self.Entity.PlayerComponent.UserId) end, 0.05)
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleUnitDead(UnitDead event)
		-- Parameters
		local KillerUnit = event.Attacker
		local DeadUnit = event.Target
		local DeadTile = event.DeadTile
		---------------------------------------------------------
		DeadUnit.UnitSynergy:OnDead()
		
		self:S10007_OnOriginUnitDead(DeadUnit)
		self:S10014_Kill(KillerUnit)
		self:S10018_RecoverHP(DeadUnit)
		self:S10020_KillUnit(KillerUnit, DeadUnit, DeadTile)
		self:S10021_OnKilled(KillerUnit, DeadUnit)
		self:S10022_GainMP(DeadUnit)
		self:S10023_GetCoin(KillerUnit, DeadUnit)
		self:S10026_SeparationByDead(DeadUnit, DeadTile)
		self:S10027_Dead(DeadUnit)
		self:S10037_Dead(DeadUnit)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Model", "e255cca4-fdda-4111-989d-1564991f553a")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		
		---------------------------------------------------------
		if self.Entity.GameManager.PhaseType ~= "Ready" then
			log_warning("준비 단계가 아닙니다.")
			return
		end
		
		local synergyCount = self.Entity.TeamManager.OnFieldSynergy["S10001"]
		if isvalid(synergyCount) == false or synergyCount < 3 then
			log_warning("시너지 활성화 상태가 아닙니다.")
			return
		else
			if self.SynergyStack["S10001"] > 0 then
				self:S10001_GiveReward_Check()
			else
				log_warning("인기도가 없습니다.")
			end
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleMergeUnit(MergeUnit event)
		-- Parameters
		local MergedUnit = event.MergedUnit
		local TargetLevel = event.TargetLevel
		---------------------------------------------------------
		local synergyCount = self.Entity.TeamManager.OnFieldSynergy["S10007"]
		if isvalid(synergyCount) and synergyCount >= 3 and MergedUnit.UnitInfo:DoesHaveSynergy("S10007") then
			self:S10007_SpawnShadowReadyPhase(synergyCount, "User")
		end
		
		
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleEquipedItem(EquipedItem event)
		-- Parameters
		local Unit = event.Unit
		local ItemID = event.ItemID
		---------------------------------------------------------
		local synergyCount = self.Entity.TeamManager.OnFieldSynergy["S10007"]
		if isvalid(synergyCount) and synergyCount >= 3 and Unit.UnitInfo:DoesHaveSynergy("S10007") then
			self:S10007_SpawnShadowReadyPhase(synergyCount, "User")
		end
	end

end