@Component
script SynergyManager_New extends Component

	@TargetUserSync
	property SyncTable<string, number> SynergyStack

	@TargetUserSync
	property SyncTable<string, number> Enemy_SynergyStack

	property SyncTable<string, Entity> S10007_OriginUnit

	@TargetUserSync
	property SyncTable<string, Entity> S10025_TargetUnit

	@TargetUserSync
	property SyncTable<Entity> S10026_YetiUnits

	@TargetUserSync
	property SyncTable<Entity> S10026_PepeUnits

	@TargetUserSync
	property SyncTable<Entity> S10026_CombinedUnits

	@TargetUserSync
	property SyncTable<string, number> SynergyRuneOn

	@TargetUserSync
	property SyncTable<string, number> Enemy_SynergyRuneOn

	property SyncTable<string, number> LoadedS10025Pos

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		self:InitAllStacks()
		
	end

	@ExecSpace("ServerOnly")
	method void InitAllStacks()
		-- 모든 시너지 관련 스택값을 0 으로 지정합니다.
		--------------------------------------------------------------------
		self.SynergyStack["S10001"] = 0				-- 마스코트 : 전투 참여 시 인기도 증가
		self.SynergyStack["S10004_Default"] = 0		-- 마법사 : 아군의 마력 증가
		self.SynergyStack["S10004"] = 0				-- 마법사 : 마법사가 스킬 사용시 마법사들의 마력 추가 증가
		self.SynergyStack["S10009"] = 0 			-- 싸움꾼 : 아군의 최대 체력 증가
		self.SynergyStack["S10010"] = 0				-- 저격수 : 사거리 +1 및 공격속도 증가
		self.SynergyStack["S10024_ActiveType"] = 0	-- 전직교관 : 현재 활성화된 타입 저장
		self.SynergyStack["S10024_Armor"] = 0		-- 전직교관 1) 방어력
		self.SynergyStack["S10024_AttackSpeed"] = 0 -- 전직교관 2) 공격속도
		self.SynergyStack["S10024_Power"] = 0		-- 전직교관 3) 공격력 및 마력
		self.SynergyStack["S10024_HPnMP"] = 0		-- 전직교관 4) MaxHP, MaxMP
		self.SynergyStack["S10024_Unstoppable"] = 0 -- 전직교관 5) 전투 시작 후 12초간 저지 불가
		if self.SynergyStack["S10025_Pos"] == nil then -- 기사단장 : 성역 위치 무작위 지정 - "y00x" 형태로 지정 (예:3행 5열인 경우 3005)
			self.SynergyStack["S10025_Pos"] = 0
		end
		 
		self.SynergyStack["S10029"] = 0				-- 악몽의 지배자 (루시드) : 루시드가 플레이어 대상 전투에 참여하면 꿈의 조각을 얻습니다. 전투 시작 시, 꿈의 조각 수만큼 무작위 아군 1명이 MP를 5 얻습니다. 이 효과는 같은 아군에게 지급될 수도 있습니다.
		self.SynergyStack["S10032_Type"] = 0	-- 마가티아 룬타입 임시 지정
		
		--------------------------------------------------------------------
		self.Enemy_SynergyStack["S10001"] = 0				-- 마스코트 : 전투 참여 시 인기도 증가
		self.Enemy_SynergyStack["S10004_Default"] = 0		-- 마법사 : 아군의 마력 증가
		self.Enemy_SynergyStack["S10004"] = 0				-- 마법사 : 마법사가 스킬 사용시 마법사들의 마력 추가 증가
		self.Enemy_SynergyStack["S10009"] = 0 			-- 싸움꾼 : 아군의 최대 체력 증가
		self.Enemy_SynergyStack["S10010"] = 0				-- 저격수 : 사거리 +1 및 공격속도 증가
		self.Enemy_SynergyStack["S10024_Armor"] = 0		-- 전직교관 1) 방어력
		self.Enemy_SynergyStack["S10024_AttackSpeed"] = 0 -- 전직교관 2) 공격속도
		self.Enemy_SynergyStack["S10024_Power"] = 0		-- 전직교관 3) 공격력 및 마력
		self.Enemy_SynergyStack["S10024_HPnMP"] = 0		-- 전직교관 4) MaxHP, MaxMP
		self.Enemy_SynergyStack["S10024_Unstoppable"] = 0 -- 전직교관 5) 전투 시작 후 12초간 저지 불가
		if self.Enemy_SynergyStack["S10025_Pos"] == nil then -- 기사단장 : 성역 위치 무작위 지정 - "y00x" 형태로 지정 (예:3행 5열인 경우 3005)
			self.Enemy_SynergyStack["S10025_Pos"] = 0
		end
		 	
		self.Enemy_SynergyStack["S10029"] = 0				-- 악몽의 지배자 (루시드) : 루시드가 플레이어 대상 전투에 참여하면 꿈의 조각을 얻습니다. 전투 시작 시, 꿈의 조각 수만큼 무작위 아군 1명이 MP를 5 얻습니다. 이 효과는 같은 아군에게 지급될 수도 있습니다.
		self.Enemy_SynergyStack["S10032_Type"] = _UtilLogic:RandomIntegerRange(1,2)		-- 마가티아 룬타입 임시 지정
		--------------------------------------------------------------------
		
		local synergyTable = _DataService:GetTable("SynergyInfo")
		
		-- 시너지 부가 효과를 받는 룬이 활성화 되어있는지 체크하는 용도
		for i = 1, synergyTable:GetRowCount() do
			local synergyID = synergyTable:GetRow(i):GetItem("SynergyID")
			self.SynergyRuneOn[synergyID] = 0
			self.Enemy_SynergyRuneOn[synergyID] = 0
		end
	end

	@ExecSpace("ServerOnly")
	method void OnGameStart()
		-- 게임을 최초 시작할 때 한 번 호출합니다. (불러오기 시에는 호출하지 않음)
		------------------------------------------------
		self:S10025_SetSaintArea()
		self:S10031_SetItemOrder()
	end

	@ExecSpace("ServerOnly")
	method void ClearAllStacks()
		self.SynergyStack["S10004"] = 0
		self.SynergyStack["S10014"] = 0
		self.Enemy_SynergyStack["S10014"] = 0
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		if name == "SynergyStack" then
			
			if _UserService.LocalPlayer.CurrentMap.MapComponent.IsDynamicMap == false then return end
			
			--마스코트 스택 체크
			local stack = _UserService.LocalPlayer.SynergyManager_New.SynergyStack["S10001"]
			
			local mascot = _UserService.LocalPlayer.CurrentMap:GetChildByName("MascotSynergy")
			if isvalid(mascot) then
				mascot = _UserService.LocalPlayer.CurrentMap:GetChildByName("MascotSynergy"):GetChildByName("MascotEntity") --  _EntityService:GetEntity("17e6364c-8a17-47c9-bb8a-a610cff19e2a")--/maps/Arena/MascotEntity
				
				_SynergyReadyDirectorLogic:SetS10001StackText(stack)
				
				if stack > 0 then
					_SynergyReadyDirectorLogic:Set10001MascotInfo(stack)
				end
			else
				_TimerService:SetTimerOnce(function() mascot = _UserService.LocalPlayer.CurrentMap:GetChildByName("MascotSynergy"):GetChildByName("MascotEntity") 	_SynergyReadyDirectorLogic:SetS10001StackText(stack)
				_SynergyReadyDirectorLogic:Set10001MascotInfo(stack) end , 0.5)
		
			end
		
			
		elseif name=="SynergyRuneOn" then
			for  k,v in pairs(self.SynergyRuneOn) do
				if v > 0 then -- 전체 갱신을 부르면 바로 break
					local synergylist=_EntityService:GetEntity("c48ec9cb-4427-42f2-8a5b-3c3fa47887a7")--/ui/Arena_Default/SynergyList_Left
					synergylist.UI_SynergyListComponent:RefreshUI()
					break
				else
					_RuneCardDirector:StrongerSynergyDirector(k,false,false)
				end
			end
		elseif name=="Enemy_SynergyRuneOn" then
			for  k,v in pairs(self.Enemy_SynergyRuneOn) do
				if v > 0 then
					_RuneCardDirector:StrongerSynergyDirector(k,true,true)
				else
					_RuneCardDirector:StrongerSynergyDirector(k,true,false)
				end
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method void OnMergeUnit()
		-- 유닛이 머지될 때 호출합니다.
		------------------------------------------------------------------------
		local ownSynergies = self.Entity.UnitInfo:GetOwnSynergies()
		------------------------------------------------------------------------
		for i=1, #ownSynergies do
			if ownSynergies[i] == "S10032" then
				self:S10032_Default("User")
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method void OnActivatedSynergyCountChanged(string synergyID, number amount)
		-- 전장에 활성화된 시너지 숫자가 변경될 때마다 호출합니다.
		------------------------------------------------------------------------
		if synergyID == "S10004" then
			self:S10004_Default("User")
		elseif synergyID == "S10007" then
			self:S10007_SpawnShadowReadyPhase(amount, "User")
		elseif synergyID == "S10008" then
			self:S10008_Stat("User")
		elseif synergyID == "S10009" then
			self:S10009_Default("User")
		elseif synergyID == "S10011" then
			self:S10011_GetItem(amount)
		elseif synergyID == "S10015" then
			self:S10015_SpawnUnitReadyPhase(amount, "User")
		elseif synergyID == "S10021" then
			log("OnActivatedSynergyCountChanged")
			self:S10021_SpawnStoneReadyPhase(amount, "User")
		elseif synergyID == "S10023" then
			self:S10023_StatSet(amount, "User")
		elseif synergyID == "S10024" then
			self:S10024("User")
		elseif synergyID == "S10031" then
			self:S10031_GetItem(amount)
		elseif synergyID == "S10032" then
			self:S10032_Default("User")
		elseif synergyID == "S10034" then
			self:S10034_Default("User")
		end
		------------------------------------------------------------------------
		local ownUnits = self.Entity.TeamManager.OwnUnits
		for i=1, #ownUnits do
			ownUnits[i].UnitSynergy:OnActivatedSynergyCountChanged()
		end
	end

	@ExecSpace("ServerOnly")
	method void OnReadyPhase()
		-- 준비 단계 시작 시 실행
		--------------------------------------------------
		for synergyID, count in pairs(self.Entity.TeamManager.OnFieldSynergy) do
			if synergyID == "S10001" and count >= 10 then
				_TimerService:SetTimerOnce(function()
					self:S10001_GiveReward()
				end, 1)
			end
		end
		
		self:S10026_CleanPhase()
	end

	@ExecSpace("ServerOnly")
	method void OnFieldUnitCountChanged()
		-- 전장 내 배치된 유닛 수가 변경되었을 때 호출합니다.
		-- 준비 단계에서 "User"팀의 유닛 수에만 적용
		-------------------------------------------------------
		self:S10008_Stat("User")
		self:S10032_Default("User")
		self:S10034_Default("User")
	end

	@ExecSpace("ServerOnly")
	method void OnLevelUp()
		self:S10023_StatSet(self.Entity.TeamManager.OnFieldSynergy["S10023"], "User")
	end

	@ExecSpace("ServerOnly")
	method void OnBattleSettingPhase()
		self:S10026_Spawn("User")
		
		
		-- 여기서 적 시너지 효과 활성화 시키기.
		local enemies = self.Entity.TeamManager.EnemyUnits
		for i=1, #enemies do
			enemies[i].UnitSynergy:OnActivatedSynergyCountChanged()
		
		end
		
		self:S10004_Default("Enemy")
		self:S10008_Stat("Enemy")
		self:S10009_Default("Enemy")
		self:S10015_SpawnUnitReadyPhase(self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10015"], "Enemy")
		self:S10015_ApplySumOfStarLevel("User")
		self:S10015_ApplySumOfStarLevel("Enemy")
		self:S10023_StatSet(self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10023"], "Enemy")
		self:S10024("Enemy")
		self:S10025_SetSainAreaTarget("User")
		self:S10025_SetSainAreaTarget("Enemy")
		self:S10026_Spawn("Enemy")
		self:S10032_Default("Enemy")
		self:S10034_Default("Enemy")
	end

	@ExecSpace("ServerOnly")
	method void OnBattleStart(string roundType)
		-- 전투가 시작할 때 호출합니다.
		--------------------------------------------------------
		local gameManager = self.Entity.GameManager
		local currentStage = gameManager.Stage
		local currentRound = gameManager.Round
		--------------------------------------------------------
		if roundType == "Battle" then
			self:S10001_GetStack() -- 마스코트 시너지 효과는 플레이어 전투에서만 효과 발생
		end
		
		self:S10007_SpawnShadowBattlePhase()
		
		self:S10012_GetInvincible("User", currentStage, currentRound)
		self:S10012_GetInvincible("Enemy", currentStage, currentRound)
		local s10012_after15sec = function()
			self:S10012_GetInvincible("User", currentStage, currentRound)
			self:S10012_GetInvincible("Enemy", currentStage, currentRound)
		end
		_TimerService:SetTimerOnce(s10012_after15sec, 15)
		
		
		self:S10015_SpawnUnitBattlePhase("User")
		
		
		self:S10015_SpawnUnitBattlePhase("Enemy")
		
		local callRecursiveFunc_S10018 = function()
			self:S10018_Curse("user")
			self:S10018_Curse("enemy")
		end
		_TimerService:SetTimerOnce(callRecursiveFunc_S10018, 3)
		
		self:S10019_OnBattleStart("User")
		self:S10019_OnBattleStart("Enemy")
		
		self:S10020_RecoverMP("User")
		self:S10020_RecoverMP("Enemy")
		
		self:S10021_OnBattleStart("User")
		self:S10021_OnBattleStart("Enemy")
		
		self:S10023_GetExp()
		
		self:S10024_BattleStart()
		
		self:S10025_GetSaintAreaEffect("User")
		self:S10025_GetSaintAreaEffect("Enemy")
		
		self:S10029("User")
		self:S10029("Enemy")
		
		self:S10031_BattleStart("User")
		self:S10031_BattleStart("Enemy")
		
		self:S10032_GetItem("User")
		self:S10032_GetItem("Enemy")
		
		self:S10036_BattleStart("User")
		self:S10036_BattleStart("Enemy")
		
		self:S10038_Blessing("User")
		self:S10038_Blessing("Enemy")
		
		_AchievementService:UpdateProgress_SynergyActivation(self.Entity)
		
	end

	@ExecSpace("ServerOnly")
	method void OnSkillUsedByAllies(Entity skillUsedUnit)
		
		-- 아군이 스킬을 사용했을 때
		--------------------------------------------------------------
		---@type table<string>
		local ownSynergies = {}
		
		-- 유닛 기초 시너지
		local unitStatus = skillUsedUnit.UnitStatus
		local synergies = skillUsedUnit.UnitInfo.synergyList 
		for i=1, #synergies do
			table.insert(ownSynergies, synergies[i])
		end
		
		-- 상징을 통해 얻는 시너지
		local equippedItems = skillUsedUnit.UnitStatus.EquippedItemIDList
		for i=1, #equippedItems do
			local keyHead = string.sub(equippedItems[i], 1, 2)
			local keyTail = string.sub(equippedItems[i], 3, -1)
			if keyHead == "EI" then
				table.insert(ownSynergies, "S"..keyTail)
			end
		end
		--------------------------------------------------------------
		for i=1, #ownSynergies do
			-- 마법사가 스킬을 사용했을 때
			if ownSynergies[i] == "S10004" then
				self:S10004_UseSkill(skillUsedUnit)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void OnBattleEnd()
		self:S10026_SeparationByBattleEnd()
		
	end

	@ExecSpace("ServerOnly")
	method void RefreshUnitStatus_AllOwnUnits(boolean onFieldUnitOnly, string stat)
		-- 아군 전체의 스탯을 refresh 합니다.
		-- onFieldUnitOnly : 전장 위의 유닛만 새로고침할 지 결정합니다.
		----------------------------------------
		local ownUnits = self.Entity.TeamManager.OwnUnits
		
		if stat == "All" then
			if onFieldUnitOnly == true then
				for i=1, #ownUnits do
					if ownUnits[i].UnitInfo:IsOnFieldUnit() == true then
						ownUnits[i].UnitStatus:SetUnitStatus(false)
					end
				end
			else
				for i=1, #ownUnits do
					ownUnits[i].UnitStatus:SetUnitStatus(false)
				end
			end
		else
			if onFieldUnitOnly == true then
				for i=1, #ownUnits do
					if ownUnits[i].UnitInfo:IsOnFieldUnit() == true then
						ownUnits[i].UnitStatus:SetUnitStatusByStat(false, stat)
					end
				end
			else
				for i=1, #ownUnits do
					ownUnits[i].UnitStatus:SetUnitStatusByStat(false, stat)
				end
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method void RefreshUnitStatus_Target(Entity target)
		target.UnitStatus:SetUnitStatus(false)
		
	end

	@ExecSpace("ServerOnly")
	method void S10001_GetStack()
		-- 마스코트 캐릭터가 플레이어 전투에 참여하면 인기도를 얻습니다. 
		local activatedSynergyCount = self.Entity.TeamManager.OnFieldSynergy["S10001"]
		----------------------------------------------------------------------
		if not isvalid(activatedSynergyCount) then
			-- 체크 필요 없음
			return
		end
		----------------------------------------------------------------------
		if activatedSynergyCount < 3 then
			--log("시너지 비활성화 상태")
		elseif activatedSynergyCount < 5 then
			self.SynergyStack["S10001"] += 10
			--log("마스코트 인기도 10 획득")
		elseif activatedSynergyCount < 7 then
			self.SynergyStack["S10001"] += 20
			--log("마스코트 인기도 20 획득")
		elseif activatedSynergyCount < 10 then
			self.SynergyStack["S10001"] += 30
			--log("마스코트 인기도 30 획득")
		else
			self.SynergyStack["S10001"] += 40
			--log("마스코트 인기도 40 획득")
		end
		
		-- 룬카드 시너지 활성화 체크
		if 0 < self.SynergyRuneOn["S10001"] then
			self.SynergyStack["S10001"] += 5 * self.SynergyRuneOn["S10001"]
		end
	end

	@ExecSpace("Server")
	method void S10001_GiveReward_Check()
		-- 보상 받기 버튼을 눌렀을 때, 누적된 인기도에 따라보상을 받습니다.
		-----------------------------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		
		-- 시너지 활성화 여부를 검사합니다.
		local activatedSynergyCount = teamManager.OnFieldSynergy["S10001"]
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
			return
		end
		
		-- 준비 단계가 아니면 받을 수 없습니다.
		if self.Entity.GameManager.PhaseType ~= "Ready" then
			return
		end
		-----------------------------------------------------------------------
		self:S10001_GiveReward()
		
		-- 인기도를 소모합니다.
		self.SynergyStack["S10001"] = 0
		--_SynergyDirectorLogic:Set10001MascotInfo(0,self.Entity.PlayerComponent.UserId)
		-------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void S10001_GiveReward()
		-- 보상 받기 버튼을 눌렀을 때, 누적된 인기도에 따라보상을 받습니다.
		-----------------------------------------------------------------------
		local teamManager = self.Entity.TeamManager
		local user = self.Entity
		-----------------------------------------------------------------------
		local stackedValue = self.SynergyStack["S10001"]
		local convertedValue = math.floor((stackedValue ^ 1.25) * 0.1) -- 골드 가치로 환산
		local directorData={["Gold"]=0,["Item"]={},["Char"]=0,["Stack"]=stackedValue} -- 연출을 위해 필요한 데이터들을 넣습니다.
		
		-- log("convertedValue = ", convertedValue)
		
		-- 보상을 랜덤으로 받습니다.
		local rewardTable = {
			"CI0003",
			"CI0004",
			"CI0005",
			"CI0008",
			"IB00001",
			"IB00004",
			"IB00013",
			"EI10001",
			"C1",
			"C2",
			"C3",
			"C4",
			"C5",
			"C20002",
			"C30001",
			"C50001",
			"GOLD"
		}
		
		
		local rewardValueTable = {
			["CI0003"] = 7,
			["CI0004"] = 10,
			["CI0005"] = 20,
			["CI0008"] = 10,
			["IB00001"] = 7,
			["IB00004"] = 10,
			["IB00013"] = 12,
			["EI10001"] = 25,
			["C1"] = 1,
			["C2"] = 3,
			["C3"] = 6,
			["C4"] = 10,
			["C5"] = 15,
			["C20002"] = 4,
			["C30001"] = 9,
			["C50001"] = 75,
			["GOLD"] = 150
		}
		
		local rewardList = {
			["CI0003"] = 0,
			["CI0004"] = 0,
			["CI0005"] = 0,
			["CI0008"] = 0,
			["IB00001"] = 0,
			["IB00004"] = 0,
			["IB00013"] = 0,
			["EI10001"] = 0,
		
			["C1"] = 0,
			["C2"] = 0,
			["C3"] = 0,
			["C4"] = 0,
			["C5"] = 0,
			["C20002"] = 0,
			["C30001"] = 0,
			["C50001"] = 0,
			["GOLD"] = 0
		}
		
		local checkingCount = 0
		while convertedValue > 0 do
			local randomReward = rewardTable[_UtilLogic:RandomIntegerRange(1, #rewardTable)]
			local rewardValue = rewardValueTable[randomReward]
			
			if rewardValue <= convertedValue then
				rewardList[randomReward] += 1
				convertedValue -= rewardValue
			else
				if checkingCount > 4 then
					-- 나머지 보상을 골드로 받습니다.
					teamManager:AddGolds(convertedValue, "synergy")
					directorData["Gold"]=convertedValue --연출을 위해 데이터를 저장합니다.
					convertedValue = 0
				else
					checkingCount += 1
				end
			end
		end
		
			for rewardID, rewardAmount in pairs(rewardList) do
				-- log("Get Reward : ", rewardID, "_", rewardAmount)
				for i=1, rewardAmount do
					if rewardID == "GOLD" then
						teamManager:AddGolds(300, "synergy")
						directorData["Gold"]+=300
					elseif rewardID == "C20002" then
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, rewardID, 1, "Force")
						directorData["Char"]+=1
					elseif rewardID == "C30001" then
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, rewardID, 1, "Force")
						directorData["Char"]+=1
					elseif rewardID == "C50001" then
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, rewardID, 2, "Force")
						directorData["Char"]+=1
					elseif rewardID == "C1" then
						local charIdx = _UtilLogic:RandomIntegerRange(1,13) + 10000
						local charID = string.format("C%d", charIdx)
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
					elseif rewardID == "C2" then
						local charIdx = _UtilLogic:RandomIntegerRange(1,13) + 20000
						local charID = string.format("C%d", charIdx)
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
					elseif rewardID == "C3" then
						local charIdx = _UtilLogic:RandomIntegerRange(1,13) + 30000
						local charID = string.format("C%d", charIdx)
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
					elseif rewardID == "C4" then
						local charIdx = _UtilLogic:RandomIntegerRange(1,13) + 40000
						local charID = string.format("C%d", charIdx)
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
					elseif rewardID == "C5" then
						local charIdx = _UtilLogic:RandomIntegerRange(1,8) + 50000
						local charID = string.format("C%d", charIdx)
						_UnitSetLogic_New:SpawnUnit(user.OwnerId, charID, 1, "Force")
					else
						table.insert(teamManager.OwnItems, rewardID)
						table.insert(directorData["Item"],rewardID..","..#teamManager.OwnItems)
					end
					
				end
			end
		
		-- 연출 관련 코드 : 연출에 필요한 데이터들을 별도 테이블변수(directorData)에 저장해 파라미터로 보냅니다.
		if #directorData["Item"]==0 then
			directorData["Item"]=nil
		end
		
		directorData=_HttpService:JSONEncode(directorData)
		
		-- 보상 연출을 보여줍니다.
		local stack = self.SynergyStack["S10001"]  
		_SynergyReadyDirectorLogic:S10001GetReward(directorData,self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void S10004_UseSkill(Entity usedUnit)
		-- 마법사가 스킬을 사용할 때마다 아군 마법사들이 추가 마력을 얻습니다.
		--------------------------------------------------------------------------------
		local teamType = usedUnit.UnitInfo.TeamType
		--------------------------------------------------------------------------------
		local activatedSynergyCount = self.Entity.TeamManager.OnFieldSynergy["S10004"]
		if teamType == "Enemy" then
			activatedSynergyCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10004"]
		end
		--------------------------------------------------------------------------------
		-- 활성화된 시너지에 따라 증가하는 마력 수치 변경
		local addedMagicalPowerAmount = 0
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
			return
		elseif activatedSynergyCount < 5 then
			addedMagicalPowerAmount = 3
		elseif activatedSynergyCount < 7 then
			addedMagicalPowerAmount = 5
		elseif activatedSynergyCount < 10 then
			addedMagicalPowerAmount = 7
		else
			addedMagicalPowerAmount = 12
		end
		--------------------------------------------------------------------------------
		-- 필드 위 아군에게 스탯 적용
		if teamType == "Enemy" then
			local targetUnits = self.Entity.TeamManager.EnemyUnits
			for i=1, #targetUnits do
				if targetUnits[i].UnitInfo:IsOnFieldUnit() then
					if ( 0 < self.Enemy_SynergyRuneOn["S10004"] ) or targetUnits[i].UnitInfo:DoesHaveSynergy("S10004") then
						targetUnits[i].UnitSynergy:S10004_Magician(addedMagicalPowerAmount)
						targetUnits[i].UnitStatus:SetUnitStatusByStat(true, "MagicalAttack")
						
						--연출
						_GeneralDirectorLogic:BattleBuffEffect(targetUnits[i],_RuneCardDirectEnum.MagicalAttack,self.Entity.PlayerComponent.UserId)
					end
				end
			end
		else 
			local ownUnits = self.Entity.TeamManager.OwnUnits
			for i=1, #ownUnits do
				if ownUnits[i].UnitInfo:IsOnFieldUnit() then
					if ( 0 < self.SynergyRuneOn["S10004"] ) or ownUnits[i].UnitInfo:DoesHaveSynergy("S10004") then
						ownUnits[i].UnitSynergy:S10004_Magician(addedMagicalPowerAmount)
						ownUnits[i].UnitStatus:SetUnitStatusByStat(true, "MagicalAttack")
						
						--연출
						_GeneralDirectorLogic:BattleBuffEffect(ownUnits[i],_RuneCardDirectEnum.MagicalAttack,self.Entity.PlayerComponent.UserId)
					end
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10004_Default(string teamType)
		-- 마법사 : 아군의 마력이 증가
		-- 10 시너지인 경우, 전투 시작 시 모든 아군이 MP를 100% 획득
		-----------------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		------------------------------------------------------------
		-- 이미 적용 중이던 효과 수치 (비교를 위해)
		local beforeStack = self.SynergyStack["S10004_Default"]
		
		-- 활성화 유닛 수에 따라 버프 수치 변경하여 적용
		local activatedSynergyCount = 0
		if teamType == "Enemy" then
			activatedSynergyCount = teamManager.EnemyOwnedFieldSynergy["S10004"]
			
			-- 룬카드 시너지 활성화 체크
			local addRuneAmount = 0
			if ( (0 < self.SynergyRuneOn["S10004"]) and teamType == "User") then
				addRuneAmount += 20 * self.SynergyRuneOn["S10004"]
			elseif ( (0 < self.Enemy_SynergyRuneOn["S10004"]) and teamType == "Enemy") then
				addRuneAmount += 20 * self.Enemy_SynergyRuneOn["S10004"]
			end
			
			
			if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
				self.Enemy_SynergyStack["S10004_Default"] = 0
			elseif activatedSynergyCount < 5 then
				self.Enemy_SynergyStack["S10004_Default"] = 15 + addRuneAmount
			elseif activatedSynergyCount < 7 then
				self.Enemy_SynergyStack["S10004_Default"] = 25 + addRuneAmount
			elseif activatedSynergyCount < 10 then
				self.Enemy_SynergyStack["S10004_Default"] = 35 + addRuneAmount
			else
				self.Enemy_SynergyStack["S10004_Default"] = 60 + addRuneAmount
				
				-- 10 시너지인 경우, 모든 아군의 MP를 100%로 채움
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:SetVariableStatus(unit, unit, "MP", unit.UnitStatus.MaxMP, "synergy")
					end
				end
			end
		else 
			activatedSynergyCount = teamManager.OnFieldSynergy["S10004"]
			
			-- 룬카드 시너지 활성화 체크
			local addRuneAmount = 0
			if 0 < self.SynergyRuneOn["S10004"] then
				addRuneAmount = 20
			end
			
			if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
				self.SynergyStack["S10004_Default"] = 0
			elseif activatedSynergyCount < 5 then
				self.SynergyStack["S10004_Default"] = 15 + addRuneAmount
			elseif activatedSynergyCount < 7 then
				self.SynergyStack["S10004_Default"] = 25 + addRuneAmount
			elseif activatedSynergyCount < 10 then
				self.SynergyStack["S10004_Default"] = 35 + addRuneAmount
			else
				self.SynergyStack["S10004_Default"] = 50 + addRuneAmount
				
				-- 10 시너지인 경우, 모든 아군의 MP를 100%로 채움
				for _, unit in pairs(teamManager.OwnUnits) do
					if unit.UnitAIWanderComponent.Enable then
						_StatusChangeLogic:SetVariableStatus(unit, unit, "MP", unit.UnitStatus.MaxMP, "synergy")
					end
				end
			end
			
			-- 변경값과 이전 효과 수치가 다르면, 바뀐 것이므로 모든 유닛의 스탯을 다르게 적용
			if beforeStack ~= self.SynergyStack["S10004_Default"] then
				self:RefreshUnitStatus_AllOwnUnits(false, "MagicalAttack")
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10007_SpawnShadowReadyPhase(number activatedCount, string teamType)
		--[[
		팀에서 가장 강한 그림자 캐릭터가 쉐도우 파트너를 소환합니다. 
		기본 공격 및 스킬 사용 시 쉐도우 파트너가 함께 공격합니다. 
		쉐도우 파트너의 피해량은 그림자 캐릭터의 70%만 적용됩니다.
		]] 
		-----------------------------------------------------------------------------------
		if isvalid(activatedCount) == false or activatedCount < 3 then
			_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, nil, teamType, "Clear", 1)
			_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, nil, teamType, "Clear", 2)
		else
			-- 가장 강한 유닛 선택 (아이템 장착 수 > 별 등급 > 코스트 순)
			---@type table<Entity>
			local ownUnits
			
			if teamType == "User" then
				ownUnits = self.Entity.TeamManager.OwnUnits
			else
				ownUnits = self.Entity.TeamManager.EnemyUnits
			end
			
			---@type Entity
			local originUnit = nil -- 쉐도우 파트너를 소환할 원본 유닛
			local itemCount = 0
			local starLevel = 0
			local cost = 0
			for _, unit in pairs(ownUnits) do
				local unitInfo = unit.UnitInfo
				if unitInfo:IsOnFieldUnit() and unitInfo:DoesHaveSynergy("S10007") and unitInfo.IsResellable then
					if isvalid(originUnit) == false then
						originUnit = unit
						itemCount = #originUnit.UnitStatus.EquippedItemIDList
						starLevel = originUnit.UnitInfo.level
						cost = originUnit.UnitInfo.cost
						continue
					end
					
					-- (1) 아이템 수량 비교
					local unitsItemCount = #unit.UnitStatus.EquippedItemIDList 
					if unitsItemCount > itemCount then
						originUnit = unit
						itemCount = unitsItemCount
					elseif unitsItemCount == itemCount then
						-- (2) 별 등급 비교
						local unitsLevel = unitInfo.level
						if unitsLevel > starLevel then
							originUnit = unit
							starLevel = unitsLevel
						elseif unitsLevel == starLevel then
							-- (3) 구매 비용 비교
							local unitsCost = unitInfo.cost
							if unitsCost > cost then
								originUnit = unit
								cost = unitsCost
							end
						end
					end
				end
			end
			
			
			self.S10007_OriginUnit[teamType] = originUnit
			
			-- 그림자 소환
			if isvalid(originUnit) == false then
				_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, originUnit, teamType, "Clear", 1)
				_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, originUnit, teamType, "Clear", 2)
			
			elseif activatedCount < 5 then
				_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, originUnit, teamType, "Spawn", 1)
				_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, originUnit, teamType, "Clear", 2)
			else
				_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, originUnit, teamType, "Spawn", 1)
				_UnitSetLogic_New:SpawnShadow(self.Entity.OwnerId, originUnit, teamType, "Spawn", 2)
			end
		end
		-----------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void S10007_SpawnShadowBattlePhase()
		local userID = self.Entity.OwnerId
		----------------------------------------------------
		local synergyCount = self.Entity.TeamManager.OnFieldSynergy["S10007"]
		if isvalid(synergyCount) == false or synergyCount < 3 then
			
		elseif synergyCount < 5 then -- (3) 1마리
			_UnitSetLogic_New:SpawnShadow(userID, self.S10007_OriginUnit["User"], "User", "InBattle", 1)
					
		else						 -- (5) 2마리
			_UnitSetLogic_New:SpawnShadow(userID, self.S10007_OriginUnit["User"], "User", "InBattle", 1)
			_UnitSetLogic_New:SpawnShadow(userID, self.S10007_OriginUnit["User"], "User", "InBattle", 2)
		end
		----------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void S10007_OnOriginUnitDead(Entity deadUnit)
		local userID = self.Entity.OwnerId
		----------------------------------------------------
		local deadUnitTeam = deadUnit.UnitInfo.TeamType
		local activatedSynergyCount = 0
		if deadUnitTeam == "User" then
			activatedSynergyCount = self.Entity.TeamManager.OnFieldSynergy["S10007"]
		elseif deadUnitTeam == "Enemy" then
			activatedSynergyCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10007"]
		end
		
		-- 예외처리: 보유한 시너지 숫자 만족 x
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
			return
		else
			-- 예외처리: 사망한 유닛이 원본 유닛이 아니라면 종료
			if isvalid(self.S10007_OriginUnit[deadUnitTeam]) == false or self.S10007_OriginUnit[deadUnitTeam] ~= deadUnit then
				return
			end
		
			local units = _UnitSetLogic_New.UnitsParentEntity[userID]
			---@type table<Entity>
			local shadowUnits_user = {
				units:GetChildByName("BTUnit_Shadow1"),
				units:GetChildByName("BTUnit_Shadow2"),
			}
			---@type table<Entity>
			local shadowUnits_enemy = {
				units:GetChildByName("EnemyUnit_Shadow1"),
				units:GetChildByName("EnemyUnit_Shadow2"),
			}
			
			local killUnit = function(target)
				-- 무적, 은신을 지움
				_StatusChangeLogic:RemoveStatusEffect(target, "SE0001")
				_StatusChangeLogic:RemoveStatusEffect(target, "SE0002")
				
				-- 강제 사망 처리
				_StatusChangeLogic:KillUnitForce(nil, target)
			end
			
			if activatedSynergyCount >= 5 then
				if deadUnitTeam == "User" then
					killUnit(shadowUnits_user[2])
					
				elseif deadUnitTeam == "Enemy" then
					killUnit(shadowUnits_enemy[2])
				end
					
			end
			
			if deadUnitTeam == "User" then
				killUnit(shadowUnits_user[1])
				
			elseif deadUnitTeam == "Enemy" then
				killUnit(shadowUnits_enemy[1])
			end
		
		end
	end

	@ExecSpace("ServerOnly")
	method void S10008_Stat(string teamType)
		-- 추격자 : 이동 속도가 100% 증가합니다.
		-------------------------------------------
		-- 룬카드 시너지 활성화 체크 변수
		local runeActiveCount = 0
		-------------------------------------------
		-- 활성화된 시너지 수를 검사
		local activatedCount = 0
		if teamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10008"]
			if 0 < self.SynergyRuneOn["S10008"] then
				runeActiveCount += self.SynergyRuneOn["S10008"]
			end
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10008"]
			if 0 < self.Enemy_SynergyRuneOn["S10008"] then
				runeActiveCount += self.Enemy_SynergyRuneOn["S10008"]
			end
		end
		
		local synergy6Effect = false
		local synergyEffect = 100
		if isvalid(activatedCount) == false or activatedCount < 2 then
			synergyEffect = 0
		elseif activatedCount >= 6 then
			synergy6Effect = true
		end
		
		if runeActiveCount > 0 then
			synergyEffect *= (1+runeActiveCount)
		end
		-------------------------------------------
		---@type table<Entity>
		local targets = {}
		if teamType == "User" then
			table.initialize(targets, self.Entity.TeamManager.OwnUnits)
		else
			table.initialize(targets, self.Entity.TeamManager.EnemyUnits)	
		end
		
		for i=#targets, 1, -1 do
			local beforeStack = targets[i].UnitSynergy.SynergyStack["S10008_MoveSpeed"]
			if targets[i].UnitInfo:IsOnFieldUnit() == false or targets[i].UnitInfo:DoesHaveSynergy("S10008") == false then
				targets[i].UnitSynergy.SynergyStack["S10008_MoveSpeed"] = 0
			else
				targets[i].UnitSynergy.SynergyStack["S10008_MoveSpeed"] = synergyEffect
				
				if synergy6Effect then
					_StatusChangeLogic:GetBuff(targets[i], "Add_CriticalDamagePercent", 10, -1)
				end
				
				_StatusChangeLogic:GetBuff(targets[i], "Multi_MagicalAttack", 10 * runeActiveCount, -1)
				if runeActiveCount>0 then
					_GeneralDirectorLogic:BattleBuffEffect(targets[i],_RuneCardDirectEnum.MagicalAttack,self.Entity.OwnerId)
				end
			end
			
			if beforeStack ~= targets[i].UnitSynergy.SynergyStack["S10008_MoveSpeed"] then
				if teamType == "User" then
					--targets[i].UnitStatus:SetUnitStatus(false)
					targets[i].UnitStatus:SetUnitStatusByStat(false, "MoveSpeed")
				
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10009_Default(string teamType)
		-- 싸움꾼 : 모든 아군이 체력 획득
		----------------------------------------------------------------
		local key = "S10009"
		----------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크 변수
		local runeAddHPAmount = 0
		----------------------------------------------------------------
		-- 시너지 활성화 여부 검토
		local beforeStack = 0 -- 이전 수치
		local activatedSynergyCount = 0
		if teamType == "Enemy" then
			if 0 < self.Enemy_SynergyRuneOn[key] then
				runeAddHPAmount = 150 * self.Enemy_SynergyRuneOn[key]
			end
			
			beforeStack = self.Enemy_SynergyStack[key]
			activatedSynergyCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy[key]
			
			if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
				self.Enemy_SynergyStack[key] = 0	
			elseif activatedSynergyCount < 5 then
				self.Enemy_SynergyStack[key] = 150 + runeAddHPAmount
			elseif activatedSynergyCount < 7 then
				self.Enemy_SynergyStack[key] = 300 + runeAddHPAmount
			elseif activatedSynergyCount < 10 then
				self.Enemy_SynergyStack[key] = 500 + runeAddHPAmount
			else
				self.Enemy_SynergyStack[key] = 800 + runeAddHPAmount
			end
		else 
			if 0 < self.SynergyRuneOn[key] then
				runeAddHPAmount = 150 * self.SynergyRuneOn[key]
			end
			
			beforeStack = self.SynergyStack[key]
			activatedSynergyCount = self.Entity.TeamManager.OnFieldSynergy[key]
			
			if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
				self.SynergyStack[key] = 0	
			elseif activatedSynergyCount < 5 then
				self.SynergyStack[key] = 150 + runeAddHPAmount
			elseif activatedSynergyCount < 7 then
				self.SynergyStack[key] = 270 + runeAddHPAmount
			elseif activatedSynergyCount < 10 then
				self.SynergyStack[key] = 420 + runeAddHPAmount
			else
				self.SynergyStack[key] = 700 + runeAddHPAmount
			end
			
			-- 변경값과 이전 효과 수치가 다르면, 바뀐 것이므로 모든 유닛의 스탯을 다르게 적용
			if beforeStack ~= self.SynergyStack[key] then
				self:RefreshUnitStatus_AllOwnUnits(false, "MaxHP")
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10011_GetItem(number synergyCount)
		--[[
		 방해꾼 : 방해꾼의 가면 아이템을 얻습니다. 아군 방해꾼 캐릭터 중 하나에게 가면을 줄 수 있습니다. 
		전투 시작 시 가면을 가진 아군 캐릭터와 반대편에 있는 적 캐릭터가 서로 위치를 바꿉니다. 
		위치를 바꾼 아군 방해꾼은 은신 상태가 됩니다.
		]]
		--------------------------------------------------------------------------------
		-- 이미 아이템을 보유 중인지 검사하는 내부 함수
		local haveItems = function()
			-- ownItems 검사
			local ownItems = self.Entity.TeamManager.OwnItems
			for i=1, #ownItems do
				if ownItems[i] == "SI10001" then
					return true
				end
			end
			
			-- 내 유닛들의 장착 여부 검사
			local ownUnits = self.Entity.TeamManager.OwnUnits
			for i=1, #ownUnits do
				local equippedItems = ownUnits[i].UnitStatus.EquippedItemIDList
				for j=1, #equippedItems do
					if equippedItems[j] == "SI10001" then
						return true
					end
				end
			end
			
			return false
		end
		--------------------------------------------------------------------------------
		-- 비활성화 상태일 경우, 회수합니다.
		if synergyCount < 3 then
			local withdrawed = false
		
			-- ownItems 검사
			local ownItems = self.Entity.TeamManager.OwnItems
			for i=1, #ownItems do
				if ownItems[i] == "SI10001" then
					table.remove(ownItems, i)
					withdrawed = true
					break
				end
			end
			
			-- 내 유닛들의 장착 여부 검사
			if withdrawed == false then
				local ownUnits = self.Entity.TeamManager.OwnUnits
				for i=1, #ownUnits do
					local equippedItems = ownUnits[i].UnitStatus.EquippedItemIDList
					for j=1, #equippedItems do
						if equippedItems[j] == "SI10001" then
							ownUnits[i].UnitStatus:SetProperty("EquippedItemIDList", "", string.format("remove,%d", j))
							break
						end
					end
				end
			end
		--------------------------------------------------------------------------------	
		-- 획득합니다.
		else
			-- 이미 보유 중이라면 획득하지 않습니다.
			if haveItems() == true then
				return
			end
			
			table.insert(self.Entity.TeamManager.OwnItems, "SI10001")
		end
		--------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void S10011_WithdrawItem(Entity targetUnit)
		-- '방해꾼의 가면'을 장착한 유닛을 대기석에 놓았을 때, 해당 아이템을 회수합니다.
		----------------------------------------------------
		local equippedItems = targetUnit.UnitStatus.EquippedItemIDList
		
		for i=1, #equippedItems do
			local itemID = equippedItems[i]
			
			if itemID == "SI10001" then
				_ItemSetLogic:WithdrawItem(targetUnit, i)
				break
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10012_GetInvincible(string teamType, number stage, number round)
		-- 숭고한 영혼 (미하일 고유 시너지) :  
		-- 전투 시작 시, 그리고 전투 15초 후 가장 가까운 아군을 3초동안 무적 상태로 만듭니다. 
		-- 미하일의 별 등급에 비례하여 대상 수가 증가합니다. 
		-----------------------------------------------------------------------------------
		-- 시너지 활성화 조건을 체크합니다.
		local teamManager = self.Entity.TeamManager
		local synergyCount = 0
		if teamType == "Enemy" then
			synergyCount = teamManager.EnemyOwnedFieldSynergy["S10012"]
		elseif teamType == "User" then
			synergyCount = teamManager.OnFieldSynergy["S10012"]
		end
		-----------------------------------------------------------------------------------
		if isvalid(synergyCount) == false or synergyCount < 1 then
		--	log("시너지 수가 nil or 0 입니다.")
			return
		end
		-----------------------------------------------------------------------------------
		-- 라운드 및 페이즈 조건을 체크합니다.
		local gameManager = self.Entity.GameManager
		local currentStage = gameManager.Stage
		local currentRound = gameManager.Round
		if stage ~= currentStage or round ~= currentRound or gameManager.PhaseType ~= "Battle" then
			return
		end
		-----------------------------------------------------------------------------------
		-- 미하일 유닛을 찾습니다. 
		-- (여러 유닛이 전투에 포함된 경우, 무작위 하나에게만 효과 적용)
		-- (미하일 유닛이 죽은 경우에는 효과 발동 X)
		---@type Entity
		local mihileUnit = nil
		---@type table<Entity>
		local onFieldUnits = {}
		if teamType == "Enemy" then
			table.initialize(onFieldUnits, teamManager.EnemyUnits) 
		elseif teamType == "User" then
			for i=1, #teamManager.OwnUnits do
				if teamManager.OwnUnits[i].UnitInfo:IsOnFieldUnit() then
					table.insert(onFieldUnits, teamManager.OwnUnits[i])
					log("INSERT_DODO #teamManager.OwnUnits = ", #teamManager.OwnUnits)
				end
			end
		end
		
		local mihileUnits = {}
		for i=1, #onFieldUnits do
			if onFieldUnits[i].UnitInfo.charID == "C50003" then
				table.insert(mihileUnits, onFieldUnits[i])
			end
		end
		
		mihileUnit = mihileUnits[_UtilLogic:RandomIntegerRange(1, #mihileUnits)]
		
		if isvalid(mihileUnit) == false then
			log("미하일 유닛이 없습니다")
			return
		end
		
		local targetCount = mihileUnit.UnitInfo.level
		if targetCount == 3 then targetCount = 4 end
		-----------------------------------------------------------------------------------
		for i=1, #onFieldUnits do
			if onFieldUnits[i] == mihileUnit then
				table.remove(onFieldUnits, i)
				break
			end
		end
		
		local targets = _BTLogic_New:getTargets(mihileUnit.UnitInfo.setTile, onFieldUnits, string.format("Nearest_%d", targetCount))
		for i=1, #targets do
			if isvalid(targets[i]) == true then
				_StatusChangeLogic:SetStatus(mihileUnit, targets[i], "SE0001", 2.4)
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method void S10014_Kill(Entity killerUnit)
		-- 여제 (시그너스 고유 시너지) : 아군이 적 유닛을 처치할 때마다 모든 아군의 상태 이상을 해제하고 공격속도를 4% 증가시킵니다.
		--------------------------------------------------------
		if isvalid(killerUnit) == false then
			return
		end
		--------------------------------------------------------
		local activatedCount = 0
		if killerUnit.UnitInfo.TeamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10014"]
		elseif killerUnit.UnitInfo.TeamType == "Enemy" then
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10014"]
		end
		
		if isvalid(activatedCount) == false then
			return
		end
		--------------------------------------------------------
		-- 공격속도 4% 증가
		---@type table<Entity>
		local targetUnits = {}
		if killerUnit.UnitInfo.TeamType == "User" then
			self.SynergyStack["S10014"] = 4	
			table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
			
			for i=#targetUnits, 1, -1 do
				if targetUnits[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(targetUnits, i)
				end
			end
		elseif killerUnit.UnitInfo.TeamType == "Enemy" then
			self.Enemy_SynergyStack["S10014"] = 4
			table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
		end
		
		-- 상태이상 해제
		for i=1, #targetUnits do
			_StatusChangeLogic:RemoveStatusEffect(targetUnits[i], "All_Debuff")
			_StatusChangeLogic:RemoveStatusEffect(targetUnits[i], "All_Control")
			
			_CustomizedBattleEffectService:PlayEffectAttached(
				"34f37734a8d849f3a85271b80962f343",
				targetUnits[i], Vector3.zero, 0, Vector3.one, false, nil, self.Entity.OwnerId)
		end
	end

	@ExecSpace("ServerOnly")
	method void S10015_SpawnUnitReadyPhase(number synergyCount, string teamType)
		local userID = self.Entity.OwnerId
		
		if isvalid(synergyCount) == false or synergyCount < 3 then
			_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "Clear", 0)
			
		elseif synergyCount < 5 then
			_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "Spawn", 1)
			
		elseif synergyCount < 7 then
			_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "Spawn", 2)
			
		else
			_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "Spawn", 3)
			
		end
		
	end

	@ExecSpace("ServerOnly")
	method void S10015_ApplySumOfStarLevel(string teamType)
		-- SettingPhase에 도도의 스탯을 설정합니다. (팀원들의 별 레벨 합에 따라)
		----------------------------------------------------
		local user = self.Entity
		local userID = user.OwnerId
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		----------------------------------------------------
		local synergyCount = 0
		if teamType == "User" then
			synergyCount = teamManager.OnFieldSynergy["S10015"]
		else
			synergyCount = teamManager.EnemyOwnedFieldSynergy["S10015"]
		end
		----------------------------------------------------
		-- 도도 스탯 강화
		if not isvalid(synergyCount) then
			return
		elseif synergyCount >= 3 then
			local units = _UnitSetLogic_New.UnitsParentEntity[userID]
			---@type Entity
			local dodoEntity = nil
			local levelAmount = 0
			
			if teamType == "User" then
				dodoEntity = units:GetChildByName("BTUnit_DoDo") 
				for _, unit in pairs(teamManager.OwnUnits) do
					if unit.UnitInfo:IsOnFieldUnit() and unit.UnitInfo:DoesHaveSynergy("S10015") then
						levelAmount += unit.UnitInfo.level
					end
				end
				
				_StatusChangeLogic:GetBuff(dodoEntity, "Multi_MagicalAttack", 5 * levelAmount, -1)
				_StatusChangeLogic:GetBuff(dodoEntity, "Multi_MaxHP", 5 * levelAmount, -1)
			else
				dodoEntity = units:GetChildByName("EnemyUnit_DoDo") 
				for _, unit in pairs(teamManager.EnemyUnits) do
					if unit.UnitInfo:IsOnFieldUnit() and unit.UnitInfo:DoesHaveSynergy("S10015") then
						levelAmount += unit.UnitInfo.level
					end
				end
				
				_StatusChangeLogic:GetBuff(dodoEntity, "Multi_MagicalAttack", 5 * levelAmount, -1)
				_StatusChangeLogic:GetBuff(dodoEntity, "Multi_MaxHP", 5 * levelAmount, -1)
			end
		end
		----------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void S10015_SpawnUnitBattlePhase(string teamType)
		-- BattlePhase 에 도도의 스탯을 설정하고 소환하는 함수입니다.
		---------------------------------------------------
		local user = self.Entity
		local userID = user.OwnerId
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		----------------------------------------------------
		local synergyCount = 0
		if teamType == "User" then
			synergyCount = teamManager.OnFieldSynergy["S10015"]
		else
			synergyCount = teamManager.EnemyOwnedFieldSynergy["S10015"]
		end
		----------------------------------------------------
		local currentRound = string.format("%d-%d", gameManager.Stage, gameManager.Round)
		local spawn = function()
			-- 전투 종료 시 예외 처리
			if gameManager.PhaseType ~= "Battle" then
				return
			end
			
			-- 라운드가 다른 경우에도 예외 처리
			local roundText = string.format("%d-%d", gameManager.Stage, gameManager.Round)
			if roundText ~= currentRound then
				return
			end
			----------------------------------------------------
			if isvalid(synergyCount) == false or synergyCount < 3 then
				return
			elseif synergyCount < 5 then -- (3) 1성
				_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "InBattle", 1)
				
			elseif synergyCount < 7 then -- (5) 2성
				_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "InBattle", 2)
				
			else						 -- (7) 3성
				_UnitSetLogic_New:SpawnDoDo(userID, "C00002", teamType, "InBattle", 3)
			end
			
			local units = _UnitSetLogic_New.UnitsParentEntity[userID]
			---@type Entity
			local dodoEntity = nil
			
			if teamType == "User" then
				dodoEntity = units:GetChildByName("BTUnit_DoDo")
			else
				dodoEntity = units:GetChildByName("EnemyUnit_DoDo")
			end
			user.GameManager:RefreshUI_TeamHPInfo(teamType, true, dodoEntity.UnitStatus.MaxHP, userID)
			user.GameManager:RefreshUI_TeamHPInfo(teamType, false, dodoEntity.UnitStatus.MaxHP, userID)
		end
		----------------------------------------------------
		-- 룬카드 시너지 효과 체크
		local spawnTime = 7
		if ( ( 0 < self.SynergyRuneOn["S10015"] ) and teamType == "User") then
			spawnTime -= 3 * self.SynergyRuneOn["S10015"]
		elseif ( ( 0 < self.Enemy_SynergyRuneOn["S10015"] ) and teamType == "Enemy") then
			spawnTime -= 3 * self.Enemy_SynergyRuneOn["S10015"]
		end
		_TimerService:SetTimerOnce(spawn, spawnTime)
		
		
	end

	@ExecSpace("ServerOnly")
	method void S10018_Curse(string teamType)
		-- 슬리피우드 : 모든 적에게 저주를 내려 3초마다 최대 체력에 비례한 고정 피해를 입힙니다. 
		----------------------------------------------------------------------------------------
		-- 재귀 종료 조건
		if self.Entity.GameManager.PhaseType ~= "Battle" then
			return
		end
		----------------------------------------------------------------------------------------
		local activatedCount = 0
		---@type table<Entity>
		local targetTeamUnits = {}
		local curseDamageRate = 0
		----------------------------------------------------------------------------------------
		-- 시너지 활성화 조건 검사 (유저 팀)
		if teamType == "user" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10018"]
			table.initialize(targetTeamUnits, self.Entity.TeamManager.EnemyUnits)
			
		-- 시너지 활성화 조건 검사 (적 팀)
		else 
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10018"]
			table.initialize(targetTeamUnits, self.Entity.TeamManager.OwnUnits)
			for i=#targetTeamUnits, 1, -1 do
				if targetTeamUnits[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(targetTeamUnits, i)
				end
			end
		end
		----------------------------------------------------------------------------------------
		-- 저주 피해율
		if isvalid(activatedCount) == false or activatedCount < 2 then
			return
		elseif activatedCount < 4 then
			curseDamageRate = 0.02
		elseif activatedCount < 6 then
			curseDamageRate = 0.03
		else 
			curseDamageRate = 0.05
		end
		----------------------------------------------------------------------------------------
		-- 저주 피해 입히기
		for i=1, #targetTeamUnits do
			if targetTeamUnits[i].UnitAIWanderComponent.Enable == true then -- 생존 여부
				local damage = targetTeamUnits[i].UnitStatus.MaxHP * curseDamageRate
				_StatusChangeLogic:HitDamage(nil, targetTeamUnits[i], 0, 0, damage, "synergy")
				
				--[[_CustomizedBattleEffectService:PlayEffectAttached(
					"f622948653984225b3207b1ebb5478dd",
					targetTeamUnits[i],
					Vector3.zero,
					0,
					Vector3.one,
					false,
					nil,
					self.Entity.OwnerId )]]--
				
				--연출
				_SynergyBattleDirectorLogic:S10018Curse(targetTeamUnits[i],self.Entity.OwnerId)
			end
		end
		----------------------------------------------------------------------------------------
		-- 재귀 호출
		local recursiveCall = function()
			self:S10018_Curse(teamType)
		end
		
		-- 룬카드 시너지 효과 확인
		local ccTime = 3
		if ( ( self.SynergyRuneOn["S10018"] > 0) and teamType == "User") then
			ccTime -= 0.5 * self.SynergyRuneOn["S10018"]
		elseif ( ( self.Enemy_SynergyRuneOn["S10018"] > 0 ) and teamType == "Enemy") then
			ccTime -= 0.5 * self.Enemy_SynergyRuneOn["S10018"]
		end
		
		_TimerService:SetTimerOnce(recursiveCall, ccTime)
	end

	@ExecSpace("ServerOnly")
	method void S10018_RecoverHP(Entity deadUnit)
		-- 슬리피우드 : 적이 처치될 때마다 슬리피우드 캐릭터들이 체력을 회복합니다.
		--------------------------------------------------------------------------
		---@type table<Entity>
		local recoverTargets = {}
		local activatedCount = 0
		local targetType = ""
		if deadUnit.UnitInfo.TeamType == "Enemy" then
			targetType = "User"
			table.initialize(recoverTargets, self.Entity.TeamManager.OwnUnits)
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10018"]
		else
			targetType = "Enemy"
			table.initialize(recoverTargets, self.Entity.TeamManager.EnemyUnits)
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10018"]
		end
		--------------------------------------------------------------------------
		-- 시너지 활성화 수 검사
		local hpRecoverAmount = 0
		if isvalid(activatedCount) == false or activatedCount < 2 then
			return
		elseif activatedCount < 4 then
			hpRecoverAmount = 120
		elseif activatedCount < 6 then
			hpRecoverAmount = 240
		else
			hpRecoverAmount = 480
		end
		--------------------------------------------------------------------------
		for i=1, #recoverTargets do
			if recoverTargets[i].UnitInfo:IsOnFieldUnit() and recoverTargets[i].UnitInfo:DoesHaveSynergy("S10018") then
				--------------------------------------------------------------------------
				local setHpRecoverAmount = hpRecoverAmount
				-- 룬카드 시너지 효과 체크
				if targetType == "User" and ( 0 < self.SynergyRuneOn["S10018"]) then
					setHpRecoverAmount += recoverTargets[i].UnitStatus.MaxHP * 0.05 * self.SynergyRuneOn["S10018"]
				elseif targetType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10018"]) then
					setHpRecoverAmount += recoverTargets[i].UnitStatus.MaxHP * 0.05 * self.Enemy_SynergyRuneOn["S10018"]
				end
				
				_StatusChangeLogic:SetVariableStatus(recoverTargets[i], recoverTargets[i], "HP", setHpRecoverAmount, "synergy")
				--[[_CustomizedBattleEffectService:PlayEffectAttached(
					"08ae116f052540318d4174cca7dcfca6",
					recoverTargets[i],
					Vector3.zero,
					0,
					Vector3.one,
					false,
					nil,
					self.Entity.OwnerId)]]--
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10019_OnBattleStart(string teamType)
		-- 루디브리엄 : 전투 시작 시, 아군이 장착한 아이템 수에 비례하여 루디브리엄 캐릭터들이 최대 체력 및 마력을 얻습니다. 
		----------------------------------------------------------------------------
		local ownSynergyCount = 0
		---@type table<Entity>
		local targets = {}
		
		if teamType == "Enemy" then
			ownSynergyCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10019"]
			table.initialize(targets, self.Entity.TeamManager.EnemyUnits)
		else
			ownSynergyCount = self.Entity.TeamManager.OnFieldSynergy["S10019"]
			table.initialize(targets, self.Entity.TeamManager.OwnUnits)
		end
		----------------------------------------------------------------------------
		
		local stacksPerItemCount = 0
		if isvalid(ownSynergyCount) == false or ownSynergyCount < 2 then
			return
		elseif ownSynergyCount < 4 then	-- (2)
			stacksPerItemCount = 3
		elseif ownSynergyCount < 6 then	-- (4)
			stacksPerItemCount = 5
		else							-- (7)
			stacksPerItemCount = 9
		end
		----------------------------------------------------------------------------
		-- 아군이 장착한 아이템 수를 검사합니다.
		local itemCount = 0
		for i=1, #targets do
			if targets[i].UnitInfo:IsOnFieldUnit() == true then
				local equippedItemList = targets[i].UnitStatus.EquippedItemIDList
				for j=1, #equippedItemList do
					local itemTag = _UtilLogic:Split(equippedItemList[j], "_")[2]
					if _UtilLogic:IsNilorEmptyString(itemTag) == true then
						itemCount += 1
					end
				end
			end
		end
		
		-- 루디브리엄 유닛들에게 그 숫자에 비례한 스탯을 적용합니다.
		for i=1, #targets do
			if targets[i].UnitInfo:DoesHaveSynergy("S10019") and targets[i].UnitInfo:IsOnFieldUnit() == true then 
				--targets[i].UnitSynergy.SynergyStack["S10019"] = (itemCount * stacksPerItemCount)
				--targets[i].UnitStatus:SetUnitStatus(true)
				_StatusChangeLogic:GetBuff(targets[i], "Multi_MaxHP", (itemCount * stacksPerItemCount), -1)
				_StatusChangeLogic:GetBuff(targets[i], "Multi_MagicalAttack", (itemCount * stacksPerItemCount), -1)
				--targets[i].UnitStatus:SetUnitStatusByStat(true, "MaxHP")
				--targets[i].UnitStatus:SetUnitStatusByStat(true, "MagicalAttack")
				
				--연출
				_GeneralDirectorLogic:BattleBuffEffect(targets[i],_RuneCardDirectEnum.MaxHP, self.Entity.OwnerId)
				_GeneralDirectorLogic:BattleBuffEffect(targets[i],_RuneCardDirectEnum.MagicalAttack, self.Entity.OwnerId)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10020_RecoverMP(string teamType)
		--[[
		 아케인리버 : 
		고유 - 아케인리버 캐릭터들은 기본 공격을 사용하지 않습니다. 대신 1초마다 마나를 15 획득합니다.
		]]--
		
		----------------------------------------------------------------------------------------
		local activatedCount = 0
		---@type table<Entity>
		local targetTeamUnits = {}
		local mpRecoverAmount = 0
		----------------------------------------------------------------------------------------
		-- 시너지 활성화 조건 검사 (유저 팀)
		if teamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10020"]
			table.initialize(targetTeamUnits, self.Entity.TeamManager.OwnUnits)
			
			for i=#targetTeamUnits, 1, -1 do
				if targetTeamUnits[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(targetTeamUnits, i)
				end
			end
		-- 시너지 활성화 조건 검사 (적 팀)
		else 
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10020"]
			table.initialize(targetTeamUnits, self.Entity.TeamManager.EnemyUnits)
		end
		----------------------------------------------------------------------------------------
		if isvalid(activatedCount) == false or activatedCount < 1 then
			return
		else
			mpRecoverAmount = 15
		end
		----------------------------------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		if ( ( 0 < self.SynergyRuneOn["S10020"] ) and teamType == "User") then
			mpRecoverAmount += 5 * self.SynergyRuneOn["S10020"]
		elseif ( ( 0 < self.Enemy_SynergyRuneOn["S10020"] ) and teamType == "Enemy") then
			mpRecoverAmount += 5 * self.Enemy_SynergyRuneOn["S10020"]
		end
		----------------------------------------------------------------------------------------
		for i=1, #targetTeamUnits do
			if targetTeamUnits[i].UnitAIWanderComponent.setBattle == true -- 생존 여부
			and targetTeamUnits[i].UnitInfo:DoesHaveSynergy("S10020") == true then -- 시너지 보유 여부
				--------------------------------------------------------------
				-- MP 회복 
				local timerID = 0
				local recursiveFunc = function()
					if isvalid(self.Entity) == false then
						_TimerService:ClearTimer(timerID)
						return
					end
					
					-- 재귀 종료 조건
					if not isvalid(targetTeamUnits[i]) then
						_TimerService:ClearTimer(timerID)
						return
					elseif targetTeamUnits[i].UnitAIWanderComponent.Enable == false then
						_TimerService:ClearTimer(timerID)
						return
					elseif self.Entity.GameManager.PhaseType ~= "Battle" then
						_TimerService:ClearTimer(timerID)
						return
					end
					
					if targetTeamUnits[i].UnitAIWanderComponent.setBattle then
						_StatusChangeLogic:SetVariableStatus(targetTeamUnits[i], targetTeamUnits[i], "MP", mpRecoverAmount, "synerge")
				
							_CustomizedBattleEffectService:PlayEffectAttached(
							"3cf1bf365a5d4b02967f35f788ed5d6f",
							targetTeamUnits[i],
							Vector3(0, 0, 0),
							0,
							0.5*Vector3.one,
							false,
							nil,
							self.Entity.OwnerId )
					end
				end
				timerID = _TimerService:SetTimerRepeat(recursiveFunc, 0.8, 0.8)
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	method void S10020_KillUnit(Entity killerUnit, Entity deadUnit, Entity deadTile)
		--[[ 
		아케인 리버 : 아케인 리버 유닛이 적을 처치하면, 대상과 가장 가까운 다른 적에게 마력에 비례한 추가 마법 피해를 입힙니다.
		(1) 가까운 적 2명에게 10 + 마력의 45%만큼 추가 피해 (20 + 합 90%)
		(2) 가까운 적 2명에게 20 + 마력의 60%만큼 추가 피해 (40 + 합 120%)
		(3) 가까운 적 2명에게 30 + 마력의 80%만큼 추가 피해 (60 + 합 160%)
		(4) 가까운 적 3명에게 30 + 마력의 80%만큼 추가 피해 (90 + 합 240%)
		]]
		-------------------------------------------------------
		if isvalid(killerUnit) == false then
			return
		end
		
		if killerUnit.UnitInfo:DoesHaveSynergy("S10020") == false then
			return
		end
		-------------------------------------------------------
		local killersTeam = killerUnit.UnitInfo.TeamType
		local activatedCount = 0
		----------------------------------------------------------------------------------------
		-- 시너지 활성화 조건 검사 (유저 팀)
		if killersTeam == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10020"]
		-- 시너지 활성화 조건 검사 (적 팀)
		else 
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10020"]
		end
		
		local damage_fromSyn = 0
		local damage_magicPowerRate = 0
		local targetCount = 0
		if isvalid(activatedCount) == false or activatedCount < 1 then
			return
		elseif activatedCount < 2 then 	-- (1)
			targetCount = 2
			damage_fromSyn = 10
			damage_magicPowerRate = 45
		elseif activatedCount < 3 then 	-- (2)
			targetCount = 2
			damage_fromSyn = 20
			damage_magicPowerRate = 45
		elseif activatedCount < 4 then 	-- (3)
			targetCount = 2
			damage_fromSyn = 30
			damage_magicPowerRate = 80
		else							-- (4)
			targetCount = 3
			damage_fromSyn = 30
			damage_magicPowerRate = 80
		end
		
		
		local damage = damage_fromSyn + killerUnit.UnitStatus.MagicalAttack * (damage_magicPowerRate / 100)
		----------------------------------------------------------------------------------------
		-- 타겟을 결정합니다.
		local targets = {}
		if killersTeam == "User" then
			local enemies = self.Entity.TeamManager.EnemyUnits
			targets = _BTLogic_New:getTargets(deadTile, enemies, string.format("Nearest_%d", targetCount))
		elseif killersTeam == "Enemy" then
			local userUnits = self.Entity.TeamManager.OwnUnits
			local targetsFrom = {}
			for _, unit in pairs(userUnits) do
				if unit.UnitInfo:IsOnFieldUnit() == true then
					table.insert(targetsFrom, unit)
				end
			end
			targets = _BTLogic_New:getTargets(deadTile, targetsFrom, string.format("Nearest_%d", targetCount))
		end
		----------------------------------------------------------------------------------------
		-- 대상들에게 추가 피해를 가합니다!
		
		-- Draw Line
		for _, target in pairs(targets) do
			_CustomizedBattleEffectService:LineRendererEffect("S10020", deadTile, {target}, 0.5, self.Entity.OwnerId)
		end
		
		
		local hit = function()
			for _, target in pairs(targets) do
				
				---@type Entity
				local targetUnit = target
				-- 사망한 적 예외처리
				if isvalid(target) == false or targetUnit.UnitInfo:IsOnFieldUnit() == false then
					continue
				end
				
				-- 데미지 처리
				_StatusChangeLogic:HitDamage(killerUnit, target, 0, damage, 0, "synergy")
				
				-- 이펙트
				_CustomizedBattleEffectService:PlayEffectAttached("d79fe794860747a4ae89fc52ce0b888f", 
					target, Vector3.zero, 0, Vector3.one, false, nil, self.Entity.OwnerId)
			end	
		end
		_TimerService:SetTimerOnce(hit, 0.5)
		----------------------------------------------------------------------------------------
	end

	@ExecSpace("ServerOnly")
	method void S10021_SpawnStoneReadyPhase(number synergyCount, string teamType)
		
		local userID = self.Entity.OwnerId
		---@type table<Entity>
		local spawnedStones = {nil, nil, nil}
		
		---@type table<Entity>
		local removedStones = {nil, nil, nil}
		
		if synergyCount < 3 then
			removedStones[1] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Clear", 1)
			removedStones[2] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Clear", 2)
			removedStones[3] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Clear", 3)
			
		elseif synergyCount < 5 then
			spawnedStones[1] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Spawn", 1)
			removedStones[1] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Clear", 2)
			removedStones[2] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Clear", 3)
			
		elseif synergyCount < 7 then
			spawnedStones[1] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Spawn", 1)
			spawnedStones[2] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Spawn", 2)
			removedStones[1] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Clear", 3)
			
		else
			spawnedStones[1] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Spawn", 1)
			spawnedStones[2] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Spawn", 2)
			spawnedStones[3] = _UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "Spawn", 3)
			
		end
		for i=1, 3 do
			if isvalid(spawnedStones[i]) == true then
				-- 룬카드 시너지 활성화 체크
				local aroundCount = 1
				if teamType == "User" then
					if 0 < self.SynergyRuneOn["S10021"] then
						aroundCount += self.SynergyRuneOn["S10021"]
					end
				else
					if 0 < self.Enemy_SynergyRuneOn["S10021"] then
						aroundCount += self.Enemy_SynergyRuneOn["S10021"]
					end
				end
				
				local tiles = _BTLogic_New:getTiles(spawnedStones[i], spawnedStones[i].UnitInfo.setTile, nil, string.format("Around_%d",math.floor(aroundCount)))
				
				_SynergyReadyDirectorLogic:Set10021TilesEffect(
					spawnedStones[i].Id, _UtilLogic:TableToString(tiles),	userID)
			end
		end
		
		for i=1, 3 do
			if isvalid(removedStones[i]) == true then
				_SynergyReadyDirectorLogic:Set10021TilesEffect(
					removedStones[i].Id, nil,	userID)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10021_OnBattleStart(string teamType)
		--[[
		오르비스 : 
		마법석 근처에서 전투를 시작한 아군 유닛은 최종 데미지가 20% 증가하고 전투 중 3초마다 60만큼의 보호막을 얻습니다. 
		이 효과는 중첩됩니다.
		]]
		----------------------------------------------------------------------
		local calledRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
		
		----------------------------------------------------------------------
		local userID = self.Entity.OwnerId
		local unitsParentEntity = _UnitSetLogic_New.UnitsParentEntity[userID]
		----------------------------------------------------------------------
		local synergyCount = 0
		local removeCount = 0
		local getBuffPercent = 1
		---@type table<Entity>
		local magicStones = {}
		----------------------------------------------------------------------
		if teamType == "User" then
			synergyCount = self.Entity.TeamManager.OnFieldSynergy["S10021"]
			
			-- 마법석 근처 유닛에게 버프를 제공합니다.
			if isvalid(synergyCount) == false or synergyCount < 3 then
				return
			elseif synergyCount < 5 then
				removeCount = 1
				magicStones[1] = unitsParentEntity:GetChildByName("BTUnit_OrbisStone1")
			elseif synergyCount < 7 then
				removeCount = 2
				magicStones[1] = unitsParentEntity:GetChildByName("BTUnit_OrbisStone1")
				magicStones[2] = unitsParentEntity:GetChildByName("BTUnit_OrbisStone2")
			else
				removeCount = 3
				magicStones[1] = unitsParentEntity:GetChildByName("BTUnit_OrbisStone1")
				magicStones[2] = unitsParentEntity:GetChildByName("BTUnit_OrbisStone2")
				magicStones[3] = unitsParentEntity:GetChildByName("BTUnit_OrbisStone3")
				
				if synergyCount >= 10 then
					getBuffPercent = 1.5
				end
			end
		else
			synergyCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10021"]
			
			-- 마법석 근처 유닛에게 버프를 제공합니다.
			if isvalid(synergyCount) == false or synergyCount < 3 then
				return
			elseif synergyCount < 5 then
				removeCount = 1
				magicStones[1] = unitsParentEntity:GetChildByName("EnemyUnit_OrbisStone1")
			elseif synergyCount < 7 then
				removeCount = 2
				magicStones[1] = unitsParentEntity:GetChildByName("EnemyUnit_OrbisStone1")
				magicStones[2] = unitsParentEntity:GetChildByName("EnemyUnit_OrbisStone2")
			else
				removeCount = 3
				magicStones[1] = unitsParentEntity:GetChildByName("EnemyUnit_OrbisStone1")
				magicStones[2] = unitsParentEntity:GetChildByName("EnemyUnit_OrbisStone2")
				magicStones[3] = unitsParentEntity:GetChildByName("EnemyUnit_OrbisStone3")
				if synergyCount >= 10 then
					getBuffPercent = 1.5
				end
			end
		end
		----------------------------------------------------------------------
		for i=1, #magicStones do
			local tileOnStone = magicStones[i].UnitInfo.setTile
			
			-- 룬카드 시너지 활성화 체크
			local aroundCount = 1
			local getShieldTime = 3
			if teamType == "User" and ( 0 < self.SynergyRuneOn["S10021"] ) then
				aroundCount += self.SynergyRuneOn["S10021"]
				getShieldTime = 2
			elseif teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10021"] ) then
				aroundCount += self.Enemy_SynergyRuneOn["S10021"]
				getShieldTime = 2
			end
		
			---@type table<Entity>
			local targets = {}
			if teamType == "User" then
				table.initialize(targets, _BTLogic_New:getTargets(tileOnStone, self.Entity.TeamManager.OwnUnits, string.format("Around_1_%d", aroundCount)))
			else
				table.initialize(targets, _BTLogic_New:getTargets(tileOnStone, self.Entity.TeamManager.EnemyUnits, string.format("Around_1_%d", aroundCount)))
			end
				
			-- 최종 데미지 20% 증가 버프
			for _, target in pairs(targets) do
				target.UnitSynergy.SynergyStack["S10021"] += 20 * getBuffPercent
				target.UnitStatus:SetUnitStatusByStat(true, "DealingDamageRate")
				
				_GeneralDirectorLogic:BattleBuffEffect(target,_RuneCardDirectEnum.DealingDamageRate,self.Entity.PlayerComponent.UserId)
			end
			----------------------------------------------------------------
			-- 재귀 형태로 3초마다 보호막 66 획득
			local timerID = 0
			local user = _UserService:GetUserEntityByUserId(userID)
			local getShields = function()
				--------------------------------
				if isvalid(user) == false then
					_TimerService:ClearTimer(timerID)
					return
				end
				
				-- 재귀 종료 조건1 : 전투 중이 아님
				if self.Entity.GameManager.PhaseType ~= "Battle" then
					_TimerService:ClearTimer(timerID)
					return
				end
				-- 재귀 종료 조건2 : 이 함수를 실행한 라운드가 아님
				local currentRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
				if currentRound ~= calledRound then
					_TimerService:ClearTimer(timerID)
					return
				end
				--------------------------------
				for _, target in pairs(targets) do
					if target.UnitAnimationComponent.Enable == true then
						_StatusChangeLogic:SetShield(target, target, 66 * getBuffPercent, -1, "S10021")
					end
				end
				--------------------------------
				--연출
				if teamType == "User" then
					_SynergyBattleDirectorLogic:S10021OrbisStoneBuff(true,self.Entity.PlayerComponent.UserId)
				else
					_SynergyBattleDirectorLogic:S10021OrbisStoneBuff(false,self.Entity.PlayerComponent.UserId)
				end
			end
			timerID = _TimerService:SetTimerRepeat(getShields, getShieldTime, 0)
			----------------------------------------------------------------
		end
			
			
		
		-- 오르비스 마법석을 제거합니다. (전투 시작 시 사망 처리)
		for i=1, removeCount do
			_UnitSetLogic_New:SpawnOrbisStone(userID, teamType, "InBattle", i)
		end
	end

	@ExecSpace("ServerOnly")
	method void S10021_OnKilled(Entity killerUnit, Entity deadUnit)
		-- 방해꾼 (7) 적 처치시, (방해꾼의 가면을 장착한 아군 유닛이) 2초간 은신
		----------------------------------------------------------------------------------
		-- 예외 처리 1. 가해자 또는 피해자가 존재 x
		if isvalid(killerUnit) == false then
			return
		elseif isvalid(deadUnit) == false then
			return
		end
		
		-- 예외 처리 2. 가해자 / 피해자가 같은 팀
		if killerUnit.UnitInfo.TeamType == deadUnit.UnitInfo.TeamType then
			return
		end
		----------------------------------------------------------------------------------
		-- 시너지 활성화 수 체크
		local teamManager = self.Entity.TeamManager
		local teamType = killerUnit.UnitInfo.TeamType
		local activatedSynergyCount = 0
		if teamType == "User" then
			activatedSynergyCount = teamManager.OnFieldSynergy["S10021"]
		elseif teamType == "Enemy" then
			activatedSynergyCount = teamManager.EnemyOwnedFieldSynergy["S10021"] 
		end
		
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 7 then
			return
		end
		----------------------------------------------------------------------------------
		-- 방해꾼의 가면을 장착한 캐릭터를 찾습니다.
		local itemOwner = nil
		if teamType == "User" then
			for _, unit in pairs(teamManager.OwnUnits) do
				if unit.UnitInfo:IsOnFieldUnit() then
					for _, equippedItemID in pairs(unit.UnitStatus.EquippedItemIDList) do
						local itemID = _UtilLogic:Split(equippedItemID, "_")[1]
						
						if itemID == "SI10001" then
							itemOwner = unit
							break
						end
					end
				end
			end
		elseif teamType == "Enemy" then
			for _, unit in pairs(teamManager.EnemyUnits) do
				if unit.UnitInfo:IsOnFieldUnit() then
					for _, equippedItemID in pairs(unit.UnitStatus.EquippedItemIDList) do
						local itemID = _UtilLogic:Split(equippedItemID, "_")[1]
						
						if itemID == "SI10001" then
							itemOwner = unit
							break
						end
					end
				end
			end
		end
		
		-- 2초간 은신 부여
		if isvalid(itemOwner) == true then
			_StatusChangeLogic:SetStatus(itemOwner, itemOwner, "SE0002", 2)
		end
	end

	@ExecSpace("ServerOnly")
	method void S10022_GainMP(Entity deadUnit)
		-- 시그너스(11) : 아군 유닛이 처치되면 생존한 모든 아군 유닛이 MP 30 회복
		----------------------------------------------------------------------
		local team = deadUnit.UnitInfo.TeamType
		local activatedCount = 0
		
		---@type table<Entity>
		local targets = {}
		if team == "Enemy" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10022"]
			table.initialize(targets, self.Entity.TeamManager.OwnUnits)
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10022"]
			table.initialize(targets, self.Entity.TeamManager.EnemyUnits)
		end
		
		if isvalid(activatedCount) == true and activatedCount >= 11 then
			for i=1, #targets do
				if targets[i].UnitInfo:IsOnFieldUnit() == true then
					_StatusChangeLogic:SetVariableStatus(targets[i], targets[i], "MP", 30, "synergy")
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10023_GetCoin(Entity killerUnit, Entity deadUnit)
		-- 모험가 : 9 시너지, 적 처치 시 50% 확률로 1코인을 획득합니다.
		-- 룬카드 활성화 시, 적 처치 시 20% 확률로 추가 1코인을 획득합니다.
		----------------------------------------------------------------------
		if not (isvalid(killerUnit) and isvalid(deadUnit)) then
			return
		end
		----------------------------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		---------------------------------------------------------------------
		local killTeamType = killerUnit.UnitInfo.TeamType
		local deadTeamType = deadUnit.UnitInfo.TeamType
		----------------------------------------------------------------------
		-- 적을 처치했는지 확인
		if killTeamType == deadTeamType then
			return
		end
		
		----------------------------------------------------------------------
		-- killerUnit 활성화된 시너지 수를 검사
		local activatedCount = 0
		if killTeamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10023"]
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10023"]
		end
		----------------------------------------------------------------------
		if not isvalid(activatedCount) then
			return
		elseif activatedCount >= 9 then
			local getCoinPer = _UtilLogic:RandomDouble()
			if getCoinPer < 0.5 then
				_TimerService:SetTimerOnce(function() teamManager:AddGolds(1, "synergy") end , 0.1)
				
				--코인 연출
				_GeneralDirectorLogic:PlayCoinDirector_Sprite(1,killerUnit.TransformComponent.WorldPosition:Clone():ToVector2(),"Adventurer",user.PlayerComponent.UserId)
			end
		end
		
		-- 룬카드 시너지 활성화 체크
		if activatedCount >= 3 then
			if ( 0 < self.SynergyRuneOn["S10023"] ) and killTeamType == "User" then
				for i = 1, self.SynergyRuneOn["S10023"] do
					local getCoinPer = _UtilLogic:RandomDouble()
					if getCoinPer < 0.2 then
						_TimerService:SetTimerOnce(function() teamManager:AddGolds(1, "synergy") end , 0.1)
						
					--코인 연출
					_GeneralDirectorLogic:PlayCoinDirector_Sprite(1,killerUnit.TransformComponent.WorldPosition:Clone():ToVector2(),"Adventurer",user.PlayerComponent.UserId)
					end
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10023_StatSet(number activatedCount, string teamType)
		-- 모험가 : 팀 레벨에 비례해 스탯이 오릅니다.
		----------------------------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		----------------------------------------------------------------------
		
		local attackStatValue = 0
		local maxHPStatValue = 0
		if isvalid(activatedCount) == false or activatedCount < 3 then
			return
		elseif activatedCount < 5 then
			attackStatValue = 3
			maxHPStatValue = 2
		elseif activatedCount < 7 then
			attackStatValue = 5
			maxHPStatValue = 4
		elseif activatedCount < 9 then
			attackStatValue = 7
			maxHPStatValue = 6
		else
			attackStatValue = 10
			maxHPStatValue = 9
		end
		
		-- 룬카드 시너지 활성화 체크
		if ( ( 0 < self.SynergyRuneOn["S10023"] ) and teamType == "User") then
			maxHPStatValue *= (1 + self.SynergyRuneOn["S10023"])
		elseif ( ( 0 < self.Enemy_SynergyRuneOn["S10023"] ) and teamType == "Enemy") then
			maxHPStatValue *= (1 + self.Enemy_SynergyRuneOn["S10023"])
		end
		
		local teamLevel = teamManager.Level
		if teamType == "Enemy" then
			teamLevel = gameManager.Stage + 2 
		end
		
		
		---@type table<Entity>
		local targetUnits = {}
		if teamType == "Enemy" then
			table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
		else
			table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
		end
		
		for i=1, #targetUnits do
			if targetUnits[i].UnitInfo:DoesHaveSynergy("S10023") then
				targetUnits[i].UnitSynergy.SynergyStack["S10023_Attack"] = attackStatValue * teamLevel
				targetUnits[i].UnitSynergy.SynergyStack["S10023_MaxHP"] = maxHPStatValue * teamLevel
			else
				targetUnits[i].UnitSynergy.SynergyStack["S10023_Attack"] = 0
				targetUnits[i].UnitSynergy.SynergyStack["S10023_MaxHP"] = 0
			end
			
			-- 스탯 갱신
			if self.Entity.GameManager.PhaseType == "Battle" then
				--targetUnits[i].UnitStatus:SetUnitStatus(true)
				targetUnits[i].UnitStatus:SetUnitStatusByStat(true, "PhysicalAttack")
				targetUnits[i].UnitStatus:SetUnitStatusByStat(true, "MagicalAttack")
				targetUnits[i].UnitStatus:SetUnitStatusByStat(true, "MaxHP")
			else
				--targetUnits[i].UnitStatus:SetUnitStatus(false)
				targetUnits[i].UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
				targetUnits[i].UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				targetUnits[i].UnitStatus:SetUnitStatusByStat(false, "MaxHP")
			end
			
		end
	end

	@ExecSpace("Server")
	method void S10023_GetExp()
		local user = self.Entity
		local teamManager = user.TeamManager
		----------------------------------
		-- 모험가 캐릭터가 플레이어 전투에 참여하면 2의 경험치를 얻습니다. 
		local activatedSynergyCount = teamManager.OnFieldSynergy["S10023"]
		
		if isvalid(activatedSynergyCount) == false or activatedSynergyCount < 3 then
			--log("시너지 비활성화 상태")
		else
			teamManager:AddEXP(2)
		end
	end

	@ExecSpace("ServerOnly")
	method void S10024(string teamType)
		--[[
		 전직교관 : 아군에게 고유 보너스를 부여합니다. 
		이 효과는 전직 교관이 정확히 하나 또는 각기 다른 전직 교관이 다섯 있을 때에만 활성화됩니다.
		]]
		----------------------------------------------------------------------
		-- 활성화된 수 및 전직교관 검사
		local targetCharIDs = {
			"C20004", -- 주먹 펴고 일어서
			"C30010", -- 다크로드
			"C30013", -- 카이린
			"C40002", -- 하인즈
			"C50007", -- 헬레나
		}
		
		local activatedCount = 0
		---@type table<Entity>
		local targets = {}
		if teamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10024"]
			table.initialize(targets, self.Entity.TeamManager.OwnUnits)
			for i=#targets, 1, -1 do
				if targets[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(targets, i)
				end
			end
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10024"]
			table.initialize(targets, self.Entity.TeamManager.EnemyUnits)
		end
		
		local activeType = ""
		if isvalid(activatedCount) == false or activatedCount < 1 then
			activeType = "disable" 
		-- 1명 활성화인 경우	
		elseif activatedCount == 1 then
			for i=1, #targets do
				local charID = targets[i].UnitInfo.charID
					
				for j=1, #targetCharIDs do
					if targetCharIDs[j] == charID then
						activeType = targetCharIDs[j]
					end
				end
				
				if activeType ~= "" then
					break
				end
			end
			
		-- 5명 활성화인 경우
		elseif activatedCount == 5 then
			activeType = "all"
			
		-- 2명 ~ 4명 (또는 6명 이상) 인 경우
		else
			activeType = "disable"
		end
		---------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		local synergyPer = 0
		if (teamType == "User" and ( 0 < self.SynergyRuneOn["S10024"] ) ) then
			synergyPer += self.SynergyRuneOn["S10024"] * 0.5
		elseif (teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10024"] ) ) then
			synergyPer += self.Enemy_SynergyRuneOn["S10024"] * 0.5
		end
		---------------------------------------------------------
		-- 활성화 여부에 따라 스탯 값 적용
		local synergyStack = nil
		if teamType == "User" then
			synergyStack = self.SynergyStack
		else
			synergyStack = self.Enemy_SynergyStack
		end
		
		local beforeValue = synergyStack["S10024_ActiveType"]
		
		-- 비활성화
		if activeType == "disable" then
			synergyStack["S10024_ActiveType"] = 0	-- 전직교관 : 타입 0
			synergyStack["S10024_Armor"] = 0		-- 전직교관 1) 방어력
			synergyStack["S10024_AttackSpeed"] = 0 -- 전직교관 2) 공격속도
			synergyStack["S10024_Power"] = 0		-- 전직교관 3) 공격력 및 마력
			synergyStack["S10024_HPnMP"] = 0		-- 전직교관 4) MaxHP, MaxMP
			synergyStack["S10024_Unstoppable"] = 0 -- 전직교관 5) 전투 시작 후 12초간 저지 불가
			
		-- (5) 활성화
		elseif activeType == "all" then
			synergyStack["S10024_ActiveType"] = 6	-- 전직교관 : 타입 6
			synergyStack["S10024_Armor"] = 15 * (1.5 + synergyPer)		-- 전직교관 1) 방어력
			synergyStack["S10024_AttackSpeed"] = 15 * (1.5 + synergyPer) -- 전직교관 2) 공격속도
			synergyStack["S10024_Power"] = 15 * (1.5 + synergyPer)		-- 전직교관 3) 공격력 및 마력
			synergyStack["S10024_HPnMP"] = 15 * (1.5 + synergyPer)		-- 전직교관 4) MaxHP, MaxMP
			synergyStack["S10024_Unstoppable"] = 8 * (1.5 + synergyPer) -- 전직교관 5) 전투 시작 후 12초간 저지 불가
			
		
		-- (1) 활성화
		else
			synergyStack["S10024_Armor"] = 0		-- 전직교관 1) 방어력
			synergyStack["S10024_AttackSpeed"] = 0 -- 전직교관 2) 공격속도
			synergyStack["S10024_Power"] = 0		-- 전직교관 3) 공격력 및 마력
			synergyStack["S10024_HPnMP"] = 0		-- 전직교관 4) MaxHP, MP
			synergyStack["S10024_Unstoppable"] = 0 -- 전직교관 5) 전투 시작 후 12초간 저지 불가
			
			if activeType == "C20004" then
				synergyStack["S10024_ActiveType"] = 1
				synergyStack["S10024_Armor"] = 15 * (1 + synergyPer)
		
			elseif activeType == "C30010" then
				synergyStack["S10024_ActiveType"] = 2
				synergyStack["S10024_AttackSpeed"] = 15 * (1 + synergyPer)
			elseif activeType == "C30013" then
				synergyStack["S10024_ActiveType"] = 3
				synergyStack["S10024_Power"] = 15 * (1 + synergyPer)
			elseif activeType == "C40002" then
				synergyStack["S10024_ActiveType"] = 4
				synergyStack["S10024_HPnMP"] = 15 * (1 + synergyPer)
			elseif activeType == "C50007" then
				synergyStack["S10024_ActiveType"] = 5
				synergyStack["S10024_Unstoppable"] = 8 * (1 + synergyPer)
			end
		end
		
		if beforeValue ~= synergyStack["S10024_ActiveType"] then
			for i=1, #targets do
				targets[i].UnitStatus:SetUnitStatusByStat(false, "Defence")
				targets[i].UnitStatus:SetUnitStatusByStat(false, "MagicalResistance")
				targets[i].UnitStatus:SetUnitStatusByStat(false, "AttackSpeed")
				targets[i].UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
				targets[i].UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
				targets[i].UnitStatus:SetUnitStatusByStat(false, "MaxHP")
				targets[i].UnitStatus:SetUnitStatusByStat(false, "MP")
			end
		end
		
		--for i=1, #targets do
		--    targets[i].UnitStatus:SetUnitStatus(false)
		--end
	end

	@ExecSpace("ServerOnly")
	method void S10024_BattleStart()
		-- 전직교관 중 하인즈(시작 MP 증가) or 헬레나(전투 시작 후 x초간 저지 불가)
		----------------------------------------------------------------------------------
		-- 스택 수 검사
		local ownUnits = self.Entity.TeamManager.OwnUnits
		local enemyUnits = self.Entity.TeamManager.EnemyUnits
		
		local synergyStack_Unstoppable = self.SynergyStack["S10024_Unstoppable"]
		local enemyStack_Unstoppable = self.Enemy_SynergyStack["S10024_Unstoppable"]
		----------------------------------------------------------------------------------
		-- 아군에게 적용
		if isvalid(synergyStack_Unstoppable) == true and synergyStack_Unstoppable > 0 then
			for i=1, #ownUnits do
				if ownUnits[i].UnitInfo:IsOnFieldUnit() then
					_StatusChangeLogic:SetStatus(ownUnits[i], ownUnits[i], "SE0016", synergyStack_Unstoppable)
				end
			end
		end
		----------------------------------------------------------------------------------
		-- 적에게 적용
		if isvalid(enemyStack_Unstoppable) == true and enemyStack_Unstoppable > 0 then
			for i=1, #enemyUnits do
				if enemyUnits[i].UnitInfo:IsOnFieldUnit() then
					_StatusChangeLogic:SetStatus(enemyUnits[i], enemyUnits[i], "SE0016", enemyStack_Unstoppable)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10025_SetSaintArea()
		-- 기사단장 : 성역 위치 무작위 지정 - "y00x" 형태로 지정 (예:3행 5열인 경우 3005)
		
		local row = _UtilLogic:RandomIntegerRange(1, 7)
		local column = _UtilLogic:RandomIntegerRange(1, 4)
		
		self.SynergyStack["S10025_Pos"] = row*1000 + column
		
		local row_e = _UtilLogic:RandomIntegerRange(1, 7)
		local column_e = 0
		if row_e%2 == 0 then
			column_e = _UtilLogic:RandomIntegerRange(5, 8) 
		else
			column_e = _UtilLogic:RandomIntegerRange(6, 9) 
		end
		
		self.Enemy_SynergyStack["S10025_Pos"] = row_e*1000 + column_e
	end

	@ExecSpace("ServerOnly")
	method void S10025_SetSainAreaTarget(string teamType)
		-- 기사단장 버프를 받을 타겟을 지정합니다.
		-----------------------------------------------------------------
		local activatedCount = 0 
		---@type table<Entity>
		local targetsForm = {}
		local saintAreaPos = 0
		
		if teamType == "Enemy" then
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10025"]
			saintAreaPos = self.Enemy_SynergyStack["S10025_Pos"]
			table.initialize(targetsForm, self.Entity.TeamManager.EnemyUnits)
		else 
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10025"]
			saintAreaPos = self.SynergyStack["S10025_Pos"]
			table.initialize(targetsForm, self.Entity.TeamManager.OwnUnits)
		end
		-----------------------------------------------------------------
		if isvalid(activatedCount) == false or activatedCount < 2 then
			self.S10025_TargetUnit[teamType] = nil
			return
		end
		-----------------------------------------------------------------
		local row = math.floor(saintAreaPos/1000)
		local col = math.floor(saintAreaPos - row*1000)
		
		for i=1, #targetsForm do
			local unit = targetsForm[i]
			if unit.UnitInfo.setTileVerticalNum == row and unit.UnitInfo.setTileHorizontalNum == col then
				self.S10025_TargetUnit[teamType] = unit
			end 
		end
	end

	@ExecSpace("ServerOnly")
	method void S10025_GetSaintAreaEffect(string teamType)
		--[[
		 기사단장 : 
		전투 시작 후 x초마다 중첩되는 버프 효과를 얻습니다.
		]]
		-----------------------------------------------------------------
		local activatedCount = 0 
		---@type table<Entity>
		local targetsForm = {}
		local saintAreaPos = 0
		
		if teamType == "Enemy" then
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10025"]
			saintAreaPos = self.Enemy_SynergyStack["S10025_Pos"]
			table.initialize(targetsForm, self.Entity.TeamManager.EnemyUnits)
		else 
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10025"]
			saintAreaPos = self.SynergyStack["S10025_Pos"]
			table.initialize(targetsForm, self.Entity.TeamManager.OwnUnits)
		end
		-----------------------------------------------------------------
		-- 활성화된 시너지 수에 따라 버프 획득 간격 변경
		local interval = 0
		if isvalid(activatedCount) == false or activatedCount < 2 then
			return
		elseif activatedCount < 4 then
			interval = 4
		elseif activatedCount < 6 then
			interval = 2
		elseif activatedCount < 9 then
			interval = 1
		else
			interval = 0.5
		end
		-----------------------------------------------------------------
		local target = self.S10025_TargetUnit[teamType]
		
		---- 성역 위에 놓여진 유닛(=target)을 찾습니다. 
		-----@type Entity
		--local target = nil
		--
		--local row = math.floor(saintAreaPos/1000)
		--local col = math.floor(saintAreaPos - row*1000)
		--
		--for i=1, #targetsForm do
		--    local unit = targetsForm[i]
		--    if unit.UnitInfo.setTileVerticalNum == row and unit.UnitInfo.setTileHorizontalNum == col then
		--        target = unit
		--    end 
		--end
		-----------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		local checkedType = "false"
		---@type table<Entity>
		local hasThisSynergyUnits = {}
		if (teamType == "User" and ( 0 < self.SynergyRuneOn["S10025"] ) ) then
			checkedType = teamType
			
			for i=1, #targetsForm do
				local unit = targetsForm[i]
				if unit.UnitInfo:DoesHaveSynergy("S10025") and unit.UnitInfo:IsOnFieldUnit() then
					table.insert(hasThisSynergyUnits, unit)
				end
			end
		elseif (teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10025"] ) ) then
			checkedType = teamType
		
			for i=1, #targetsForm do
				local unit = targetsForm[i]
				if unit.UnitInfo:DoesHaveSynergy("S10025") then
					table.insert(hasThisSynergyUnits, unit)
				end
			end
		end
		-----------------------------------------------------------------
		-- target(+ 룬카드 시너지 활성화 시, 기사단장 유닛도 포함)이 interval 간격으로 버프를 얻습니다.
		local reservatedRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
		local buff = function()
			-- 예외처리: 버프를 실행한 라운드와 현재 라운드가 다름
			local currentRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
			if reservatedRound ~= currentRound then
				return
			end
			
			-- 예외처리: 현재가 전투 단계가 아님
			if self.Entity.GameManager.PhaseType ~= "Battle" then
				return
			end
		
			-- 예외처리: 타겟이 죽음
			if isvalid(target) == false or target.UnitStatus:IsDead() then
				return
			end
			
			target.UnitSynergy.SynergyStack["S10025"] += 15
			target.UnitStatus:SetUnitStatusByStat(true, "MaxHP")
			target.UnitStatus:SetUnitStatusByStat(true, "PhysicalAttack")
			target.UnitStatus:SetUnitStatusByStat(true, "MagicalAttack")
			--target.UnitStatus:SetUnitStatus(true)
			
			--연출
			_SynergyBattleDirectorLogic:S10025Tree(target,self.Entity.PlayerComponent.UserId)
			
			if checkedType ~= "false" then
				local stack = 0
		
				if checkedType == "User" then
					stack = self.SynergyRuneOn["S10025"]
				else
					stack = self.Enemy_SynergyRuneOn["S10025"]
				end
				
				for i, unit in pairs(hasThisSynergyUnits) do
					_StatusChangeLogic:GetBuff(unit, "Multi_MaxHP", 5 * stack, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_PhysicalAttack", 5 * stack, -1)
					_StatusChangeLogic:GetBuff(unit, "Multi_MagicalAttack", 5 * stack, -1)
				end
			end
		end
		for i=1, 15/interval do
			_TimerService:SetTimerOnce(buff, interval*i)
		end
		
		-- 9 시너지 전투 참여 시, 10초동안 저지 불가
		-- 24.10.07. 임시 추가
		if activatedCount >= 9 then
			_StatusChangeLogic:SetStatus(target, target, "SE0016", 10)
		end
	end

	@ExecSpace("ServerOnly")
	method void S10026_Spawn(string teamType)
		-- [예티와 페페] (2) : 전투 시작 시, '예티'와 '페페' 유닛들이 힘을 합칩니다. 예티와 페페를 소환합니다.
		------------------------------------------------------------------------------------------------------------------
		-- 1. 전체 유닛 목록을 가져옵니다. teamType에 따라 가져오는 목록이 다릅니다(적 유닛 / 내 유닛).
		local activatedCount = 0
		---@type table<Entity>
		local targetsFrom = {}
		
		if teamType == "Enemy" then
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10026"]
			table.initialize(targetsFrom, self.Entity.TeamManager.EnemyUnits)
			
		else
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10026"]
			table.initialize(targetsFrom, self.Entity.TeamManager.OwnUnits)
		end
		---------------------------------------------------------
		-- 2. 가져온 유닛 목록에서 예티, 페페를 구분합니다. 예티+페페 1쌍당 1회의 합성(?)을 발생시킵니다.
		if isvalid(activatedCount) == false or activatedCount < 2 then
			return
		else
			for i=#targetsFrom, 1, -1 do
				if targetsFrom[i].UnitInfo:IsOnFieldUnit() == false then
					table.remove(targetsFrom, i)
				end
			end
				
			---@type table<Entity>
			local yeti = {}
			---@type table<Entity>
			local pepe = {}
			
			for i=1, #targetsFrom do
				local charID = targetsFrom[i].UnitInfo.charID
				
				if charID == "C30001" then
					table.insert(yeti, targetsFrom[i])
				elseif charID == "C20002" then
					table.insert(pepe, targetsFrom[i])
				end
			end
			
			local combineCount = math.min(#yeti, #pepe)
				
			for i=1, combineCount do
				-- '예티'
				local randomVal1 = _UtilLogic:RandomIntegerRange(1, #yeti)
				local targetYeti = yeti[randomVal1]
				table.insert(self.S10026_YetiUnits, targetYeti)
				table.remove(yeti, randomVal1)
				targetYeti.UnitAIWanderComponent.setBattle = false
				_CustomizedBattleEffectService:SetEntityVisible(targetYeti, false, self.Entity.OwnerId)
				
				-- '페페'
				local randomVal2 = _UtilLogic:RandomIntegerRange(1, #pepe)
				local targetPepe = pepe[randomVal2] 
				table.insert(self.S10026_PepeUnits, targetPepe)
				table.remove(pepe, randomVal2)
				targetPepe.UnitAIWanderComponent.setBattle = false
				_CustomizedBattleEffectService:SetEntityVisible(targetPepe, false, self.Entity.OwnerId)
				
				-- '예티와페페' 소환
				local combinedLevel = math.floor((targetYeti.UnitInfo.level + targetPepe.UnitInfo.level) / 2)
				local summonTile = targetYeti.UnitInfo.setTile
				local combinedUnit = _UnitSetLogic_New:SpawnOnetimeUnit(self.Entity.OwnerId, "C00001", summonTile, combinedLevel, teamType, true)
				table.insert(self.S10026_CombinedUnits, combinedUnit)
				combinedUnit.UnitAIWanderComponent.setBattle = false
				
				-- 소환 이펙트
				_CustomizedBattleEffectService:PlayEffectAttached(
					"2f5bbf0e23cc40ecb1c424da6da3cc9e",
					combinedUnit, Vector3.zero, 0, Vector3.one, false, nil, self.Entity.OwnerId)
				
				-- '예티', '페페'가 장착하고 있는 아이템 중 무작위 3개를 장착합니다.
				---@type table<string>
				local targetItemList = {}
				local targetPepeItemList = targetPepe.UnitStatus.EquippedItemIDList
				local targetYetiItemList = targetYeti.UnitStatus.EquippedItemIDList
				for i=1, #targetPepeItemList do
					table.insert(targetItemList, targetPepeItemList[i])
				end
				
				for i=1, #targetYetiItemList do
					table.insert(targetItemList, targetYetiItemList[i])
				end
				
				local copyCount = #targetItemList
				if copyCount > 3 then
					copyCount = 3 -- 최대 3개만 장착 가능
				end
				
				for i=1, copyCount do			
					local randomIdx = _UtilLogic:RandomIntegerRange(1, #targetItemList) -- 복사 가능 대상 중 1개를 뽑습니다.
					local copiedItemID = _UtilLogic:Split(targetItemList[randomIdx], "_")[1].."_copied" 
					combinedUnit.UnitStatus:SetProperty("EquippedItemIDList", copiedItemID, "insert,-1") -- 임시 딱지를 븥여서 장착합니다.
					table.remove(targetItemList, randomIdx)	-- 복사했으므로 복사 가능 대상에서 제거합니다.
				end
				combinedUnit.UnitItem:RefreshItemStatus()
				--combinedUnit.UnitStatus:SetUnitStatus(false)
				
				-- '예티', '페페' 초기 통계 기록 활성화
				targetYeti.UnitBattleStatistics:RoundPropertyInitialize(targetYeti.UnitInfo.charID)
				targetPepe.UnitBattleStatistics:RoundPropertyInitialize(targetPepe.UnitInfo.charID)
				
				-- '예티', '페페'를 비활성화
				targetYeti.UnitInfo:SetPropertyToServer("setTile", nil, "All", true)
				targetPepe.UnitInfo:SetPropertyToServer("setTile", nil, "All", true)
				
				
				-- 예티, 페페의 체력 감소
				_StatusChangeLogic:SetVariableStatus(targetYeti, targetYeti, "HP", -targetYeti.UnitStatus.MaxHP*0.5, "synergy")
				_StatusChangeLogic:SetVariableStatus(targetPepe, targetPepe, "HP", -targetPepe.UnitStatus.MaxHP*0.5, "synergy")
				
				
				-- "예티와 페페" 체력, 공격력 적용 ("예티"와 "페페"의 스탯 합으로 적용)
				local getMaxHP = targetYeti.UnitStatus.MaxHP + targetPepe.UnitStatus.MaxHP - combinedUnit.UnitStatus.MaxHP
				local getPhysicalAttack = targetYeti.UnitStatus.PhysicalAttack + targetPepe.UnitStatus.PhysicalAttack - combinedUnit.UnitStatus.PhysicalAttack
				local getMagicalAttack = targetYeti.UnitStatus.MagicalAttack + targetPepe.UnitStatus.MagicalAttack - combinedUnit.UnitStatus.MagicalAttack
				_StatusChangeLogic:GetBuff(combinedUnit, "Add_MaxHP", getMaxHP, -1)
				_StatusChangeLogic:GetBuff(combinedUnit, "Add_PhysicalAttack", getPhysicalAttack, -1)
				_StatusChangeLogic:GetBuff(combinedUnit, "Add_MagicalAttack", getMagicalAttack, -1)
				
				-- "예티와 페페" 시너지 스택 리셋
				combinedUnit.UnitSynergy:ClearAllStackProperties()
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10026_SeparationByDead(Entity deadUnit, Entity deadTile)
		if #self.S10026_CombinedUnits < 1 then
			return
		end
		------------------------------------------------------------
		local combineIdx = 0
		for i=1, #self.S10026_CombinedUnits do
			if self.S10026_CombinedUnits[i] == deadUnit then
				combineIdx = i
				break
			end
		end
		
		if combineIdx == 0 then
			return
		end
		------------------------------------------------------------
		
		-- 원본 예티, 페페 재소환
		local yeti = self.S10026_YetiUnits[combineIdx]
		local pepe = self.S10026_PepeUnits[combineIdx]
		
		-- 예티 소환
		local spawnTile1 = _BTLogic_New:getTileFromTile(deadTile, nil, "EmptyTileNearestToTheUnit_All", self.Entity.OwnerId)[1]
		yeti.UnitInfo:SetPropertyToServer("setTile", spawnTile1, "OnlySetTile", true)
		_CustomizedBattleEffectService:SetEntityVisible(yeti, true, self.Entity.OwnerId)
		
		-- 페페 소환  
		local spawnTile2 = _BTLogic_New:getTileFromTile(deadTile, nil, "EmptyTileNearestToTheUnit_All", self.Entity.OwnerId)[1]
		pepe.UnitInfo:SetPropertyToServer("setTile", spawnTile2, "OnlySetTile", true)
		_CustomizedBattleEffectService:SetEntityVisible(pepe, true, self.Entity.OwnerId)
		
		
		-- 예티, 페페의 체력 감소
		--_StatusChangeLogic:SetVariableStatus(yeti, yeti, "HP", -yeti.UnitStatus.MaxHP*0.5, "synergy")
		--_StatusChangeLogic:SetVariableStatus(pepe, pepe, "HP", -pepe.UnitStatus.MaxHP*0.5, "synergy")
		
		-- 예티 및 페페 모션 추가
		-- 24. 10. 08.
		_StatusChangeLogic:SetStatus(yeti, yeti, "SE0001", -1)
		_StatusChangeLogic:SetStatus(yeti, yeti, "SE0002", -1)
		_StatusChangeLogic:SetStatus(pepe, pepe, "SE0001", -1)
		_StatusChangeLogic:SetStatus(pepe, pepe, "SE0002", -1)
		
		self:S10026_SpawnYetiAndPePe(yeti, deadTile, spawnTile1, 0.8)
		self:S10026_SpawnYetiAndPePe(pepe, deadTile, spawnTile2, 0.8)
		
		--yeti.UnitAIWanderComponent:YetiAndPePe(deadTile, spawnTile1, 0.8)
		--pepe.UnitAIWanderComponent:YetiAndPePe(deadTile, spawnTile2, 0.8)
	end

	@ExecSpace("ServerOnly")
	method void S10026_SeparationByBattleEnd()
		for _, unit in pairs(self.S10026_CombinedUnits) do
			if unit.UnitStatus.HP > 0 then
				self:S10026_SeparationByDead(unit, unit.UnitInfo.setTile)
			end
		end
	end

	@ExecSpace("Server")
	method void S10026_SpawnYetiAndPePe(Entity myUnit, Entity nowTile, Entity nextMoveTile, number setTime)
		local unitInfo = myUnit.UnitInfo
		local unitStatus = myUnit.UnitStatus
		local unitAIComponent = myUnit.UnitAIWanderComponent
		local animComponent = myUnit.UnitAnimationComponent
		
		local fncTime = 0 
		local function moveFnc()
			fncTime += 0.01
			if (fncTime / setTime) >= 1 then
				_TimerService:ClearTimer(unitStatus.ActionTimer)
			end
			
			-- 날리기
			local nowTilePos = nowTile.TransformComponent.WorldPosition
			local moveTilePos = nextMoveTile.TransformComponent.WorldPosition
			local per = math.min(1, (fncTime / setTime) )
				
			local setPosX = nowTilePos.x * (1 - per) + moveTilePos.x * per
			local setPosY = nowTilePos.y * (1 - per) + moveTilePos.y * per - 10 * (fncTime^2 - setTime*fncTime)
			
			unitInfo:SetPosition(setPosX, setPosY, unitInfo.OwnerId)
			unitInfo.spriteRenderer.TransformComponent.ZRotation = fncTime * 720 / setTime
			unitStatus.SetPos = Vector2(setPosX, setPosY)
			
			if (fncTime / setTime) >= 1 then
				--------- 임시코드
				local nextMoveTilePos = nextMoveTile.TransformComponent.WorldPosition
				unitInfo:SetPosition(nextMoveTilePos.x, nextMoveTilePos.y, unitInfo.OwnerId)
				
				unitStatus.SetPos = Vector2(nextMoveTilePos.x, nextMoveTilePos.y)
				myUnit.TransformComponent.ZRotation = 0
				animComponent:PlayAnimation(1, "Idle", nil, unitInfo.OwnerId)
				unitStatus:SetProperty("state", "Idle", "")
				------------------
				if self.Entity.GameManager.PhaseType == "Battle" then
					unitAIComponent.Enable = true
					unitAIComponent.setBattle = true
				end
				
				myUnit.UnitItem:OnBattleStart()
				_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0001", 0)
				_StatusChangeLogic:SetStatus(myUnit, myUnit, "SE0002", 0)
				unitStatus:SetActionType("Idle")
				--_TimerService:ClearTimer(unitStatus.ActionTimer)
				unitStatus.ActionTimer = 0
			end
		end
		
		_TimerService:ClearTimer(unitStatus.ActionTimer)
		unitStatus:SetActionType("Move")
		unitStatus.ActionTimer = _TimerService:SetTimerRepeat(moveFnc, 0.01, 0)
	end

	@ExecSpace("ServerOnly")
	method void S10026_CleanPhase()
		for i=1, #self.S10026_PepeUnits do
			_CustomizedBattleEffectService:SetEntityVisible(self.S10026_PepeUnits[i], true, self.Entity.OwnerId)
			_CustomizedBattleEffectService:SetEntityVisible(self.S10026_YetiUnits[i], true, self.Entity.OwnerId)
			_CustomizedBattleEffectService:SetEntityVisible(self.S10026_CombinedUnits[i], true, self.Entity.OwnerId)
		end
		
		table.clear(self.S10026_YetiUnits)
		table.clear(self.S10026_PepeUnits)
		table.clear(self.S10026_CombinedUnits)
	end

	@ExecSpace("ServerOnly")
	method void S10027_Dead(Entity deadUnit)
		-- 발록 : 아군이 처치될 때마다 발록 유닛들이 추가 최대 체력을 얻고 거대해집니다.
		------------------------------------------------------------------------------------
		local teamType = deadUnit.UnitInfo.TeamType
		local activatedCount = 0
		
		if teamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10027"]
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10027"]
		end
		------------------------------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		if isvalid(activatedCount) == false or activatedCount < 2 then
			return
		else
			if teamType == "User" then
				table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
				for i=#targetUnits, 1, -1 do
					if targetUnits[i].UnitInfo:IsOnFieldUnit() 
					and targetUnits[i].UnitInfo:DoesHaveSynergy("S10027")
					and targetUnits[i].UnitAIWanderComponent.Enable then
						
					else
						table.remove(targetUnits, i)
					end
				end
			else
				table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
				for i=#targetUnits, 1, -1 do
					if targetUnits[i].UnitInfo:IsOnFieldUnit() 
					and targetUnits[i].UnitInfo:DoesHaveSynergy("S10027")
					and targetUnits[i].UnitAIWanderComponent.Enable then
						
					else
						table.remove(targetUnits, i)
					end
				end
			end
		end
		------------------------------------------------------------------------------------
		for i=1, #targetUnits do
			targetUnits[i].UnitSynergy.SynergyStack["S10027"] += 4
			targetUnits[i].UnitStatus:SetUnitStatusByStat(true, "MaxHP")
			
		    --local scaleStack = 0.05 * (targetUnits[i].UnitSynergy.SynergyStack["S10027"] / 9)
		    --targetUnits[i].UnitInfo:SetTransformScale((1+ scaleStack), self.Entity.OwnerId)
		    --
			_CustomizedBattleEffectService:PlayEffectAttached(
				"0e4122e1e9bf42f3ba8a22452dbe5cf3",
				targetUnits[i], Vector3.zero, 0, Vector3.one, false, nil, self.Entity.OwnerId)
		end
	end

	@ExecSpace("ServerOnly")
	method void S10029(string teamType)
		--[[
		악몽의 지배자 (루시드 고유) : 
		루시드가 플레이어 대상 전투에 참여하면 꿈의 조각을 얻습니다. 
		전투 시작 시, 꿈의 조각 수만큼 무작위 아군 1명이 MP를 5 얻습니다. 이 효과는 같은 아군에게 지급될 수도 있습니다.
		]]
		---------------------------------------------
		local activatedCount = 0
		---@type table<Entity>
		local targets = {}
		
		if teamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10029"]
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10029"]
		end
		
		if isvalid(activatedCount) == false or activatedCount < 1 then
			return
		end
		
		---------------------------------------------
		if teamType == "User" then
			-- 아군 꿈의 조각 수 +1
			self.SynergyStack["S10029"] += 1
			
			table.initialize(targets, self.Entity.TeamManager.OwnUnits)
			for i=#targets, 1, -1 do
				if targets[i].UnitInfo:IsOnFieldUnit() == false or targets[i].UnitAIWanderComponent.setBattle == false then
					table.remove(targets, i)
				end
			end
			-- 보유한 꿈의 조각 수만큼 무작위 아군 1명이 MP를 5 얻음
			for i=1, self.SynergyStack["S10029"] do
				local randomIdx = _UtilLogic:RandomIntegerRange(1, #targets)
				local target = targets[randomIdx]
				
				_StatusChangeLogic:SetVariableStatus(nil, target, "MP", 5, "")
				_CustomizedBattleEffectService:PlayEffectAttached(
					"a0cb3579f8774b99832bc362d4f5a640", 
					target, Vector3.zero, 0, Vector3.one, false, nil, self.Entity.OwnerId)
			end
			
			
		else
			-- 적 꿈의 조각 수 +1
			self.Enemy_SynergyStack["S10029"] += 1
			table.initialize(targets, self.Entity.TeamManager.EnemyUnits)
			for i=#targets, 1, -1 do
				if targets[i].UnitInfo:IsOnFieldUnit() == false or targets[i].UnitAIWanderComponent.setBattle == false then
					table.remove(targets, i)
				end
			end
			
			-- 보유한 꿈의 조각 수만큼 무작위 적 1명이 MP를 5 얻음
			for i=1, self.Enemy_SynergyStack["S10029"] do
				local randomIdx = _UtilLogic:RandomIntegerRange(1, #targets)
				local target = targets[randomIdx]
				
				if isvalid(target) then
					_StatusChangeLogic:SetVariableStatus(nil, target, "MP", 5, "")
					_CustomizedBattleEffectService:PlayEffectAttached(
						"a0cb3579f8774b99832bc362d4f5a640", 
						target, Vector3.zero, 0, Vector3.one, false, nil, self.Entity.OwnerId)
				else
					log_error("Target이 없음")
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10032_Default(string teamType)
		-- 마가티아 유닛 별 합계에 따라 아군 유닛의 능력치가 증가합니다.
		----------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		local activatedCount = 0
		if teamType == "Enemy" then
			table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10032"]
		else
			table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10032"]
		end
		----------------------------------------------------------------
		if not isvalid(activatedCount) then
			-- 체크할 필요 없음
			return
		end
		----------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		local runeType = 0
		if (teamType == "User" and ( 0 < self.SynergyRuneOn["S10032"] ) ) then
			runeType = self.SynergyStack["S10032_Type"]
		elseif (teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10032"] ) ) then
			runeType = self.Enemy_SynergyStack["S10032_Type"]
		end
		----------------------------------------------------------------
		local addAttackCheck = 0
		if runeType == 1 then
			addAttackCheck = 1
		end
		----------------------------------------------------------------
		-- 전장 위 유닛 별 합계 체크
		local setLevelAmount = 0
		for _, unit in pairs(targetUnits) do
			if unit.UnitInfo:DoesHaveSynergy("S10032") and unit.UnitInfo:IsOnFieldUnit() then
				setLevelAmount += unit.UnitInfo.level
			end
		end
		
		-- 별에 따라 스탯 강화
		for _, unit in pairs(targetUnits) do
			local unitSynergy = unit.UnitSynergy
			
			if isvalid(activatedCount) == false or activatedCount < 3 then
				unitSynergy.SynergyStack["S10032_HP"] = 0
				unitSynergy.SynergyStack["S10032_DEF"] = 0
				unitSynergy.SynergyStack["S10032_ATK"] = 0
			elseif activatedCount < 5 then
				unitSynergy.SynergyStack["S10032_HP"] = 10 * setLevelAmount
				unitSynergy.SynergyStack["S10032_DEF"] = 3 * setLevelAmount
				unitSynergy.SynergyStack["S10032_ATK"] = setLevelAmount * addAttackCheck
			elseif activatedCount < 7 then
				unitSynergy.SynergyStack["S10032_HP"] = 20 * setLevelAmount
				unitSynergy.SynergyStack["S10032_DEF"] = 5 * setLevelAmount
				unitSynergy.SynergyStack["S10032_ATK"] = setLevelAmount * addAttackCheck
			elseif activatedCount < 10 then
				if unit.UnitInfo:DoesHaveSynergy("S10032") then
					unitSynergy.SynergyStack["S10032_HP"] = 55 * setLevelAmount
					unitSynergy.SynergyStack["S10032_DEF"] = 15 * setLevelAmount
					unitSynergy.SynergyStack["S10032_ATK"] = setLevelAmount * addAttackCheck
				else
					unitSynergy.SynergyStack["S10032_HP"] = 35 * setLevelAmount
					unitSynergy.SynergyStack["S10032_DEF"] = 10 * setLevelAmount
					unitSynergy.SynergyStack["S10032_ATK"] = setLevelAmount * addAttackCheck
				end
			else
				if unit.UnitInfo:DoesHaveSynergy("S10032") then
					unitSynergy.SynergyStack["S10032_HP"] = 100 * setLevelAmount
					unitSynergy.SynergyStack["S10032_DEF"] = 35 * setLevelAmount
					unitSynergy.SynergyStack["S10032_ATK"] = setLevelAmount * addAttackCheck
				else
					unitSynergy.SynergyStack["S10032_HP"] = 60 * setLevelAmount
					unitSynergy.SynergyStack["S10032_DEF"] = 20 * setLevelAmount
					unitSynergy.SynergyStack["S10032_ATK"] = setLevelAmount * addAttackCheck
				end
			end
			
			unit.UnitStatus:SetUnitStatusByStat(false, "MaxHP")
			unit.UnitStatus:SetUnitStatusByStat(false, "PhysicalAttack")
			unit.UnitStatus:SetUnitStatusByStat(false, "MagicalAttack")
			unit.UnitStatus:SetUnitStatusByStat(false, "Defence")
			unit.UnitStatus:SetUnitStatusByStat(false, "MagicalResistance")
		end
	end

	@ExecSpace("ServerOnly")
	method void S10034_Default(string teamType)
		-- 처형자 : 추가 크리티컬 확률 및 크리티컬 피해량 획득
		----------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		local activatedCount = 0
		if teamType == "Enemy" then
			table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10034"]
		else
			table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10034"]
		end
		----------------------------------------------------------------
		for _, unit in pairs(targetUnits) do
			if unit.UnitInfo:DoesHaveSynergy("S10034") then
				local unitSynergy = unit.UnitSynergy
				-- 시너지 활성화 여부 검토
				local beforeStack = 0 -- 이전 수치
				beforeStack = unitSynergy.SynergyStack["S10034_Critical"]
				
				if isvalid(activatedCount) == false or activatedCount < 2 then
					unitSynergy.SynergyStack["S10034_Critical"] = 0
					unitSynergy.SynergyStack["S10034_CriticalDamage"] = 0
				elseif activatedCount < 4 then
					unitSynergy.SynergyStack["S10034_Critical"] = 10
					unitSynergy.SynergyStack["S10034_CriticalDamage"] = 0
				elseif activatedCount < 6 then
					unitSynergy.SynergyStack["S10034_Critical"] = 20
					unitSynergy.SynergyStack["S10034_CriticalDamage"] = 0
				elseif activatedCount < 8 then
					unitSynergy.SynergyStack["S10034_Critical"] = 35
					unitSynergy.SynergyStack["S10034_CriticalDamage"] = 10
				else
					unitSynergy.SynergyStack["S10034_Critical"] = 70
					unitSynergy.SynergyStack["S10034_CriticalDamage"] = 30
				end
				
				-- 변경값과 이전 효과 수치가 다르면, 바뀐 것이므로 유닛의 스탯을 다시 적용
				unit.UnitStatus:SetUnitStatusByStat(false, "CriticalPercent")
				unit.UnitStatus:SetUnitStatusByStat(false, "CriticalDamagePercent")
				--unit.UnitStatus:SetUnitStatus(false)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10037_Dead(Entity deadUnit)
		-- 분노 : 아군이 둘 이상 죽으면 도깨비가 분노합니다. 전투가 끝날 때까지 저지 불가 상태에 돌입하며, 이동 속도와 공격 속도가 증가합니다.
		------------------------------------------------------------------------------------
		local teamType = deadUnit.UnitInfo.TeamType
		local activatedCount = 0
		
		if teamType == "User" then
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10037"]
		else
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10037"]
		end
		------------------------------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		if isvalid(activatedCount) == false or activatedCount < 1 then
			return
		else
			if teamType == "User" then
				table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
				for i=#targetUnits, 1, -1 do
					if targetUnits[i].UnitInfo:IsOnFieldUnit() 
					and targetUnits[i].UnitInfo:DoesHaveSynergy("S10037")
					and targetUnits[i].UnitAIWanderComponent.Enable then
						
					else
						table.remove(targetUnits, i)
					end
				end
			else
				table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
				for i=#targetUnits, 1, -1 do
					if targetUnits[i].UnitInfo:IsOnFieldUnit() 
					and targetUnits[i].UnitInfo:DoesHaveSynergy("S10037")
					and targetUnits[i].UnitAIWanderComponent.Enable then
						
					else
						table.remove(targetUnits, i)
					end
				end
			end
		end
		------------------------------------------------------------------------------------
		for i=1, #targetUnits do
			if isvalid(targetUnits[i].C50009_KingGoblin_Skill.deathCount) then
				targetUnits[i].C50009_KingGoblin_Skill.deathCount += 1
				
				if targetUnits[i].C50009_KingGoblin_Skill.deathCount >= 2 then
					targetUnits[i].C50009_KingGoblin_Skill:PhaseChange()
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10031_SetItemOrder()
		-- 아랫마을
		-- 나오는 아이템 순서 설정
		------------------------------------------------
		local itemTable = {2, 3, 4, 5, 6, 7}
		
		local setItemList = 0
		
		for i = 1, 6 do
			local selectIdx = _UtilLogic:RandomIntegerRange(1, #itemTable)
			
			setItemList = setItemList * 10 + itemTable[selectIdx]
			table.remove(itemTable, selectIdx)
		end
		
		setItemList = setItemList * 10 + 8
		
		self.SynergyStack["S10031_ItemOrder"] = setItemList
		self.Enemy_SynergyStack["S10031_ItemOrder"] = setItemList
		
	end

	@ExecSpace("ServerOnly")
	method void S10031_GetItem(number synergyCount)
		-- 아랫마을
		-- 순서에 맞게 아이템을 지급 및 회수합니다.
		------------------------------------------------------------------------------------
		-- 수치를 계산해야하는 경우
		if synergyCount < 0 then
			synergyCount = self.Entity.TeamManager.OnFieldSynergy["S10034"]
		end
		------------------------------------------------------------------------------------
		-- 아이템을 가지고 있는지 체크해주는 함수
		local haveItems = function(checkItemID)
			-- ownItems 검사
			local ownItems = self.Entity.TeamManager.OwnItems
			for i=1, #ownItems do
				if ownItems[i] == checkItemID then
					return true
				end
			end
			
			-- 내 유닛들의 장착 여부 검사
			local ownUnits = self.Entity.TeamManager.OwnUnits
			for i=1, #ownUnits do
				local equippedItems = ownUnits[i].UnitStatus.EquippedItemIDList
				for j=1, #equippedItems do
					if equippedItems[j] == checkItemID then
						return true
					end
				end
			end
			
			return false
		end
		-----------------------------------------------------------------------------------
		-- 아이템을 회수하는 함수
		local withDrawFnc = function(checkItemID)
			local withdrawed = false
		
			-- ownItems 검사
			local ownItems = self.Entity.TeamManager.OwnItems
			for i=1, #ownItems do
				if ownItems[i] == checkItemID then
					table.remove(ownItems, i)
					withdrawed = true
					break
				end
			end
			
			-- 내 유닛들의 장착 여부 검사
			if withdrawed == false then
				local ownUnits = self.Entity.TeamManager.OwnUnits
				for i=1, #ownUnits do
					local equippedItems = ownUnits[i].UnitStatus.EquippedItemIDList
					for j=1, #equippedItems do
						if equippedItems[j] == checkItemID then
							ownUnits[i].UnitStatus:SetProperty("EquippedItemIDList", "", string.format("remove,%d", j))
							break
						end
					end
				end
			end
		end
		------------------------------------------------------------------------------------
		-- 아이템 리스트 정렬
		local itemListNum = self.SynergyStack["S10031_ItemOrder"]
		local itemSetTable = {}
		
		for i = 1, 7 do
			local itemNum = itemListNum % 10
			table.insert(itemSetTable, 1, string.format("SI1000%d", itemNum))
			
			itemListNum = math.floor(itemListNum / 10)
		end
		
		------------------------------------------------------------------------------------
		-- 지급 아이템 개수 체크
		local insertNum = 0
		if not isvalid(synergyCount) or synergyCount < 3 then
			-- 모든 아이템 회수
			insertNum = 0
		elseif synergyCount < 5 then
			-- 첫번째 아이템 지급, 다른 아이템 회수
			insertNum = 1
		elseif synergyCount < 8 then
			-- 3번째 아이템까지 지급, 다른 아이템 회수
			insertNum = 3
		elseif synergyCount < 10 then
			-- 6번째 아이템까지 지급, 다른 아이템 회수
			insertNum = 6
		else
			-- 전부 지급
			insertNum = 7
		end
		------------------------------------------------------------------------------------
		-- 아이템 지급 및 회수
		for i = 1, 7 do
			local itemID = itemSetTable[i]
			
			if i <= insertNum then
				local set = haveItems(itemID)
				if not set then
					table.insert(self.Entity.TeamManager.OwnItems, itemID)
				end
			else
				withDrawFnc(itemID)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void S10038_Blessing(string teamType)
		-- 여우신의 가호
		-- 전투가 끝날 때까지, 랑의 영혼이 3초마다 가장 체력 비율이 낮은 아군에게 이동하며 머뭅니다.
		-- 머물러 있는 동안 그 유닛은 여우신의 가호를 받아 피해량이 20% 감소하며 그 유닛의 체력을 초당 최대 체력의 1%씩 회복시킵니다.
		------------------------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		---@type Entity
		local unit_Sino
		local activatedCount = 0
		if teamType == "Enemy" then
			table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10038"]
		else
			table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10038"]
		end
		------------------------------------------------------------------------------
		for _, target in pairs(targetUnits) do
			if target.UnitInfo:DoesHaveSynergy("S10038") then
				unit_Sino = target
				break
			end
		end
		------------------------------------------------------------------------------
		if not isvalid(activatedCount) or activatedCount < 1 then
			return
		end
		
		-- 전투 시작하면 랑 소환 후 버프 주는 타이머 확인
		local fncCount = 0
		local fncTimer = 0
		---@type table<Entity>, Entity
		local checkUnits, setUnit
		
		local function BuffFnc()
			-- 회복 : 1초마다 대상 최대 체력의 1%씩 회복
			if isvalid(setUnit) then
				_StatusChangeLogic:SetVariableStatus(unit_Sino, setUnit, "HP", setUnit.UnitStatus.MaxHP * 0.01, "synergy")
			end
			
			if fncCount == 0 then
				-- 새로 다른 유닛한테 버프를 줄 때
				checkUnits = _BTLogic_New:getEntities(targetUnits, "AttackAble")
				setUnit = _BTLogic_New:getTarget(unit_Sino.UnitInfo.setTile, checkUnits, "HPper_Low")
				
				if isvalid(setUnit) then
					-- 랑 소환
					self:S10038_BlessingEffect(setUnit, self.Entity.OwnerId)
					
					-- 버프 : 피해량 20% 감소
					_StatusChangeLogic:GetBuff(setUnit, "DamageDecrease_Per", 20, 3)
				else
					_TimerService:ClearTimer(fncTimer)
				end
				
			end
			
			
			-- 카운트
			fncCount = (fncCount+1)%3
		end
		
		fncTimer = _TimerService:SetTimerRepeat(BuffFnc, 1, 3)
	end

	@ExecSpace("Client")
	method void S10038_BlessingEffect(Entity target)
		local unitInfo = target.UnitInfo
		local unitStatus = target.UnitStatus
		
		-- Set Attack Effect
		local filpX = unitInfo.spriteRenderer.SpriteRendererComponent.FlipX
		local options = {["FlipX"] = filpX, ["PlayRate"] = 1,["Color"]=Color(1,1,1,_ESCMenuService.skillEffectAlpha/100)}
		_EffectService:PlayEffectAttached("b36c5e08227b41c0b092a55e6716501f", target, Vector3(0, 0, 0), 0, Vector3.one, false, options)
	end

	@ExecSpace("ServerOnly")
	method void S10032_GetItem(string teamType)
		-- 마가티아 "알카드노" 전투 시작 후, 그리고 8초마다 살아있는 랜덤한 아군 유닛에게 알맞은 완성 아이템을 장착합니다.
		-- 이 아이템은 전투 종료 후 사라집니다.
		----------------------------------------------------------------
		local calledRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
		----------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		local activatedCount = 0
		if teamType == "Enemy" then
			table.initialize(targetUnits, self.Entity.TeamManager.EnemyUnits)
			activatedCount = self.Entity.TeamManager.EnemyOwnedFieldSynergy["S10032"]
		else
			table.initialize(targetUnits, self.Entity.TeamManager.OwnUnits)
			activatedCount = self.Entity.TeamManager.OnFieldSynergy["S10032"]
		end
		
		if isvalid(activatedCount) == false or activatedCount < 3 then
			return
		end
		----------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		local runeType = 0
		if (teamType == "User" and ( 0 < self.SynergyRuneOn["S10032"] ) ) then
			runeType = self.SynergyStack["S10032_Type"]
		elseif (teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10032"] ) ) then
			runeType = self.Enemy_SynergyStack["S10032_Type"]
		end
		
		if runeType ~= 2 then
			log("알카드노가 아님")
			return
		end
		----------------------------------------------------------------
		-- 아이템 지급 함수
		local mostItemSet = _DataService:GetTable("CharMostItemSet")
		
		local fncTimer = 0
		local function setItemFnc()
			--------------------------------
			if isvalid(self.Entity) == false then
				_TimerService:ClearTimer(fncTimer)
				return
			end
			
			-- 재귀 종료 조건1 : 전투 중이 아님
			if self.Entity.GameManager.PhaseType ~= "Battle" then
				log("전투 중이 아님")
				_TimerService:ClearTimer(fncTimer)
				return
			end
			-- 재귀 종료 조건2 : 이 함수를 실행한 라운드가 아님
			local currentRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
			if currentRound ~= calledRound then
				log("이 함수를 실행한 라운드가 아님")
				_TimerService:ClearTimer(fncTimer)
				return
			end
			--------------------------------
			-- 아이템 지급 가능한 유닛 체크
			
			---@type table<Entity>
			local t_Units = _BTLogic_New:getEntities(targetUnits, "Alive")
			
			---@type table<Entity>
			local checkUnits = {}
			
			for _, unit in pairs(t_Units) do
				if #unit.UnitStatus.EquippedItemIDList < 3 then
					table.insert(checkUnits, unit)
				end
			end
			
			---@type Entity
			local setUnit = checkUnits[_UtilLogic:RandomIntegerRange(1, #checkUnits)]
			if isvalid(setUnit) then
				local charID = setUnit.UnitInfo.charID
				
				local charBestItemRow = mostItemSet:FindRow("CharID", charID)
				
				---@type table<string>
				local setItemList = {}
				for i = 1, 8 do
					table.insert(setItemList, charBestItemRow:GetItem( string.format("ItemID_%d", i) ).."_copied" )
				end
				
				local randItemIdx = _UtilLogic:RandomIntegerRange(1, #setItemList)
				local randItemID = setItemList[randItemIdx]
				setUnit.UnitStatus:SetProperty("EquippedItemIDList", randItemID, "insert,-1")
				--setUnit.UnitStatus:SetUnitStatus(true)
			end
		end
		
		fncTimer = _TimerService:SetTimerRepeat(setItemFnc, 12, 0)
		
	end

	@ExecSpace("ServerOnly")
	method void S10031_BattleStart(string teamType)
		-- 아랫마을 룬카드 효과
		-- 옥석을 장착한 유닛이 한 개당 추가로 최대 체력을 200 얻습니다.
		----------------------------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		----------------------------------------------------------------------
		---@type table<Entity>
		local targetUnits = {}
		local activatedCount = 0
		if teamType == "Enemy" then
			table.initialize(targetUnits, teamManager.EnemyUnits)
			activatedCount = teamManager.EnemyOwnedFieldSynergy["S10031"]
		else
			table.initialize(targetUnits, teamManager.OwnUnits)
			activatedCount = teamManager.OnFieldSynergy["S10031"]
		end
		
		if isvalid(activatedCount) == false or activatedCount < 3 then
			return
		end
		----------------------------------------------------------------------
		-- 룬카드 시너지 활성화 체크
		local runeCount = 0
		if (teamType == "User" and ( 0 < self.SynergyRuneOn["S10031"] ) ) then
			runeCount = self.SynergyRuneOn["S10031"]
		elseif (teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10031"] ) ) then
			runeCount = self.Enemy_SynergyRuneOn["S10031"]
		end
		
		if runeCount <= 0 then
			return
		end
		----------------------------------------------------------------------
		-- 옥석 장착 유닛 체력 증가
		for _, unit in pairs(targetUnits) do
			local getHPAmount = 0
			local unitSynergy = unit.UnitSynergy
			
			for _, itemID in pairs(unit.UnitStatus.EquippedItemIDList) do
				if string.sub(itemID, 1, 6) == "SI1000" and itemID ~= "SI10001" and itemID ~= "SI10009" then
					getHPAmount += 200
				end
			end
			
			if getHPAmount > 0 then
				unitSynergy.SynergyStack["S10031_HP"] = getHPAmount
			end
			
			unit.UnitStatus:SetUnitStatusByStat(true, "MaxHP")
		end
		----------------------------------------------------------------------
		
	end

	@ExecSpace("ServerOnly")
	method void S10036_BattleStart(string teamType)
		-- 판타스틱 테마파크 : 퍼레이드가 열렸습니다! 일정한 간격으로 다양한 효과를 받습니다. 퍼레이드의 효과는 아군 판타스틱 테마파크 유닛의 레벨당 10%씩 더 강해집니다.
		-- 
		----------------------------------------------------------------------
		local user = self.Entity
		local teamManager = user.TeamManager
		local nItemtable = _ItemSetLogic:GetItemList(user.OwnerId, "NormalItem")
		local calledRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
		----------------------------------------------------------------------
		---@type table<Entity>
		local teamUnits = {}
		---@type table<Entity>
		local targetUnits = {}
		local activatedCount = 0
		if teamType == "Enemy" then
			table.initialize(teamUnits, teamManager.EnemyUnits)
			table.initialize(targetUnits, teamManager.OwnUnits)
			activatedCount = teamManager.EnemyOwnedFieldSynergy["S10036"]
		else
			table.initialize(teamUnits, teamManager.OwnUnits)
			table.initialize(targetUnits, teamManager.EnemyUnits)
			activatedCount = teamManager.OnFieldSynergy["S10036"]
		end
		----------------------------------------------------------------------
		for i = #teamUnits, 1, -1 do
			local unit = teamUnits[i]
			
			if not unit.UnitInfo:IsOnFieldUnit() then
				table.remove(teamUnits, i)
			end
		end
		---------------------------------------------------------------------
		local levelAmount = 0
		for _, unit in pairs(teamUnits) do
			if unit.UnitInfo:DoesHaveSynergy("S10036") then
				levelAmount += unit.UnitInfo.level
			end
		end
		----------------------------------------------------------------------
		local paradeGrade = 0
		local paradeCycleTime = 0
		local synergyNine = 1
		if isvalid(activatedCount) == false or activatedCount < 3 then
			return
		elseif activatedCount < 5 then
			paradeGrade = 3
			paradeCycleTime = 3
		elseif activatedCount < 7 then
			paradeGrade = 5
			paradeCycleTime = 2.5
		elseif activatedCount < 9 then
			paradeGrade = 6
			paradeCycleTime = 2
		else
			paradeGrade = 6
			paradeCycleTime = 1
			synergyNine = 2
		end
		----------------------------------------------------------------------
		-- 퍼레이드 효과 목록
		-- 1. 공격 속도 버프 (기본 20%)
		-- 2. 회복 (기본 90)
		-- 3. 유령 폭발 범위 피해 (기본 90)
		-- 4. 범위 피해량 증가 버프 (마몬, 기본 10%)
		-- 5. 롤링 돌리온 일직선 공격 (기본 100)
		-- 6. 임시 아이템 장착 ( 7시너지 1개 / 10시너지 2개 )
		----------------------------------------------------------------------
		local paradeTimer = 0
		local function ParadeFnc()
			if isvalid(self.Entity) == false then
				_TimerService:ClearTimer(paradeTimer)
				return
			end
			
			-- 타이머 종료 체크
			-- 재귀 종료 조건1 : 전투 중이 아님
			if self.Entity.GameManager.PhaseType ~= "Battle" then
				_TimerService:ClearTimer(paradeTimer)
				return
			end
			-- 재귀 종료 조건2 : 이 함수를 실행한 라운드가 아님
			local currentRound = string.format("%d-%d", self.Entity.GameManager.Stage, self.Entity.GameManager.Round)
			if currentRound ~= calledRound then
				_TimerService:ClearTimer(paradeTimer)
				return
			end
			---------------------------------------------------------------------------
			-- 룬카드 시너지 활성화 체크
			local runeCount = 0
			if (teamType == "User" and ( 0 < self.SynergyRuneOn["S10036"] ) ) then
				runeCount = self.SynergyRuneOn["S10036"]
			elseif (teamType == "Enemy" and ( 0 < self.Enemy_SynergyRuneOn["S10036"] ) ) then
				runeCount = self.Enemy_SynergyRuneOn["S10036"]
			end
			---------------------------------------------------------------------------
			local paradeCount = 1
			for i = 1, runeCount do
				local per = _UtilLogic:RandomDouble()
				if per < 0.4 then
					paradeCount += 1
				end
			end
			
			for i = 1, paradeCount do
				local setParadeNum = _UtilLogic:RandomIntegerRange(1, paradeGrade)
				if setParadeNum == 1 then
					-- 무작위 아군 공격 속도 버프
					log("무작위 아군 공격 속도 버프")
					local buffAmount = (20 * synergyNine) * (1 + levelAmount * 0.1)
					local setTeams = _BTLogic_New:getEntities(teamUnits, "Alive")
					if #setTeams > 0 then
						-- 9b72c73ee6cb4e9f960c17a72be6bde6 머리 위에 해당 이펙트가 뜨며, 4초간 공속 20% 증가
						local setUnit = setTeams[_UtilLogic:RandomIntegerRange(1, #setTeams)]
						_StatusChangeLogic:GetBuff(setUnit, "Multi_AttackSpeed", buffAmount, 4)
						
						_EffectService:PlayEffectAttached("9b72c73ee6cb4e9f960c17a72be6bde6", setUnit, Vector3(0,1,0), 0, Vector3.one * 1.2, false)
					end
				elseif setParadeNum == 2 then
					-- 가장 체력이 낮은 아군 회복
					log("가장 체력이 낮은 아군 회복")
					local buffAmount = (90 * synergyNine) * (1 + levelAmount * 0.1)
					local setTeams = _BTLogic_New:getEntities(teamUnits, "Alive")
					if #setTeams > 0 then
						-- b518120d049a4a2f8957a438cb66a884 머리 위에 해당 이펙트가 뜨며 회복
						local setUnit = _BTLogic_New:getTarget(nil, setTeams, "HPper_Low")
						_StatusChangeLogic:SetVariableStatus(nil, setUnit, "HP", buffAmount, "synergy")
						
						_EffectService:PlayEffectAttached("b518120d049a4a2f8957a438cb66a884", setUnit, Vector3(0,0.5,0), 0, Vector3.one * 1.2, false)
					end
				elseif setParadeNum == 3 then
					-- 유령이 위에서 날아와 해당 타일로 이동, 그 후 폭발 범위 피해
					log("유령이 위에서 날아와 해당 타일로 이동, 그 후 폭발 범위 피해")
					local dmgAmount = (90 * synergyNine) * (1 + levelAmount * 0.1)
					local setTargets = _BTLogic_New:getEntities(targetUnits, "Alive")
					local setTileInfo = _BTLogic_New:getTile(teamUnits[1], setTargets, "TileWithMostEnemies_All_1")
					_EffectService:PlayEffectAttached("12b01a00bcd34bfdba7be8efe2d69406", setTileInfo[1], Vector3(0,0,0), 0, Vector3.one * 1.7, false)
					
					-- 피해
					local function dmgFnc()
						local setDMGTargets = _BTLogic_New:getTargets(setTileInfo[1], setTargets, "Around_0_1")
						for _, target in pairs(setDMGTargets) do
							_StatusChangeLogic:HitDamage(nil, target, 0, 0, dmgAmount, "synergy")
							_EffectService:PlayEffectAttached("353079a9d111455ab55d75577f9d7967", setTileInfo[1], Vector3(0,0.3,0), 0, Vector3.one, false)
						end
					end
					_TimerService:SetTimerOnce(dmgFnc, 1)
					
				elseif setParadeNum == 4 then
					-- 마몬이 하늘에서 뚝 떨어짐 99db528ea79d44e6b0b8a7fd8d5c7c4b, 이후 주변 1칸 이내 범위 피해량 증가 버프 4초간 지속
					log("범위 피해량 증가 버프 4초간 지속")
					local buffAmount = (20 * synergyNine) * (1 + levelAmount * 0.1)
					local setTeams = _BTLogic_New:getEntities(teamUnits, "Alive")
					local setTileInfo = _BTLogic_New:getTile(teamUnits[1], setTeams, "TileWithMostEnemies_All_1")
					
					-- 범위 피해량 증가 버프
					local setBuffTargets = _BTLogic_New:getTargets(setTileInfo[1], setTeams, "Around_0_1")
					for _, unit in pairs(setBuffTargets) do
						_StatusChangeLogic:GetBuff(unit, "Add_DealingDamageRate", buffAmount, 4)
					end
					-- 마몬이 하늘에서 뚝 떨어짐
					_EffectService:PlayEffectAttached("99db528ea79d44e6b0b8a7fd8d5c7c4b", setTileInfo[1], Vector3(0,0,0), 0, Vector3.one * 1.3, false)
				elseif setParadeNum == 5 then
					-- 롤링 돌리온이 가장 많은 줄에서 왼쪽에서 오른쪽으로 일직선 돌진
					log("롤링 돌리온이 왼쪽에서 오른쪽으로 일직선 돌진")
					local dmgAmount = (100 * synergyNine) * (1 + levelAmount * 0.1)
					local paradeMonster = _UnitSetLogic_New:GetProjectileEntity(user.OwnerId, "Skill")
					paradeMonster:AddComponent(S10036_RollingDollion_projectileInfo)
					
					paradeMonster.SpriteRendererComponent.SpriteRUID = "20aa6ebb9fc54b5d831f03f48add3349"
					paradeMonster.TransformComponent.Scale = Vector3.one
					paradeMonster.SpriteRendererComponent.FlipX = true
					
					-- Tile 선택
					---@type table<Entity>
					local setTargets = _BTLogic_New:getEntities(targetUnits, "Alive")
					local idxTable = {}
					for _, target in pairs(setTargets) do
						local lineIdx = target.UnitInfo.setTile.TileComponent_New.verticalNum
						if isvalid(idxTable[lineIdx]) then
							idxTable[lineIdx] += 1
						else
							idxTable[lineIdx] = 1
						end
					end
					
					local maxCount = 0
					local setIdxTable = {}
					for idx, count in pairs(idxTable) do
						if maxCount < count then
							maxCount = count
							table.clear(setIdxTable)
							table.insert(setIdxTable, idx)
						elseif maxCount == count then
							table.insert(setIdxTable, idx)
						end
					end
					
					local tileIdx = setIdxTable[_UtilLogic:RandomIntegerRange(1,#setIdxTable)]
					local jMin = 2 - (tileIdx%2)
					local jMax = ( (8 + tileIdx%2) * 2 ) - jMin
					local ownerTile = self.Entity.GameManager.RoomTile[string.format("%d,%d", jMin, tileIdx)]
					local targetTile = self.Entity.GameManager.RoomTile[string.format("%d,%d", jMax, tileIdx)]
					paradeMonster.S10036_RollingDollion_projectileInfo:SetProjectile(ownerTile, targetTile, 1.3, 1, 0, 0, dmgAmount, teamType)
				elseif setParadeNum == 6 then
					-- 임시 아이템 장착
					log("임시 아이템 장착")
					local itemAmount = synergyNine
					---@type table<Entity>
					local setTeams = _BTLogic_New:getEntities(teamUnits, "Alive")
					local canEquipItemUnits = {}
					for _, unit in pairs(setTeams) do
						if #unit.UnitStatus.EquippedItemIDList < 3 and unit.UnitInfo.IsItemEquippable then
							table.insert(canEquipItemUnits, unit)
						end
					end
					if #canEquipItemUnits > 0 then
						local target = canEquipItemUnits[_UtilLogic:RandomIntegerRange(1, #canEquipItemUnits)]
						local itemIdx = _UtilLogic:RandomIntegerRange(1, #nItemtable)
						_ItemSetLogic:EquipItemThroughItemID(target, nItemtable[itemIdx].."_copied")
					end
				end
			end
		end
		
		paradeTimer = _TimerService:SetTimerRepeat(ParadeFnc, paradeCycleTime, paradeCycleTime)
	end

