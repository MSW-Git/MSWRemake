	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5b5e30d0-d1b3-4a22-8058-ffe874b09929")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		local tmProperty = self.Entity.TM_PropertyControl
		
		if self.Entity.GameManager.ModeType == "Tutorial" then
			if self.Entity.TutorialManager_New.AllowRuneCardReroll == true then
				
			else
				_UIToast:ShowMessageByLocalizingKey("Toast_TutoTargetButtonError")
				return
			end
		end
		
		
		if tmProperty.RuneReroll_FreeCounts_Temporary > 0
		or tmProperty.RuneReroll_FreeCounts_Permanents > 0
		or self.Entity.TeamManager.Golds >= tmProperty.RuneReroll_Cost then
			self:CheckReroll_Runes()
		else
			self.Entity:SendEvent(NotEnoughCoin())
			_UIToast:ShowMessageByLocalizingKey("LessCoin")
			return
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "DictionaryManager")
	handler HandleDictionaryFavoriteEvent(DictionaryFavoriteEvent event)
		-- Parameters
		local settedFaveChar = event.settedFaveChar
		local settedFaveItem = event.settedFaveItem
		local settedFaveRune = event.settedFaveRune
		---------------------------------------------------------
		
		if settedFaveItem == nil and settedFaveRune == nil then return end
		
		-- 아이템 상점에 즐겨찾기 마크를 추가합니다.
		for i=1, 2 do	
			local ui_product = self.UI_ItemShop:GetChildByName(string.format("Product_%d", i))
			local itemID = self.ShopList_Items[i]
			
			local ui_favorite = ui_product:GetChildByName("Sprite_FavoriteMark")
			
			if _DictionaryFavoriteListManager:IsSettedFave_Item(itemID) then
				ui_favorite.Enable = true
			else
				ui_favorite.Enable = false
			end
		end
		
		-- 룬 카드 상점 즐찾마크
		for i=1, 2 do	
			local ui_product = self.UI_RuneShop:GetChildByName(string.format("Product_%d", i))
			local runeID = self.ShopList_Runes[i]
			
			local ui_favorite = ui_product:GetChildByName("Sprite_FavoriteMark")
			
			if _DictionaryFavoriteListManager:IsSettedFave_Rune(runeID) then
				ui_favorite.Enable = true
			else
				ui_favorite.Enable = false
			end
		end
	end

end