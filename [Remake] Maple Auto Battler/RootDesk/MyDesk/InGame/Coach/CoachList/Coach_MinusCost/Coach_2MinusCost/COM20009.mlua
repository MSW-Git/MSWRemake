@Component
script COM20009 extends CoachComponent

	@ExecSpace("ServerOnly")
	method void StartGameHandler(any event)
		__base:StartGameHandler(event)
		-- 플레이어가 레벨 1로 게임을 시작하고, 1 스테이지동안 골드로 레벨업을 할 수 없습니다.
		-----------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local specialShopManager = user.SpecialShopManager
		local userPControl = user.TM_PropertyControl
		-----------------------------------------------------
		teamManager.Level = 1
		teamManager:AddEXP(0)
		userPControl.Coach_SetCheck["COM20009"] += 1
		
		self:PlayAbilityEffect("",user.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void StartStageHandler(any event)
		__base:StartStageHandler(event)
		-- 플레이어가 레벨 1로 게임을 시작하고, 1 스테이지동안 골드로 레벨업을 할 수 없습니다.
		-----------------------------------------------------
		local user = self.Entity.Parent.Parent
		local teamManager = user.TeamManager
		local gameManager = user.GameManager
		local userPControl = user.TM_PropertyControl
		-----------------------------------------------------
		if gameManager.Stage >= 2 then
			userPControl.Coach_SetCheck["COM20009"] -= 1
		end
	end

	@ExecSpace("Client")
	method void PlayAbilityEffect(string data)
		__base:PlayAbilityEffect(data)
		
		--------------------------------------------------------------
		local userEntity = _UserService.LocalPlayer
		local gameMap = userEntity.CurrentMap
		local coachArea = gameMap:GetChildByName("CoachArea")
		local coachInfo = _DataService:GetTable("CoachInfo")
		--------------------------------------------------------------
		local coachlist=userEntity.CoachManager.PlayCoachesID 
		
		for i=1,#coachlist do
			if coachlist[i] == "COM20009" then
				local coachEntity = coachArea:GetChildByName(string.format("Coach_%d", i))
				--발동연출
				coachEntity.CoachIngameComponent:PlayCoachAbilityEffect(coachlist[i])
				break
			end
		end
	end

end