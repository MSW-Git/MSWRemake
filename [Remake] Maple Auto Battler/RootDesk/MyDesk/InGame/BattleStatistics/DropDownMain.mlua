@Component
script DropDownMain extends Component

	property Entity DropDownBox = "dad45ee3-4969-49dc-96ba-327d47fa9735"

	property table CurrentRound = {["Stage"]=0, ["Round"]=0, ["Round2"]=0}

	@ExecSpace("ClientOnly")
	method void Initialize(integer currentStage, integer currentRound, integer currentRound2)
		-- 현재 stage round 정보에 따라 라운드 선택 슬롯을 활성화 (이전의 모든 스테이지-라운드)
		------------------------------------------------------------------------------------------
		self.CurrentRound["Stage"] = currentStage
		self.CurrentRound["Round"] = currentRound
		self.CurrentRound["Round2"] = currentRound2
		------------------------------------------------------------------------------------------
		local currentRoundIdx = 3*(currentStage-1) + currentRound
		if currentStage == 8 and currentRound == 3 then 
			currentRoundIdx += (currentRound2 - 1)
		end
		
		-- 재도전 라운드가 있는 경우, 탭 추가
		if currentStage == 8 and currentRound == 3 and currentRound2 > 1 then
			local ui_tab = self.DropDownBox:GetChildByName(string.format("Tab_%d", currentRoundIdx))
			if isvalid(ui_tab) == false then
				local ui_originTab = self.DropDownBox:GetChildByName("Tab")
				ui_tab = ui_originTab:Clone(string.format("Tab_%d", currentRoundIdx))
			end
			 
			ui_tab.TextComponent.Text = string.format("%d-%d(%d)", currentStage, currentRound, currentRound2)
			
			local tabPosX = 60
			if currentRound2%2 == 1 then
				tabPosX = 150
			end
			ui_tab.UITransformComponent.anchoredPosition = Vector2(tabPosX, -289 - 34 * math.floor(currentRound2/2))
			
			-- 재도전 라운드 목록을 표시하는 UI 활성화
			local ui_retryTitle = self.DropDownBox:GetChildByName("Text_Retry")
			ui_retryTitle.Enable = true
			
			-- 박스 길이 수정
			local ui_closeBtn = self.DropDownBox:GetChildByName("Button_Close")
			ui_closeBtn.UITransformComponent.anchoredPosition.y = ui_tab.UITransformComponent.anchoredPosition.y - 34
			self.DropDownBox.UITransformComponent.RectSize.y = math.abs(ui_closeBtn.UITransformComponent.anchoredPosition.y - 17)
			
			self.DropDownBox.TabComponent:SetChildren()
		end
		------------------------------------------------------------------------------------------
		-- 현재 라운드까지는 탭 활성화
		for i=1, currentRoundIdx do
			local ui_tab = self.DropDownBox:GetChildByName(string.format("Tab_%d", i))
		
			ui_tab.SpriteGUIRendererComponent.Color = Color.FromHexCode("#111b2d")
			ui_tab.TextComponent.FontColor = Color.white
			
			if i == currentRoundIdx then
				ui_tab.SpriteGUIRendererComponent.Color = Color.FromHexCode("#4b6dc4")
				ui_tab.TextComponent.FontColor = Color.FromHexCode("#131d30")
			end
		end
		
		-- 이후 라운드는 탭 비활성화
		for i=currentRoundIdx+1, 50 do
			local ui_tab = self.DropDownBox:GetChildByName(string.format("Tab_%d", i))
			if isvalid(ui_tab) == false then
				break
			end
			
			ui_tab.SpriteGUIRendererComponent.Color = Color.FromHexCode("#111b2d")
			ui_tab.TextComponent.FontColor = Color.FromHexCode("#314574")
		end
		------------------------------------------------------------------------------------------
		-- 현재 라운드로 기본 표시 텍스트 변경
		if currentStage == 8 and currentRound == 3 and currentRound2 > 1 then
			self.Entity.TextComponent.Text = string.format("%d-%d(%d)", currentStage, currentRound, currentRound2)
		else
			self.Entity.TextComponent.Text = string.format("%d-%d", currentStage, currentRound)
		end
	end

	@ExecSpace("ClientOnly")
	method void Close()
		---- 창을 닫을 시 슬롯을 제거한다
		--for i = 1, #self.StageRoundSlotList do
		--    _EntityService:Destroy(self.StageRoundSlotList[i])
		--end
		--self.StageRoundSlotList = {}
	end

	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 드랍다운 버튼을 누르면 박스 목록을 열거나 닫습니다.
		self.DropDownBox:SetEnable(not self.DropDownBox.Enable)
	end

	@EventSender("Entity", "dad45ee3-4969-49dc-96ba-327d47fa9735")
	handler HandleTabChangedEvent(TabChangedEvent event)
		-- 드롭다운에서 특정 라운드 탭을 선택했을 때 해당 라운드의 전투 통계로 전환
		-- Parameters
		local ChangedIdx = event.ChangedIdx
		---------------------------------------------------------
		-- 드랍다운 슬롯을 클릭했을 경우의 처리.
		---- 현재 스탯 탭은 유지하고 선택한 스테이지라운드의 데이터를 로딩 후 새로고침
		--------------------------------------------------------------------------------
		local currentRoundIndex = 3*(self.CurrentRound["Stage"]-1) + self.CurrentRound["Round"] + self.CurrentRound["Round2"]
		if ChangedIdx > currentRoundIndex then
			return
		end
		--------------------------------------------------------------------------------
		local stage = 0
		local round = 0
		local round_2nd = 0 
		
		-- 드랍다운 버튼의 라운드 표시를 변경합니다.
		if ChangedIdx < 25 then
			stage = math.floor((ChangedIdx-1) / 3 + 1)
			round = ChangedIdx % 3 
			if round == 0 then 
				round = 3 
			end
			
			self.Entity.TextComponent.Text = string.format("%d-%d", stage, round)
			
			if stage == 8 and round == 3 then
				round_2nd = 1
			end
		else
			stage = 8
			round = 3
			round_2nd = ChangedIdx-23
			
			self.Entity.TextComponent.Text = string.format("%d-%d(%d)", stage, round, round_2nd)
		end
		
		-- 박스 목록을 새로고침합니다
		for i=1, 50 do
			local ui_tab = self.DropDownBox:GetChildByName(string.format("Tab_%d", i))
			if isvalid(ui_tab) == false then
				break
			end
			
			if i <= currentRoundIndex then
				if i == ChangedIdx then
					ui_tab.SpriteGUIRendererComponent.Color = Color.FromHexCode("#4b6dc4")
					ui_tab.TextComponent.FontColor = Color.FromHexCode("#131d30")
				else
					ui_tab.SpriteGUIRendererComponent.Color = Color.FromHexCode("#111b2d")
					ui_tab.TextComponent.FontColor = Color.white
				end
			else
				ui_tab.SpriteGUIRendererComponent.Color = Color.FromHexCode("#111b2d")
				ui_tab.TextComponent.FontColor = Color.FromHexCode("#314574")
			end
		end
		
		_UI_BattleStatistics:RefreshUI_RoundInfo(stage, round, round_2nd)
		_UI_BattleStatistics:ChangeTab_1stCategory(1)
		
		--드랍다운을 닫기
		self.DropDownBox.Enable = false
	end

end