@Component
script StatCoachHoverInfo extends Component

	property string CurrentCoachID = ""

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스가 코치 아이콘 위에 올라갔을 때 코치 정보 툴팁을 표시
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		-- local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		
		if self.CurrentCoachID ~= "" then
			_UI_UnitInfoPopup:UI_ShowCoachInfoTooltip(self.CurrentCoachID)
			_UI_Tooltip:SetMouseHoveredUI(self.Entity)
		end
		
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스가 코치 아이콘에서 벗어났을 때 코치 정보 툴팁을 숨김
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		-- local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		
		if self.CurrentCoachID ~= "" then
			_UI_UnitInfoPopup:UI_ShowCoachInfoTooltip(self.CurrentCoachID)
			_UI_Tooltip:SetMouseHoveredUI(nil)
			_EntityService:GetEntityByPath("/ui/UnitInfoPopupGroup/Tooltip_CoachInfo"):SetEnable(false)
		end
	end

end