@Component
script UI_BattleStatistics_UnitTooltipActivator extends Component

	property string UnitID = ""

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스가 유닛 초상화 위에 올라갔을 때 유닛 정보 툴팁을 표시
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		-- local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		
		if self.UnitID ~= "" then
			_UI_Tooltip:SetCharShopInfo(true, self.UnitID, 1, false, "BattleStat")
			_UI_Tooltip:SetMouseHoveredUI(self.Entity)
		end
		
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스가 유닛 초상화에서 벗어났을 때 유닛 정보 툴팁을 숨김
		--------------- Native Event Sender Info ----------------
		-- Sender: UITouchReceiveComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		-- local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		if self.UnitID ~= "" then
			_UI_Tooltip:SetCharShopInfo(false, self.UnitID, 1, false, "")
			_UI_Tooltip:SetMouseHoveredUI(nil)
		end
		
	end

end