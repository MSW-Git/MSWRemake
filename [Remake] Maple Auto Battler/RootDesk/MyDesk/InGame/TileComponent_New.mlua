@Component
script TileComponent_New extends Component

	property string Zone = "Neutral"

	property string type = "Unit"

	@Sync
	property number horizontalNum = 0

	@Sync
	property number verticalNum = 0

	@ExecSpace("Multicast")
	method void TileSet(string zone, string tileType, number horizontalNum, number verticalNum)
		-- 새로운 타일 시스템에서 타일의 영역과 타입, 좌표를 설정
		self.Zone = zone
		self.type = tileType
		self.horizontalNum = horizontalNum
		self.verticalNum = verticalNum
	end

end