@Component
script UI_AutoScroll extends Component

	@HideFromInspector
	property number time = 0

	@HideFromInspector
	property number TotalMoveTime = 0

	@HideFromInspector
	@Description("vertical = , horizontal = 2")
	property boolean IsVerticalType = true

	@Description("초당 px 변동값")
	@MinValue(0)
	property number Speed = 100

	@Description("움직임을 시작하기 전후로 대기하는 시간입니다.")
	@MinValue(0)
	property number WaitTime = 0

	@Description("스크롤 내용이 변경되었는지 여부를 검사하여 속도를 재조정하는 주기입니다. 주기가 빠를 수록 최적화에 영향을 미칩니다.")
	property number ScrollSpeedControlPeriod = 1

	@HideFromInspector
	property number ScrollSpeedControlCheckTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 자동 스크롤 컴포넌트 초기화 및 스크롤 타입 설정
		self.ScrollSpeedControlCheckTime = self.ScrollSpeedControlPeriod
		
		if self.Entity.ScrollLayoutGroupComponent.Type == LayoutGroupType.Horizontal then
			self.IsVerticalType = false
		end	
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 자동 스크롤 위치를 업데이트
		if self.Entity.Enable == false then
			self.time = 0
			return
		end
		----------------------------------------------------------------------
		self.time += delta
		self.ScrollSpeedControlCheckTime += delta
		----------------------------------------------------------------------
		if self.IsVerticalType == true then
			if self.time < self.WaitTime then
				self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Vertical, 0)
			elseif self.time < (self.WaitTime + self.TotalMoveTime) then
				self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Vertical, (self.time - self.WaitTime) / (self.TotalMoveTime - self.WaitTime))
			elseif self.time < (self.TotalMoveTime + 2*self.WaitTime) then
				self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Vertical, 1)
			else
				self.time = 0
			end
		----------------------------------------------------------------------	
		else
			if self.time < self.WaitTime then
				self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Horizontal, 0)
			elseif self.time < self.TotalMoveTime then
				self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Horizontal, (self.time - self.WaitTime) / (self.TotalMoveTime - self.WaitTime))
			elseif self.time < (self.TotalMoveTime + self.WaitTime) then
				self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Horizontal, 1)
			else
				self.time = 0
			end
			
		end
		----------------------------------------------------------------------
		if self.ScrollSpeedControlCheckTime >= self.ScrollSpeedControlPeriod then
			self.ScrollSpeedControlCheckTime = 0
			local totalLength = 0
			if self.IsVerticalType == true then
				local scrollLayoutCompo = self.Entity.ScrollLayoutGroupComponent
				totalLength = scrollLayoutCompo.Padding.top + scrollLayoutCompo.Padding.bottom
				
				local spacing = scrollLayoutCompo.Spacing
				for i=1, #self.Entity.Children do
					if self.Entity.Children[i].Enable then
						totalLength += (self.Entity.Children[i].UITransformComponent.RectSize.y + spacing)
					end
				end
				totalLength -= spacing
			else
				local scrollLayoutCompo = self.Entity.ScrollLayoutGroupComponent
				totalLength = scrollLayoutCompo.Padding.left + scrollLayoutCompo.Padding.right
				
				local spacing = scrollLayoutCompo.Spacing
				for i=1, #self.Entity.Children do
					if self.Entity.Children[i].Enable then
						totalLength += (self.Entity.Children[i].UITransformComponent.RectSize.x + spacing)
					end
				end
				totalLength -= spacing
			end
			
			self.TotalMoveTime = totalLength / self.Speed
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void InitScroll()
		-- 스크롤 위치를 초기화
		if self.IsVerticalType == true then
			self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Vertical, 0)
			self.time = 0
		-------------------------------------------------------------	
		else
			self.Entity.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Horizontal, 0)
			self.time = 0
		end
	end

end