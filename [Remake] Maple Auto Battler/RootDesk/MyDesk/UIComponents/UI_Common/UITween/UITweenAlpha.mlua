@Component
script UITweenAlpha extends Component

	property number from = 0

	property number to = 0

	property boolean loop = true

	property boolean pingpong = false

	property boolean autoPlay = true

	property number duration = 1

	property string tweenType = "Linear"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 알파 트윈 컴포넌트 초기화 및 자동 재생 설정
		self._T.isPlay = false
		self._T.time = 0
		if self.autoPlay then
			self:Play()
		else
			self.Enable = false
		end
		self._T.tweenType = EaseType.SineEaseIn
		for k,v in pairs(EaseType) do
			if k == self.tweenType then
				self._T.tweenType = k
				break
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 알파 트윈 애니메이션 업데이트
		self._T.time = self._T.time + delta
		
		local time = self._T.time 
		if self.loop then
			if self.pingpong then
				time = self:PoingPonng(time,self.duration)
			else
				time = self:Repeat(time,self.duration)
			end
		else
			if time > self.duration then
				time = self.duration
				self:Stop()
			end
		end
		local tweenValue = _TweenLogic:Ease(0,1,self.duration,self._T.tweenType,time)
		self.Entity.SpriteGUIRendererComponent.Color.a = self.to * tweenValue + self.from * (1 - tweenValue)	
		if isvalid(self.Entity.TextComponent) then
			self.Entity.TextComponent.FontColor.a=self.to * tweenValue + self.from * (1 - tweenValue)
		end
	end

	method void Play()
		-- 알파 트윈 애니메이션 재생 시작
		self._T.isPlay = true
		self._T.originPos = self.Entity.UITransformComponent.anchoredPosition
		self.Enable = true
		self._T.time = 0
	end

	method number PoingPonng(number t, number length)
		-- 핑폁 모드로 시간 값 계산 (앞뒤로 왕복)
		t = self:Repeat(t, length * 2)
		return length - math.abs(t - length)
	end

	method number Repeat(number t, number length)
		-- 루프 모드로 시간 값 반복 계산
		return t - (math.floor(t / length) * length)
	end

	method void Stop()
		-- 알파 트윈 애니메이션 정지
		self._T.isPlay = false
		self.Enable = false
	end

end