@Component
script UI_ExitButton extends Component

	@Description("이 컴포넌트가 붙은 UI엔티티(버튼)을 누르면, TargetUI.Enable을 끕니다.")
	property Entity TargetUI = nil

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 지정된 대상 UI를 비활성화
		
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		if self.TargetUI ~= nil then
			self.TargetUI.Enable = false
		end
	end

end