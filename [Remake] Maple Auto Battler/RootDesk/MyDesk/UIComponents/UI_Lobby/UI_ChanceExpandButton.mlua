@Component
script UI_ChanceExpandButton extends Component

	@ExecSpace("Client")
	method void SetButtonShape()
		-- 화살표 UI 변경
		local expandUI = self.Entity:GetChildByName("Icon_Expand")
		local closeUI = self.Entity:GetChildByName("Icon_Close")
		
		--현재 슬롯 인덱스
		local index = _UtilLogic:SubString(self.Entity.Name, string.len(self.Entity.Name), 1)
		if expandUI.Enable then
			expandUI.Enable = false
			closeUI.Enable = true
			self.Entity.Parent.UI_ChanceTable:ShowSmallSlots(false, tonumber(index))
		else
			expandUI.Enable = true
			closeUI.Enable = false
			self.Entity.Parent.UI_ChanceTable:ShowSmallSlots(true, tonumber(index))
		end 
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 확률 테이블 확장/축소 버튼 클릭 처리
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:SetButtonShape()
	end

end