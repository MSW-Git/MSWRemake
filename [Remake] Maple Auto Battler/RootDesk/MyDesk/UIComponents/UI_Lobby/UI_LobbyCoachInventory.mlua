	@ExecSpace("Client")
	method void RefreshFollowingCoach()
		-- 동행 코치 패널 내용을 갱신합니다.
		------------------------------------------------------------------------
		-- 현재 선택된 코치의 UI를 갱신합니다.
		local ui_currentFollowingCoach = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/Following_Coach")
		
		local coach_icon = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/Following_Coach/Sprite_CoachBG/Sprite_Coach")
		local coach_name = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/Following_Coach/FollowingCoach_Name")
			
		-- 현재 동행중인 코치가 있음
		if _UtilLogic:IsNilorEmptyString(self.CurrentFollowingCoachID) == false then
			local coachData = _CoachService:GetCoachInfo(self.CurrentFollowingCoachID)
			local profileRUID = coachData.ProfileRUID
			coach_icon.SpriteGUIRendererComponent.ImageRUID = profileRUID
			coach_icon.SpriteGUIRendererComponent.LocalPosition = _LoadResourcesInfo:GetUILocalPositionScale(profileRUID)["pos"]
			coach_icon.SpriteGUIRendererComponent.LocalScale = _LoadResourcesInfo:GetUILocalPositionScale(profileRUID)["scale"]
			coach_icon.SpriteGUIRendererComponent.Color.a = 1
			coach_icon.SpriteGUIRendererComponent.MaterialId = ""
			coach_name.TextComponent.Text = coachData.Name
		-- 현재 동행중인 코치가 없는 경우
		-- 기본값으로 갈색고양이 스프라이트에 마테리얼을 입힌 이미지로 교체합니다.
		else
			local profileRUID = "f8756e7774ae4d2bb0ed2c65ec81d706"
			coach_icon.SpriteGUIRendererComponent.ImageRUID = profileRUID
			coach_icon.SpriteGUIRendererComponent.LocalPosition = _LoadResourcesInfo:GetUILocalPositionScale(profileRUID)["pos"]
			coach_icon.SpriteGUIRendererComponent.LocalScale = _LoadResourcesInfo:GetUILocalPositionScale(profileRUID)["scale"] 
			coach_icon.SpriteGUIRendererComponent.Color.a = 1
			coach_icon.SpriteGUIRendererComponent.MaterialId = "material://e70dfe07-01ad-4ddc-bc12-f0858c772837"
			coach_name.TextComponent.Text = _LocalizationService:GetText("Coach_None")
		end
		
		if _UserService.LocalPlayer.CoachManager:GetHasType(self.CurrentFollowingCoachID) == 2 then 
			self:EnableMasterCoachEffect(true)
		else
			self:EnableMasterCoachEffect(false)	
		end
	end

	@ExecSpace("Client")
	method void RefreshCoachList()
		-- 코치 보관함의 코치 리스트를 갱신합니다.
		---------------------------------------------------
		local ui_coachList = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/List_Coach")
		
		local coachManager = _UserService.LocalPlayer.CoachManager
		
		local isSelectedCoach = function(coachID)
		    if self.CurrentFollowingCoachID == coachID then
				return true
			else
				return false
		    end
		end
		
		
		local coachColor = _UI_Color.CoachCost[self.ShowingCoachCost]
		--------------------------------------------------
		local coachList = {} -- 정보를 가져올 코치 리스트
		local coachIdx = math.abs(self.ShowingCoachCost) * 10000
		
		local targetID = ""
		while true do
			coachIdx += 1
			
			if self.ShowingCoachCost < 0 then
				targetID = "COM"..coachIdx
			else
				targetID = "COP"..coachIdx
			end
			
			local coachInfo = _CoachService:GetCoachInfo(targetID)
			if isvalid(coachInfo) == true then
				table.insert(coachList, coachInfo)
			else
				break
			end
		end
		
		-- 정렬 ON 인 경우, 미보유한 코치들을 맨 뒤로 보냅니다.
		if self.SortByPossession == true then
			local noHaveCoaches = {}
			
			for i=#coachList, 1, -1 do
				---@type CoachInfo
				local coachInfo = coachList[i]
				local coachID = coachInfo.CoachID
				
				if _UserService.LocalPlayer.CoachManager.PlayerOwnedCoachesID[coachID] ~= 1 then
					table.remove(coachList, i)
					table.insert(noHaveCoaches, 1, coachInfo)
				end
			end
			
			for i=1, #noHaveCoaches do
				table.insert(coachList, noHaveCoaches[i])
			end
		end
		--------------------------------------------------
		-- UI를 갱신합니다.
		local originSlot = ui_coachList:GetChildByName("Slot")
		for i=1, #coachList do
			local ui_slot = ui_coachList:GetChildByName(string.format("Slot_%d", i))
			if isvalid(ui_slot) == false then
				ui_slot = originSlot:Clone(string.format("Slot_%d", i))
			end
			ui_slot.Enable = true
			--------------------------------------------------------------
			local ui_icon = ui_slot:GetChildByName("Icon")
			local ui_name = ui_slot:GetChildByName("Name")
			local ui_selectedBtn = ui_slot:GetChildByName("IsSelected")
		    
			---@type CoachInfo
			local coachData = coachList[i]
			local coachID = coachData.CoachID
			
			local profileRUID = coachData.ProfileRUID
		        
		        
			ui_icon.SpriteGUIRendererComponent.ImageRUID = profileRUID
			ui_icon.SpriteGUIRendererComponent.LocalPosition = _LoadResourcesInfo:GetUILocalPositionScale(profileRUID)["pos"]
			ui_icon.SpriteGUIRendererComponent.LocalScale = _LoadResourcesInfo:GetUILocalPositionScale(profileRUID)["scale"]
			ui_name.TextComponent.Text = coachData.Name
			ui_selectedBtn.Enable = isSelectedCoach(coachID)		
		        
			if _UserService.LocalPlayer.CoachManager.PlayerOwnedCoachesID[coachID] == 1 then
				ui_icon.SpriteGUIRendererComponent.Color = Color.white
			else
				ui_icon.SpriteGUIRendererComponent.Color = Color.black
			end
			
			ui_slot.UI_CoachInventory_CoachSlot.CoachID = coachID
		end
		--------------------------------------------------------------
		-- 잉여 슬롯을 끕니다.
		local surplusSlotIdx = #coachList + 1
		while true do
			local slot = ui_coachList:GetChildByName(string.format("Slot_%d", surplusSlotIdx))
			if isvalid(slot) == true then
				slot.Enable = false
				surplusSlotIdx += 1
			else
				break
			end
		end
	end

	@ExecSpace("Client")
	method void RefreshCurrencyList()
		-- 화폐 정보 UI를 갱신합니다.
		local ui_currencyList = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/List_Currency")
		
		local playerData = _UserService.LocalPlayer.PlayerDataComponent
		local amounts = {
			playerData.Syrup,
			playerData.RoyalSyrup,
			playerData.Repechage + playerData.Repechage_Free
		}
		
		for i=1, 3 do
			local ui_currency = ui_currencyList:GetChildByName(string.format("Currency_%d", i))
			ui_currency:GetChildByName("Amount").TextComponent.Text = amounts[i]
		end
	end

	@ExecSpace("Server")
	method void ChangeFollowingCoach_Check(string selectedFollowingCoachID)
		-- 선택한 동행 코치를 서버에 보내고, 검증합니다.
		
		local targetUser = _UserService:GetUserEntityByUserId(senderUserId)
		local coachManager = targetUser.CoachManager
		
		-------------------------------------------------------------------
		local isEnterConditions = true
		local totalCost = 0
			-- 선택한 코치 보유 여부 검증
			if _UtilLogic:IsNilorEmptyString(selectedFollowingCoachID) == false then
				if coachManager.PlayerOwnedCoachesID[selectedFollowingCoachID] ~= 1 then
					isEnterConditions = false
				end
		end
		
		-------------------------------------------------------------------
		if isEnterConditions == false then
			return
		end
		
		-- 코치 변경사항이 없는 경우 
		if selectedFollowingCoachID == coachManager.FollowingCoachID then
			if not isvalid(selectedFollowingCoachID) then
				return
			end
			
			--[[
			-- 마스터 코치 이펙트 변경사항 적용 시
			local myCoach = _EntityService:GetEntityByPath("/maps/Lobby/coach"..senderUserId)
			local effect = myCoach:GetChildByName("Effect")
			if coachManager.MasterCoachEffect ~= effect.Enable then
				
				effect:SetEnable(coachManager.MasterCoachEffect)
			end
			
			]]--
			return
		
		end
		
		-------------------------------------------------------------------
		coachManager.FollowingCoachID = selectedFollowingCoachID
		--log("change coach@",coachManager.FollowingCoachID,targetUser.OwnerId)
		_PlayerDataLogic:SetPlayerFollowingCoachIDData(senderUserId)
		self:ChangeCoachList_OnClient(senderUserId,senderUserId)
		self:ChangeFollowingCoach_Client(senderUserId,selectedFollowingCoachID)
		_CoachService:UpdateCoach(targetUser)
	end

	@ExecSpace("Client")
	method void ChangeFollowingCoach_Client(string userId, string coachID)
		-- 코치 변경 완료 후 클라이언트 처리
		local targetUser = _UserService:GetUserEntityByUserId(userId)
		if not isvalid(targetUser) then 
			return
		end
		local coachManager = targetUser.CoachManager
		
		coachManager.FollowingCoachID = coachID
	end

	@ExecSpace("Client")
	method void ChangeCoachList_OnClient(string userId)
		-- 코치 변경 완료 후 토스트 메시지 표시
		if self.FollowingCoach_BeforeChange ~= self.CurrentFollowingCoachID and _UtilLogic:IsNilorEmptyString(self.CurrentFollowingCoachID) then
			_UIToast:ShowMessageByLocalizingKey("ReturnCoach")
		elseif self.FollowingCoach_BeforeChange == self.CurrentFollowingCoachID and _UtilLogic:IsNilorEmptyString(self.CurrentFollowingCoachID) then
			
		else
			_UIToast:ShowMessageByLocalizingKey("ChangeFriendCoach")
		end
		
	end

	@ExecSpace("Client")
	method void SetCoachUnfollow()
		-- 동행중인 코치를 동행 해제시키는 함수입니다.
		-------------------------------------------------
		if self.CurrentFollowingCoachID ~= "" then
			self.CurrentFollowingCoachID = ""
			-- UI 새로고침 요청
			self:RefreshFollowingCoach()
			self:RefreshCoachList()
		else
			_UIToast:ShowMessageByLocalizingKey("EmptyCoachSlot")
		end
	end

	@ExecSpace("Client")
	method void SetCoachFollow(string coachID)
		-- 코치 보관함에서 특정 코치를 선택했을 때 실행
		-------------------------------------------------
		-- 예외처리1. 미보유
		local coachManager = _UserService.LocalPlayer.CoachManager
		if coachManager.PlayerOwnedCoachesID[coachID] ~= 1 then
			_UIToast:ShowMessageByLocalizingKey("NotOwnedCoach")
			return
		end
		
		-- 예외처리2. 이미 선택한 코치를 다시 선택 -> 선택 해제
		if self.CurrentFollowingCoachID == coachID then
			log("코치 해제")
			self:SetCoachUnfollow()
			return
		end
		-------------------------------------------------
		self.CurrentFollowingCoachID = coachID
		
		-- UI 새로고침 요청
		self:RefreshFollowingCoach()
		self:RefreshCoachList()
	end

	@ExecSpace("Client")
	method void OnClick_MasterCoachEffect(boolean masterCoachEffectOn)
		-- 마스터 코치의 이펙트를 On/Off할 수 있는 함수입니다.
		--[[local coachManager = _UserService.LocalPlayer.CoachManager
		local effectButton = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/Button_MasterCoachOnOff")
		
		if not masterCoachEffectOn  then
			self.MasterCoachEffectOn = true 
			effectButton.SpriteGUIRendererComponent.Color = Color.FromHexCode("#FFFFFF")
			coachManager:setCoachMasterEffect(true)
		elseif masterCoachEffectOn then 
			self.MasterCoachEffectOn = false 
			effectButton.SpriteGUIRendererComponent.Color = Color.FromHexCode("#777777")
			coachManager:setCoachMasterEffect(false)
		end]]--
	end

	@ExecSpace("ClientOnly")
	method void EnableMasterCoachEffect(boolean enable)
		-- 마스터 코치 이팩트 버튼 활성화/비활성화
		--[[local coachManager = _UserService.LocalPlayer.CoachManager
		local masterCoachEffectButton =  _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/Button_MasterCoachOnOff")
		
		if enable then 
			masterCoachEffectButton:SetEnable(true)
			masterCoachEffectButton.SpriteGUIRendererComponent.Color = Color.FromHexCode("#FFFFFF")
		--	coachManager:setCoachMasterEffect(true)
			
		else
			
			masterCoachEffectButton:SetEnable(false)
		--	coachManager:setCoachMasterEffect(false)
			
		end]]--
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "3e7ce914-c634-4a56-812d-33c800737e59")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 코치 보관함 열기 버튼 클릭 시 리스트 갱신
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		-- 코치 보관함을 활성화할 때, 리스트를 갱신합니다.
		---------------------------------------------------------
		local ui_coachList = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory/Panel_CoachInventory/List_Coach")
		
		if not _UtilLogic:IsNilorEmptyString(self.CurrentFollowingCoachID) then
			self.FollowingCoach_BeforeChange = self.CurrentFollowingCoachID
		else
			self.FollowingCoach_BeforeChange = nil
		end
		
		
		local ui_coachInventory = _EntityService:GetEntityByPath("/ui/Lobby_CoachInventory")
		ui_coachInventory.Enable = true
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "22fd2afe-2d08-47ff-864e-480fabdce528")
	handler HandleTabChangedEvent(TabChangedEvent event)
		-- 코치 보관함 UI에서 등급 필터를 바꿨을 때 실행합니다.
		--------------------------------------------------------------------
		local cost = {
			[1] = -3,
			[2] = -2,
			[3] = -1,
			[4] = 1,
			[5] = 2,
			[6] = 3,
			[7] = 4,
			[8] = 5,
			[9] = 7,
		}
		
		local idx = event.ChangedIdx
		if self.ShowingCoachCost ~= cost[idx] then
			self.ShowingCoachCost = cost[idx]
			self:RefreshCoachList()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "dfb9b07e-6630-4927-bdc1-1944862c2b6d")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 코치 변경 완료 버튼 클릭 시 서버로 변경사항 전송
		--[[if _UtilLogic:IsNilorEmptyString(self.CurrentFollowingCoachID) then 
			return 
		end
		self:ChangeFollowingCoach_Check(self.CurrentFollowingCoachID)]]
		
		if self.FollowingCoach_BeforeChange ~= self.CurrentFollowingCoachID then
			self:ChangeFollowingCoach_Check(self.CurrentFollowingCoachID)
			self.FollowingCoach_BeforeChange = self.CurrentFollowingCoachID
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5ba809ef-47be-4355-b542-9657f4d10fa0")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 보유 코치 정렬 버튼 클릭 시 정렬 옵션 토글
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		-- 정렬 ON --> OFF
		if self.SortByPossession == true then
			self.SortByPossession = false
			self:RefreshCoachList()
			
			Entity:GetChildByName("IsChecked").Enable = false
			
			
		-- 정렬 OFF --> ON
		else
			self.SortByPossession = true
			self:RefreshCoachList()
			
			Entity:GetChildByName("IsChecked").Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "3e7ce914-c634-4a56-812d-33c800737e59")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 코치 보관함 열기 시 코치 리스트 새로고침
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		self:RefreshCoachList()
	end

end