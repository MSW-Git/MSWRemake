@Logic
script UI_LobbyCoachInventory extends Logic

	property integer ShowingCoachCost = -3

	property table CurrentShowingCoachIDList = {}

	property string CurrentFollowingCoachID = ""

	@Description([[코치 보관함을 열었을 때, 동행 중이던 코치의 ID입니다. 
코치 보관함을 닫을 때 동행 중인 코치와 비교하여, 코치 변경 여부를 알아냅니다.]])
	property string FollowingCoach_BeforeChange = ""

	property boolean MasterCoachEffectOn = true

	property boolean SortByPossession = true

