@Component
script UI_CombineTable_ItemTooltipActivator extends Component

	property string ItemID = ""

	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 조합 테이블에서 아이템 호버 시 아이템 정보 툴팁 표시
		-- Parameters
		local state = event.state
		---------------------------------------------------------
		if state == ButtonState.Hover then
			_UI_Tooltip:SetItemInfo(true, self.ItemID, "combineTable")
			
		else
			_UI_Tooltip:SetItemInfo(false, self.ItemID, "combineTable")
			
		end
	end

end