@Component
script UI_PlayerTitleButton extends Component

	property Entity TitleElementListUI = "6d058c71-d236-4e56-84eb-1bf6e02f5c8e"

	property string TitleElement = ""

	property string ButtonKey = ""

	property Entity NameTagButton = "20842d23-9466-449f-a763-3e18fdad63f2"

	property Entity KeyWordFrontButton = "5c183c0f-33e7-49be-9c51-7954bdc4f733"

	property Entity KeyWordBackButton = "f815abf3-1c72-4656-b54f-f959336115d3"

	property string ElementID = ""

	property Entity PreviousArrowButton = "61327e70-95d6-4972-8014-4e8670ec3772"

	property Entity NextArrowButton = "9c815e6a-9e7c-4881-a3f5-f0bf4a2f3b70"

	@ExecSpace("ClientOnly")
	method void callTitleElementList()
		--현재 버튼에 맞는 칭호 요소를 리스트에 불러옵니다.
		-------------------------------------------------
		local nametagTable = _DataService:GetTable("Title_NameTagDataset")
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		local listNumber = _EntityService:GetEntityByPath("/ui/Lobby_TitleSetting/TitleSettingUI/TitleElementListUI/ListNumberText")
		local targetTable
		local targetID
		local titleManager = _UserService.LocalPlayer.TitleManager
		local targetTitleData
		
		_UserService.LocalPlayer.TitleManager.currentSelectedElements = self.ButtonKey
		self:ButtonChangeColor(true)
		
		if _UI_PlayerTitleSetting.currentIndex <= 0 then
			self.PreviousArrowButton.Enable = false
		else
			self.PreviousArrowButton.Enable = true
		end
		
		if self.TitleElementListUI.Enable == false then
			self.TitleElementListUI.Enable = true
		end
		
		--현재 보유중인 항목만 보기 체크 시
		if  _UI_PlayerTitleSetting.ShowOwnedTitlesOnly then
		local targetTable2
			for i=1,8 do
				local titleElement = self.TitleElementListUI:GetChildByName("TitleElement"..i)
				titleElement.UI_PlayerTitleButton.TitleElement = self.ButtonKey
				self.PreviousArrowButton.UI_PlayerTitleButton.TitleElement = self.ButtonKey
				self.NextArrowButton.UI_PlayerTitleButton.TitleElement = self.ButtonKey
				
				local elementText = titleElement:GetChildByName("ElementText")
				
				if self.ButtonKey == "KeyWordFront" then
					targetTable = _UI_PlayerTitleSetting.KWFTable_owned
					targetID = "KeyWordID"
					targetTitleData = titleManager.KeyWordFrontTable
					targetTable2 = keywordFrontTable
				elseif self.ButtonKey == "KeyWordBack" then
					targetTable = _UI_PlayerTitleSetting.KWBTable_owned
					targetID = "KeyWordID"
					targetTitleData = titleManager.KeyWordBackTable
					targetTable2 = keywordBackTable
				elseif self.ButtonKey == "NameTag" then
					targetTable = _UI_PlayerTitleSetting.NTTable_owned
					targetID = "NameTagID"
					targetTitleData = titleManager.NameTagTable
					targetTable2 = nametagTable
				end
				
				
				--현재 선택된 데이터셋 한계를 초과할 경우
				if (#targetTable < _UI_PlayerTitleSetting.currentIndex+i) then
					titleElement.Enable = false
					i = i + 1
				    --더이상의 데이터가 없으므로 공란으로 등록됩니다.
					self.NextArrowButton.Enable = false
					continue
				end
			
				titleElement.UI_PlayerTitleButton.ElementID = targetTable[ _UI_PlayerTitleSetting.currentIndex+i]
			
				--보유 여부에 따라 잠금 활성화
			
				if targetTitleData[titleElement.UI_PlayerTitleButton.ElementID] == true then
					titleElement:GetChildByName("LockedCover").Enable = false
					titleElement.ButtonComponent.Enable = true
				elseif targetTitleData[titleElement.UI_PlayerTitleButton.ElementID] == false then
					titleElement:GetChildByName("LockedCover").Enable = true
					titleElement.ButtonComponent.Enable = false
				end
				
				--레드닷 여부에 따라 기능 활성화
				if isvalid(titleManager.redDotTable[titleElement.UI_PlayerTitleButton.ElementID]) then
					titleElement:GetChildByName("RedDot").Enable = true
				else
					titleElement:GetChildByName("RedDot").Enable = false
				end
				----------------------------
				elementText.TextComponent.Text = _LocalizationService:GetText(targetTable2:FindRow(targetID,titleElement.UI_PlayerTitleButton.ElementID):GetItem("Name"))
				if self.ButtonKey == "NameTag" then
					local NTRank = nametagTable:FindRow(targetID,titleElement.UI_PlayerTitleButton.ElementID):GetItem("Rank")
					elementText.TextComponent.FontColor = self:SetNameTagFontColor(NTRank)
				else
					elementText.TextComponent.FontColor = Color.FromHexCode("#FFFFFF")
				end
		
				titleElement.Enable = true
				elementText.Enable = true
				
				if self.Entity:GetChildByName(self.ButtonKey).TextComponent.Text == elementText.TextComponent.Text then
					titleElement:GetChildByName("Selected").Enable = true
				else
					titleElement:GetChildByName("Selected").Enable = false
				end
				self.NextArrowButton.Enable = true
			end
			listNumber.TextComponent.Text = tostring(math.floor(_UI_PlayerTitleSetting.currentIndex/8)+1)
			return
		end
		
		--------------------------------------------
		
		listNumber.TextComponent.Text = tostring(math.floor(_UI_PlayerTitleSetting.currentIndex/8)+1)
		
		if self.ButtonKey == "KeyWordFront" then
			targetTable = keywordFrontTable
			targetID = "KeyWordID"
			targetTitleData = titleManager.KeyWordFrontTable
		elseif self.ButtonKey == "KeyWordBack" then
			targetTable = keywordBackTable
			targetID = "KeyWordID"
			targetTitleData = titleManager.KeyWordBackTable
		elseif self.ButtonKey == "NameTag" then
			targetTable = nametagTable
			targetID = "NameTagID"
			targetTitleData = titleManager.NameTagTable
		end
		
		--리스트에 등록된 칭호 요소가 8개가 될 때까지 1개씩 채워넣습니다.
		for i=1,8 do
			local titleElement = self.TitleElementListUI:GetChildByName("TitleElement"..i)
			
				titleElement.UI_PlayerTitleButton.TitleElement = self.ButtonKey
				self.PreviousArrowButton.UI_PlayerTitleButton.TitleElement = self.ButtonKey
				self.NextArrowButton.UI_PlayerTitleButton.TitleElement = self.ButtonKey
				
				local elementText = titleElement:GetChildByName("ElementText")
				
				--현재 선택된 데이터셋 한계를 초과할 경우
				if (targetTable:GetRowCount() < _UI_PlayerTitleSetting.currentIndex+i) then
					titleElement.Enable = false
				    --더이상의 데이터가 없으므로 공란으로 등록됩니다.
					self.NextArrowButton.Enable = false
					continue
				end
			
				titleElement.UI_PlayerTitleButton.ElementID = targetTable:GetRow(_UI_PlayerTitleSetting.currentIndex+i):GetItem(targetID)
			
				--보유 여부에 따라 잠금 활성화
			
				if targetTitleData[titleElement.UI_PlayerTitleButton.ElementID] == true then
					titleElement:GetChildByName("LockedCover").Enable = false
					titleElement.ButtonComponent.Enable = true
				elseif targetTitleData[titleElement.UI_PlayerTitleButton.ElementID] == false then
					titleElement:GetChildByName("LockedCover").Enable = true
					titleElement.ButtonComponent.Enable = false
				end
				
				--레드닷 여부에 따라 기능 활성화
				if isvalid(titleManager.redDotTable[titleElement.UI_PlayerTitleButton.ElementID]) then
					titleElement:GetChildByName("RedDot").Enable = true
					
				else
					titleElement:GetChildByName("RedDot").Enable = false
				end
			
		
				
				elementText.TextComponent.Text = _LocalizationService:GetText(targetTable:FindRow(targetID,titleElement.UI_PlayerTitleButton.ElementID):GetItem("Name"))
				if self.ButtonKey == "NameTag" then
					local NTRank = nametagTable:FindRow(targetID,titleElement.UI_PlayerTitleButton.ElementID):GetItem("Rank")
					elementText.TextComponent.FontColor = self:SetNameTagFontColor(NTRank)
				else
					elementText.TextComponent.FontColor = Color.FromHexCode("#FFFFFF")
				end
		
				titleElement.Enable = true
				elementText.Enable = true
				
				if self.Entity:GetChildByName(self.ButtonKey).TextComponent.Text == elementText.TextComponent.Text then
					titleElement:GetChildByName("Selected").Enable = true
				else
					titleElement:GetChildByName("Selected").Enable = false
				end
			self.NextArrowButton.Enable = true
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void TitleElementChange()
		--칭호 요소를 변경하고, 서버에 올려줍니다.
		------------------------------
		local titleManager = _UserService.LocalPlayer.TitleManager
		local title = _UserService.LocalPlayer:GetChildByName("PlayerTitle")
		
		local elementText = self.Entity:GetChildByName("ElementText")
		
		local NT_RUID = titleManager.EquippedTitle["NameTag"]
		local KWFront = titleManager.EquippedTitle["KeyWordFront"]
		local KWBack = titleManager.EquippedTitle["KeyWordBack"]
		
		if self.TitleElement == "KeyWordFront" then
				titleManager:CheckTitleAvaliable(self.Entity.UI_PlayerTitleButton.ElementID)
				self.KeyWordFrontButton:GetChildByName("KeyWordFront").TextComponent.Text = elementText.TextComponent.Text
		elseif self.TitleElement == "KeyWordBack" then
				titleManager:CheckTitleAvaliable(self.Entity.UI_PlayerTitleButton.ElementID)
				self.KeyWordBackButton:GetChildByName("KeyWordBack").TextComponent.Text = elementText.TextComponent.Text
		elseif self.TitleElement == "NameTag" then
				titleManager:CheckTitleAvaliable(self.Entity.UI_PlayerTitleButton.ElementID)
				self.NameTagButton:GetChildByName("NameTag").TextComponent.Text = elementText.TextComponent.Text
		end
		self.Entity:GetChildByName("RedDot").Enable = false
		self.Entity:GetChildByName("Selected").Enable = true
		titleManager.redDotTable[self.ElementID] = nil
		
		
		if self.TitleElement == "KeyWordFront" then 
				self.KeyWordFrontButton.UI_PlayerTitleButton:callTitleElementList()
			elseif self.TitleElement == "KeyWordBack" then
				self.KeyWordBackButton.UI_PlayerTitleButton:callTitleElementList()
			elseif self.TitleElement == "NameTag" then
				self.NameTagButton.UI_PlayerTitleButton:callTitleElementList()
		end
		
	end

	@ExecSpace("Client")
	method void elementSelected(table equippedTable)
		--현재 장착 중인 칭호 요소를 UI에 갱신합니다.
		-------------------------------------------
		local nametagTable = _DataService:GetTable("Title_NameTagDataset")
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		
		self.KeyWordFrontButton:GetChildByName("KeyWordFront").TextComponent.Text = _LocalizationService:GetText(keywordFrontTable:FindRow("KeyWordID",equippedTable["KeyWordFront"]):GetItem("Name"))
		self.KeyWordBackButton:GetChildByName("KeyWordBack").TextComponent.Text = _LocalizationService:GetText(keywordBackTable:FindRow("KeyWordID",equippedTable["KeyWordBack"]):GetItem("Name"))
		self.NameTagButton:GetChildByName("NameTag").TextComponent.Text = _LocalizationService:GetText(nametagTable:FindRow("NameTagID",equippedTable["NameTag"]):GetItem("Name"))
		
	end

	@ExecSpace("Client")
	method any SetNameTagFontColor(string NTRank)
		--네임태그의 Rank 값에 따라 폰트 색깔을 설정하는 함수입니다.
		-----------------------------
		local fontColor
		if tonumber(NTRank) == 0 then
			fontColor = Color.FromHexCode("#FFFFFF")
		elseif tonumber(NTRank) == 1 then
			fontColor = Color.FromHexCode("#FFFFFF")
		elseif tonumber(NTRank) == 2 then
			fontColor = Color.FromHexCode("#85db8f")
		elseif tonumber(NTRank) == 3 then
			fontColor = Color.FromHexCode("#859fdb")
		elseif tonumber(NTRank) == 4 then
			fontColor = Color.FromHexCode("#ddff94")
		elseif tonumber(NTRank) == 5 then
			fontColor = Color.FromHexCode("#2495ff")
		elseif tonumber(NTRank) == 6 then
			fontColor = Color.FromHexCode("#fec343")
		elseif tonumber(NTRank) == 7 then
			fontColor = Color.FromHexCode("#b870ff")
		elseif tonumber(NTRank) == 8 then
			fontColor = Color.FromHexCode("#fffa70")
		elseif tonumber(NTRank) == 9 then
			fontColor = Color.FromHexCode("#ff5252")
		else
			fontColor = Color.FromHexCode("#FFFFFF")
		end
		return fontColor
	end

	@ExecSpace("Client")
	method void TitleSettingInit()
		-- 칭호 설정 UI 초기화 시 현재 장착된 칭호 정보를 표시
		local titleManager = _UserService.LocalPlayer.TitleManager
		
		local nametagTable = _DataService:GetTable("Title_NameTagDataset")
		local keywordFrontTable = _DataService:GetTable("Title_KeyWordFrontDataset")
		local keywordBackTable = _DataService:GetTable("Title_KeyWordBackDataset")
		
		local NT_RUID = titleManager.EquippedTitle["NameTag"]
		local KWFront = titleManager.EquippedTitle["KeyWordFront"]
		local KWBack = titleManager.EquippedTitle["KeyWordBack"]
		
		self.NameTagButton:GetChildByName("NameTag").TextComponent.Text = _LocalizationService:GetText(nametagTable:FindRow("NameTagID",NT_RUID):GetItem("Name"))
		self.KeyWordFrontButton:GetChildByName("KeyWordFront").TextComponent.Text = _LocalizationService:GetText(keywordFrontTable:FindRow("KeyWordID",KWFront):GetItem("Name"))
		self.KeyWordBackButton:GetChildByName("KeyWordBack").TextComponent.Text = _LocalizationService:GetText(keywordBackTable:FindRow("KeyWordID",KWBack):GetItem("Name"))
		
		
	end

	@ExecSpace("ClientOnly")
	method void ButtonChangeColor(boolean onOff)
		-- 버튼 선택 상태에 따라 색상을 변경
		self.NameTagButton.ButtonComponent.Colors.NormalColor = Color.FromHexCode("#FFFFFF")
		self.KeyWordFrontButton.ButtonComponent.Colors.NormalColor = Color.FromHexCode("#FFFFFF")
		self.KeyWordBackButton.ButtonComponent.Colors.NormalColor = Color.FromHexCode("#FFFFFF")
		
		self.NameTagButton.ButtonComponent.Colors.SelectedColor = Color.FromHexCode("#f5f5f5")
		self.KeyWordFrontButton.ButtonComponent.Colors.SelectedColor = Color.FromHexCode("#f5f5f5")
		self.KeyWordBackButton.ButtonComponent.Colors.SelectedColor = Color.FromHexCode("#f5f5f5")
		
		self.NameTagButton.ButtonComponent.Colors.PressedColor = Color.FromHexCode("c8c8c8")
		self.KeyWordFrontButton.ButtonComponent.Colors.PressedColor = Color.FromHexCode("#f5f5f5")
		self.KeyWordBackButton.ButtonComponent.Colors.PressedColor = Color.FromHexCode("#f5f5f5")
		
		if onOff then
			self.Entity.ButtonComponent.Colors.NormalColor = Color.FromHexCode("#00FF00")
			self.Entity.ButtonComponent.Colors.SelectedColor = Color.FromHexCode("#00FF00")
			self.Entity.ButtonComponent.Colors.PressedColor = Color.FromHexCode("#00FF00")
		else
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void ActivateButton()
		-- 칭호 요소 버튼 활성화 시 목록 초기화 및 UI 설정
		local previousArrowButton = _EntityService:GetEntityByPath("/ui/Lobby_TitleSetting/TitleSettingUI/TitleElementListUI/LeftArrow")
		local nextArrowButton = _EntityService:GetEntityByPath("/ui/Lobby_TitleSetting/TitleSettingUI/TitleElementListUI/RightArrow")
		local listNumber = _EntityService:GetEntityByPath("/ui/Lobby_TitleSetting/TitleSettingUI/TitleElementListUI/ListNumberText")
		
		listNumber.TextComponent.Text = "1"
		nextArrowButton.Enable = true
		previousArrowButton.Enable = false
		_UI_PlayerTitleSetting.currentIndex = 0
		self:callTitleElementList()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 칭호 관련 버튼 클릭 시 해당 기능 실행
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		
		if self.ButtonKey == "TitleChange" then
			self:TitleElementChange()
		elseif self.ButtonKey == "NameTag" or self.ButtonKey == "KeyWordFront" or self.ButtonKey == "KeyWordBack" then
			self:ActivateButton()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "aab51532-9cbb-481f-8d4a-0ff6ef453f4a")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 프로필 창 열기 버튼 클릭 시 프로필 UI 활성화 및 카메라 줌
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		local profileGroup = _EntityService:GetEntityByPath("/ui/ProfileGroup")
		profileGroup:SetEnable(true)
		
		_UI_CameraZoomLogic:Zoom()
		self.TitleElementListUI.Enable = false
		self:ButtonChangeColor(false)
		_UI_Profile:RequestData(_UserService.LocalPlayer.OwnerId)
	end

end