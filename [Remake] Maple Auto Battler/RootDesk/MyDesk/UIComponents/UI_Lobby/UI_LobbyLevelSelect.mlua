		-----------------------------------------------------------
		local ui_levelSelectGroup = _EntityService:GetEntityByPath("/ui/Lobby_LevelSelect")
		ui_levelSelectGroup.Enable = true
		
		self:RefreshUI_ModeSelectPanel()
		
		local ui_selectMode = ui_levelSelectGroup:GetChildByName("Panel_SelectMode")
		local ui_selectCoach = ui_levelSelectGroup:GetChildByName("Panel_SelectCoach")
		local ui_main = ui_levelSelectGroup:GetChildByName("Panel_Main")
		local ui_selectLevel = ui_levelSelectGroup:GetChildByName("Panel_LevelSelect")
		local ui_resume = ui_levelSelectGroup:GetChildByName("Panel_Resume")
		local ui_noResumePopup = ui_levelSelectGroup:GetChildByName("Popup_CheckRemoveData")
		
		ui_selectMode.Enable 	= true
		ui_selectCoach.Enable 	= false
		ui_main.Enable 			= false
		ui_selectLevel.Enable 	= false
		ui_resume.Enable 		= false
		ui_noResumePopup.Enable = false
	end

end