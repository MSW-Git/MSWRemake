		-- 레벨 선택 버튼 클릭 시 레벨 선택 패널 열기
		-- Parameters
		-- local Entity = event.Entity
		---------------------------------------------------------
		if self.CurrentShowingMode == "Single" then
			self:RefreshUI_LevelSelectPanel(self.SelectedSingleTabIdx)
		elseif self.CurrentShowingMode == "Challenge" then
			self:RefreshUI_LevelSelectPanel(self.SelectedChallengeTabIdx)
		end
		
		local ui_levelSelectPanel = _EntityService:GetEntityByPath("/ui/Lobby_LevelSelect/Panel_LevelSelect")
		ui_levelSelectPanel.Enable = true
	end

