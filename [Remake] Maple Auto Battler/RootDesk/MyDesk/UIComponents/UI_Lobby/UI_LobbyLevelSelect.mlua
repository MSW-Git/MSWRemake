	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5500603f-db2c-4214-9c38-65223d4dbf36")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 이전에 저장된 게임이 있을 때 등장하는 '이어하기' 팝업에서, 'yes' 버튼을 눌렀을 때 실행
		---------------------------------------------------------
		local user = _UserService.LocalPlayer
		local gameManager = user.GameManager
		---------------------------------------------------------
		if gameManager.SetSavedData == true then
			user.PlayerAvatarChangeCompoenent:False_change() 
			_UserService.LocalPlayer.LoadingManager:SetEnableUI(true)
			_UserService.LocalPlayer.LoadingManager.LoadingUI.UI_Loading.TipUpdate_IsGoingToLobby = false
			
			local usePortal = function()
				gameManager:MoveToArena(
							user,
							gameManager.NeedDataLoadVersion,
							gameManager.NeedDataLoadType,
							gameManager.NeedDataLoadLevel,
							true
						)
			end
			_TimerService:SetTimerOnce(usePortal, 1)
			--_PlaySoundLogic:FadeInFadeOut(false, 1, 0.5, 0)
		else
			log("저장된 게임이 없습니다.")
		end
		
	end

