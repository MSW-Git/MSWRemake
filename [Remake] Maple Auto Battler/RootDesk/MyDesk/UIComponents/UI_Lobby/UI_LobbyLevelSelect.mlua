	@ExecSpace("ClientOnly")
	@EventSender("Entity", "096e0599-9ae6-4341-9cbd-f2c4936cc98a")
	handler HandleTabChangedEvent3(TabChangedEvent event)
		-- 코치 프리셋 버튼 변경 시 실행
		-- Parameters
		local ChangedIdx = event.ChangedIdx
		local user = _UserService.LocalPlayer
		---------------------------------------------------------
		if self.SelectedPresetNum == ChangedIdx then
			return
		end
		---------------------------------------------------------
		if self.IsCoachChangeMode == false then
			self.SelectedPresetNum = ChangedIdx
			user.CoachManager:SetCoachPreset(ChangedIdx, "load")
		end
		
		-- 버튼 목록 이미지 변경
		local buttonList = _EntityService:GetEntityByPath("/ui/Lobby_LevelSelect/Panel_Main/List_CoachPresetButton")
		for i=1, 5 do
			local button = buttonList:GetChildByName(string.format("PresetButton_%d", i))
			if i == self.SelectedPresetNum then
				button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#354e88")
				button.TextComponent.FontColor = Color.white
			else
				button.SpriteGUIRendererComponent.Color = Color.FromHexCode("#242f4d")
				button.TextComponent.FontColor = Color.FromHexCode("#6078b7")
			end
		end
	end

	@ExecSpace("ClientOnly")
