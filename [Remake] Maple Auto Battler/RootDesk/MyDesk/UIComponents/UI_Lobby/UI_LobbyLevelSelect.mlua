	@ExecSpace("ClientOnly")
	@EventSender("Entity", "eefee85f-5cf6-457c-9cad-0df401cee87e")
	handler HandleTabChangedEvent2(TabChangedEvent event)
		-- 코치 선택 UI에서 등급 필터를 바꿨을 때 실행합니다.
		--------------------------------------------------------------------
		local cost = {
			[1] = -3,
			[2] = -2,
			[3] = -1,
			[4] = 1,
			[5] = 2,
			[6] = 3,
			[7] = 4,
			[8] = 5,
			[9] = 7,
		}
		
		local idx = event.ChangedIdx
		
		self.ShowingCoachCost = cost[idx]
			
		-- 보고 있는 스크롤 목록을 변경
		local ui_coachList = _EntityService:GetEntityByPath("/ui/Lobby_LevelSelect/Panel_SelectCoach/List_Coach")
		
		local ownedCoachList = _UserService.LocalPlayer.CoachManager:GetOwnedCoachList(cost[idx])
		table.initialize(self.CurrentShowingCoachIDList, ownedCoachList)
		
		local ownedCoachCount = #ownedCoachList
		ui_coachList.CustomScrollLayoutComponent:SetChildrenCount(ownedCoachCount)
		
		-- 스크롤을 최상단으로 조절하고, 새로고침합니다.
		ui_coachList.CustomScrollLayoutComponent:SetCurrentScroll(1)
	end

