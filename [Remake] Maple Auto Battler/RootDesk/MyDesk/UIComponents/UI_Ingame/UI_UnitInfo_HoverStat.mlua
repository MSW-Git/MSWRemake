@Component
script UI_UnitInfo_HoverStat extends Component

	property string Name = ""

	property string Desc = ""

	property string TargetStatus = ""

	property number DefaultStat = 0

	property number CurrentStat = 0

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 유닛 스탯에 마우스 진입 시 스탯 정보 툴팁 표시
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		_UI_Tooltip:SetStatInfo(true, self.Name, self.Desc, self.Entity)
		_UI_Tooltip:SetMouseHoveredUI(self.Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 유닛 스탯에서 마우스 빠져나갈 시 스탯 정보 툴팁 숨김
		-- Parameters
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		_UI_Tooltip:SetStatInfo(false, self.Name, self.Desc, nil)
		_UI_Tooltip:SetMouseHoveredUI(nil)
	end

end