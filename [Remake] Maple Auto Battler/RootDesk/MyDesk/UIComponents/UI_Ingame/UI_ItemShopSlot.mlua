@Component
script UI_ItemShopSlot extends Component

	property string ItemID = ""

	property number Cost = 0

	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 아이템 슬롯 우클릭 시 조합 테이블 툴팁 표시
		-- Parameters
		-- local Entity = event.Entity
		local TouchId = event.TouchId
		-- local TouchPoint = event.TouchPoint
		---------------------------------------------------------
		if TouchId == -2 then
			_ItemCombineService.WatchingUI = "Shop"
			_ItemCombineService:ShowCombineTableTooltip(self.ItemID, "Shop")
		end
	end

	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 아이템 슬롯에 마우스 진입 시 아이템 정보 툴팁 표시
		if _ItemCombineService.IsShowingCombineTableUI == false then
		    _UI_Tooltip:SetItemInfo(true, self.ItemID, "Shop")
		end
	end

	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 아이템 슬롯에서 마우스 빠져나갈 시 툴팁 숨김
		_UI_Tooltip:SetItemInfo(false, self.ItemID, "Shop")
	end

end