@Component
script UI_BattleTeamInfo_RuneButton extends Component

	property string Team = ""

	property string Name = ""

	property string Desc = ""

	property number Grade = 0

	property number Cost = 0

	property boolean Tag_Indestructible = false

	property boolean Tag_Deactivated = false

	property integer Tag_Incineration = 0

	@ExecSpace("Client")
	method void SetProperty(string Name, string Desc, number Grade, number Cost)
		-- 룬 버튼의 이름, 설명, 등급, 비용 정보 설정
		self.Name = Name
		self.Desc = Desc
		self.Grade = Grade
		self.Cost = Cost
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 룬 버튼 마우스 오버/아웃 시 툴팁 표시 및 특수 효과 처리
		-- Parameters
		local state = event.state
		local index=tonumber(_UtilLogic:SubString(self.Entity.Name,6,1))
		---------------------------------------------------------
		if Environment:IsPCPlatform() then
			
			
			if state == ButtonState.Hover then
				_UI_Tooltip:SetRuneInfoUI_OnBattlePhase(self.Name, self.Desc, self.Grade)
				
				if isvalid(_UserService.LocalPlayer.TeamManager.OwnRunes[index]) then
					local checkedRune = _UtilLogic:Split(_UserService.LocalPlayer.TeamManager.OwnRunes[index], "_")
					--팬텀에 마우스 오버했다면 강조처리 + 오른쪽카드도 강조
					if checkedRune[1] == "RC40003" and self.Team=="User" then
						_RuneCardDirector:RC40003Director(index,true,false)
					elseif checkedRune[1] == "RC40003" and self.Team=="Enemy" then
						_RuneCardDirector:RC40003Director(index,true,true)
					end
				end
			else
				_UI_Tooltip:SetRuneInfoUI_OnBattlePhase("", "", 0)
				
				if isvalid(_UserService.LocalPlayer.TeamManager.OwnRunes[index]) then
					local checkedRune = _UtilLogic:Split(_UserService.LocalPlayer.TeamManager.OwnRunes[index], "_")
					if checkedRune[1] == "RC40003" and self.Team =="User" then
						_RuneCardDirector:RC40003Director(index,false,false)
					elseif checkedRune[1] == "RC40003" and self.Team =="Enemy" then
						_RuneCardDirector:RC40003Director(index,false,true)
					end
				end
			end
		end
	end

end