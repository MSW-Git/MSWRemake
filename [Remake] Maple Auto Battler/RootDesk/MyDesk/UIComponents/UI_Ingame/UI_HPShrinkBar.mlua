@Component
script UI_HPShrinkBar extends Component

	@Description("이 엔티티가 따라갈 원본(체력 바 ui) 엔티티입니다. 원본과 동일한 값이 될 때까지 0.5초동안 연출이 진행됩니다.")
	property Entity UI_TargetHPBar = nil

	property number ShrinkTime = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- HP 바 축소 애니메이션 업데이트
		if self.ShrinkTime > 0 then
			self.ShrinkTime -= delta
			
			local currentValue = self.Entity.SpriteGUIRendererComponent.FillAmount
			local targetValue = self.UI_TargetHPBar.SpriteGUIRendererComponent.FillAmount
			self.Entity.SpriteGUIRendererComponent.FillAmount = self:Lerp(currentValue, targetValue, self.ShrinkTime / 1)
		end
	end

	method number Lerp(number a, number b, number t)
		-- 두 값 사이의 선형 보간 계산
		return (1-t)*b + t*a
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- HP 바 엔티티 초기화 및 타겟 HP 바 참조 설정
		if self.Entity.Parent.Name == "StatInfo" then
			self.UI_TargetHPBar = self.Entity.Parent:GetChildByName("HPBar")	-- 유닛의 HPBar 인 경우
		end
	end

end