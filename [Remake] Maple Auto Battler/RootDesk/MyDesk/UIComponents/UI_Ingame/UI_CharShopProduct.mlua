@Component
script UI_CharShopProduct extends Component

	property integer SlotIdx = 0

	property integer cost = 0

	property string CharID = ""

	property Entity UI_BackgroundPanel = nil

	property Entity UI_Sprite = nil

	property Entity UI_SynergyList_2type = nil

	property Entity UI_SynergyList_3type = nil

	property Entity UI_Name = nil

	property Entity UI_CostText = nil

	property Entity UI_CostIcon = nil

	property Entity UI_Synergy2type_Slot1_Name = nil

	property Entity UI_Synergy2type_Slot1_Icon = nil

	property Entity UI_Synergy2type_Slot2_Name = nil

	property Entity UI_Synergy2type_Slot2_Icon = nil

	property Entity UI_Synergy3type_Slot1_Name = nil

	property Entity UI_Synergy3type_Slot1_Icon = nil

	property Entity UI_Synergy3type_Slot2_Name = nil

	property Entity UI_Synergy3type_Slot2_Icon = nil

	property Entity UI_Synergy3type_Slot3_Name = nil

	property Entity UI_Synergy3type_Slot3_Icon = nil

	property boolean IsInitiatedProperty = false

	property Entity UI_Effect = nil

	property Entity UI_ParticleEffect = nil

	property Entity UI_Stars = nil

	property SyncTable<Entity> UI_Effect_Stars

	property Entity UI_FavoriteMark = nil

	@ExecSpace("Client")
	method void InitProperty()
		-- 캐릭터 상점 상품 UI 요소들의 참조 초기화
		self.UI_BackgroundPanel = self.Entity:GetChildByName("Sprite_Character")
		self.UI_Sprite = self.UI_BackgroundPanel:GetChildByName("Sprite_Character_SpriteType")
		self.UI_SynergyList_2type = self.Entity:GetChildByName("List_Synergy_2type")
		self.UI_SynergyList_3type = self.Entity:GetChildByName("List_Synergy_3type")
		self.UI_Name = self.Entity:GetChildByName("Text_Name")
		self.UI_CostText = self.Entity:GetChildByName("Panel_Cost")
		--self.UI_CostIcon = self.Entity:GetChildByName("Icon_Cost")
		
		self.UI_Synergy2type_Slot1_Icon = self.UI_SynergyList_2type:GetChildByName("Synergy_1"):GetChildByName("Icon")
		self.UI_Synergy2type_Slot1_Name = self.UI_SynergyList_2type:GetChildByName("Synergy_1"):GetChildByName("Name")
		self.UI_Synergy2type_Slot2_Icon = self.UI_SynergyList_2type:GetChildByName("Synergy_2"):GetChildByName("Icon")
		self.UI_Synergy2type_Slot2_Name = self.UI_SynergyList_2type:GetChildByName("Synergy_2"):GetChildByName("Name")
		
		self.UI_Synergy3type_Slot1_Icon = self.UI_SynergyList_3type:GetChildByName("Synergy_1"):GetChildByName("Icon")
		self.UI_Synergy3type_Slot1_Name = self.UI_SynergyList_3type:GetChildByName("Synergy_1"):GetChildByName("Name")
		self.UI_Synergy3type_Slot2_Icon = self.UI_SynergyList_3type:GetChildByName("Synergy_2"):GetChildByName("Icon")
		self.UI_Synergy3type_Slot2_Name = self.UI_SynergyList_3type:GetChildByName("Synergy_2"):GetChildByName("Name")
		self.UI_Synergy3type_Slot3_Icon = self.UI_SynergyList_3type:GetChildByName("Synergy_3"):GetChildByName("Icon")
		self.UI_Synergy3type_Slot3_Name = self.UI_SynergyList_3type:GetChildByName("Synergy_3"):GetChildByName("Name")
		
		self.UI_Effect = self.Entity:GetChildByName("Effect")
		self.UI_ParticleEffect = self.Entity:GetChildByName("Particle_Own")
		self.UI_Stars = self.Entity:GetChildByName("Stars") 
		self.UI_Effect_Stars[1] = self.UI_Stars:GetChildByName("Star_1")
		self.UI_Effect_Stars[2] = self.UI_Stars:GetChildByName("Star_2")
		self.UI_Effect_Stars[3] = self.UI_Stars:GetChildByName("Star_3")
		
		-- 240610 추가
		self.UI_FavoriteMark = self.Entity:GetChildByName("Sprite_FavoriteMark")
		-- 추가
		
		self.IsInitiatedProperty = true
	end

	@ExecSpace("Client")
	method boolean CheckTutorial()
		-- 튜토리얼 진행 상태에서 해당 슬롯의 캐릭터 구매 가능 여부 확인
		if self.SlotIdx == 1 then
				if _UserService.LocalPlayer.TutorialManager_New.AllowPurchaseChar1 == true then
					return true
				else
					return false
				end
		elseif self.SlotIdx == 2 then
				if _UserService.LocalPlayer.TutorialManager_New.AllowPurchaseChar2 == true then
					return true
				else
					return false
				end
		elseif self.SlotIdx == 3 then
				if _UserService.LocalPlayer.TutorialManager_New.AllowPurchaseChar3 == true then
					return true
				else
					return false
				end
		elseif self.SlotIdx == 4 then
				if _UserService.LocalPlayer.TutorialManager_New.AllowPurchaseChar4 == true then
					return true
				else
					return false
				end
		elseif self.SlotIdx == 5 then
				if _UserService.LocalPlayer.TutorialManager_New.AllowPurchaseChar5 == true then
					return true
				else
					return false
				end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐릭터 상품 좌클릭 시 구매 처리 및 유효성 검사
		-- 좌클릭 시 구매 처리
		local user = _UserService.LocalPlayer
		local gameManager = user.GameManager
		local teamManager = user.TeamManager
		local userPControl = user.TM_PropertyControl
		local ArenaMap = _EntityService:GetEntityByPath("/maps/Arena")
		--------------------------------------------------------------
		if self.SlotIdx < 1 or self.SlotIdx > 5 then
			log_warning("slotIdx가 잘못되어 있습니다.")
			return
		end
		
		--튜토리얼 진행 시, 캐릭터 구매가 막혀있는 지 확인
		if user.GameManager.ModeType == "Tutorial" then
			local arrow = _EntityService:GetEntityByPath("/ui/TutorialGuideGroup/InteractionGuide/Arrow")
			if self:CheckTutorial() == true then
				arrow.Children[self.SlotIdx]:SetEnable(false)
			else
				_UIToast:ShowMessageByLocalizingKey("Toast_TutoTargetButtonError")
				return	
			end	
		end
		
		if _UserService.LocalPlayer.TeamManager.Golds < self.cost then
			user:SendEvent((NotEnoughCoin()))
			log("비용이 부족합니다.")
			return
		end
		
		
		_RuneCardDirector:RC20014Director(self.SlotIdx,"index")
		
		_UserService.LocalPlayer.CharacterShopManager_New:BuyCharacter_Check(self.SlotIdx)
		
		_UI_Tooltip:SetCharShopInfo(false, self.CharID, 0, false, "")
		_UI_UnitInfoPopup:UI_ShowFromCharacterShop(false, self.CharID)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 캐릭터 상품에 마우스 오버 시 툴팁 정보 표시
		-- 마우스 오버 시, 해당 캐릭터의 간단 정보 출력
		---------------------------------------------------------
		local slotIdx = tonumber(string.sub(self.Entity.Name, 9, -1))
		_UI_Tooltip:SetCharShopInfo(true, self.CharID, slotIdx, true, "CharShop")
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 캐릭터 상품 우클릭 시 상세 정보 팝업 표시
		-- 우클릭시 해당 유닛 정보 출력
		--------------------------------------------------------------
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		
		if TouchId == -2 then
			--local id = shopManager.shopManager.CurrentDisplayedUnits[self.SlotIdx]
			_UI_Tooltip:SetCharShopInfo(false, self.CharID, 0, false, "")
			_UI_UnitInfoPopup:UI_ShowFromCharacterShop(true, self.CharID)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- touch를 벗어나는 경우, 툴팁을 모두 끕니다.
		--------------------------------------------------------------
		_UI_Tooltip:SetCharShopInfo(false, self.CharID, 0, false, "")
		_UI_UnitInfoPopup:UI_ShowFromCharacterShop(false, self.CharID)
	end

end