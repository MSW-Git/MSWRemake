@Component
script UI_HUD_HoverSynergy extends Component

	property string ConnectedSynergyID = ""

	property Entity TargetUI = "be53e3e5-1521-4426-8763-165f7c4660ce"

	property string TargetTeam = ""

	@ExecSpace("Client")
	method void SetSynergyHoverOutline(boolean OnOff)
		-- 시너지에 마우스를 올렸을 때, 해당 시너지를 가진 유닛에 타일을 표시합니다.
		--------------------------------------------------------------------
		local userId = _UserService.LocalPlayer.PlayerComponent.UserId
		
		if _UtilLogic:IsNilorEmptyString(userId) then return end
			
		local teamManager = _UserService.LocalPlayer.TeamManager
		local units = teamManager.OwnUnits
		
		for i=1, #units do
			local unit = units[i]
			local synergyList = unit.UnitInfo.synergyList
			for j=1, #synergyList do
				if synergyList[j] == self.ConnectedSynergyID then
					--unit.UnitInfo:SetOutlineMaterial(OnOff, "synergy")
					_GeneralDirectorLogic:ShowSynergyTile(unit, OnOff)
					break
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 시너지 UI에 마우스 진입 시 툴팁 표시 및 유닛 강조
		if self.ConnectedSynergyID == "" then
			log("ConnectedSynergyID is nil")
			return
		end
		
		_UI_Tooltip:SetSynergyInfo(true, self.ConnectedSynergyID, self.TargetTeam, "hud")
		_UI_Tooltip:SetMouseHoveredUI(self.Entity)
		
		self:SetSynergyHoverOutline(true)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 시너지 UI에서 마우스 벗어날 시 툴팁 숨김 및 유닛 강조 해제
		
		_UI_Tooltip:SetSynergyInfo(false, self.ConnectedSynergyID, self.TargetTeam, "hud")
		_UI_Tooltip:SetMouseHoveredUI(nil)
		
		--유닛 강조끄기
		self:SetSynergyHoverOutline(false)
	end

end