@Component
script UI_Tooltip_SynergyInfo extends Component

	property Entity Desc = "53bf4d60-0004-453a-8b08-d325e9a212ff"

	property Entity Line_desc = "a9435a56-77c3-4d35-b615-ba7f81a2527d"

	property Entity CharList = "3addc6ce-dd9a-4ee3-957a-c35b4bd771ac"

	property Entity CharList_List = "afaea25a-9296-4ba6-9f1b-35faa702a052"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 구성 엔티티들의 위치 조절
		self.Line_desc.UITransformComponent.anchoredPosition.y = 
			self.Desc.UITransformComponent.anchoredPosition.y - self.Desc.UITransformComponent.RectSize.y - 20
		
		self.CharList.UITransformComponent.anchoredPosition.y = 
			self.Line_desc.UITransformComponent.anchoredPosition.y - self.Line_desc.UITransformComponent.RectSize.y
		
		local activatedChildCount = 0
		for _, child in pairs(self.CharList_List.Children) do
			if child.Enable == true then
				activatedChildCount += 1
			end
		end
		self.CharList_List.UITransformComponent.RectSize.y = 50 * activatedChildCount + 5 * (activatedChildCount-1)
		
		self.CharList.UITransformComponent.RectSize.y = self.CharList_List.UITransformComponent.RectSize.y + 40
		-------------------------------------------------------
		-- 툴팁 사이즈 조절
		self.Entity.UITransformComponent.RectSize.y = self.CharList.UITransformComponent.RectSize.y + math.abs(self.CharList.UITransformComponent.anchoredPosition.y) 
	end

end