@Component
script UI_LevelUpPopup_RewardButton extends Component

	property string RewardTitle = ""

	property string RewardDesc = ""

	property Vector2 TooltipPosition = Vector2(0,0)

	@HideFromInspector
	property boolean IsHovered = false

	@HideFromInspector
	property Entity UI_Tooltip = "83eb0cba-4ff5-4d74-b845-fd3efc855820"

	@HideFromInspector
	property Entity UI_Tooltip_Title = "850b71e1-261c-489e-b87c-002d66e476e0"

	@HideFromInspector
	property Entity UI_Tooltip_Desc = "bdeff3c3-8941-4632-8e68-f3d51893ce83"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 호버 중일 때 툴팁 크기를 내용에 맞게 동적으로 조정
		if self.IsHovered == true then
			self.UI_Tooltip.UITransformComponent.RectSize.y =
				math.abs(self.UI_Tooltip_Desc.UITransformComponent.anchoredPosition.y)
				+ self.UI_Tooltip_Desc.UITransformComponent.RectSize.y
				+ 20
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchEnterEvent(UITouchEnterEvent event)
		-- 마우스 진입 시 보상 툴팁을 표시
		self.UI_Tooltip_Title.TextComponent.Text = self.RewardTitle
		self.UI_Tooltip_Desc.TextComponent.Text = self.RewardDesc
		
		self.UI_Tooltip.UITransformComponent.anchoredPosition = self.TooltipPosition
		self.UI_Tooltip.Enable = true
		self.IsHovered = true
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchExitEvent(UITouchExitEvent event)
		-- 마우스 벗어날 시 툴팁을 숨김
		self.UI_Tooltip.Enable = false
		self.IsHovered = false
	end

end