@Component
script UI_WorldExitTooltipEnabler extends Component

	@EventSender("Service", "InputService")
	handler HandleMouseMoveEvent(MouseMoveEvent event)
		-- 마우스 이동 시 화면 우상단 영역에서 월드 종료 툴팁을 활성화
		-- Parameters
		-- local MouseDelta = event.MouseDelta
		---------------------------------------------------------
		local mousePos = _InputService:GetCursorPosition()
		local uiPos = _Util:ScreenPostoUIPos(mousePos)
		
		local uiResolution = self.Entity.Parent.UITransformComponent.RectSize
		if uiPos.x >= (uiResolution.x - 105) and uiPos.y >= (uiResolution.y - 110) then
			self.Entity.UI_ActivateTooltipOnMouseHover.TooltipUI.Enable = true
		else
			self.Entity.UI_ActivateTooltipOnMouseHover.TooltipUI.Enable = false
		end
	end

end