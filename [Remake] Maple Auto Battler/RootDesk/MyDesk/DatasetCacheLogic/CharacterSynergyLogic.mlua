@Logic
script CharacterSynergyLogic extends Logic

	property table CharacterSynergy = {}

	property boolean IsInitialized = false

	method void OnBeginPlay()
		-- 게임 시작 시 캐릭터 시너지 데이터 로드
		self:LoadTable()
	end

	method void LoadTable()
		-- 캐릭터 시너지 데이터셋을 메모리에 캐싱
		local dataSet = _DataService:GetTable("CharacterSynergy")
		
		local columnNameTable = dataSet.Columns:ToTable()
		local rows = dataSet:GetAllRow()
		
		for i, row in pairs(rows) do
			local id = row:GetItem("CharID")
			
			local obj = {}
			self.CharacterSynergy[id] = obj
			
			for k, colName in pairs(columnNameTable) do
				if colName ~= "CharId" then
					obj[colName] = row:GetItem(colName)
				end
			end
		end
		
		self.IsInitialized = true
	end

end