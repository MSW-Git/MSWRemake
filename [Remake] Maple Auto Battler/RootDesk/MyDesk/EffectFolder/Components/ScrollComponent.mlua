@Component
script ScrollComponent extends Component

	@ExecSpace("Client")
	method void SpawnScroll()
		--1초동안 알파값 0.5로, 좌표 0.3이동
		local appear = function()
			self.Entity.SpriteRendererComponent.Color.a += 1/30
			self.Entity.TransformComponent.Position.y += 1/180
		end
		
		for i = 1, 30 do
			_TimerService:SetTimerOnce(appear, i/60)
		end
	end

end