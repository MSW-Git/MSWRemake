@Component
script TileSetAlpha extends Component

	@ExecSpace("Client")
	method void Starttoalpha100()
		--점점 알파값이 100으로 감
		
		local setalpha=function()
			self.Entity.SpriteRendererComponent.Color.a += 0.035
		end
		
		for i = 1, 20 do
			_TimerService:SetTimerOnce(setalpha, i/125)
		end
		
		_TimerService:SetTimerOnce(function() self:Starttoalpha0() end, 0.3)
	end

	@ExecSpace("Client")
	method void Starttoalpha0()
		--점점 알파값이 0으로 감
		local setalpha=function()
			self.Entity.SpriteRendererComponent.Color.a -= 0.035
		end
		
		for i = 1, 20 do
			_TimerService:SetTimerOnce(setalpha, i/125)
		end
	end

end