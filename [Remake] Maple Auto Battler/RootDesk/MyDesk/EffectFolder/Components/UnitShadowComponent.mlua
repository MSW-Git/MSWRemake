@Component
script UnitShadowComponent extends Component

	@ExecSpace("Client")
	method void Init(string CharID, integer level)
		-- 캐릭터 ID와 레벨에 따른 유닛 그림자 초기화 설정
		--opacity,color, scale 세팅
		self.Entity.SpriteRendererComponent.Color = Color.FromHexCode("#19182E")
		self.Entity.SpriteRendererComponent.Color.a = 0.4
		self.Entity.TransformComponent.Scale = Vector3.one
		self.Entity.TransformComponent.Position = Vector3.zero
		
		--정해진 그림자 크기에 따라 RUID변경
		self.Entity.SpriteRendererComponent.SpriteRUID = _ShadowTableLogic.ShadowRUID[_ShadowTableLogic:GetShadowScaleType(CharID)][level]
		
		--self.Entity.Enable=true
	end

end