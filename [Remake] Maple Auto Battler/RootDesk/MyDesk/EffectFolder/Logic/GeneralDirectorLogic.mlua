@Logic
script GeneralDirectorLogic extends Logic

	property table ItemDirectorData = {}

	property Entity ShopPanel = "29a8634f-838f-4661-b385-d467b2b8b114"

	property Entity Inventory = "9465845f-8755-49ad-a7aa-aedce3e79ccf"

	property boolean IsCoinDirection = false

	property Entity UI_UnitInfoTooltip = "a8328c55-62ec-4946-a6be-835cba3e9bcf"

	property Entity deco_ProductsList_bg = "09fc191d-fedb-49fe-943c-c46052fdaae7"

	property Entity Button_ExpandInventory = "d54e4a52-1205-467a-8a57-16b8c74cb073"

	property table SpawnUnitBuffEffect_Timer = {}

	property table IconRUIDList = {}

	property Entity RuneInvenUI = "309a408e-bb71-4232-b5dd-8e944de2df04"

	property table CoinDirectorData = {}

	property boolean IsShowReadyUI = false

	property Entity ESCMenu = "4f5e9ff9-40e0-4070-a811-7d06b359a616"

	property boolean IsCoinAnimationOn = true

	property Entity SynergyList_Right = "824af3d1-76cf-4a9a-a732-00697165d194"

	property SyncTable<string, integer> ResultCoin

	property table RangeColorTable = {}

	property table SkillRangeTiles = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 및 데이터 초기화
		self:Init() -- UI 관련 초기화
		
		-- 스킬 범위 타일 관련 데이터 세팅
		local dataset = _DataService:GetTable("TileColorInBattle")
		local columns = dataset.Columns:ToTable()
		
		for i = 1, dataset:GetRowCount() do
			local row = dataset:GetRow(i)
			local obj = {}
			
			for j = 1, #columns do
				if columns[j] ~= "Type" then
					obj[columns[j]] = row:GetItem(columns[j])
				end
			end
			
			self.RangeColorTable[row:GetItem("Type")] = obj
		end
		
		local TileList = _UserService.LocalPlayer.CurrentMap:GetChildByName("BattleEffectTile")
		
		if isvalid(TileList) then
			self:InsertRangeEntity(TileList:GetChildByName("RangeTile_1"))
		end
	end

	@ExecSpace("Client")
	method void ShowReadyPhaseUI()
		--준비단계UI들 보여주기
		
		self.Inventory.UITransformComponent.anchoredPosition = Vector2(440,-220)
		self.Button_ExpandInventory.UITransformComponent.anchoredPosition = Vector2(422,-230)
		
		self.Inventory.UITweenPosition.from = Vector2(440,-220)
		self.Inventory.UITweenPosition.to = Vector2(-10,-220)
		
		self.Button_ExpandInventory.UITweenPosition.from = Vector2(422,-230)
		self.Button_ExpandInventory.UITweenPosition.to = Vector2(-25,-230)
		self.Inventory.UITweenPosition:Play()
		self.Button_ExpandInventory.UITweenPosition:Play()
		
		self.UI_UnitInfoTooltip.UITransformComponent.anchoredPosition = Vector2(-4,-220)
		self.UI_UnitInfoTooltip.UITweenPosition.from.x = -4
		self.UI_UnitInfoTooltip.UITweenPosition.to.x = -434
		
		if self.UI_UnitInfoTooltip.Enable then
			self.UI_UnitInfoTooltip.UITweenPosition:Play()
		else
			self.UI_UnitInfoTooltip.UITransformComponent.anchoredPosition.x = -434
		end
		
		local delaytime = self.ShopPanel.UITweenPosition_Stretch.duration
		_TimerService:SetTimerOnce(function() self.IsShowReadyUI=true self:StarttoPlayItemDirector() end, 0.3)
		
		--상점UI
		local chshop = _EntityService:GetEntity("a256f313-0101-4f47-bf62-670ec793d199") -- 캐릭터 상점
		local itemshop = _EntityService:GetEntity("fbad54ce-1c60-4c6e-b0ad-f8bde26325ff") -- 아이템 상점
		local runeshop = _EntityService:GetEntity("ff9b1cce-f30c-49a6-a3f1-0805190fcef9") -- 룬카드 상점
		
		chshop.UITransformComponent.anchoredPosition = Vector2(360.0001,-250)
		chshop.UITweenPosition.from = Vector2(360.0001,-250)
		chshop.UITweenPosition.to = Vector2(360.0001,5.000336)
		chshop.UITweenPosition.duration = 0.2
		
		itemshop.UITransformComponent.anchoredPosition = Vector2(1375,-200)
		itemshop.UITweenPosition.from = Vector2(1375,-200)
		itemshop.UITweenPosition.to = Vector2(1375,10)
		itemshop.UITweenPosition.duration = 0.2
		
		runeshop.UITransformComponent.anchoredPosition = Vector2(1540,-20)
		runeshop.UITweenPosition.from =Vector2(1540,-20)
		runeshop.UITweenPosition.to =  Vector2(1540,0)
		runeshop.UITweenPosition.duration = 0.2
		
		chshop.UITweenPosition:Play()
		itemshop.UITweenPosition:Play()
		runeshop.UITweenPosition:Play()
	end

	@ExecSpace("Client")
	method void ShowBattleUI()
		--적팀 시너지리스트UI 생김
		local from_s = self.SynergyList_Right.UITweenPosition.from:Clone()
		local to_s = self.SynergyList_Right.UITweenPosition.to:Clone()
		
		self.SynergyList_Right.UITweenPosition.from = to_s
		self.SynergyList_Right.UITweenPosition.to = from_s
		
		self.SynergyList_Right.UITweenPosition:Play()
		
		local init = function()
			self.SynergyList_Right.UITweenPosition.from = from_s
			self.SynergyList_Right.UITweenPosition.to = to_s
		end
		
		_TimerService:SetTimerOnce(init, 0.3)
		
		--룬카드 정보
		local runeinfo = _EntityService:GetEntity("df8629b8-bf26-46c6-a91e-17756f7d80b4") -- 룬카드 정보
		runeinfo.UITweenPosition:Play()
		
		--룬카드리스트
		local myteam = _EntityService:GetEntity("989767eb-505d-4eb2-968c-e8677a711c7f") -- 내팀
		local enemyteam = _EntityService:GetEntity("f59e6afe-7a7e-4e7f-949e-e2f35963aaa9") -- 적팀
		
		myteam:GetChildByName("Panel_RuneList").UITweenPosition:Play()
		myteam:GetChildByName("RuneList_BG").UITweenPosition:Play()
		myteam:GetChildByName("RuneList").UITweenPosition:Play()
		
		enemyteam:GetChildByName("Panel_RuneList").UITweenPosition:Play()
		enemyteam:GetChildByName("RuneList_BG").UITweenPosition:Play()
		enemyteam:GetChildByName("RuneList").UITweenPosition:Play()
		
	end

	@ExecSpace("Client")
	method void ResetReadyPhaseUI()
		--버튼 취소 등 기타 이유로 초기화
		self.IsShowReadyUI = true
		
		_TimerService:ClearTimer(self._T.offshoptimer)
		self._T.offshopimer = 0
		
		--캐릭터 상점
		local chshop = _EntityService:GetEntity("a256f313-0101-4f47-bf62-670ec793d199") -- 캐릭터 상점
		chshop.UITweenPosition:Stop()
		
		chshop.UITransformComponent.anchoredPosition = Vector2(360.0001,5.000336)
		chshop.UITweenPosition.from = Vector2(360.0001,5.000336)
		chshop.UITweenPosition.to = Vector2(360.0001,-250)
		chshop.UITweenPosition.duration = 0.2
		
		--아이템 상점
		_TimerService:ClearTimer(self._T.offitemimer)
		self._T.offitemimer = 0
		local itemshop = _EntityService:GetEntity("fbad54ce-1c60-4c6e-b0ad-f8bde26325ff") -- 아이템 상점
		itemshop.UITweenPosition:Stop()
		
		itemshop.UITransformComponent.anchoredPosition = Vector2(1375,10)
		itemshop.UITweenPosition.from = Vector2(1375,10)
		itemshop.UITweenPosition.to = Vector2(1375,-200)
		itemshop.UITweenPosition.duration = 0.2
		
		--룬 카드
		_TimerService:ClearTimer(self._T.offruneimer)
		self._T.offruneimer = 0
		local runeshop = _EntityService:GetEntity("ff9b1cce-f30c-49a6-a3f1-0805190fcef9") -- 룬카드 상점
		runeshop.UITweenPosition:Stop()
		
		runeshop.UITransformComponent.anchoredPosition = Vector2(1540,0)
		runeshop.UITweenPosition.from = Vector2(1540,0)
		runeshop.UITweenPosition.to = Vector2(1540,-20)
		runeshop.UITweenPosition.duration = 0.2
		
		--인벤토리
		_TimerService:ClearTimer(self._T.offinventimer)
		self._T.offinventimer = 0
		self.Inventory.UITweenPosition:Stop()
		self.Button_ExpandInventory.UITweenPosition:Stop()
		
		self.Inventory.UITransformComponent.anchoredPosition = Vector2(-10,-220)
		self.Button_ExpandInventory.UITransformComponent.anchoredPosition = Vector2(-25,-230)
		
		self.Inventory.UITweenPosition.from = Vector2(-10,-220)
		self.Inventory.UITweenPosition.to = Vector2(440,-220)
		
		self.Button_ExpandInventory.UITweenPosition.from = Vector2(-25,-230)
		self.Button_ExpandInventory.UITweenPosition.to = Vector2(422,-230)
		
		
		--유닛정보툴팁
		_TimerService:ClearTimer(self._T.offinventimer2)
		self._T.offinventimer2 = 0
		self.UI_UnitInfoTooltip.UITweenPosition:Stop()
		
		
		self.UI_UnitInfoTooltip.UITransformComponent.anchoredPosition = Vector2(-434,-220)
		self.UI_UnitInfoTooltip.UITweenPosition.from.x = -434
		self.UI_UnitInfoTooltip.UITweenPosition.to.x = -4
		
	end

	@ExecSpace("Client")
	method void ShowFreeCost(Entity Cost, boolean OnOff)
		--코스트가 0원일 때 코인 UI 처리
		if OnOff then
			Cost.SpriteGUIRendererComponent:ChangeMaterial("material://a662a412-9e11-4249-b8ef-02515c716e8d")
			if isvalid(Cost:GetChildByName("CoinEffect")) then
				Cost:GetChildByName("CoinEffect").Enable = true
			end
			
		else
			Cost.SpriteGUIRendererComponent:ChangeMaterial("")
			if isvalid(Cost:GetChildByName("CoinEffect")) then
				Cost:GetChildByName("CoinEffect").Enable = false
			end
		end
	end

	@ExecSpace("Client")
	method void LockCharacterShopSlot(integer slots, boolean Lock)
		-- 캐릭터 상점의 지정된 개수만큼 슬롯을 잠그거나 해제
		local count = 0
		for i = 1, 5 do
			local slot = self.deco_ProductsList_bg:GetChildByName("Product_"..tostring(math.floor(i)))
			
			if Lock then
				if slot:GetChildByName("LockChslot").Enable == false then
					slot:GetChildByName("LockChslot").Enable = true
					count += 1
				end
			else
				if slot:GetChildByName("LockChslot").Enable then
					slot:GetChildByName("LockChslot").Enable = false
					count += 1
				end
			end
			
			if count >= slots then
				break
			end
		end
		
		
		
	end

	@ExecSpace("Client")
	method void SpawnRuneCard(integer runeindex)
		-- 룬카드 획득 시 변화 이펙트를 재생하는 함수
		local invenrune = _EntityService:GetEntity("309a408e-bb71-4232-b5dd-8e944de2df04")--/ui/Arena_ReadyPhase/InventoryPanel/RuneCardInventory
		local slot = invenrune:GetChildByName("Item_"..tostring(math.floor(runeindex)))
		local directionsprite = invenrune:GetChildByName("ChangeEffect")
		
		local clonesprite = directionsprite:Clone("sprite")
		clonesprite.UITransformComponent.anchoredPosition = slot.UITransformComponent.anchoredPosition:Clone()
		
		_TimerService:SetTimerOnce(function() clonesprite:Destroy() end, 1)
	end

	@ExecSpace("Client")
	method void BattleBuffEffect(Entity Unit, integer stattype)
		--전투 중 스탯 버프를 받을 때 재생하는 연출
		-------------------------------------------------
		--이펙트생성
		local buff = _SpawnService:SpawnByModelId("model://ccedb1a2-803b-43af-b741-3986f8d862c4", "Buff", Vector3(0,-0.1,0), Unit)
		buff.Enable = false
		if not isvalid(self.SpawnUnitBuffEffect_Timer[Unit.Id]) then
			self.SpawnUnitBuffEffect_Timer[Unit.Id] ={ }
		end
		table.insert(self.SpawnUnitBuffEffect_Timer[Unit.Id], {buff,stattype})
		if #self.SpawnUnitBuffEffect_Timer[Unit.Id] == 1 then
			self:PlayBuff(Unit.Id) -- 순차 재생
		end
		
	end

	@ExecSpace("Client")
	method void PlayBuff(string UnitId)
		--순차 재생
		--local bufflist=self.SpawnUnitBuffEffect_Timer[UnitId]
		local buffeffect = 0
		
		local spawnbuff = function()
			if not isvalid(self.SpawnUnitBuffEffect_Timer[UnitId]) then _TimerService:ClearTimer(buffeffect) return end
			if not isvalid(self.SpawnUnitBuffEffect_Timer[UnitId][1]) then _TimerService:ClearTimer(buffeffect) return end
			local particle = self.SpawnUnitBuffEffect_Timer[UnitId][1][1]
			if not isvalid(particle) then table.remove(self.SpawnUnitBuffEffect_Timer[UnitId], 1) return end
			particle.RuneCardBuffComponent:Init_ver2(self.SpawnUnitBuffEffect_Timer[UnitId][1][2], "")
			
			local checklist = function()
				if isvalid(self.SpawnUnitBuffEffect_Timer[UnitId]) then
					table.remove(self.SpawnUnitBuffEffect_Timer[UnitId], 1)
					if #self.SpawnUnitBuffEffect_Timer[UnitId] == 0 then
						_TimerService:ClearTimer(buffeffect)
					end
				end
			end
			_TimerService:SetTimerOnce(checklist, 0.3)
		end
		
		buffeffect = _TimerService:SetTimerRepeat(spawnbuff, 0.8)
	end

	@ExecSpace("Client")
	method void UnitOnTileDirector(Entity selectUnit, boolean dropoff)
		--유닛이 스폰될 때, 드래그로 타일에 놓을 때 재생
		--사운드
		
		if not isvalid(selectUnit) then return end -- 유닛이 판매될 때는 사운드, 아트 재생안함
		
		if dropoff then
			_PlaySoundLogic:PlayTileSettingSound()
		end
		
		--아트 이펙트
		_EffectService:PlayEffectAttached("a9587cf1082c4c0d8c9edeed656c750d", selectUnit, Vector3.zero, 0, Vector3.one*1.2)
		_EffectService:PlayEffectAttached("5a02b2145e2c4e3fb02e79eaba7bf23b", selectUnit, Vector3(0,0.1,0), 0, Vector3.one)
	end

	@ExecSpace("Client")
	method void InsertItemDirectorData(string type, any value, string ItemID)
		--아이템 연출용 테이블에 데이터를 넣어둡니다.
		--readyphase일 때만 재생하고 그렇지 않으면 대기합니다.
		--value : 룬 카드 연출이면 룬 카드 인덱스, 마스코트/코치면 Pos
		-------------------------------------------------------------------------
		local data = {type, value, ItemID}
		table.insert(self.ItemDirectorData, data)
		
		if self.IsShowReadyUI then
			self:StarttoPlayItemDirector()
		end
	end

	@ExecSpace("Client")
	method void StarttoPlayItemDirector()
		-- 큐에 쌓인 아이템 연출들을 순차적으로 재생 시작
		if #self.ItemDirectorData == 0 then return end
		
		for i = #self.ItemDirectorData, 1, -1 do
			self:PlayItemDirector(self.ItemDirectorData[i][1], self.ItemDirectorData[i][2], self.ItemDirectorData[i][3])
			table.remove(self.ItemDirectorData, i)
		end
	end

	@ExecSpace("Client")
	method void PlayItemDirector(string type, any value, string ItemID)
		--아이템 획득 시, 연출.
		--type종류 : 마스코트, 상점 구매, 치트, 룬카드, 아이템박스
		--마스코트에서 보상받을 경우 screenpos로 보낼 것
		
		if _UtilLogic:IsNilorEmptyString(type) then return end
		
		----------------------------------------------------------------------------------
		--아이템을 얻었으나 인벤이 꺼져있는 경우, 바로 아이템 띄우기
		if self.Inventory.Enable == false then
			local parse = _UtilLogic:Split(ItemID, ",")
			if tonumber(parse[2]) <= 10 then
				local invenslot = _EntityService:GetEntity("36df1686-bd85-4854-bde6-609ccf89e30b"):GetChildByName("Item_"..parse[2])
				invenslot.Visible = true
			else
				local reddot = _EntityService:GetEntity("35568b5a-2b93-493a-8e13-6d3d808d5ef5") -- /ui/Arena_ReadyPhase/InventoryPanel/Button_NextPage/Reddot
				reddot.Visible = true
			end
			return
		end
		----------------------------------------------------------------------------------
		
		local function playItemDirectorFnc()
			--시작 위치 찾기
			local Pos = Vector2(0,0)
			if type == "Mascot" then
				Pos = _Util:ScreenPostoUIPos(value)
			end
			
			if type == "Rune" then
				local directionSprite = _EntityService:GetEntityByPath("/ui/Arena_Default/DirectionSprites/Item"):Clone()
				directionSprite.Enable = false
				local card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(value)))
				if not isvalid(card) then
					card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(#_UserService.LocalPlayer.TeamManager.OwnRunes+1)))
				end
				
				directionSprite:AttachTo(card)
				directionSprite.UITransformComponent.anchoredPosition=Vector2(-25,-30)
				directionSprite:AttachTo(self.RuneInvenUI.Parent.Parent)
				Pos=directionSprite.UITransformComponent.anchoredPosition:Clone()
				
				directionSprite:Destroy()
			end
			
			--아이템 연출 : 타입에 따라 연출이 달라집니다.
			if type == "shopbox" then
				
			elseif type == "Mascot" or type == "Rune" then
				--아이템 RUID찾기
				local itemTable = _DataService:GetTable("ItemStatus")
				local parse = _UtilLogic:Split(ItemID,",")
				local RUID = ""
				if parse[1] == "random" then
					RUID = "e28914f9fe924f5386c7593182d8c1ba"
				else
					RUID = itemTable:FindRow("ItemID",parse[1]):GetItem("RUID")
				end
				
				--아이템 스폰 -> 인벤토리로 이동
				local directionSprite = _EntityService:GetEntity("f937542e-9e9f-4bda-80ed-e94eebee6f65")
				local Item = directionSprite:Clone(ItemID.."Item")
				Item.Enable = false
				Item:GetChildByName("Sprite").SpriteGUIRendererComponent.ImageRUID = RUID
			
				--출발지점 세팅
				Item.UITransformComponent.anchoredPosition = Pos
				Item.UI_FlyingUIEntity.StartPos = Pos
				
				--목적지 : 1페이지에 있으면 해당 슬롯 위치, 2페이지 이상이면 페이지 넘김 버튼
				local destination = Vector2(0,0)
				if tonumber(parse[2]) <= 10 then
					--도착지점 세팅
					local invenslot=_EntityService:GetEntity("36df1686-bd85-4854-bde6-609ccf89e30b"):GetChildByName("Item_"..parse[2])
					Item:AttachTo(invenslot)
					Item.UITransformComponent.anchoredPosition = Vector2(-26,-26)
					Item:AttachTo(self.ShopPanel.Parent)
					
					Item.UI_FlyingUIEntity.Destination=Item.UITransformComponent.anchoredPosition:Clone()
					Item.UITransformComponent.anchoredPosition = Pos
					
					--트윈 시작
					Item.Enable = true
					Item.UI_FlyingUIEntity.Enable = true
					
					local setVisible = function()
						for i = 1, tonumber(parse[2]) do
							local childslot = _EntityService:GetEntity("36df1686-bd85-4854-bde6-609ccf89e30b"):GetChildByName("Item_"..tostring(i))
							childslot.Visible = true
						end
					end
					
					_TimerService:SetTimerOnce(setVisible, Item.UI_FlyingUIEntity.DirectionTime + 0.1)
				else
					Item.UI_FlyingUIEntity.Destination = Vector2(1051,341)
					Item.UI_FlyingUIEntity.Enable = true
					
					local setreddot = function()
						local reddot = _EntityService:GetEntity("35568b5a-2b93-493a-8e13-6d3d808d5ef5") -- /ui/Arena_ReadyPhase/InventoryPanel/Button_NextPage/Reddot
						reddot.Visible = true
					end
					
					_TimerService:SetTimerOnce(setreddot, Item.UI_FlyingUIEntity.DirectionTime + 0.2)
				end
			end
		end
		
		_TimerService:SetTimerOnce(playItemDirectorFnc, 0.03)
	end

	@ExecSpace("Client")
	method void PlayCoinDirector_Text(boolean Force, integer coin)
		-- 코인 획득 연출 : 텍스트 변경 연출입니다.
		------------------------------------------------------------------------------
		-- 코인 연출 테이블에 정보 추가
		if coin >= 0 then
			table.insert(self.CoinDirectorData, {Force,coin})
			if #self.CoinDirectorData > 1 then
				-- log("재생순서가 뒤로 밀림")
				return
			end -- 최신 데이터 인덱스가 1번이 아니면 리턴(현재 연출 재생중이라는 뜻)
			
		else
			
		end
		
		------------------------------------------------------------------------------
		if not isvalid(self.CoinDirectorData[1]) then return end
		
		Force = self.CoinDirectorData[1][1] -- 차례대로 숫자 줄어드는 연출 재생 여부
		coin = self.CoinDirectorData[1][2] -- 최종 코인
		
		if 	_EntityService:GetEntityByPath("/ui/Arena_Default/InfoPanel/TextField_Coin/Text").TextComponent.Text == math.floor(coin) then -- 최종 코인과 현재 코인이 같으면 return
			table.remove(self.CoinDirectorData, 1)
			self:PlayCoinDirector_Text(false, -100)
			return
		end
		
		-- 연출 없이 UI 내용만 변경하는 경우
		if Force then
			--_TimerService:ClearTimer(self._T.TextTimer)
			--self._T.TextTimer=0
			_EntityService:GetEntityByPath("/ui/Arena_Default/InfoPanel/TextField_Coin/Text").TextComponent.Text = string.format("%d", coin)
			table.remove(self.CoinDirectorData, 1)
			self:PlayCoinDirector_Text(false, -100)
			return
		end
			
		-- 개인 설정에서 코인 연출 재생이 꺼져 있는 경우, 연출 없이 내용만 변경
		if self.IsCoinAnimationOn == false then
			--coin = _UserService.LocalPlayer.TeamManager.Golds
			_EntityService:GetEntityByPath("/ui/Arena_Default/InfoPanel/TextField_Coin/Text").TextComponent.Text = string.format("%d", coin)
			table.remove(self.CoinDirectorData, 1)
			self:PlayCoinDirector_Text(false, -100)
			return
		end
			
		
		local ui_coinText = _EntityService:GetEntityByPath("/ui/Arena_Default/InfoPanel/TextField_Coin/Text").TextComponent.Text
		local displayingCoinAmount = math.floor(tonumber(ui_coinText))
		local duration = 0
		if coin > displayingCoinAmount then
			duration = 0.77
		elseif coin < displayingCoinAmount then
			duration = 0
		end
		
		local playcoineffect=function()
			-- 연출 함수
			--[[ocal changeCoinText = function()
				if coin > displayingCoinAmount then
					displayingCoinAmount += 1
				elseif coin < displayingCoinAmount then
					displayingCoinAmount -= 1
				end
				
				_EntityService:GetEntityByPath("/ui/Arena_Default/InfoPanel/TextField_Coin/Text").TextComponent.Text = string.format("%d", displayingCoinAmount)
				
				if displayingCoinAmount == coin then -- 실제 코인과 UI가 같을 때까지 계속 텍스트 연출이 이루어집니다
					table.remove(self.CoinDirectorData, 1)
					_TimerService:ClearTimer(self._T.TextTimer)
						
					if #self.CoinDirectorData > 0 then
						self:PlayCoinDirector_Text(false, -100)
					end
				else
				end
			end
			self._T.TextTimer=_TimerService:SetTimerRepeat(changeCoinText, 0.03, 0)]]--
				
			_EntityService:GetEntityByPath("/ui/Arena_Default/InfoPanel/TextField_Coin/Text").TextComponent.Text = string.format("%d", coin)
			table.remove(self.CoinDirectorData, 1)
			self:PlayCoinDirector_Text(false, -100)
		end
		 
		_TimerService:SetTimerOnce(playcoineffect, duration)
	end

	@ExecSpace("Client")
	method void PlayCoinDirector_Sprite(integer value, Vector2 Pos, string type)
		--코인 획득 연출 : 스프라이트 연출입니다.
		--옵션에서 코인 획득 연출이 켜져있다면 작동합니다.
		if self.IsCoinAnimationOn == false then return end
		
			--screenpos를 UIpos로 변경
			local map = _UserService.LocalPlayer.CurrentMap
			local userpos = map:GetChildByName(_UserService.LocalPlayer.PlayerComponent.UserId).TransformComponent.Position:Clone()
			if not isvalid(Pos) then
				Pos = _InputService:GetCursorPosition()
			end
		
		
			--라운드 결과는 직접 위치 설정
			if type == "RoundResult" then
				Pos = Vector2(1134,356)
			end
		
			--모험가는 스크린위치로 변경
			if type == "Adventurer" then
				Pos = _UILogic:WorldToScreenPosition(Pos)
			end
			
			_Util:ScreenPostoUIPos(Pos)
		
			--코인 와르르 연출
			local directionSprite = _EntityService:GetEntityByPath("/ui/Arena_Default/DirectionSprites/Coin")
			local cloneSprite = function()
				local ui_flyingCoin = directionSprite:Clone("coinSprite_cloned")
			
				if type == "RoundResult" then
					local group = _EntityService:GetEntity("218d9946-21e5-43a5-946e-6919a3c0106f")
					ui_flyingCoin:AttachTo(group)
				elseif  type == "Shop" then
					ui_flyingCoin:AttachTo(self.ShopPanel.Parent)
				end
				ui_flyingCoin.UITransformComponent.anchoredPosition = Pos
				ui_flyingCoin.UI_FlyingUIEntity.StartPos = ui_flyingCoin.UITransformComponent.anchoredPosition:Clone()
				ui_flyingCoin.UI_FlyingUIEntity.Enable = true
			
				--enable이 꺼져있을 경우, 직접 삭제
				_TimerService:SetTimerOnce(function() if isvalid(ui_flyingCoin) then ui_flyingCoin:Destroy() end end , 1.5)
			end
			for i = 1, value do
				_TimerService:SetTimerOnce(cloneSprite, 0.03*i)
			end
	end

	@ExecSpace("Client")
	method void SetTileDirection_Main(string type, boolean OnOff)
		-- 전장 타일 표시 관련 로직입니다. 시너지 제외 전장타일은 이 함수를 거쳐서 표시합니다.
		
		--if _UserService.LocalPlayer.CurrentMap.Name ~= "Arena" then return end
		if _UserService.LocalPlayer.CurrentMap.MapComponent.IsDynamicMap == false then return end
		
		
		if type == "OnDragging" then
			if OnOff then
				--유닛을 놓을 수 있는 타일 표시
				for i = 1, 7 do --전장
					local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
					
					for j = 1, 4 do
						tilegroup:GetChildByName("Tile_"..tostring(j)).Visible = true
						
						--튜토리얼 상황에 타겟 타일이 활성화되어있을 경우, 전장 타일을 표시하지 않습니다.
						if isvalid(tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("TutorialTile")) then
							if tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("TutorialTile").Enable == true then
							
							else
								tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("CanDragOffTile").Enable = true
							end
						else
							tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("CanDragOffTile").Enable = true
						end
					end
				end
				
				local waittilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("WaitLine")
			
				for i = 1, #waittilegroup.Children do --대기석
					waittilegroup:GetChildByName("Tile_"..tostring(i)).SpriteRendererComponent.Color.a = 1
					--튜토리얼 상황에 타겟 타일이 활성화되어있을 경우, 전장 타일을 표시하지 않습니다.
					
					if isvalid(waittilegroup:GetChildByName("Tile_"..tostring(i)):GetChildByName("TutorialTile")) then
						if waittilegroup:GetChildByName("Tile_"..tostring(i)):GetChildByName("TutorialTile").Enable == true then
							
						else
							waittilegroup:GetChildByName("Tile_"..tostring(i)):GetChildByName("CanDragOffTile").Enable = true
						end
					else
						waittilegroup:GetChildByName("Tile_"..tostring(i)):GetChildByName("CanDragOffTile").Enable = true
					end
				end
		
				--현재 오버중인 타일은 다른 아웃라인
				_CursorPosManager:CheckHoverEntity(false)
				
			else
				--유닛을 놓을 수 있는 타일 표시 끄기
				
				local waittilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("WaitLine")
				
				for i= 1, #waittilegroup.Children do --대기석
					waittilegroup:GetChildByName("Tile_"..tostring(i)).SpriteRendererComponent.Color.a = 0
					waittilegroup:GetChildByName("Tile_"..tostring(i)):GetChildByName("CanDragOffTile").Enable = false
					waittilegroup:GetChildByName("Tile_"..tostring(i)):GetChildByName("OnDraggingTile").Enable = false
				end
				
				if _UserService.LocalPlayer.GameManager.ModeType == "Tutorial" then
					if _UserService.LocalPlayer.TutorialManager_New.AlwaysShowFieldTile == true then
						--튜토리얼에서 계속 전장 타일을 보여줘야 할 시, DragOffTile을 해제하지 않음.
						return
					end
					
				end
				
				for i=1,7 do --전장
					local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
				
					for j = 1, 4 do
						tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("CanDragOffTile").Enable = false
						tilegroup:GetChildByName("Tile_"..tostring(j)):GetChildByName("OnDraggingTile").Enable = false
					end
				end
				
				_GeneralDirectorLogic:OnOffTileVisible("DragOff")
				
			end
		end
	end

	@ExecSpace("Client")
	method void BattleDebuffEffect(Entity Unit, integer stattype)
		-- 전투 중 유닛이 디버프를 받을 때 파티클 이펙트 생성
		--전투 중 스탯 디버프를 받을 때 재생하는 연출
		-------------------------------------------------
		-- 어떤 타입의 색상을 재생할 것인지 체크
		local buffcolortype = {{},{},{},{},{},{},{},{}}
		
		
		--이펙트생성
		
		local particle = _SpawnService:SpawnByModelId("model://85d69e47-99f3-4ea2-ad15-c943df717d8a","Debuff",Vector3(0,1,0),Unit)
		particle.Enable = false
		if not isvalid(self.SpawnUnitBuffEffect_Timer[Unit.Id]) then
			self.SpawnUnitBuffEffect_Timer[Unit.Id] = {}
		end
		table.insert(self.SpawnUnitBuffEffect_Timer[Unit.Id], {particle, stattype})
			
		if #self.SpawnUnitBuffEffect_Timer[Unit.Id] == 1 then
			self:PlayBuff(Unit.Id) -- 순차 재생
		end
	end

