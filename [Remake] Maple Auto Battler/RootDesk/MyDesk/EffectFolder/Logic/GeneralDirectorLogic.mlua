	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEntityMapChangedEvent(EntityMapChangedEvent event)
		-- 플레이어 맵 변경 시 UI와 시너지 타일을 초기화하는 핸들러
		-- Parameters
		local NewMap = event.NewMap
		local OldMap = event.OldMap
		local Entity = event.Entity
		---------------------------------------------------------
		if _UserService.LocalPlayer ~= Entity then return end
		--if NewMap.Name ~= "Arena" then return end
		if NewMap.MapComponent.IsDynamicMap == false then return end
		
		self:Init()
		_SynergyReadyDirectorLogic:InitOrbistile() 
		
	end

end