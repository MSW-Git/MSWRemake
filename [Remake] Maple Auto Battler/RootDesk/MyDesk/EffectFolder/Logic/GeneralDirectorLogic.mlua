	@ExecSpace("Client")
	method void SetResultCoinTable(boolean Insert, string ID, integer Coins)
		-- 라운드 결과 화면 : 룬카드/코치 항목에 출력한 정보목록입니다.
		-- 테이블에 [ID] = Coins 로 넣습니다.(Insert는 추가인지 제거인지 체크)
		
		if Insert then
			if isvalid(self.ResultCoin[ID]) then
				self.ResultCoin[ID] += Coins -- 중복 룬카드일 경우, 합계 계산
			else
				self.ResultCoin[ID] = Coins
			end
		else
			if isvalid(self.ResultCoin[ID]) then
				self.ResultCoin[ID] -= Coins
			end
			
			--라나, 팬텀은 아예 0으로
			if ID == "RC20036" or ID == "RC40003" then
				self.ResultCoin[ID] = 0
			end
		end
	end

	@ExecSpace("Client")
	method void ShowResultCoins(table value)
		-- 라운드 결과 화면에서 룬카드/코치 보상을 순차적으로 표시
		local toastUI = _EntityService:GetEntity("1fa4efe3-fceb-401f-93ef-e31302c7fd9a") --/ui/Arena_BattlePhase/Panel_BattleResult/Panel_Result/Text_Reward_RuneCard/Text
		-- value : 승리 등 라운드 결과 정보(룬카드, 코치 조건때문에 받아옴)
		-- {boolean 승리여부, ...}
		
		local posy = 0
		local timer=0
		for ID, Coins in pairs(self.ResultCoin) do
			
			-- 승리 조건 체크(슈미, 쁘띠 우르스)
			if ID == "RC10023" or ID == "COP30014" then
				if value[1] == false then
					goto skip_to_next
				end
			end
				
			if Coins <= 0 then
				goto skip_to_next
			end
			
			local name = ""  --이름
			if _UtilLogic:Contains(ID,"RC") then -- 룬카드
				name = _LocalizationService:GetText("RuneCard_"..ID.."_Name")
			elseif  _UtilLogic:Contains(ID,"CO") then -- 코치
				name = _CoachService.CoachData[ID].Name
			end
			
			local toastUI_Clone = toastUI:Clone("ToastUI")
			
			toastUI_Clone.TextComponent.Text = name.."+"..tostring(math.floor(Coins)) -- 텍스트 입력 (이름 + 획득 코인 수)
			toastUI_Clone.Enable = false
			
			-- UI 순차 표시
			local showUI = function()
				toastUI_Clone.Enable = true
				toastUI_Clone.UITweenAlpha.to = 0.7
				
				toastUI_Clone.UITweenPosition:Play()
				toastUI_Clone.UITweenAlpha:Play()
		
				toastUI_Clone:Destroy(0.5)
			end
			
			_TimerService:SetTimerOnce(showUI, timer)
			timer+=0.4
			
			
			::skip_to_next::
		end
		
		
	end

	@ExecSpace("Client")
	method void ShowSynergyTile(Entity unit, boolean OnOff)
		-- 유닛의 시너지 타일을 보여줍니다.
		unit:GetChildByName("SynergyTile").Enable = OnOff
	end

	@ExecSpace("Client")
	method table ShowSkillRangeInBattle(string type, integer range, Entity targetTile)
		-- 유닛 공격범위를 표시합니다.
		local colortable = self.RangeColorTable[type] -- 범위 색상값
		local TileList = _UserService.LocalPlayer.CurrentMap:GetChildByName("BattleEffectTile")
		--------------------------------------------------------------------------------------------
		
		
		
		-- 표시할 타일 범위 체크
		local showTileEntity = {}
		local TileVerticalNum = tonumber(_UtilLogic:SubString(targetTile.Parent.Name, string.len(targetTile.Parent.Name), 1))
		local TileHorizontalNum = tonumber(_UtilLogic:SubString(targetTile.Name, string.len(targetTile.Name), 1))
		
		for i=1, 7 do
			local line =  _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(math.floor(i)))
			
			for j=1, #line.Children do
				local tile = line:GetChildByName("Tile_"..tostring(j))
				if self:GetTileDistance(targetTile, tile) <= range then
					table.insert(showTileEntity,tile)
				end
			end
		end
		
		----------------------------------------------------------------------------------------------
		-- 타일 표시
		local AvailableTiles = {} -- 사용가능한 엔터티 수(enable이 켜져있는 엔터티는 사용불가)
		
		for i = #self.SkillRangeTiles, 1, -1 do
			table.insert(AvailableTiles, self.SkillRangeTiles[1])
			table.remove(self.SkillRangeTiles, 1)
			if #AvailableTiles == #showTileEntity then
				break
			end
		end
		
		if #AvailableTiles < #showTileEntity then -- 사용가능한 엔터티가 필요한 엔터티보다 적으면 클론
			for i = 1, #showTileEntity - #AvailableTiles do
				local clone = TileList:GetChildByName("RangeTile_1"):Clone("RangeTile_"..tostring(#TileList.Children + 1))
				table.insert(AvailableTiles, clone)
			end
		end
		
		for i = 1, #showTileEntity do
			local tileentity = AvailableTiles[i]:GetChildByName("BattleRangeTile")
			
			if not isvalid(AvailableTiles[i]) then
				table.remove(AvailableTiles, i)
				local clone = TileList:GetChildByName("RangeTile_1"):Clone("RangeTile_"..tostring(#TileList.Children + 1))
				table.insert(AvailableTiles, i, clone)
				tileentity = clone:GetChildByName("BattleRangeTile")
			end
			
			tileentity.SpriteRendererComponent.Color = Color.FromHexCode(colortable["ParentColor"])
			tileentity.SpriteRendererComponent.Color.a = _ESCMenuService.skillEffectAlpha
			tileentity:GetChildByName("BattleRangeTile_2").SpriteRendererComponent.Color = Color.FromHexCode(colortable["ChildColor"])
			tileentity:GetChildByName("BattleRangeTile_2").SpriteRendererComponent.Color = _ESCMenuService.skillEffectAlpha
			
			AvailableTiles[i].TransformComponent.WorldPosition = showTileEntity[i].TransformComponent.WorldPosition:Clone()
			AvailableTiles[i].Enable = true
		end
		
		return AvailableTiles
		
		
	end

	@ExecSpace("Client")
	method integer GetTileDistance(Entity startTile, Entity EndTile)
		-- 두 타일 간의 거리를 계산하는 함수 (헥사곤 타일 기준)
		local startY = startTile.TileComponent_New.verticalNum
		local startX = startTile.TileComponent_New.horizontalNum * 2 - (startY%2)
		
		local endY = EndTile.TileComponent_New.verticalNum
		local endX = EndTile.TileComponent_New.horizontalNum * 2 - (endY%2)
		
		local checkXGap = math.abs(startX - endX)
		local checkYGap = math.abs(startY - endY)
		
		local distance = 0
		-- 거리 계산
		
		distance = checkXGap
		for i = 1, checkYGap do
			if distance > 0 then
				distance -= 1
			else
				distance += 1
			end
		end
				
		distance = (distance/2) + checkYGap
		
		return distance
	end

	@ExecSpace("Client")
	method void OnOffTileVisible(string type)
		-- 타일 엔터티의 아웃라인을 표시합니다.
		-- type : Orbis(오르비스 타일 세팅), Knight(기사단장 타일 세팅), DragOff(유닛 놓을 때), Ellnas(엘나스 타일 세팅)
		
		--[[if type == "Orbis" then
			for i = 1, 7 do --전장
				local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
						
				for j = 1, 9 do
					if isvalid(tilegroup:GetChildByName("Tile_"..tostring(j))) then
						local tileentity = tilegroup:GetChildByName("Tile_"..tostring(j))
						
						if tileentity:GetChildByName("Knight").Enable == false and tileentity:GetChildByName("Orbis").Enable == false then
							tileentity.Visible = false
						else
							tileentity.Visible = true
						end
					end
				end
			end
			return
		end]]--
		
		for i = 1, 7 do --전장
			local tilegroup = _UserService.LocalPlayer.CurrentMap:GetChildByName("Line_"..tostring(i))
			for j = 1, 9 do
				if isvalid(tilegroup:GetChildByName("Tile_"..tostring(j))) then
					local tileentity = tilegroup:GetChildByName("Tile_"..tostring(j))
					
					if tileentity:GetChildByName("Knight").Enable == false and tileentity:GetChildByName("Orbis").Enable == false then
						tileentity.Visible = false
					else
						tileentity.Visible = true
					end
				end
			end
		end
	end

