	@ExecSpace("Client")
	method void RemoveHectorEffect(Entity unit, string phase)
		-- 헥터 캐릭터의 위협 이펙트를 제거하는 함수
		for i = 1, #unit.Children do
			if isvalid(unit.Children[i]) then
				if isvalid(unit:GetChildByName("Threaten")) then -- 헥터 피격 연출 삭제(위협 이펙트)
					unit:GetChildByName("Threaten"):Destroy()
				end
			end
		end
		
		if phase ~= "Battle" then
			for i = 1, #unit.Children do
				if isvalid(unit.Children[i]) then
					if isvalid(unit:GetChildByName("Threaten")) then -- 헥터 피격 연출 삭제(위협 이펙트)
						unit:GetChildByName("Threaten"):Destroy()
					end
				end
			end
		end
	end

	@ExecSpace("Client")
	method void ShowRedTile(string userID)
		-- 레벨 초과로 배치된 유닛들에게 빨간 타일 표시
		local teammanager = _UserService:GetUserEntityByUserId(userID).TeamManager	
		--전장 배치 인원 체크해서 인원 초과 타일을 표시합니다.
			local count = 0
			for i = 1, #teammanager.OwnUnits do
				if isvalid(teammanager.OwnUnits[i].UnitInfo) then 
					if isvalid(teammanager.OwnUnits[i].UnitInfo.setTile) then
						if teammanager.OwnUnits[i].UnitInfo.setTile.Parent.Name == "WaitLine" or teammanager.OwnUnits[i].UnitInfo.setTile.Parent.Name == "SpecialTile" then -- 도도거나 대기석 유닛
							if isvalid(teammanager.OwnUnits[i]:GetChildByName("OverTile")) then
								teammanager.OwnUnits[i]:GetChildByName("OverTile").OverTileComponent:SetTileEnable(false)
							end
						else
							if teammanager.OwnUnits[i].UnitInfo.IsSettableOnWatingField == false then -- 무공, 오르비스, 미르, 허수아비 등 전장 카운트 안되는 애들
								teammanager.OwnUnits[i]:GetChildByName("OverTile").OverTileComponent:SetTileEnable(false)
							else
								if isvalid(teammanager.OwnUnits[i]:GetChildByName("OverTile")) then -- 나머지..
									count += 1
									if count <= teammanager.Level+teammanager.Entity.TM_PropertyControl.Level_MaxUnitAdjustment then
										teammanager.OwnUnits[i]:GetChildByName("OverTile").OverTileComponent:SetTileEnable(false)
									else
										teammanager.OwnUnits[i]:GetChildByName("OverTile").OverTileComponent:SetTileEnable(true)
									end
								end
							end
						end
					end
				end
			end
	end

