	@ExecSpace("Client")
	method void OffInventoryUI()
		-- 준비 단계 종료 시 인벤토리 UI를 화면에서 숨기는 함수
		if self.IsShowReadyUI == false then return end
		
		self.IsShowReadyUI = false
		
		--인벤토리 사라짐
		self.Inventory.UITweenPosition.from.x = -10
		self.Inventory.UITweenPosition.to.x = 440
		
		self.Inventory.UITweenPosition:Play()
		
		
		self.Button_ExpandInventory.UITweenPosition.from.x = -25
		self.Button_ExpandInventory.UITweenPosition.to.x = 422
		
		self.Button_ExpandInventory.UITweenPosition:Play()
		
		
		local init=function()
			self.Inventory.UITweenPosition.from.x = 440
			self.Inventory.UITweenPosition.to.x = -10
			
			self.Button_ExpandInventory.UITweenPosition.from.x = 422
			self.Button_ExpandInventory.UITweenPosition.to.x = -25
		
		end
		
		self._T.offinventimer = _TimerService:SetTimerOnce(init, 0.35)
		
		--유닛정보툴팁도 이동
		if self.UI_UnitInfoTooltip.Enable then
			self.UI_UnitInfoTooltip.UITweenPosition.from.x = -434
			self.UI_UnitInfoTooltip.UITweenPosition.to.x = -4
			
			self.UI_UnitInfoTooltip.UITweenPosition:Play()
		else
			_TimerService:SetTimerOnce(function() self.UI_UnitInfoTooltip.UITransformComponent.anchoredPosition.x = -4 end , 0.3)
		end
		
		
		local init2=function()
			self.UI_UnitInfoTooltip.UITweenPosition:Stop()
			self.UI_UnitInfoTooltip.UITransformComponent.anchoredPosition.x = -4
			self.UI_UnitInfoTooltip.UITweenPosition.from.x = -4
			self.UI_UnitInfoTooltip.UITweenPosition.to.x = -434
		end
		
		self._T.offinventimer2=_TimerService:SetTimerOnce(init2, 0.35)
		
	end

	@ExecSpace("Client")
	method void OffShopUI(number delta)
		--카운트에 맞춰 UI가 순차적으로 꺼집니다.
		self._T.offshopimer = 0
		self._T.offitemimer = 0
		self._T.offruneimer = 0
		
		--캐릭터 상점확률, 리롤 버튼, 잠금버튼
		if math.floor(delta) == 0 then
			local chshop = _EntityService:GetEntity("a256f313-0101-4f47-bf62-670ec793d199") -- 캐릭터 상점
			
				--위로 살짝 올리기
				chshop.UITweenPosition.from.y = 5.000336
				chshop.UITweenPosition.to.y = 13
				chshop.UITweenPosition.duration = 0.1
				chshop.UITweenPosition:Play()
				
				--아래로 내리기
				local down = function()
					if self._T.offshopimer ~= 0 then -- 타이밍이슈 발생 위험이 있어 한 번 더 검증
						chshop.UITweenPosition.from.y = 30
						chshop.UITweenPosition.to.y = -250
						chshop.UITweenPosition.duration = 0.3
						chshop.UITweenPosition:Play()
						
						local init = function()
							chshop.UITweenPosition.from.y = -250
							chshop.UITweenPosition.to.y = 5.000336
						end
						_TimerService:SetTimerOnce(init, 0.35)
					end
				end
			
			self._T.offshopimer = _TimerService:SetTimerOnce(down, 0.12)
		end
		
		--아이템 상점
		if math.floor(delta) == 1 then
			local itemshop = _EntityService:GetEntity("fbad54ce-1c60-4c6e-b0ad-f8bde26325ff") -- 아이템 상점
			
			--위로 살짝 올리기
			itemshop.UITweenPosition.from.y = 10
			itemshop.UITweenPosition.to.y = 13
			itemshop.UITweenPosition.duration = 0.1
			itemshop.UITweenPosition:Play()
			
			--아래로 내리기
			local down = function()
				if self._T.offitemimer ~= 0 then -- 타이밍이슈 발생 위험이 있어 한 번 더 검증
					itemshop.UITweenPosition.from.y = 30
					itemshop.UITweenPosition.to.y =- 200
					itemshop.UITweenPosition.duration = 0.3
					itemshop.UITweenPosition:Play()
					
					local init=function()
						itemshop.UITweenPosition.from.y =- 200
						itemshop.UITweenPosition.to.y = 10
					end
					
					_TimerService:SetTimerOnce(init,0.35)
				end
			end
			
			self._T.offitemimer=_TimerService:SetTimerOnce(down,0.12)
		end
		
		--룬 카드 상점
		if math.floor(delta) == 2 then
			local runeshop = _EntityService:GetEntity("ff9b1cce-f30c-49a6-a3f1-0805190fcef9") -- 룬카드 상점
		
			
			--위로 살짝 올리기
			runeshop.UITweenPosition.from.y = 0
			runeshop.UITweenPosition.to.y = 13
			runeshop.UITweenPosition.duration = 0.1
			runeshop.UITweenPosition:Play()
			
			--아래로 내리기
			local down=function()
				if self._T.offruneimer ~= 0 then -- 타이밍이슈 발생 위험이 있어 한 번 더 검증
					runeshop.UITweenPosition.from.y = 30
					runeshop.UITweenPosition.to.y =- 200
					runeshop.UITweenPosition.duration = 0.3
					runeshop.UITweenPosition:Play()
					
					local init=function()
						runeshop.UITweenPosition.from.y =- 200
						runeshop.UITweenPosition.to.y = 0
					end
					_TimerService:SetTimerOnce(init, 0.35)
				end
			end
			
			self._T.offruneimer = _TimerService:SetTimerOnce(down, 0.12)
		end
		
		
	end

	@ExecSpace("Client")
	method void SetEffectAlpha(Entity Entity)
		--서버에서 알파값을 수정해야할 때 이 함수 호출
		if isvalid(Entity.SpriteRendererComponent) then
			Entity.SpriteRendererComponent.Color.a = _ESCMenuService.skillEffectAlpha/100
		elseif isvalid(Entity.SpriteParticleComponent) then 
			Entity.SpriteParticleComponent.Color.a = _ESCMenuService.skillEffectAlpha/100
		end
		
	end

	@ExecSpace("Client")
	method void CheckLife(integer lifecount)
		-- 남은 하트 개수를 체크. 2개 이하라면 하트 UI가 붉은색으로 깜빡
		
		--[[local lifelist = _EntityService:GetEntity("c3d0e78a-3eac-4467-9441-2d2a092b8ef7") -- /ui/Arena_Default/Progress/List_Life
		if lifecount <= 2 then
			for i = 1, 2 do
				lifelist.Children[i].ChangeLifeColorComponent.ChangeColor = true
				lifelist.Children[i].ChangeLifeColorComponent.delta = 0
			end
			
		else
			for i = 1, 2 do
				lifelist.Children[i].ChangeLifeColorComponent.ChangeColor = false
				lifelist.Children[i].ChangeLifeColorComponent.delta = 0
			end
			
		end]]--
	end

