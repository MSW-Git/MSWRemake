@Logic
script RuneCardDirectEnum extends Logic

	property integer AttackSpeed = 1

	property integer Coin = 2

	property integer Reroll = 3

	property integer PhysicalAttack = 4

	property integer MagicalAttack = 5

	property integer MaxHP = 6

	property integer MP = 7

	property integer MoveSpeed = 8

	property integer Defence = 9

	property integer MagicalResistance = 10

	property integer BloodAbsorption = 12

	property integer Weakening = 13

	property integer DealingDamageRate = 11

	property integer DamageDecrease = 14

	property integer Debuff = 0

	property integer HP = 15

	property integer ChangeUnit = -1

	property table StatText = {}

	property integer Shield = 16

	property integer Exp = 17

	property integer AttackRange = 18

	property integer CriticalPercent = 19

	property table StatNameTable = {}

	property table StatIcon = {}

	property integer CriticalDamagePercent = 20

	method void OnBeginPlay()
		-- 룬카드 스탯 관련 데이터 테이블 초기화
		if self:IsClient() then
			self.StatText = {"","","","","","","","","","","","",
							"","","","","","","",""}
		end
		
		self.StatNameTable = {"AttackSpeed","Coin","Reroll","PhysicalAttack","MagicalAttack","MaxHP","MP","MoveSpeed","Defence","MagicalResistance","DealingDamageRate","BloodAbsorption","Weakening","DamageDecrease","HP","Shield","Exp","AttackRange","CriticalPercent","CriticalDamagePercent"}
		
		self.StatIcon = {"e5bce89c02f0434d8494866649d1ffb7","","","315ee8206a324854915bf0e24ffbd7a5","e426b1f2a65d40ec94472de8e49e13c6","","","03e514648ba641c781d0d9ea8ff725c6","8aca7aa417ac4ba985fcc2551abac561","c4f198fe316d45b3bba76b7f2128572f"
						,"acc13f50646945fb85bed8a6098e397c","5f39aa3980f749cdbb380dff8fed01eb"
						,"","646b2ac68bf747a7ad4dad11b10daa97","","","","2100de26d6c647148752732f87f34d9c","1971e74097e94990a9957239bfda14a2","53366de56bfe4fd58a541a6509114f87"}
	end

	method integer GetBuffDirectorType(string statusType)
		-- 스탯 타입 문자열을 버프 연출 타입 번호로 변환
		local statustext = _UtilLogic:Split(statusType,"_") -- 연출용 변수
		
		for i = 1, #self.StatNameTable do
			if self.StatNameTable[i] == statustext[1] then
				return i
			end
		end
		
		for i = 1, #self.StatNameTable do
			if self.StatNameTable[i] == statustext[2] then
				return i
			end
		end
		
		return -100
	end

end