@Logic
script RuneCardDirector extends Logic

	property Entity RuneInvenUI = "309a408e-bb71-4232-b5dd-8e944de2df04"

	property Entity BattleRuneUI = "89fb2374-57b4-4b28-991c-79ac9c5d4c49"

	property Entity EnemyBattleRuneUI = "ba7175a7-8c1a-4206-abe9-d65eb0dcae50"

	property table IconRUIDList = {}

	property table RuneCardPos = {}

	@Description("룬 카드를 연출을 위해 필요한 프로퍼티들을 정리")
	property table RuneCardManagingValue = {}

	property Entity Trash = "258eb4bb-ac0e-4cef-be9a-96dffed8ade4"

	property Entity Trashbin = "9a3e4727-f1d3-4807-8456-35f4c2c6d1c9"

	property Entity CharacterShopBonus = "0d4ac14a-f6cc-4382-8d42-6bd6cb999604"

	property table RuneCardMaxStack = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 룬카드 연출에 필요한 아이콘과 데이터를 초기화
		self.IconRUIDList = {"39dfb7d3137a48beb17bd428aaf3fea9","b20e6d0b6e9e48abb5b293afdc836b40","75077cd46cc4c554c98801273a15acd3","f08029ba45e547109570bfffbe1a7b5f"
							,"ad2ce52353f34ab8b6db38d7813bfdfb","c2a3b3122a6a438e8068402b51b2606e","9f6eb41459d1491a8a6efe0596342872","fe674867b9af43778f0d3343f9df67ed"
							,"01b857115f5e474ca78f7968a348cfc7","99d6d95e312544c4bb22b5d747e21890","fa815264dda24458b399f928884d9fbb","47e7f8129424455b9c6d2017df0d7b6f"
							,"6bcf0f057eb14f70a0d28543d44c94fd","52616cd70c2943c5b632ec687dd2a452","63d2e8b8aa1e4471b3ea8917716544b8","fe58638ec6064d4088cc9c0ef570484e"
							,"3e9d52ed52d64794bbd6f72bab8ee3d9","3e9d52ed52d64794bbd6f72bab8ee3d9"}
		
		--별도 값관리가 필요한 룬 카드
		self.RuneCardManagingValue = {["RC10010"] = {}, ["RC10024"] = {}, ["RC10020"] = {}, ["RC10026"] = {},["RC10029"] = {},["RC10036"] = {}
									,["RC20007"] = {},["RC20008"] = {},["RC20011"] = {}, ["RC20012"] = {}, ["RC20013"] = {}, ["RC20014"] = {},["RC20021"] = {},["RC20031"] = {},["RC20034"] = {}, ["RC20067"] = {}
									,["RC30001"] = {},["RC30002"] = {},["RC30010"] = {},["RC30017"] = {},["RC30019"] = {}
									,["RC40002"] = {}}
		
		--스택형 룬 카드 중 맥스값이 있는 룬 카드
		self.RuneCardMaxStack = {["RC10010"] = 1, ["RC10029"] = 1, ["RC10024"] = 4,["RC10036"] = 222,["RC20011"] = 50,["RC20013"] = 2,["RC20014"] = 3,["RC20021"] = 1,["RC30002"] = 12,["RC30010"] = 7,["RC30017"] = 30,["RC40002"] = 333, ["RC20067"] = 10}
	end

	@ExecSpace("Client")
	method void ShakingCard_Battle(integer runeindex, boolean Enemy)
		-- 전투 중 룬카드가 발동할 때 흔들림 연출을 재생
		if runeindex == 0 then return end
		
		
		--ID에 해당되는 카드는 모두 트윈연출적용합니다.
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local Enemyrune = _UserService.LocalPlayer.TeamManager.EnemyOwnedRunes
		--------------------------------------------------------------------------
		if Enemy == false then
			local card = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
			card.UITweenRotate:Play()
				
			local off = function()
				card.UITweenRotate:Stop()
				card.UITransformComponent.ZRotation = 0
			end
				
			_TimerService:SetTimerOnce(off,0.3)
		end
		
		--------------------------------------------------------------------------
		if Enemy then
			local card = self.EnemyBattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
			
			if not isvalid(card) then
				return
			end
			card.UITweenRotate:Play()
				
			local off = function()
				card.UITweenRotate:Stop()
				card.UITransformComponent.ZRotation = 0
			end
				
			_TimerService:SetTimerOnce(off,0.3)
		end
	end

	@ExecSpace("Client")
	method void ShakingCard_Ready(integer runeindex)
		-- 준비 단계에서 룬카드 발동 시 흔들림 연출을 재생
		if runeindex == 0 then return end
		
		--ID에 해당하는 룬 카드 흔들기
			_PlaySoundLogic:PlaySound("M0160")
			local card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(runeindex)))
			card.UITweenRotate:Play()
			
			local off=function()
				card.UITweenRotate:Stop()
				card.UITransformComponent.ZRotation = 0
			end
			
			_TimerService:SetTimerOnce(off, 0.5)
	end

	@ExecSpace("Client")
	method void IconToastDirector_Ready(integer runeindex, integer type, string value)
		-- 준비 단계에서 룬카드 위에 효과 아이콘과 수치를 표시하는 토스트 UI 생성
		--ID에 해당되는 카드에 토스트 UI를 띄웁니다. 만약 ID가 빈값이면 모든 UI에 토스트를 띄웁니다.
		
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local toastUI = _EntityService:GetEntity("5260297d-c3ba-4519-8afc-c6c36910816d")--/ui/Arena_Default/DirectionSprites/ToastIcon
		local RUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
		if type > 0 then RUID = self.IconRUIDList[type] end
		
		toastUI:GetChildByName("Value"):GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = RUID
		toastUI:GetChildByName("Value").TextComponent.Text = value
		
		local card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(runeindex)))
		local worldpos = card.UITransformComponent.WorldPosition:Clone()
		local toastclone = toastUI:Clone("IconToast")
		toastclone.Enable = false
		
		toastclone:AttachTo(self.RuneInvenUI.Parent)
		toastclone.UITransformComponent.WorldPosition = worldpos:Clone()
		toastclone.UITransformComponent.anchoredPosition.x -= 1
		toastclone.UITransformComponent.anchoredPosition.y += 3
			
		toastclone.UITweenPosition.from=toastclone.UITransformComponent.anchoredPosition:Clone()
		toastclone.UITweenPosition.to = Vector2(toastclone.UITweenPosition.from.x, toastclone.UITweenPosition.from.y + 30)
		toastclone.UITweenPosition:Play()
			
		local index = 1
		toastclone.Enable = true
		local setalpha = function()
			toastclone.CanvasGroupComponent.GroupAlpha -= 1/60
		
			if index >= 60 then
				toastclone:Destroy()
			end
			index += 1
		end
			
		for j = 1,60 do
			_TimerService:SetTimerOnce(setalpha, j/45)
		end
	end

	@ExecSpace("Client")
	method void IconToastDirector_Battle(integer runeindex, table type, table value, boolean enemy)
		-- 전투 중 룬카드 위에 다중 효과 아이콘과 수치를 표시하는 토스트 UI 생성
		if runeindex == 0 then return end
		
		--ID에 해당되는 카드에 토스트 UI를 띄웁니다. 만약 ID가 빈값이면 모든 UI에 토스트를 띄웁니다.
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local Enemyrune = _UserService.LocalPlayer.TeamManager.EnemyOwnedRunes
		local toastUI = _EntityService:GetEntity("cd64686d-5772-4f4f-9d17-f9dc34fabc07")--/ui/Arena_Default/DirectionSprites/ToastIcon
		--------------------------------------------------------------------------
		if enemy == false then
			_PlaySoundLogic:PlaySound("M0160")
			local card = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
			local worldpos = card.UITransformComponent.WorldPosition:Clone()
			
			for k = 1, #type do
			
				local toastclone = toastUI:Clone("IconToast")
					
				--텍스트, 아이콘 세팅
				if type[k] <= 0 then
					toastclone.SpriteGUIRendererComponent.ImageRUID = self.IconRUIDList[#self.IconRUIDList]
					local ruid = toastclone.SpriteGUIRendererComponent.ImageRUID
				else
					toastclone.SpriteGUIRendererComponent.ImageRUID = self.IconRUIDList[type[k]]
				end
				if _UtilLogic:Contains(value[k], "-") then
					toastclone:GetChildByName("Value").TextComponent.Text = value[k]
				else
					toastclone:GetChildByName("Value").TextComponent.Text = "+"..value[k]
				end
		
					
				--UI 계층 및 위치 세팅
				toastclone:AttachTo(self.BattleRuneUI.Parent)
				toastclone.UITransformComponent.WorldPosition = worldpos:Clone()
				toastclone.UITransformComponent.anchoredPosition.x -= 1
				toastclone.UITransformComponent.anchoredPosition.y += 3
			
				toastclone.UITweenPosition.from = toastclone.UITransformComponent.anchoredPosition:Clone()
				toastclone.UITweenPosition.to = Vector2(toastclone.UITweenPosition.from.x, toastclone.UITweenPosition.from.y + 30)
				toastclone.UITweenPosition:Play()
					
				local setalpha = function()
					toastclone.CanvasGroupComponent.GroupAlpha -= 1/60
							
					if toastclone.CanvasGroupComponent.GroupAlpha <= 0 then
						toastclone:Destroy()
					end
				end
					
				for j = 1, 60 do
					_TimerService:SetTimerOnce(setalpha, j/60)
				end
					
				--다음 UI를 위해 위치 보정
				worldpos.y += 25
			end
		end
		--------------------------------------------------------------------------
		if enemy then
				local card = self.EnemyBattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
				local worldpos = card.UITransformComponent.WorldPosition:Clone()
			
				for k = 1, #type do
			
					local toastclone = toastUI:Clone("IconToast")
					
					--텍스트, 아이콘 세팅
				if type[k] <= 0 then
					toastclone.SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
				else
					toastclone.SpriteGUIRendererComponent.ImageRUID = self.IconRUIDList[type[k]]
				end
					if _UtilLogic:Contains(value[k], "-") then
						toastclone:GetChildByName("Value").TextComponent.Text = value[k]
					else
						toastclone:GetChildByName("Value").TextComponent.Text = "+"..value[k]
					end
					
					--UI 계층 및 위치 세팅
					toastclone:AttachTo(self.EnemyBattleRuneUI.Parent)
					toastclone.UITransformComponent.WorldPosition=worldpos:Clone()
					toastclone.UITransformComponent.anchoredPosition.x -= 1
					toastclone.UITransformComponent.anchoredPosition.y += 3
			
					toastclone.UITweenPosition.from = toastclone.UITransformComponent.anchoredPosition:Clone()
					toastclone.UITweenPosition.to = Vector2(toastclone.UITweenPosition.from.x,toastclone.UITweenPosition.from.y + 30)
					toastclone.UITweenPosition:Play()
					
					local setalpha = function()
					toastclone.CanvasGroupComponent.GroupAlpha -= 1/60
						
						if toastclone.CanvasGroupComponent.GroupAlpha <= 0 then
							toastclone:Destroy()
						end
					end
					
					for j = 1, 60 do
						_TimerService:SetTimerOnce(setalpha, j/60)
					end
					
					--다음 UI를 위해 위치 보정
					worldpos.y += 25
				end
			end
	end

	@ExecSpace("Client")
	method boolean GoldenMaterial(integer index)
		-- 특정 룬카드에 황금 머티리얼 효과를 적용하는 함수
		--index에 해당되는 카드에 금빛 머티리얼을 씌웁니다.
		local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
		local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
		
		--머티리얼
		battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("material://6cb92d4f-2e22-420e-90a5-21fb0f2ed9c9")
		invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("material://6cb92d4f-2e22-420e-90a5-21fb0f2ed9c9")
		
		return true
	end

	@ExecSpace("Client")
	method void InitDirector(integer index, string type)
		-- 룬카드에 적용된 연출 효과들을 초기화하는 함수
		--연출을 위해 카드 UI에 적용했던 머티리얼 등을 삭제할 때 이 함수를 부릅니다.
		--안전하게 인덱스값을 보낼 것
		--type : All, Material, FillAmount
		
		local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
		local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
		invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("HIghValueEffect").Enable = false
		battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("HIghValueEffect").Enable = false
		invencard:GetChildByName("Sprite_ProductBg").SpriteGUIRendererComponent:ChangeMaterial("")
		battlecard.SpriteGUIRendererComponent.Outline = false
		
		if type == "All" then
			--머티리얼
			battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("")
			invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("")
			
			--stackUI
			invencard:GetChildByName("StackText").Enable = false
			invencard:GetChildByName("StackGuageBack").Enable = false
			invencard:GetChildByName("StackGuage").Enable = false
			
			--상징 UI
			invencard:GetChildByName("Symbol").Enable = false
			
			
		elseif type == "Material" then
			--머티리얼
			battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("")
			invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("")
			
		elseif type == "FillAmount" then
			
		elseif type == "Stack" then
			--stackUI
			invencard:GetChildByName("StackText").Enable = false
			invencard:GetChildByName("StackGuageBack").Enable = false
			invencard:GetChildByName("StackGuage").Enable = false
			
		elseif type == "Symbol" then
			--상징 UI
			invencard:GetChildByName("Symbol").Enable = false
		end
	end

	@ExecSpace("Client")
	method void RuneCardItemDirector_Ready(integer itemindex, string ID, string ItemID, integer runeindex)
		-- 준비 단계에서 룬카드로 아이템 획득 시 연출을 재생하는 함수
		--룬 카드에서 아이템을 획득했을 때 : 준비단계에 연출 보여주기
		-----------------------------------------------------------------------
		--인벤토리 슬롯 끄기
		if itemindex <= 10 then
			local invenslot = _EntityService:GetEntity("36df1686-bd85-4854-bde6-609ccf89e30b"):GetChildByName("Item_"..tostring(math.floor(itemindex)))
			invenslot.Visible = false
		end
		
		local reddot = _EntityService:GetEntity("35568b5a-2b93-493a-8e13-6d3d808d5ef5") -- /ui/Arena_ReadyPhase/InventoryPanel/Button_NextPage/Reddot
		reddot.Visible = false
		
		_GeneralDirectorLogic:InsertItemDirectorData("Rune",runeindex,ItemID..","..tostring(math.floor(itemindex)))
	end

	@ExecSpace("Client")
	method void RC10010Director(boolean GetCoin, Entity Card)
		-- 비셔스 룬카드 효과 연출 (코인 획득 및 회색조 처리)
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local directionSprite = _EntityService:GetEntityByPath("/ui/Arena_Default/DirectionSprites/Coin")
		--------------------------------------------------------------
		local index = self:GetRuneCardIndex(Card,false)
		if index == 0 then
			index = #Ownrune+1
		end
		
		local pos = Vector2(0,0)
		if GetCoin then
			--코인 연출
			self:RuneCardCoinDirector(index, 5)
				
			--룬 카드 회색조 머티리얼
			self.RuneCardManagingValue["RC10010"][Card.Id] = 1
			self:CheckRuneCardManagingValue("RC10010",index)
		else
			self.RuneCardManagingValue["RC10010"][Card.Id] = 0
			self:CheckRuneCardManagingValue("RC10010",index)
		end
	end

	@ExecSpace("Client")
	method void Setgraysprite(integer index)
		-- 룬카드의 스택 게이지를 0으로 초기화하는 함수
		--룬 카드 게이지 초기화
		local card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
		
		card:GetChildByName("StackGuage").SpriteGUIRendererComponent.FillAmount = 0
	end

	@ExecSpace("Client")
	method void RC30001Director(string RUID, boolean Init, integer runeindex)
		-- 기억하는 자 룬카드 효과 연출 (유닛 이미지 변경 및 깜빡임)
		local ownRune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local ResourceInfo = _LoadResourcesInfo:GetUILocalPositionScale(RUID)
		local toastUI = _EntityService:GetEntity("cd64686d-5772-4f4f-9d17-f9dc34fabc07")--/ui/Arena_Default/DirectionSprites/ToastIcon
		-----------------------------------------------------------------------
		--룬 카드 위치 찾기
		local index = runeindex
		--[[for i = 1, #ownRune do
			local runeIDInfo = _UtilLogic:Split(ownRune[i], "_")
			if runeIDInfo[1] == "RC30001" then
				table.insert(index, i)
			end
		end]]--
		
		if Init == false then
			--유닛 RUID에서 프레임 1개만 가져오기
			local anim = _ResourceService:LoadAnimationClipAndWait(RUID)
			local frame = anim.Frames[1]
			--룬 카드에 머티리얼 씌우기
			--for i = 1, #index do
				local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
				local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
				
				--왜곡 증가
				local value = 0
				local strongerwave = function()
					local options = {["Intensity"] = value}
					_MaterialService:ChangeMaterialProperty("material://f3ca939e-5808-4587-9c7a-a52b847e3561", options)
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("material://f3ca939e-5808-4587-9c7a-a52b847e3561")
					
					value += 0.05
				end
				
				for j = 1, 10 do
					_TimerService:SetTimerOnce(strongerwave, j/20)
				end
				
				--이미지 변경
				local changeruid = function()
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID = frame.FrameSprite.RUID
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalScale = ResourceInfo["scale"]
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalPosition = ResourceInfo["pos"]
					
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID = frame.FrameSprite.RUID
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalScale = ResourceInfo["scale"]
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalPosition = ResourceInfo["pos"]
				end
				_TimerService:SetTimerOnce(changeruid, 0.5)
				
				--왜곡 감소
				local value2 = 0.5
				local weakerwave = function()
					local options={["Intensity"] = value2}
					_MaterialService:ChangeMaterialProperty("material://f3ca939e-5808-4587-9c7a-a52b847e3561", options)
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("material://f3ca939e-5808-4587-9c7a-a52b847e3561")
		
					value2 -= 0.05
				end
				
				for j = 1, 11 do
					_TimerService:SetTimerOnce(weakerwave, 0.5+(j/10))
				end
				
				--기억하는자효과와 유닛 리소스 번갈아가며 재생
				local currentanim = frame.FrameSprite.RUID
				local blinkanim = function()
					if currentanim == "0129ee9aa3e74f7ebfa5e8275e04023e" then
						battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID = frame.FrameSprite.RUID
						battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalScale = ResourceInfo["scale"]
						battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalPosition = ResourceInfo["pos"]
						currentanim = frame.FrameSprite.RUID
						
					elseif currentanim == frame.FrameSprite.RUID then
						local npcresourceinfo = _LoadResourcesInfo:GetUILocalPositionScale("089d45123b4c4fef81df85c3ba99df16")
						battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID = "0129ee9aa3e74f7ebfa5e8275e04023e"
						battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalScale = npcresourceinfo["scale"]
						battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalPosition = npcresourceinfo["pos"]
						currentanim = "0129ee9aa3e74f7ebfa5e8275e04023e"
					end
				end
				
				
				local timer = _TimerService:SetTimerRepeat(blinkanim, 1.3, 2.5)
				table.insert(self.RuneCardManagingValue["RC30001"],timer)
			--end
			
		else
			--타이머 제거
			self:InitRuneCardManagingValue("RC30001","")
			
			--원래대로 되돌리기
			--for i = 1, #index do
				local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
				local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
				
				local value = 0
				local strongerwave = function()
					local options = {["Intensity"]=value}
					_MaterialService:ChangeMaterialProperty("material://f3ca939e-5808-4587-9c7a-a52b847e3561", options)
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("material://f3ca939e-5808-4587-9c7a-a52b847e3561")
					
					value += 0.05
				end
				
				for j = 1, 10 do
					_TimerService:SetTimerOnce(strongerwave, j/20)
				end
				
				local initruid = function()
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID = RUID
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalScale = ResourceInfo["scale"]
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalPosition = ResourceInfo["pos"]
					--battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Gray").Enable=true
					
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.ImageRUID = RUID
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalScale = ResourceInfo["scale"]
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent.LocalPosition = ResourceInfo["pos"]
				end
				_TimerService:SetTimerOnce(initruid, 0.5)
				
				local value2 = 0.5
				local weakerwave = function()
					local options = {["Intensity"] = value2}
					_MaterialService:ChangeMaterialProperty("material://f3ca939e-5808-4587-9c7a-a52b847e3561", options)
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("material://f3ca939e-5808-4587-9c7a-a52b847e3561")
					
					if value2 <= 0.01 then
						invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("Sprite_Product").SpriteGUIRendererComponent:ChangeMaterial("")
						options={["Intensity"] = 0.5}
						_MaterialService:ChangeMaterialProperty("material://f3ca939e-5808-4587-9c7a-a52b847e3561", options)
					end
					
					value2 -= 0.05
				end
				
				for j = 1, 11 do
					_TimerService:SetTimerOnce(weakerwave, 0.5+(j/10))
				end
			--end
		end
		
		
		
	end

	@ExecSpace("Client")
	method void RC10022Director(integer availabletiles)
		-- 대기석 타일의 사용 가능 여부를 설정하는 함수
		--대기석 타일 잠그거나 해제
		local waitline = _UserService.LocalPlayer.CurrentMap:GetChildByName("WaitLine")
		
		
		for i = 1, #waitline.Children do
			local tile = waitline.Children[i]
			
			if i <= availabletiles then
				tile:GetChildByName("Lock").Enable = false
				tile.SpriteRendererComponent.Color.a = 0.5
			else
				tile:GetChildByName("Lock").Enable = true
				tile.SpriteRendererComponent.Color.a = 0.2
			end
			
		end
	end

	@ExecSpace("Client")
	method void BattleResultDirector(string type, any value)
		-- 전투 결과에 따라 발동하는 룬카드 효과들을 처리하는 함수
		--배틀 결과와 관련된 룬 카드 효과가 발생할 때는 이 함수를 부릅니다.
		local ownrunes = _UserService.LocalPlayer.TeamManager.OwnRunes
		local OnEntityOwnrune = _UserService.LocalPlayer.TeamManager.OnEntityUsingToOwnedRunes
		
			
		if type == "win" then
			if value then
				for i = 1, #ownrunes do
					local runeIDInfo = _UtilLogic:Split(ownrunes[i], "_")
					if runeIDInfo[1] == "RC10023" then -- 슈미
						for j = 1, #OnEntityOwnrune do
							if OnEntityOwnrune[j].RuneCardComponent.UID == tonumber(runeIDInfo[2]) then
								_RuneCardDirector:ShakingCard_Battle(j, false)
								_RuneCardDirector:IconToastDirector_Battle(i,{_RuneCardDirectEnum.Coin}, {"4"}, false)
								break
							end
						end
					end
				end
			end
			
		elseif type == "interest" then
			for i = 1, #ownrunes do
				local runeIDInfo = _UtilLogic:Split(ownrunes[i], "_")
				if runeIDInfo[1] == "RC20001" then --골드 리치
					for j = 1, #OnEntityOwnrune do
						if OnEntityOwnrune[j].RuneCardComponent.UID == tonumber(runeIDInfo[2]) then
							_RuneCardDirector:ShakingCard_Battle(j, false)
							_RuneCardDirector:IconToastDirector_Battle(i, {_RuneCardDirectEnum.Coin}, {tostring(math.floor(value))}, false)
							break
						end
					end
				end
			end
		end
	end

	@ExecSpace("Client")
	method boolean CheckRuneCardManagingValue(string ID, integer runeindex)
		-- 특별한 관리가 필요한 룬카드들의 상태를 확인하고 연출을 적용
		
		local index = runeindex
		
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local OnEntityOwnrune = _UserService.LocalPlayer.TeamManager.OnEntityUsingToOwnedRunes
		local entityid = ""
		if isvalid(OnEntityOwnrune[index]) then
			entityid = OnEntityOwnrune[index].Id
		else
			return true
		end
		---------------------------------------------------------------------------------
		
		--RuneCardManagingValue에서 관리하는 룬 카드들은 이 함수를 거쳐서 연출재생합니다.
		if ID == "RC10010" or ID == "RC20014" or ID == "RC20021" or ID == "RC10029"  then -- 비셔스, 해나, 나무꾼, 유타(역순 카운트)
			_RuneCardDirector:InitDirector(index, "Material")
			_RuneCardDirector:InitDirector(index, "Stack")
			_RuneCardDirector:InitDirector(index, "Symbol")
			
			if not isvalid( _RuneCardDirector.RuneCardManagingValue[ID][entityid]) then
				self:InitRuneCardManagingValue(ID, entityid)
			end
			
			local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
			local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
			if _RuneCardDirector.RuneCardManagingValue[ID][entityid] == 0 then
		
				
				
				--스택 텍스트 띄우기
				invencard:GetChildByName("StackText").Enable = true
		
			end
				local amount = (self.RuneCardMaxStack[ID]-self.RuneCardManagingValue[ID][entityid])/self.RuneCardMaxStack[ID]
				local text = tostring(math.floor(self.RuneCardMaxStack[ID]-self.RuneCardManagingValue[ID][entityid])).."/"..tostring(math.floor(self.RuneCardMaxStack[ID]))
		
				self:SetFillAmount(index, amount, text, false)
		
			
			return true
			
		elseif ID == "RC10024" or ID == "RC10036" or ID == "RC20011" or ID == "RC20013" or ID == "RC30002" or ID == "RC30017" or ID == "RC30010" or ID == "RC20067"  then --몽땅따, 무라트, 에이센, 가면신사, 윈스턴, 피그미, 만지, 박첨지(오름차순 카운트)
			_RuneCardDirector:InitDirector(index, "Material")
			_RuneCardDirector:InitDirector(index, "Symbol")
			if not isvalid( _RuneCardDirector.RuneCardManagingValue[ID][entityid]) then
				self:InitRuneCardManagingValue(ID, entityid)
			end
			
			local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
			local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
			if _RuneCardDirector.RuneCardManagingValue[ID][entityid] == 0 then
				_RuneCardDirector:Setgraysprite(index)
				
				--스택 텍스트 띄우기
				invencard:GetChildByName("StackText").Enable = true
				invencard:GetChildByName("StackText").TextComponent.Text = "0/"..tostring(math.floor(self.RuneCardMaxStack[ID]))
			else
				local amount = self.RuneCardManagingValue[ID][entityid]
				local text = tostring(math.floor(self.RuneCardManagingValue[ID][entityid]*self.RuneCardMaxStack[ID])).."/"..tostring(math.floor(self.RuneCardMaxStack[ID]))
				if ID == "RC10024" or ID == "RC20013" then
					self:SetFillAmount(index, amount, text, true)
				else
					self:SetFillAmount(index, amount, text, false)
				end
				
				--에픽 카드 중, 스택이 높은 카드들은 별도 표시합니다.
				if ID == "RC30010" and _RuneCardDirector.RuneCardManagingValue[ID][entityid]*self.RuneCardMaxStack[ID] >= 6 then
					invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("HIghValueEffect").Enable = true
					battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("HIghValueEffect").Enable = true
				end
			end
			return true
		elseif ID == "RC10026" or ID == "RC20007"  or ID == "RC20012" or ID == "RC30019" or ID == "RC10020" or ID == "RC20031" then -- 압둘라 8세, 떠돌이 연금술사, 파웬, 변신술사 바로크, 달리어, 쿠디, 탕윤
		
			_RuneCardDirector:InitDirector(index, "Material")
			_RuneCardDirector:InitDirector(index, "Symbol")
		
			if not isvalid( self.RuneCardManagingValue[ID][entityid]) then
				self:InitRuneCardManagingValue(ID, entityid)
			end
			if _RuneCardDirector.RuneCardManagingValue[ID][entityid] == 0 then
				_RuneCardDirector:Setgraysprite(index)
			else
				self:InitDirector(index, "All")
			end
			
			local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
			local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
			--스택 텍스트 띄우기
			invencard:GetChildByName("StackText").Enable = true
			invencard:GetChildByName("StackText").TextComponent.Text = tostring(math.floor(self.RuneCardManagingValue[ID][entityid]))
			
			--에픽 카드 중, 스택이 높은 카드들은 별도 표시합니다.
			if ID == "RC30019" and _RuneCardDirector.RuneCardManagingValue[ID][entityid] >= 100 then
				invencard:GetChildByName("Sprite_ProductBg"):GetChildByName("HIghValueEffect").Enable = true
				battlecard:GetChildByName("Sprite_ProductBg"):GetChildByName("HIghValueEffect").Enable = true
			end 
			
			return true
		
		elseif ID == "RC20008" then--카르카사
			_RuneCardDirector:InitDirector(index, "Material")
			_RuneCardDirector:InitDirector(index, "Stack")
			_RuneCardDirector:InitDirector(index, "FillAmount")
			if not isvalid(self.RuneCardManagingValue["RC20008"][entityid]) then
				self:InitRuneCardManagingValue("RC20008", entityid)
			end
			
			self:RC20008Director(index, false)
			return true
		
		elseif ID == "RC40002" then--아란
			_RuneCardDirector:InitDirector(index, "Material")
			_RuneCardDirector:InitDirector(index, "Symbol")
			if not isvalid( _RuneCardDirector.RuneCardManagingValue[ID][entityid]) then
				self:InitRuneCardManagingValue(ID, entityid)
			end
			
			local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
			local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
			if _RuneCardDirector.RuneCardManagingValue[ID][entityid] < 1 then
				_RuneCardDirector:Setgraysprite(index)
				
				--스택 텍스트 띄우기
				invencard:GetChildByName("StackText").Enable = true
				local amount = self.RuneCardManagingValue[ID][entityid]
				local text = tostring(math.floor(self.RuneCardManagingValue[ID][entityid]*self.RuneCardMaxStack[ID])).."/"..tostring(math.floor(self.RuneCardMaxStack[ID]))
				self:SetFillAmount(index, amount, text, false)
			else
				local amount = self.RuneCardManagingValue[ID][entityid]
				local text = "∞"
				self:SetFillAmount(index, amount, text, false)
			end
			return true
		elseif ID == "RC40003" then -- 팬텀
			local entity = _EntityService:GetEntity(entityid)
			local value = false
			for k,v in pairs(self.RuneCardManagingValue) do
				local component = k
				if isvalid(entity:GetComponent(component)) then
					value=self:CheckRuneCardManagingValue(component, index)
					break
				end
			end
			return value
		elseif ID == "RC20034" then
			_RuneCardDirector:InitDirector(index, "Material")
			_RuneCardDirector:InitDirector(index, "Stack")
			_RuneCardDirector:InitDirector(index, "Symbol")
			if not isvalid( _RuneCardDirector.RuneCardManagingValue[ID][entityid]) then
				self:InitRuneCardManagingValue(ID, entityid)
			end
		end 
		
		return false
	end

	@ExecSpace("Client")
	method void SetFillAmount(integer index, number amount, string text, boolean timer)
		-- 룬카드의 스택 게이지를 채우는 연출을 재생하는 함수
		--룬 카드 색 채우는 연출 사용할 때 부르는 함수
		local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
		local battlecard = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(index)))
		local invengap = amount-invencard:GetChildByName("StackGuage").SpriteGUIRendererComponent.FillAmount
		
		
		--음수라면 0에서부터 채우기
		if invengap < 0 then
			invencard:GetChildByName("StackGuage").SpriteGUIRendererComponent.FillAmount = 0
			invengap = amount-invencard:GetChildByName("StackGuage").SpriteGUIRendererComponent.FillAmount
		
		end
		
		if timer then
			local fill = function()
				invencard:GetChildByName("StackGuage").SpriteGUIRendererComponent.FillAmount += invengap/60
			end
			
			for i = 1, 60 do
				_TimerService:SetTimerOnce(fill, i/60)
			end
		else
			invencard:GetChildByName("StackGuage").SpriteGUIRendererComponent.FillAmount = amount
		end
		
		--스택 텍스트 띄우기
		invencard:GetChildByName("StackGuageBack").Enable = true
		invencard:GetChildByName("StackGuage").Enable = true
		invencard:GetChildByName("StackText").Enable = true
		invencard:GetChildByName("StackText").TextComponent.Text = text
		
	end

	@ExecSpace("Client")
	method void InitRuneCardManagingValue(string CardID, string value)
		-- 특별 관리 룬카드들의 값을 초기화하는 함수
		--RuneCardManagingValue에서 관리하는 룬 카드들 값 초기화
		if CardID == "RC10024" or  CardID == "RC10026" or CardID == "RC10029" or CardID == "RC10036" or CardID == "RC20007" or CardID == "RC20012" or CardID == "RC20013" or CardID == "RC30002" or CardID == "RC30017"or CardID == "RC30010"
								or CardID == "RC30019" or CardID == "RC10020" or CardID == "RC20031" or CardID == "RC40002" or CardID == "RC20067"  then
			
			self.RuneCardManagingValue[CardID][value] = 0
			
		elseif CardID == "RC30001" then
			for i = 1, #self.RuneCardManagingValue[CardID] do
				_TimerService:ClearTimer(self.RuneCardManagingValue[CardID][i])
			end
			table.clear(self.RuneCardManagingValue[CardID])
			
		elseif CardID == "RC10010" or CardID == "RC20014" or CardID == "RC20021" then
			self.RuneCardManagingValue[CardID][value] = 0
			
		elseif CardID == "RC20008" then
			self.RuneCardManagingValue[CardID][value] = ""
			
		elseif CardID == "RC20011" then
			self.RuneCardManagingValue[CardID][value] = 50 / self.RuneCardMaxStack["RC20011"]
			
		elseif CardID == "RC20034" then
			self.RuneCardManagingValue[CardID][value] = true
			
		elseif CardID == "All" then
			self:RC40002Director(false)
			
			for i = 1, #self.RuneCardManagingValue["RC30001"] do
				_TimerService:ClearTimer(self.RuneCardManagingValue["RC30001"][i])
			end
			
			self.RuneCardManagingValue={["RC10010"] = {}, ["RC10024"] = {}, ["RC10020"] = {}, ["RC10026"] = {},["RC10029"] = {},["RC10036"] = {}
										,["RC20007"] = {},["RC20008"] = {},["RC20011"] = {}, ["RC20012"] = {}, ["RC20013"] = {}, ["RC20014"] = {},["RC20021"] = {},["RC20031"] = {},["RC20034"] = {}, ["RC20067"] = {}
										,["RC30001"] = {},["RC30002"] = {},["RC30010"] = {},["RC30017"] = {}, ["RC30019"] = {}
										,["RC40002"] = {}}
			
			for i = 1, 5 do
				self:RC30004Director_New(i,"sell")
			end
			
		end
	end

	method integer GetRuneCardIndex(Entity RuneCard, boolean enemy)
		-- 룬카드 엔터티로부터 인덱스를 찾는 함수
		local OnEntityOwnrune = _UserService.LocalPlayer.TeamManager.OnEntityUsingToOwnedRunes
		local enemyOnEntityOwnrune = _UserService.LocalPlayer.TeamManager.OnEntityUsingToEnemyOwnedRunes
		local OwnRune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local EnemyRune = _UserService.LocalPlayer.TeamManager.EnemyOwnedRunes
		----------------------------------------------------------------
		local index = 0
		if enemy == false then
			for i = 1, #OnEntityOwnrune do
				if OnEntityOwnrune[i] == RuneCard then
					index = i
				end
			end
		else
			for i = 1, #enemyOnEntityOwnrune do
				if enemyOnEntityOwnrune[i] == RuneCard then
					index = i
				end
			end
		end
		
		return index
	end

	@ExecSpace("Client")
	method void RuneCardCoinDirector(integer runeindex, integer coin)
		-- 룬카드에서 코인을 획득할 때 코인 스프라이트 연출을 재생
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local directionSprite = _EntityService:GetEntityByPath("/ui/Arena_Default/DirectionSprites/Coin"):Clone()
		directionSprite.Enable = false
		------------------------------------------------------------
		--코인 연출
		local pos = Vector2(0,0)
		local card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(runeindex)))
		if not isvalid(card) then
			card=self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(#Ownrune)))
		end
		--룬 카드 위치 찾기
		directionSprite:AttachTo(card)
		directionSprite.UITransformComponent.anchoredPosition = Vector2(10,10)
		directionSprite:AttachTo(self.RuneInvenUI.Parent.Parent)
		pos = directionSprite.UITransformComponent.anchoredPosition:Clone()
		
		directionSprite:Destroy()
		pos = _Util:UIPostoScreenPos(pos)
		_GeneralDirectorLogic:PlayCoinDirector_Sprite(coin,pos,"Rune")
	end

	@ExecSpace("Client")
	method void ChangeInvenItem(integer index)
		-- 인벤토리 아이템 변경 시 이펙트를 재생하는 함수
		local inven = _EntityService:GetEntity("36df1686-bd85-4854-bde6-609ccf89e30b")--/ui/Arena_ReadyPhase/InventoryPanel/Inventory
		local slot = inven:GetChildByName("Item_"..tostring(math.floor(index)))
		
		if isvalid(slot) then
			if slot.Visible then
				local effect = slot:GetChildByName("ChangeEffect"):Clone("change")
				effect.UITransformComponent.anchoredPosition = Vector2(0,0)
				
				_TimerService:SetTimerOnce(function() effect:Destroy() end, 1)
			end
		end
	end

	@ExecSpace("Client")
	method void DestroyRuneCard(integer index, boolean Isincineration)
		-- 룬카드 파괴 시 소각 또는 일반 파괴 연출을 재생
		
		if index < 1 or index > 5 then log("룬 카드 인덱스가 "..tostring(index).."입니다.") return end
		
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local OnEntityOwnrune = _UserService.LocalPlayer.TeamManager.OnEntityUsingToOwnedRunes
		local id = ""
		if isvalid(OnEntityOwnrune[index]) then
			id = OnEntityOwnrune[index].Id
		else
			return
		end
		-------------------------------------------------------------------------------
		local card = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
		
		if Isincineration then -- 소각
			local destroysprite = _EntityService:GetEntity("23957e05-d036-4604-99ef-8605853e1019") -- /ui/Arena_Default/DirectionSprites/IncinerationCardd
			local clone = destroysprite:Clone("destroydirectonsprite")
			clone.Enable = false
			clone:AttachTo(_EntityService:GetEntityByPath("/ui/Arena_ReadyPhase"))
			clone.UITransformComponent.WorldPosition = card.UITransformComponent.WorldPosition:Clone()
			
			clone.Enable = true
			clone:Destroy(1)
			
		else -- 파괴
			local destroysprite = _EntityService:GetEntity("5c8fd81a-4c80-47dc-a70b-b853eb4bbf6d") -- /ui/Arena_Default/DirectionSprites/DestoryCard
			local clone = destroysprite:Clone("destroydirectonsprite")
			clone.Enable = false
			clone:AttachTo(_EntityService:GetEntityByPath("/ui/Arena_ReadyPhase"))
			clone.UITransformComponent.WorldPosition = card.UITransformComponent.WorldPosition:Clone()
			
			clone.Enable = true
			clone:Destroy(1)
		end
	end

	@ExecSpace("Client")
	method void RC20008Director(integer index, boolean new)
		-- 카르카사 룬카드의 시너지 아이콘 변경 연출
		local ownentityrunecard = _UserService.LocalPlayer.TeamManager.OnEntityUsingToOwnedRunes[index]
		--룬 카드 구석 상단에 있는 시너지 아이콘 변경
		local invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(index)))
		if not isvalid(invencard) then
			if not isvalid(ownentityrunecard) then
				invencard = self.RuneInvenUI:GetChildByName("Item_1")
			else
				invencard = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(#ownentityrunecard+1)))
			end
		end
		
		--상징 UI 일단 끄기
		local iconUI = invencard:GetChildByName("Symbol")
		iconUI.Enable = false
		
		--이미지가 없다면 리턴
		if self.RuneCardManagingValue["RC20008"][ownentityrunecard.Id] == "" then return end
		
		--이미지 변경
		iconUI.SpriteGUIRendererComponent.ImageRUID = self.RuneCardManagingValue["RC20008"][ownentityrunecard.Id]
		
		--연출
		if new == false then -- 신규 갱신이 아니라면 별도 연출 없음
			iconUI.Enable = true
		else
			local effect = function()
				_GeneralDirectorLogic:SpawnRuneCard(index) -- 스폰 연출이랑 동일한 걸로 사용
				iconUI.SpriteGUIRendererComponent.ImageRUID = self.RuneCardManagingValue["RC20008"][ownentityrunecard.Id]
				iconUI.Enable = true
			end
			_TimerService:SetTimerOnce(effect, 0.3)
		end
	end

	@ExecSpace("Client")
	method void ChangeShopCharacterValues()
		-- 해나와 팬텀 룬카드 효과로 상점 캐릭터 구매 개수 변경 UI 표시
		--상점 캐릭터 구매 시, 획득 개수에 영향 주는 룬 카드는 이 함수를 부릅니다.
		--RC20014 : 3코스트 이하 캐릭터 슬롯 위에 복사값 표시
		--RC40003 : 모든 슬롯 위에 스와핑 숫자 표시
		local teammanager = _UserService.LocalPlayer.TeamManager
		local shoplist = _UserService.LocalPlayer.CharacterShopManager_New.CurrentDisplayedUnitsCost
		local shopChlist = _UserService.LocalPlayer.CharacterShopManager_New.CurrentDisplayedUnits
		
		for i = 1, #self.CharacterShopBonus.Children do
			self.CharacterShopBonus.Children[i].Enable = false
			self.CharacterShopBonus.Children[i]:GetChildByName("AddText").Enable = false
			self.CharacterShopBonus.Children[i]:GetChildByName("NumText_1").Enable = false
			self.CharacterShopBonus.Children[i]:GetChildByName("NumText_2").Enable = false
			self.CharacterShopBonus.Children[i]:GetChildByName("MultipleText").Enable = false
		end
		
		
		local copyvalue_20014 = 1 --해나 복사장수
		local copyvalue_40003 = 0 --팬텀 복사풀
		
		for k,v in pairs(self.RuneCardManagingValue["RC20014"]) do
			local entity=_EntityService:GetEntity(k)
			if isvalid(entity.RC20014) then
				if entity.RC20014.UsedRuneAbility then
					copyvalue_20014 += 1
				end
			end
		end
		
		if copyvalue_20014 == 1 and copyvalue_40003 == 0 then
			return
		end
		
		--20014 3코 이하 서칭
		local shopindex = {}
		for i = 1, #shoplist do
			if shoplist[i] <= 3 and (not _UtilLogic:IsNilorEmptyString(shopChlist[i])) then
				table.insert(shopindex, i)
			end
		end
		
		--20014 복사값 표시
		if copyvalue_20014 > 1 then
			for i = 1, #shopindex do
				--UI 세팅
				local UI = self.CharacterShopBonus.Children[shopindex[i]]
				UI.Enable = true
				UI:GetChildByName("MultipleText").Enable = true
				UI:GetChildByName("NumText_1").Enable = true
				UI:GetChildByName("NumText_1").TextComponent.Text = tostring(math.floor(copyvalue_20014))
			end
		end
		
		--40003 복사값 표시
		local pool = {}
		if copyvalue_20014 == 0 then
			for i=copyvalue_40003+1 , 2, -1 do
				table.insert(pool, i)
			end
		elseif copyvalue_20014 > 0 then
			for i = 1, copyvalue_40003 do
				table.insert(pool, i)
			end
		end
		
		if copyvalue_40003 > 0 then
			for i = 1, 5 do
				if not _UtilLogic:IsNilorEmptyString(shopChlist[i])then
					local UI = self.CharacterShopBonus.Children[i]
					UI.Enable = true
					--해나 value가 있다면 + UI 키기
					if UI:GetChildByName("NumText_1").Enable == true then
						UI:GetChildByName("AddText").Enable = true
					end
					UI:GetChildByName("MultipleText").Enable = true
					UI:GetChildByName("NumText_2").Enable = true
					UI:GetChildByName("NumText_2").NumChange:StopTimer()
					UI:GetChildByName("NumText_2").NumChange:Swaping(pool)
				end
			end
		end
	end

	@ExecSpace("Client")
	method void RC20030Director(integer index)
		-- 폭탄마 룬카드 파괴 시 폭발 연출과 사운드 재생
		--사운드
		_RuneCardDirector:DestroyRuneCard(index, false)
		
		local directionSprite = _EntityService:GetEntityByPath("/ui/Arena_Default/DirectionSprites/RC20030Bomb")
		local bomb = directionSprite:Clone("bomb")
		_PlaySoundLogic:PlaySound("M0175")
		
		_TimerService:SetTimerOnce(function() bomb:Destroy() end, 0.5)
	end

	@ExecSpace("Client")
	method void ChangeUnifEffect(Entity Unit, integer Cost)
		-- 유닛 변화 효과를 재생하는 함수 (덴마 룬카드 효과)
		local buff = _SpawnService:SpawnByModelId("model://ce3810a4-9847-4d26-b570-89c042c7c60e", "Buff", Vector3(0,0,0), Unit)
		buff.RuneCardBuffComponent:ChangeUnitEffect(7, Cost, "")
	end

	@ExecSpace("Client")
	method void StrongerSynergyDirector(string SyenrgyID, boolean Enemy, boolean OnOff)
		-- 강화된 시너지 효과 표시를 위한 UI 연출 함수
		--시너지 UI 리스트, 시너지 정보
		local synergylist = _EntityService:GetEntity("c48ec9cb-4427-42f2-8a5b-3c3fa47887a7")--/ui/Arena_Default/SynergyList_Left
		local synergyinfolist = synergylist:GetChildByName("List_ActivatedSynergy_ReadyPhaseOnly")
		local synergyiconlist = synergylist:GetChildByName("List_ActivatedSynergy") 
		
		if Enemy then
			synergylist = _EntityService:GetEntity("824af3d1-76cf-4a9a-a732-00697165d194")--/ui/Arena_BattlePhase/SynergyList_Right
			synergyinfolist = synergylist:GetChildByName("List_ActivatedSynergy_ReadyPhaseOnly")
			synergyiconlist = synergylist:GetChildByName("List_ActivatedSynergy") 
		end
		
		
		--시너지리스트에 시너지가 있는지 확인
		local checkindex = ""
		for i = 1, #synergyiconlist.Children do
			local slot = synergyiconlist.Children[i]
			if isvalid(slot) == false then break end
			if SyenrgyID == slot.UI_HUD_HoverSynergy.ConnectedSynergyID then
				checkindex = synergyiconlist.Children[i].Name
				break
			end
		end
		
		if _UtilLogic:IsNilorEmptyString(checkindex) then return end
		
		
		local index = _UtilLogic:SubString(checkindex, 6, 1)
		local infoslot = synergyinfolist:GetChildByName(checkindex)
		local sprite = synergylist:GetChildByName("RuneEffect_"..index)
		
		if OnOff then
			if Enemy == false then
				sprite.UITransformComponent.RectSize = Vector2(infoslot.UITransformComponent.RectSize.x+28, 80)
				sprite.UITransformComponent.anchoredPosition = Vector2(-5, infoslot.UITransformComponent.anchoredPosition.y+6)
			else
				sprite.UITransformComponent.RectSize = Vector2(infoslot.UITransformComponent.RectSize.x+28, 80)
				sprite.UITransformComponent.anchoredPosition = Vector2(5, infoslot.UITransformComponent.anchoredPosition.y+6)
			end
			sprite.Enable = true
		else
			sprite.Enable = false
		end
	end

	@ExecSpace("Client")
	method void RC20014Director(integer value, string type)
		-- 해나 룬카드 효과로 선택된 슬롯 외 다른 슬롯의 숫자 표시 제거
		--누른 슬롯 제외하고 캐릭터 상점 상단 위에 숫자가 사라집니다.
		if value <= 0 then return end
		
		if type == "index" then
			self._T.idx_RC20014 = value
			return
		end
		
		if not isvalid(self._T.idx_RC20014) then return end
		
		local productlist = _EntityService:GetEntity("cdd50ce8-1e67-473d-85da-98e6790c110d")--/ui/Arena_ReadyPhase/ShopPanel/CharacterShop/List_Products
		local slot = self.CharacterShopBonus.Children[self._T.idx_RC20014]
		
		for i = 1, 5 do
			local productslot=self.CharacterShopBonus.Children[i]
			if productslot ~= slot then
				productslot.Enable = false
			end
		end
		_TimerService:SetTimerOnce(function() self:ChangeShopCharacterValues() end, 1)
	end

	@ExecSpace("Client")
	method void RC40003Director(integer runeindex, boolean OnOff, boolean Enemy)
		-- 팬텀 룬카드 효과로 룬카드들의 강조 표시를 제어하는 함수
		 --드래깅한 경우를 대비해 우선 전체 초기화 해줍니다.
		for i = 1, 5 do
			local slot = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(i)))
			local enemyslot = self.EnemyBattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(i)))
			local battleslot = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(i)))
		
			slot.SpriteGUIRendererComponent:ChangeMaterial("")
			battleslot.SpriteGUIRendererComponent.Outline = false
			enemyslot.SpriteGUIRendererComponent.Outline = false
			
		end
		
		--오른쪽에 카드가 없다면 회색조 처리하고 리턴
		if Enemy == false and not isvalid(_UserService.LocalPlayer.TeamManager.OwnRunes[runeindex+1]) then 
			self:Setgraysprite(runeindex)
			return
		end
		
		if OnOff == false then return end
		
		--팬텀과 오른쪽카드를 강조처리합니다. runeindex는 겔리메르 인덱스입니다
		local rightslot = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(runeindex+1)))
		local gellislot = self.RuneInvenUI:GetChildByName("Item_"..tostring(math.floor(runeindex)))
		local battlerightslot = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex+1)))
		local battlegellislot = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
		
		if Enemy then
			battlerightslot = self.EnemyBattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex+1)))
			battlegellislot = self.EnemyBattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
		end
		
		if OnOff then
			rightslot.SpriteGUIRendererComponent:ChangeMaterial("material://c4b3547a-69ef-48e6-b1ba-44856e8eb1a3")
			gellislot.SpriteGUIRendererComponent:ChangeMaterial("material://c4b3547a-69ef-48e6-b1ba-44856e8eb1a3")
		
			battlerightslot.SpriteGUIRendererComponent.Outline = true
			battlegellislot.SpriteGUIRendererComponent.Outline = true
		end
	end

	@ExecSpace("Client")
	method void RC30004Director_New(integer runeindex, string type)
		-- 타우로스피어 룬카드 효과로 대기석 타일 상태를 변경하는 함수
		--type : buy, sell, copy
		--if _UserService.LocalPlayer.CurrentMap.Name ~= "Arena" then return end
		if _UserService.LocalPlayer.CurrentMap.MapComponent.IsDynamicMap == false then return end
		
		local tiles = _UserService.LocalPlayer.CurrentMap:GetChildByName("WaitLine").Children
		
		if type == "buy" then
			local count = 0
			for i = 1, #tiles do
				local waittile=tiles[i]
				if waittile:GetChildByName("RC30004").Enable == false then
					waittile:GetChildByName("RC30004").Enable = true
					count += 1
				end
				
				if count == 2 then
					break
				end
			end
			
		elseif type == "sell" then
			local count = 0
			for i = #tiles, 1, -1 do
				local waittile = tiles[i]
				if waittile:GetChildByName("RC30004").Enable then
					waittile:GetChildByName("RC30004").Enable = false
					count += 1
				end
				
				if count == 2 then
					break
				end
			end
		elseif type == "copy" then
			--사운드
			_PlaySoundLogic:PlaySound("M0005")
			
			for i = 1, #tiles do
				local waittile = tiles[i]
				if waittile:GetChildByName("RC30004").Enable then
					--복사 이펙트
					_EffectService:PlayEffectAttached("871b8999c3fb4b42904f43432cb7bda1", tiles[i], Vector3.zero, 0, Vector3(1, 1.2, 1))
				end
			end
		end
	end

	@ExecSpace("Client")
	method void RC40001Director(Entity unit)
		-- 메르세데스 룬카드 효과로 유닛에게 엘비쉬 블레싱 이펙트 재생
		--메르세데스 : 유닛에게 가해량 기본 연출 + 엘비쉬 블레싱 스킬 이펙트
		_EffectService:PlayEffectAttached("59a57e5c6e334ab496a6742c3042a0d3", unit, Vector3.zero, 0, Vector3.one)
	end

	@ExecSpace("Client")
	method void RC40002Director(boolean OnOff)
		-- 아란 룬카드 효과로 화면 가장자리에 불꽃 UI를 표시하거나 숨김
		--화면 가장자리에 불꽃을 띄웁니다.
