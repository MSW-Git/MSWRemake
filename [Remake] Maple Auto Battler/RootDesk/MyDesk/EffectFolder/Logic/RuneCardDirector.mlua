	@ExecSpace("Client")
	method void RC40004Director_1(table Tilevalue, boolean enemy, integer runeindex, table Runevalue, string type)
		-- 아델 룬카드 1단계 연출 (대기석 타일 순차 확인)
		if enemy then
			_RuneCardDirector:ShakingCard_Battle(runeindex, true)
		else
			local map = _UserService.LocalPlayer.CurrentMap
			local tiles = map:GetChildByName("WaitLine") -- 대기석 부모엔터티
			local timer = 0
		
			--대기석 타일이 왼쪽부터 순서대로 빛납니다. 조건 체크 연출입니다.
			local index = 1
			local nexttile = true
			local changetilecolor = function()
				local tileentity = tiles.Children[index]
				
				--이미 표시 중인 타일이면 전체 타일 끄기
				if nexttile == false then
					tileentity = tiles.Children[index+1]
					
					if isvalid(tileentity) and index+1 <= _UserService.LocalPlayer.TM_PropertyControl.Tile_AvailableWaitingTile then
						--타일 빛남 처리
						local pos = tileentity.TransformComponent.WorldPosition:Clone()
						_EffectService:PlayEffect("bc22e1fd7ab346b1befc404c3842543f", _UserService.LocalPlayer.CurrentMap, pos, 0, Vector3.one)
						
						_TimerService:SetTimerOnce(function() _EffectService:PlayEffect("eb7fb0e1f6fb468b8e6c55f5ecff14ec", _UserService.LocalPlayer.CurrentMap, pos, 0, Vector3.one) end, 0.5)
					end
					
					_TimerService:ClearTimer(timer)
					
					local init = function()
						--룬 카드 효과 연출
						self:RC40004Director_2(Runevalue, enemy, type, #Tilevalue)
					end
					
					_TimerService:SetTimerOnce(init, 0.2)
				else
					_PlaySoundLogic:PlaySound("M0165")
					local pos = tileentity.TransformComponent.WorldPosition:Clone()
					_EffectService:PlayEffect("46c260d6f0ec4f6396762bba08818404", _UserService.LocalPlayer.CurrentMap, pos, 0, Vector3.one)
					--타일 빛남 처리
					
					--다음 타일 표시 여부 체크
					if Tilevalue[index] == Tilevalue[index+1] then
						index += 1
						nexttile = true
					else
						nexttile = false
					end
				end
			end
			
			timer=_TimerService:SetTimerRepeat(changetilecolor, 0.2)
		end
		
	end

	@ExecSpace("Client")
	method void RC40004Director_2(table Runevalue, boolean enemy, string Type, integer tilenum)
		-- 아델 룬카드 2단계 연출 (보상 지급)
		local map = _UserService.LocalPlayer.CurrentMap
		if Type == "full" then
			--캐릭터
			for i = 1, #Runevalue do
				local entity = _EntityService:GetEntity(Runevalue[i])
				_EffectService:PlayEffectAttached("0e3e5c3397104c838d154db33e2a4332", entity, Vector3(0,-0.2,0), 0, Vector3.one)
			end
		elseif Type == "empty" then
			--아이템(1: 아이템아이디)
			local tile = map:GetChildByName("WaitLine"):GetChildByName("Tile_"..tostring(math.floor(_UserService.LocalPlayer.TM_PropertyControl.Tile_AvailableWaitingTile)))
			local pos = tile.TransformComponent.WorldPosition:Clone():ToVector2()
			pos = _UILogic:WorldToScreenPosition(pos)
			pos = _Util:ScreenPostoUIPos(pos)
			pos.x -= 70
		
			
			--아이템 RUID찾기
			local itemTable = _DataService:GetTable("ItemStatus")
			local parse = _UtilLogic:Split(Runevalue[1],",")
			local RUID = ""
			if parse[1] == "random" then
				RUID = "e28914f9fe924f5386c7593182d8c1ba"
			else
				RUID = itemTable:FindRow("ItemID",parse[1]):GetItem("RUID")
			end
			
			--아이템 스폰
			local directionSprite = _EntityService:GetEntity("f937542e-9e9f-4bda-80ed-e94eebee6f65")
			local Item = directionSprite:Clone(Runevalue[1].."Item")
			Item.Enable = false
			Item:GetChildByName("Sprite").SpriteGUIRendererComponent.ImageRUID = RUID
		
			--트윈
			Item.UITransformComponent.anchoredPosition = pos:Clone()
			Item.UI_FlyingUIEntity.StartPos = pos:Clone()
			Item.UI_FlyingUIEntity.Destination = Vector2(pos.x, pos.y+50)
			Item.Enable = true
			Item.UI_FlyingUIEntity.Enable = true
		end
	end

	@ExecSpace("Client")
	method void RC40005SpawnDirector(Entity unit)
		-- 제로 룬카드 효과로 유닛 스폰 시 사운드와 이펙트 재생
		_PlaySoundLogic:PlaySound("M0164")
		_EffectService:PlayEffectAttached("e159772b152b433ebc9ea9d720dbb1ac", unit, Vector3.zero, 0, Vector3.one)
	end

	@ExecSpace("Client")
	method void StrongerSynergyDirector_Init(boolean Enemy)
		-- 강화된 시너지 연출 효과를 초기화하는 함수
		
		--시너지 UI 리스트, 시너지 정보
		local synergylist =_EntityService:GetEntity("c48ec9cb-4427-42f2-8a5b-3c3fa47887a7")--/ui/Arena_Default/SynergyList_Left
		local synergyinfolist =synergylist:GetChildByName("List_ActivatedSynergy_ReadyPhaseOnly")
		local synergyiconlist =synergylist:GetChildByName("List_ActivatedSynergy") 
		
		if Enemy then
			synergylist =_EntityService:GetEntity("824af3d1-76cf-4a9a-a732-00697165d194")--/ui/Arena_BattlePhase/SynergyList_Right
			synergyinfolist =synergylist:GetChildByName("List_ActivatedSynergy_ReadyPhaseOnly")
			synergyiconlist =synergylist:GetChildByName("List_ActivatedSynergy") 
		end
		
		for i = 1, #synergyiconlist.Children do
			local slot = synergyiconlist.Children[i]
			if string.len(slot.Name) >= 6 then
				local index = _UtilLogic:SubString(slot.Name, 6, 1)
				
				local sprite = synergylist:GetChildByName("RuneEffect_"..index)
				
				sprite.Enable = false
			end
		end
	end

	@ExecSpace("Client")
	method void RuneCardItemDirector_Battle(string ItemID, integer runeindex)
		-- 전투 중 룬카드로 아이템 획득 시 연출을 재생하는 함수
		--룬 카드에서 아이템을 획득했을 때 : 전투단계에 연출 보여주기
		-----------------------------------------------------------------------
		if runeindex == 0 then return end
		
		--ID에 해당되는 카드는 모두 트윈연출적용합니다.
		local Ownrune = _UserService.LocalPlayer.TeamManager.OwnRunes
		local Enemyrune = _UserService.LocalPlayer.TeamManager.EnemyOwnedRunes
		--------------------------------------------------------------------------
		
			local card = self.BattleRuneUI:GetChildByName("Rune_"..tostring(math.floor(runeindex)))
			
			--아이템(1: 아이템아이디)
			local pos = card.UITransformComponent.WorldPosition:Clone()
			
			--아이템 RUID찾기
			local itemTable = _DataService:GetTable("ItemStatus")
			local RUID = itemTable:FindRow("ItemID", ItemID):GetItem("RUID")
			
			--아이템 스폰
			local directionSprite = _EntityService:GetEntity("f937542e-9e9f-4bda-80ed-e94eebee6f65")
			local Item = directionSprite:Clone(ItemID.."Item")
			Item.Enable = false
			Item:AttachTo(_EntityService:GetEntity("218d9946-21e5-43a5-946e-6919a3c0106f"))--/ui/Arena_BattlePhase
			Item:GetChildByName("Sprite").SpriteGUIRendererComponent.ImageRUID = RUID
			Item.UITransformComponent.Pivot = Vector2(0.5, 0.5)
		
			--트윈
			Item.UITransformComponent.WorldPosition = pos:Clone()
			Item.UI_FlyingUIEntity.StartPos = Item.UITransformComponent.anchoredPosition:Clone()
			Item.UI_FlyingUIEntity.Destination = Vector2(Item.UI_FlyingUIEntity.StartPos.x, Item.UI_FlyingUIEntity.StartPos.y+50)
			Item.Enable = true
			Item.UI_FlyingUIEntity.Enable = true
	end

	@ExecSpace("Client")
	method void RC20009Director(integer lifeindex)
		-- 토푸 룬카드 효과로 하트 감소 방지 연출을 재생
		local lifelist = _EntityService:GetEntity("c3d0e78a-3eac-4467-9441-2d2a092b8ef7") -- /ui/Arena_Default/Progress/List_Life
		
		if lifeindex > _UserService.LocalPlayer.TM_PropertyControl.HP_Max then
			lifeindex =  _UserService.LocalPlayer.TM_PropertyControl.HP_Max
		end
		
		-- 토푸효과로 하트 감소 막힐 때 발동
		local effect = _EntityService:GetEntity("70987bb6-3f06-4368-aa14-db5830e82496") -- /ui/Arena_Default/DirectionSprites/DecreaseLifeEffect
		local directionsprite = effect:Clone("direction")
		directionsprite.Enable = false
		directionsprite:AttachTo(effect.Parent)
		
		-- 위치 조정
		directionsprite.UITransformComponent.WorldPosition = lifelist.Children[lifeindex].UITransformComponent.WorldPosition:Clone()
		directionsprite.Enable = true
		
		
		directionsprite.SpriteGUIRendererComponent.ImageRUID = "355803a377c64f14a781b8f48c77c86c"
		directionsprite.SpriteGUIRendererComponent.LocalScale = Vector2(0.2,0.2)
		directionsprite.Enable = true
		
		directionsprite:Destroy(1.7)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "UserService")
	handler HandleUserLeaveEvent(UserLeaveEvent event)
		-- 유저 퇴장 시 룬카드 관리 값들을 초기화하는 핸들러
		--------------- Native Event Sender Info ----------------
		-- Sender: UserService
		-- Space: Server
		---------------------------------------------------------
		
		-- Parameters
		local ProfileCode = event.ProfileCode
		local UserId = event.UserId
		---------------------------------------------------------
		if _UserService.LocalPlayer.PlayerComponent.UserId ~= UserId then return end
		
		self:InitRuneCardManagingValue("All", "")
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEntityMapChangedEvent(EntityMapChangedEvent event)
		-- 플레이어 맵 변경 시 룬카드 관리 값들을 초기화하는 핸들러
		--------------- Native Event Sender Info ----------------
		-- Sender: MODEntity
		-- Space: Server, Client
		---------------------------------------------------------
		
		-- Parameters
		local NewMap = event.NewMap
		local OldMap = event.OldMap
		local Entity = event.Entity
		---------------------------------------------------------
		if _UserService.LocalPlayer ~= Entity then return end
		
		self:InitRuneCardManagingValue("All", "")
	end

end