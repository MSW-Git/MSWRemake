@Logic
script CustomChatLogic extends Logic

	property table chatQueue = {}

	property number BROADCAST_INTERVAL = 0.2

	property integer TYPE_DEFAULT = 0

	property integer TYPE_PARTY = 1

	property integer TYPE_WHISPER = 2

	property integer TYPE_CACHED = -1

	property integer TYPE_SYSTEM = 3

	property integer TYPE_MEGAPHONE = 4

	property integer cachedDefaultMessageCount = 10

	property integer currentCachedDefaultMessageCount = 0

	property integer CharacterLimit = 50

	property number minChatInterval = 1

	property UICustomChat uiCustomChat = "3e14dff3-cc08-48f6-b90a-8ff6f78465ef"

	property boolean usingCommand = false

	property integer BroadcastedIndex_DEFAULT = 0

	property string Report_Message = ""

	property string Report_ProfileCode = ""

	property integer TimerID_UpdateDefaultMessage = 0

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 채팅 시스템 초기화 및 브로드캐스트 타이머 설정
		self.chatQueue[self.TYPE_CACHED] = {}
		self.chatQueue[self.TYPE_DEFAULT] = {}
		self.chatQueue[self.TYPE_PARTY] = {}
		self.chatQueue[self.TYPE_WHISPER] = {}
		self.chatQueue[self.TYPE_MEGAPHONE] = {}
		local lastSyncTime = 0
		--------------------------------------------------------------------------
		-- 일정 시간마다 채팅 큐에 새로운 채팅이 존재하는지 검사합니다.
		-- 새로운 채팅이 존재하면 모든 클라이언트로 채팅 업데이트를 지시합니다.
		local updateDefaultMsg = function() 
			if _UtilLogic.ServerElapsedSeconds - lastSyncTime < self.BROADCAST_INTERVAL then
				return
			end 
			lastSyncTime = _UtilLogic.ServerElapsedSeconds 
			if #self.chatQueue[self.TYPE_DEFAULT] > self.BroadcastedIndex_DEFAULT then
				local broadcastList = {}
				for i=self.BroadcastedIndex_DEFAULT+1, #self.chatQueue[self.TYPE_DEFAULT] do
					table.insert(broadcastList, self.chatQueue[self.TYPE_DEFAULT][i])
				end
				self:OnGetMessage(_HttpService:JSONEncode(broadcastList))
		        --table.clear(self.chatQueue[self.TYPE_DEFAULT])
				self.BroadcastedIndex_DEFAULT = #self.chatQueue[self.TYPE_DEFAULT]
			end
			
			if #self.chatQueue[self.TYPE_MEGAPHONE] > 0 then		
				self:OnGetMessage(_HttpService:JSONEncode(self.chatQueue[self.TYPE_MEGAPHONE]))
				table.clear(self.chatQueue[self.TYPE_MEGAPHONE])
			end
		end
		self.TimerID_UpdateDefaultMessage = _TimerService:SetTimerRepeat(updateDefaultMsg, 0.02)
	end

	@ExecSpace("Server")
	method void RequestChat(string msg, integer ts, integer type, string to)
		-- 채팅 메시지 요청 처리 및 큐에 추가
		local ppsn = senderUserId
		--------------------------------------------------------------------------
		--if Environment:IsPublishedPlay() then
		--    pcall(function() 
		--        msg = self:ReplaceNonSpaceWithAsterisk(msg)
		--    end)
		--end
		--------------------------------------------------------------------------
		local user = _UserService:GetUserEntityByUserId(ppsn)
		
		if isvalid(user) == false then
			return
		end
		
		local userInfo = _UserService.Users[ppsn]
		local profileCode = _UserService.Users[ppsn].ProfileCode
		local name = string.format("%s[%s]",userInfo.Nickname, profileCode)
		
		local data = {
			name = name,
			ppsn = ppsn,
			msg = msg,
			type = type,
			ts = ts,
		}
		
		--if type == self.TYPE_WHISPER then
		--    for k,v in pairs(_UserService.Users) do
		--        if v.ProfileCode == to then
		--            name = string.format("(귓속말) %s[%s]",userInfo.Nickname,_UserService.Users[ppsn].ProfileCode)
		--            self:OnGetMessage(_HttpService:JSONEncode({data}),v.UserId)
		--            return
		--        end		
		--    end
		--    self:AddSystemMessage("대상 유저가 접속해있지 않습니다",ppsn)
		--    return
		--elseif type == self.TYPE_PARTY then
		--    local partyIndex = user.PlayerScript.PartyIndex
		--    if partyIndex == 0 then
		--        self:AddSystemMessage("파티에 가입되어있지 않습니다.",ppsn)
		--        return
		--    end
		--    local dataJson = _HttpService:JSONEncode({data})
		--    
		--    local members = _UserPartyLogic:GetPartyMembers(partyIndex)
		--    for k,v in pairs(members) do
		--        self:OnGetMessage(dataJson,v)
		--    end
		--    return
		--elseif type == self.TYPE_MEGAPHONE then
		--    self:SendMegaphone(data)
		--    return
		--end
		
		table.insert(self.chatQueue[type], data)
		
		log("type =", type, ", #self.chatQueue[type] = ", #self.chatQueue[type])
		
		-- 100개 까지만 저장합니다.
		if #self.chatQueue[type] > 100 then
			table.remove(self.chatQueue[type], 1)
			self.BroadcastedIndex_DEFAULT -= 1
		end
		
		if type == self.TYPE_DEFAULT then
			--접속 이전의 메시지도 n개 노출시켜주기 위해서 n개 캐싱해놓는다
			local cachedIndex = self.currentCachedDefaultMessageCount%self.cachedDefaultMessageCount + 1
			self.chatQueue[self.TYPE_CACHED][cachedIndex] ={
				name = name,
				ppsn = ppsn,
				msg = msg,
				type = type,
				ts = ts,
			}
		end
		self.currentCachedDefaultMessageCount += 1
	end

	@ExecSpace("Client")
	method void OnGetMessage(string data)
		-- 서버에서 받은 채팅 데이터를 파싱하여 이벤트 발생
		-- 서버로부터 채팅 업데이트를 지시받았을 때 실행하는 함수
		-- 채팅 내역들을 정렬한 뒤, 자신(로직)에게 이벤트를 발생시킵니다.
		----------------------------------------------------------
		local chatQueue = _HttpService:JSONDecode(data)
		
		table.sort(chatQueue,function(a,b) 
			return a.ts < b.ts
		end)
		
		for k,v in pairs(chatQueue) do
			self:SendEvent(OnGetChatMessage(v.msg,v.name,v.ppsn,v.type,v))	-- 에러 아님
		end
	end

	@ExecSpace("ServerOnly")
	method string ReplaceNonSpaceWithAsterisk(string input)
		-- 공백이 아닌 모든 문자를 별표로 치환 (검열용)
		local result,error = string.gsub(input, "[^ ]", "*")
		return result
	end

	@ExecSpace("Client")
	method void AddSystemMessage(string msg)
		-- 클라이언트에서 시스템 메시지 출력
		-- (클라이언트에서) 시스템 메세지를 출력하는 함수입니다.
		---------------------------------------------------------------
		local ppsn = ""
		local ts = _UtilLogic.ServerElapsedSeconds
		self:SendEvent(OnGetChatMessage(msg,"",ppsn,self.TYPE_SYSTEM,{	-- 에러 아님
			name = "",
			ppsn = ppsn,
			msg = msg,
			ts = ts,
			to = "",
		}))
	end

	method integer GetTypeByMessage(string msg)
		-- 메시지 내용으로 채팅 타입 판별
		if self.usingCommand == false then
			return self.TYPE_DEFAULT
		end
		if self:StartsWith(msg,"\\w") then
			return self.TYPE_WHISPER
		end
		if self:StartsWith(msg,"\\p") then
			return self.TYPE_PARTY
		end
		if self:StartsWith(msg,"\\m") then
			return self.TYPE_MEGAPHONE
		end
		return self.TYPE_DEFAULT
	end

	method boolean StartsWith(string str, string prefix)
		-- 문자열이 특정 접두사로 시작하는지 확인
		return str:sub(1, #prefix) == prefix
	end

	@ExecSpace("ServerOnly")
	method void SendMegaphone(table data)
		-- 전체 서버에 확성기 메시지 전송
		_WorldInstanceService:RequestSendEventToAllWorldInstancesAsync(
			OnGetChatMessage(data.msg,data.name,data.ppsn,data.type,{}),		-- 에러 아님
			function(code,eventType) 
				if code == SendEventRequestResultCode.OK then
				
				else
					self:AddSystemMessage("메시지 전달에 실패했습니다.",data.ppsn)
				end
			end
		)
	end

	@ExecSpace("Server")
	method void RequestReport(string profileCode, string msg)
		-- 채팅 신고 요청 처리 및 신고 팝업 표시
		-- profileCode와 msg를 전송 받아 신고를 요청합니다.
		---------------------------------------------------------------
		-- 검증 : 데이터 유효성 검사
		---@type table
		local targetData = nil
		local targetIndex = 0
		
		for i=1, #self.chatQueue[self.TYPE_DEFAULT] do
			if self.chatQueue[self.TYPE_DEFAULT][i].msg == msg then
				targetData = self.chatQueue[self.TYPE_DEFAULT][i]
				targetIndex = i
			end
		end
		
		if isvalid(targetData) == false then
			log("target data is not valid")
			return
		end
		----------------------------
		local targetProfileCode = string.sub(targetData.name, -6, -2)
		
		-- 신고 대상 채팅 전후로 10개씩 채팅을 모아 함께 전달합니다.
		local reportChatList = {}
		local beforeIndex = targetIndex - 10
		local afterIndex = targetIndex + 10
		if beforeIndex < 1 then beforeIndex = 1 end
		if afterIndex > #self.chatQueue[self.TYPE_DEFAULT] then afterIndex = #self.chatQueue[self.TYPE_DEFAULT] end
		
		for i=beforeIndex, targetIndex-1 do
			table.insert(reportChatList, self.chatQueue[self.TYPE_DEFAULT][i].name..": "..self.chatQueue[self.TYPE_DEFAULT][i].msg)
		end
		for i=targetIndex+1, afterIndex do
			table.insert(reportChatList, self.chatQueue[self.TYPE_DEFAULT][i].name..": "..self.chatQueue[self.TYPE_DEFAULT][i].msg)
		end
		
		-- 신고 팝업을 띄우는 함수를 호출합니다.
		self:ShowReportPopup(
			targetData.ppsn, 
			targetData.name, 
			senderUserId, 
			msg, 
			_UtilLogic:TableToString(reportChatList), 
			senderUserId
		)
	end

	@ExecSpace("Client")
	method void ShowReportPopup(string userID, string nickName, string profileCode, string reportChat, string userChats)
		-- 신고 팝업 UI 표시
		if userID == _UserService.LocalPlayer.OwnerId then
			return
		end
		
		
	end

	@ExecSpace("Client")
	method void ShowReportSuccessPopup()
		-- 신고 성공 팝업 표시
		log("성공적으로 신고되었다!")
	end

	@ExecSpace("ServerOnly")
	method void OnEndPlay()
		-- 게임 종료 시 타이머 정리
		_TimerService:ClearTimer(self.TimerID_UpdateDefaultMessage)
		self.TimerID_UpdateDefaultMessage = 0
	end

	@EventSender("Service", "UserService")
	handler HandleUserEnterEvent(UserEnterEvent event)
		-- 사용자 입장 시 캐시된 채팅 메시지 전송
		--------------- Native Event Sender Info ----------------
		-- Sender: UserService
		-- Space: Server
		---------------------------------------------------------
		
		-- Parameters
		local UserId = event.UserId
		---------------------------------------------------------
		if self.currentCachedDefaultMessageCount > 0 then
			self:OnGetMessage(_HttpService:JSONEncode(self.chatQueue[self.TYPE_CACHED]),UserId)
		end
	end

	@EventSender("Service", "WorldInstanceService")
	handler HandleOnGetChatMessage(OnGetChatMessage event)
		-- 다른 서버에서 온 채팅 메시지 처리
		-- Parameters
		local msg = event.msg
		local name = event.name
		local ppsn = event.ppsn
		local type = event.type
		--local extra = event.extra
		---------------------------------------------------------
		
		
		table.insert(self.chatQueue[type],{
			name = name,
			ppsn = ppsn,
			msg = msg,
			type = type,
			ts = _UtilLogic.ServerElapsedSeconds,
		})
		
	end

end