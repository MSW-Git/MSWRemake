            {
              "@type": "MOD.Core.TextComponent",
              "Alignment": 0,
              "AllowAutomaticTranslation": false,
              "Bold": false,
              "ConstraintX": 830.0,
              "ConstraintY": 154.0,
              "FontColor": {
                "r": 0.858823538,
                "g": 0.894117653,
                "b": 0.929411769,
                "a": 1.0
              },
              "FontSize": 15,
              "InternalFontName": "Paperlogy-5Medium",
              "IsLocalizationKey": true,
              "MaxSize": 40,
              "MinSize": 10,
              "OutlineDistance": {
                "x": 1.0,
                "y": -1.0
              },
              "OverrideSorting": false,
              "SizeFit": true,
              "Text": "전투 시작 시, 거대 괘종시계에 탑승합니다. 탑승 중 기본 공격 시 양손으로 내려찍어 주변 1칸 이내 적에게 {0}({1}+{2})만큼의 물리 피해를 입힙니다. 체력이 50% 미만이 되면 비상탈출하면서 괘종시계를 터뜨려 주변 모든 적에게 {3}({4}+{5})만큼의 고정 피해를 입힙니다.",
              "UseConstraintX": true,
              "UseConstraintY": false,
              "Enable": true
            }
          ],
          "@version": 1
        }
      },
