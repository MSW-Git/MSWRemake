            {
              "@type": "MOD.Core.TextComponent",
              "Alignment": 0,
              "AllowAutomaticTranslation": false,
              "BestFit": false,
              "Bold": false,
              "ConstraintX": 314.0,
              "ConstraintY": 219.607849,
              "FontColor": {
                "r": 0.858823538,
                "g": 0.894117653,
                "b": 0.929411769,
                "a": 1.0
              },
              "FontSize": 15,
              "InternalFontName": "Paperlogy-5Medium",
              "IsLocalizationKey": true,
              "MaxSize": 40,
              "MinSize": 10,
              "OutlineDistance": {
                "x": 1.0,
                "y": -1.0
              },
              "OverrideSorting": false,
              "SizeFit": true,
              "Text": "고유 : 추격자는 새로운 공격 대상을 찾을 때, 마법 방어력이 가장 낮은 적을 타겟으로 합니다.\\n추격자의 이동속도가 100% 증가하고, 대상 체력에 따라 공격 및 스킬이 크리티컬로 적용됩니다.\\n\\n(2) 체력 35% 미만인 적에게 크리티컬로 적용\\n(4) 체력 70% 미만인 적에게 크리티컬로 적용\\n(6) 무조건 크리티컬로 적용, 크리티컬 데미지 +10%",
              "UseConstraintX": true,
              "UseConstraintY": false,
              "Enable": true
            }
          ],
          "@version": 1
        }
      },
      {
