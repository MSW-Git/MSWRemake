@Component
script CraftingMaterialSlot extends Component

	property string itemId = ""

	property integer itemCount = 0

	property integer index = 0

	method void Init(string itemId, integer itemCount, integer index)
		-- 제작 재료 슬롯 초기화 및 아이템 정보 설정
		self.itemId = itemId
		self.itemCount = itemCount
		self.index = index
		
		local craftingCount = _CraftingLogic.craftingCount
		local itemData = _ItemDataLogic.itemData[self.itemId]
		
		local haveCount = 0
		local needCount = 0
			
		if itemData ~= nil then
			haveCount = _CraftingLogic:GetUserItemCount(self.itemId, _UserService.LocalPlayer.PlayerComponent.UserId)
			needCount = self.itemCount * craftingCount
		end
		
		_CraftingLogic:SetCraftingSlot(self.Entity:GetChildByName("Item_Slot", true), self.itemId)	
		self.Entity:GetChildByName("Name_MaterialItem", true).TextComponent.Text = _LocalizeLogic:GetItemName(itemId)
		
		self:ChangeCount()
	end

	method void ChangeCount()
		-- 재료 아이템 보유/필요 수량 비교 및 UI 업데이트
		local haveCount = _CraftingLogic:GetUserItemCount(self.itemId, _UserService.LocalPlayer.PlayerComponent.UserId)
		local needCount = self.itemCount * _CraftingLogic.craftingCount
		
		if haveCount >= needCount then
			self.Entity:GetChildByName("Count_MaterialItem").TextComponent.FontColor = Color.white
			self.Entity:GetChildByName("Count_MaterialItem").TextComponent.Text =  string.format("%d/%d", haveCount, needCount)
		else
			self.Entity:GetChildByName("Count_MaterialItem").TextComponent.FontColor = Color.FromHexCode("#FF6868")
			self.Entity:GetChildByName("Count_MaterialItem").TextComponent.Text =  string.format("%d/%d", haveCount, needCount)
		end
	end

end