@Component
script CraftingTypeTabButton extends Component

	property string type = ""

	method void Init(string typeName, integer index)
		-- 제작 타입 탭 버튼 초기화 및 기본 선택 설정
		self.type = typeName
		self.Entity.TextComponent.Text = _LocalizationService:GetText(typeName)
		
		if _CraftingLogic.resetCategoryType == true and index == 1 then
			_CraftingLogic.resetCategoryType = false
			self:Selected(true)
			self:OnClick()
		else
			self:Selected(false)
		end
	end

	method void Selected(boolean isSelected)
		-- 타입 탭 버튼 선택 상태 UI 업데이트
		if isSelected then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "994e2ad676fe4b4c9782186b06f02a4a"
			self.Entity.TextComponent.FontColor = Color.FromHexCode("#FFFFFF")
			
		else
				
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "6cb1470eea884424886399b0fc9f3c95"
			self.Entity.TextComponent.FontColor = Color.FromHexCode("#a0acca")
		end
	end

	method void OnClick()
		-- 타입 탭 버튼 클릭 시 제작 UI 탭 변경
		_CraftingLogic.UICrafting:ChangeItemTypeTab(self.type)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 타입 탭 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		
		if _UtilLogic:IsNilorEmptyString(_CraftingLogic.selectedCategory) or _UtilLogic:IsNilorEmptyString(self.type) then
			return
		end 
		
		self:OnClick()
	end

end