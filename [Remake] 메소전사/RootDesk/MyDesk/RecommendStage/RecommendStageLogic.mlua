@Logic
script RecommendStageLogic extends Logic

	property table clearAndReward = {}

	method void OnBeginPlay()
		-- 추천 스테이지 클리어 및 보상 데이터 초기화
		local data = _DataService:GetTable("ClearAndRewardData")
		
		for i = 1, data:GetRowCount() do
		
			local clearAndReward = {}
			
			clearAndReward.id = data:GetCell(i, "id")
			clearAndReward.clearCount = tonumber(data:GetCell(i, "clearCount"))
			clearAndReward.index = clearAndReward.clearCount
			if i > 1 then
				clearAndReward.index = clearAndReward.clearCount - self.clearAndReward[tostring(i - 1)].clearCount
			end
			clearAndReward.rewardType = data:GetCell(i, "rewardType")
			clearAndReward.rewardId = data:GetCell(i, "rewardId")
			clearAndReward.rewardNum = tonumber(data:GetCell(i, "rewardNum"))
			
			self.clearAndReward[clearAndReward.id] = clearAndReward
		end
	end

end