@Logic
script UIPopup extends Logic

	property TextComponent message = "3606e39d-32de-427e-8d23-b38af810a3b4"

	property ButtonComponent btnOk = "94a274e4-4111-40f1-924d-c95a3a1f14d5"

	property ButtonComponent btnCancel = "0f5de49b-2adc-409a-816d-15aa43df8e0d"

	property Entity popupGroup = "fb7a3b06-7026-4590-8efe-bb33416dd8f9"

	property Entity popup = "aa954759-0e39-430f-85fa-80bf2e5fe31d"

	property any onOk = nil

	property any onCancel = nil

	property number duration = 0.15

	property number from = 0.5

	property number to = 1

	property boolean isOpen = false

	property boolean isTweenPlaying = false

	property number tweenEventId = 0

	property any okHandler = nil

	property any cancelHandler = nil

	property Entity popUpBack = "e25e8e41-5cb9-4fae-8dc0-ea7dca85a91d"

	property Entity panelDefault = "f85663bf-3b75-4634-b416-60fb47410a1c"

	property Entity panelSell = "d0690ceb-bd7e-42aa-96a9-61e7779a3059"

	property Entity panelMerge = "9b497a52-697c-423c-aded-9af989b593c0"

	property UINewMergeItem sellWeapon = "7868b3dd-3b0b-42cf-b4c8-a4ed8042fb03"

	property TextComponent textCost = "54f25bfc-a3aa-4fbf-8d58-17503ca0d1e3"

	property TextComponent textSellName = "ef19324c-0040-4455-8f72-6379637ed8f2"

	property TextComponent textTitle = "ea0b9115-6ac6-4d07-b75e-3ada0eaec1c8"

	property UINewMergeItem mergeItem = "a16a0c86-ad8b-4812-896a-638f182f752c"

	property TextComponent textMergeMessage = "9311faf9-6c40-4531-b33f-ca0dde892082"

	property TextComponent textMergeSubMessage = "9f1a19f9-ca0d-49bb-b219-4d465fde0855"

	property TextComponent textMergeName = "8a9d13f6-6438-4e8a-8973-909a2d265ec7"

	property Entity panelPurchase = "ee83222c-7674-489d-bba1-e65778bfcb17"

	property TextComponent purchaseMessage = "b8f8cbab-e6fe-454a-9d65-5fedd92d424e"

	property TextComponent purchaseSubMessage = "8fc7ce91-2d43-4409-bb8b-4975c673ba7b"

	property SpriteGUIRendererComponent purchaseCurrencyIcon = "1fa71a84-73d1-46e1-be17-ba156da92911"

	property TextComponent purchaseCurrencyValue = "dfb0e713-6a89-4097-9353-cdbf69205c2f"

	property Entity itemPanel = "6706cd47-c5cb-43e8-9b17-f2de2e917d14"

	property string currentUniqueKey = ""

	property string currentId = ""

	@HideFromInspector
	property integer countNum = 1

	property TextComponent countText = "470f0a7c-dde1-4580-bef2-edbb47757148"

	property integer previousCountNum = 0

	property number requestedTime = 0

	method void Open(string title, string message, any onOk, any onCancel)
		-- 기본 팝업을 열고 제목, 메시지, 콜백 설정
		_UIPopup:ForceClose()
		_UIOnlyConfirmPopUp:ForceClose()
		_SelectSoulPiecePopUp:ForceClose()
		table.insert(_UIGroupManager.selectedPopup, self)
		
		if self.isOpen == true then
			return
		end
		self:SetPopupType("default")
		self.isOpen = true
		self.popUpBack.Enable = true
		self.popupGroup.Enable = true
		self.message.Text = message
		self.message.Enable = true
		self.textTitle.Text = title
		self.onOk = onOk
		self.onCancel = onCancel
		self.okHandler = self.btnOk.Entity:ConnectEvent(ButtonClickEvent,self.OnClickOk)
		self.cancelHandler = self.btnCancel.Entity:ConnectEvent(ButtonClickEvent,self.OnClickCancel)
		self:StartTween(true)
	end

	method void OnClickOk()
		-- 확인 버튼 클릭 시 콜백 실행 및 팝업 닫기
		if self.isTweenPlaying == true then
			return
		end
		if self.onOk ~= nil then
			self.onOk()
			self.onOk = nil
		end
		
		self:Close()
	end

	method void OnClickCancel()
		-- 취소 버튼 클릭 시 콜백 실행 및 팝업 닫기
		if self.isTweenPlaying == true then
			return
		end
		if self.onCancel ~= nil then
			self.onCancel()
			self.onCancel = nil
		end
		self:Close()
	end

	method void Close()
		-- 팝업을 닫고 이벤트 연결 해제 및 상태 초기화
		for k,v in ipairs(_UIGroupManager.selectedPopup) do
			if v == self then
				table.remove(_UIGroupManager.selectedPopup,k)
			end
		end
		self.btnOk.Entity:DisconnectEvent(ButtonClickEvent,self.okHandler)
		self.btnCancel.Entity:DisconnectEvent(ButtonClickEvent,self.cancelHandler)
		self:StartTween(false)
		self.currentUniqueKey = ""
		self.currentId = ""
		self.countNum = 1
	end

	method void StartTween(boolean open)
		-- 팝업 열기/닫기 애니메이션 시작
		_TimerService:ClearTimer(self.tweenEventId)
		
		local transform = self.popup.UITransformComponent
		local canvasGroup = self.popupGroup.CanvasGroupComponent 
		if open == true then
			canvasGroup.GroupAlpha = 0
			transform.UIScale = Vector3(self.from,self.from,1)
		else
			transform.UIScale = Vector3(self.to,self.to,1)
		end
		self.isTweenPlaying = true
		local time = 0
		
		
		local preTime = _UtilLogic.ElapsedSeconds
		
		local tween = function()
			local delta = _UtilLogic.ElapsedSeconds - preTime
			time = time + delta
			local timeValue = time	
			preTime = _UtilLogic.ElapsedSeconds
		
			if time >= self.duration then
				timeValue = self.duration
				if open == false then
					self.popupGroup.Enable = false
					self.isOpen = false
					self.popUpBack.Enable = true
		
					for k,v in ipairs(_UIGroupManager.selectedPopup) do
						if v == self then
							table.remove(_UIGroupManager.selectedPopup,k)
						end
					end
				end
				self.isTweenPlaying = false
				_TimerService:ClearTimer(self.tweenEventId)
		
			end
			if open == false then
				timeValue = self.duration - timeValue
			end
			local tweenValue = _TweenLogic:Ease(self.from, self.to, 
				self.duration, EaseType.SineEaseIn, timeValue)
			transform.UIScale = Vector3(tweenValue,tweenValue,1)
			canvasGroup.GroupAlpha = timeValue / self.duration
		end
		self.tweenEventId = _TimerService:SetTimerRepeat(tween,1/60)
		
	end

	@ExecSpace("ClientOnly")
	method void ForceClose()
		-- 팝업을 강제로 닫고 모든 상태 초기화
		local transform = self.popup.UITransformComponent
		local canvasGroup = self.popupGroup.CanvasGroupComponent
		
		_TimerService:ClearTimer(self.tweenEventId)
		self.popupGroup.Enable = false
		self.isOpen = false
		self.popUpBack.Enable = false
		self.isTweenPlaying = false
		transform.UIScale = Vector3(self.to,self.to,1)
		
		self.okHandler = self.btnOk.Entity:ConnectEvent(ButtonClickEvent,self.OnClickOk)
		self.cancelHandler = self.btnCancel.Entity:ConnectEvent(ButtonClickEvent,self.OnClickCancel)
		self.btnOk.Entity:DisconnectEvent(ButtonClickEvent,self.okHandler)
		self.btnCancel.Entity:DisconnectEvent(ButtonClickEvent,self.cancelHandler)
		
		for k,v in ipairs(_UIGroupManager.selectedPopup) do
			if v == self then
				table.remove(_UIGroupManager.selectedPopup,k)
			end
		end
		
		self.currentUniqueKey = ""
		self.currentId = ""
		self.countNum = 1
		self.countText.Text = "1"
	end

	method void OpenSellPopup(string title, string message, string uniqueKey, number cost, any onOk, any onCancel)
		-- 아이템 판매 팝업을 열고 아이템 정보와 가격 표시
		self:Open(title,"",onOk,onCancel)
		self:SetPopupType("sell")
		self.textSellName.Text = message
		self.textCost.Text = string.format("%s",_NumberSeparator:ConvertToMetricPrefixString(cost,"ko"))
		self.sellWeapon:SetWeaponID(uniqueKey,_UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey])
	end

	method void SetPopupType(string type)
		-- 팝업 타입에 따라 적절한 패널 활성화/비활성화
		if type == "sell" then
			self.panelSell.Enable = true
			self.panelDefault.Enable = false
			self.panelMerge.Enable = false
			self.panelPurchase.Enable = false
			self.itemPanel.Enable = false
		elseif type == "merge" then
			self.panelSell.Enable = false
			self.panelDefault.Enable = false
			self.panelMerge.Enable = true
			self.panelPurchase.Enable = false
			self.itemPanel.Enable = false
		elseif type == "purchase" then
			self.panelSell.Enable = false
			self.panelDefault.Enable = false
			self.panelMerge.Enable = false
			self.panelPurchase.Enable = true
			self.itemPanel.Enable = false
		elseif type == "sellItem" then
			self.panelSell.Enable = false
			self.panelDefault.Enable = false
			self.panelMerge.Enable = false
			self.panelPurchase.Enable = false
			self.itemPanel.Enable = true
		elseif type == "use" then
			self.panelSell.Enable = false
			self.panelDefault.Enable = false
			self.panelMerge.Enable = false
			self.panelPurchase.Enable = false
			self.itemPanel.Enable = true
		else
			self.panelSell.Enable = false
			self.panelDefault.Enable = true
			self.panelMerge.Enable = false
			self.panelPurchase.Enable = false
			self.itemPanel.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 팝업 초기화 및 스프라이트 설정
		self.sellWeapon:InitSprite()
		self.mergeItem:InitSprite()
	end

	@ExecSpace("ClientOnly")
	method void OpenMergeItem(string title, string message, string subMessage, string itemName, string uniqueKey, any onOk, any onCancel)
		-- 아이템 합성 팝업을 열고 합성 아이템 정보 표시
		self:Open(title,"",onOk,onCancel)
		self:SetPopupType("merge")
		self.textMergeMessage.Text = message
		self.textMergeSubMessage.Text = subMessage
		self.textMergeName.Text = itemName
		self.mergeItem:SetWeaponID(uniqueKey,_UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey])
	end

	@ExecSpace("ClientOnly")
	method void OpenPurchasePopup(string title, string message, string subMessage, string currencyType, integer value, any onOk, any onCancel)
		-- 구매 팝업을 열고 가격 및 통화 정보 표시
		self:Open(title, "", onOk, onCancel)
		self:SetPopupType("purchase")
		self.purchaseMessage.Text = message
		self.purchaseSubMessage.Text = subMessage
		
		local coinRUID = _ItemDataLogic:GetCoinRUID(currencyType)
		self.purchaseCurrencyIcon.ImageRUID = coinRUID
		self.purchaseCurrencyValue.FontColor = Color.white
		
		if title == _LocalizeLogic:GetText("popup48") then
			if value > _UserService.LocalPlayer.PlayerCurrencyData.currencyTable["Diamond"].amount then
				self.purchaseCurrencyValue.FontColor = Color.FromHexCode("#FF6868")
			end
			self.purchaseCurrencyValue.Text = string.format("%d/%d", _UserService.LocalPlayer.PlayerCurrencyData.currencyTable["Diamond"].amount, value)
		else
			self.purchaseCurrencyValue.Text = string.format("%d", value)
		end
		
		
		
	end

	@ExecSpace("ClientOnly")
	method void OpenSellItem(string uniqueKey)
		-- 아이템 판매 팝업을 열고 아이템 정보와 가격 표시
		_UIPopup:ForceClose()
		_UIOnlyConfirmPopUp:ForceClose()
		
		local storageCompo = _UserService.LocalPlayer.PlayerStorageComponent
		local storage = storageCompo.storage
		
		if not isvalid(storage[uniqueKey]) then
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:ForceClose()
			
			return
		end
		
		local item = storage[uniqueKey]
		
		if item.equippedSlotNum > 0 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast346"))
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:ForceClose()
			
			return
		end
		
		local itemData = _ItemDataLogic.itemData[item.originalId]
		
		if not isvalid(itemData) then
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:ForceClose()
			
			return
		end
		
		local category = itemData.category
		local isCanSellMultiple = true
		self.currentId = item.originalId
		
		if category == "decoration" then
			local decoData = _ItemDataLogic.decorationData[self.currentId]
			category = decoData.category
			isCanSellMultiple = false
		end
		
		local sell = function()
			if _UtilLogic:IsNilorEmptyString(self.currentId) or self.countNum <= 0 then
				_UIToast:ShowMessage("Invalid request.")
				_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
				self:Close()
				
				return
			end
			
			_UIGroupManager.playerStatusPopup.UIPlayerStatusPopup:SetUIInputEnable(false)
			storageCompo:RequestSellItemByCount(self.currentId, self.countNum)
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:Close()
		end
		
		self:Open2(_LocalizeLogic:GetText("etcStr200"), sell, nil)
		
		self.currentUniqueKey = uniqueKey
		
		self:SetPopupType("sellItem")
		
		local count = storageCompo:GetItemCount(item.originalId)
		
		local layout = self.itemPanel:GetChildByName("Scroll_Layout")
		local itemPanel = layout:GetChildByName("item_panel")
		local itemSlot = itemPanel:GetChildByName("item_slot")
		local iconRenderer = itemSlot:GetChildByName("item").SpriteGUIRendererComponent
		local bgRenderer = itemSlot:GetChildByName("icon_bg").SpriteGUIRendererComponent
		local categoryBgRenderer = itemSlot:GetChildByName("panel_category").SpriteGUIRendererComponent
		local categoryIconRenderer = itemSlot:GetChildByName("icon_category").SpriteGUIRendererComponent
		local nameText = itemSlot:GetChildByName("name").TextComponent
		local countPanel = layout:GetChildByName("count_panel")
		local costPanel = layout:GetChildByName("cost_panel")
		local costText = costPanel:GetChildByName("text_cost").TextComponent
		
		iconRenderer.ImageRUID = itemData.ruid
		iconRenderer.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
		bgRenderer.ImageRUID = _GameUtil:GetBackgroundRUIDByItemGrade(itemData.grade)
		categoryBgRenderer.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
		categoryIconRenderer.ImageRUID = _GameUtil:GetCategoryIconRUID(category)
		nameText.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(itemData.grade))
		nameText.Text = string.format("[%s] %s", _LocalizationService.LocalTranslator:GetText(itemData.grade), _LocalizeLogic:GetItemName(self.currentId))
		costText.Text = string.format("%d", itemData.sellingPrice)
		
		if count <= 1 or not isCanSellMultiple then
			countPanel.Enable = false
		else
			self.countText.Text = "1"
			countPanel.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void OpenUseItem(string uniqueKey)
		-- 아이템 사용 팝업을 열고 사용 가능 여부 확인
		_UIPopup:ForceClose()
		_UIOnlyConfirmPopUp:ForceClose()
		
		local storageCompo = _UserService.LocalPlayer.PlayerStorageComponent
		local storage = storageCompo.storage
		
		if not isvalid(storage[uniqueKey]) then
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:ForceClose()
			
			return
		end
		
		local item = storage[uniqueKey]
		local itemData = _ItemDataLogic.itemData[item.originalId]
		
		
		if not isvalid(itemData) then
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:ForceClose()
			
			return
		end
		
		local category = itemData.category
		
		if category == "decoration" then
			local decoData = _ItemDataLogic.decorationData[category]
			category = decoData.category
		end
		
		local title = _LocalizeLogic:GetText("etcStr201")
		
		local use = function()
			if _UtilLogic:IsNilorEmptyString(self.currentId) or self.countNum <= 0 then
				_UIToast:ShowMessage("Invalid request.")
				_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
				self:Close()
				
				return
			end
			if self.requestedTime + 0.5 > _UtilLogic.ServerElapsedSeconds then 
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
				_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
				self:Close()
		
				return 
			end
		
			self.requestedTime = _UtilLogic.ServerElapsedSeconds
			
			if not _ConsumeLogic:IsCanUseItemInClient(self.currentId, self.countNum) then
				_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
				self:Close()
				
				return
			end
			
			if self.currentId == "6_000051" then
				self:ForceClose()
				_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:ForceClose()
				_TimerService:SetTimerOnce(function() _SelectSoulPiecePopUp:Open() end, 0.16)
			else
				_UIGroupManager.playerStatusPopup.UIPlayerStatusPopup:SetUIInputEnable(false)
				storageCompo:RequestUseItemById(self.currentId, self.countNum)
				_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
				self:Close()
			end
		end
		
		self:Open2(title, use, nil)
		self:SetPopupType("use")
		
		self.currentUniqueKey = uniqueKey
		self.currentId = item.originalId
		
		local count = storageCompo:GetItemCount(item.originalId)
		
		local layout = self.itemPanel:GetChildByName("Scroll_Layout")
		local itemPanel = layout:GetChildByName("item_panel")
		local itemSlot = itemPanel:GetChildByName("item_slot")
		local iconRenderer = itemSlot:GetChildByName("item").SpriteGUIRendererComponent
		local bgRenderer = itemSlot:GetChildByName("icon_bg").SpriteGUIRendererComponent
		local categoryBgRenderer = itemSlot:GetChildByName("panel_category").SpriteGUIRendererComponent
		local categoryIconRenderer = itemSlot:GetChildByName("icon_category").SpriteGUIRendererComponent
		local nameText = itemSlot:GetChildByName("name").TextComponent
		local countPanel = layout:GetChildByName("count_panel")
		local costPanel = layout:GetChildByName("cost_panel")
		
		iconRenderer.ImageRUID = itemData.ruid
		iconRenderer.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
		bgRenderer.ImageRUID = _GameUtil:GetBackgroundRUIDByItemGrade(itemData.grade)
		categoryBgRenderer.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
		categoryIconRenderer.ImageRUID = _GameUtil:GetCategoryIconRUID(category)
		nameText.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(itemData.grade))
		nameText.Text = string.format("[%s] %s", _LocalizationService.LocalTranslator:GetText(itemData.grade), _LocalizeLogic:GetItemName(self.currentId))
		costPanel.Enable = false
		
		if count <= 1 or category == "nameTag" or category == "damageSkin" or category == "chatBalloon" then
			title = _LocalizeLogic:GetText("etcStr202")
			countPanel.Enable = false
		else
			countPanel:GetChildByName("text_count").TextComponent.Text = "1"
			
			if self.currentId == "6_000001" or self.currentId == "6_000051" then
				countPanel.Enable = false
			else
				countPanel.Enable = true
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Open2(string title, any onOk, any onCancel)
		-- 메시지 없이 제목만 있는 팝업 열기
		table.insert(_UIGroupManager.selectedPopup, self)
		
		if self.isOpen == true then
			return
		end
		self:SetPopupType("default")
		self.isOpen = true
		self.popUpBack.Enable = true
		self.popupGroup.Enable = true
		self.message.Enable = false
		self.textTitle.Text = title
		self.onOk = onOk
		self.onCancel = onCancel
		self.okHandler = self.btnOk.Entity:ConnectEvent(ButtonClickEvent,self.OnClickOk)
		self.cancelHandler = self.btnCancel.Entity:ConnectEvent(ButtonClickEvent,self.OnClickCancel)
		self:StartTween(true)
	end

	@ExecSpace("ClientOnly")
	method void CheckCountInputText(string text)
		-- 입력된 개수 텍스트의 유효성 검사 및 범위 제한
		if not isvalid(tonumber(text)) then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast345"))
			self.countText.Text = "1"
			
			return
		end
		
		if _UtilLogic:IsNilorEmptyString(self.currentId) then 
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Hide()
			self:ForceClose()
		
			return 
		
		end
		
		if self.previousCountNum == tonumber(text) then return end
		
		local storageCompo = _UserService.LocalPlayer.PlayerStorageComponent
		local maxCount = storageCompo:GetItemCount(self.currentId)
		local textNum = tonumber(text)
		
		if textNum <= 0 then
			self.countText.Text = "1"
		elseif textNum >= maxCount then
			self.countText.Text = tostring(maxCount)
		end
		
		self.countNum = tonumber(self.countText.Text)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "83e34367-62e0-4937-b36d-85317836ca6c")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 개수 증가 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UtilLogic:IsNilorEmptyString(self.currentId) then 
			self.countText.Text = "1"
			return 
		end
		
		local storageCompo = _UserService.LocalPlayer.PlayerStorageComponent
		local maxCount = storageCompo:GetItemCount(self.currentId)
		local textNum = tonumber(self.countText.Text)
		
		if textNum >= maxCount then
			self.countText.Text = tostring(maxCount)
		else
			self.countText.Text = string.format("%d", textNum + 1)
		end
		
		self.countNum = tonumber(self.countText.Text)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "25739959-bbb3-4420-b9db-747ba54d2757")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 개수 감소 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UtilLogic:IsNilorEmptyString(self.currentId) then 
			self.countText.Text = "1"
			
			return 
		end
		
		local storageCompo = _UserService.LocalPlayer.PlayerStorageComponent
		local maxCount = storageCompo:GetItemCount(self.currentId)
		local textNum = tonumber(self.countText.Text)
		
		if textNum <= 1 then
			self.countText.Text = "1"
		else
			self.countText.Text = string.format("%d", textNum - 1)
		end
		
		self.countNum = tonumber(self.countText.Text)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "470f0a7c-dde1-4580-bef2-edbb47757148")
	handler HandleTextInputValueChangeEvent(TextInputValueChangeEvent event)
		-- 텍스트 입력 값 변경 이벤트 처리
		
		local text = event.text
		self:CheckCountInputText(text)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "470f0a7c-dde1-4580-bef2-edbb47757148")
	handler HandleTextInputEndEditEvent(TextInputEndEditEvent event)
		-- 텍스트 입력 종료 이벤트 처리
		
		local text = event.text
		self:CheckCountInputText(text)
	end

end