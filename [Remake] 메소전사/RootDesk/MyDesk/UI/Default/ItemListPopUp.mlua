@Logic
script ItemListPopUp extends Logic

	property GridViewComponent itemGridView = "b9a9f066-4ffb-4309-a0b0-e85173d126a4"

	property ButtonComponent btnCancel = "37d66759-71b9-46c4-8a61-e6927853f868"

	property Entity popupGroup = "1ab176aa-13dd-4ae6-8d09-2e6de943af1c"

	property Entity popup = "4df8dbbb-1f20-48bf-b897-e02287d5e1b7"

	property any onCancel = nil

	property number duration = 0.15

	property number from = 0.5

	property number to = 1

	property boolean isOpen = false

	property boolean isTweenPlaying = false

	property number tweenEventId = 0

	property any okHandler = nil

	property any cancelHandler = nil

	property Entity popUpBack = "43a5ba00-4c0e-4a56-9635-bf31bb3514dc"

	property Entity originalSlot = "f11fbc5d-6d48-420b-95de-4539059917be"

	property table itemInfos = {}

	property TextComponent titleText = "43479001-6c7c-4a10-aa8e-19595c128563"

	@ExecSpace("ClientOnly")
	method void Open(table itemInfos, any onCancel, string titleText)
		-- 아이템 목록 팝업을 열고 아이템 정보를 표시
		_UIPopup:ForceClose()
		_UIOnlyConfirmPopUp:ForceClose()
		table.insert(_UIGroupManager.selectedPopup, self)
		
		if titleText == "획득" then 
			titleText = _LocalizeLogic:GetText("etcStr219")
		end
		
		self.titleText.Text = titleText
		
		local lastIndex = 0
		
		if self.isOpen == true then
			lastIndex = #self.itemInfos
		end
		
		for key, value in pairs(itemInfos) do
			local needIndexIncrease = true
			
			for k, v in pairs(self.itemInfos) do
				if v.itemType == value.itemType and v.id == value.id then
					v.count += value.count
					needIndexIncrease = false
					
					break
				end
			end
			
			if needIndexIncrease then
		
				lastIndex += 1
				
				self.itemInfos[lastIndex] = value
			end
		end
		
		if self.isOpen == true then
			self.itemGridView.TotalCount = #self.itemInfos
			self.itemGridView:Refresh(true, true)
			self.onCancel = onCancel
			
			return
		end
		self.isOpen = true
		self.popUpBack.Enable = true
		self.popupGroup.Enable = true
		self.itemGridView.TotalCount = #self.itemInfos
		self.itemGridView:Refresh(true, true)
		self.onCancel = onCancel
		
		
		self.cancelHandler = self.btnCancel.Entity:ConnectEvent(ButtonClickEvent,self.OnClickCancel)
		self:StartTween(true)
	end

	@ExecSpace("ClientOnly")
	method void OnClickCancel()
		-- 취소 버튼 클릭 시 팝업 닫기
		if self.isTweenPlaying == true then
			return
		end
		
		self:Close()
		
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 아이템 목록 팝업을 닫고 이벤트 연결 해제
		if self.onCancel ~= nil then
			self.onCancel()
			self.onCancel = nil
		end
		self.btnCancel.Entity:DisconnectEvent(ButtonClickEvent,self.cancelHandler)
		self:StartTween(false)
		
		for k,v in ipairs(_UIGroupManager.selectedPopup) do
			if v == self then
				table.remove(_UIGroupManager.selectedPopup,k)
			end
		end
		
		table.clear(self.itemInfos)
	end

	@ExecSpace("ClientOnly")
	method void StartTween(boolean open)
		-- 팝업 열기/닫기 애니메이션 시작
		if open then
		else
		end
		local transform = self.popup.UITransformComponent
		local canvasGroup = self.popupGroup.CanvasGroupComponent 
		if open == true then
			canvasGroup.GroupAlpha = 0
			transform.UIScale = Vector3(self.from,self.from,1)
		else
			transform.UIScale = Vector3(self.to,self.to,1)
		end
		self.isTweenPlaying = true
		local time = 0
		
		
		local preTime = _UtilLogic.ElapsedSeconds
		
		local tween = function()
			local delta = _UtilLogic.ElapsedSeconds - preTime
			time = time + delta
			local timeValue = time	
			preTime = _UtilLogic.ElapsedSeconds
		
			if time >= self.duration then
				timeValue = self.duration
				if open == false then
					self.popupGroup.Enable = false
					self.isOpen = false
					self.popUpBack.Enable = true
					table.clear(self.itemInfos)
		
					for k,v in ipairs(_UIGroupManager.selectedPopup) do
						if v == self then
							table.remove(_UIGroupManager.selectedPopup,k)
						end
					end
				end
				self.isTweenPlaying = false
				_TimerService:ClearTimer(self.tweenEventId)
		
			end
			if open == false then
				timeValue = self.duration - timeValue
			end
			local tweenValue = _TweenLogic:Ease(self.from, self.to, 
				self.duration, EaseType.SineEaseIn, timeValue)
			transform.UIScale = Vector3(tweenValue,tweenValue,1)
			canvasGroup.GroupAlpha = timeValue / self.duration
		end
		self.tweenEventId = _TimerService:SetTimerRepeat(tween,1/60)
		
	end

	@ExecSpace("ClientOnly")
	method void ForceClose()
		-- 아이템 목록 팝업을 강제로 닫기
		_UIPopup:ForceClose()
		_UIOnlyConfirmPopUp:ForceClose()
		
		local transform = self.popup.UITransformComponent
		local canvasGroup = self.popupGroup.CanvasGroupComponent
		
		self.popupGroup.Enable = false
		self.isOpen = false
		self.popUpBack.Enable = true
		self.isTweenPlaying = false
		_TimerService:ClearTimer(self.tweenEventId)
		transform.UIScale = Vector3(self.to,self.to,1)
		
		self.btnCancel.Entity:DisconnectEvent(ButtonClickEvent,self.cancelHandler)
		
		for k,v in ipairs(_UIGroupManager.selectedPopup) do
			if v == self then
				table.remove(_UIGroupManager.selectedPopup,k)
			end
		end
		
		table.clear(self.itemInfos)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 아이템 목록 팝업 초기화 및 그리드뷰 설정
		self.itemGridView.ItemEntity = self.originalSlot
		self.itemGridView.OnRefresh = function(index, entity)
			---@type Entity
			local newEntity = entity
			local itemInfo = self.itemInfos[index + 1]
			local grade = ""
			
			if not _UtilLogic:IsNilorEmptyString(itemInfo.grade) then
				grade = itemInfo.grade
			end
			
			newEntity.PopUpItemSlotComponent:SetSlot(itemInfo.itemType, itemInfo.id, itemInfo.count, grade)
		end
	end

end