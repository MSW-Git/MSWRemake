@Component
script UIMergeResultPopup extends UICommonPopup

	property UINewMergeItem weaponItem = "4264d9c4-6a6e-4b6f-8431-960ee28fb7eb"

	property TextComponent textWeaponName = "ec18f58a-0d2b-4707-8d19-5362198d683d"

	property TextComponent textWeaponGradePrev = "d5f6c73a-6ccf-4730-a791-cba6001bd2c1"

	property TextComponent textWeaponGradeResult = "cd1512af-d610-4ef9-9863-5737aff3f6ae"

	property SpriteGUIRendererComponent panelTitle = "dd55b5ff-8ccc-4900-aa72-d2ce9e9d20cc"

	property any closeFunc = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 무기 아이템 스프라이트 설정
		__base:OnBeginPlay()
		self.weaponItem:InitSprite()
	end

	method void Open(string uniqueKey, any closeFunc)
		-- 무기 합성 결과 팝업을 열고 결과 정보를 표시
		self.closeFunc = closeFunc
		_SoundService:PlaySound("3522602059be4376a95c47c981ec0099",1)
		self:Show()
		
		self.weaponItem:SetWeaponID(uniqueKey,_UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey])
		
		
		local id = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId
		local grade = _ItemDataLogic.equipmentData[id].grade
		local name = _LocalizationService.LocalTranslator:GetText(_WeaponSpecLogic.weaponData[id].type)
		
		local color1 = "white"
		local color2 = "white"
		local grade1 = ""
		local grade2 = ""
		if grade == "rare" then
			grade1 = _LocalizationService.LocalTranslator:GetText("normal")
			grade2 = _LocalizationService.LocalTranslator:GetText("rare")
			color1 = _WeaponSpecLogic:GetHexColorByGrade("normal")
			color2 = _WeaponSpecLogic:GetHexColorByGrade("rare")
		elseif grade == "epic" then
			grade1 = _LocalizationService.LocalTranslator:GetText("rare")
			grade2 = _LocalizationService.LocalTranslator:GetText("epic")	
			color1 = _WeaponSpecLogic:GetHexColorByGrade("rare")
			color2 = _WeaponSpecLogic:GetHexColorByGrade("epic")
		elseif grade == "unique" then
			grade1 = _LocalizationService.LocalTranslator:GetText("epic")
			grade2 = _LocalizationService.LocalTranslator:GetText("unique")	
			color1 = _WeaponSpecLogic:GetHexColorByGrade("epic")
			color2 = _WeaponSpecLogic:GetHexColorByGrade("unique")
		elseif grade == "legendary" then
			grade1 = _LocalizationService.LocalTranslator:GetText("unique")
			grade2 = _LocalizationService.LocalTranslator:GetText("legendary")	
			color1 = _WeaponSpecLogic:GetHexColorByGrade("unique")
			color2 = _WeaponSpecLogic:GetHexColorByGrade("legendary")
		end
		
		self.textWeaponName.Text = name
		
		self.textWeaponGradePrev.Text = string.format("<color=%s>%s</color>", color1,grade1)
		self.textWeaponGradeResult.Text = string.format("<color=%s>%s</color>", color2,grade2)
		self.panelTitle.Color = _WeaponSpecLogic:GetColorBackByGrade(grade)
	end

	method void Hide()
		-- 합성 결과 팝업을 숨김
		__base:Hide()
		
	end

	method void OnFinishHide()
		-- 팝업 숨김 완료 후 콜백 함수 실행
		__base:OnFinishHide()
		if self.closeFunc ~= nil then
			self.closeFunc()
		end
	end

	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		-- 화면 터치 시 팝업을 숨김
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.isOpen == false then
			return
		end
		if self.isShowTween then
			return
		end
		self:Hide()
	end

end