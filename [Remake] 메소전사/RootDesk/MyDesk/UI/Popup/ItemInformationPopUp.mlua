@Component
script ItemInformationPopUp extends UICommonPopup

	property Entity titleText = "7b7a9f71-5ffd-4e4c-955b-1bc8e97432e9"

	property Entity itemCategoryText = "f4f73f9a-2995-4066-afda-57d34add1f9e"

	property Entity itemCategoryIcon = "8b8db62d-8b95-4db7-9c76-e6d412725289"

	property Entity itemSlotBg = "27da5287-677b-4f0b-9643-1e8abb6f5043"

	property Entity itemIcon = "e56ad5dc-e90a-4a02-82a5-283ab61ec3ba"

	property Entity equippedText = "a084baf3-c363-4556-900c-eb45e2881116"

	property Entity descriptionText = "c240cf23-5184-4300-9683-31202d091e3e"

	property Entity exitButton = "063a59d5-198f-4490-bb16-d2d7fbe87fcf"

	property Entity equipButton = "3af6bb75-2c10-434a-a282-e9c81ff7ca7d"

	property Entity unEquipButton = "5208b286-fa75-4cf5-8b96-3a4de74c68e7"

	property Entity sellButton = "07825c8d-2321-4e35-91fb-23ab0365eaa9"

	@HideFromInspector
	property string currentItemId = ""

	property string currentUniqueKey = ""

	property Entity itemNameText = "d4c45fce-e567-424a-b6b9-66c226d05ee2"

	property Entity categoryTitle = "f4f73f9a-2995-4066-afda-57d34add1f9e"

	property Entity mesoText = "32cb9b63-0131-4cef-af74-f1a4768bffce"

	property Entity useButton = "62d09340-47fe-4c98-9ce3-93cd5ceef61c"

	property Entity itemCountText = "123277e0-ef48-4b9f-a808-b36a7f7a98c1"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 아이템 정보 팝업 초기화 및 버튼 설정
		__base:OnBeginPlay()
		self:InitButtons()
	end

	@ExecSpace("ClientOnly")
	method void InitButtons()
		-- 모든 버튼에 이벤트 핸들러 연결
		self.exitButton:ConnectEvent(ButtonClickEvent, function()
			self:Hide()
			end)
		
		self.equipButton:ConnectEvent(ButtonClickEvent, function()
			self:Equip()
			end)
		
		self.unEquipButton:ConnectEvent(ButtonClickEvent, function()
			self:UnEquip()
			end)
		
		self.sellButton:ConnectEvent(ButtonClickEvent, function()
			self:Sell()
			end)
		
		self.useButton:ConnectEvent(ButtonClickEvent, function()
			self:Use()
			end)
	end

	@ExecSpace("ClientOnly")
	method void Sell()
		-- 아이템 판매 처리
		local data = _ItemDataLogic.itemData[self.currentItemId]
		
		if not isvalid(data) then
			
			return
		end
		
		_UIPopup:OpenSellItem(self.currentUniqueKey)
		
	end

	@ExecSpace("ClientOnly")
	method void Equip()
		-- 장식 아이템 착용 처리
		local data = _ItemDataLogic.itemData[self.currentItemId]
		
		if not isvalid(data) then
			
			return
		end
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		
		playerInfo:RequestSetDecoration(self.currentUniqueKey)
		
		self.equippedText.Enable = true
		self.equipButton.Enable = false
		self.unEquipButton.Enable = true
		self.useButton.Enable = false
		
		self:Hide()
		_UIPopup:Close()
	end

	@ExecSpace("ClientOnly")
	method void UnEquip()
		-- 장식 아이템 해제 처리
		local data = _ItemDataLogic.itemData[self.currentItemId]
		
		if not isvalid(data) then
			
			return
		end
		
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		
		playerInfo:RequestUnEquipDecoration(_ItemDataLogic.decorationData[self.currentItemId].category)
		
		self.equippedText.Enable = false
		self.equipButton.Enable = true
		self.unEquipButton.Enable = false
		self.useButton.Enable = false
		
		self:Hide()
		_UIPopup:Close()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 아이템 정보 UI 새로고침
		local data = _ItemDataLogic.itemData[self.currentItemId]
		
		if not isvalid(data) then
			
			return
		end
		
		local storage = _UserService.LocalPlayer.PlayerStorageComponent
		local category = data.category
		
		
		if category == "decoration" then
			local isEquipped = false
			
			if isvalid(storage.storage[self.currentUniqueKey]) then
				if storage.storage[self.currentUniqueKey].equippedSlotNum > 0 then
					isEquipped = true
				end
			end
			
			if isEquipped then
				self.equippedText.Enable = true
				self.equipButton.Enable = false
				self.unEquipButton.Enable = true
			else
				self.equippedText.Enable = false
				self.equipButton.Enable = true
				self.unEquipButton.Enable = false
			end
		else
			self.equippedText.Enable = false
			self.equipButton.Enable = false
			self.unEquipButton.Enable = false
		end
		
		if category == "consume" then
			self.useButton.Enable = true
		else
			self.useButton.Enable = false
		end
		
		local gradeText = ""
		local slotBgRenderer = self.itemSlotBg.SpriteGUIRendererComponent
		
		if data.grade == "normal" then
			gradeText = string.format("[%s]", _LocalizeLogic:GetText("normal"))
			slotBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
		elseif data.grade == "rare" then
			gradeText = string.format("[%s]", _LocalizeLogic:GetText("rare"))
			slotBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
		elseif data.grade == "epic" then
			gradeText = string.format("[%s]", _LocalizeLogic:GetText("epic"))
			slotBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
		elseif data.grade == "unique" then
			gradeText = string.format("[%s]", _LocalizeLogic:GetText("unique"))
			slotBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
		elseif data.grade == "legendary" then
			gradeText = string.format("[%s]", _LocalizeLogic:GetText("legendary"))
			slotBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
		end
		
		local itemName = string.format("%s %s", gradeText, _LocalizeLogic:GetItemName(self.currentItemId))
		self.categoryTitle.SpriteGUIRendererComponent.Color = Color.FromHexCode(_GameUtil:GetBackgroundColorByItemGrade(data.grade))
		
		local renderer = self.itemIcon.SpriteGUIRendererComponent
		
		renderer.ImageRUID = data.ruid
		renderer.LocalPosition = Vector2(data.offsetX, data.offsetY)
		
		self.descriptionText.TextComponent.Text = _LocalizeLogic:GetItemDesc(self.currentItemId) 
		self.mesoText.TextComponent.Text = string.format("%d", data.sellingPrice)
		
		self.itemCountText.Enable = true
		
		if category == "decoration" then
			local decoData = _ItemDataLogic.decorationData[data.id]
			
			if isvalid(decoData) then
				local decoCategory = decoData.category
				
				if decoCategory == "damageSkin" then
					self.itemCategoryIcon.SpriteGUIRendererComponent.ImageRUID = "77f57b2a6a9e4db7a86da5a327d1e677"
				elseif decoCategory == "nameTag" then
					self.itemCategoryIcon.SpriteGUIRendererComponent.ImageRUID = "bd2317f490ae46d2ade4fda1e0e2e889"
				elseif decoCategory == "chatBalloon" then
					self.itemCategoryIcon.SpriteGUIRendererComponent.ImageRUID = "30f4265a088846bfb9faefdcd6381748"
				end
			end
			
			self.itemCountText.Enable = false
		elseif category == "consume" then
			self.itemCategoryIcon.SpriteGUIRendererComponent.ImageRUID = "7c4e6cfd278b4b77be07a5791d6c3915"
		elseif category == "etc" then
			self.itemCategoryIcon.SpriteGUIRendererComponent.ImageRUID = "e6842de3a1e14624b9abbb328e878e8f"
		end
		
		self.itemCountText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr188"), storage:GetItemCount(self.currentItemId))
		self.itemCategoryText.TextComponent.Text = itemName
	end

	@ExecSpace("ClientOnly")
	method void Open(string uniqueKey)
		-- 아이템 정보 팝업 열기 및 스크롤 위치 초기화
		self.currentUniqueKey = uniqueKey
		self.currentItemId = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId
		self.descriptionText.Parent.ScrollLayoutGroupComponent:ResetScrollPosition(UITransformAxis.Vertical)
		
		self:Refresh()
		self:Show()
	end

	@ExecSpace("ClientOnly")
	method void Use()
		-- 소모 아이템 사용 처리
		local data = _ItemDataLogic.itemData[self.currentItemId]
		
		if not isvalid(data) then
			
			return
		end
		
		if self.currentItemId == "6_000051" then
			_SelectSoulPiecePopUp:Open()
		else
			_UIPopup:OpenUseItem(self.currentUniqueKey)
		end
		
		self.equippedText.Enable = false
		self.equipButton.Enable = false
		self.unEquipButton.Enable = false
		self.useButton.Enable = true
	end

end