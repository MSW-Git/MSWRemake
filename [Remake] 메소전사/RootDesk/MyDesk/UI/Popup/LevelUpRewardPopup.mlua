@Component
script LevelUpRewardPopup extends UICommonPopup

	property integer level = 0

	property table rewardSlotIdTable = {}

	property Entity reward_Origin_Slot = "b5e2707e-cde8-428d-a1be-73ad1fa5506a"

	method void init(integer level)
		-- 레벨업 보상 팝업 초기화 (미구현)
		
		
	end

	method void Hide()
		-- 팝업 숨김
		__base:Hide()
	end

	method void Show()
		-- 팝업 표시
		__base:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "90d27d32-b2e1-4d15-b8ca-a661a56c7b38")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 보상 수령 버튼 클릭 시 팝업 닫고 계정 데이터 업데이트
		
		local Entity = event.Entity
		
		_PlayerAccountLogic:CloseRewardPopUp()
		_UserService.LocalPlayer.PlayerAccount:ChangAccountShowPopupData(_UserService.LocalPlayer.PlayerAccount.accountTable.level)
	end

end