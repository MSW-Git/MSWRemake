@Component
script ArmorInformationUI extends UICommonPopup

	property table itemData = {}

	property Entity highlightedSlot = "9b830ddd-8f30-4a1d-92ee-4e0b501d6b37"

	property Entity highlightedSlot_Category = "164fc84b-88be-43a5-9eb0-391058f88fe5"

	property Entity highlightedSlot_NamePanel = "e7fc2506-84ec-45da-88ca-f07236919d4f"

	property Entity highlightedSlot_StatusPanel = "f32d235e-232e-4a9e-a6ba-ef92bba71f0b"

	property Entity highlightedSlot_SkillPanel = "6224a802-9d24-4c54-a9a6-62ac45bbd988"

	property Entity highlightedSlot_UpgradePanel = "2df71dba-5887-4b26-ad6b-f22492496134"

	property Entity itemList = nil

	property Entity itemList_OriginSlot = nil

	property Entity tab = nil

	property string selectedUniqueKey = ""

	property Entity gradeUp = "20c22ca9-5c69-4634-ae83-26cac1fc2663"

	property Entity gradeUp_targetSlot = "37770821-e778-40ea-a843-3d977d52a6be"

	property Entity gradeUp_materialSlot = "68810148-c6dd-4c0d-bda2-fc137fe04475"

	property Entity gradeUp_resultSlot = "019532ce-d343-4051-8e14-b3207593d81c"

	property Entity gradeUp_materialList = "53461d2b-b479-42af-9afe-a312f2668762"

	property Entity gradeUp_materialList_originSlot = "461dcfc0-26b9-4994-a888-1d9ec4c3e13f"

	property table clonnedSlotIdTable = {}

	property string selectedMaterialUniqueKey = ""

	property Entity levelUpEffect = "b58bfac4-5504-4b2d-8220-a74f72f38d14"

	property Entity gradeUpEffect = "47801ae6-0c18-4a3f-92d3-b38cea2473d1"

	property Entity levelUp_mainPanel = "2df71dba-5887-4b26-ad6b-f22492496134"

	property Entity resetPopup = "9ea0e15c-6002-4211-bcdc-2d90999932f6"

	property Entity resetPopup_Scroll = "aa029820-11dd-4ac8-a3e4-40b9ef64cabb"

	property Entity resetPopup_Gold = "abac5cbb-e8fd-4392-8916-5d9a8e184e40"

	property Entity resetPopup_beforeArmor = "b817e154-b1b0-4a6b-bf0c-ffc5f4eed908"

	property Entity resetPopup_afterArmor = "7c7db8ad-b616-46a5-b65d-b7b5060841fa"

	property string selectedType = ""

	property Entity itemInfo = "a13d5ef2-f9a5-4299-ab41-1867494d9d0e"

	property Entity equipButton = "0170ddca-973d-4dc0-973c-ffb55f27b86d"

	property Entity unequipButton = "4fdc8562-20d2-42cd-b6bc-7ff76a8899b9"

	property Entity armorSellPopup = "49da0ee2-13ec-4ed4-8693-6e0b84cd4cc8"

	property Entity gradeUp_NeedMaterialSlot = "88acba36-8c11-46a0-8874-9ab5dc20b943"

	property table materialSlotList = {}

	property Entity armorBatchLevelupPopup = "6cc2869a-1799-4751-887c-86b30b4f4fe1"

	method void OpenInventory(string type, string uniqueKey)
		-- 방어구 인벤토리 열기 및 아이템 정보 설정
		
		if uniqueKey == "" then
			self:RefreshItemInformation(uniqueKey, true)
		else
			self:RefreshItemInformation(uniqueKey, false)
		end
		
		self:Show()
	end

	method void CloseInventory()
		-- 방어구 인벤토리 닫기 및 초기화
		self.selectedUniqueKey = ""
		
		self.selectedMaterialUniqueKey = ""
		self.selectedType = ""
		self.itemData = nil
		self:Hide()
	end

	method void RefreshItemInformation(string uniqueKey, boolean reset)
		-- 선택된 방어구 아이템 정보 새로고침 및 UI 업데이트
		local originalId = ""
		
		if isvalid(_UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey]) then
			originalId = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId
		else
			reset = true
		end
		
		if reset then 
			self.itemInfo:SetEnable(false)
			self.selectedMaterialUniqueKey = ""
		
			self.selectedUniqueKey = ""
			self.itemData = nil
			
		else 
		
			local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey]
			
			
			self.itemData = _ItemDataLogic:GetItemData(originalId)
			self.selectedUniqueKey = uniqueKey
		
			
			if storage.equippedSlotNum <= 0 then
				self.equipButton:SetEnable(true)
				self.unequipButton:SetEnable(false)
			else
				self.equipButton:SetEnable(false)
				self.unequipButton:SetEnable(true)
			end
		
			local armorData = _ArmorSpecLogic.armorData[originalId]
			local grade = armorData.grade
			
			local optionDesc = _ItemDataLogic.equipmentOptionData[self.itemData.name]
			local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey]
			local armorStatusData = _ArmorSpecLogic.armorLevelUpData[item.level]
			local currency = _UserService.LocalPlayer.PlayerCurrencyData
		
		
			self.highlightedSlot.SpriteGUIRendererComponent.Color = Color.FromHexCode(_ArmorSystemLogic:GetColorCodeByGrade(self.itemData.grade))
		
			self.highlightedSlot:GetChildByName("Icon", true).SpriteGUIRendererComponent.ImageRUID = self.itemData.ruid 
			self.highlightedSlot:GetChildByName("Category", true):GetChildByName("CategoryIcon", true).SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetCategoryIconRUID(originalId) 
			
			
			local splitGrade = _UtilLogic:Split(self.itemData.grade, "_")
			
			self.Entity:GetChildByName("textItemName", true).SpriteGUIRendererComponent.Color = Color.FromHexCode(_GameUtil:GetBackgroundColorByItemGrade(splitGrade[1]))
			self.Entity:GetChildByName("icon_category", true).SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetCategoryIconRUID(item.originalId)
			
			if _UtilLogic:IsNilorEmptyString(splitGrade[2]) then
				self.Entity:GetChildByName("textItemName",true).TextComponent.Text = "[".._LocalizationService:GetText(splitGrade[1]).."] ".._LocalizationService:GetText(self.itemData.name)		
			else
		
				self.Entity:GetChildByName("textItemName",true).TextComponent.Text = "[".._LocalizationService:GetText(splitGrade[1]).."] +"..splitGrade[2].." ".._LocalizationService:GetText(self.itemData.name)
			end
			
		
			local armorGrade = self.Entity:GetChildByName("GradeStar", true)
			local starCount = tonumber(_ArmorSpecLogic.armorData[originalId].star)
		
			for i = 1, #armorGrade.Children do
				if i <= starCount then
					armorGrade.Children[i].Enable = true
				else
					armorGrade.Children[i].Enable = false
				end
			end
		
			self.Entity:GetChildByName("text_level",true).TextComponent.Text = item.level.."/"..string.format("<color=gray> %d </color>", self.itemData.maxLevel)
			
			local statusRUID = ""
			local statusValue = ""
			local statusName = ""
		
			local fTable = _ArmorSpecLogic.armorData
				
			if armorData.mainStatus == "hp" then
				if armorData.type == "helmet" then
					statusValue = "+"..string.format("%d",(armorStatusData.helmet_hp + fTable[originalId].maxHp))
				elseif armorData.type == "suit" then
					statusValue = "+"..string.format("%d",(armorStatusData.suit_hp + fTable[originalId].maxHp))
				elseif armorData.type == "shoes" then
					statusValue = "+"..string.format("%d",(armorStatusData.shoes_hp + fTable[originalId].maxHp))
				end  
				statusRUID = "691fb3a497044f349554b85c2c4b1159" 
				statusName = _LocalizeLogic:GetText("maxHp")
		
			elseif armorData.mainStatus == "attack" then
				statusRUID = "d5c304dfa5024c1686a06b670d7bcb03" 
				statusValue = string.format("%.2f", armorStatusData.glove_attack + fTable[originalId].addAttackRate).."%"
				statusName = _LocalizeLogic:GetText("common_IncreaseDamage")  
			end
		
			self.highlightedSlot_StatusPanel:GetChildByName("Icon", true).SpriteGUIRendererComponent.ImageRUID = statusRUID 
			self.highlightedSlot_StatusPanel:GetChildByName("Value", true).TextComponent.Text = statusValue 
			self.highlightedSlot_StatusPanel:GetChildByName("Name", true).TextComponent.Text = statusName 
			
			local grade1 = self.highlightedSlot_SkillPanel:GetChildByName("textSpec_normal",true) 
			local grade2 = self.highlightedSlot_SkillPanel:GetChildByName("textSpec_rare",true)
			local grade3 = self.highlightedSlot_SkillPanel:GetChildByName("textSpec_epic",true)
			local grade4 = self.highlightedSlot_SkillPanel:GetChildByName("textSpec_unique",true) 
			local grade5 = self.highlightedSlot_SkillPanel:GetChildByName("textSpec_legendary",true)
			
			grade1.TextComponent.Text = _LocalizeLogic:GetText("option1_Desc_".._ItemDataLogic.equipmentOptionData[self.itemData.name].name)
			grade2.TextComponent.Text = _LocalizeLogic:GetText("option2_Desc_".._ItemDataLogic.equipmentOptionData[self.itemData.name].name)
			grade3.TextComponent.Text = _LocalizeLogic:GetText("option3_Desc_".._ItemDataLogic.equipmentOptionData[self.itemData.name].name)
			grade4.TextComponent.Text = _LocalizeLogic:GetText("option4_Desc_".._ItemDataLogic.equipmentOptionData[self.itemData.name].name)
			grade5.TextComponent.Text = _LocalizeLogic:GetText("option5_Desc_".._ItemDataLogic.equipmentOptionData[self.itemData.name].name)
			
		
			local gradeMax = 0
			
			if _UtilLogic:Contains(grade, "normal") == true then
				gradeMax = 1	
			elseif _UtilLogic:Contains(grade, "rare") == true then
				gradeMax = 2	
			elseif _UtilLogic:Contains(grade, "epic") == true then
				gradeMax = 3
			elseif _UtilLogic:Contains(grade, "unique") == true then
				gradeMax = 4
			elseif _UtilLogic:Contains(grade, "legendary") == true then
				gradeMax = 5
			end
			local gradeTable = {"normal", "rare", "epic", "unique", "legendary"}
			
			for i = 1 , #self.highlightedSlot_SkillPanel.Children do
				if i <= gradeMax and not isvalid(_UserService.LocalPlayer.MultiBattlePlayer) then
					self.highlightedSlot_SkillPanel.Children[i].TextComponent.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(gradeTable[i]))
					self.highlightedSlot_SkillPanel.Children[i]:GetChildByName("lock", true):SetEnable(false)
				else
					self.highlightedSlot_SkillPanel.Children[i].TextComponent.FontColor = Color.gray
					self.highlightedSlot_SkillPanel.Children[i]:GetChildByName("lock", true):SetEnable(true)
				end
			end
		
		local canLevelUp = true
		local canGradeUp = true
		
		local gradeUpMaterialList =  _ArmorSystemLogic:GetGradeUpMaterialList(uniqueKey, _UserService.LocalPlayer)
		local tempTable = {}
		for key, value in pairs(gradeUpMaterialList) do
			table.insert(tempTable, value)
		end
		
			if #tempTable >= 1 then
				canGradeUp = true
			else
				canGradeUp = false
			end
			
			if tonumber(self.itemData.mergeLevel) >= 12 and item.level >= tonumber(self.itemData.maxLevel) then
				self.levelUp_mainPanel:SetEnable(false)
		
			else
				
				self.levelUp_mainPanel:SetEnable(true)
				
				self.highlightedSlot_UpgradePanel:GetChildByName("NeedGold"):GetChildByName("Value").TextComponent.Text =
				_NumberSeparator:ConvertToMetricPrefixString(currency.currencyTable["Gold"].amount, "ko").."/"..
				_NumberSeparator:ConvertToMetricPrefixString(_ArmorSpecLogic.armorLevelUpData[item.level + 1].needGold, "ko")
				
				if currency.currencyTable["Gold"].amount < _ArmorSpecLogic.armorLevelUpData[item.level + 1].needGold then
					canLevelUp = false
					self.highlightedSlot_UpgradePanel:GetChildByName("NeedGold"):GetChildByName("Value").TextComponent.FontColor = Color.FromHexCode("#FF6868")
				else
					self.highlightedSlot_UpgradePanel:GetChildByName("NeedGold"):GetChildByName("Value").TextComponent.FontColor = Color.white
				end
			
		
				self.highlightedSlot_UpgradePanel:GetChildByName("NeedScroll"):GetChildByName("Value").TextComponent.Text =
				_NumberSeparator:ConvertToMetricPrefixString(currency.currencyTable["WeaponScroll"].amount, "ko").."/"..
				_NumberSeparator:ConvertToMetricPrefixString(_ArmorSpecLogic.armorLevelUpData[item.level + 1].needScroll, "ko")
				
				if currency.currencyTable["WeaponScroll"].amount < _ArmorSpecLogic.armorLevelUpData[item.level + 1].needScroll then
					canLevelUp = false
					self.highlightedSlot_UpgradePanel:GetChildByName("NeedScroll"):GetChildByName("Value").TextComponent.FontColor = Color.FromHexCode("#FF6868")
				else
					self.highlightedSlot_UpgradePanel:GetChildByName("NeedScroll"):GetChildByName("Value").TextComponent.FontColor = Color.white
				end
				
				local itemData = _ItemDataLogic.equipmentData[storage.originalId]
				if storage.level >= itemData.maxLevel then
					canLevelUp = false
				end
			end
		
			if canLevelUp == true then
				self.highlightedSlot_UpgradePanel:GetChildByName("LevelUpArrow", true):SetEnable(true)
				self.highlightedSlot_UpgradePanel:GetChildByName("BatchLevelUpArrow", true):SetEnable(true)
			else
				self.highlightedSlot_UpgradePanel:GetChildByName("LevelUpArrow", true):SetEnable(false)
				self.highlightedSlot_UpgradePanel:GetChildByName("BatchLevelUpArrow", true):SetEnable(false)
			end
			
			if canGradeUp == true then
				self.highlightedSlot_UpgradePanel:GetChildByName("GradeUpArrow", true):SetEnable(true)
			else
				self.highlightedSlot_UpgradePanel:GetChildByName("GradeUpArrow", true):SetEnable(false)
			end
			
			if _ItemDataLogic:CheckItemEquipped(uniqueKey, _UserService.LocalPlayer, 2) == true then
				self.highlightedSlot:GetChildByName("equipped", true):SetEnable(true)
			else
				self.highlightedSlot:GetChildByName("equipped", true):SetEnable(false)
			end
			self.itemInfo:SetEnable(true)
		end
	end

	method void RefreshInventoryList(table uniqueKeyList)
		-- 인벤토리 리스트 새로고침 (현재 비활성화됨)
		if true then
			return
		end
	end

	@ExecSpace("Client")
	method void ChangeTab(string type)
		-- 방어구 탭 변경 (현재 비활성화됨)
		if true then
			return
		end
		--[[
		local tabList = self.tab.Children
		local uniqueKeyList = _ItemDataLogic:GetUniqueKeyListByFiltering(type, _UserService.LocalPlayer)
		self.selectedType = type
		
		for i = 1 , #tabList do
			if tabList[i].Name == type then 
				tabList[i].SpriteGUIRendererComponent.Color = Color.green
			else 
				tabList[i].SpriteGUIRendererComponent.Color = Color.gray
			end
		end
		
		if self.selectedUniqueKey == "" then
			self:RefreshItemInformation("", true)
		end
		
		self:RefreshInventoryList(uniqueKeyList)]]--
	end

	method void InitGradeUpPopup(string uniqueId, boolean reset, Entity player)
		-- 방어구 등급업 팝업 초기화 및 재료 리스트 설정
		self.selectedUniqueKey = uniqueId
		self.selectedMaterialUniqueKey = ""
		
		self.gradeUp_NeedMaterialSlot:SetEnable(true)
		
		
		self:SetArmorSlot(uniqueId, self.gradeUp_NeedMaterialSlot, player, true) 
		
		self.gradeUp_materialSlot:SetEnable(false)
		
		local gridView = self.gradeUp_materialList.GridViewComponent
		local materialList = _ArmorSystemLogic:GetGradeUpMaterialList(uniqueId, _UserService.LocalPlayer)
		
		local tempTable = {}
		for key, value in pairs(materialList) do
			table.insert(tempTable, value)
		end
		gridView.TotalCount = #tempTable
		
		gridView:Refresh(true, true)
		
		
		if reset then
			self.gradeUp.ArmorGradeUpPopup:Hide()
			return
		end
		
		local storage = player.PlayerStorageComponent.storage
		local targetItem = storage[uniqueId] 
		local equipmentData = _ItemDataLogic.equipmentData
		local targetItemData = _ItemDataLogic.equipmentData[targetItem.originalId]
		
		
		self:SetArmorSlot(uniqueId, self.gradeUp_targetSlot, player, false) 
		self:SetGradeResultSlot(targetItemData.nextEquipment, self.gradeUp_resultSlot) 
		
		
		self.gradeUp.ArmorGradeUpPopup:Show()
	end

	@ExecSpace("Client")
	method void SetArmorSlot(string uniqueId, Entity targetUI, Entity player, boolean material)
		-- 방어구 슬롯 UI 설정 (아이템 정보 표시)
		if not material then 
			_UIGroupManager:SetItemSlot(targetUI, 2, uniqueId, "")
			return
		end
		
		
		local item = player.PlayerStorageComponent.storage[uniqueId]
		local itemData = _ItemDataLogic.equipmentData[item.originalId]
		
		local icon = targetUI:GetChildByName("Icon")
		local level = targetUI:GetChildByName("Level")
		local gradeStar = targetUI:GetChildByName("GradeStar")
		local selected = targetUI:GetChildByName("Selected")
		local categorySlot = targetUI:GetChildByName("Category")
		
		
		if targetUI ~= self.gradeUp_NeedMaterialSlot then 
		
		local equipped = targetUI:GetChildByName("equipped", true)
		
		if _ItemDataLogic:CheckItemEquipped(uniqueId, _UserService.LocalPlayer, 2) then
			equipped:SetEnable(true)
		else
			equipped:SetEnable(false)
		end
		end
		
		targetUI.SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetSlotColorRUID(item.originalId)
		icon.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
		level.TextComponent.Text = item.level.."/"..itemData.maxLevel
		
		targetUI:GetChildByName("Category"):GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetCategoryIconRUID(item.originalId)
		selected:SetEnable(false)
		categorySlot.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUID(item.originalId)
		
		if material then 
			level.Enable = false
			if itemData.mergeLevel == 1 or itemData.mergeLevel == 3 or itemData.mergeLevel == 5 or itemData.mergeLevel == 8 then
		
			else
				icon.SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetCategoryIconRUID(item.originalId)	
			end
		
		else 
			level.Enable = true
		end
		
		
		for i = 1 , #gradeStar.Children do
			if i <= tonumber(itemData.star) then
				gradeStar:GetChildByName("Star_"..math.floor(i)):SetEnable(true)
			else
				gradeStar:GetChildByName("Star_"..math.floor(i)):SetEnable(false)
			end
		end
		
		if targetUI.Enable == false then
			targetUI.Enable = true
		end
		 
	end

	@ExecSpace("Client")
	method void SetGradeResultSlot(string originalId, Entity targetUI)
		-- 등급업 결과 슬롯 설정
		if originalId == "" then 
			self.gradeUp_resultSlot.Parent:SetEnable(false)	
			return
		end
		
		_UIGroupManager:SetItemSlot(targetUI, 2, nil, originalId)
		
	end

	method void OpenResetPopup()
		-- 방어구 리셋 팝업 열기 및 정보 설정
		local targetId = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.selectedUniqueKey].originalId
		local armorData = _ArmorSpecLogic.armorData[targetId]
		
		_UIGroupManager:SetItemSlot(self.resetPopup_beforeArmor,2, self.selectedUniqueKey,"")
		_UIGroupManager:SetItemSlot(self.resetPopup_afterArmor,2, self.selectedUniqueKey,"")
		self.resetPopup_afterArmor:GetChildByName("armor_level", true).TextComponent.Text = "1"
		
		local valueTable = _ArmorSystemLogic:GetResetValue(self.selectedUniqueKey, _UserService.LocalPlayer.PlayerComponent.UserId)
		self.resetPopup_Scroll.TextComponent.Text = valueTable.scroll 
		self.resetPopup_Gold.TextComponent.Text = valueTable.gold
		
		self.resetPopup.ArmorResetPopup:Show()
	end

	method void CloseResetPopup()
		-- 방어구 리셋 팝업 닫기
		self.resetPopup.ArmorResetPopup:Hide()
	end

	method void Show()
		-- 방어구 정보 UI 표시
		__base:Show()
	end

	method void ChangeSelected(Entity targetUI)
		-- 등급업 재료 선택 상태 변경
		for i = 1 , #self.gradeUp_materialList.Children do
			if targetUI == self.gradeUp_materialList.Children[i] then
				if targetUI:GetChildByName("CheckImage", true).Enable == true then
					targetUI:GetChildByName("CheckImage", true).Enable = false
				else
					targetUI:GetChildByName("CheckImage", true).Enable = true
				end
			else
				self.gradeUp_materialList.Children[i]:GetChildByName("CheckImage", true).Enable = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 방어구 정보 UI 초기화 및 그리드뷰 설정
		__base:OnBeginPlay()
		
		self._T.listSlot = {}
		local gridView = self.gradeUp_materialList.GridViewComponent
		gridView.ItemEntity = self.gradeUp_materialList_originSlot
		
		gridView.OnRefresh = function(index, entity)
			if self.selectedUniqueKey == "" then return end
			local uniqueKey = self.selectedUniqueKey
			local materialList = _ArmorSystemLogic:GetGradeUpMaterialList(uniqueKey, _UserService.LocalPlayer)
		
			local player = _UserService.LocalPlayer
			local storage = player.PlayerStorageComponent.storage
			local tempTable = {}
			
			for key, value in pairs(materialList) do
				table.insert(tempTable, value)
			end
			
			table.sort(tempTable, function(a, b) return a.inventoryNum < b.inventoryNum end)
			entity.ArmorGradeUpMaterialSlotButton:Init(tempTable[index + 1].uniqueKey)
			_UIGroupManager:SetItemSlot(entity, 2, tempTable[index + 1].uniqueKey, "")
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "fcae86a2-66e8-46c4-92c8-27c122932892")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 인벤토리 닫기
		
		local Entity = event.Entity
		self:CloseInventory()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "11caf153-04c5-426e-b417-9343842fd752")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 레벨업 버튼 클릭 시 방어구 레벨업 실행
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		_ArmorSystemLogic:LevelUp(self.selectedUniqueKey, true, "ArmorLevelUp")
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "409b92f1-b9cb-40e0-a2a4-717ff9c5225a")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 등급업 팝업 닫기 버튼 클릭 처리
		
		local Entity = event.Entity
		self:InitGradeUpPopup(self.selectedUniqueKey, true, _UserService.LocalPlayer)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "0170ddca-973d-4dc0-973c-ffb55f27b86d")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 장착 버튼 클릭 시 방어구 장착 처리
		
		local Entity = event.Entity
		local slotNum = 0
		local category = self.itemData.detailCategory
		
		if category == "helmet" then
			slotNum = 21
		elseif category == "suit" then
			slotNum = 22
		elseif category == "glove" then
			slotNum = 23
		elseif category == "shoes" then	
			slotNum = 24
		end
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		_UserService.LocalPlayer.PlayerStorageComponent:Equip(self.selectedUniqueKey, slotNum)
		_SoundService:PlaySound("e4a63892e7534618b9fb35d7e755663c", 1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "4fdc8562-20d2-42cd-b6bc-7ff76a8899b9")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 장착 해제 버튼 클릭 시 방어구 해제 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		_UserService.LocalPlayer.PlayerStorageComponent:UnEquip(self.selectedUniqueKey)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "8029ee6f-2084-400c-aecb-11cf0ab1b055")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 등급업 버튼 클릭 시 등급업 팝업 초기화
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		if tonumber(self.itemData.mergeLevel) >= 12 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast355"))
			return
		end
		self:InitGradeUpPopup(self.selectedUniqueKey, false, _UserService.LocalPlayer)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "ItemReinforceLogic")
	handler HandleItemLevelUpEvent(ItemLevelUpEvent event)
		-- 아이템 레벨업 이벤트 처리 및 이펙트 표시
		local level = event.level
		local uniqueKey = event.uniqueKey
		local category = event.category
		local showEffect = event.showEffect
		
		if showEffect == true then
			_SoundService:PlaySound("1f902813d41c469c9d406b5e4668e076", 1)
		
			local effect = _ArmorSystemLogic.armorInformation.levelUpEffect:Clone("lvUpEffect") 
			_TimerService:SetTimerOnce(function() 
					_EntityService:Destroy(effect)
					end, 0.5)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleArmorGradeUpMaterialSlotClick(ArmorGradeUpMaterialSlotClick event)
		-- 방어구 등급업 재료 슬롯 클릭 이벤트 처리
		local uniquekey = event.uniquekey
		local targetUI = event.targetUI
		if _UtilLogic:IsNilorEmptyString(self.selectedUniqueKey) then 
			self.selectedUniqueKey = uniquekey
		else
			if self.selectedMaterialUniqueKey == uniquekey then
				self.selectedMaterialUniqueKey = ""
				self.gradeUp_NeedMaterialSlot:SetEnable(true)
				self.gradeUp_materialSlot:SetEnable(false)
			else
				self.selectedMaterialUniqueKey = uniquekey	
				self.gradeUp_NeedMaterialSlot:SetEnable(false)
				self.gradeUp_materialSlot:SetEnable(true)
				self:SetArmorSlot(uniquekey, self.gradeUp_materialSlot, _UserService.LocalPlayer, false)	
			end
		end
		
		self:ChangeSelected(targetUI)
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5481786b-9d29-4353-ba5e-51994444ab22")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 등급업 실행 버튼 클릭 시 방어구 등급업 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		if self.selectedUniqueKey == "" or self.selectedMaterialUniqueKey == "" then
			return
		end
		
		_ArmorSystemLogic:GradeUp(self.selectedUniqueKey, self.selectedMaterialUniqueKey)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleArmorGradeUp(ArmorGradeUp event)
		-- 방어구 등급업 완료 이벤트 처리 및 이펙트 표시
		local uniqueId = event.uniqueId
		local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueId]
		local itemData = _ItemDataLogic.equipmentData[item.originalId]
		
		
		local grade = _UtilLogic:Split(itemData.grade, "_")
		local targetRUID = ""
		
		if grade[1] == "normal" then
			targetRUID = ""
		elseif grade[1] == "rare" then
			targetRUID = "59022fb08d8b465a9e1b44ddbb5c78de"	
		elseif grade[1] == "epic" then
			targetRUID = "34e8c32ff00b44e0b694a4e25e673fbd"	
		elseif grade[1] == "unique" then
			targetRUID = "10ca913712914d5f95703566f528ce2a"	
		elseif grade[1] == "legendary" then
			targetRUID = "11843cae856b4724b8042f8a03852b80"	
		end
		_ArmorSystemLogic.armorInformation.gradeUpEffect.SpriteGUIRendererComponent.ImageRUID = targetRUID
		local effect = _ArmorSystemLogic.armorInformation.gradeUpEffect:Clone("gradeUpEffect") 
		
		_SoundService:PlaySound("9a13bf85ee7242d8a32ea357538c6501", 1)
		_SoundService:PlaySound("07a156f100e045189c0481ec07785aba", 1)
		
		_TimerService:SetTimerOnce(function() 
				_EntityService:Destroy(effect)
				end, _GameUtil:GetRuidTime(targetRUID))
		
		self:ChangeTab(itemData.detailCategory)
		
		if tonumber(itemData.mergeLevel) >= 12 then
			self:InitGradeUpPopup(uniqueId, true, _UserService.LocalPlayer)
			 _UIPopup:Open(_LocalizeLogic:GetText("popup67"), _LocalizeLogic:GetText("popup68"), function() end, function() end)
		else
			self:InitGradeUpPopup(uniqueId, false, _UserService.LocalPlayer)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5164ca96-4767-4551-8ee1-2a86525f4e98")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 리셋 버튼 클릭 시 리셋 팝업 열기
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		if self.selectedUniqueKey == "" then
			return
		end
		
		if _UserService.LocalPlayer.PlayerStorageComponent.storage[self.selectedUniqueKey].level <= 1 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast356"))
		else
			self:OpenResetPopup() 
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6de9155d-1ce2-49ff-90c9-08c3dcdd380e")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 리셋 확인 버튼 클릭 시 방어구 리셋 실행
		
		local Entity = event.Entity
		
		
		_ArmorSystemLogic:ResetArmor(self.selectedUniqueKey)
		self:CloseResetPopup()
		self:RefreshInventoryList(_ItemDataLogic:GetUniqueKeyListByFiltering(self.selectedType, _UserService.LocalPlayer))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "8230a1dd-d3fa-4d69-94a6-deae7521ccc6")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- 리셋 취소 버튼 클릭 시 리셋 팝업 닫기
		
		local Entity = event.Entity
		self:CloseResetPopup()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "27b0f21d-fa84-44bd-b368-fac5a69317c7")
	handler HandleButtonClickEvent11(ButtonClickEvent event)
		-- 판매 버튼 클릭 시 판매 팝업 초기화
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		if _UserService.LocalPlayer.PlayerStorageComponent.storage[self.selectedUniqueKey].equippedSlotNum > 0 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast357"))
		else
			self.armorSellPopup.ArmorSellPopUp:Init(self.selectedUniqueKey)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "e15e0818-b262-4583-aca9-142acfaac912")
	handler HandleButtonClickEvent12(ButtonClickEvent event)
		-- 일괄 레벨업 버튼 클릭 시 일괄 레벨업 팝업 열기
		
		local Entity = event.Entity
		self.armorBatchLevelupPopup.ArmorBatchLevelupPopup:Open(self.selectedUniqueKey)
		
	end

end