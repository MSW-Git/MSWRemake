@Component
script UIEquipCollectionPopup extends UICommonPopup

	property Entity ePanel_1 = "f2673da2-cc46-4bdc-9c31-049cba4d6537"

	property Entity ePanel_2 = "73092c7b-d5ed-40a9-a9f6-9fb861b1dba9"

	property Entity ePanel_3 = "dec7ca30-e28d-4bfd-81a7-bcb2eb08de5b"

	property Entity ePanel_4 = "84149354-e820-47a8-bc25-cfb338c46996"

	property table ePanelList = {}

	property number gradeNum = 0

	property number pageNum = 0

	property number totalPageNum = 0

	property Entity pageTextEntity = "d7f73054-de48-4ebf-b6a7-3d32173f71a0"

	property Entity categoryPanel = "0e01a167-b640-4cf1-b2c8-ffbc6dc61f87"

	property Entity normalCategoryButton = "f4e12a36-1f46-41dd-a6d0-22bb287e54ce"

	property Entity materialOriginSlot = "3a009f9d-393b-432e-a4ac-c7f0c68eb70f"

	property Entity materialGrid = "5cd8c76b-0e5a-4419-bbcc-bbf5386fd016"

	property Entity materialListPopup = "49b72751-a19e-488c-888c-4acd75da9ebf"

	property table materialSlotTable = {}

	property TextComponent ability_hp = "07b115c4-88bb-462d-bf6e-7acd5baeb1d9"

	property TextComponent ability_moveSpeed = "45d8cf34-1691-4a27-998a-afdf044ff5a2"

	property TextComponent ability_attackSpeed = "063ea54d-6bd0-46d6-8994-2cb63d4292fe"

	property TextComponent ability_range = "3bf49782-70f4-499f-82d9-2ff8e63f2de3"

	property TextComponent ability_evade = "6aebce2f-0b33-4a38-852f-8b1bf83c4f5a"

	property TextComponent ability_damage = "8cda10f7-af98-42c5-a0ef-1dabfc58f984"

	property TextComponent ability_physicalDamage = "1b793263-d5c0-4406-a483-9a910e1df405"

	property TextComponent ability_magicalDamage = "eb509beb-62b4-42cc-ab1d-2bf14e83951c"

	property TextComponent ability_criticalPercent = "df3342b3-c2cc-4ca5-88d7-6d718b257b6c"

	property TextComponent ability_criticalDamage = "83d0de6f-cdd8-4ae8-a809-e0cfab2ba7a4"

	property TextComponent ability_bossDamage = "b3eaf1d4-347b-48c0-a3ba-8dd2b5ed19a1"

	property boolean filtering = false

	property Entity filledGauge = "c41bddf3-1e75-4273-8256-14b0c12bf2dc"

	property Entity filledGaugeText = "6028767e-b7e4-4ae4-a942-9c8fb62f1ace"

	property Entity collection_RegistedCount = "7a2396d6-df0e-499b-b969-c1a3e59c7d1e"

	property Entity collection_MaterialName = "0cc155c2-8ee3-45b4-a152-02b60b71a15c"

	property Entity collection_RegistButton = "1e4de853-9892-4ff9-b2ad-54be43c9b1d5"

	property Entity collection_SelectAllButton = "6812bc47-9eb9-4c68-b35b-e185a63ecd0e"

	property table materialList = {}

	property Entity alert_haveNoCount = "e5edf07e-e663-417b-92d5-b87c83b8d6f2"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 장비 컴렉션 팝업 초기화 및 그리드뷰 설정
		__base:OnBeginPlay()
		
		local gridView = self.materialGrid.GridViewComponent
		gridView.ItemEntity = self.materialOriginSlot
		gridView.OnRefresh = function(index, entity)
			if _UtilLogic:IsNilorEmptyString(_CollectionLogic.selectedMaterialId) then
				return
			end
			entity.EquipCollectionInventoryMaterialSlot:Init(self.materialList[index +1])
		end
		
		self:Init()
		
		table.insert(self.ePanelList, self.ePanel_1)
		table.insert(self.ePanelList, self.ePanel_2)
		table.insert(self.ePanelList, self.ePanel_3)
		table.insert(self.ePanelList, self.ePanel_4)
	end

	method void SetGradeNumber(number index, Entity target)
		-- 등급 버튼 선택 시 탭 상태 변경 및 페이지 업데이트
		for i = 1 , #self.categoryPanel.Children do
			if self.categoryPanel.Children[i] == target then
				self.categoryPanel.Children[i].SpriteGUIRendererComponent.ImageRUID = "994e2ad676fe4b4c9782186b06f02a4a"
				self.categoryPanel.Children[i].TextComponent.FontColor = Color.FromHexCode("#FFFFFF")
			else
				self.categoryPanel.Children[i].SpriteGUIRendererComponent.ImageRUID = "6cb1470eea884424886399b0fc9f3c95"
				self.categoryPanel.Children[i].TextComponent.FontColor = Color.FromHexCode("#a0acca")
			end
		end
		self.pageNum = 1
		self.gradeNum = index
		self:SetPage(0)
	end

	method void SetPage(number addNum)
		-- 컴렉션 페이지 이동 및 목록 업데이트
		local newPage = self.pageNum + addNum
		local rowTable = {}
		local player = _UserService.LocalPlayer
		self.totalPageNum = _CollectionLogic:GetTotalPage(self.gradeNum)
		
		if newPage <= 0 then
			return
		end
		
		if newPage > self.totalPageNum then
			return
		end
		self.pageNum = newPage
		self.pageTextEntity.TextComponent.Text = math.floor(newPage).."/"..math.floor(self.totalPageNum)
		
		rowTable = _CollectionLogic:GetRowList(self.gradeNum, self.pageNum)
		self:ListRefresh(rowTable)
		
		self.filledGauge.SliderComponent.Value = _CollectionLogic:GetCollectionClearCount(player, player.PlayerCollectionComponent.eCollectionTable)/_CollectionLogic.maxCollectionSize
		self.filledGaugeText.TextComponent.Text = _CollectionLogic:GetCollectionClearCount(player, player.PlayerCollectionComponent.eCollectionTable).."/".._CollectionLogic.maxCollectionSize
		
		
		local target = self:GetTabDotTable()
		self.Entity:GetChildByName("Button_Normal", true):GetChildByName("Dot").Enable = target[1]	
		self.Entity:GetChildByName("Button_Rare", true):GetChildByName("Dot").Enable = target[2]	
		self.Entity:GetChildByName("Button_Epic", true):GetChildByName("Dot").Enable = target[3]	
		self.Entity:GetChildByName("Button_Unique", true):GetChildByName("Dot").Enable = target[4]	
		self.Entity:GetChildByName("Button_Legendary", true):GetChildByName("Dot").Enable = target[5]	
	end

	method void Init()
		-- 컴렉션 팝업 초기화 및 페이지/등급 초기설정
		self.pageNum = 1
		self.gradeNum = 1
	end

	method void Show()
		-- 컴렉션 팝업 표시 및 콘텐츠 잠금 상태 확인
		if self.Entity.ContentLockComponent:CheckUIAvailable() then
			self:Init()
			__base:Show()
			_UIOpenQuestLogic:CheckQuestInProgress("collection",self.Entity)
			self.normalCategoryButton:SendEvent(ButtonClickEvent(self.normalCategoryButton))
		end
	end

	method void Hide()
		-- 컴렉션 팝업 숨김
		__base:Hide()
	end

	method void ListRefresh(table rows)
		-- 컴렉션 목록 새로고침 및 패널 표시 업데이트
		local col = _CollectionLogic.equipCollectionSet
		for i = 1, 4 do
			if i > #rows then
				self.ePanelList[i]:SetEnable(false)
			else
				self.ePanelList[i]:SetEnable(true)
				self:ListSlotSet(self.ePanelList[i] ,true, col[rows[i]], i)
			end 
		end
	end

	@ExecSpace("Client")
	method void ListSlotSet(Entity target, boolean visible, table collection, number panelNum)
		-- 컴렉션 슬롯 정보 설정 및 진행도 업데이트
		local progressNum = 0
		local clear =false
		target:GetChildByName("CompletePanel"):SetEnable(false)
		
		local collectionTable =  _UserService.LocalPlayer.PlayerCollectionComponent.eCollectionTable
		local count = _UserService.LocalPlayer.PlayerCollectionComponent:GetMaterialTypeCount(collection.id)
		
		for i = 1 , count do
			local listCategory = _CollectionLogic.statusTable[collection.id].category
			
			if listCategory == "armor" then
				if _GameUtil:GetBoolValue(collectionTable[collection.id],i) then
					progressNum = progressNum + 1 
				end
		
				if progressNum == count then
					clear = true
					target:GetChildByName("CompletePanel"):SetEnable(true)
				end
		
			else
				if _GameUtil:GetNumberValueTen(collection.id,i,_UserService.LocalPlayer) then
					progressNum = progressNum + 1
				end
		 
				if progressNum == count then
					clear = true
					target:GetChildByName("CompletePanel"):SetEnable(true)
				end
			end
		end
		
		if clear == true then
			target:GetChildByName("TitlePanel"):GetChildByName("Title").TextComponent.Text = _LocalizeLogic:GetText("collectionName_"..collection.id).." "..string.format("<color=#899bbf>%s</color>", _LocalizeLogic:GetText("common_Complete"))
		else
			target:GetChildByName("TitlePanel"):GetChildByName("Title").TextComponent.Text = _LocalizeLogic:GetText("collectionName_"..collection.id).." "..string.format("<color=#899bbf>(%d/%d)</color>", progressNum, collection.materialTypeCount)
		end
		
		if collection.status_id == "hitDamage" then
			target:GetChildByName("TitlePanel"):GetChildByName("Ability", true).TextComponent.Text = _LocalizationService:GetText(collection.status_id).." "..tostring(collection.status_value).."%"
		elseif collection.status_id == "maxHp" then
			target:GetChildByName("TitlePanel"):GetChildByName("Ability", true).TextComponent.Text = _LocalizationService:GetText(collection.status_id).." +"..collection.status_value
		else
			target:GetChildByName("TitlePanel"):GetChildByName("Ability", true).TextComponent.Text = _LocalizationService:GetText(collection.status_id).." +"..tostring(collection.status_value).."%"
		end
		
		target:GetChildByName("MaterialPanelSlot"):GetChildByName("MaterialSlot_1").EquipCollectionMaterialSlot:Init(collection.material1_id, collection.id)
		target:GetChildByName("MaterialPanelSlot"):GetChildByName("MaterialSlot_2").EquipCollectionMaterialSlot:Init(collection.material2_id, collection.id)
		target:GetChildByName("MaterialPanelSlot"):GetChildByName("MaterialSlot_3").EquipCollectionMaterialSlot:Init(collection.material3_id, collection.id)
		target:GetChildByName("MaterialPanelSlot"):GetChildByName("MaterialSlot_4").EquipCollectionMaterialSlot:Init(collection.material4_id, collection.id)
		target:GetChildByName("MaterialPanelSlot"):GetChildByName("MaterialSlot_5").EquipCollectionMaterialSlot:Init(collection.material5_id, collection.id)
	end

	@ExecSpace("Client")
	method void OpenMaterialInventory()
		-- 재료 인벤토리 열기 및 재료 목록 초기화
		
		table.clear(self.materialList)
		local materialTable = {}
		materialTable = _CollectionLogic:GetEquipCollectionMaterialList(_UserService.LocalPlayer, _CollectionLogic.selectedMaterialId) 
		
		for key, value in pairs(materialTable) do
			table.insert(self.materialList, value) 
		end
		_CollectionLogic:RefreshCollectionPopupUI()
		
		local gridView = self.materialGrid.GridViewComponent
		gridView.TotalCount = #self.materialList
		gridView:Refresh(true , true)
		
		if #self.materialList >= 1 then
			self.alert_haveNoCount.Enable = false
		else
			self.alert_haveNoCount.Enable = true
		end
		
		if self.materialListPopup.CollectionMaterialListPopup.isOpen == false then
			self.materialListPopup.CollectionMaterialListPopup:Show()
		end
	end

	method void ResetMaterialInventory()
		-- 재료 인벤토리 선택 상태 초기화
		
		_CollectionLogic.selectedMaterialSlotNum = 0 
		_CollectionLogic.selectedListId = "" 
		_CollectionLogic.selectedMaterialId = "" 
		table.clear(_CollectionLogic.selectedUniqueKey) 
	end

	method void RefreshAbilityText(table statusTable)
		-- 컴렉션 달성 시 얻는 능력치 텍스트 업데이트
		self.ability_hp.Text = _LocalizationService:GetText("EnchantData_16").." "..statusTable["maxHp"] 
		self.ability_moveSpeed.Text = _LocalizationService:GetText("dateSet_CharacteristicData_skillName7").." "..statusTable["speed"].."%" 
		self.ability_attackSpeed.Text = _LocalizationService:GetText("ui_CharacterGroup_statName_3").." "..statusTable["attackSpeed"].."%"
		self.ability_range.Text = _LocalizationService:GetText("detailStatus14").." "..statusTable["range"].."%"
		self.ability_evade.Text = _LocalizationService:GetText("detailStatus20").." "..statusTable["evade"].."%"
		self.ability_damage.Text = _LocalizationService:GetText("common_IncreaseDamage").." "..statusTable["totalDamage"].."%"
		self.ability_physicalDamage.Text = _LocalizationService:GetText("EnchantData_18").." "..statusTable["physicalDamage"].."%"
		self.ability_magicalDamage.Text = _LocalizationService:GetText("EnchantData_19").." "..statusTable["magicalDamage"].."%"
		self.ability_criticalPercent.Text = _LocalizationService:GetText("EnchantData_21").." "..statusTable["criticalPercent"].."%"
		self.ability_criticalDamage.Text = _LocalizationService:GetText("ui_CharacterGroup_statName_6").." "..statusTable["criticalDamage"].."%"
		self.ability_bossDamage.Text = _LocalizationService:GetText("ui_CharacterGroup_statName_7") .. " "..statusTable["bossDamage"].."%"
	end

	method table GetTabDotTable()
		-- 각 등급별 컴렉션 등록 가능 여부 확인하여 닷 표시 상태 반환
		local publicCollectionTable = _CollectionLogic.equipCollectionSet
		local userCollectionTable = _UserService.LocalPlayer.PlayerCollectionComponent.eCollectionTable
		local userStorage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		local itemData = _ItemDataLogic.equipmentData
		
		local equipEnableNormal = false
		local equipEnableRare = false
		local equipEnableEpic = false
		local equipEnableUnique = false
		local equipEnableLegendary = false
		
		local normalTable = {}
		local rareTable = {}
		local epicTable = {}
		local uniqueTable = {}
		local legendaryTable = {}
		
		
		for k, value in pairs (publicCollectionTable) do
		
			local count = value.materialTypeCount 
			local listCategory = value.category 
			local grade = _UtilLogic:Split(value.grade, "_") 
		
			if _UtilLogic:IsNilorEmptyString(userCollectionTable[value.id]) then 
				for _, v  in pairs (userStorage) do 
					if v.originalId == value.material1_id or v.originalId == value.material2_id or v.originalId == value.material3_id or v.originalId == value.material4_id or v.originalId == value.material5_id then
						if v.lock == false then
							if grade[1] == "normal" then
								equipEnableNormal = true	
							elseif grade[1] == "rare" then
								equipEnableRare = true
							elseif grade[1] == "epic" then
								 equipEnableEpic = true
							elseif grade[1] == "unique" then
							 	equipEnableUnique = true
							elseif grade[1] == "legendary" then
								equipEnableLegendary = true
							end
						end
					end
				end
		
		 	else 
				for j = 1 , count do 
					local table = {value.material1_id, value.material2_id, value.material3_id, value.material4_id, value.material5_id}
					
					if listCategory == "armor" then	
						if not _GameUtil:GetBoolValue(userCollectionTable[value.id], j) then 
							for _, v in pairs (userStorage) do
								if v.originalId == table[j] then
									if grade[1] == "normal" then
										equipEnableNormal = true	
									elseif grade[1] == "rare" then
										equipEnableRare = true
									elseif grade[1] == "epic" then
							 			equipEnableEpic = true
									elseif grade[1] == "unique" then
								 		equipEnableUnique = true
									elseif grade[1] == "legendary" then
										equipEnableLegendary = true
									end	
								end
								break
							end
								
						end
					
					else 
						if not _GameUtil:GetNumberValueTen(value.id, j, _UserService.LocalPlayer) then
							for _, v in pairs (userStorage) do
								if v.originalId == table[j] then
									if v.lock == false then
										if grade[1] == "normal" then
											equipEnableNormal = true	
										elseif grade[1] == "rare" then
											equipEnableRare = true
										elseif grade[1] == "epic" then
									 		equipEnableEpic = true
										elseif grade[1] == "unique" then
								 			equipEnableUnique = true
										elseif grade[1] == "legendary" then
											equipEnableLegendary = true
										end
									end
									break
								end
							end
						end
					end
				end
			end
		end
		
		local result = {equipEnableNormal, equipEnableRare, equipEnableEpic, equipEnableUnique, equipEnableLegendary}
		
		return result
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "b3674e6f-ba44-4e4d-a10b-6842c9258cbc")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 컴렉션 팝업 열기 버튼 클릭
		
		local Entity = event.Entity
		self:Show()
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "045b7592-73c1-443d-954a-f76c956d3b25")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 컴렉션 팝업 닫기 버튼 클릭
		
		local Entity = event.Entity
		self:Hide()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "30f90058-29a9-4fe5-855f-0b36a077c81c")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 이전 페이지 버튼 클릭
		
		local Entity = event.Entity
		self:SetPage(-1)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "3215c3a6-ffc6-4477-9d8e-6dc403b67ce9")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 다음 페이지 버튼 클릭
		
		local Entity = event.Entity
		self:SetPage(1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f4e12a36-1f46-41dd-a6d0-22bb287e54ce")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 일반 등급 버튼 클릭
		
		local Entity = event.Entity
		self:SetGradeNumber(1, Entity)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "80d7d1c2-a250-446a-9208-2de22de3d0ee")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 레어 등급 버튼 클릭
		
		local Entity = event.Entity
		self:SetGradeNumber(2, Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "4b03cfd8-e6ad-49c8-9e55-e69ded1c4075")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 에픽 등급 버튼 클릭
		
		local Entity = event.Entity
		self:SetGradeNumber(3, Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "9325cc7d-0c4b-4361-b23a-5e6cfb163c07")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 유니크 등급 버튼 클릭
		
		local Entity = event.Entity
		self:SetGradeNumber(4, Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "fe863023-1914-479b-82b5-3b15bd866031")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 레전드 등급 버튼 클릭
		
		local Entity = event.Entity
		self:SetGradeNumber(5, Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "963c71fe-01e2-4d4f-b79d-017bf9166cce")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- 재료 인벤토리 닫기 버튼 클릭 이벤트
		
		local Entity = event.Entity
		self:ResetMaterialInventory()
		self.materialListPopup.CollectionMaterialListPopup:Hide()
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "1e4de853-9892-4ff9-b2ad-54be43c9b1d5")
	handler HandleButtonClickEvent11(ButtonClickEvent event)
		-- 컴렉션 등록 버튼 클릭 이벤트
		
		local Entity = event.Entity
		
		if #_CollectionLogic.selectedUniqueKey < 1 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast369"))
		else
			_UIPopup:Open(_LocalizeLogic:GetText("popup69"), _LocalizeLogic:GetText("popup70"), function ()
			 _CollectionLogic:RegisterToCollection(_UserService.LocalPlayer) end, function() end)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6812bc47-9eb9-4c68-b35b-e185a63ecd0e")
	handler HandleButtonClickEvent13(ButtonClickEvent event)
		-- 전체 선택/해제 버튼 클릭 이벤트
		
		local Entity = event.Entity
		local category = _CollectionLogic.statusTable[_CollectionLogic.selectedListId].category
		local requestState = "registAll"
		
		if #_CollectionLogic.selectedUniqueKey >= 1 then 
			requestState = "removeAll"
		end
		
		for i =1, #self.materialList do 
			_CollectionLogic:SendEvent(SelectCollectionMaterial(self.materialList[i].uniqueKey, _UserService.LocalPlayer, nil, category, requestState))
		end
		
		local gridView = self.materialGrid.GridViewComponent
		gridView.TotalCount = #self.materialList
		gridView:Refresh(true, true)
	end

end