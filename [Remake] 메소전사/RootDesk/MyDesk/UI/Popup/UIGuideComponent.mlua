@Component
script UIGuideComponent extends UICommonPopup

	method void Show()
		-- 가이드 팝업을 화면에 표시
		__base:Show()
	end

	method void Hide()
		-- 가이드 팝업을 화면에서 숨김
		__base:Hide()
	end

	@EventSender("Entity", "e7d7555e-c285-49a8-959f-6c6949df1406")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 가이드 팝업을 숨김
		
		local Entity = event.Entity
		self:Hide()
	end

end