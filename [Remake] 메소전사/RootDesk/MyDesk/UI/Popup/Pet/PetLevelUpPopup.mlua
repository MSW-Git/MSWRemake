@Component
script PetLevelUpPopup extends UICommonPopup

	property Entity displaySlot_1 = "33d409bc-5342-4b1b-bbb5-e28ead5fbd04"

	property Entity displaySlot_2 = "ce0821ce-548a-43dd-ac17-8bf1eee79e55"

	property Entity clickDescPanel = "6b5c4292-6440-421d-83ad-4e07a41089ff"

	@ExecSpace("Client")
	method void Init(string uniqueKey)
		-- 펫 레벨업 팝업 초기화 및 펫 정보 표시
		self.displaySlot_1.PetListSlotComponent:SetSlot(uniqueKey)
		
		local originalId = _UserService.LocalPlayer.PlayerPetStorageComponent.petInventory[uniqueKey].originalId
		local petData = _PetLogic.petData[originalId]
		
		self.Entity:GetChildByName("desc_TopPanel", true).SpriteGUIRendererComponent.Color = Color.FromHexCode(_PetLogic:GetCategoryPanelColor(originalId))
		self.Entity:GetChildByName("PetTitle", true).TextComponent.Text = _LocalizeLogic:GetPetName(originalId)
		self.Entity:GetChildByName("DescriptionText_1", true).TextComponent.Text = _PetLogic:GetDescription(uniqueKey, petData, false, true)
		
		_PetUILogic.petLevelUpList:SetDescriptionPanel("")
		self:Show()
	end

	method void Hide()
		-- 펫 레벨업 팝업을 숨김
		__base:Hide()
		
	end

end