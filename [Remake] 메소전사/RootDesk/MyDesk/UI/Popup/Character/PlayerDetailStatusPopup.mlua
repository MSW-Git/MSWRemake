@Component
script PlayerDetailStatusPopup extends UICommonPopup

	property Entity statLayout = "51518731-e3d9-48b8-a975-d68b875dddea"

	method void Show()
		-- 플레이어 상세 스테이터스 팝업을 표시하고 상태 새로고침
		self:StatusRefresh()
		__base:Show()
	end

	method void StatusRefresh()
		-- 플레이어의 모든 상세 스테이터스 정보를 새로고침
		local textEntities = self.statLayout.Children
		
		for _, entity in pairs(textEntities) do
			entity.Enable = true
		end
		
		textEntities[1].TextComponent.Text = _LocalizeLogic:GetText("battlePowerToast1")
		textEntities[1]:GetChildByName("Value").TextComponent.Text = string.format("%d", _MySpecLogic.mySpec.battlePower)
		
		textEntities[2].TextComponent.Text = _LocalizeLogic:GetText("detailStatus1")
		textEntities[2]:GetChildByName("Value").TextComponent.Text = string.format("%d", _MySpecLogic.mySpec.attack)
		
		textEntities[3].TextComponent.Text = _LocalizeLogic:GetText("common_Hp")
		textEntities[3]:GetChildByName("Value").TextComponent.Text = string.format("%d", _MySpecLogic.mySpec.maxHp)
		
		textEntities[4].TextComponent.Text = _LocalizeLogic:GetText("totalDamage") 
		textEntities[4]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", (_MySpecLogic.mySpec.totalDamage+1) * 100) 
		
		textEntities[5].TextComponent.Text = _LocalizeLogic:GetText("physicalDamage") 
		textEntities[5]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", (_MySpecLogic.mySpec.physicalDamage+1) * 100) 
		
		textEntities[6].TextComponent.Text = _LocalizeLogic:GetText("magicalDamage") 
		textEntities[6]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", (_MySpecLogic.mySpec.magicalDamage+1) * 100) 
		
		textEntities[7].TextComponent.Text = _LocalizeLogic:GetText("hpRecovery")
		textEntities[7]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.hpRecovery * 100) 
		textEntities[7].Enable = false	
		
		textEntities[8].TextComponent.Text = _LocalizeLogic:GetText("detailStatus7")
		textEntities[8]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.absorption)
		textEntities[8].Enable = false 
		
		textEntities[9].TextComponent.Text = _LocalizeLogic:GetText("dateSet_CharacteristicData_skillName7")
		textEntities[9]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", (_MySpecLogic.mySpec.speed-1)*100)
		
		textEntities[10].TextComponent.Text = _LocalizeLogic:GetText("ui_CharacterGroup_statName_3")
		textEntities[10]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", (_MySpecLogic.mySpec.attackSpeed-1)*100)
		
		textEntities[11].TextComponent.Text = _LocalizeLogic:GetText("criticalPercent")
		textEntities[11]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.criticalPercent)
			
		textEntities[12].TextComponent.Text = _LocalizeLogic:GetText("ui_CharacterGroup_statName_6")
		textEntities[12]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.criticalDamage) 
		
		textEntities[13].TextComponent.Text = _LocalizeLogic:GetText("ui_CharacterGroup_statName_7")
		textEntities[13]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.bossDamage * 100) 
		
		textEntities[14].TextComponent.Text = _LocalizeLogic:GetText("detailStatus13")
		textEntities[14]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.hitDamage * 100) 
		textEntities[14].Enable = false 
		
		textEntities[15].TextComponent.Text = _LocalizeLogic:GetText("detailStatus14")
		textEntities[15]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.range * 100)
			
		textEntities[16].TextComponent.Text = _LocalizeLogic:GetText("evade")
		textEntities[16]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.evade * 100) 
		
		textEntities[17].TextComponent.Text = _LocalizeLogic:GetText("detailStatus16")
		textEntities[17]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", math.abs(_MySpecLogic.mySpec.reductMeleeDamage * 100))
		
		textEntities[18].TextComponent.Text = _LocalizeLogic:GetText("detailStatus17")
		textEntities[18]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", math.abs(_MySpecLogic.mySpec.reductProjectileDamage * 100))
		
		
		textEntities[19].TextComponent.Text = _LocalizeLogic:GetText("detailStatus18") 
		textEntities[19]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.extraEggDropRate)
		textEntities[19].Enable = false 
		
		textEntities[20].TextComponent.Text = _LocalizeLogic:GetText("detailStatus19") 
		textEntities[20]:GetChildByName("Value").TextComponent.Text = string.format("%.2f%%", _MySpecLogic.mySpec.stageClearRewardBonusRate)
		textEntities[20].Enable = false 
		
		
		
		for _, entity in pairs(textEntities) do
			local value = entity:GetChildByName("Value")
			
			if value.TextComponent.Text == "0.00%" then
				value.TextComponent.Text = "0%"
			end
		end
	end

end