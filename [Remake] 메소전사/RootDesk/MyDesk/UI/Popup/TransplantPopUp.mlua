@Component
script TransplantPopUp extends UICommonPopup

	property Entity accSlot = "23776ff8-3cfa-485b-905d-8e7bde60e162"

	property Entity materialAccSlot = "af491df6-1096-4715-ba05-26f910bc7a17"

	property Entity contentPanel = "710f0223-a3fb-40be-9bde-2b5b1c72f8d8"

	property Entity bottomPanel = "2ec7b107-10b7-4ec8-b446-c429d56645d6"

	property string accUniqueKey = ""

	property string materialAccUniqueKey = ""

	property Entity predictAccSlot = "f812897d-0d23-4c55-a1a6-0b5c4d303f44"

	property MaterialListPopUp materialList = "842d49fa-9956-4d87-bb2a-fa3cea79e712"

	property Entity detailGuide = "c83718ae-47d9-45e5-9306-47f635207bb2"

	property Entity topPanel = "37e91d0c-560e-4da0-84ce-85cf78d20f0f"

	property Entity clickEffect = "337544d8-2270-4998-96e6-de18cfadea93"

	method void Show()
		-- 이식 팝업 표시 전 내용 새로고침
		self:Refresh()
		__base:Show()
	end

	method void Hide()
		-- 팝업 숨김 시 상태 초기화
		self:Init()
		__base:Hide()
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 이식 팝업 초기화
		__base:OnBeginPlay()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 이식 UI 전체 새로고침 및 예측 결과 표시
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		
		
		local accBgRenderer = self.accSlot.SpriteGUIRendererComponent
		local accSprite = self.accSlot:GetChildByName("Sprite")
		local accReinforceText = self.accSlot:GetChildByName("reinforceText")
		local accGrade = self.accSlot:GetChildByName("Grade_Alphabet")
		local accCategory = self.accSlot:GetChildByName("Category")
		
		local matAccBgRenderer = self.materialAccSlot.SpriteGUIRendererComponent
		local matAccSprite = self.materialAccSlot:GetChildByName("Sprite")
		local matAccReinforceText = self.materialAccSlot:GetChildByName("reinforceText")
		local matAccGrade = self.materialAccSlot:GetChildByName("Grade_Alphabet")
		local matAccCategory = self.materialAccSlot:GetChildByName("Category")
		
		local predictAccBgRenderer = self.predictAccSlot.SpriteGUIRendererComponent
		local predicAccSprite = self.predictAccSlot:GetChildByName("Sprite")
		local predicAccReinforceText = self.predictAccSlot:GetChildByName("reinforceText")
		local predicAccGrade = self.predictAccSlot:GetChildByName("Grade_Alphabet")
		local predictAccCategory = self.predictAccSlot:GetChildByName("Category")
		
		local optionPanel = self.contentPanel:GetChildByName("OptionPanel")
		local matOptionPanel = self.contentPanel:GetChildByName("OptionPanel_Material")
		local matNoticeEmpty = matOptionPanel:GetChildByName("text_empty")
		local predictOptionPanel = self.contentPanel:GetChildByName("OptionPanel_Predict")
		
		local materialText = self.bottomPanel:GetChildByName("MaterialText")
		local materialIcon = materialText:GetChildByName("IconMaterial")
		local mesoText = self.bottomPanel:GetChildByName("MesoText")
		
		materialText.TextComponent.Text = ""
		mesoText.TextComponent.Text = ""
			
		self.clickEffect.Enable = false
		
		self.bottomPanel.Enable = false
		
		
		if self.accUniqueKey == "" then
			self.materialAccUniqueKey = ""
			accReinforceText.Enable = false
			
			self.accSlot.Enable = false
			accGrade.Enable = false
			
			for i = 1, 5 do
				local slot = optionPanel:GetChildByName("list"):GetChildByName(string.format("optionSlot_%d", i))
				slot.Enable = false
			end
		else
			local item = storage.storage[self.accUniqueKey]
			local itemData =  _ItemDataLogic.itemData[item.originalId]
				
			if itemData.grade == "normal" then
				accBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			elseif itemData.grade == "rare" then
				accBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
			elseif itemData.grade == "epic" then
				accBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
			elseif itemData.grade == "unique" then
				accBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
			elseif itemData.grade == "legendary" then
				accBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
			end
			accCategory.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
			
			local categoryIcon = _ItemDataLogic:GetCategoryRUID(_ItemDataLogic:GetAccessoryDetailCategory(item.originalId))
			accCategory:GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = categoryIcon
			matAccCategory:GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = categoryIcon
			predictAccCategory:GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = categoryIcon
			
			accSprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
			accSprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
			accReinforceText.TextComponent.Text = string.format("%d", item.level)
			accReinforceText.Enable = true
			
			accGrade.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(item.grade)
			accGrade.Enable = true
			
			optionPanel:GetChildByName("TitleText").Enable = true
			for i = 1, 5 do
				local key = string.format("option_%d", i) 
				local slot = optionPanel:GetChildByName("list"):GetChildByName(string.format("optionSlot_%d", i))
				local icon = slot:GetChildByName("icon_grade")
				local bg = slot:GetChildByName("bg")
				local desc = slot:GetChildByName("desc")
				
				if isvalid(item[key]) then
					if item[key] ~= "" then
						local parse = _UtilLogic:Split(item[key], "_")
						local optionId = parse[1]
						local stat = tonumber(parse[2])
						local enchantGrade = _AccessoryLogic:GetEnchantGrade(optionId, stat)
						
						desc.TextComponent.Text = string.format("%s : %s%%", _LocalizeLogic:GetEnchantName(optionId), _GameUtil:GetOptimalFloatStr(stat))
						desc.TextComponent.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(enchantGrade))
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID(enchantGrade)
					else
						desc.TextComponent.Text = _LocalizeLogic:GetText("etcStr185")
						desc.TextComponent.FontColor = Color.FromHexCode("#6f6f6f")
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID("")
					end
					
					slot.Enable = true
				else
					slot.Enable = false
				end
			end
			
			self.accSlot.Enable = true
		end
		
		
		
		if self.materialAccUniqueKey == "" then
			matAccReinforceText.Enable = false
			
			self.materialAccSlot.Enable = false
			matAccGrade.Enable = false
			
			for i = 1, 5 do
				local slot = matOptionPanel:GetChildByName("list"):GetChildByName(string.format("optionSlot_%d", i))
				slot.Enable = false
			end
			
			self.clickEffect.Enable = true
			matNoticeEmpty.Enable = true
		else
			local item = storage.storage[self.materialAccUniqueKey]
			local itemData =  _ItemDataLogic.itemData[item.originalId]
				
			if itemData.grade == "normal" then
				matAccBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			elseif itemData.grade == "rare" then
				matAccBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
			elseif itemData.grade == "epic" then
				matAccBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
			elseif itemData.grade == "unique" then
				matAccBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
			elseif itemData.grade == "legendary" then
				matAccBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
			end
			matAccCategory.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
			
			matAccSprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
			matAccSprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
			matAccReinforceText.TextComponent.Text = string.format("%d", item.level)
			matAccReinforceText.Enable = true
			
			matAccGrade.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(item.grade)
			matAccGrade.Enable = true
			
			matOptionPanel:GetChildByName("TitleText").Enable = true
			for i = 1, 5 do
				local key = string.format("option_%d", i) 
				local slot = matOptionPanel:GetChildByName("list"):GetChildByName(string.format("optionSlot_%d", i))
				local icon = slot:GetChildByName("icon_grade")
				local bg = slot:GetChildByName("bg")
				local desc = slot:GetChildByName("desc")
				
				if isvalid(item[key]) then
					if item[key] ~= "" then
						local parse = _UtilLogic:Split(item[key], "_")
						local optionId = parse[1]
						local stat = tonumber(parse[2])
						local enchantGrade = _AccessoryLogic:GetEnchantGrade(optionId, stat)
						
						desc.TextComponent.Text = string.format("%s : %s%%", _LocalizeLogic:GetEnchantName(optionId), _GameUtil:GetOptimalFloatStr(stat))
						desc.TextComponent.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(enchantGrade))
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID(enchantGrade)
					else
						desc.TextComponent.Text = _LocalizeLogic:GetText("etcStr185")
						desc.TextComponent.FontColor = Color.FromHexCode("#6f6f6f")
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID("")
					end
					
					slot.Enable = true
				else
					slot.Enable = false
				end
			end
			
			matNoticeEmpty.Enable = false
			self.materialAccSlot.Enable = true
		end
		
		if self.accUniqueKey ~= "" and self.materialAccUniqueKey ~= "" then
			local userId = _UserService.LocalPlayer.PlayerComponent.UserId
			local currency = player.PlayerCurrencyData
			local accessoryData = _AccessoryLogic.accessoryData[storage.storage[self.accUniqueKey].originalId]
			local needScrollId = accessoryData.transplantMaterialId
			local needScrollCount = accessoryData.transplantMaterialCount
			local needMeso = accessoryData.transplantMeso
			
			local item = storage.storage[self.accUniqueKey]
			local itemData = _ItemDataLogic.itemData[item.originalId]
			local material = storage.storage[self.materialAccUniqueKey]
				
			if itemData.grade == "normal" then
				predictAccBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			elseif itemData.grade == "rare" then
				predictAccBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
			elseif itemData.grade == "epic" then
				predictAccBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
			elseif itemData.grade == "unique" then
				predictAccBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
			elseif itemData.grade == "legendary" then
				predictAccBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
			end
			predictAccCategory.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
			
			predicAccSprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
			predicAccSprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
			predicAccReinforceText.TextComponent.Text = string.format("%d", item.level)
			predicAccReinforceText.Enable = true
			
			predicAccGrade.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(item.grade)
			predicAccGrade.Enable = true
			
			predictOptionPanel:GetChildByName("TitleText").Enable = true
			for i = 1, _AccessoryLogic:GetGradeNum(item.grade) do
				local key = string.format("option_%d", i) 
				local slot = predictOptionPanel:GetChildByName("list"):GetChildByName(string.format("optionSlot_%d", i))
				local icon = slot:GetChildByName("icon_grade")
				local bg = slot:GetChildByName("bg")
				local desc = slot:GetChildByName("desc")
				
				if isvalid(material[key]) then
					if material[key] ~= "" then
						local parse = _UtilLogic:Split(material[key], "_")
						local optionId = parse[1]
						local stat = tonumber(parse[2])
						local enchantGrade = _AccessoryLogic:GetEnchantGrade(optionId, stat)
						
						desc.TextComponent.Text = string.format("%s : %s%%", _LocalizeLogic:GetEnchantName(optionId), _GameUtil:GetOptimalFloatStr(stat))
						desc.TextComponent.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(enchantGrade))
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID(enchantGrade)
					else
						desc.TextComponent.Text = _LocalizeLogic:GetText("etcStr185")
						desc.TextComponent.FontColor = Color.FromHexCode("#6f6f6f")
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID("")
					end
					
					slot.Enable = true
				else
					if isvalid(item[key]) then
						desc.TextComponent.Text = _LocalizeLogic:GetText("etcStr185")
						desc.TextComponent.FontColor = Color.FromHexCode("#6f6f6f")
						icon.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID("")
							
						slot.Enable = true
					else
						slot.Enable = false
					end
				end
			end
			
			self.predictAccSlot.Enable = true
			
			
			if needScrollId == "" then
				materialIcon.Enable = false
				materialText.TextComponent.Text = ""
			else
				local materialData = _ItemDataLogic.itemData[needScrollId]
				materialIcon.SpriteGUIRendererComponent.ImageRUID = materialData.ruid
				materialIcon.SpriteGUIRendererComponent.LocalPosition = Vector2(materialData.offsetX / 2, materialData.offsetY / 2)
				materialIcon.Enable = true
				materialText.TextComponent.Text = 
					string.format("%d/%d", storage:GetItemCount(needScrollId), needScrollCount)
				
				self.bottomPanel.Enable = true
			end
			
			mesoText.TextComponent.Text = 
				string.format("%s/%s", _NumberSeparator:ConvertToMetricPrefixString(currency.gold, "ko"), _NumberSeparator:ConvertToMetricPrefixString(needMeso, "ko"))
			
			if needScrollId ~= "" and storage:GetItemCount(needScrollId) < needScrollCount then
				materialText.TextComponent.FontColor = Color.FromHexCode("#E55454")
			else
				materialText.TextComponent.FontColor = Color.white
			end
			
			if not _CheckLogic:IsEnoughWealth(userId, _GameConfig:GetConfig().WEALTHTYPE_MESO, needMeso) then
				mesoText.TextComponent.FontColor = Color.FromHexCode("#E55454")
			else
				mesoText.TextComponent.FontColor = Color.white
			end
		else
			materialIcon.Enable = false
			materialText.TextComponent.Text = ""
			self.predictAccSlot.Enable = false
			
			for i = 1, 5 do
				local slot = predictOptionPanel:GetChildByName("list"):GetChildByName(string.format("optionSlot_%d", i))
				slot.Enable = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 이식 팝업 상태 초기화
		self.accUniqueKey = ""
		self.materialAccUniqueKey = ""
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2746aa03-a386-4609-bbd3-313a93c3b056")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 이식 실행 버튼 클릭 시 유효성 검사 후 이식 요청
		
		local Entity = event.Entity
		if self.accUniqueKey == "" then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast366"))
			
			return
		end
		
		if self.materialAccUniqueKey == "" then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast365"))
			
			return
		end
		
		local player = _UserService.LocalPlayer
		local userId = player.PlayerComponent.UserId
		local storage = player.PlayerStorageComponent
		local targetGrade = storage.storage[self.accUniqueKey].grade
		local materialGrade = storage.storage[self.materialAccUniqueKey].grade
		
		if _AccessoryLogic:GetGradeNum(targetGrade) < _AccessoryLogic:GetGradeNum(materialGrade) then
			local str = string.format(_LocalizeLogic:GetText("toast91"), targetGrade, materialGrade)
			_UIToast:ShowMessage(str)
			
			return
		end
		
		local accData = _AccessoryLogic.accessoryData[storage.storage[self.accUniqueKey].originalId]
		local needScrollId = accData.transplantMaterialId
		local needScrollCount = accData.transplantMaterialCount
		
		if needScrollId ~= "" and storage:GetItemCount(needScrollId) < needScrollCount then
			_UIToast:ShowMessage(string.format(_LocalizeLogic:GetText("toast69"), _ItemDataLogic.itemData[needScrollId]))
			
			return
		end
		
		if not _CheckLogic:IsEnoughWealth(userId, _GameConfig:GetConfig().WEALTHTYPE_MESO, accData.transplantMeso) then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast86"))
			
			return
		end
		
		_UIPopup:Open(_LocalizeLogic:GetText("transplantStr1"), _LocalizeLogic:GetText("transplantStr2"), function()
			_AccessoryLogic:RequestTransplant(self.accUniqueKey, self.materialAccUniqueKey)
			self:Hide()
			end, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "00bde89b-1baa-4483-bc95-631fd3127fc5")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "3a2df6ef-e2ea-44f4-b48a-651d14082341")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 대상 액세서리 선택 버튼 클릭 시 재료 목록 열기
		
		local Entity = event.Entity
		self.materialList:SetCategory("TransplantTarget", "accessory", "")
		self.materialList:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "4f8e6e91-5531-4c2b-a8e9-eeb8499ab7fc")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 재료 액세서리 선택 버튼 클릭 시 재료 목록 열기
		
		local Entity = event.Entity
		if self.accUniqueKey == "" then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast367"))	
		
			return
		end
		
		local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.accUniqueKey]
		
		self.materialList:SetCategory("TransplantMaterial", _ItemDataLogic:GetAccessoryDetailCategory(item.originalId), item.grade)
		self.materialList:Show()
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "d8a2e9fd-e3e9-4beb-a336-7914f0630330")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 상세 가이드 열기 버튼 클릭
		
		local Entity = event.Entity
		if not self.detailGuide.Enable then
			self.detailGuide.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "531fdb24-d792-47b6-b773-2b77393a714e")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 상세 가이드 닫기 버튼 클릭
		
		local Entity = event.Entity
		if self.detailGuide.Enable then
			self.detailGuide.Enable = false
		end
		
	end

end