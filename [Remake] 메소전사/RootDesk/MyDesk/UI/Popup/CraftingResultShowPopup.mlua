@Component
script CraftingResultShowPopup extends UICommonPopup

	property SpriteGUIRendererComponent panelTitle = "2bf236dc-21cf-4d70-9be3-244b79dde974"

	method void Show()
		-- 팝업을 화면에 표시
		__base:Show()
	end

	method void Open(string grade)
		-- 제작 결과 팝업을 등급에 맞는 색상으로 열기
		_SoundService:PlaySound("3522602059be4376a95c47c981ec0099",1)
		self.panelTitle.Color = _WeaponSpecLogic:GetColorBackByGrade(grade)
		self:Show()
	end

end