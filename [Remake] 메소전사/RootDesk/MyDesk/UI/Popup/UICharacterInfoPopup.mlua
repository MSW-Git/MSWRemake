		local Entity = event.Entity
		self:InitCharList(true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a71961da-0856-4595-b773-1696cc05d345")
	handler HandleButtonClickEvent15(ButtonClickEvent event)
		-- 현재 장비된 캐릭터 정보 보기 버튼 클릭
		
		local Entity = event.Entity
		
		local charIndex = tostring(math.floor(_UserService.LocalPlayer.PlayerCharacterData.charIndex))
		self:OpenCharacterInformationPanel(charIndex)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleChangeCharacterPieceCount(ChangeCharacterPieceCount event)
		-- 캐릭터 조각 수 변경 이벤트 처리
		local pieceTable = event.table
		local index = self._T.selectedIndex 
		
		if self._T.selectedIndex == nil or self._T.selectedIndex == "" then
			return
		end
		
		self.panel_CharacterPiece:GetChildByName("PieceCount").TextComponent.Text = pieceTable.count.."/"..
		_CharacterGachaLogic.characterExpTable[index][_UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[index].tier]
		
		self.panel_CharacterPiece:GetChildByName("Bar").SliderComponent.Value = 
		pieceTable.count/_CharacterGachaLogic.characterExpTable[index][_UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[index].tier]
		
		self.panel_CharacterPiece:GetChildByName("PieceIcon").SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[tostring(index)].pieceLargeRUID
	end

end