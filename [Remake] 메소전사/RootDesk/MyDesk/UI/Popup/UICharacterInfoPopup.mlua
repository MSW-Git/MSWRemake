	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a9714a49-a4d2-49cd-b95e-6fa2fe89e906")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- 관계 탭 버튼 클릭 시 관계 목록으로 전환
		
		local Entity = event.Entity
		self:InitCharList(false)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "66fdb17f-9bfe-4c87-bbd9-9b11caf370c1")
	handler HandleButtonClickEvent11(ButtonClickEvent event)
