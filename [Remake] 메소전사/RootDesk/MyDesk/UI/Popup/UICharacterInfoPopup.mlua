	method void OpenCharacterInformationPanel(string index)
		-- 캐릭터 정보 패널 열기 및 장비 상태 설정
		
		_UIGroupManager.uiCharacterGroup.listPage:SetEnable(false)
		
		if _UserService.LocalPlayer.PlayerCharacterData.charIndex == tonumber(index) then
			self.button_equip.Enable = false
			self.button_equipping.Enable = true
		
			self.equippedIcon.Enable = true
		else
			self.button_equip.Enable = true
			self.button_equipping.Enable = false
		
			self.equippedIcon.Enable = false
		end
		
		self.selectedCharIndex = tonumber(index)
		
		local data = _CharacterLogic.characterTable[index]
		local myCharData = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(index)]
		local exWeaponId = data.exWeaponId
		
		self.charName.Text = _LocalizationService:GetText("soul_name_"..index)
		self.charModifier.Text = _LocalizationService:GetText("soul_modifier_"..index)
		self.char_illust.ImageRUID = data.charRUID 
		
		self.image_exWeapon_1.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(exWeaponId[1])
		self.image_exWeapon_2.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(exWeaponId[2])
		self.image_exWeapon_3.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(exWeaponId[3])
		self.image_exWeapon_4.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(exWeaponId[4])
		self.image_exWeapon_5.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(exWeaponId[5])
		
		self.exWeaponIcon.SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[exWeaponId[1]].type)
		
		local nameKey =  _WeaponSpecLogic.weaponData[exWeaponId[1]].type
		self.exWeaponName.Text = _LocalizationService:GetText(nameKey)
		
		self.desc_exWeapon_0.Text = _LocalizeLogic:GetText("dataSet_CharacterData_lvEffect_desc_0")
		self.desc_exWeapon_1.Text = _LocalizeLogic:GetText("dataSet_CharacterData_lvEffect_desc_1")
		self.desc_exWeapon_2.Text = _LocalizeLogic:GetText("dataSet_CharacterData_lvEffect_desc_2")
		self.desc_exWeapon_3.Text = _LocalizeLogic:GetText("dataSet_CharacterData_lvEffect_desc_3")
		self.desc_exWeapon_4.Text = _LocalizeLogic:GetText("dataSet_CharacterData_lvEffect_desc_4")
		self.desc_exWeapon_5.Text = _LocalizeLogic:GetText("dataSet_CharacterData_lvEffect_desc_5")
		
		self:RefreshMainPanel()
		
		self:Show()
		
		_UIOpenQuestLogic:CheckQuestInProgress("soul",self.Entity)
	end

	method void CloseCharacterInformationPanel()
		-- 캐릭터 정보 패널 닫기 및 목록 복귀
		self.selectedCharIndex = 0
		
		_UIGroupManager.uiCharacterGroup.listPage:SetEnable(true)
		self.Entity:SetEnable(false)
		
		if self.panel_charList.Enable == true then 
			self:InitCharList(true)
		else 
			self:InitCharList(false)
		end
	end

	@ExecSpace("Client")
	method void RefreshMainPanel()
		-- 캐릭터 정보 메인 패널 새로고침
		if self.selectedCharIndex == 0 then
			return
		end
		
		local data = _CharacterLogic.characterTable[tostring(self.selectedCharIndex)]
		local character = _UserService.LocalPlayer.PlayerCharacterData
		local myCharData = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[self.selectedCharIndex]
		local armorStatus = _UserService.LocalPlayer.PlayerStorageComponent.armorStatusTable
		local starChildren = self.panel_CharStarCount.Children
		local tier = myCharData.tier
		
		self.charCurrentLevel.Text = myCharData.level .."/"..string.format("<color=#7484A3>%d</color>", myCharData.maxLevel) 
		
		for i = 1 , #starChildren do
			if i <= tier then 
				self.panel_CharStarCount:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "3843e4fe4bb94566aca74d99df0f1a67"
			else
				self.panel_CharStarCount:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "39e0123e4b18480d9fda2505d4074ef1"
			end
		end
		
		for i = 1 , #self.starEffectDescPanel.Children do
			if tier >= i - 1 then
				for j = 1 , 5 do
					self.starEffectDescPanel.Children[i]:GetChildByName("stars"):GetChildByName("Star_"..math.floor(j)).SpriteGUIRendererComponent:ChangeMaterial("")	
				end
				self.starEffectDescPanel.Children[i]:GetChildByName("Desc").TextComponent.FontColor = Color.white
			else
				for j = 1 , 5 do
					self.starEffectDescPanel.Children[i]:GetChildByName("stars"):GetChildByName("Star_"..math.floor(j)).SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4")	
				end
				self.starEffectDescPanel.Children[i]:GetChildByName("Desc").TextComponent.FontColor = Color.gray
			end
		end
		
		local canLvUp = _CharacterLogic:GetLevelUpEnable(_UserService.LocalPlayer, myCharData.level)
		local canBreak = _CharacterLogic:GetBreakLimitEnable(_UserService.LocalPlayer, tier, self.selectedCharIndex)
		
		if myCharData.level == _CharacterLogic.charMaxLevel then
			canLvUp = false
			canBreak = false
		end
		
		if myCharData.level >= myCharData.maxLevel then
			canLvUp = false
		end
		
		self.levelButton:GetChildByName("upArrow", true).Enable = canLvUp
		self.breakButton:GetChildByName("upArrow", true).Enable = canBreak
		self.piece_UpArrow.Enable = canBreak
		
		self.panel_CharacterPiece:GetChildByName("PieceIcon").SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[tostring(self.selectedCharIndex)].pieceLargeRUID
		
		if tier >= 5 then
			self.panel_CharacterPiece:GetChildByName("PieceCount").TextComponent.Text = "MAX!"
			self.panel_CharacterPiece:GetChildByName("Bar").SliderComponent.Value = 1
		else
			local getPieceCount = character.charPieceStorage[self.selectedCharIndex].count
			local needPieceCount = _CharacterLogic:GetCharBreakLimitCost(myCharData.tier).needPiece
			
			self.panel_CharacterPiece:GetChildByName("PieceCount").TextComponent.Text = math.floor(getPieceCount).."/"..math.floor(needPieceCount)
			self.panel_CharacterPiece:GetChildByName("Bar").SliderComponent.Value = getPieceCount/needPieceCount
		end
		
		local statusData = _CharacterLogic:GetCharacterStatus(self.selectedCharIndex, myCharData.level) 
		
		self.desc_charStat_1.Text = string.format("%d", statusData.maxHp)
		self.desc_charStat_2.Text = string.format("%.2f%%", statusData.damageRate + 100)
		self.desc_charStat_3.Text = string.format("%.2f%%", statusData.attackSpeed * 100)
		self.desc_charStat_4.Text = string.format("%.2f%%", statusData.moveSpeed * 100)
		self.desc_charStat_5.Text = string.format("%.2f%%", statusData.criticalRate )
		self.desc_charStat_6.Text = string.format("%.2f%%", statusData.criticalDamageRate * 100)
		self.desc_charStat_7.Text = string.format("%.2f%%", (statusData.typeDamageRate+1) * 100)
		self.desc_charStat_8.Text = string.format("%.2f%%", statusData.bossDamageRate * 100)
		
		
		if data.attackType == "physical" then
			self.char_Stat_7.TextComponent.Text = _LocalizationService:GetText("physicalDamage")
		elseif data.attackType == "magical" then
			self.char_Stat_7.TextComponent.Text = _LocalizationService:GetText("magicalDamage")
		end
	end

	@ExecSpace("Client")
	method void Equip(number equippedIndex)
		-- 캐릭터 장비 상태 업데이트
		if equippedIndex ~= self.selectedCharIndex then
			return
		end
		
		self.button_equip.Enable = false
		self.button_equipping.Enable = true
		self.equippedIcon.Enable = true
		
		
		self:RefreshMainPanel()
	end

	@ExecSpace("Client")
	method void RefreshCharInfo(number targetIndex, number level)
		-- 캐릭터 정보 및 HUD 업데이트
		
		
		
		if targetIndex == 0 then
			return
		end
		
		local player = _UserService.LocalPlayer
		local index = tostring(math.floor(targetIndex))
		
		for i = 1 , #self.parentCharSlot.Children do 
			
			local slotIndex = tonumber(string.sub(self.parentCharSlot.Children[i].Name, -6, -1))
			
			if slotIndex == player.PlayerCharacterData.charIndex then
				self.parentCharSlot.Children[i]:GetChildByName("Equipped").Enable = true
			else
				self.parentCharSlot.Children[i]:GetChildByName("Equipped").Enable = false
			end 
			
			if slotIndex == targetIndex then
				self.parentCharSlot.Children[i]:GetChildByName("button",true).PlayerCharacterSlotButton:Init(tostring(math.floor(targetIndex)))
			end
		end
		
		local charIndex = math.floor(player.PlayerCharacterData.charIndex)
		
		
		local exWeaponId = _CharacterLogic.characterTable[tostring(charIndex)].exWeaponId[1]
		
		self.HUD_CharIcon.ImageRUID = _CharacterLogic.characterTable[tostring(charIndex)].thumbnailRUID
		self.HUD_CharLevel.Text = tostring(math.floor(player.PlayerCharacterData.charLevel))
		if _MySpecLogic.mySpec.battlePower ~= nil then
			self.HUD_CharBattleStatus.Text = string.format("%s", _NumberSeparator:ConvertToMetricPrefixString(_MySpecLogic.mySpec.battlePower, "ko")) 
		end
		self.HUD_ExWeaponIcon.SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[exWeaponId].type)
	end

	@ExecSpace("Client")
	method void RefreshCharacterSlot(string charIndex)
		-- 특정 캐릭터 슬롯 새로고침
		if isvalid(self.parentCharSlot:GetChildByName("CharSlot_"..charIndex)) then
			self.parentCharSlot:GetChildByName("CharSlot_"..charIndex):GetChildByName("button", true).PlayerCharacterSlotButton:Init(charIndex)
		end
	end

	@ExecSpace("Client")
	method void InitCharList(boolean switch)
		-- 캐릭터 목록과 관계 목록 간 탭 전환
		if switch then 
			self.panel_charList:SetEnable(true)
			self.panel_relationList:SetEnable(false)
			self.tab_Panel:GetChildByName("Button_CharRelation", true).SpriteGUIRendererComponent.ImageRUID = "75ff2132ace346358699f21009389b99"
			self.tab_Panel:GetChildByName("Button_CharRelation", true).SpriteGUIRendererComponent.Color = Color.FromHexCode("#A0ACCA")
			self.tab_Panel:GetChildByName("Button_CharRelation", true):GetChildByName("Text").TextComponent.FontColor = Color.FromHexCode("#A0ACCA")
		
			self.tab_Panel:GetChildByName("Button_CharList").SpriteGUIRendererComponent.ImageRUID = "a98b037c6b0f45288ce63cb8414b83b5"
			self.tab_Panel:GetChildByName("Button_CharList", true).SpriteGUIRendererComponent.Color = Color.FromHexCode("#ffffff")
			self.tab_Panel:GetChildByName("Button_CharList", true):GetChildByName("Text").TextComponent.FontColor = Color.FromHexCode("#ffffff")
		else 
			self.panel_charList:SetEnable(false)	
			self.panel_relationList:SetEnable(true)
			self.tab_Panel:GetChildByName("Button_CharRelation").SpriteGUIRendererComponent.ImageRUID = "a98b037c6b0f45288ce63cb8414b83b5"
			self.tab_Panel:GetChildByName("Button_CharRelation", true).SpriteGUIRendererComponent.Color = Color.FromHexCode("#ffffff")
			self.tab_Panel:GetChildByName("Button_CharRelation", true):GetChildByName("Text").TextComponent.FontColor = Color.FromHexCode("#ffffff")
		
			self.tab_Panel:GetChildByName("Button_CharList").SpriteGUIRendererComponent.ImageRUID = "75ff2132ace346358699f21009389b99"
			self.tab_Panel:GetChildByName("Button_CharList", true).SpriteGUIRendererComponent.Color = Color.FromHexCode("#A0ACCA")
			self.tab_Panel:GetChildByName("Button_CharList", true):GetChildByName("Text").TextComponent.FontColor = Color.FromHexCode("#A0ACCA")
		end
	end

	@ExecSpace("Client")
	method void CloneRelationSlot(table relationTable)
		-- 캐릭터 관계 슬롯 복제 생성 및 초기 설정
		if _UtilLogic:IsNilorEmptyString(self.grayMaterialId) then
			self.grayMaterialId =""
		end
		
		local clone = self.originRelationSlot:Clone("slot_"..relationTable.id)
		
		self.relationSlotTable[relationTable.id] = clone.Id
		
		local effectPanel = clone:GetChildByName("Panel_RelationEffect", true)
		local charSlot_1 = clone:GetChildByName("CharSlot_1", true)
		local charSlot_2 = clone:GetChildByName("CharSlot_2", true)
		local charSlot_3 = clone:GetChildByName("CharSlot_3", true)
		local mainStars = clone:GetChildByName("relationMainStars", true)
		
		charSlot_1.CharacterRelationMemberSlotButton.index =  _CharacterLogic.characterTable[relationTable.member_1].id
		charSlot_2.CharacterRelationMemberSlotButton.index =  _CharacterLogic.characterTable[relationTable.member_2].id
		charSlot_3.CharacterRelationMemberSlotButton.index =  _CharacterLogic.characterTable[relationTable.member_3].id
		
		local refreshStar = function(slot)
			local stars = slot:GetChildByName("stars", true)
			slot.SpriteGUIRendererComponent:ChangeMaterial(self.grayMaterialId) 
			for i = 1 , 5 do
				stars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "cdb4f75585614caa9647d7eb04545dfe"
				stars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent:ChangeMaterial(self.grayMaterialId)
				
				mainStars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "6d92d9b508454f8f8aa1b57cb37299b0" 
				
				local target = effectPanel:GetChildByName("Lv"..math.floor(i))
				for j = 1 , 5 do
					target:GetChildByName("stars").Children[j].SpriteGUIRendererComponent:ChangeMaterial(self.grayMaterialId)
				end
				target:GetChildByName("Status_Value").TextComponent.FontColor = Color.gray
			end
		end
		
		charSlot_1.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[relationTable.member_1].thumbnailRUID 
		charSlot_2.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[relationTable.member_2].thumbnailRUID 
		charSlot_3.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[relationTable.member_3].thumbnailRUID 
		
		if isvalid(_WeaponSpecLogic.weaponData[_CharacterLogic.characterTable[relationTable.member_1].exWeaponId[1]].type) then
			charSlot_1:GetChildByName("icon_weapon", true).SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[_CharacterLogic.characterTable[relationTable.member_1].exWeaponId[1]].type)	
		end
		
		if isvalid(_WeaponSpecLogic.weaponData[_CharacterLogic.characterTable[relationTable.member_2].exWeaponId[1]].type) then
			charSlot_2:GetChildByName("icon_weapon", true).SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[_CharacterLogic.characterTable[relationTable.member_2].exWeaponId[1]].type)
		end
		
		if isvalid(_WeaponSpecLogic.weaponData[_CharacterLogic.characterTable[relationTable.member_3].exWeaponId[1]].type) then
			charSlot_3:GetChildByName("icon_weapon", true).SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[_CharacterLogic.characterTable[relationTable.member_3].exWeaponId[1]].type)	
		end
		
		
		refreshStar(charSlot_1)
		refreshStar(charSlot_2)
		refreshStar(charSlot_3)
		
		local effectTable = {relationTable.effect_1, relationTable.effect_2, relationTable.effect_3, relationTable.effect_4, relationTable.effect_5}
		local valueTable = {relationTable.value_1, relationTable.value_2, relationTable.value_3, relationTable.value_4, relationTable.value_5}
		
		for i = 1 , 5 do
			local nameKey = effectTable[i]
			local value = valueTable[i]
			
			if effectTable[i] == "maxHp" then
				nameKey = "maxHp"
				value = string.format("+%d", valueTable[i])
			else
				value = tostring(math.floor(valueTable[i]*100*100)/100)
			end
			 
			if effectTable[i] == "maxHp" then
				effectPanel:GetChildByName("Lv"..math.floor(i)):GetChildByName("Status_Value").TextComponent.Text =  _LocalizeLogic:GetText(nameKey).." +"..tostring(value)
			else
				effectPanel:GetChildByName("Lv"..math.floor(i)):GetChildByName("Status_Value").TextComponent.Text = _LocalizeLogic:GetText(nameKey).." +"..tostring(value).."%"
			end
		end
		
		clone:GetChildByName("relationName", true).TextComponent.Text = _LocalizeLogic:GetText("dataSet_characterRelation_"..tostring(math.floor(relationTable.id)))
	end

	@ExecSpace("Client")
	method void RefreshRelationSlot(string relationId, table relationTable)
		-- 캐릭터 관계 슬롯 상태 업데이트 및 별 표시
		if _UtilLogic:IsNilorEmptyString(self.grayMaterialId) then
			self.grayMaterialId =""
		end
		
		local charData = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage
		local targetSlot = _EntityService:GetEntity(self.relationSlotTable[relationId])
		
		local charSlot_1 = targetSlot:GetChildByName("CharSlot_1")
		local charSlot_2 = targetSlot:GetChildByName("CharSlot_2")
		local charSlot_3 = targetSlot:GetChildByName("CharSlot_3")
		
		local effectPanel = targetSlot:GetChildByName("Panel_RelationEffect")
		
		local refreshStar = function(slot, tier)
			local stars = slot:GetChildByName("stars") 
			if not isvalid(tier) then
				slot.SpriteGUIRendererComponent:ChangeMaterial(self.grayMaterialId) 
				for i = 1 , #stars.Chidren do
					stars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent:ChangeMaterial(self.grayMaterialId) 
				end
			else
				slot.SpriteGUIRendererComponent:ChangeMaterial("")
				for i = 1 , #stars.Children do
					stars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent:ChangeMaterial("")
					if tier >= i then
						stars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "877d010d8bfe46bc881f26f1c7adc3ba" 
					else
						stars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "cdb4f75585614caa9647d7eb04545dfe" 
					end
				end
			end
		end
		
		
		charSlot_1.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[relationTable.member_1].thumbnailRUID 
		charSlot_2.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[relationTable.member_2].thumbnailRUID 
		charSlot_3.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[relationTable.member_3].thumbnailRUID 
		
		refreshStar(charSlot_1, charData[tonumber(relationTable.member_1)].tier)
		refreshStar(charSlot_2, charData[tonumber(relationTable.member_2)].tier)
		refreshStar(charSlot_3, charData[tonumber(relationTable.member_3)].tier)
		
		targetSlot:GetChildByName("relationName", true).TextComponent.Text = _LocalizeLogic:GetText("dataSet_characterRelation_"..tostring(math.floor(relationTable.id))) 
		
		local mainStars = targetSlot:GetChildByName("relationMainStars", true)
		
		for i = 1 , #effectPanel.Children do
			
		
			local target = effectPanel:GetChildByName("Lv"..math.floor(i))
			
			if relationTable.level >= i then
				mainStars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "52f7bc6b8fb044eda7b876604730124d"
				for j = 1 , 5 do
					target:GetChildByName("stars").Children[j].SpriteGUIRendererComponent:ChangeMaterial("")
				end
				target:GetChildByName("Status_Value").TextComponent.FontColor = Color.white
			else
				mainStars:GetChildByName("Star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "6d92d9b508454f8f8aa1b57cb37299b0"
				for j = 1 , 5 do
					target:GetChildByName("stars").Children[j].SpriteGUIRendererComponent:ChangeMaterial(self.grayMaterialId) 
				end
				target:GetChildByName("Status_Value").TextComponent.FontColor = Color.gray
			end
		end
	end

	@ExecSpace("Client")
	method void CloseGetCharacterPopUp()
		-- 캐릭터 획득 팝업 닫기 및 선택 인덱스 초기화
		self._T.selectedIndex = ""
		_UIGroupManager.uiCharacterGroup.getCharPopup:Hide()
	end

	method void OnFinishHide()
		-- 팝업 숨김 완료 시 호출되는 콜백 함수
		
	end

	@ExecSpace("Client")
	method void RefreshCharSlotLevelOnly(string relationId, integer slotNum, integer level, boolean valid)
		-- 관계 슬롯의 특정 캐릭터 레벨만 업데이트
		local targetSlot = _EntityService:GetEntity(self.relationSlotTable[relationId])
		
		if not isvalid(targetSlot) then
			return
		end
		
		local charSlot = nil
		
		if slotNum == 1 then
			charSlot = targetSlot:GetChildByName("CharSlot_1")
		elseif slotNum == 2 then
			charSlot = targetSlot:GetChildByName("CharSlot_2")
		elseif  slotNum == 3 then
			charSlot = targetSlot:GetChildByName("CharSlot_3")
		end
		
		
		if valid then
			charSlot.SpriteGUIRendererComponent:ChangeMaterial("")
			for i = 1 , 5 do
				local target = charSlot:GetChildByName("stars"):GetChildByName("Star_"..math.floor(i))
				target.SpriteGUIRendererComponent:ChangeMaterial("")
				if level >= i then
					target.SpriteGUIRendererComponent.ImageRUID = "877d010d8bfe46bc881f26f1c7adc3ba"
				else
					target.SpriteGUIRendererComponent.ImageRUID = "cdb4f75585614caa9647d7eb04545dfe"
		
				end
			end
		end
	end

	method void Show()
		-- 캐릭터 정보 팝업 표시
		 __base:Show()
	end

	method void Hide()
		-- 캐릭터 정보 팝업 숨김 및 정리
		self.char_illust.ImageRUID = ""
		__base:Hide()
		self:CloseCharacterInformationPanel()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "261c6d1f-6a29-44ed-818f-ac08106c627b")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 레벨업 버튼 클릭 시 레벨업 팝업 열기
		
		local Entity = event.Entity
		self.popup_levelUp.CharacterLevelupPopup:Init(self.selectedCharIndex, true)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "68dc8b1c-eee4-4ed5-9d9a-0981488a860b")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 캐릭터 장비 버튼 클릭 시 캐릭터 장비 및 사운드 재생
		
		local Entity = event.Entity
		_UserService.LocalPlayer.PlayerCharacterData:EquipCharacter(self.selectedCharIndex)
		_SoundService:PlaySound("e4a63892e7534618b9fb35d7e755663c", 1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "fc8a3687-2288-4f10-a9ca-8a140d0ee23a")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2510963b-3dd3-427d-9fef-9869f5c0ebe8")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 캐릭터 레벨업 버튼 클릭 시 레벨 제한 확인 후 레벨업 실행
		
		local Entity = event.Entity
		
		local myCharData = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[self.selectedCharIndex]
		
		if myCharData.level >= 50 then 
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast368"))
			return
		end
		
		_UserService.LocalPlayer.PlayerCharacterData:LevelUp(self.selectedCharIndex)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "80632161-d4d3-4ac7-986a-02f98b2fedd9")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 돌파 버튼 클릭 시 돌파 팝업 열기
		
		local Entity = event.Entity
		self.popup_breakLimit.CharacterBreakupPopup:Init(self.selectedCharIndex, true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "cf7e8b95-b511-47dc-8783-1d0b263231ee")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 돌파 실행 버튼 클릭 시 캐릭터 돌파 실행
		
		local Entity = event.Entity
