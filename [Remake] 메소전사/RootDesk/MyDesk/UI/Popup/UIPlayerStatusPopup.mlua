				local exWeaponId = _CharacterLogic.characterTable[tostring(math.floor(_UserService.LocalPlayer.PlayerCharacterData.charIndex))].exWeaponId[1]
					if string.sub(exWeaponId, 1,5) == string.sub(originalId,1,5) then
						slot.SpriteGUIRendererComponent:ChangeMaterial("material://3287b600-bc16-4239-89e5-0fce58638ac5")	
					else
						slot.SpriteGUIRendererComponent:ChangeMaterial("")
					end
				end
				slot:GetChildByName("Damage").TextComponent.Text = "DMG:"..tostring(math.floor(_CalcLogic:GetWeaponAttackDamageByKey(uniqueKey, _UserService.LocalPlayer))) 
				
				
				
				local starCount = _StatusLogic:GetGradeToStarCount(_WeaponSpecLogic.weaponData[originalId].grade)
				for i = 1, 5 do
					slot:GetChildByName("Scroll_Layout_stars"):GetChildByName("Star_"..i).Enable = true
					if i <= starCount then
						slot:GetChildByName("Scroll_Layout_stars"):GetChildByName("Star_"..i).SpriteGUIRendererComponent.ImageRUID = "216ed9c8fccd4264b88e90320b5d38d6"
					else
						slot:GetChildByName("Scroll_Layout_stars"):GetChildByName("Star_"..i).SpriteGUIRendererComponent.ImageRUID = "bad7568a8b8d465882733acf629d8776"
					end
				end
			end
		end
		
		
		for i = 1 , 6 do
			if i <= _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount then 
				local slot = self.weaponScroll:GetChildByName("WeaponSlot_"..math.floor(i))
		
				for j = 1, #equippedWeaponData do
		
					if equippedWeaponData[j].equippedSlotNum == i then 
						refreshSlot(slot, equippedWeaponData[j].uniqueKey, false)
						goto endFunc
					end
		
				end
				refreshSlot(slot, "", true) 
				
				slot.Enable = true
				::endFunc::
		
			else 
		
				self.weaponScroll:GetChildByName("WeaponSlot_"..math.floor(i)).Enable = false
			end	
		end]]--
	end

	@ExecSpace("Client")
	method void RefreshStatusPanel()
		-- 플레이어 스테이터스 패널 정보 새로고침
		if not isvalid(_MySpecLogic.mySpec) or not isvalid(_MySpecLogic.mySpec.totalDamage) then return end
		
		self.attackValue.Text = string.format("%.2f%%",(_MySpecLogic.mySpec.totalDamage+1)*100)  
		self.maxHpValue.Text = string.format("%d", _MySpecLogic.mySpec.maxHp)
		self.combatPowerValue.Text =string.format("%d", _MySpecLogic.mySpec.battlePower)
	end

	@ExecSpace("Client")
	method void OpenStatusPanel()
		-- 상태 패널을 열고 모든 하위 패널 새로고침
		self:RefreshCharacterPanel()
		self:RefreshArmorPanel()
		self:RefreshWeaponPanel()
		self:RefreshStatusPanel()
		self:RefreshAccessoryPanel()
		
		self:ChangeTab("armor")
	end

	@ExecSpace("Client")
	method void CloseStatusPanel()
		-- 상태 패널을 닫기
		self:Hide()
		
		
	end

	method void OpenCharacterList()
		-- 캐릭터 목록 팝업을 열기
		_UIGroupManager.uiCharacterInfoPopup:InitCharList(true)
		self.CharacterGroupUI:Show()
	end

	@ExecSpace("Client")
	method void RefreshCharacterExpGauge()
		-- 캐릭터 경험치 게이지 새로고침
		local expData = _DataService:GetTable("CharacterExpData")
		local charData = _UserService.LocalPlayer.PlayerCharacterData
		
		self.characterExpGauge.SpriteGUIRendererComponent.FillAmount = 
		charData.charDeckStorage[charData.charIndex].exp.."/"..
		expData:GetCell(charData.charDeckStorage[charData.charIndex].tier, tostring(math.floor(charData.charIndex)))
		
		self.characterExpText.TextComponent.Text = 
		charData.charDeckStorage[charData.charIndex].exp.."/"..
		expData:GetCell(charData.charDeckStorage[charData.charIndex].tier, tostring(math.floor(charData.charIndex)))
	end

	@ExecSpace("Client")
	method void RefreshStatPanel()
		-- 스테이터스 패널 새로고침
		local textEntities = self.statLayout.Children
		
		self.statPreviousButton.Enable = true
		self.statNextButton.Enable = true
		
		for _, entity in pairs(textEntities) do
			entity.Enable = true
		end
		
		
		self:RefreshStatusPanel()
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 방어구 인벤토리 UI 설정
		__base:OnBeginPlay()
		self.lastPage = 4
		
		local target = _EntityService:GetEntityByPath("/ui/InventoryGroup/Background/Popup/Inventory/Armor_Scroll_Layout")
		target:AddComponent("ArmorInventoryUI")
		self.armorInventory = target.ArmorInventoryUI
	end

	@ExecSpace("Client")
	method void RefreshEquipmentList()
		-- 장비 목록 새로고침 (현재 비어있음)
	end

	method void Show()
		-- 플레이어 상태창을 표시하고 데이터 새로고침
		_UserService.LocalPlayer.PlayerStorageComponent:CheckExpiredItems()
		_PetUILogic.petInformationUI:Refresh()
		
		self:OpenStatusPanel()
		
		__base:Show()
		
		_UIOpenQuestLogic:CheckQuestInProgress("myInfo",self.Entity)
		
	end

	method void Hide()
		-- 플레이어 상태창을 숨기고 하위 UI 정리
		self.petList.UIPetPopup:Hide()
		__base:Hide()
		if self.armorInventory.sortingMenu.Enable then
			self.armorInventory.sortingMenu:SetEnable(false)
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshDecorationPanel()
		-- 장식 아이템 패널 새로고침 (네임태그, 채팅벌룬, 데미지스킨)
		local nameTag = self.characterInfoPanel:GetChildByName("DecoSlot_NameTag"):GetChildByName("DecoSlot_NameTag")
		local chatBalloon = self.characterInfoPanel:GetChildByName("DecoSlot_ChatBalloon"):GetChildByName("DecoSlot_ChatBalloon")
		local damageSkin = self.characterInfoPanel:GetChildByName("DecoSlot_DamageSkin"):GetChildByName("DecoSlot_DamageSkin")
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		
		local damageSkinId = playerInfo.playerInfo.damageSkin
		local nameTagId = playerInfo.playerInfo.nameTag
		local chatBalloonId = playerInfo.playerInfo.chatBalloon
		
		local refreshFunction = function(entity, id, key)
			local data = _ItemDataLogic.itemData[id]
			---@type Entity
			local sprite = entity:GetChildByName("Sprite")
			---@type DecorationButtonComponent
			local decoSlot = entity.DecorationButtonComponent
			
			if isvalid(data) then
				sprite.SpriteGUIRendererComponent.ImageRUID = data.ruid
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(data.offsetX, data.offsetY)
				
				if id == "5_000001" or id == "5_000002" or id == "5_000003" then
					entity.Enable = false
					entity.Parent:GetChildByName("Empty").Enable = true
					decoSlot.uniqueKey = ""
				else
					entity.Enable = true
					entity.Parent:GetChildByName("Empty").Enable = false
					entity.SpriteGUIRendererComponent.ImageRUID = _GameUtil:GetBackgroundRUIDByItemGrade(data.grade)
					decoSlot.uniqueKey = key
				end
		
				local categoryBg = entity:GetChildByName("Category").SpriteGUIRendererComponent
				categoryBg.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(data.grade)
			else
				sprite.SpriteGUIRendererComponent.ImageRUID = ""
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2.zero
				
				entity.Enable = false
				entity.Parent:GetChildByName("Empty").Enable = true
				
				decoSlot.uniqueKey = ""
			end
		end
		
		refreshFunction(nameTag, nameTagId, _UserService.LocalPlayer.PlayerStorageComponent:GetEquippedKey(_GameEnum.EQUIPNUM_NAMETAG))
		refreshFunction(damageSkin, damageSkinId, _UserService.LocalPlayer.PlayerStorageComponent:GetEquippedKey(_GameEnum.EQUIPNUM_DAMAGESKIN))
		refreshFunction(chatBalloon, chatBalloonId, _UserService.LocalPlayer.PlayerStorageComponent:GetEquippedKey(_GameEnum.EQUIPNUM_CHATBALLOON))
	end

	@ExecSpace("ClientOnly")
	method void RefreshAccessoryPanel()
		-- 액세서리 패널 새로고침 (반지, 귀걸이, 목걸이)
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		
		local accPanel = self.characterInfoPanel:GetChildByName("AccPanel")
		local ringSlot = accPanel:GetChildByName("AccSlot_Ring")
		local earringSlot = accPanel:GetChildByName("AccSlot_Earring")
		local necklaceSlot = accPanel:GetChildByName("AccSlot_Necklace")
		
		ringSlot.AccessorySlotComponent:Init()
		earringSlot.AccessorySlotComponent:Init()
		necklaceSlot.AccessorySlotComponent:Init()
		
		for key, value in pairs(storage.storage) do
			if value.equippedSlotNum == 51 then
				ringSlot.AccessorySlotComponent:SetSlot(key, value.originalId)
			elseif value.equippedSlotNum == 52 then
				earringSlot.AccessorySlotComponent:SetSlot(key, value.originalId)
			elseif value.equippedSlotNum == 53 then
				necklaceSlot.AccessorySlotComponent:SetSlot(key, value.originalId)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "cd248f9d-f38a-4c1f-b661-edeb0f4dd606")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 상태창 열기 버튼 클릭 이벤트
		
		local Entity = event.Entity
		self:ShowByButtonClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "3681e7d3-7526-4ec6-b216-a65bf22137df")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트
		
		local Entity = event.Entity
		self:CloseStatusPanel()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2ad9ce27-de34-4018-9ce5-6efb3c05297e")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 캐릭터 목록 열기 버튼 클릭 이벤트
		
		local Entity = event.Entity
		self:OpenCharacterList()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2438174c-362f-466c-956d-fb8517cff108")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 스테이터스 이전 페이지 버튼 클릭 이벤트
		
		local Entity = event.Entity
		if self.currentPage > 1 then
			self.currentPage = self.currentPage - 1
			self:RefreshStatPanel()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "63ae31ac-9991-4773-b647-097b01e505ce")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 스테이터스 다음 페이지 버튼 클릭 이벤트
		
		local Entity = event.Entity
		if self.currentPage < self.lastPage then
			self.currentPage = self.currentPage + 1
			self:RefreshStatPanel()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "49c56d66-3262-4451-b08a-a4067f33db23")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 캐릭터 정보 팝업 열기 버튼 클릭 이벤트
		
		local Entity = event.Entity
		_UIGroupManager.uiCharacterInfoPopup:OpenCharacterInformationPanel(tostring(math.floor(_UserService.LocalPlayer.PlayerCharacterData.charIndex)))
	end

