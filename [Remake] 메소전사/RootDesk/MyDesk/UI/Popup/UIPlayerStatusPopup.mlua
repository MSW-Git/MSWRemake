	@ExecSpace("Client")
	method void ChangeTab(string category)
		-- 플레이어 상태창에서 카테고리 탭 변경 처리
		local selectedId = "994e2ad676fe4b4c9782186b06f02a4a"
		local unSelectedId = "6cb1470eea884424886399b0fc9f3c95"
		local tabTable = {self.CategoryBtn_Armor, self.CategoryBtn_Accessory, self.CategoryBtn_Pet, self.CategoryBtn_Deco, self.CategoryBtn_Usable, self.CategoryBtn_Etc}
		
		self.armorInventory.sortingMenu.Enable = false
		
		local changeTabRUID = function(num)
			for i = 1 , #tabTable do
				if i == num then
					tabTable[i].SpriteGUIRendererComponent.ImageRUID = selectedId
				else
					tabTable[i].SpriteGUIRendererComponent.ImageRUID = unSelectedId
				end
			end
		end
		
		self.armorInventory.sortingOptionButton:SetEnable(true)
		self.currentCategory = category
		
		if category == "armor" then 
			self.armorList:SetEnable(true)
			self.petList.UIPetPopup:TurnOff() 
			self.inventoryList:SetEnable(false)
			local uniqueKeyList = _ItemDataLogic:GetUniqueKeyListByCategory(category, _UserService.LocalPlayer.PlayerComponent.UserId)
			self:RefreshInventoryList(uniqueKeyList, category) 
		
			changeTabRUID(1)
		elseif category == "accessory" then 
			self.armorList:SetEnable(false)
			self.petList.UIPetPopup:TurnOff() 
			self.inventoryList:ChangeTab("accessory")
			self.inventoryList:SetEnable(true)
			
			changeTabRUID(2)
		elseif category == "pet" then 
			self.armorList:SetEnable(false)
			self.inventoryList:SetEnable(false)
			self.petList.UIPetPopup:TurnOn() 
			
		
			changeTabRUID(3)
		elseif category == "decoration" then 
			self.armorList:SetEnable(false)
			self.petList.UIPetPopup:TurnOff() 
			self.inventoryList:ChangeTab("decoration")
			self.inventoryList:SetEnable(true)
			
			changeTabRUID(4)
		elseif category == "usable" then 
			self.armorList:SetEnable(false)
			self.petList.UIPetPopup:TurnOff() 
			self.inventoryList:ChangeTab("consume")
			self.inventoryList:SetEnable(true)
			
			changeTabRUID(5)
		elseif category == "etc" then 
			self.armorList:SetEnable(false)
			self.petList.UIPetPopup:TurnOff() 
			self.inventoryList:ChangeTab("etc")
			self.inventoryList:SetEnable(true)
			changeTabRUID(6)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshInventoryList(table uniqueKeyList, string category)
		-- 인벤토리 목록을 새로고침하고 저장공간 상태 표시
		
		self.armorInventory:Refresh()
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent.playerInfo
		
		if #uniqueKeyList >= _GameConfig:GetConfig().LIMIT_ARMORSLOT + playerInfo.armorStorageSlot then 
			self.storageCount.FontColor = Color.FromHexCode("#FF6868")
		else
			self.storageCount.FontColor = Color.white
		end
		
		self.storageCount.Text = math.floor(#uniqueKeyList).."/"..math.floor(_GameConfig:GetConfig().LIMIT_ARMORSLOT + playerInfo.armorStorageSlot)
		
		if true then
			return
		end
		--[[
		local findNewItem = {}
		
		local findDeletedItem = {}
		
		
		local itemList = self.armorSlotList 
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		
		for i = 1, #itemList do
			for j =1 , #uniqueKeyList do
				if itemList[i].InventoryItemSlot.uniqueKey  == uniqueKeyList[j] then
					break
				end
				if j == #uniqueKeyList then
					table.insert(findNewItem, uniqueKeyList[j])
				end
			end
		end 
		
		for i = 1, #uniqueKeyList do
			for j =1 , #itemList do
				if uniqueKeyList[i] == itemList[j].InventoryItemSlot.uniqueKey then
					break
				end
				if j == #itemList then
					table.insert(findDeletedItem, itemList[j])
				end
			end
		end 
		
		
		for i = 1, #itemList do
			itemList[i].InventoryItemSlot:UnInit()
			for key, value in pairs(storage) do
				local itemData = _ItemDataLogic:GetItemData(value.originalId)
				if itemData ~= nil and itemData.category == "armor" then
					if value.inventoryNum == itemList[i].InventoryItemSlot.inventoryNumber then
						itemList[i].InventoryItemSlot:Init(value.uniqueKey, category)
						break
					end
				end
			end
		end
		]]--
	end

	@ExecSpace("Client")
	method void RefreshCharacterPanel()
		-- 캐릭터 패널 정보를 새로고침
		
		local player = _UserService.LocalPlayer
		
		if player.PlayerCharacterData.charIndex == 0 or player.PlayerCharacterData.charLevel == 0 then
			return
		end
		
		local charData = _CharacterLogic.characterTable[tostring(math.floor(player.PlayerCharacterData.charIndex))]
		local exWeaponId = charData.exWeaponId
		_UIGroupManager:SetCharacterSlot(self.characterCard, tostring(math.floor(player.PlayerCharacterData.charIndex)))
	end

	@ExecSpace("Client")
	method void RefreshArmorPanel()
		-- 장착된 방어구 정보를 새로고침
		local equippedArmorData = _UserService.LocalPlayer.PlayerStorageComponent.equipArmorTable
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		local uniquekeyTable = {}
		
		for key, value in pairs(storage) do
			if value.equippedSlotNum == 21 then
				uniquekeyTable["helmet"] = value.uniqueKey
			elseif value.equippedSlotNum == 22 then
				uniquekeyTable["suit"] = value.uniqueKey
			elseif value.equippedSlotNum == 23 then
				uniquekeyTable["glove"] = value.uniqueKey
			elseif value.equippedSlotNum == 24 then
				uniquekeyTable["shoes"] = value.uniqueKey
			end
		end
		
		local refreshSlot = function(slot, originalId, empty, uniqueKey)
			slot.ArmorSlotComponent:Init(originalId, empty, uniqueKey)
		end
		
		if isvalid(equippedArmorData["helmet"]) then
			refreshSlot(self.equip_helmetSlot, equippedArmorData["helmet"], false, uniquekeyTable["helmet"])
		else
			refreshSlot(self.equip_helmetSlot, "" ,true,"")
		end
			
		if isvalid(equippedArmorData["suit"]) then
			refreshSlot(self.equip_suitSlot, equippedArmorData["suit"], false, uniquekeyTable["suit"])
		else
			refreshSlot(self.equip_suitSlot, "" ,true,"")
		end
		
		if isvalid(equippedArmorData["glove"]) then
			refreshSlot(self.equip_gloveSlot, equippedArmorData["glove"], false, uniquekeyTable["glove"])
		else
			refreshSlot(self.equip_gloveSlot, "" ,true,"")
		end
		
		if isvalid(equippedArmorData["shoes"]) then
			refreshSlot(self.equip_shoesSlot, equippedArmorData["shoes"], false, uniquekeyTable["shoes"])
		else
			refreshSlot(self.equip_shoesSlot, "" ,true,"")
		end
		
		if not _UtilLogic:IsNilorEmptyString(self.ArmorInformation.ArmorInformationUI.selectedUniqueKey) then
			self.ArmorInformation.ArmorInformationUI:RefreshItemInformation(self.ArmorInformation.ArmorInformationUI.selectedUniqueKey, false)
		end
	end

	@ExecSpace("Client")
	method void RefreshWeaponPanel()
		-- 무기 패널 새로고침 (현재 비활성화)
		if true then return end
		--[[
		local equippedWeaponData = _UserService.LocalPlayer.PlayerStorageComponent:GetAllEquippedWeapon()
		
		local refreshSlot = function(slot, uniqueKey, empty)
		
			if empty then 
				slot:GetChildByName("Empty").Enable = true
				slot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = ""
				slot:GetChildByName("Damage").TextComponent.Text = ""
				for i = 1, 5 do
					slot:GetChildByName("Scroll_Layout_stars"):GetChildByName("Star_"..i).Enable = false
				end
