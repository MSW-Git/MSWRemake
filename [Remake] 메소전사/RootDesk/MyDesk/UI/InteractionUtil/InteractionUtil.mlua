@Logic
script InteractionUtil extends Logic

	property string toolTipModel = "model://13cbe063-e685-4d77-ac83-c43e9c324b1c"

	property number scaleRatio = 1

	method void ShowInteraction(Entity interactionEntity, string description, string keycode, number offset)
		-- 상호작용 툴팁을 생성하고 표시
		if isvalid(self._T.toolTip) == false then
			self._T.toolTip = _SpawnService:SpawnByModelId(self.toolTipModel,"tooltip",Vector3.zero,_UserService.LocalPlayer.CurrentMap)
		end
		
		self:SendEvent(OnEnableInteraction(true))
		self._T.toolTip:AttachTo(interactionEntity)
		self._T.toolTip.TransformComponent.Position = Vector3(0,offset,0)
		self._T.toolTip.Enable = true
		self._T.toolTip.InteractionToolTip:SetTooltip(interactionEntity,description,keycode)
		
		if  interactionEntity.InteractionComponent ~= nil then
			self._T.toolTip.ButtonComponent.KeyCode = interactionEntity.InteractionComponent.ActionKey
		else
			self._T.toolTip.ButtonComponent.KeyCode = KeyboardKey.None
		end
	end

	method void HideInteraction(Entity interactionEntity)
		-- 상호작용 툴팁을 숨김
		if isvalid(self._T.toolTip) == false then
			return
		end
		
		
		self:SendEvent(OnEnableInteraction(false))
		if self._T.toolTip.Parent == interactionEntity then
			self._T.toolTip.Enable = false
		end
	end

	method void OnInteraction(Entity interactionEntity)
		-- 상호작용 실행 시 툴팁 스케일 애니메이션
		if isvalid(self._T.toolTip) == false then
			return
		end
		
		if self._T.toolTip.Parent == interactionEntity then
			self._T.toolTip.InteractionToolTip:SetTweenScale()
		end
	end

end