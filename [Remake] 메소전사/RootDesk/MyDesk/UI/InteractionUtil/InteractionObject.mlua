@Component
script InteractionObject extends Component

	property string keycode = "W"

	property string mobileKeycode = "cc55ed79f099cc94fae152e754984ddd"

	property string description = "포탈타기"

	property number offset = 1

	property string localizationKey = "etcStr203"

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 상호작용 영역에 진입 시 상호작용 UI 표시
		local InteractionEntity = event.InteractionEntity
		if not self.Enable then return end
		
		local keycode = self.keycode
		if Environment:IsMobilePlatform() then
			keycode = self.mobileKeycode
		end
		
		if not _UtilLogic:IsNilorEmptyString(self.localizationKey) then
			self.description = _LocalizeLogic:GetText(self.localizationKey)
			_InteractionUtil:ShowInteraction(self.Entity, _LocalizeLogic:GetText("etcStr203"),keycode,self.offset)
		else
			_InteractionUtil:ShowInteraction(self.Entity, self.description,keycode,self.offset)
		end
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-- 상호작용 영역에서 나갈 시 상호작용 UI 숨김
		local InteractionEntity = event.InteractionEntity
		_InteractionUtil:HideInteraction(self.Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 상호작용 키 입력 시 상호작용 실행
		local InteractionEntity = event.InteractionEntity
		_InteractionUtil:OnInteraction(self.Entity)
	end

end