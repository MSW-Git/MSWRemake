@Logic
script RecommendPopUpLogic extends Logic

	property RecommendPopup recommendPopUp = "188b5b65-cc75-499a-8ded-497274a9a676"

	@ExecSpace("Server")
	method void RequestShow(string popUpId)
		-- 추천 팝업 표시 요청을 처리하고 기간을 확인하여 클라이언트에 전송
		local data = _DataService:GetTable("RecommendPopUpData")
		local row = data:FindRow("id", popUpId)
		
		if isvalid(row) then
			local currentDate = _LocalTimeLogic:GetKST()
			local startPeriod = _UtilLogic:Split(row:GetItem("startPeriod"), "/")
			local endPeriod = _UtilLogic:Split(row:GetItem("endPeriod"), "/")
		
			local year = tonumber(startPeriod[1])
			local month = tonumber(startPeriod[2])
			local day = tonumber(startPeriod[3])
			local hour = tonumber(startPeriod[4])
			local minute = tonumber(startPeriod[5])
			
			local startPeriodDate = DateTime(year, month, day, hour, minute, 0)
		
			year = tonumber(endPeriod[1])
			month = tonumber(endPeriod[2])
			day = tonumber(endPeriod[3])
			hour = tonumber(endPeriod[4])
			minute = tonumber(endPeriod[5])
			
			local endPeriodDate = DateTime(year, month, day, hour, minute, 0)
			
			if currentDate >= startPeriodDate and currentDate <= endPeriodDate then
				self:ShowPopUpInClient(popUpId, senderUserId)
			end
		else
		end
	end

	@ExecSpace("Client")
	method void ShowPopUpInClient(string popUpId)
		-- 클라이언트에서 추천 팝업을 실제로 표시
		self.recommendPopUp:ShowPopUpInClient(popUpId)
	end

end