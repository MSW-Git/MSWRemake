@Component
script OutGameBuffUIComponent extends Component

	@HideFromInspector
	property GridViewComponent girdView = nil

	property Entity originalSlot = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 그리드뷰 설정
		self.girdView = self.Entity.GridViewComponent
		self.originalSlot = self.Entity:GetChildByName("BuffSlot")
		self.girdView.ItemEntity = self.originalSlot
		
		self:Init()
	end

	@ExecSpace("ClientOnly")
	method void InitGridView()
		-- 플레이어 버프 정보를 기반으로 그리드뷰 초기화
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent.playerInfo
		
		if not isvalid(playerInfo) or not isvalid(playerInfo.appliedBuff) or playerInfo.appliedBuff == "" then 
			self.girdView.OnRefresh = nil
			self.girdView.TotalCount = 0
			return
		end
		
		self.girdView.OnRefresh = function(index, entity)
			entity.OutGameBuffSlotComponent:SetSlot(index + 1)
		end
		
		self.girdView.TotalCount = #_UtilLogic:Split(playerInfo.appliedBuff, "/")
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 버프 UI 초기화
		self:InitGridView()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 버프 UI 새로고침
		self:InitGridView()
		self.girdView:Refresh(false, true)
	end

end