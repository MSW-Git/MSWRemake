@Component
script LoadingPopup extends Component

	property SpriteGUIRendererComponent loadingBar = "a897da1a-62cb-4fed-aed0-825faf66b1d9"

	property table tips = {}

	property Entity tipText = "fe8e064f-a6f9-4c39-834b-2ac38c013291"

	property boolean isHideTween = false

	property Entity illust = "59527c37-a855-4c92-9c89-96006c0d6ff4"

	method void Show()
		-- 로딩 팝업을 화면에 표시하고 플레이어 이동을 제한
		if self.isHideTween then
			return
		end
		self:RefreshTip()
		
		_UserService.LocalPlayer.ExtendKinematicbodyComponent.movement.InputSpeed = 0
		_UserService.LocalPlayer.ExtendKinematicbodyComponent.enableMoving = false
		
		self.Entity.Enable = true
		self.loadingBar.FillAmount = 0.1
	end

	method void Hide(number duration, any callback)
		-- 로딩바 애니메이션과 함께 팝업을 숨기고 플레이어 이동을 복원
		self:RefreshTip()
		self.isHideTween = true
		_TimerService:SetTimerOnce(function() 
			local tween = _TweenLogic:MakeTween(0.1,1,duration,EaseType.Linear,function(value) 
					self.loadingBar.FillAmount = value
					end)
			
			tween:Play()
			
			tween:SetOnEndCallback(function() 
					self.isHideTween = false
					_UserService.LocalPlayer.ExtendKinematicbodyComponent.enableMoving = true
					self.Entity.Enable = false
					if callback~=nil then
						callback()
					end
				
			end)
		
		end,0.1)
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 로딩 팁 데이터를 초기화하고 지역에 따른 일러스트 설정
		local data = _DataService:GetTable("LoadingTip")
		
		for i = 1, data:GetRowCount() do
			local tipTable = {}
			
			tipTable.tip = data:GetCell(i,"tip")
			tipTable.mode = tonumber(data:GetCell(i,"mode")) 
			
			self.tips[i] = tipTable
		end
		
		if _LocalizationService.CurrentLocaleId ~= "ko" then
			self.illust.SpriteGUIRendererComponent.ImageRUID = "596622086af04b91a699c8693192b601"
		end
		
		self:RefreshTip()
	end

	method void RefreshTip()
		-- 랜덤한 로딩 팁을 선택하여 화면에 표시
		local head = ""
		local randomInt = _UtilLogic:RandomIntegerRange(1,#self.tips) 
		local tipData = self.tips[randomInt]
		
		if not isvalid(tipData) then 
			self.tipText.TextComponent.Text = ""
			
			return 
		end
		
		if tipData.mode == 1 then
			head = "[".._LocalizationService:GetText("stage").."] "
		elseif tipData.mode == 2 then
			head = "[".._LocalizationService:GetText("field").."] "
		end
		self.tipText.TextComponent.Text = head.._LocalizationService:GetText("tip"..randomInt)
	end

end