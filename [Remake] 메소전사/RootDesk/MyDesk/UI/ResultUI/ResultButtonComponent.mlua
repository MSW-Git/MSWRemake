@Component
script ResultButtonComponent extends ButtonComponent

	property string itemId = ""

	@ExecSpace("ClientOnly")
	method void SetText(integer count)
		-- 결과 UI에서 아이템 개수 텍스트 설정
		self.Entity.Parent:GetChildByName("UIText").TextComponent.Text = string.format("%d", count)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 상태 변경 시 아이템 설명 표시
		
		local state = event.state
		if state == ButtonState.Hover or state == ButtonState.Pressed then
			_ResultUILogic:ShowDescription(self.itemId, self.Entity)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageEndEvent(StageEndEvent event)
		-- 스테이지 종료 시 결과 UI 닫기
		_ResultUILogic.resultUI:Close()
	end

end