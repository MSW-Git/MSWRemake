@Logic
script ResultUILogic extends Logic

	property ResultUIComponent resultUI = "d8f572e8-63ef-4404-9159-b8139e2108e2"

	property Entity resultItemDescription = "3ebf0527-c767-4b73-9f06-cb40732ada8e"

	@ExecSpace("ClientOnly")
	method void ShowDescription(string itemId, Entity entity)
		-- 결과 UI에서 아이템 설명 팝업 표시
		local data = _ItemDataLogic.equipmentData[itemId]
		local name = ""
		local str = ""
		
		if not isvalid(data) then
			data = _ItemDataLogic.itemData[itemId]
			name = _LocalizeLogic:GetItemName(itemId)
		else
			name = _LocalizeLogic:GetText(data.name)
			for i = 1, tonumber(data.star) do
				str = str .. "★"
			end
		end
		
		
		self.resultItemDescription.TextComponent.Text = string.format("%s %s", str, name)
		local clone = entity:Clone("clone")
		clone:AttachTo(self.resultUI.Entity)
		clone.Enable = false
		self.resultItemDescription.UITransformComponent.anchoredPosition = clone.UITransformComponent.anchoredPosition:Clone() + Vector2(50, -50)
		clone:Destroy()
		
		self.resultItemDescription.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void CloseDescription()
		-- 아이템 설명 팝업 닫기
		self.resultItemDescription.Enable = false
	end

end