@Component
script EquipmentListManager extends Component

	property EntityRef originSlot = "8df8aeb6-2a07-490e-90b9-8e5d32872891"

	property EntityRef slotParent = "36613b6d-8c70-4658-871b-0686c34ac4cf"

	property string selectedUniqueId = ""

	property number selectedSlotNum = 0

	property table slotIdTable = {}

	@ExecSpace("Client")
	method void SetList(string selectedCategory, number slotNum)
		-- 선택된 카테고리의 장비 리스트를 생성하여 표시
		
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		self.selectedSlotNum = slotNum
		
		for key, value in pairs(storage) do
			local originalId = value.originalId
			if string.sub(originalId,1,1) == "1" or string.sub(originalId,1,1) == "2" then 
				local category = _ItemDataLogic.equipmentData[originalId].category
				if category == selectedCategory then
					local newSlot = self.originSlot:Clone("slot")
					table.insert(self.slotIdTable, newSlot.Id)
					newSlot:GetChildByName("Level").TextComponent.Text = value.level
					newSlot:GetChildByName("Selected").Enable = false
		
					if string.sub(_CharacterLogic.characterTable[tostring(math.floor(_UserService.LocalPlayer.PlayerCharacterData.charIndex))].exWeaponId[1], 1,5) == string.sub(originalId,1,5) then
						newSlot.SpriteGUIRendererComponent:ChangeMaterial("material://3287b600-bc16-4239-89e5-0fce58638ac5")	
					else
						newSlot.SpriteGUIRendererComponent:ChangeMaterial("")
					end
					if value.equippedSlotNum > 0 then
						newSlot:GetChildByName("Equipped").Enable = true
					else
						newSlot:GetChildByName("Equipped").Enable = false
					end
					newSlot.EquipmentListSlotButton.uniqueKey = value.uniqueKey
				end
			end
		end
		
		self.Entity.Enable = true
	end

	@ExecSpace("Client")
	method void ResetList()
		-- 장비 리스트 초기화 및 생성된 슬롯들 제거
		self.Entity.Enable = false
		self.selectedUniqueId = nil
		self.selectedSlotNum = nil
		
		for i = 1 , #self.slotIdTable do
			if isvalid(self.slotIdTable[i]) then
				_EntityService:GetEntity(self.slotIdTable[i]):Destroy()
				if i == #self.slotIdTable then
					table.clear(self.slotIdTable)
				end
			end
		end
	end

	method void SelectedButton(string uniqueKey, EntityRef selectedButton)
		-- 선택된 장비 버튼 상태 업데이트
		
		for i = 1 , #self.slotIdTable do
			if self.slotIdTable[i] == selectedButton.Id then
				_EntityService:GetEntity(self.slotIdTable[i]):GetChildByName("Selected").Enable = true
				self.selectedUniqueId = uniqueKey
			else
				_EntityService:GetEntity(self.slotIdTable[i]):GetChildByName("Selected").Enable = false
			end
		end
	end

	@ExecSpace("Client")
	method void ExchangeWeapon()
		-- 선택된 무기를 장착 슬롯에 교체
		if self.selectedUniqueId == nil or self.selectedUniqueId == "" then return end
		local storageCompo = _UserService.LocalPlayer.PlayerStorageComponent
		
		storageCompo:Equip(self.selectedUniqueId, self.selectedSlotNum)
		
	end

	@ExecSpace("Client")
	method void Refresh()
		-- 장비 리스트의 선택 상태 및 장착 상태 새로고침
		for i = 1 , #self.slotIdTable do
			local button = _EntityService:GetEntity(self.slotIdTable[i])
			local uniqueKey = button.EquipmentListSlotButton.uniqueKey
			if uniqueKey == self.selectedUniqueId then
				_EntityService:GetEntity(self.slotIdTable[i]):GetChildByName("Selected").Enable = true
			else
				_EntityService:GetEntity(self.slotIdTable[i]):GetChildByName("Selected").Enable = false
			end
		
			if _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].equippedSlotNum > 0 then
				button:GetChildByName("Equipped").Enable = true
			else
				button:GetChildByName("Equipped").Enable = false
			end
				
			button:GetChildByName("Level").TextComponent.Text = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].level
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "0bb18aaf-5460-48ef-bf3a-d3f96cb618d8")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 리스트 초기화
		
		local Entity = event.Entity
		self:ResetList()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a60d30c7-602a-4f59-8eaa-b0c2bef95342")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 교체 버튼 클릭 시 무기 교체 실행
		
		local Entity = event.Entity
		self:ExchangeWeapon()
	end

end