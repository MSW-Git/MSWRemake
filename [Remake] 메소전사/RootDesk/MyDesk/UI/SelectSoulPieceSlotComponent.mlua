@Component
script SelectSoulPieceSlotComponent extends Component

	property integer index = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 영혼 조각 슬롯의 증감 버튼 이벤트를 초기화
		local countText = self.Entity:GetChildByName("Count")
		---@type Entity
		local downButton = countText:GetChildByName("CountDown")
		---@type Entity
		local upButton = countText:GetChildByName("CountUp")
		
		downButton:ConnectEvent(ButtonClickEvent, self.DecreaseCount)
		upButton:ConnectEvent(ButtonClickEvent, self.IncreaseCount)
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(integer index)
		-- 슬롯 인덱스를 설정하고 UI를 갱신
		self.index = index
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 캐릭터 정보와 선택된 수량에 따라 슬롯 UI를 갱신
		local sprite = self.Entity:GetChildByName("sprite")
		local soulName = self.Entity:GetChildByName("soulName")
		local countText = self.Entity:GetChildByName("Count")
		local downButton = countText:GetChildByName("CountDown")
		local upButton = countText:GetChildByName("CountUp")
		
		local charId = _CharacterLogic.indexAndId[self.index]
		local charData = _CharacterLogic.characterTable[tostring(charId)]
		local count = _SelectSoulPiecePopUp.currentSelectedSouls[charId]
		local ticketCount = _UserService.LocalPlayer.PlayerStorageComponent:GetItemCount("6_000051")
		
		sprite.SpriteGUIRendererComponent.ImageRUID = charData.pieceLargeRUID
		soulName.TextComponent.Text = _LocalizationService:GetText("soul_name_"..tostring(charId))
		if not isvalid(count) then
			countText.TextComponent.Text = "0"
		else
			countText.TextComponent.Text = tostring(count)
		end
		
		downButton.Enable = true
		upButton.Enable = true
		
		if not isvalid(count) or count < 1 then
			downButton.Enable = false
		end
		
		if isvalid(count) and count >= ticketCount then
			upButton.Enable = false
		end
		
		_SelectSoulPiecePopUp:RefreshMyItemCount()
	end

	@ExecSpace("ClientOnly")
	method void DecreaseCount()
		-- 선택된 영혼 조각 수량을 감소시키고 UI를 갱신
		local charId = _CharacterLogic.indexAndId[self.index]
		
		if not isvalid(_SelectSoulPiecePopUp.currentSelectedSouls[charId]) then
			return
		end
		
		_SelectSoulPiecePopUp.currentSelectedSouls[charId] -= 1
		
		if _SelectSoulPiecePopUp.currentSelectedSouls[charId] <= 0 then
			_SelectSoulPiecePopUp.currentSelectedSouls[charId] = nil
		end
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void IncreaseCount()
		-- 티켓 수량을 확인하여 영혼 조각 선택 수를 증가시키고 UI를 갱신
		local count = 0
		
		for key, value in pairs(_SelectSoulPiecePopUp.currentSelectedSouls) do
			count += value
		end
		
		local ticketCount = _UserService.LocalPlayer.PlayerStorageComponent:GetItemCount("6_000051")
		
		if ticketCount <= count then 
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast338"))
			
			return
		end
		
		local charId = _CharacterLogic.indexAndId[self.index]
		if not isvalid(_SelectSoulPiecePopUp.currentSelectedSouls[charId]) then
			_SelectSoulPiecePopUp.currentSelectedSouls[charId] = 1
		else
			_SelectSoulPiecePopUp.currentSelectedSouls[charId] += 1
		end
		self:Refresh()
	end

end