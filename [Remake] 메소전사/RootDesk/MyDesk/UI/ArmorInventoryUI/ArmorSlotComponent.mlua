@Component
script ArmorSlotComponent extends Component

	property string type = ""

	property integer slotNum = 0

	property Entity option = nil

	method void Init(string originalId, boolean empty, string uniqueKey)
		-- 방어구 슬롯 초기화 및 비어있음 여부에 따라 UI 설정
		if empty then
			self.Entity:GetChildByName("Empty",true).Enable = true
			self.Entity:GetChildByName("SlotEntity",true).Enable = false
		else
			self.Entity:GetChildByName("Empty",true).Enable = false
			self.Entity:GetChildByName("SlotEntity",true).Enable = true
			
			_UIGroupManager:SetItemSlot(self.Entity:GetChildByName("SlotEntity",true), 2, uniqueKey,"") 
			self.Entity:GetChildByName("equipped", true).Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 슬롯 엔티티에 버튼 클릭 이벤트 연결
		
		self.Entity:GetChildByName("SlotEntity",true):ConnectEvent(ButtonClickEvent, self.SendEvent )
	end

	@ExecSpace("ClientOnly")
	method void SendEvent()
		-- 버튼 클릭 이벤트를 상위 엔티티로 전달
		self.Entity:SendEvent(ButtonClickEvent())
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 방어구 슬롯 클릭 시 인벤토리 열기 처리
		
		local Entity = event.Entity
		local uniqueKey = _ItemDataLogic:GetUniqueKeyBySlotNum(self.slotNum, _UserService.LocalPlayer)
		
		if _UtilLogic:IsNilorEmptyString(uniqueKey) == true then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast340"))
			return
		end
		
		 _ArmorSystemLogic.armorInformation:OpenInventory(self.type, uniqueKey)
	end

end