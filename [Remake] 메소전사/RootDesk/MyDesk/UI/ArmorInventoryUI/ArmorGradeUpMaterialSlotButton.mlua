@Component
script ArmorGradeUpMaterialSlotButton extends Component

	property string uniqueKey = ""

	method void Init(string uniqueKey)
		-- 방어구 강화 재료 슬롯 버튼을 초기화하고 체크 이미지를 비활성화
		self.uniqueKey = uniqueKey
		self.Entity:GetChildByName("CheckImage", true):SetEnable(false)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 방어구 강화 재료 슬롯 버튼 클릭 시 방어구 정보 UI에 이벤트 전송
		
		local Entity = event.Entity
		
		_UIGroupManager.armorInformation:SendEvent(ArmorGradeUpMaterialSlotClick(self.uniqueKey, self.Entity)) 
	end

end