@Component
script InventoryItemSlot extends Component

	property string uniqueKey = ""

	property string category = ""

	property boolean init = false

	property integer inventoryNumber = 0

	method void Init(string uniqueKey, string category)
		-- 인벤토리 아이템 슬롯을 카테고리에 따라 초기화
		local playerData = {}
		local data = {}
		local option = self.Entity:GetChildByName("ArmorOptions")
		
		if category == "armor" then
			if _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey] == nil then
				self.Entity:SetEnable(false)
				return
			end
		
			self.init = true
			_UIGroupManager:SetItemSlot(self.Entity, 2, uniqueKey, "")
		
		elseif category == "pet" then
			
			option:SetEnable(false)
			playerData = _UserService.LocalPlayer.PlayerPetStorageComponent.petInventory[uniqueKey] 
			data = _PetLogic.petData[playerData.originalId]
			local playerStorage = _UserService.LocalPlayer.PlayerPetStorageComponent
			local id = playerStorage.petInventory[self.uniqueKey].originalId
			local petData = _PetLogic.petData[id]
			local renderer = self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
			renderer.ImageRUID = petData.ruid
			renderer.LocalPosition = Vector2(tonumber(petData.pivotX), tonumber(petData.pivotY))
		
		if playerStorage.petInventory[self.uniqueKey].equippedSlotNum > 0 then
			self.Entity:GetChildByName("EquippedText").Enable = true
		else
			self.Entity:GetChildByName("EquippedText").Enable = false
		end
		
		local grade = petData.grade
		
		if grade == "S" then
			self.Entity.SpriteGUIRendererComponent.Color = Color.red
		elseif grade == "A" then
			self.Entity.SpriteGUIRendererComponent.Color = Color.green
		elseif grade == "B" then
			self.Entity.SpriteGUIRendererComponent.Color = Color.yellow
		end
		
		self.Entity:GetChildByName("Level").TextComponent.Text = string.format("Lv. %d", playerStorage.petInventory[self.uniqueKey].level)
		
		end
		self.uniqueKey = uniqueKey
		self.category = category
		
		self.Entity.Enable = true
	end

	method void UnInit()
		-- 인벤토리 아이템 슬롯 초기화 해제
		self.uniqueKey = ""
		self.category = ""
		self.init = false
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 인벤토리 아이템 슬롯 클릭 시 카테고리에 따라 정보 창 열기
		
		local Entity = event.Entity
		
		if self.category == "armor" and self.init == true then
			_ArmorSystemLogic.armorInformation:OpenInventory("", self.uniqueKey)
		elseif self.category == "pet" then
		elseif self.category == "accessory" and self.init == true then 
			_ArmorSystemLogic.armorInformation:OpenInventory("", self.uniqueKey)
		end
	end

end