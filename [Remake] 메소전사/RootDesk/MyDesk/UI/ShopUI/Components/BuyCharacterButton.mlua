@Component
script BuyCharacterButton extends Component

	property Entity shopGroup = "a658240c-dfea-46e9-a055-443fa3d01885"

	@Description("직업 내의 캐릭터 넘버")
	property number index = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 엔티티 이름에서 캐릭터 인덱스 추출
		self.index = tonumber(string.sub(self.Entity.Name, -6, -1))
	end

	@ExecSpace("Client")
	method void Popup(string msg)
		-- 메시지를 표시하는 팝업 열기
		_UIPopup:Open("",msg, function()end, function()end)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐릭터 구매 버튼 클릭 이벤트 처리 (현재 비어있음)
		
		local Entity = event.Entity
	end

end