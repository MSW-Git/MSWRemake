@Component
script UIOffsetMyMode extends Component

	property number default = 170

	property number stage = 170

	property number field = 290

	@EventSender("LocalPlayer")
	handler HandleOnMapEnter(OnMapEnter event)
		-- 맵 진입 시 맵 타입에 따라 UI 위치를 조정
		local currentMap = event.currentMap
		local userEnter = event.userEnter
		
		if currentMap.MultiBattleMap ~= nil then
			self.Entity.UITransformComponent.anchoredPosition.y = self.field
		elseif currentMap.BattleMap ~= nil then
			self.Entity.UITransformComponent.anchoredPosition.y = self.stage
		else
			self.Entity.UITransformComponent.anchoredPosition.y = self.default	
		end
	end

end