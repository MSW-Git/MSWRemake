@Component
script CloneEffect extends Component

	property EntityRef parent = "b830279e-0851-484d-badd-31b9c3301c89"

	method void Destroy()
		-- 부모에게 파괴 이벤트를 전송하고 자신을 파괴
		self.parent:SendEvent(CloneEffectDestroyEvent())
		self.Entity:Destroy()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEntityDestroyEvent(EntityDestroyEvent event)
		-- 엔티티 파괴 이벤트 처리
		
		local Entity = event.Entity
		if Entity == self.Entity then
		end
	end

end