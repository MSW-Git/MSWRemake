@Component
script BeanChickUIComponent extends Component

	property Entity slot1 = "7c267036-9f45-4519-9210-402b76d41d6f"

	property Entity slot2 = "926b51b1-eb27-423f-bf28-0adace717a79"

	@HideFromInspector
	property string item1Key = ""

	@HideFromInspector
	property string item2Key = ""

	property Entity item1 = nil

	property Entity item2 = nil

	@ExecSpace("ClientOnly")
	method void SetSlot(integer slotNum, string uniqueKey, Entity entity)
		-- 아이템을 슬롯에 설정하고 같은 종류면 자동으로 합성 실행
		local storage = _UserService.LocalPlayer.PlayerStorageComponent
		local slot = self.slot1
		local otherSlot = self.slot2
		local otherId = ""
		
		if slotNum == 2 then
			if self.item1Key == uniqueKey then return end
			
			slot = self.slot2
			otherSlot = self.slot1
			self.item2Key = uniqueKey
			self.item2 = entity
			
			if isvalid(storage.storage[self.item1Key]) then
				otherId = storage.storage[self.item1Key].originalId
			end
		else
			if self.item2Key == uniqueKey then return end
			
			self.item1Key = uniqueKey
			self.item1 = entity
			
			if isvalid(storage.storage[self.item2Key]) then
				otherId = storage.storage[self.item2Key].originalId
			end
		end
		
		entity.Visible = false
		
		
		local id = ""
		
		if slotNum == 1 then
			id = storage.storage[self.item1Key].originalId
		else
			id = storage.storage[self.item2Key].originalId
		end
		
		
		
		local data = _WeaponSpecLogic.weaponData[id]
		if not isvalid(data) then
			data = _ArmorSpecLogic.armorData[id]
		end
		if not isvalid(data) then
			data = _ItemDataLogic.equipmentData[id]
		end
		local sprite = slot:GetChildByName("sprite")
		sprite.SpriteGUIRendererComponent.ImageRUID = data.ruid
		
		if not isvalid(storage.storage[self.item2Key]) then return end
		
		if isvalid(self.item1) and isvalid(self.item2) and self.item1Key ~= "" and self.item2Key ~= "" and self.item1Key ~= self.item2Key then
			if id == otherId then
				_TimerService:SetTimerOnce(function()
					_ItemReinforceLogic:RequestItemMerge(self.item1, self.item2, _UserService.LocalPlayer)
					
					self.item1 = nil
					self.item2 = nil
					
					self.item1Key = ""
					self.item2Key = ""
					
					sprite.SpriteGUIRendererComponent.ImageRUID = ""
					otherSlot:GetChildByName("sprite").SpriteGUIRendererComponent.ImageRUID = ""
					end, 0.1)
			else
				_UIToast:ShowMessage("같은 종류, 등급의 방어구만 합성할 수 있습니다.")
				self:ClearSlot(slotNum)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void ClearSlot(integer slotNum)
		-- 지정된 슬롯을 비우고 아이템을 다시 보이게 설정
		local slot = self.slot1
		
		if slotNum == 1 then
			self.item1Key = ""
			self.item1.Visible = true
			self.item1 = nil
		else
			self.item2Key = ""	
			self.item2.Visible = true
			self.item2 = nil
			slot = self.slot2
		end
		
		slot:GetChildByName("sprite").SpriteGUIRendererComponent.ImageRUID = ""
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "7c267036-9f45-4519-9210-402b76d41d6f")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 1번 슬롯 클릭 시 장비 등록 해제 확인 팝업 표시
		
		local Entity = event.Entity
		if isvalid(self.item1) then
			_UIPopup:Open("","1번 슬롯의 장비 등록을 해제하시겠습니까?", function()
					self:ClearSlot(1)
				end, nil)
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "926b51b1-eb27-423f-bf28-0adace717a79")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 2번 슬롯 클릭 시 장비 등록 해제 확인 팝업 표시
		
		local Entity = event.Entity
		
		if isvalid(self.item2) then
			_UIPopup:Open("","2번 슬롯의 장비 등록을 해제하시겠습니까?", function()
					self:ClearSlot(2)
				end, nil)
		end
	end

end