@Component
script DailyMissionSlotComponent extends Component

	property Entity missionTitle = nil

	property Entity missionProgress = nil

	property Entity rewardCanCompleteEffect = nil

	property Entity rewardNum = nil

	property Entity rewardCover = nil

	property Entity rerollButton = nil

	property integer currentSlotNum = 0

	property string currentMissionId = ""

	property DailyMissionUIComponent dailyMissionUI = "70362a0b-53d4-4d34-aeda-66e922be3b90"

	property Entity slotCover = nil

	property Entity rewardButton = nil

	property number requestedTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 일일 미션 슬롯 컴포넌트 초기화 및 이벤트 연결
		local contentPanel = self.Entity:GetChildByName("MissionPanel")
		local rewardPanel = self.Entity:GetChildByName("MissionRewardPanel")
		
		
		self.missionTitle = contentPanel:GetChildByName("MissionObjective")
		self.missionProgress = contentPanel:GetChildByName("Progress")
		
		local rewardButton = rewardPanel:GetChildByName("MissionRewardButton")
		self.rewardButton = rewardButton
		
		self.rewardButton:ConnectEvent(ButtonClickEvent, function()
			if self.requestedTime + 1 > _UtilLogic.ServerElapsedSeconds then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
				
				return
			end
			
			local isDailyMission = true
			
			if self.dailyMissionUI.currentCategory == "Weekly" then
				isDailyMission = false
			end
			
			if not _UserService.LocalPlayer.PlayerDailyMissionComponent:IsCanCompleteMission(isDailyMission, self.currentSlotNum) then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast105"))
				
				return
			end
			
			_UserService.LocalPlayer.PlayerDailyMissionComponent:RequestCompleteMission(isDailyMission, self.currentSlotNum)
			
			self.requestedTime = _UtilLogic.ServerElapsedSeconds
		end)
		
		self.rewardCanCompleteEffect = rewardButton:GetChildByName("ClearRewardEffect")
		self.rewardNum = rewardButton:GetChildByName("RewardNum")
		self.rewardCover = rewardButton:GetChildByName("cover")
		
		
		
		self.rerollButton = rewardPanel:GetChildByName("RerollButtonPanel"):GetChildByName("RerollButtonIcon")
		self.rerollButton:ConnectEvent(ButtonClickEvent, function()
			self:RequestResetMission()
		end)
		
		self.slotCover = self.Entity:GetChildByName("SlotCover")
	end

	@ExecSpace("ClientOnly")
	method void SetSlotNum(integer slotNum)
		-- 슬롯 번호 설정
		self.currentSlotNum = slotNum
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 미션 슬롯 UI 새로고침 및 진행도 업데이트
		local player = _UserService.LocalPlayer
		local dailyMissionCompo = player.PlayerDailyMissionComponent
		local missionInfo = {}
		local missionData = _DailyMissionLogic.missionData[self.currentMissionId]
		local rewardData = {}
		local objectiveNum = missionData.objectiveNum
		local objectiveType = missionData.objectiveType
		local title = _LocalizeLogic:GetMissionName(self.currentMissionId)
		
		if self.dailyMissionUI.currentCategory == "Daily" then
			rewardData = _DailyMissionLogic.rewardData[string.format("day_%s", missionData.missionDifficulty)]
			missionInfo = dailyMissionCompo.missionInfo[string.format("dm_%d", self.currentSlotNum)]
		else
			rewardData = _DailyMissionLogic.rewardData[string.format("week_%s", missionData.missionDifficulty)]
			missionInfo = dailyMissionCompo.missionInfo[string.format("wm_%d", self.currentSlotNum)]
			objectiveNum = objectiveNum * 10
		end
		
		local targetObject = missionInfo.obj
		
		self.rewardCover.Enable = false
		self.slotCover.Enable = false
		self.Entity:GetChildByName("icon_info").Enable = false
		self.Entity.SpriteGUIRendererComponent.RaycastTarget = false
		
		
		if objectiveType == "levelUpSoul" then
		elseif objectiveType == "randomStageClear" then
			local stageStep = tonumber(targetObject)
			local chapter = math.floor(stageStep / 10)
			local stage = stageStep % 10
			
			if stageStep ~= 0 and stage == 0 then
				stage = 10
			end
			
			local chapterStr = ""
			
			if stageStep < 80 and stage < 10 then
				chapter += 1
			end
		
			if chapter == 1 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup5")
			elseif chapter == 2 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup6")
			elseif chapter == 3 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup7")
			elseif chapter == 4 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup8")
			elseif chapter == 5 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup9")
			elseif chapter == 6 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup10")
			elseif chapter == 7 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup11")
			elseif chapter == 8 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup12")
			end
			
			local stageStr = string.format("[%s] %d - %d", chapterStr, chapter, stage)
			
			title = string.format(title, stageStr)
		elseif objectiveType == "equipSoulAndClear" or objectiveType == "equipSoulAndRecommendClear" then
			title = string.format(title, _LocalizationService:GetText("soul_name_"..targetObject), objectiveNum)
		elseif objectiveType == "equipWeaponAndClear" then
			title = string.format(title, _LocalizationService.LocalTranslator:GetText(targetObject), objectiveNum)
		elseif objectiveType == "killSelectedMonster" then
			title = _LocalizationService:GetTextFormat("mission_Name_20", _LocalizeLogic:GetMonsterName(targetObject), tostring(objectiveNum))
		else
			title = string.format(title, objectiveNum)
		end
		
		self.missionTitle.TextComponent.Text = title
		
		if missionInfo.status == 1 then
			self.rewardCanCompleteEffect.Enable = false
			self.rewardCover.Enable = true
			self.slotCover.Enable = true
			self.rerollButton.Enable = false
		else
			if missionInfo.prg >= objectiveNum then
				self.rewardCanCompleteEffect.Enable = true
				self.rerollButton.Enable = false
			else
				self.rewardCanCompleteEffect.Enable = false
				self.rerollButton.Enable = true
			end
		end
		
		self.missionProgress.SpriteGUIRendererComponent.FillAmount = missionInfo.prg / objectiveNum
		self.missionProgress.TextComponent.Text = string.format("%d / %d", missionInfo.prg, objectiveNum)
		
		self.rewardNum.TextComponent.Text = string.format("%d", rewardData.rewardNum)
		
		if objectiveType == "stageClear" or objectiveType == "equipSoulAndRecommendClear" or objectiveType == "equipWeaponAndClear" 
			or objectiveType == "killMonster" or objectiveType == "killFlyingMonsterInRecommend" or objectiveType == "killSelectedMonster" then
			self.Entity:GetChildByName("icon_info").Enable = true
			self.Entity.SpriteGUIRendererComponent.RaycastTarget = true
		end
	end

	@ExecSpace("Client")
	method void RequestResetMission()
		-- 미션 재설정 요청 및 비용 결제 확인
		if self.requestedTime + 1 > _UtilLogic.ServerElapsedSeconds then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
			
			return
		end
		
		local userId = _UserService.LocalPlayer.PlayerComponent.UserId
		local needDiamond = 5
		
		if self.dailyMissionUI.currentCategory == "Weekly" then
			needDiamond = 10
		end 
		
		if _CheckLogic:IsEnoughWealth(userId, _GameConfig:GetConfig().WEALTHTYPE_DIAMOND, needDiamond) then
			local str = _LocalizeLogic:GetText("missionStr_1")
			if self.dailyMissionUI.currentCategory == "Weekly" then
				str = _LocalizeLogic:GetText("missionStr_2")
			end
			
			
			_UIPopup:OpenPurchasePopup(_LocalizeLogic:GetText("popup43"), _LocalizeLogic:GetText("popup44"), _LocalizeLogic:GetText("popup45"), "diamond", needDiamond, function()
				local dailyMission = _UserService.LocalPlayer.PlayerDailyMissionComponent
				
				if self.dailyMissionUI.currentCategory == "Daily" then
					dailyMission:RequestSetDailyMission(self.currentSlotNum, true)
				elseif self.dailyMissionUI.currentCategory == "Weekly" then
					dailyMission:RequestSetWeeklyMission(self.currentSlotNum, true)
				end
			end, nil)
		else
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast103"))
		end
		
		self.requestedTime = _UtilLogic.ServerElapsedSeconds
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string missionId)
		-- 미션 ID로 슬롯 설정 및 새로고침
		self.currentMissionId = missionId
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void ShowRecommendStage()
		-- 추천 스테이지 목록 표시 팝업
		local minStage = _UserService.LocalPlayer.PlayerInfoComponent.minRecommendStage
		local playerStep = _UserService.LocalPlayer.PlayerInfoComponent.playerInfo.stageStep
		local str = ""
		local count = 1
		
		if playerStep == 0 then
			playerStep = 1
		end
		
		if playerStep - 9 >= minStage and playerStep < 80 then
			minStage += 1
		end
		
		for i = minStage, playerStep + 1 do
			if i > playerStep + 1 or i > 80 then 
				break
			elseif i > 1 and _UserService.LocalPlayer.PlayerInfoComponent.playerInfo.stageStep == 0 then
				break
			elseif playerStep - 9 > i then
				continue
			end
			
			local chapter = math.floor(i / 10)
			local stage = i % 10
		
			
			if chapter < 1 then
				chapter = 1
			elseif stage ~= 0 then
				chapter += 1
			end
			
			if stage == 0 then
				if chapter > 1 then
					stage = 10
				elseif chapter == 1 and i == 1 then
					stage = 1
				elseif chapter == 1 and i == 10 then
					stage = 10
				end
			elseif stage == 10 then
				if chapter == 10 then
					stage = 10
				end
			end
			
			local chapterStr = ""
		
			if chapter == 1 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup5")
			elseif chapter == 2 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup6")
			elseif chapter == 3 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup7")
			elseif chapter == 4 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup8")
			elseif chapter == 5 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup9")
			elseif chapter == 6 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup10")
			elseif chapter == 7 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup11")
			elseif chapter == 8 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup12")
			end
			
			local stageStr = string.format("[%s] %d - %d", chapterStr, chapter, stage)
			
			if str == "" then
				str = stageStr
			else
				if (count - 1) % 4 == 0 then
					str = str ..",\n".. stageStr
				else
					str = str ..", ".. stageStr
				end
			end
			
			count += 1
		end
		
		_UIOnlyConfirmPopUp:Open(str, _LocalizeLogic:GetText("confirmPopup4"), nil)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 미션 슬롯 클릭 시 상세 정보 표시 이벤트 처리
		
		local Entity = event.Entity
		local player = _UserService.LocalPlayer
		local dailyMissionCompo = player.PlayerDailyMissionComponent
		local missionInfo = {}
		local missionData = _DailyMissionLogic.missionData[self.currentMissionId]
		local objectiveNum = missionData.objectiveNum
		local objectiveType = missionData.objectiveType
		
		if objectiveType == "killSelectedMonster" then
			if self.dailyMissionUI.currentCategory == "Daily" then
				missionInfo = dailyMissionCompo.missionInfo[string.format("dm_%d", self.currentSlotNum)]
			else
				missionInfo = dailyMissionCompo.missionInfo[string.format("wm_%d", self.currentSlotNum)]
			end
			
			local targetObject = missionInfo.obj
			
			if targetObject ~= "" then
				self.dailyMissionUI:ShowTargetMonster(targetObject)
			end
		elseif objectiveType == "stageClear" or objectiveType == "equipSoulAndRecommendClear" or objectiveType == "equipWeaponAndClear" 
			or objectiveType == "killMonster" or objectiveType == "killFlyingMonsterInRecommend" then
			self:ShowRecommendStage()
		end
		
	end

end