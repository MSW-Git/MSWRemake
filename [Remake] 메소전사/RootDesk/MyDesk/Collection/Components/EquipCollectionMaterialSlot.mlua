@Component
script EquipCollectionMaterialSlot extends Component

	property string listId = ""

	property string materialId = ""

	property number materialNum = 0

	property number parentPanelNumber = 0

	property string listCategory = ""

	method void Init(string id, string listId)
		-- 컬렉션 재료 슬롯을 초기화하고 UI 상태를 설정
		local userCollectionTable = _UserService.LocalPlayer.PlayerCollectionComponent.eCollectionTable[listId]
		local userStorage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		self.listCategory = _CollectionLogic.statusTable[listId].category 
		local count = self.Entity:GetChildByName("count", true)
		
		if _UtilLogic:IsNilorEmptyString(id) or _UtilLogic:IsNilorEmptyString(listId) then
			self.Entity:SetEnable(false)
			return
		end
		
		self.listId = listId
		self.materialId = id
		
		local equip =  {} 
		local category = "" 
		
		if isvalid(_ItemDataLogic.equipmentData[id]) then
			equip = _ItemDataLogic.equipmentData[id]
			category = _ItemDataLogic.equipmentData[id].category
		else
			equip = _ItemDataLogic.itemData[id]
			category = _ItemDataLogic.itemData[id].category
		end
		
		if category == "weapon" then
			self.Entity:GetChildByName("GradeStar", true):SetEnable(false)
			self.Entity.SpriteGUIRendererComponent.ImageRUID =  _WeaponSpecLogic:GetWeaponSlotRUIDByGrade(equip.grade)
			
		elseif category == "accessory" then
			self.Entity:GetChildByName("GradeStar", true):SetEnable(false)
			local grade = _UtilLogic:Split(_CollectionLogic.statusTable[listId].grade, "_")
			self.Entity.SpriteGUIRendererComponent.ImageRUID =  _WeaponSpecLogic:GetWeaponSlotRUIDByGrade(grade[1])
			
		elseif category == "armor" then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetSlotColorRUID(id)
			local starCount = _ArmorSpecLogic.armorData[id].star
			
			self.Entity:GetChildByName("GradeStar", true):SetEnable(true)
			
			for i = 1, #self.Entity:GetChildByName("GradeStar", true).Children do
				if starCount >= i then
					self.Entity:GetChildByName("GradeStar", true).Children[i]:SetEnable(true)
				else
					self.Entity:GetChildByName("GradeStar", true).Children[i]:SetEnable(false)
				end
			end
		end
		
		if category == "weapon" or category == "armor" then
			self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(id)
		elseif category == "accessory" then
			self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic.itemData[id].ruid
		end
		
		self.Entity:GetChildByName("Dot"):SetEnable(false)
		self.Entity:GetChildByName("Grade_Alphabet"):SetEnable(false)
		
		if self.listCategory == "armor" then
			count.Enable = true
		
			if _GameUtil:GetBoolValue(userCollectionTable,self.materialNum) then 
				self.Entity:GetChildByName("Registered"):SetEnable(true)
				count.TextComponent.Text = "1/1"
			else
				count.TextComponent.Text = "0/1"
				self.Entity:GetChildByName("Registered"):SetEnable(false)	
				for key , value in pairs(userStorage) do
					if value.originalId == id and value.lock == false then
						self.Entity:GetChildByName("Dot"):SetEnable(true)
						break
					end	
				end
			end
			
		elseif self.listCategory == "weapon" then
			count.TextComponent.Text = tostring(_CollectionLogic:GetCollectionEquippedCount(listId, self.materialNum, _UserService.LocalPlayer))
			count.Enable = true
		
			if _GameUtil:GetNumberValueTen(listId, self.materialNum, _UserService.LocalPlayer) then  
				self.Entity:GetChildByName("Registered"):SetEnable(true)
			else
				self.Entity:GetChildByName("Registered"):SetEnable(false)	
		
				for key , value in pairs(userStorage) do
					if value.originalId == id and value.lock == false then
						self.Entity:GetChildByName("Dot"):SetEnable(true)
						break
					end	
				end
			end
		
		elseif self.listCategory == "accessory" then
			count.TextComponent.Text = tostring(_CollectionLogic:GetCollectionEquippedCount(listId, self.materialNum, _UserService.LocalPlayer))
			count.Enable = true
			local accessoryGrade = _CollectionLogic:GetAccessoryGrade(_CollectionLogic.statusTable[self.listId].grade)
			
			if _GameUtil:GetNumberValueTen(listId, self.materialNum, _UserService.LocalPlayer) then  
				self.Entity:GetChildByName("Registered"):SetEnable(true)
			else
				
				self.Entity:GetChildByName("Registered"):SetEnable(false)	
				
				for key , value in pairs(userStorage) do
				
					if value.originalId == id and value.grade == accessoryGrade[2] then
						self.Entity:GetChildByName("Dot"):SetEnable(true)
						break
					end	
				end
		
		
			end
			local grade = _UtilLogic:Split(_CollectionLogic.statusTable[listId].grade, "_")
			self.Entity:GetChildByName("Grade_Alphabet").SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(accessoryGrade[2])
			self.Entity:GetChildByName("Grade_Alphabet"):SetEnable(true)
		end
		
		self.Entity:SetEnable(true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 컬렉션 재료 슬롯 클릭 시 재료 선택 팝업을 열기
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		local Entity = event.Entity
		local userCollectionTable = _UserService.LocalPlayer.PlayerCollectionComponent.eCollectionTable[self.listId]
		if self.listCategory == "armor" then
			if _GameUtil:GetBoolValue(userCollectionTable,self.materialNum) == true then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast36")) 
				return
			end	
		elseif self.listCategory == "weapon" then
			if _GameUtil:GetNumberValueTen(self.listId, self.materialNum, _UserService.LocalPlayer) == true then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast36")) 
				return
			end	
		end
		
		_CollectionLogic.selectedListId = self.listId
		_CollectionLogic.selectedMaterialId = self.materialId
		_CollectionLogic.selectedMaterialSlotNum = self.materialNum
		_CollectionLogic.EquipCollectionPopup:OpenMaterialInventory()
	end

end