@Component
script EquipCollectionInventoryMaterialSlot extends Component

	property string uniqueKey = ""

	property Entity selected = nil

	property boolean redDot = false

	property boolean isEquipped = false

	method void Init(table itemTable)
		-- 컬렉션 인벤토리 재료 슬롯을 초기화하고 선택 상태를 설정
		self.selected = self.Entity:GetChildByName("CheckImage", true)
		self.uniqueKey = itemTable.uniqueKey
		
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.uniqueKey]
		local originId = storage.originalId
		
		local categoryNum = 1
		self.Entity:GetChildByName("Grade_Alphabet", true).Enable = false
		if isvalid(_ItemDataLogic.equipmentData[originId]) then	
			if _ItemDataLogic.equipmentData[originId].category == "armor" then
				categoryNum = 2
			end 
		else
			if _ItemDataLogic.itemData[originId].category == "accessory" then
				categoryNum = 5
				self.Entity:GetChildByName("Grade_Alphabet", true).SpriteGUIRendererComponent.ImageRUID = 
					_AccessoryLogic:GetAlphabetGradeRUID(storage.grade)
				self.Entity:GetChildByName("Grade_Alphabet", true).Enable = true
			end
		end
		
		_UIGroupManager:SetItemSlot(self.Entity, categoryNum, self.uniqueKey, "")
		
		self.Entity:GetChildByName("CheckImage", true):SetEnable(false)
		
		for i = 1 , #_CollectionLogic.selectedUniqueKey do
			if _CollectionLogic.selectedUniqueKey[i] == self.uniqueKey then
				self.Entity:GetChildByName("CheckImage", true):SetEnable(true)
				break
			end
		end
		
		if storage.equippedSlotNum > 0 then
			self.Entity:GetChildByName("equipped", true).Enable = true
			self.isEquipped = true
		else
			self.Entity:GetChildByName("equipped", true).Enable = false
			self.isEquipped = false
		end
	end

	method void OnButtonClick()
		-- 재료 슬롯 클릭 시 선택/해제 이벤트를 발생
		local category = _CollectionLogic.statusTable[_CollectionLogic.selectedListId].category
		_CollectionLogic:SendEvent(SelectCollectionMaterial(self.uniqueKey, _UserService.LocalPlayer, self.Entity, category))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하여 재료 선택 처리
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		self:OnButtonClick()
	end

end