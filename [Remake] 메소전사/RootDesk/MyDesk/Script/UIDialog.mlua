@Logic
script UIDialog extends Logic

	property Entity dialog = "08935eaa-4477-4ed4-a90b-d02259f0a89e"

	property Entity dialogText = "0598498f-dab2-4a30-b9a1-8bf441b86b8c"

	property boolean isShow = false

	property string message = ""

	property number interval = 0.085

	property Entity nameTextLeft = "a733a96d-1667-46b1-8639-3d294a9c2974"

	property Entity thumbParent = "a3daece5-ba4b-4d68-8c7b-d063de1ce09c"

	property Entity nameTextRight = "d7746409-66a5-4ba8-86fb-929aac3fe5bc"

	property AvatarGUIRendererComponent avatar = "0c9de86f-6f75-40fb-82cd-86638ff22749"

	property string currentDialogKey = ""

	property Entity skipButton = "dd121d25-e6c0-4acd-bb38-6573e7e96a45"

	property Entity questUICover = "f6a707c3-1868-44fb-afbb-c8d8e82711e8"

	method void ShowDialog(string name, string message, string thumb, string emotion, string theOtherName, string theOtherThumb, any callback, boolean skipEnable)
		-- 대화 창을 표시하고 캐릭터 이모션 및 썸네일 설정
		if _UtilLogic:IsNilorEmptyString(message) then
			if callback ~= nil then
				callback()
			end
			return
		end
		
		if _UtilLogic:IsNilorEmptyString(thumb) == false then
			for k,v in pairs(self.thumbParent.Children) do
				if thumb == v.Name then
					if name ~= self._T.speaker then
						self:SetSpriteColor(true,v)
					end
					v.Enable = true
					self._T.thumbUI = v
					self._T.speaker = name
				end
			end
			
		end
		
		for k,v in pairs(self.thumbParent.Children) do
			if v ~= self._T.thumbUI then
				v.Enable = false
			end
		end
		
		if thumb == "avatar" then
			self.nameTextLeft.TextComponent.Text = name
			self.nameTextLeft.Parent.Enable = true
			self.nameTextRight.Parent.Enable = false
		
			local duration = math.maxinteger
			local emotionType = EmotionalType.Default
			if _UtilLogic:IsNilorEmptyString(emotion) == false then		
				if emotion == "당황" then
					emotionType = EmotionalType.Bewildered
				elseif emotion == "좌절" then
					emotionType = EmotionalType.Oops
				elseif emotion == "분노" then
					emotionType = EmotionalType.Angry
				elseif emotion == "꺄오" then
					emotionType = EmotionalType.Cheers
				elseif emotion == "반짝" then
					emotionType = EmotionalType.Shine
				elseif emotion == "흐음" then
					emotionType = EmotionalType.Hum
				elseif emotion == "창백" then
					emotionType = EmotionalType.qBlue
				elseif emotion == "활활" then
					emotionType = EmotionalType.Blaze
				elseif emotion == "사랑" then
					emotionType = EmotionalType.Love
				elseif emotion == "한숨" then
					emotionType = EmotionalType.Stunned
				elseif emotion == "뜨거" then
					emotionType = EmotionalType.Hot
				elseif emotion == "초롱" then
					emotionType = EmotionalType.Glitter
				elseif emotion == "눈치" then
					emotionType = EmotionalType.Troubled
				elseif emotion == "우웩" then
					emotionType = EmotionalType.Vomit
		 		end
				self._T.previousEmotion = emotionType
					_TimerService:SetTimerOnce(function() 
					
					_UserService.LocalPlayer.AvatarRendererComponent:PlayEmotion(emotionType,duration)
					self.avatar:PlayEmotion(emotionType,duration)
					end,0.01)
			end
			
			if _UtilLogic:IsNilorEmptyString(theOtherName) == false then
				local ruid = ""
				if theOtherThumb == "npc" or theOtherThumb == "seren" or theOtherThumb == "cygnus" or theOtherThumb == "frog" or theOtherThumb == "guardianAngelSlime" or theOtherThumb == "guardianAngelSlime_hit" then
					ruid = _NPCLogic.npcData[theOtherName].ruid
				elseif theOtherThumb == "soul" then
					ruid = _CharacterLogic.characterTable[theOtherName].charRUID
				end
				local thumbEntity = self.thumbParent:GetChildByName(theOtherThumb).SpriteGUIRendererComponent
				if tostring(thumbEntity.ImageRUID.DataId) ~= ruid then
					thumbEntity.ImageRUID = ""
					thumbEntity.ImageRUID = ruid
					self:SetSpriteColor(false,thumbEntity.Entity)
					thumbEntity.Entity.Enable = true
				elseif thumbEntity.LocalScale == Vector2.one then
					self:SetSpriteColor(false,thumbEntity.Entity)
					thumbEntity.Entity.Enable = true
				else
					thumbEntity.Entity.Enable = true
				end
			end
		
			
		elseif _UtilLogic:IsNilorEmptyString(thumb) == false then
			local ruid = ""
			local chrName = ""
			if thumb == "npc" or thumb == "seren" or thumb == "cygnus" or thumb == "frog" or thumb == "guardianAngelSlime" or thumb == "guardianAngelSlime_hit" then
				ruid = _NPCLogic.npcData[name].ruid
				chrName = _LocalizationService:GetText("npc_name_"..name)
			elseif thumb == "soul" then
				ruid = _CharacterLogic.characterTable[name].charRUID
				chrName = _LocalizationService:GetText("soul_name_"..name)
			end
			
			if tostring(self._T.thumbUI.SpriteGUIRendererComponent.ImageRUID.DataId) ~= ruid then
				self._T.thumbUI.SpriteGUIRendererComponent.ImageRUID = ""
			end
			self._T.thumbUI.SpriteGUIRendererComponent.ImageRUID = ruid
		
			self.nameTextRight.TextComponent.Text = chrName
			self.nameTextLeft.Parent.Enable = false
			self.nameTextRight.Parent.Enable = true
			
			local avatarEntity = self.thumbParent:GetChildByName("avatar")
			if avatarEntity.UITransformComponent.UIScale == Vector3.one then
				self:SetSpriteColor(false,avatarEntity)
			end
			avatarEntity.Enable = true
		else
			self.nameTextRight.TextComponent.Text = name
			self.nameTextLeft.Parent.Enable = false
			self.nameTextRight.Parent.Enable = true
		end
		if _UtilLogic:IsNilorEmptyString(name) then
			self.nameTextLeft.Parent.Enable = false
			self.nameTextRight.Parent.Enable = false
		end
		
		
		self.dialog.Enable = true
		self.message = message
		self.dialogText.TextComponent.Text = ""
		
		self._T.enableNext = false
		self._T.callback = callback
		
		self.isShow = true
		
		self._T.skipEnable = skipEnable
	end

	method void OnNext()
		-- 다음 대화로 넘어가기 및 이모션 초기화
		if self._T.skipEnable == false then
			return
		end
		if self.isShow == false then
			return
		end
		if self._T.enableNext == false then
			self:OnSkip()
			return
		end
		
		
		if self._T.previousEmotion ~= nil then
				_UserService.LocalPlayer.AvatarRendererComponent:PlayEmotion(EmotionalType.Default,0.1)
				self.avatar:PlayEmotion(EmotionalType.Default,0.1)
				self._T.previousEmotion = nil
		end
		
		if self._T.callback ~= nil then
			self._T.callback()
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 대화 텍스트 타이핑 애니메이션 설정
		local timeIndex = 0
		_TimerService:SetTimerRepeat(function() 
				local length = utf8.len(self.message)
				local currentlength = utf8.len(self.dialogText.TextComponent.Text)
				
				if currentlength < length then
					self.dialogText.TextComponent.Text = _UtilLogic:SubString(self.message,1,currentlength + 1)
					if currentlength > 0 then
						local text = _UtilLogic:SubString(self.message,currentlength,1)
						if text ~= " " then
						end
					end
					
				else
					if self._T.skipEnable then			
						self.dialogText.TextComponent.Text = self.message 
						self._T.enableNext = true
						timeIndex = timeIndex + 1
					else
						self.dialogText.TextComponent.Text = self.message
					end
				end
		end,self.interval,self.interval)
		self._T.skipEnable = true
		
	end

	method void OnSkip()
		-- 대화 텍스트 애니메이션 스킵
		if self._T.enableNext then
			return
		end
		self.dialogText.TextComponent.Text = self.message
	end

	method void Hide()
		-- 대화 창 숨김 및 콜백 실행
		self.dialog.Enable = false
		self.isShow = false
		if self._T.callback ~= nil then
			self._T.callback()
		end
		
	end

	method void ShowDialogList(table messageList, any callback, boolean skipEnable)
		-- 대화 리스트를 순차적으로 표시
		
		self._T.message = messageList
		self._T.finalCallback = callback
		self._T.speaker = nil
		self:OnNextDialogList(1,callback,skipEnable)
	end

	method void OnNextDialogList(number index, any callback, boolean skipEnable)
		-- 대화 리스트의 다음 대화를 표시
		
		if not isvalid(self._T.message) then
			
			return
		end
		
		self:ShowDialog(self._T.message [index].name,_LocalizationService:GetText(self._T.message [index].localizationKey),self._T.message[index].thumb,self._T.message[index].emotion,self._T.message[index].theOtherName,self._T.message[index].theOtherThumb,function()	
			if #self._T.message  > index then
				self:OnNextDialogList(index + 1,callback,skipEnable)
			else
				self.dialog.Enable = false
				self.isShow = false
		
				self:SendEvent(DialogEndEvent())
				
				if self._T.previousEmotion ~= nil then
						_UserService.LocalPlayer.AvatarRendererComponent:PlayEmotion(EmotionalType.Default,0.1)
						self.avatar:PlayEmotion(EmotionalType.Default,0.1)
						self._T.previousEmotion = nil
				end
				
				if callback ~= nil then	
					callback()
				end
			end
				
			if _UtilLogic:IsNilorEmptyString(self._T.message [index].event) == false then
				self:SendEvent(DialogEvent(self._T.message [index].event,self._T.message [index].option))
			end
		
		end,skipEnable)
	end

	method void SetSpriteColor(boolean bright, Entity sprite)
		-- 스프라이트 색상과 크기 애니메이션 설정
		local localScale = nil
		---@type SpriteGUIRendererComponent
		local spriteGUI = nil
		if sprite.Name ~= "avatar" then
			spriteGUI = sprite.SpriteGUIRendererComponent
			localScale = sprite.SpriteGUIRendererComponent.LocalScale
		else
			spriteGUI = sprite.AvatarGUIRendererComponent
			localScale = sprite.UITransformComponent.UIScale
		end
		
		if bright then
			localScale.x = 0.95
			localScale.y = 0.95
			local tween = _TweenLogic:PlayTween(0.95,1,0.15,EaseType.QuadEaseIn,function(value) 
					localScale.x = value
					localScale.y = value
			end)
			tween:SetOnEndCallback(function() 
				spriteGUI.Color = Color.FromHexCode("#FFFFFF")
				
				localScale.x = 1
				localScale.y = 1
			end)
		else
			localScale.x = 1
			localScale.y = 1
			local tween = _TweenLogic:PlayTween(1,0.95,0.15,EaseType.QuadEaseIn,function(value) 
					localScale.x = value
					localScale.y = value
			end)
			tween:SetOnEndCallback(function() 
			
				spriteGUI.Color = Color.FromHexCode("#5C5C5C")
			
				localScale.x = 0.95
				localScale.y = 0.95
			end)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "dd121d25-e6c0-4acd-bb38-6573e7e96a45")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 대화 스킵 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UIDialog.currentDialogKey == "intro" then
			_IntroStoryLogic:SkipIntro()
		else
			self:SendEvent(DialogEvent(self._T.message [#self._T.message].event,self._T.message [#self._T.message].option))
			if self._T.previousEmotion ~= nil then
					_UserService.LocalPlayer.AvatarRendererComponent:PlayEmotion(EmotionalType.Default,0.1)
					self.avatar:PlayEmotion(EmotionalType.Default,0.1)
					self._T.previousEmotion = nil
			end
			self.dialog.Enable = false
			self.isShow = false
			self:SendEvent(DialogEndEvent())
			if self._T.finalCallback ~= nil then
				self._T.finalCallback()
			end
			self._T.finalCallback = nil
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleDialogEvent(DialogEvent event)
		-- 대화 이벤트 처리 (카메라 흔들기 등)
		local eventKey = event.eventKey
		local option = event.option
		if eventKey == "shake" then
			_UserService.LocalPlayer.CameraComponent:ShakeCamera(0.3,2)
		end
	end

end