@Logic
script DialogDataLogic extends Logic

	property table dialog = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 대화 데이터를 로드하여 대화 테이블 초기화
		local data = _DataService:GetTable("Dialog")
		
		for i = 1, data:GetRowCount() do
			local key = data:GetCell(i,"key")
			if self.dialog[key] == nil then
				self.dialog[key] = {}
			end
			
			local name = data:GetCell(i,"name")
			if name == "player" then
				name = _UserService.LocalPlayer.PlayerComponent.Nickname
			end
			local eachData = {}
			eachData.name = name
			eachData.text = data:GetCell(i,"text")
			eachData.event = data:GetCell(i,"event")
			eachData.option =  data:GetCell(i,"option")
			eachData.thumb =  data:GetCell(i,"thumb")
			eachData.emotion =  data:GetCell(i,"emotion")
			eachData.theOtherName = data:GetCell(i,"theOtherName")
			eachData.theOtherThumb = data:GetCell(i,"theOtherThumb")
			eachData.localizationKey = data:GetCell(i,"localizationKey")
			table.insert(self.dialog[key],eachData)
		end
	end

	@ExecSpace("Client")
	method void StartScene(string key, string type, any callback)
		-- 지정된 키에 따라 대화 시나리오 시작
		if not isvalid(self.dialog[key]) then
			
			return
		end
		
		_UIDialog.currentDialogKey = key
		
		local callbackFunc = function()
			if callback ~= nil then
				callback()
			end
		end
		if type == "normal" then
			self:UIAndControllerOnOff(false)
			callbackFunc = function()
				self:UIAndControllerOnOff(true)
				if callback ~= nil then
					callback()
				end
			end
		end
		
		_UIDialog.dialog.Enable = false
		for _, child in pairs(_UIDialog.dialog.Children) do
			child.Enable = true
		end
		
		
		_UIDialog:ShowDialogList(self.dialog[key],callbackFunc,true)
	end

	method void UIAndControllerOnOff(boolean onoff)
		-- UI와 컨트롤러를 켜거나 끄는 기능
		if onoff == false then
			self._T.uiGroups = {}
			for _, uiGroup in pairs(_EntityService:GetEntityByPath("/ui").Children) do
				if uiGroup.Enable == true and uiGroup ~= _BattleUIManager.loadingUI.Entity then
					table.insert(self._T.uiGroups,uiGroup)
					uiGroup.Enable = false
				end
			end
			_UserService.LocalPlayer.PlayerControllerComponent.Enable = false
		else
			for _, uiGroup in pairs(self._T.uiGroups) do
				uiGroup.Enable = true
			end
			_UserService.LocalPlayer.PlayerControllerComponent.Enable = true
		end
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력 이벤트 처리 (스페이스바로 대화 넘기기)
		
		local key = event.key
		if key == KeyboardKey.Space then
			_UIDialog:OnNext()
		end
	end

end