@Logic
script IntroStoryLogic extends Logic

	property Entity introCamera = "7cc70dc7-589a-4341-8700-8cd8f37abcc0"

	property Entity playerAvatar = "5d1883ef-eebd-4610-8d27-b257d9e87dab"

	property EntityRef soulcalibur = "f0f604fd-a163-4c33-baa1-6154a415a58c"

	@ExecSpace("Client")
	method void StartScene()
		-- 인트로 스토리 시나리오 시작
		_UserService.LocalPlayer.CurrentMap.SoundComponent:Stop()
		
		self._T.introStarted = true
		self._T.introEnd = false
		_UIDialog.currentDialogKey = "intro"
		self._T.uiGroups = {}
		for _, uiGroup in pairs(_EntityService:GetEntityByPath("/ui").Children) do
			if uiGroup.Enable == true and uiGroup ~= _BattleUIManager.loadingUI.Entity then
				table.insert(self._T.uiGroups,uiGroup)
			end
		end
		
		for _, uiGroup in pairs(self._T.uiGroups) do
			uiGroup.Enable = false
		end
		
		_CameraService:SwitchCameraTo(self.introCamera.CameraComponent)
		self.introCamera.CameraComponent:SetZoomTo(150,0.1)
		_BattleUIManager.loadingUI:Hide(5,function()
		
			_UIDialog.dialog.Enable = true
			for _, child in pairs(_UIDialog.dialog.Children) do
				child.Enable = false
			end
			_UIDialog.skipButton.Enable = true
				
			_UserService.LocalPlayer.PlayerControllerComponent.Enable = false
			
			self:PlayScene("start")
		end)
		
		_ResourceService:PreloadAsync({"dae202b67a4b43c680505b47ee69c7cc"},nil)
	end

	method void PlayScene(string scene)
		-- 지정된 인트로 시나리오 장면 재생
		if self._T.introEnd then return end
		
		if scene == "start" then
			_SoundService:PlayBGM("87455f5f463441b4befc83a2c0b8b12a",_SoundLogic.bgmRatio)
			local duration = 5
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Default,duration)
			_TweenLogic:MoveTo(self.playerAvatar,Vector2(self.playerAvatar.TransformComponent.Position.x-4,self.playerAvatar.TransformComponent.Position.y),duration,EaseType.Linear)
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("walk1","walk1"))
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene00")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
		
		elseif scene == "scene00" then
			local duration = 3
			self.playerAvatar.ChatBalloonComponent.Enable = true
			self.playerAvatar.ChatBalloonComponent.Message = "!"
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Shine,duration)	
			_SoundService:PlaySound("029a02e537d642f4a8023d096ccf3c9a",_SoundLogic.effectRatio)
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("stand1","stand1"))
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene01")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene == "scene01" then
			local duration = 3.5
			self.playerAvatar.ChatBalloonComponent.Enable = false
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Default,duration)
			_TweenLogic:MoveTo(self.playerAvatar,Vector2(self.soulcalibur.TransformComponent.Position.x+0.5,self.playerAvatar.TransformComponent.Position.y),duration,EaseType.Linear)
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("walk1","walk1"))
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene02")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene == "scene02" then
			local duration = 2
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("stand1","stand1"))
			_SoundService:PlaySound("01d17707062d4ddaa3bf7554b8cf5aa3",_SoundLogic.effectRatio)
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Glitter,duration)
			self.playerAvatar.ChatBalloonComponent.Enable = true
			self.playerAvatar.ChatBalloonComponent.Message = "♥"
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene03")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
		
		elseif scene  == "scene03" then	
			local duration = 1
			self.playerAvatar.ChatBalloonComponent.Enable = false
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("heal","heal",1,SpriteAnimClipPlayType.Loop,2,2))
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Cheers,duration)
			
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene04")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene  == "scene04" then
			local duration = 2
			self.introCamera.CameraComponent:ShakeCamera(0.3,duration)
			local question = function()
				if self._T.introEnd then return end
				self.playerAvatar.ChatBalloonComponent.Enable = true
				self.playerAvatar.ChatBalloonComponent.Message = "?"
			end
			_TimerService:SetTimerOnce(question,duration-1)
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Default,duration)
			_SoundService:PlaySound("b07190103c1945eca86959243afed890",_SoundLogic.effectRatio)
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene05")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene  == "scene05" then
			local duration = 4.3
			self.playerAvatar.ChatBalloonComponent.Message = "?!"
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Angry,duration)
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene06")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
			_TweenLogic:PlayTween(1,0,1,EaseType.Linear,function(value) 
				self.soulcalibur.SpriteRendererComponent.Color.a = value
			end)
			local effectOption = {["SortingLayer"]=self.soulcalibur.SpriteRendererComponent.SortingLayer,["OrderInLayer"]=-1}
			_EffectService:PlayEffect("dae202b67a4b43c680505b47ee69c7cc",self.soulcalibur,self.soulcalibur.TransformComponent.WorldPosition+Vector3(0,0.225,0),0,Vector3.one,false,effectOption)
			_SoundService:PlaySound("b07190103c1945eca86959243afed890",_SoundLogic.effectRatio)
			local effectSound = function()
				_SoundService:PlaySound("ead747830d4f4ca392d722b13fd95913",_SoundLogic.effectRatio)
			end
			_TimerService:SetTimerOnce(effectSound,2.8)
			
		elseif scene  == "scene06" then
			local duration = 0.4
			self.playerAvatar.ChatBalloonComponent.Enable = false
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Hit,duration)
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("fly","fly"))
			local originX = self.playerAvatar.TransformComponent.Position.x
			local originY = self.playerAvatar.TransformComponent.Position.y
			_TweenLogic:PlayTween(0,2,duration,EaseType.SineEaseIn,function(value)
				self.playerAvatar.TransformComponent.Position.x = originX+value
			end)
			_TweenLogic:PlayTween(0,0.5,duration/2,EaseType.Linear,function(value)
				self.playerAvatar.TransformComponent.Position.y = originY+value
			end)
		
			local playerDown = function()
				if self._T.introEnd then return end
				_TweenLogic:PlayTween(0.5,0,duration/2,EaseType.Linear,function(value)
					self.playerAvatar.TransformComponent.Position.y = originY+value
				end)
			end
			_TimerService:SetTimerOnce(playerDown,duration/2)
		
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene07")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene  == "scene07" then
			local duration = 2
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Hit,duration)
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("prone","prone"))
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("scene08")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene == "scene08" then
			local duration = 3
			self.playerAvatar.ChatBalloonComponent.Enable = true
			self.playerAvatar.ChatBalloonComponent.Message = "..."
			self.playerAvatar.AvatarRendererComponent:PlayEmotion(EmotionalType.Bewildered,duration)
			_SoundService:PlaySound("86ba8172e390469cb3e0b4c450886f4a",_SoundLogic.effectRatio)
			self.playerAvatar.AvatarRendererComponent:GetBodyEntity():SendEvent(ActionStateChangedEvent("stand1","stand1"))
			local nextScene = function()
				if self._T.introEnd then return end
				self:PlayScene("end")
			end
			self._T.timer = _TimerService:SetTimerOnce(nextScene,duration)
			
		elseif scene == "end" then
			_UIDialog.dialog.Enable = false
			for _, child in pairs(_UIDialog.dialog.Children) do
				child.Enable = true
			end
			
			_BattleUIManager.loadingUI:Show()	
			_SoundService:StopBGM(false)
			
			_CameraService:SwitchCameraTo(_UserService.LocalPlayer.CameraComponent)
			self._T.introEnd = true
			if isvalid(self._T.timer) then _TimerService:ClearTimer(self._T.timer) end
		
			_BattleUIManager.loadingUI:Hide(4,function()
				_UserService.LocalPlayer.CurrentMap.SoundComponent:Play()
				_DialogDataLogic:StartScene("main_0","",function() 
					for _, uiGroup in pairs(self._T.uiGroups) do
						uiGroup.Enable = true
					end
					_UserService.LocalPlayer.PlayerInfoComponent:SetIntroPlayedDataTrue()
					_TutorialLogic:StartTutorial("first_tutorial",function()
						_UserService.LocalPlayer.PlayerControllerComponent.Enable = true
					end)
				end)
			end)
			
		end
	end

	method void SkipIntro()
		-- 인트로 스토리 스킵 기능
		if self._T.introStarted ~= true then return end
		
		self:PlayScene("end")
	end

end