@Component
script StageMovePortalComponent extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 스테이지 이동 포털과 상호작용 시 스테이지 이동 팝업 표시
		
		local InteractionEntity = event.InteractionEntity
		if InteractionEntity ~= _UserService.LocalPlayer then return end
		
		_UIGroupManager.uiStageMovePopup:ShowByButtonClick()
	end

end