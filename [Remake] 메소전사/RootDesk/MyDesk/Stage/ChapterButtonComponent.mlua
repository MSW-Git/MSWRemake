@Component
script ChapterButtonComponent extends Component

	@HideFromInspector
	property string chapterId = ""

	property string pressedSprite = ""

	@HideFromInspector
	property Entity rewardButton = nil

	@HideFromInspector
	property Entity clearText = nil

	property boolean firstInit = false

	property boolean fieldAvailable = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 챕터 버튼 초기화 및 보상 버튼 이벤트 연결
		local clearIcon = self.Entity:GetChildByName("Icon_Clear")
		clearIcon.Enable = false
		
		self.rewardButton = self.Entity:GetChildByName("ChapterClearRewardButton", true)
		
		self.rewardButton:ConnectEvent(ButtonClickEvent, function()
				if _UIGroupManager:IsEnableOpenPopup() == false then
					return
				end
		
			
				self.rewardButton.UITweenScale.Enable = false
				self.rewardButton.UITransformComponent.RectSize = Vector2(80, 80)
			
				local rewardRenderer = self.rewardButton.SpriteGUIRendererComponent
				rewardRenderer.AnimClipPlayType = SpriteAnimClipPlayType.Onetime
				rewardRenderer.PreserveSprite = PreserveSpriteType.AspectOnly
				rewardRenderer.ImageRUID = self.pressedSprite
				rewardRenderer.LocalScale = Vector2(1.2, 1.2)
				rewardRenderer.LocalPosition = Vector2(-10, -28)
			
				self.rewardButton:GetChildByName("UISprite").Enable = false
				_TimerService:SetTimerOnce(function()
						self.rewardButton.Enable = false
						_RewardLogic:RequestGetChapterReward(tonumber(self.chapterId))
					end, 1)
			end)
	end

	@ExecSpace("ClientOnly")
	method void Init(number field)
		-- 챕터 버튼 상태 초기화 (필드 모드에 따라)
		if field == 0 then
			local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
			local chapterNum = tonumber(self.chapterId)
			
			local clearIcon = self.Entity:GetChildByName("Icon_Clear")
			local clearReward = self.rewardButton
			
			self.rewardButton.Enable = true
			clearReward.Enable = true
			
			if isvalid(playerInfo.chapterRewardData[chapterNum]) and playerInfo.chapterRewardData[chapterNum].rewarded then
				clearReward.Enable = false
			end
			
			if (playerInfo.playerInfo.stageStep) / 10 < tonumber(chapterNum) then
				clearIcon.Enable = false
			else
				clearIcon.Enable = true
			end
		else
			local clearIcon = self.Entity:GetChildByName("Icon_Clear")
			clearIcon.Enable = false
			self.rewardButton.Enable = false
		end
		
		if self.firstInit == true then
			self:RefreshLockButton(field)
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshLockButton(number field)
		-- 챕터 잠금 버튼 상태 새로고침
		local pricePanel = self.Entity:GetChildByName("panel_price")
		local priceText = pricePanel:GetChildByName("price")
		local freeText = pricePanel:GetChildByName("text_free")
		local mesoIcon = pricePanel:GetChildByName("icon_price")
		local currentPos = self.Entity:GetChildByName("icon_pin")
		local chapterTitle = self.Entity:GetChildByName("ChapterTitle")
		local lockComponent = self.Entity.ContentLockComponent
		
		if field == 0 then
			local questId = _UserService.LocalPlayer.PlayerQuestComponent.currentQuestId
			if isvalid(_QuestLogic.questData[questId]) and tonumber(_QuestLogic.contentOpenData["chapter"..self.chapterId].unlockQuestId) < tonumber(questId) then
				lockComponent:Open()
			end
			currentPos.Enable = false
			pricePanel.Enable = false
			chapterTitle.SpriteGUIRendererComponent.ImageRUID = "6b99a36e97c94303a2d7dd75c3453096"
		else
			local fieldMapComponent = _UserService.LocalPlayer.PlayerFieldMapComponent
			local currentMapNum = 0
			for i=1,#fieldMapComponent.fieldMapData do
				if fieldMapComponent.fieldMapData[i][0] == 2 then
					currentMapNum = i
					break
				end
			end
			if fieldMapComponent.fieldMapData[1][0] == 0 then
				if self.chapterId == "1" then
					pricePanel.Enable = true
					priceText.Enable = false
					freeText.Enable = true
					mesoIcon.Enable = false
					currentPos.Enable = true
					self.fieldAvailable = true
				else
					lockComponent:Close()
					currentPos.Enable = false
					pricePanel.Enable = false
					self.fieldAvailable = false
				end
			else
				if fieldMapComponent.fieldMapData[tonumber(self.chapterId)][0] == 0 then
					lockComponent:Close()
					currentPos.Enable = false
					pricePanel.Enable = false
					self.fieldAvailable = false
				elseif fieldMapComponent.fieldMapData[tonumber(self.chapterId)][0] == 1 then
					lockComponent:Open()
					local engMapName = _MultiMapDataLogic:GetMapNameByNum(tonumber(self.chapterId))
					local price = fieldMapComponent:GetPrice(currentMapNum,tonumber(self.chapterId))
					pricePanel.Enable = true
					priceText.Enable = true
					freeText.Enable = false
					mesoIcon.Enable = true
					priceText.TextComponent.Text = tostring(_NumberSeparator:ConvertToMetricPrefixString(price, "ko"))
					if _UserService.LocalPlayer.PlayerCurrencyData.currencyTable["Gold"].amount < price then
						priceText.TextComponent.FontColor = Color.FromHexCode("#FF6868")
					else
						priceText.TextComponent.FontColor = Color.FromHexCode("#FFFFFF")
					end
					currentPos.Enable = false
					self.fieldAvailable = true
				elseif fieldMapComponent.fieldMapData[tonumber(self.chapterId)][0] == 2 then
					lockComponent:Open()
					pricePanel.Enable = true
					if field == 1 then
						freeText.Enable = true
						priceText.Enable = false
						mesoIcon.Enable = false
					else
						freeText.Enable = false
						priceText.Enable = true
						mesoIcon.Enable = true
						local price = fieldMapComponent:GetPrice(currentMapNum,tonumber(self.chapterId))
						priceText.TextComponent.Text = tostring(_NumberSeparator:ConvertToMetricPrefixString(price, "ko"))
						if _UserService.LocalPlayer.PlayerCurrencyData.currencyTable["Gold"].amount < price then
							priceText.TextComponent.FontColor = Color.FromHexCode("#FF6868")
						else
							priceText.TextComponent.FontColor = Color.FromHexCode("#FFFFFF")
						end
					end
					currentPos.Enable = true
					self.fieldAvailable = true
				end
			end
			chapterTitle.SpriteGUIRendererComponent.ImageRUID = "3b53a148d5b7475a8b7b19a6b5adf0fd"
		end
	end

end