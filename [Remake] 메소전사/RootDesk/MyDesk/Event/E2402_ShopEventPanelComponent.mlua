@Component
script E2402_ShopEventPanelComponent extends Component

	property Entity originalSlot = "e67c853b-5db8-4f13-8d0c-ed756e4de262"

	property Entity buttonLayout = "ca513e69-1b4c-400f-85ec-dc575ef09f7c"

	property Entity reamainTime = "a5f83662-cb24-4b3f-a4a5-2889be5b76ad"

	property Entity recommendStageText = "afdf8d7f-292f-45c7-ba76-1743172228d2"

	property Entity bokjoriCountText = "0a8a801f-838a-4057-a72e-59afedb6a4fe"

	property number requestedTime = 0

	property boolean isInitted = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 2024년 2월 샵 이벤트 패널 초기화 및 보상 버튼 생성 (현재 비활성화)
		--[[
		if true then return end
		self.originalSlot.Enable = false
		
		for i = 1, 3 do
			local str = string.format("ClearRewardButton_%d", i)
			local entity = self.originalSlot:Clone(str)
		end]]--
	end

	@ExecSpace("ClientOnly")
	method void Show()
		-- 이벤트 패널 표시 시 클리어 정보 새로고침 및 추천 스테이지 설정 (현재 비활성화)
		if true then return end
		--[[
		_UserService.LocalPlayer.PlayerInfoComponent:RefreshClearInfo()\
		
		self:SetRecommendStage()
		self:RefreshBokjoriCount()]]--
	end

	@ExecSpace("ClientOnly")
	method void SetRecommendStage()
		-- 플레이어 진행 단계에 따른 추천 스테이지 텍스트 설정 (현재 비활성화)
		if true then return end
		--[[
		local minStage = _UserService.LocalPlayer.PlayerInfoComponent.minRecommendStage
		local playerStep = _UserService.LocalPlayer.PlayerInfoComponent.playerInfo.stageStep
		local beginStr = ""
		local endStr = ""
		local count = 1
		local isFirstEntreanceUser = false
		
		if playerStep == 0 then
			playerStep = 1
			isFirstEntreanceUser = true
		end
		
		local getStr = function(stageStep)
			local chapter = math.floor(stageStep / 10)
			local stage = stageStep % 10
			
			if stageStep ~= 0 and stage == 0 then
				stage = 10
			end
			
			local chapterStr = ""
			
			if stageStep < 80 and stage < 10 then
				chapter += 1
			end
			
			if chapter == 1 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup5")
			elseif chapter == 2 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup6")
			elseif chapter == 3 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup7")
			elseif chapter == 4 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup8")
			elseif chapter == 5 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup9")
			elseif chapter == 6 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup10")
			elseif chapter == 7 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup11")
			elseif chapter == 8 then
				chapterStr = _LocalizeLogic:GetText("confirmPopup12")
			end
			
			return string.format("[%s] %d - %d", chapterStr, chapter, stage)
		end
		
		beginStr = getStr(minStage)
		
		if isFirstEntreanceUser then
			self.recommendStageText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr57"), beginStr)
		else
			if playerStep >= 80 then
				endStr = getStr(80)
			else
				endStr = getStr(playerStep + 1)
			end
			
			self.recommendStageText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr56"), beginStr, endStr)
		end]]--
		
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshBokjoriCount()
		-- 복조리 아이템 보유 개수 표시 새로고침 (현재 비활성화)
		if true then return end
		--[[
		self.bokjoriCountText.TextComponent.Text = string.format("%d", _UserService.LocalPlayer.PlayerStorageComponent:GetItemCount("9_000016"))]]--
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 전체 이벤트 패널 UI 새로고침 (보상 버튼 및 클리어 수 표시, 현재 비활성화)
		if true then return end
		--[[for i = 1, 3 do
			local entity = self.buttonLayout:GetChildByName(string.format("ClearRewardButton_%d", i))
			entity.RecommendClearButtonComponent:Refresh()
		end
		
		self.Entity:GetChildByName("ClearCountText").TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr58"), _UserService.LocalPlayer.PlayerInfoComponent.playerInfo.clearCount)
		self:RefreshBokjoriCount()]]--
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 이벤트 패널 초기화 및 보상 버튼 데이터 연결 (현재 비활성화)
		if true then return end
		--[[
		if self.isInitted then return end
		
		for i = 1, 3 do
			local entity = self.buttonLayout:GetChildByName(string.format("ClearRewardButton_%d", i))
			local data = _RecommendStageLogic.clearAndReward[tostring(i)]
			
			entity.RecommendClearButtonComponent:SetSlot(tostring(i), data)
			
			entity.Enable = true
		end
		
		self.isInitted = true]]--
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "bd95e45c-f7da-4dbd-84de-9eb2f226019d")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 샵 열기 버튼 클릭 시 샵 UI 표시 (현재 비활성화)
		
		local Entity = event.Entity
		if true then return end
		
		--_ShopLogic.shopUI:Init("1")
		--_ShopLogic.shopUI:Show()
	end

end