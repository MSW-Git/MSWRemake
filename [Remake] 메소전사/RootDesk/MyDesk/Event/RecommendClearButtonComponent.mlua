@Component
script RecommendClearButtonComponent extends Component

	property E2402_ShopEventPanelComponent shopPanel = "8c03972b-050d-4ae9-9d8d-75dd97a3b3c7"

	property string id = ""

	property table connectedData = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 추천 클리어 버튼 컴포넌트 초기화 (현재 비어있음)
		
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string id, table data)
		-- 버튼에 연결된 데이터 설정 및 클릭 이벤트 연결
		if self.id == "" then
			self.id = id
			self.connectedData = data
			
			self.Entity:ConnectEvent(ButtonClickEvent, function() self:RequestGetBokjori() end)
			
			self:Refresh()
		end
	end

	@ExecSpace("ClientOnly")
	method void RequestGetBokjori()
		-- 복조리 보상 요청 (클리어 수 및 중복 수령 검증 포함, 현재 비활성화)
		if true then return end
		--[[
		if self.shopPanel.requestedTime + 1 > _UtilLogic.ServerElapsedSeconds then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
			
			return
		end
		self.shopPanel.requestedTime = _UtilLogic.ServerElapsedSeconds
		
		local clearCount = _UserService.LocalPlayer.PlayerInfoComponent.playerInfo.clearCount
		
		if self.connectedData.clearCount > clearCount then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast117"))
			
			return
		end
		
		if _UserService.LocalPlayer.PlayerNewYearEventComponent.eventInfo[string.format("rewarded%d", self.id)] then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast116"))
			
			return
		end
		
		_EventLogic:RequestGetBokjori(self.id)]]--
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 버튼 UI 상태 새로고침 (보상 수령 가능 여부에 따른 시각적 변경, 현재 비활성화)
		if true then return end--[[
		if not isvalid(self.connectedData) or not isvalid(self.connectedData.clearCount) then return end
		
		local titleText = self.Entity:GetChildByName("title")
		local itemText = self.Entity:GetChildByName("item")
		local clickIcon = self.Entity:GetChildByName("icon_click")
		local cover = self.Entity:GetChildByName("cover_dark")
		local clearStr = string.format(_LocalizeLogic:GetText("etcStr61"), self.connectedData.clearCount)
		
		
		titleText.TextComponent.Text = clearStr
		local itemName = _LocalizeLogic:GetItemName(_ItemDataLogic.itemData[self.connectedData.rewardId].name)
		local str = _LocalizationService:GetTextFormat("confirmPopup24", itemName, tostring(self.connectedData.rewardNum))
		itemText.TextComponent.Text = str
		
		self.Entity.SpriteGUIRendererComponent.ImageRUID = "2c3c6c1336844271aa84080b2317d824"
		self.Entity.SpriteGUIRendererComponent:ChangeMaterial("")
		titleText.SpriteGUIRendererComponent:ChangeMaterial("")
		titleText.TextComponent.Enable = true
		titleText.SpriteGUIRendererComponent.Enable = false
		clickIcon.Enable = false
		cover.Enable = false
		
		if _EventLogic:IsCanGetBokjori(self.id, _UserService.LocalPlayer.PlayerComponent.UserId) then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "010d93509b51407fb90dc318b73972f3"
			self.Entity.SpriteGUIRendererComponent:ChangeMaterial("material://3287b600-bc16-4239-89e5-0fce58638ac5")
			titleText.TextComponent.Text = _LocalizeLogic:GetText("etcStr62")
			clickIcon.Enable = true
		else
			if _UserService.LocalPlayer.PlayerNewYearEventComponent.eventInfo[string.format("rewarded%d", self.id)] then
				titleText.TextComponent.Text = ""
				titleText.SpriteGUIRendererComponent.Enable = true
				cover.Enable = true
			end
		end]]--
	end

end