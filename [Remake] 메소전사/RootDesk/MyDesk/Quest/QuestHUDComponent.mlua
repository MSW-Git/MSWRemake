@Component
script QuestHUDComponent extends Component

	property Entity hudButton = "a0570e4d-5ee8-40d6-97f6-ff741b238b4a"

	property boolean allQuestCompleted = false

	property boolean needToUpdate = false

	property Entity badgeClear = "0bc8b915-f303-4844-bdcb-f21cc8815237"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 퀘스트 HUD 버튼 초기화 및 이벤트 연결
		self.hudButton:ConnectEvent(ButtonClickEvent, function()
			
			_TimerService:SetTimerOnce(function() _QuestUILogic.questUI:SetEnable(true) end, self.hudButton.UIButtonTweenScale.tweenDuration * 2)
			end)
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 퀘스트 HUD 상태 갱신
		local playerQuest = _UserService.LocalPlayer.PlayerQuestComponent
		
		if isvalid(_QuestLogic.questData[playerQuest.currentQuestId]) then
			self.needToUpdate = true
		end
	end

	@ExecSpace("Client")
	method void OffUI()
		-- 퀘스트 HUD UI 비활성화
		self.Entity.Enable = false
		self.allQuestCompleted = true
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 퀘스트 HUD 정보 업데이트 및 표시 처리
		if self.needToUpdate then
			self.needToUpdate = false
			local playerQuest = _UserService.LocalPlayer.PlayerQuestComponent
			local questData = _QuestLogic.questData[playerQuest.currentQuestId]
			
			if not isvalid(questData) or playerQuest.allQuestCompleted then
				self.Entity.Enable = false
		
				self.allQuestCompleted = true
				return
			end
			
			local title = self.Entity:GetChildByName("Title")
			local summary = self.Entity:GetChildByName("Summary")
			
			title.TextComponent.Text = "#"..questData.id.." ".._LocalizationService:GetText("quest_"..questData.id.."_name")
			if questData.id == "24" then
				title.TextComponent.Text = "#"..questData.id.." ".._LocalizationService:GetText("ui_open_limitLand")
			end
			
			local questType = questData.questType
			
			if questType == "guide" then
				local str = string.format(_LocalizeLogic:GetText("etcStr136"), _LocalizationService:GetText("quest_"..questData.id.."_description"))
				summary.TextComponent.Text = str
				summary.AutoTextFlow:Refresh()
				
			elseif questType == "objective" then
				local objectiveTypes = _UtilLogic:Split(questData.objectiveType, "/")
				local objectiveIds = _UtilLogic:Split(questData.objectiveId, "/")
				local objectiveNums = _UtilLogic:Split(questData.objectiveNum, "/")
				local summaryStr = ""
				playerQuest:RefreshObjectiveCount(playerQuest.currentQuestId)
				
				local notAllClear = false
				
				for i = 1, #objectiveTypes do
					local objectiveType = objectiveTypes[i]
					local objectiveId = objectiveIds[i]
					local objectiveNum = tonumber(objectiveNums[i])
					local objectiveCount = _QuestLogic:GetObjectiveCount(playerQuest.currentQuestId, objectiveId)
					
					if isvalid(objectiveCount) then
						if objectiveCount < objectiveNum then
							notAllClear = true				
						end
						
						local tempStr = ""
						if objectiveType == "stageClear" then
							local chapterNum = _StageLogic.stageData[objectiveId].chapter
							local chapterName = _LocalizeLogic:GetChapterName(tostring(chapterNum)) 
							local stageNum = _StageLogic.stageData[objectiveId].stage
							
							tempStr = string.format(_LocalizeLogic:GetText("etcStr125"), chapterName, chapterNum, stageNum, objectiveCount, objectiveNum)
						elseif objectiveType == "killMonster" then
							local monsterName = _LocalizeLogic:GetMonsterName(objectiveId)
							tempStr = string.format(_LocalizeLogic:GetText("etcStr126"), monsterName, objectiveCount, objectiveNum)
						elseif objectiveType == "killBoss" then
							local monsterName = _LocalizeLogic:GetMonsterName(objectiveId) 
							tempStr = string.format(_LocalizeLogic:GetText("etcStr127"), monsterName, objectiveCount, objectiveNum)
						elseif objectiveType == "reachBattlePower" then
							local battlePower = _BattlePowerLogic:CalcBattlePower(_UserService.LocalPlayer)
							tempStr = string.format(_LocalizeLogic:GetText("etcStr128"), objectiveNum, battlePower, objectiveNum)
						elseif objectiveType == "getItem" then
							local itemData = _ItemDataLogic.itemData[objectiveId]
							local itemName = ""
							if isvalid(itemData) then
								itemName = _LocalizeLogic:GetItemName(objectiveId)
							else
								itemName = _LocalizationService:GetText(string.sub(_ItemDataLogic.equipmentData[objectiveId].name,1,-3)).." (".._LocalizationService:GetText(_ItemDataLogic.equipmentData[objectiveId].grade)..")"
							end
							tempStr = string.format(_LocalizeLogic:GetText("etcStr129"), itemName, objectiveCount, objectiveNum)
						elseif objectiveType == "npc" then
							local npcName = _LocalizeLogic:GetNPCName(objectiveId)
							if objectiveCount >= objectiveNum then
								tempStr = string.format(_LocalizeLogic:GetText("etcStr130"), npcName)
							else
								tempStr = string.format(_LocalizeLogic:GetText("etcStr131"), npcName)
							end
						elseif objectiveType == "openUI" then
							local uiName = _LocalizationService:GetText(_QuestLogic.contentOpenData[questData.objectiveId].localizationKey)
							if objectiveCount >= objectiveNum then
								tempStr = string.format(_LocalizeLogic:GetText("etcStr132"), uiName)			
							else
								tempStr = string.format(_LocalizeLogic:GetText("etcStr133"), uiName)			
							end
						elseif objectiveType == "randomBossClear" then
							tempStr = string.format(_LocalizeLogic:GetText("etcStr134"), objectiveCount, objectiveNum)
						elseif objectiveType == "equipWeapon" then
							local weaponName = _LocalizationService:GetText(objectiveId)
							tempStr = string.format(_LocalizeLogic:GetText("etcStr135"), weaponName, objectiveCount,objectiveNum)
						end
						
						if notAllClear then
							summaryStr = tempStr
							if #objectiveTypes > 1 then
									summaryStr = _LocalizationService:GetTextFormat("etcStr214", summaryStr, tostring(math.floor(#objectiveTypes - 1)))	
								
							end
							break
						elseif i == 1 then
							summaryStr = tempStr
						end
					end
				end
				
				if notAllClear then
					self.hudButton.SpriteGUIRendererComponent.Color = Color.FromHexCode("#1D1D1D")
					self.hudButton.SpriteGUIRendererComponent.Color.a = 0.85
					self.hudButton.Parent.UITweenPosition.Enable = false
					self.badgeClear.Enable = false
				else
					self.hudButton.SpriteGUIRendererComponent.Color = Color.FromHexCode("#0E3EAA")
					self.hudButton.SpriteGUIRendererComponent.Color.a = 0.85
					self.hudButton.Parent.UITweenPosition.Enable = true
					self.badgeClear.Enable = true
				end
				
				summary.TextComponent.Text = summaryStr
				summary.AutoTextFlow:Refresh()
				
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEntityMapChangedEvent(EntityMapChangedEvent event)
		-- 맵 변경 시 퀘스트 HUD 표시 상태 조절
		
		local NewMap = event.NewMap
		local OldMap = event.OldMap
		local Entity = event.Entity
		if NewMap.Name == "Town" then
			if not self.allQuestCompleted then
				self.Entity.Enable = true
			end
		else
			self.Entity.Enable = false
		end
	end

end