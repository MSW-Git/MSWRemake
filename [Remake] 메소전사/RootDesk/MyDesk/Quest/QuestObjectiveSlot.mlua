@Component
script QuestObjectiveSlot extends Component

	property Entity objectiveText = nil

	property Entity objectiveIcon = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 퀘스트 목표 슬롯 UI 요소 초기화
		self.objectiveText = self.Entity:GetChildByName("ObjectiveText")
		self.objectiveIcon = self.Entity:GetChildByName("ObjectiveIcon")
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string objectiveType, integer objectiveNum, string objectiveId, string stageInfo)
		-- 퀘스트 목표 슬롯 설정 및 표시 텍스트 업데이트
		local textComponent = self.objectiveText.TextComponent
		local objectiveCount = _QuestLogic:GetObjectiveCount(_QuestUILogic.questUI.selectedQuestId, objectiveId)
		
		if objectiveType == "stageClear" then
			local chapterNum = _StageLogic.stageData[objectiveId].chapter
			local chapterName = _LocalizeLogic:GetChapterName(tostring(chapterNum)) 
			local stageNum = _StageLogic.stageData[objectiveId].stage
			
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr125"), chapterName, chapterNum, stageNum, objectiveCount, objectiveNum)
		elseif objectiveType == "killMonster" then
			local monsterName = _LocalizeLogic:GetMonsterName(objectiveId)
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr138"), monsterName, objectiveCount, objectiveNum)
			local stages = _UtilLogic:Split(stageInfo,"_")
			for i, stage in pairs(stages) do
				textComponent.Text ..= _StageLogic.stageData[stage].chapter .. "-" .. _StageLogic.stageData[stage].stage
				if i ~= #stages then
					textComponent.Text ..= ", "
				end
			end
			textComponent.Text ..= "></color>"
		elseif objectiveType == "killBoss" then
			local monsterName = _LocalizeLogic:GetMonsterName(objectiveId)
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr139"), monsterName, objectiveCount, objectiveNum)
			local stages = _UtilLogic:Split(stageInfo,"_")
			for i, stage in pairs(stages) do
				textComponent.Text ..= _StageLogic.stageData[stage].chapter .. "-" .. _StageLogic.stageData[stage].stage
				if i ~= #stages then
					textComponent.Text ..= ", "
				end
			end
			textComponent.Text ..= "></color>"
		elseif objectiveType == "reachBattlePower" then
			local battlePower = _BattlePowerLogic:CalcBattlePower(_UserService.LocalPlayer)
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr128"), objectiveNum, battlePower, objectiveNum)
		elseif objectiveType == "getItem" then
			local itemData = _ItemDataLogic.itemData[objectiveId]
			local itemName = ""
			if isvalid(itemData) then
				itemName = _LocalizeLogic:GetItemName(objectiveId)
			else
				itemName = _LocalizationService:GetText(string.sub(_ItemDataLogic.equipmentData[objectiveId].name,1,-3)).." (".._LocalizationService:GetText(_ItemDataLogic.equipmentData[objectiveId].grade)..")"
			end
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr129"), itemName, objectiveCount, objectiveNum)
		elseif objectiveType == "guide" then
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr140"))
		elseif objectiveType == "npc" then
			local npcName = _LocalizeLogic:GetNPCName(objectiveId)
			if objectiveCount >= objectiveNum then
				textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr130"), npcName)
			else
				textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr131"), npcName)
			end
		elseif objectiveType == "openUI" then
			local uiName = _LocalizationService:GetText(_QuestLogic.contentOpenData[objectiveId].localizationKey)
			if objectiveCount >= objectiveNum then
				textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr132"), uiName)
			else
				textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr133"), uiName)
			end
		elseif objectiveType == "randomBossClear" then
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr134"), objectiveCount, objectiveNum)
		elseif objectiveType == "equipWeapon" then
			local weaponName = _LocalizationService:GetText(objectiveId)
			textComponent.Text = string.format(_LocalizeLogic:GetText("etcStr135"), weaponName, objectiveCount,objectiveNum)
		end
		
		if objectiveCount >= objectiveNum or _QuestUILogic.questUI.currentCategory == "COMPLETE" then
			textComponent.Text = string.format("<color=silver>%s</color>", textComponent.Text)
			self.objectiveIcon.SpriteGUIRendererComponent:ChangeMaterial("")
		else
			textComponent.Text = string.format("<color=white>%s</color>", textComponent.Text)
			self.objectiveIcon.SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4")
		end
	end

end