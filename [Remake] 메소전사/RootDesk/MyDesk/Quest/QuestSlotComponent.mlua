@Component
script QuestSlotComponent extends Component

	property Entity questTitle = nil

	property Entity questInfo = nil

	@HideFromInspector
	property string questId = ""

	property QuestUIComponent questUI = "b1d82416-19d2-42c7-8477-6418930bdd3d"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 퀘스트 슬롯 UI 요소 초기화
		self.questTitle = self.Entity:GetChildByName("QuestTitle")
		self.questInfo = self.Entity:GetChildByName("QuestInfo")
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string questId)
		-- 퀘스트 슬롯 데이터 설정 및 표시
		if not isvalid(_QuestLogic.questData[questId]) then return end
		
		self.questId = questId
		self.questTitle.TextComponent.Text = "#".._QuestLogic.questData[self.questId].id.." ".._LocalizationService:GetText("quest_"..self.questId.."_name")
		
		if questId == "24" then 
			self.questTitle.TextComponent.Text = "#"..questId.." ".._LocalizationService:GetText("ui_open_limitLand")
		end
		
		self.questInfo.TextComponent.Text = _LocalizationService:GetText("quest_"..self.questId.."_subinfo")
		
		if _QuestUILogic.questUI.currentCategory == "PROGRESS" and _QuestLogic.questData[self.questId].category == "main" then
			self.Entity:SendEvent(ButtonClickEvent(self.Entity))
		end
	end

	@ExecSpace("ClientOnly")
	method void SetEnable(boolean onOff)
		-- 퀘스트 슬롯 활성화 상태 설정
		self.Entity.Enable = onOff
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 퀘스트 슬롯 클릭 시 상세 내용 표시
		
		local Entity = event.Entity
		self.questUI.selectedQuestId = self.questId
		self.questUI.emptyPanel.Enable = false
		self.questUI.questContentPanel.Enable = true
		self.questUI:RefreshContentPanel()
	end

end