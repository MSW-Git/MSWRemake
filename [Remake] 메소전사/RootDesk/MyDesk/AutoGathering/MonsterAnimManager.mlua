@Component
script MonsterAnimManager extends Component

	property string idle = ""

	property string hit = ""

	@ExecSpace("Client")
	method void Hit()
		-- 몬스터가 공격받았을 때 히트 애니메이션 재생
		local renderer = self.Entity.SpriteGUIRendererComponent
		
		
		renderer.ImageRUID.DataId = self.hit
		
		renderer.AnimClipPlayType = SpriteAnimClipPlayType.Onetime
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 기본 애니메이션 설정
		local renderer = self.Entity.SpriteGUIRendererComponent
		self.idle = renderer.ImageRUID.DataId
		renderer.AnimClipPlayType = SpriteAnimClipPlayType.Loop
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 히트 애니메이션이 끝나면 기본 애니메이션으로 복귀
		if self.Entity.SpriteGUIRendererComponent.ImageRUID.DataId == self.hit then
			self.Entity.SpriteGUIRendererComponent.ImageRUID.DataId = self.idle
			self.Entity.SpriteGUIRendererComponent.AnimClipPlayType = SpriteAnimClipPlayType.Loop
		end
	end

end