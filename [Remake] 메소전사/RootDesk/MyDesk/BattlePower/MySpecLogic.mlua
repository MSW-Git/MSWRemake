@Logic
script MySpecLogic extends Logic

	@HideFromInspector
	property table mySpec = {}

	property table weaponStatus = {}

	property table armorStatus = {}

	property table characterStatus = {}

	property table petStatus = {}

	property table characterRelationStatus = {}

	property table codexStatus = {}

	property number lastRefreshedTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 로직 초기화 (현재 빈 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshSpec()
		-- 플레이어의 모든 스탯을 계산하여 갱신하고 UI에 반영
		local playerEntity = _UserService.LocalPlayer
		local playerInfo = playerEntity.PlayerInfoComponent
		local statusTable = _UserService.LocalPlayer.PlayerCharacterData.statusTable
		local previousBattlePower = math.maxinteger
		
		
		if isvalid(self.mySpec["battlePower"]) then
			previousBattlePower = self.mySpec["battlePower"]
		end
		
		self.mySpec["battlePower"] = _BattlePowerLogic:CalcBattlePower(_UserService.LocalPlayer)
		
		self.mySpec["maxHp"] = self:GetMaxHp(playerEntity)
		self.mySpec["attack"] = self:GetAttack(playerEntity)
		self.mySpec["attackIncreaseRate"] = self:GetAttackIncreaseRate(playerEntity)
		self.mySpec["hpRecovery"] = self:GetHpRecovery(playerEntity)
		self.mySpec["absorption"] = self:GetAbsorption(playerEntity)
		self.mySpec["totalDamage"] = self:GetTotalDamage(playerEntity)
		self.mySpec["physicalDamage"] = self:GetPhysicalDamage(playerEntity)
		self.mySpec["magicalDamage"] = self:GetMagicalDamage(playerEntity)
		self.mySpec["attackSpeed"] = self:GetAttackSpeed(playerEntity)
		self.mySpec["criticalPercent"] = self:GetCriticalPercent(playerEntity)
		self.mySpec["criticalDamage"] = self:GetCriticalDamage(playerEntity)
		self.mySpec["bossDamage"] = self:GetBossDamage(playerEntity)
		self.mySpec["hitDamage"] = self:GetHitDamage(playerEntity)
		self.mySpec["range"] = self:GetRange(playerEntity)
		self.mySpec["evade"] = self:GetEvade(playerEntity)
		self.mySpec["speed"] = self:GetSpeed(playerEntity)
		self.mySpec["expRatio"] = self:GetExpRatio(playerEntity)
		self.mySpec["extraEggDropRate"] = self:GetExtraEggDropRate(playerEntity)
		self.mySpec["extraDashStamina"] = self:GetExtraDashStamina(playerEntity)
		self.mySpec["stageClearRewardBonusRate"] = self:GetStageClearRewardBonusRate(playerEntity)
		self.mySpec["knockbackRatio"] = self:GetKnockbackRatio(playerEntity)
		self.mySpec["reductMeleeDamage"] = self:GetReductMeleeDamage(playerEntity)
		self.mySpec["reductProjectileDamage"] = self:GetReductProjectileDamage(playerEntity)
		
		local playerQuest = playerEntity.PlayerQuestComponent
		playerInfo:SetBestBattlePower()
		playerQuest:SetObjectiveCount("reachBattlePower", "battlePower", self.mySpec.battlePower, playerQuest.currentQuestId, "play") 
		
		self:SendEvent(RefreshMySpecEvent(self.mySpec.battlePower, previousBattlePower))
	end

	method number GetMaxHp(Entity player)
		-- 플레이어의 최대 체력 계산
		local status = player.PlayerCharacterData.statusTable["maxHp"]
		local originValue = 0
		return originValue + status
	end

	method number GetAttack(Entity player)
		-- 장착된 무기들의 총 공격력 계산
		local attack = 0
		local storage = player.PlayerStorageComponent
		local character = player.PlayerCharacterData
		local armorStatus = player.PlayerStorageComponent.armorStatusTable
		
		
		
		for key, value in pairs(storage.storage) do 
			if value.equippedSlotNum > 0 then
				local id = value.originalId
				if isvalid(_ItemDataLogic.equipmentData[id]) then
					local category = _ItemDataLogic.equipmentData[id].category
					
					if _UtilLogic:Contains(category, "weapon") then
							attack = attack + _CalcLogic:GetWeaponAttackDamageByKey(key, player)
					end
				end
			end
		end
		
		
		
		return attack
	end

	method number GetHpRecovery(Entity player)
		-- 플레이어의 체력 회복량 계산
		local status = player.PlayerCharacterData.statusTable["hpRecovery"]
		local originValue = 0
		return originValue + status
	end

	method number GetAbsorption(Entity player)
		-- 플레이어의 흡수량 계산 (현재 미구현)
		return 0
	end

	method number GetTotalDamage(Entity player)
		-- 플레이어의 총 데미지 증가율 계산
		local status = player.PlayerCharacterData.statusTable["totalDamage"]
		local originValue = 0
		return originValue + status
	end

	method number GetPhysicalDamage(Entity player)
		-- 플레이어의 물리 데미지 증가율 계산
		local status = player.PlayerCharacterData.statusTable["physicalDamage"]
		local originValue = 0
		return originValue + status
	end

	method number GetMagicalDamage(Entity player)
		-- 플레이어의 마법 데미지 증가율 계산
		local status = player.PlayerCharacterData.statusTable["magicalDamage"]
		local originValue = 0
		return originValue + status
	end

	method number GetAttackSpeed(Entity player)
		-- 플레이어의 공격 속도 계산
		local status = player.PlayerCharacterData.statusTable["attackSpeed"]
		local originValue = 1
		return originValue + status
	end

	method number GetCriticalPercent(Entity player)
		-- 플레이어의 치명타 확률 계산
		local status = player.PlayerCharacterData.statusTable["criticalPercent"]
		local originValue = 0
		return originValue + status
	end

	method number GetCriticalDamage(Entity player)
		-- 플레이어의 치명타 데미지 계산
		local status = player.PlayerCharacterData.statusTable["criticalDamage"]
		local originValue = 0
		return originValue + status
	end

	method number GetBossDamage(Entity player)
		-- 플레이어의 보스 데미지 증가율 계산
		local status = player.PlayerCharacterData.statusTable["bossDamage"]
		local originValue = 0
		return originValue + status
	end

	method number GetHitDamage(Entity player)
		-- 플레이어의 피격 데미지 감소율 계산
		local status = player.PlayerCharacterData.statusTable["hitDamage"]
		local originValue = 0
		
		return originValue - status
	end

	method number GetRange(Entity player)
		-- 플레이어의 공격 범위 증가율 계산
		local status = player.PlayerCharacterData.statusTable["range"]
		local originValue = 0
		return originValue + status
	end

	method number GetEvade(Entity player)
		-- 플레이어의 회피율 계산
		local status = player.PlayerCharacterData.statusTable["evade"]
		local originValue = 0
		return originValue + status
	end

	method number GetSpeed(Entity player)
		-- 플레이어의 이동 속도 계산
		local status = player.PlayerCharacterData.statusTable["speed"]
		
		return (1 + status)
	end

	method number GetExpRatio(Entity player)
		-- 장착된 펫들의 경험치 보너스 합계 계산
		local pets = _PetLogic:GetEquippedPets(player)
		local petInventory = player.PlayerPetStorageComponent.petInventory
		local expRatio = 0
		
		for key, value in pairs(pets) do
			local id = petInventory[value].originalId
			local level = petInventory[value].level
			local increaseRatio = 1 + ((level - 1) * 0.15)
			local ratio = _PetLogic.petData[id].expBonus * increaseRatio
			
			expRatio = expRatio + ratio
		end
		
		return expRatio
	end

	method number GetExtraEggDropRate(Entity player)
		-- 장착된 펫들의 아이템 드롭 보너스 합계 계산
		local pets = _PetLogic:GetEquippedPets(player)
		local petInventory = player.PlayerPetStorageComponent.petInventory
		local itemDropRatio = 0
		
		for key, value in pairs(pets) do
			local id = petInventory[value].originalId
			local level = petInventory[value].level
			local increaseRatio = 1 + ((level - 1) * 0.15)
			local ratio = _PetLogic.petData[id].itemDropBonus * increaseRatio
			
			itemDropRatio = itemDropRatio + ratio
		end
		
		return itemDropRatio
	end

	method number GetExtraDashStamina(Entity player)
		-- 플레이어의 추가 대시 스태미나 계산 (현재 미구현)
		return 0
	end

	method number GetStageClearRewardBonusRate(Entity player)
		-- 장착된 펫들의 재화 보너스 합계 계산
		local pets = _PetLogic:GetEquippedPets(player)
		local petInventory = player.PlayerPetStorageComponent.petInventory
		local goodsRatio = 0
		
		for key, value in pairs(pets) do
			local id = petInventory[value].originalId
			local level = petInventory[value].level
			local increaseRatio = 1 + ((level - 1) * 0.15)
			local ratio = _PetLogic.petData[id].goodsBonus * increaseRatio
			
			goodsRatio = goodsRatio + ratio
		end
		
		return goodsRatio
	end

	method number GetKnockbackRatio(Entity player)
		-- 플레이어의 넉백 비율 계산 (현재 미구현)
		return 0
	end

	method number GetAttackIncreaseRate(Entity player)
		-- 플레이어의 공격력 증가율 계산
		local attackIncreaseRate = 0 
		
		attackIncreaseRate = player.PlayerCharacterData.statusTable["damageRate"]
		return attackIncreaseRate
	end

	method number GetReductMeleeDamage(Entity player)
		-- 플레이어의 근접 데미지 감소율 계산
		
		if not isvalid(player.PlayerCharacterData.statusTable["reductMeleeDamage"]) then
			return  0
		end
		
		local status = player.PlayerCharacterData.statusTable["reductMeleeDamage"]
		
		local originValue = 0
		return originValue + status
	end

	method number GetReductProjectileDamage(Entity player)
		-- 플레이어의 투사체 데미지 감소율 계산
		if not isvalid(player.PlayerCharacterData.statusTable["reductProjectileDamage"]) then
			return  0
		end
		
		local status = player.PlayerCharacterData.statusTable["reductProjectileDamage"]
		local originValue = 0
		return originValue + status
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleRefreshMySpecEvent(RefreshMySpecEvent event)
		-- 스탯 갱신 이벤트 처리하여 UI 업데이트
		local battlePower = event.battlePower
		
		
		local player = _UserService.LocalPlayer
		local characterData = player.PlayerCharacterData
		
		_UIGroupManager.uiPlayerStatusPopup:RefreshStatPanel()
		_UIGroupManager.uiCharacterInfoPopup:RefreshCharInfo(characterData.charIndex, characterData.charLevel)
		_QuestUILogic.questHUD:Refresh()
	end

end