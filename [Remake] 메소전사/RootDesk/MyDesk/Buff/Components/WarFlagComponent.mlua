@Component
script WarFlagComponent extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 전쟁 깃발 진입 이벤트 처리 (대미지 증가)
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		
		if not isvalid(TriggerBodyEntity) then return end
		if not isvalid(TriggerBodyEntity.BattlePlayer) then return end
		
		_BuffLogic.appliedBuff.totalDamage += 0.4
		TriggerBodyEntity:SendEvent(ChangeTotalDamageEvent())
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 전쟁 깃발 탈출 이벤트 처리 (대미지 감소)
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		
		if not isvalid(TriggerBodyEntity) then return end
		if not isvalid(TriggerBodyEntity.BattlePlayer) then return end
		
		_BuffLogic.appliedBuff.totalDamage -= 0.4
		TriggerBodyEntity:SendEvent(ChangeTotalDamageEvent())
	end

end