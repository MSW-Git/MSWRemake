@Component
script ImprisonComponent extends Component

	property boolean isActive = false

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 감옥 이팩트 업데이트 (크기 축소 및 소멸 처리)
		if self.isActive then
			self._T.transform.Scale = self._T.transform.Scale * (1 - delta * 0.05)
			
			if self._T.transform.Scale.x <= 0.2 then
				_PoolingLogic:DestroyEntity(self.Entity)
				self.isActive = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 감옥 컴포넌트 초기화
		self._T.transform = self.Entity.TransformComponent
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 감옥 이팩트 시작 설정
		self.isActive = true
		self._T.transform.Scale = Vector3.one
		self.Entity.SpriteRendererComponent.Color.a = _OptionLogic.myEffectTransparency * 0.7
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 감옥에서 탈출 시 몰스터를 뒤로 밀어내기
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		
		if not isvalid(TriggerBodyEntity.MonsterObject) then return end
		if not self.isActive then return end
		
		local monster = TriggerBodyEntity.MonsterObject
		local diff = monster:GetPositionVec2() - self.Entity.TransformComponent.Position:ToVector2()
		
		monster:SetKnockback(diff:Normalize() * (-8.5), 0.1, true)
	end

end