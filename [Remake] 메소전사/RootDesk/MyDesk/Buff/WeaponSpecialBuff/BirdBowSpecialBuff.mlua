@Component
script BirdBowSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 15

	property number damageRate = 1

	property number timer = 0

	property table posTable = {{Vector3(1.5,0,0)},{Vector3(1.5,0,0),Vector3(-1.5,0,0)},{Vector3(1.5,-1.5,0),Vector3(0,1.5,0),Vector3(-1.5,-1.5,0)},{Vector3(1.5,1.5,0),Vector3(1.5,-1.5,0),Vector3(-1.5,1.5,0),Vector3(-1.5,-1.5,0)},{Vector3(1.5,0.5,0),Vector3(0,2,0),Vector3(-1.5,0.5,0),Vector3(-1,-1,0),Vector3(1,-1,0)},{Vector3(1,2,0),Vector3(2,0,0),Vector3(1,-2,0),Vector3(-1,2,0),Vector3(-2,0,0),Vector3(-1,-2,0)}}

	method void BuffOn()
		-- 새 활 특수 버프 활성화 및 새 소환 시작
		__base:BuffOn()
		
		_SpecialBuffLogic.birdBowTable[#_SpecialBuffLogic.birdBowTable + 1] = self.Entity.BattleGunObject
		if #_SpecialBuffLogic.birdBowTable == 1 then
			self:Summon()
		end
		
	end

	method void Summon()
		-- 추적하는 새 소환 및 타겟 변경 시스템
		local shoot = function()
			
			if not isvalid(self) then return end
		
			local lookDir = _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local currentPosTable = self.posTable[#_SpecialBuffLogic.birdBowTable]
		
			for count=1,#_SpecialBuffLogic.birdBowTable do
				local pos = _UserService.LocalPlayer.TransformComponent.Position + Vector3(currentPosTable[count].x*lookDir,currentPosTable[count].y,0)
		
				local battleGunObject = _SpecialBuffLogic.birdBowTable[count]
				local damage = battleGunObject:CalculateDamage() * self.damageRate
				local criticalDamage = battleGunObject:CalculateCriticalDamage()
				local criticalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
		
				local dir = 1
				if currentPosTable[count].x < 0 then
					dir = -1
				end
		
				local option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
				_EffectService:PlayEffect("4444fe91a03c46d49272f4f0b6d55327",_UserService.LocalPlayer,pos,0,Vector3(dir,1,1),false,option)
		
				local appear = function()
					if isvalid(self) == false then return end
					
					local effect = _PoolingLogic:SpawnModel("model://ca614642-76bd-4ac4-80da-3abb3ed2d0d0",pos,self.Entity.CurrentMap)
					local skillEffect = effect.SkillEffectObject
					
					skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
					skillEffect:SetAngle(90-dir*lookDir*90,false)
					skillEffect.criticalRate = criticalRate
					skillEffect.criticalDamage = criticalDamage
					if count == 1 then
						_SoundService:PlaySound("1bcc05d9369a4595bd05c5fe997522f8", _SoundLogic.effectRatio)
					end
					
					for i=1,3 do
						local newTarget = function()
							if isvalid(self) == false then return end
							
							local target = self:SearchTarget(skillEffect.Entity)
							if isvalid(target) then
								skillEffect:SetTarget(target)
							end
						end
						_TimerLogic:SetTimerOnce(newTarget,2*i, "BirdBowSpecialBuff.Summon_searchTarget")
					end
					
					local disappear = function()
						if isvalid(self) == false then return end
						
						option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
						_EffectService:PlayEffect("4444fe91a03c46d49272f4f0b6d55327",effect,skillEffect.Entity.TransformComponent.Position,0,Vector3.one,false,option)
					end
					_TimerLogic:SetTimerOnce(disappear,skillEffect.life-0.1, "BirdBowSpecialBuff.Summon_disappear")
				end
				_TimerLogic:SetTimerOnce(appear,0.5, "BirdBowSpecialBuff.Summon_appaear")
			
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(shoot,self.cooltime,0.5,"BirdBowSpecialBuff.Summon")
	end

	method Entity SearchTarget(Entity bullet)
		-- 가장 가까운 적 타겟 검색
		local target = nil
		
		local maxDist = 99999999
		local pos = bullet.TransformComponent.Position 
		local range = 8
		for k,v in pairs(self.Entity.BattleGunObject.monsters) do
			---@type DestroyableObject
			local eachMonster = v
			
			if not eachMonster.Entity.Enable or eachMonster.isDead then
			
			else
				local diff = eachMonster:GetPosition() - pos
				local dist = diff.x * diff.x + diff.y * diff.y
				if eachMonster.type == _BattleEnumLogic.BOX then
					dist = dist + range
				end
				if dist < maxDist then
					maxDist = dist
					target = eachMonster.Entity
				end
			end
		end
		
		return target
	end

	method void BuffOnForField(number mode)
		-- 필드 모드에서의 새 활 버프 처리
		__base:BuffOnForField(mode)
		
		if mode == 1 then
			_SpecialBuffLogic.birdBowTable = {}
			
		
		elseif mode == 2 then
			_SpecialBuffLogic.birdBowTable[#_SpecialBuffLogic.birdBowTable + 1] = self.Entity.BattleGunObject
			
		
		elseif mode == 3 then
			local lookDir = _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local currentPosTable = self.posTable[#_SpecialBuffLogic.birdBowTable]
		
			for count=1,#_SpecialBuffLogic.birdBowTable do
				local pos = _UserService.LocalPlayer.TransformComponent.Position + Vector3(currentPosTable[count].x*lookDir,currentPosTable[count].y,0)
		
				local battleGunObject = _SpecialBuffLogic.birdBowTable[count]
				local damage = battleGunObject:CalculateDamage() * self.damageRate
				local criticalDamage = battleGunObject:CalculateCriticalDamage()
				local criticalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
		
				local dir = 1
				if currentPosTable[count].x < 0 then
					dir = -1
				end
		
				local option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
				_EffectService:PlayEffect("4444fe91a03c46d49272f4f0b6d55327",_UserService.LocalPlayer,pos,0,Vector3(dir,1,1),false,option)
		
				local appear = function()
					if isvalid(self) == false then return end
					
					local effect = _PoolingLogic:SpawnModel("model://ca614642-76bd-4ac4-80da-3abb3ed2d0d0",pos,self.Entity.CurrentMap)
					local skillEffect = effect.SkillEffectObject
					
					skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
					skillEffect:SetAngle(90-dir*lookDir*90,false)
					skillEffect.criticalRate = criticalRate
					skillEffect.criticalDamage = criticalDamage
					if count == 1 then
						_SoundService:PlaySound("1bcc05d9369a4595bd05c5fe997522f8", _SoundLogic.effectRatio)
					end
					
					for i=1,3 do
						local newTarget = function()
							if isvalid(self) == false then return end
							
							local target = _UserService.LocalPlayer.MultiBattlePlayer.target
							if isvalid(target) and target.MultiMonsterObject.isDead == false then
								skillEffect:SetTarget(target)
							end
						end
						_TimerService:SetTimerOnce(newTarget,2*i)
					end
					
					local disappear = function()
						if isvalid(self) == false then return end
						
						option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
						_EffectService:PlayEffect("4444fe91a03c46d49272f4f0b6d55327",effect,skillEffect.Entity.TransformComponent.Position,0,Vector3.one,false,option)
					end
					_TimerService:SetTimerOnce(disappear,skillEffect.life-0.1)
				end
				_TimerService:SetTimerOnce(appear,0.5)
			
			end
		end
	end

end