@Component
script PistolSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 6

	property number damageRate = 1

	property number duration = 2.5

	property table posTable = {{Vector3(2,0,0)},{Vector3(2,0,0),Vector3(-2,0,0)},{Vector3(1.5,-1,0),Vector3(0,1.5,0),Vector3(-1.5,-1,0)},{Vector3(1.5,1.5,0),Vector3(1.5,-1.5,0),Vector3(-1.5,1.5,0),Vector3(-1.5,-1.5,0)},{Vector3(1.5,1,0),Vector3(0,2,0),Vector3(-1.5,1,0),Vector3(-1,-1,0),Vector3(1,-1,0)},{Vector3(1,2,0),Vector3(2,0,0),Vector3(1,-2,0),Vector3(-1,2,0),Vector3(-2,0,0),Vector3(-1,-2,0)}}

	property table bulletTable = {"model://612cae80-dbe7-41dc-b617-29cf5ef038fb","model://bc886dee-f83e-4c66-bf4a-5227ddb0914b","model://7a4ed76f-767b-4368-9694-a33409b2d8a4","model://e791096f-f342-4991-beee-8ea920b4812e","model://42bea4b1-f39b-4fb3-8865-c2edffaef882"}

	property number timer = 0

	property table personEffect = {}

	property table bulletEffect = {}

	method void BuffOn()
		-- 권총 특수 버프 활성화 및 연발 사격 시작
		__base:BuffOn()
		
		_SpecialBuffLogic.pistolTable[#_SpecialBuffLogic.pistolTable + 1] = self.Entity.BattleGunObject
		if #_SpecialBuffLogic.pistolTable == 1 then
			self.personEffect = {}
			self.bulletEffect = {}
			self:Spree()
		end
		
	end

	method void Spree()
		-- 다중 권총 연발 사격 파티 스킬 실행
		local bulletParty = function()
			if isvalid(self) == false then return end
		
			local lookDir = _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local currentPosTable = self.posTable[#_SpecialBuffLogic.pistolTable]
			
			if not isvalid(currentPosTable) then return end
		
			for count = 1, #_SpecialBuffLogic.pistolTable do
				local pos = _UserService.LocalPlayer.TransformComponent.Position + Vector3(currentPosTable[count].x*lookDir,currentPosTable[count].y,0)
		
				self.personEffect[count] = _EffectLogic:PlayEffect("ff649315debc4ea2897469f984d119f8",self.Entity,pos,0,Vector3.one,true,_UserService.LocalPlayer)
				self.bulletEffect[count] = _EffectLogic:PlayEffect("ec2a2a71fc1845d68d8fef7ba6a7f22d",self.Entity,pos,0,Vector3.one*0.5,true,_UserService.LocalPlayer)
				
				local battleGunObject = _SpecialBuffLogic.pistolTable[count]
				local damage = battleGunObject:CalculateDamage() * self.damageRate
				local criticalDamage = battleGunObject:CalculateCriticalDamage()
				local cricicalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
				
				local weaponGrade = _ItemDataLogic.equipmentData[battleGunObject.weaponSpec.id].grade
				if weaponGrade == "normal" then
					weaponGrade = 1
				elseif weaponGrade == "rare" then
					weaponGrade = 2
				elseif weaponGrade == "epic" then
					weaponGrade = 3
				elseif weaponGrade == "unique" then
					weaponGrade = 4
				elseif weaponGrade == "legendary" then
					weaponGrade = 5
				end
				local bulletModel = self.bulletTable[weaponGrade]
				
				local bulletCount = 40
				for i = 1, bulletCount do
					local spawnFunc = function()
						if isvalid(self) == false then return end
						
						local effect = _PoolingLogic:SpawnModel(bulletModel,pos,self.Entity.CurrentMap)
						local skillEffect = effect.SkillEffectObject
										
						skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
						skillEffect.criticalRate = cricicalRate
						skillEffect.criticalDamage = criticalDamage
						if i == 1 and count == 1 then
							_SoundService:PlaySound("0d552c38689140e7a36179bcef7f639e", _SoundLogic.effectRatio)
						end
						if i == bulletCount then
							local option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
							_EffectService:PlayEffect("25d7aced1efb43749fbfa7a055c57713",self.Entity,pos,0,Vector3.one,false,option)
							_EffectLogic:RemoveEffect(self.personEffect[count])
							_EffectLogic:RemoveEffect(self.bulletEffect[count])
						end
					end
					_TimerLogic:SetTimerOnce(spawnFunc,self.duration/bulletCount*i, "PistolSpecialBuff.Spree_SpawnBullet")
				end
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(bulletParty,self.cooltime,_UtilLogic:RandomDouble()*self.cooltime, "PistolSpecialBuff.Spree_SpawnBullets")
	end

	method void Reset()
		-- 권총 특수 버프 리셋 시 이펙트 정리
		__base:Reset()
		
		for count = 1, #self.personEffect do
			if isvalid(self.personEffect[count]) then
				_EffectLogic:RemoveEffect(self.personEffect[count])
			end
			if isvalid(self.bulletEffect[count]) then
				_EffectLogic:RemoveEffect(self.bulletEffect[count])
			end
		end
	end

	method void BuffOnForField(number mode)
		-- 멀티 필드 모드에서 권총 특수 버프 처리
		__base:BuffOnForField(mode)
		
		
		if mode == 1 then
			_SpecialBuffLogic.pistolTable = {}
		
		elseif mode == 2 then
			_SpecialBuffLogic.pistolTable[#_SpecialBuffLogic.pistolTable + 1] = self.Entity.BattleGunObject
			
		
		elseif mode == 3 then
			self.personEffect = {}
			self.bulletEffect = {}
			
			local lookDir = _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local currentPosTable = self.posTable[#_SpecialBuffLogic.pistolTable]
			
			for count = 1, #_SpecialBuffLogic.pistolTable do
				local pos = _UserService.LocalPlayer.TransformComponent.Position + Vector3(currentPosTable[count].x*lookDir,currentPosTable[count].y,0)
			
				self.personEffect[count] = _EffectLogic:PlayEffect("ff649315debc4ea2897469f984d119f8",self.Entity,pos,0,Vector3.one,true,_UserService.LocalPlayer)
				self.bulletEffect[count] = _EffectLogic:PlayEffect("ec2a2a71fc1845d68d8fef7ba6a7f22d",self.Entity,pos,0,Vector3.one*0.5,true,_UserService.LocalPlayer)
				
				local battleGunObject = _SpecialBuffLogic.pistolTable[count]
				local damage = battleGunObject:CalculateDamage() * self.damageRate
				local criticalDamage = battleGunObject:CalculateCriticalDamage()
				local cricicalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
				
				local weaponGrade = _ItemDataLogic.equipmentData[battleGunObject.weaponSpec.id].grade
				if weaponGrade == "normal" then
					weaponGrade = 1
				elseif weaponGrade == "rare" then
					weaponGrade = 2
				elseif weaponGrade == "epic" then
					weaponGrade = 3
				elseif weaponGrade == "unique" then
					weaponGrade = 4
				elseif weaponGrade == "legendary" then
					weaponGrade = 5
				end
				local bulletModel = self.bulletTable[weaponGrade]
				
				local bulletCount = 40
				for i = 1, bulletCount do
					local spawnFunc = function()
						if isvalid(self) == false then return end
						
						local effect = _PoolingLogic:SpawnModel(bulletModel,pos,self.Entity.CurrentMap)
						local skillEffect = effect.SkillEffectObject
										
						skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
						skillEffect.criticalRate = cricicalRate
						skillEffect.criticalDamage = criticalDamage
						if i == 1 and count == 1 then
							_SoundService:PlaySound("0d552c38689140e7a36179bcef7f639e", _SoundLogic.effectRatio)
						end
						if i == bulletCount then
							local option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
							_EffectService:PlayEffect("25d7aced1efb43749fbfa7a055c57713",self.Entity,pos,0,Vector3.one,false,option)
							_EffectLogic:RemoveEffect(self.personEffect[count])
							_EffectLogic:RemoveEffect(self.bulletEffect[count])
						end
					end
					_TimerService:SetTimerOnce(spawnFunc,self.duration/bulletCount*i)
				end
			end
		end
	end

end