@Component
script WeaponSpecialBuff extends Component

	property number timer = 0

	property number cooltime = 5

	property number damageRate = 3

	property number duration = 5

	method void BuffOn()
		-- 무기 특수 버프 활성화 시 해당 무기의 업그레이드 카운트 증가
		if isvalid(_SpecialBuffLogic.upgradedWeaponCount[self.Entity.BattleGunObject.weaponSpec.cardDescription]) then
			_SpecialBuffLogic.upgradedWeaponCount[self.Entity.BattleGunObject.weaponSpec.cardDescription] += 1
		else
			_SpecialBuffLogic.upgradedWeaponCount[self.Entity.BattleGunObject.weaponSpec.cardDescription] = 1
		end
	end

	method void Reset()
		-- 특수 버프 타이머 초기화 및 정리
		if self.timer ~= 0 then
			if isvalid(self.Entity.MultiBattleGunObject) then
				_TimerService:ClearTimer(self.timer)
			else
				_TimerLogic:ClearTimer(self.timer)
			end
			self.timer = 0
		end
	end

	method void BuffOnForField(number mode)
		-- 필드에서의 특수 버프 활성화 처리 (하위 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageEndEvent(StageEndEvent event)
		-- 스테이지 종료 시 특수 버프 초기화
		
		self:Reset()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleBattlePlayerDeadEvent(BattlePlayerDeadEvent event)
		-- 플레이어 사망 시 특수 버프 초기화
		
		self:Reset()
	end

end