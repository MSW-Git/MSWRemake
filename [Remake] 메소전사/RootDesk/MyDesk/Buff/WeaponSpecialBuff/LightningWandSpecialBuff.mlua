@Component
script LightningWandSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 5

	property number damageRate = 2

	property number timer = 0

	method void BuffOn()
		-- 번개 지팡이 특수 버프 활성화 및 번개 생성 시작
		__base:BuffOn()
		
		self:ThunderSpawn()
	end

	method void ThunderSpawn()
		-- 번개 스킬 반복 생성 및 스턴 효과 적용
		local thunder = function()
			
			if not isvalid(self) then return end
			
			local battleGunObject = self.Entity.BattleGunObject
			local damage = battleGunObject:CalculateDamage() * self.damageRate
			local criticalDamage = battleGunObject:CalculateCriticalDamage()
			local cricicalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
		
			for i = 1, 3 do
				local spawnFunc = function()
					if isvalid(self) == false then return end
					local effect = _PoolingLogic:SpawnModel("model://6d9b80b3-e97f-495b-b350-909ebcbec902",self.Entity.TransformComponent.WorldPosition,self.Entity.CurrentMap)
					local skillEffect = effect.SkillEffectObject
					
					skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
					skillEffect.criticalRate = cricicalRate
					skillEffect.criticalDamage = criticalDamage
					if i == 1 then
						_SoundService:PlaySound("14aee91eba44493eae2745b186268812", _SoundLogic.effectRatio)
					end
					local eventHandler = skillEffect.Entity:ConnectEvent(TriggerEnterEvent,function(e)
						local TriggerBodyEntity = e.TriggerBodyEntity
						if isvalid(TriggerBodyEntity.MonsterObject) then
							TriggerBodyEntity.MonsterObject:ApplyStun(1)
						end
					end)
					local disconnectEvent = function()
						if isvalid(self) == false then return end
						if isvalid(skillEffect) == false then return end
						skillEffect.Entity:DisconnectEvent(TriggerEnterEvent,eventHandler)
					end
					_TimerLogic:SetTimerOnce(disconnectEvent,skillEffect.life-0.05, "LightningWandSpecialBuff.ThunderSpawn_disconnectEvent")
					
				end
				_TimerLogic:SetTimerOnce(spawnFunc,1*i, "LightningWandSpecialBuff.ThunderSpawn_spawnThunder")
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(thunder,self.cooltime,_UtilLogic:RandomDouble()*self.cooltime, "LightningWandSpecialBuff.ThunderSpawn")
	end

	method void BuffOnForField(number mode)
		-- 필드에서 번개 지팡이 특수 버프 활성화 처리
		__base:BuffOnForField(mode)
		
		if mode == 2 then
			local battleGunObject = self.Entity.BattleGunObject
			local damage = battleGunObject:CalculateDamage() * self.damageRate
			local criticalDamage = battleGunObject:CalculateCriticalDamage()
			local cricicalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
		
			for i = 1, 3 do
				local spawnFunc = function()
					if isvalid(self) == false then return end
					local effect = _PoolingLogic:SpawnModel("model://6d9b80b3-e97f-495b-b350-909ebcbec902",_UserService.LocalPlayer.TransformComponent.WorldPosition,self.Entity.CurrentMap)
					local skillEffect = effect.SkillEffectObject
					
					skillEffect:Init(damage, true,"[\""..battleGunObject.uniqueKey.."\"]", "")
					skillEffect.criticalRate = cricicalRate
					skillEffect.criticalDamage = criticalDamage
					if i == 1 then
						_SoundService:PlaySound("14aee91eba44493eae2745b186268812", _SoundLogic.effectRatio)
					end
					local eventHandler = skillEffect.Entity:ConnectEvent(TriggerEnterEvent,function(e)
						local TriggerBodyEntity = e.TriggerBodyEntity
						if isvalid(TriggerBodyEntity.MonsterObject) then
							TriggerBodyEntity.MonsterObject:ApplyStun(1)
						end
					end)
					local disconnectEvent = function()
						if isvalid(self) == false then return end
						if isvalid(skillEffect) == false then return end
						skillEffect.Entity:DisconnectEvent(TriggerEnterEvent,eventHandler)
					end
					_TimerService:SetTimerOnce(disconnectEvent,skillEffect.life-0.05)
					
				end
				_TimerService:SetTimerOnce(spawnFunc,1*i)
			end
		end
	end

end