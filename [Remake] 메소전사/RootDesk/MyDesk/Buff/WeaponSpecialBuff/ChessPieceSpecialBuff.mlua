@Component
script ChessPieceSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 10

	property number damageRate = 1.5

	property number timer = 0

	method void BuffOn()
		-- 체스 말 특수 버프 활성화 및 필드 전체 공격 시작
		__base:BuffOn()
		
		_SpecialBuffLogic.chessPieceTable[#_SpecialBuffLogic.chessPieceTable + 1] = self.Entity.BattleGunObject
		if #_SpecialBuffLogic.chessPieceTable == 1 then
			self:TurnOnField()
		end
		
	end

	method void TurnOnField()
		-- 체스 말 필드 전체 공격 스킬 반복 실행
		local shoot = function()
			
			if not isvalid(self) then return end
			
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			for i=1,#_SpecialBuffLogic.chessPieceTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.chessPieceTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.chessPieceTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.chessPieceTable[i]:CalculateDamage() * self.damageRate
			end
			
			local effect = _PoolingLogic:SpawnModel("model://6d5c30c7-79cc-43f9-9857-a92955fb60c0",Vector3.zero,_UserService.LocalPlayer)
			effect.SpriteRendererComponent.SortingLayer = "Layer1"
			effect.SpriteRendererComponent.OrderInLayer = 1
			local skillEffect = effect.SkillEffectObject
		
			skillEffect:Init(damage, true,"chessPiece", "")
			skillEffect.criticalRate = criticalRate
			skillEffect.criticalDamage = criticalDamage
		
			_SoundService:PlaySound("7024153df14044899ce3b7ad26ed5734", _SoundLogic.effectRatio)
			
			local damageSpawn = function()
				if isvalid(self) == false then return end
		
				local effect2 = _PoolingLogic:SpawnModel("model://6156042f-85a1-45d9-a7b4-dc1120bea199",Vector3.zero,_UserService.LocalPlayer)
				effect2.SpriteRendererComponent.SortingLayer = "Layer1"
				effect2.SpriteRendererComponent.OrderInLayer = 1
				local skillEffect2 = effect2.SkillEffectObject
			
				skillEffect2:Init(damage, true,"chessPiece", "")
				skillEffect2.criticalRate = criticalRate
				skillEffect2.criticalDamage = criticalDamage
			end
			_TimerLogic:SetTimerOnce(damageSpawn,1, "ChessPieceSpecialBuff.TurnOnField_damageSpawn")
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(shoot,self.cooltime,0.5, "ChessPieceSpecialBuff.TurnOnField")
	end

	method void BuffOnForField(number mode)
		-- 필드에서 체스 말 특수 버프 활성화 처리
		__base:BuffOnForField(mode)
		
		
		if mode == 1 then
			_SpecialBuffLogic.chessPieceTable = {}
			
		
		elseif mode == 2 then
			_SpecialBuffLogic.chessPieceTable[#_SpecialBuffLogic.chessPieceTable + 1] = self.Entity.BattleGunObject
			
		
		elseif mode == 3 then
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			local uniqueKey = "["
			for i=1,#_SpecialBuffLogic.chessPieceTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.chessPieceTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.chessPieceTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.chessPieceTable[i]:CalculateDamage() * self.damageRate
				if i == #_SpecialBuffLogic.chessPieceTable then
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.chessPieceTable[i].uniqueKey.."\""
				else
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.chessPieceTable[i].uniqueKey.."\","
				end
			end
			uniqueKey = uniqueKey.."]"
			
			local effect = _PoolingLogic:SpawnModel("model://6d5c30c7-79cc-43f9-9857-a92955fb60c0",Vector3.zero,_UserService.LocalPlayer)
			effect.SpriteRendererComponent.SortingLayer = "Tile"
			effect.SpriteRendererComponent.OrderInLayer = 1
			local skillEffect = effect.SkillEffectObject
		
			skillEffect:Init(damage, true,uniqueKey, "")
			skillEffect.criticalRate = criticalRate
			skillEffect.criticalDamage = criticalDamage
		
			_SoundService:PlaySound("7024153df14044899ce3b7ad26ed5734", _SoundLogic.effectRatio)
			
			local damageSpawn = function()
				if isvalid(self) == false then return end
		
				local effect2 = _PoolingLogic:SpawnModel("model://6156042f-85a1-45d9-a7b4-dc1120bea199",Vector3.zero,_UserService.LocalPlayer)
				effect2.SpriteRendererComponent.SortingLayer = "Tile"
				effect2.SpriteRendererComponent.OrderInLayer = 1
				local skillEffect2 = effect2.SkillEffectObject
			
				skillEffect2:Init(damage, true,uniqueKey, "")
				skillEffect2.criticalRate = criticalRate
				skillEffect2.criticalDamage = criticalDamage
			end
			_TimerService:SetTimerOnce(damageSpawn,1)
		end
	end

end