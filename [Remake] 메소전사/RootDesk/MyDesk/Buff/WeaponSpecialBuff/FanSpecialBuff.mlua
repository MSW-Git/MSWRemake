@Component
script FanSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 10

	property number damageRate = 1

	property number timer = 0

	property table angleTable = {{0},{0,180},{330,90,210},{45,315,135,225},{18,90,162,234,306},{60,0,300,120,180,240}}

	property number duration = 5

	property table posTable = {{Vector3(4,0,0)},{Vector3(4,0,0),Vector3(-4,0,0)},{Vector3(3,-2,0),Vector3(0,3,0),Vector3(-3,-2,0)},{Vector3(3,3,0),Vector3(3,-3,0),Vector3(-3,3,0),Vector3(-3,-3,0)},{Vector3(3,2,0),Vector3(0,4,0),Vector3(-3,2,0),Vector3(-2,-2,0),Vector3(2,-2,0)},{Vector3(2,4,0),Vector3(4,0,0),Vector3(2,-4,0),Vector3(-2,4,0),Vector3(-4,0,0),Vector3(-2,-4,0)}}

	method void BuffOn()
		-- 부채 특수 버프 활성화 및 폭풍 생성 시작
		__base:BuffOn()
		_SpecialBuffLogic.fanTable[#_SpecialBuffLogic.fanTable + 1] = self.Entity.BattleGunObject
		if #_SpecialBuffLogic.fanTable == 1 then
			self:Storm()
		end
	end

	method void Storm()
		-- 폭풍 스킬 반복 생성 및 몬스터 빨아들이기 효과 적용
		local spawnStorm = function()
			
			if not isvalid(self) then return end
			
			local lookDir = _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			for i=1,#_SpecialBuffLogic.fanTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.fanTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.fanTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.fanTable[i]:CalculateDamage() * self.damageRate
			end
			for count = 1, #_SpecialBuffLogic.fanTable do
				if isvalid(self) == false then return end
						
				if count == 1 then
					_SoundService:PlaySound("154680b9decd4f79bac4da81ccc740e1", _SoundLogic.effectRatio)
				end
				
				local localPos = Vector3(self.posTable[#_SpecialBuffLogic.fanTable][count].x*lookDir,self.posTable[#_SpecialBuffLogic.fanTable][count].y,0)
				local stormObject = _PoolingLogic:SpawnModel("model://83e39081-6a4e-493d-b55e-e88730d20a42",_UserService.LocalPlayer.TransformComponent.Position+localPos,self.Entity.CurrentMap)
				local stormSkillObject = stormObject.SkillEffectObject
				stormSkillObject:Init(damage, true,"fan", "")
				stormSkillObject.spiralAngle = (90*lookDir-90) + lookDir * self.angleTable[#_SpecialBuffLogic.fanTable][count]
				stormSkillObject:SetAngle(0,false)
				stormSkillObject.criticalRate = criticalRate
				stormSkillObject.criticalDamage = criticalDamage
				local eventHandler = stormObject:ConnectEvent(TriggerEnterEvent,function(e)
					local TriggerBodyEntity = e.TriggerBodyEntity
					if isvalid(TriggerBodyEntity.MonsterObject) then
						TriggerBodyEntity.MonsterObject:ApplyStorm(stormObject)
					end
				end)
		
				local disconnectEvent = function()
					if isvalid(self) == false then return end
					if isvalid(stormSkillObject) == false then return end
					stormObject:DisconnectEvent(TriggerEnterEvent,eventHandler)
				end
				_TimerLogic:SetTimerOnce(disconnectEvent,stormSkillObject.life-0.05, "FanSpecialBuff.Storm_disconnectEvent")
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(spawnStorm,self.cooltime,_UtilLogic:RandomDouble()*self.cooltime, "FanSpecialBuff.Storm")
	end

	method void BuffOnForField(number mode)
		-- 필드에서 부채 특수 버프 활성화 처리
		__base:BuffOnForField(mode)
		
		
		if mode == 1 then
			_SpecialBuffLogic.fanTable = {}
			
		
		elseif mode == 2 then
			_SpecialBuffLogic.fanTable[#_SpecialBuffLogic.fanTable + 1] = self.Entity.BattleGunObject
			
		
		elseif mode == 3 then
			local lookDir = _UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			local uniqueKey = "["
			for i=1,#_SpecialBuffLogic.fanTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.fanTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.fanTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.fanTable[i]:CalculateDamage() * self.damageRate
				if i == #_SpecialBuffLogic.fanTable then
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.fanTable[i].uniqueKey.."\""
				else
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.fanTable[i].uniqueKey.."\","
				end
			end
			uniqueKey = uniqueKey.."]"
			for count = 1, #_SpecialBuffLogic.fanTable do
				if isvalid(self) == false then return end
						
				if count == 1 then
					_SoundService:PlaySound("154680b9decd4f79bac4da81ccc740e1", _SoundLogic.effectRatio)
				end
				
				local localPos = Vector3(self.posTable[#_SpecialBuffLogic.fanTable][count].x*lookDir,self.posTable[#_SpecialBuffLogic.fanTable][count].y,0)
				local stormObject = _PoolingLogic:SpawnModel("model://83e39081-6a4e-493d-b55e-e88730d20a42",_UserService.LocalPlayer.TransformComponent.Position+localPos,self.Entity.CurrentMap)
				local stormSkillObject = stormObject.SkillEffectObject
				stormSkillObject:Init(damage, true,uniqueKey, "")
				stormSkillObject.spiralAngle = (90*lookDir-90) + lookDir * self.angleTable[#_SpecialBuffLogic.fanTable][count]
				stormSkillObject:SetAngle(0,false)
				stormSkillObject.criticalRate = criticalRate
				stormSkillObject.criticalDamage = criticalDamage
				local eventHandler = stormObject:ConnectEvent(TriggerEnterEvent,function(e)
					local TriggerBodyEntity = e.TriggerBodyEntity
					if isvalid(TriggerBodyEntity.MonsterObject) then
						TriggerBodyEntity.MonsterObject:ApplyStorm(stormObject)
					end
				end)
		
				local disconnectEvent = function()
					if isvalid(self) == false then return end
					if isvalid(stormSkillObject) == false then return end
					stormObject:DisconnectEvent(TriggerEnterEvent,eventHandler)
				end
				_TimerService:SetTimerOnce(disconnectEvent,stormSkillObject.life-0.05)
			end
		end
	end

end