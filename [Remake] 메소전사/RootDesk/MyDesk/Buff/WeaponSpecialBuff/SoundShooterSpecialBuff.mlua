@Component
script SoundShooterSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 8

	property number damageRate = 1

	property number duration = 3

	property table posTable = {Vector3(4,0,0),Vector3(-4,0,0),Vector3(2,4,0),Vector3(-2,-4,0),Vector3(-2,4,0),Vector3(2,-4,0)}

	property number timer = 0

	method void BuffOn()
		-- 음파 발사기 특수 버프 활성화 및 콘서트 시작
		__base:BuffOn()
		
		self._T.effectAttached = nil
		self:Concert()
		
	end

	method void Concert()
		-- 원형 탄환 발사 콘서트 스킬 반복 실행
		local playConcert = function()
			
			if not isvalid(self) then return end
			
			local pos = self.Entity.TransformComponent.WorldPosition
			self._T.effectAttached = _PoolingLogic:SpawnModel("model://a3a709d1-c72a-4db4-9ba3-a28dabc4ba60",pos+Vector3(0,2.5,0),self.Entity.CurrentMap)
			
			local battleGunObject = self.Entity.BattleGunObject
			local damage = battleGunObject:CalculateDamage() * self.damageRate
			local criticalDamage = battleGunObject:CalculateCriticalDamage()
			local cricicalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
		
			local bulletModel = battleGunObject.weaponSpec.bullet
			
			local bulletCount = 20
			for i = 1, bulletCount do
				local spawnFunc = function()
					if isvalid(self) == false then return end
					
					local effect = _PoolingLogic:SpawnModel(bulletModel,self.Entity.TransformComponent.WorldPosition,self.Entity.CurrentMap)
					local skillEffect = effect.SkillEffectObject
									
					local angle = i * (360/bulletCount)
					skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
					skillEffect:SetAngle(angle,false)
					skillEffect.criticalRate = cricicalRate
					skillEffect.criticalDamage = criticalDamage
					if i == 1 then
						_SoundService:PlaySound("2e7463aaf3484e2a9d806136640ec2cc", _SoundLogic.effectRatio)
					end
					if i == bulletCount then
						_PoolingLogic:DestroyEntity(self._T.effectAttached)
						self._T.effectAttached = nil
					end
				end
				_TimerLogic:SetTimerOnce(spawnFunc,self.duration/bulletCount*i, "SoundShooterSpecialBuff.Concert_spawnBullet")
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(playConcert,self.cooltime,_UtilLogic:RandomDouble()*self.cooltime,"SoundShooterSpecialBuff.Concert")
	end

	method void Reset()
		-- 음파 발사기 특수 버프 리셋 시 이펙트 정리
		if self.timer ~= 0 then
			_PoolingLogic:DestroyEntity(self._T.effectAttached)
		end
		
		__base:Reset()
		
		self._T.effectAttached = nil
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 콘서트 이펙트의 위치를 무기에 맞춰 업데이트
		if isvalid(self) == false then return end
		if isvalid(self._T.effectAttached) == false then return end
		
		local pos = self.Entity.TransformComponent.WorldPosition
		self._T.effectAttached.TransformComponent.Position = pos+Vector3(0,2.5,0)
	end

	method void BuffOnForField(number mode)
		-- 멀티 필드 모드에서 음파 발사기 특수 버프 처리
		__base:BuffOnForField(mode)
		
		if mode == 2 then
			self._T.effectAttached = nil
			
			if self.Entity.Enable == false then
				self.Entity.Enable = true
			end
			
			local pos = self.Entity.TransformComponent.WorldPosition
			self._T.effectAttached = _PoolingLogic:SpawnModel("model://a3a709d1-c72a-4db4-9ba3-a28dabc4ba60",pos+Vector3(0,2.5,0),self.Entity.CurrentMap)
			
			local battleGunObject = self.Entity.MultiBattleGunObject
			battleGunObject.specialBuffOn = true
			
			local damage = battleGunObject:CalculateDamage() * self.damageRate
			local criticalDamage = battleGunObject:CalculateCriticalDamage()
			local cricicalRate = battleGunObject.weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent()
		
			local bulletModel = battleGunObject.weaponSpec.bullet
			
			local bulletCount = 20
			for i = 1, bulletCount do
				local spawnFunc = function()
					if isvalid(self) == false then return end
					
					local effect = _PoolingLogic:SpawnModel(bulletModel,self.Entity.TransformComponent.WorldPosition,self.Entity.CurrentMap)
					local skillEffect = effect.SkillEffectObject
									
					local angle = i * (360/bulletCount)
					skillEffect:Init(damage, true,battleGunObject.uniqueKey, "")
					skillEffect:SetAngle(angle,false)
					skillEffect.criticalRate = cricicalRate
					skillEffect.criticalDamage = criticalDamage
					if i == 1 then
						_SoundService:PlaySound("2e7463aaf3484e2a9d806136640ec2cc", _SoundLogic.effectRatio)
					end
					if i == bulletCount then
						_PoolingLogic:DestroyEntity(self._T.effectAttached)
						self._T.effectAttached = nil
						battleGunObject.specialBuffOn = false	
						if battleGunObject.fighting == false then
							self.Entity.Enable = false
						end
					end
				end
				_TimerService:SetTimerOnce(spawnFunc,self.duration/bulletCount*i)
			end
		end
	end

end