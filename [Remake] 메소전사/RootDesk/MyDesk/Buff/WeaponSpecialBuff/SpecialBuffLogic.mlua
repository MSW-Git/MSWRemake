@Logic
script SpecialBuffLogic extends Logic

	property SyncTable<string, number> upgradedWeaponCount

	property table swordTable = {}

	property table pistolTable = {}

	property table fireStaffTable = {}

	property table bowTable = {}

	property table chessPieceTable = {}

	property table breathShooterTable = {}

	property table birdBowTable = {}

	property table wristbandTable = {}

	property table fanTable = {}

	property table hammerTable = {}

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageStartEvent(StageStartEvent event)
		-- 스테이지 시작 시 모든 특수 버프 테이블과 업그레이드 무기 카운트 초기화
		
		table.clear(self.upgradedWeaponCount)
		self.swordTable = {}
		self.pistolTable = {}
		self.fireStaffTable = {}
		self.bowTable = {}
		self.chessPieceTable = {}
		self.breathShooterTable = {}
		self.birdBowTable = {}
		self.wristbandTable = {}
		self.fanTable = {}
		self.hammerTable = {}
		
		_DPSLogic:InitSpecialBuffTable()
	end

end