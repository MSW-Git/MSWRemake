@Component
script ToggleGroupControlComponent extends Component

	property integer viewCount = 1

	property string optionName = ""

	@ExecSpace("ClientOnly")
	method void OnInitialize()
		-- 토글 그룹 컨트롤러 초기화 및 내부 테이블 설정
		self._T.viewTable = {}
		self._T.registerCount = 0
	end

	method void RegisterMember(ToggleGroupViewComponent member, boolean isDefault)
		-- 토글 그룹에 멤버 뷰 컴포넌트를 등록하고 기본 선택 처리
		if isDefault and self._T.selectedComponent == nil then
			self._T.selectedComponent = member
			member:Selected()
		end
		
		local viewTable = self._T.viewTable
		viewTable[#viewTable + 1] = member
		
		self._T.registerCount += 1
		if self.viewCount == self._T.registerCount and self._T.selectedComponent == nil then
			self._T.selectedComponent = viewTable[1]
		end
	end

	method void OnClickedView(ToggleGroupViewComponent view, number value)
		-- 토글 뷰 클릭 시 선택 상태 변경 및 옵션 값 설정
		if _OptionLogic[self.optionName] == nil then
			return
		end
		
		if self._T.selectedComponent == view then return end
		
		---@type ToggleGroupViewComponent
		local comp = self._T.selectedComponent
		comp:Deselected()
		view:Selected()
		
		self._T.selectedComponent = view
		
		_OptionLogic:SetOptionValue(self.optionName, value)
	end

	method void Refresh()
		-- 현재 옵션 값에 맞는 토글 뷰를 선택 상태로 갱신
		local currentValue = _OptionLogic[self.optionName]
		if currentValue == nil then
			return
		end
		
		for i, viewComp in ipairs(self._T.viewTable) do
			if viewComp.optionValue == currentValue then
				self._T.selectedComponent:Deselected()
				viewComp:Selected()
				self._T.selectedComponent = viewComp
				return
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "OptionLogic")
	handler HandleOptionDataLoadedEvent(OptionDataLoadedEvent event)
		-- 옵션 데이터 로드 완료 시 토글 그룹 상태 갱신
		self:Refresh()
	end

end