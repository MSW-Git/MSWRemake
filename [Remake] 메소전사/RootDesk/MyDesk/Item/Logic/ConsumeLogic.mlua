@Logic
script ConsumeLogic extends Logic

	property table consumeEffectData = {}

	@ExecSpace("ServerOnly")
	method boolean UseConsumeItem(string itemId, string userId)
		-- 소비 아이템을 사용하고 해당 효과를 적용
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local playerStorage = playerEntity.PlayerStorageComponent
		local playerCharData = playerEntity.PlayerCharacterData
		local playerQuest = playerEntity.PlayerQuestComponent
		local itemData = _ItemDataLogic.itemData[itemId]
		local fixedItem = itemData.fixedItem
		local category = itemData.category
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		if category == "decoration" then
			playerEntity.PlayerInfoComponent:SetDecoration(itemId)
			
			return true
		end
		
		local playerInfo = playerEntity.PlayerInfoComponent
		local slot = 0
		
		if itemId == "6_000001" then 
			if tonumber(playerQuest.currentQuestId) >= 44 then
				_GameLogic:TryEnterRandomBossMapByTicket(playerEntity)
			end
		elseif itemId == "6_000002" then 
			playerEntity.PlayerInfoComponent:AddBuff("1", 1)
		elseif itemId == "6_000003" then 
			_GatchaLogic:DoGatchaCauseNotCashItem("5", userId, nil, itemId)
		elseif itemId == "6_000004" then 
			_GatchaLogic:DoGatchaCauseNotCashItem("6", userId, nil, itemId)
		elseif itemId == "6_000005" then 
			slot = playerInfo.playerInfo.armorStorageSlot
			playerInfo:SetStorageSlot("armor", slot + 10)
			
			_LocalizeLogic:ShowToast("toast138", userId)
		elseif itemId == "6_000006" then 
			slot = playerInfo.playerInfo.petStorageSlot
			playerInfo:SetStorageSlot("pet", slot + 10)
			
			_LocalizeLogic:ShowToast("toast142", userId)
		elseif itemId == "6_000007" then 
			slot = playerInfo.playerInfo.consumeStorageSlot
			playerInfo:SetStorageSlot("consume", slot + 10)
			
			_LocalizeLogic:ShowToast("toast151", userId)
		elseif itemId == "6_000008" then 
			slot = playerInfo.playerInfo.etcStorageSlot
			playerInfo:SetStorageSlot("etc", slot + 10)
			
			_LocalizeLogic:ShowToast("toast143", userId)
		elseif itemId == "6_000009" then 
			slot = playerInfo.playerInfo.weaponStorageSlot
			playerInfo:SetStorageSlot("weapon", slot + 10)
			
			_LocalizeLogic:ShowToast("toast147", userId)
		elseif itemId == "7_000003" or itemId == "7_000004" or itemId == "7_000005" or itemId == "7_000006" or itemId == "7_000007" or itemId == "7_000008" or itemId == "7_000009" or
			itemId == "7_000010" or itemId == "7_000011" or itemId == "7_000012" or itemId == "7_000013" or itemId == "7_000014" or itemId == "7_000015" or itemId == "7_000016" or
			itemId == "7_000017" then
			local playerCharacter = playerEntity.PlayerCharacterData
			
			playerCharacter:AddCharPieceCount(tonumber(fixedItem), 1, "SoulPieceExchangeTicket")
			
			self:NoticeGetSoulPieces(fixedItem, 1, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000010" or itemId == "6_000011" or itemId == "6_000012" then 
			_RewardLogic:RequestGetBundleReward(itemData.fixedItem, userId, true)
		elseif itemId == "6_000013" then 
			_GatchaLogic:DoRandomPickDecoration(userId, "damageSkin", 1)
		elseif itemId == "6_000014" then 
			_GatchaLogic:DoRandomPickDecoration(userId, "chatBalloon", 1)
		elseif itemId == "6_000015" then 
			_GatchaLogic:DoRandomPickDecoration(userId, "nameTag", 1)
		elseif itemId == "6_000016" then 
			local count = _UtilLogic:RandomIntegerRange(10, 50)
			local soulTable = {}
			
			for i = 1, count do
				local index = _UtilLogic:RandomIntegerRange(1, #table.keys(_ItemDataLogic.soulDustTable))
				
				if isvalid(soulTable[index]) then
					soulTable[index] = soulTable[index] + 1
				else
					soulTable[index] = 1
				end
			end
		
			for i = 1, #table.keys(_ItemDataLogic.soulDustTable) do
				if isvalid(soulTable[i]) then
					playerStorage:RequestAddItemFromServer(_ItemDataLogic.soulDustTable[i], soulTable[i], _ItemDataLogic.soulDustTable[i], 0, userId, "CONSUMED_SOULDUST_PACK",itemId)
				end
			end
			
			self:ShowDustResults(soulTable, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000017" then 
			local count = _UtilLogic:RandomIntegerRange(250, 350)
			local soulTable = {}
			
			for i = 1, count do
				local index = _UtilLogic:RandomIntegerRange(1, #table.keys(_ItemDataLogic.soulDustTable))
				
				if isvalid(soulTable[index]) then
					soulTable[index] = soulTable[index] + 1
				else
					soulTable[index] = 1
				end
				
				if i % 250 == 0 then
					wait(0.02)
				end
			end
			
			for i = 1, #table.keys(_ItemDataLogic.soulDustTable) do
				if isvalid(soulTable[i]) then
		
					playerStorage:RequestAddItemFromServer(_ItemDataLogic.soulDustTable[i], soulTable[i], _ItemDataLogic.soulDustTable[i], 0, userId, "CONSUMED_MANYSOULDUST_PACK",itemId)
				end
			end
			self:ShowDustResults(soulTable, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000018" then 
			local rand = _UtilLogic:RandomIntegerRange(1, #table.keys(_CharacterLogic.indexAndId))
			local charId = _CharacterLogic.indexAndId[rand]
			local charData = _CharacterLogic.characterTable[tostring(charId)]
			
			playerCharData:AddCharPieceCount(charId, 1, "SoulPiecePocket")
			self:NoticeGetSoulPieces(tostring(charId), 1, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000019" then 
			local rand = _UtilLogic:RandomIntegerRange(1, #table.keys(_CharacterLogic.indexAndId))
			local charId = _CharacterLogic.indexAndId[rand]
			local charData = _CharacterLogic.characterTable[tostring(charId)]
			
			playerCharData:AddCharPieceCount(charId, 5, "SoulPiecePocket")
			self:NoticeGetSoulPieces(tostring(charId), 5, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000020" then 
			local rand = _UtilLogic:RandomIntegerRange(1, #table.keys(_CharacterLogic.indexAndId))
			local charId = _CharacterLogic.indexAndId[rand]
			local charData = _CharacterLogic.characterTable[tostring(charId)]
			
			playerCharData:AddCharPieceCount(charId, 10, "SoulPiecePocket")
			self:NoticeGetSoulPieces(tostring(charId), 10, userId)
		
			self:RefreshInventory(userId)
		elseif itemId == "6_000021" or itemId == "6_000022" or itemId == "6_000023" or itemId == "6_000024" or itemId == "6_000025" or itemId == "6_000026" or itemId == "6_000027" then 
			playerStorage:RequestAddEgg(fixedItem, 10, fixedItem, 1, "", 0, "SouelEggPocket")
		elseif itemId == "6_000028" or itemId == "6_000029" or itemId == "6_000030" or itemId == "6_000031" or itemId == "6_000032" or itemId == "6_000033" or itemId == "6_000034" or itemId == "6_000035"
		 	or itemId == "6_000036" or itemId == "6_000037" or itemId == "6_000038" or itemId == "6_000039" or itemId == "6_000040" or itemId == "6_000041" then
			_RewardLogic:GetBundleReward(itemData.fixedItem, userId, true)
			self:NoticeUseItem(itemData.fixedItem, userId)
			self:RefreshInventory(userId)
		elseif itemId == "8_000001" then 
			local rand = _UtilLogic:RandomDouble() * 100
			local amount = 0
			local itemList = {}
			
			if rand >= 90 then
				amount = 120
			elseif rand >= 70 then
				amount = 100
			elseif rand >= 30 then
				amount = 80
			elseif rand >= 10 then
				amount = 60
			else
				amount = 40
			end
			
			
			itemList[1] = {["itemType"] = "diamond", ["id"] = 0, ["count"] = amount}
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_DIAMOND, amount, userId, "DAILY MISSION POCKET", itemId)
			self:ShowItemListPopUp(itemList, userId)
			self:RefreshInventory(userId)
		elseif itemId == "8_000002" then 
			local rand = _UtilLogic:RandomDouble() * 100
			local amount = 0
			local itemList = {}
			
			if rand >= 90 then
				amount = 280
			elseif rand >= 70 then
				amount = 240
			elseif rand >= 30 then
				amount = 200
			elseif rand >= 10 then
				amount = 160
			else
				amount = 120
			end
			
			itemList[1] = {["itemType"] = "diamond", ["id"] = 0, ["count"] = amount}
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_DIAMOND, amount, userId, "DAILY MISSION POCKET", itemId)
			self:ShowItemListPopUp(itemList, userId)
			self:RefreshInventory(userId)
		elseif itemId == "8_000003" or itemId == "8_000004" then 
			_RewardLogic:RequestGetBundleReward(itemData.fixedItem, userId, true)
		elseif itemId == "8_000005" or itemId == "8_000006" then 
			_RewardLogic:RequestGetBundleReward(itemData.fixedItem, userId, true)
		elseif itemId == "6_000044" then 
			local rand = _UtilLogic:RandomDouble() * 100
			local amount = 0
			local itemList = {}
			
			if rand >= 10 then
				amount = 500
			elseif rand > 1 then
				amount = 1000
			else
				amount = 2000
			end
			
			itemList[1] = {["itemType"] = "diamond", ["id"] = 0, ["count"] = amount}
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_DIAMOND, amount, userId, "USE 2024 POCKET", itemId)
			self:ShowItemListPopUp(itemList, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000045" then 
		    local itemList = {}
			local result = _CharacterGachaLogic:GetCharacter(playerEntity, false, "USE SOUL TICKET")
			
		    itemList[1] = {["itemType"] = "soulPiece", ["id"] = result[1], ["count"] = 1}
			_GatchaLogic:ShowGatchaScene("3", userId) 
			_WorldLog:LogGatchaFlow(userId, "character", "3", "USE SOUL TICKET", itemId, {result[1]})
		    self:ShowItemListPopUp(itemList, userId)
		elseif itemId == "6_000046" then 
		    local itemList = {}
			local result = _ArmorSystemLogic:RequestArmorGacha(userId, false)
			
		
		    itemList[1] = {["itemType"] = "item", ["id"] = result[1], ["count"] = 1}
			_GatchaLogic:ShowGatchaScene("1", userId) 
			_WorldLog:LogGatchaFlow(userId, "armor", "1", "USE ARMOR TICKET", itemId, result)
		    self:ShowItemListPopUp(itemList, userId)
		elseif itemId == "6_000047" then 
			playerEntity.PlayerInfoComponent:AddBuff("2", 1)
		elseif itemId == "6_000048" then 
			playerEntity.PlayerInfoComponent:AddBuff("3", 1)
		elseif itemId == "6_000049" then 
			playerEntity.PlayerInfoComponent:AddBuff("4", 1)
		elseif itemId == "6_000050" then 
			playerEntity.PlayerInfoComponent:AddBuff("5", 1)
		elseif itemId == "6_000051" then 
		elseif itemId == "8_000007" then 
			_RewardLogic:RequestGetBundleReward(itemData.fixedItem, userId, true)
		end
		return true
	end

	@ExecSpace("ServerOnly")
	method void ApplyConsumeItem(string effectId, string userId)
		-- 소비 아이템의 효과를 플레이어에게 적용
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local effectData = self.consumeEffectData[effectId]
		
	end

	@ExecSpace("Client")
	method void ApplyConsumeItemInClient(string effectId)
		-- 클라이언트에서 소비 아이템 효과를 적용
		
	end

	method void OnBeginPlay()
		-- 소비 아이템 효과 데이터를 초기화
		local data = _DataService:GetTable("ConsumeItemEffectData")
		
		for i = 1, data:GetRowCount() do
			local effectData = {}
			
			effectData.id = data:GetCell(i,"id")
			effectData.name = data:GetCell(i,"name")
			effectData.description = data:GetCell(i, "description")
			effectData.duration = tonumber(data:GetCell(i, "duration"))
			effectData.ruid = data:GetCell(i,"ruid")
		
			effectData.offsetX = tonumber(data:GetCell(i, "offsetX"))
			effectData.offsetY = tonumber(data:GetCell(i, "offsetY"))
			
			self.consumeEffectData[effectData.id] = effectData
		end
		
	end

	@ExecSpace("ServerOnly")
	method boolean IsCanUseItemInServer(string itemId, integer count, string userId)
		-- 서버에서 아이템 사용 가능 여부를 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local playerStorage = playerEntity.PlayerStorageComponent
		local playerCharData = playerEntity.PlayerCharacterData
		local playerQuest = playerEntity.PlayerQuestComponent
		local itemData = _ItemDataLogic.itemData[itemId]
		local fixedItem = itemData.fixedItem
		local category = itemData.category
		local splitId = _UtilLogic:Split(itemId, "_")
		if not isvalid(playerEntity) then
			
			return false
		end
		
		if category == "decoration" then
			return true
		end
		
		local playerInfo = playerEntity.PlayerInfoComponent
		local slot = 0
		local canUse = false
		
		if itemId == "6_000001" then 
			if tonumber(playerQuest.currentQuestId) < 44 then
				local questId = "43"
				self:ShowQuestMessageInClient(questId,userId)
				
				canUse = false
			else
				canUse = true
			end
		elseif itemId == "6_000002" then 
			canUse = true
		elseif itemId == "6_000003" then 
			canUse = _CheckLogic:IsEnoughPetSlot(userId, count)
			
			if not canUse then
				_LocalizeLogic:ShowToast("toast124", userId)
			end
		elseif itemId == "6_000004" then 
			canUse = _CheckLogic:IsEnoughPetSlot(userId, count * 11)
			
			if not canUse then
				_LocalizeLogic:ShowToast("toast124", userId)
			end
		elseif itemId == "6_000005" or itemId == "6_000006" or itemId == "6_000007" or itemId == "6_000008" then 
			canUse = true
		elseif itemId == "6_000009" then 
			_LocalizeLogic:ShowToast("toast144", userId)
			
			canUse = false
		elseif itemId == "7_000003" or itemId == "7_000004" or itemId == "7_000005" or itemId == "7_000006" or itemId == "7_000007" or itemId == "7_000008" or itemId == "7_000009" or
			itemId == "7_000010" or itemId == "7_000011" or itemId == "7_000012" or itemId == "7_000013" or itemId == "7_000014" or itemId == "7_000015" or itemId == "7_000016" or
			itemId == "7_000017" then 
			
			canUse = true
		elseif itemId == "6_000010" or itemId == "6_000011" or itemId == "6_000012" then 
			canUse = _CheckLogic:IsEnoughDecorationSlot(userId, 3 * count)
		elseif itemId == "6_000013" or itemId == "6_000014" or itemId == "6_000015" then 
			canUse = _CheckLogic:IsEnoughDecorationSlot(userId, count)
		elseif itemId == "6_000016" then 
			local maxCount = 50 * count
			local countDivision = math.ceil(maxCount / 1000)
			local needSlot = #table.keys(_CharacterLogic.indexAndId) - 1 + countDivision
			
			canUse = _CheckLogic:IsEnoughETCSlot(userId, needSlot)
		elseif itemId == "6_000017" then 
			local maxCount = 350 * count
			local countDivision = math.ceil(maxCount / 1000)
			local needSlot = #table.keys(_CharacterLogic.indexAndId) - 1 + countDivision
			
			canUse = _CheckLogic:IsEnoughETCSlot(userId, needSlot)
		elseif itemId == "6_000018" or itemId == "6_000019" or itemId == "6_000020" then 
			canUse = true
		elseif itemId == "6_000021" or itemId == "6_000022" or itemId == "6_000023" or itemId == "6_000024" or itemId == "6_000025" or itemId == "6_000026" or itemId == "6_000027" then 
			canUse = true
		elseif itemId == "6_000028" or itemId == "6_000029" or itemId == "6_000030" or itemId == "6_000031" or itemId == "6_000032" or itemId == "6_000033" or itemId == "6_000034" or itemId == "6_000035"
		 	or itemId == "6_000036" or itemId == "6_000037" or itemId == "6_000038" or itemId == "6_000039" or itemId == "6_000040" or itemId == "6_000041" then
			
			canUse = _CheckLogic:IsEnoughConsumeSlot(userId, count) 
		elseif itemId == "8_000001" or itemId == "8_000002" then
			canUse = true
		elseif itemId == "8_000003" then 
			canUse = _CheckLogic:IsEnoughConsumeCount(userId, count * 5, itemId)
		elseif itemId == "8_000004" then 
			canUse = _CheckLogic:IsEnoughConsumeCount(userId, count * 15, itemId)
		elseif itemId == "6_000044" then 
			return true
		elseif itemId == "6_000045" then 
			return true
		elseif itemId == "6_000046" then 
			canUse = _CheckLogic:IsEnoughArmorSlot(userId, count)
			
			if not canUse then
				_LocalizeLogic:ShowToast("toast125", userId)
			end
		elseif itemId == "6_000047" then 
			return true
		elseif itemId == "6_000048" then 
			return true
		elseif itemId == "6_000049" then 
			return true
		elseif itemId == "6_000050" then 
			return true
		elseif itemId == "6_000051" then 
			return true
		elseif itemId == "8_000005" or itemId == "8_000006" then 
			return true
		elseif itemId == "8_000007" then 
			canUse = _CheckLogic:IsEnoughConsumeCount(userId, count * 20, "6_000001")
		elseif splitId[1] == "104" then
			if itemId == "104_000026" then
				local ability = playerEntity.PlayerAbilityComponent.ability
				if ability["lvData"].baggageSlot + count > _AbilityLogic.maxBaggaeSlotCount then
					self:NoticeNotEnoughBaggageSlot(userId)
		
					return false
				end
			end
			
			if itemData.option ~= nil and (itemData.option.type == "HP" or  itemData.option.type == "MP") then
				local multiPlayer = playerEntity.MultiBattlePlayer
				if isvalid(multiPlayer) then
					return multiPlayer:IsEnableUsedPotion(itemData.option.type)
				end
			end
			
			return true
		end
		
		
		return canUse
	end

	@ExecSpace("Client")
	method void ShowDustResults(table result)
		-- 소울 더스트 획득 결과를 UI로 표시
		local infos = {}
		
		for key, value in pairs(result) do
			infos[key] = {["id"] = _ItemDataLogic.soulDustTable[key], ["itemType"] = "item", ["count"] = value}
		end
		
		_ItemListPopUp:Open(infos, nil, "획득")
	end

	@ExecSpace("Client")
	method void RefreshInventory()
		-- 인벤토리 UI를 새로고침
		if _UIGroupManager.playerStatusPopup.UIPlayerStatusPopup.isOpen then
			_UIGroupManager.playerStatusPopup.UIPlayerStatusPopup.inventoryList:Refresh()
		end
	end

	@ExecSpace("ClientOnly")
	method boolean IsCanUseItemInClient(string itemId, integer count)
		-- 클라이언트에서 아이템 사용 가능 여부를 확인
		local playerEntity = _UserService.LocalPlayer
		local userId = playerEntity.PlayerComponent.UserId
		local playerStorage = playerEntity.PlayerStorageComponent
		local playerCharData = playerEntity.PlayerCharacterData
		local playerQuest = playerEntity.PlayerQuestComponent
		local itemData = _ItemDataLogic.itemData[itemId]
		local fixedItem = itemData.fixedItem
		local category = itemData.category
		local splitId = _UtilLogic:Split(itemId, "_")
		if not isvalid(playerEntity) then
			
			return false
		end
		
		if category == "decoration" then
			return true
		end
		
		local playerInfo = playerEntity.PlayerInfoComponent
		local slot = 0
		local canUse = false
		
		if itemId == "6_000001" then 
			if #_UserService.LocalPlayer.PlayerStorageComponent:GetAllEquippedWeapon() < 1 then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast52"))
				
				canUse = false
			else
				if tonumber(playerQuest.currentQuestId) < 44 then
					local questId = "43"
					local questName = "#".._QuestLogic.questData[questId].id.." ".._LocalizationService:GetText("quest_"..questId.."_name")
					local str = string.format(_LocalizeLogic:GetText("toast135"), questName)
					_UIToast:ShowMessage(str)
					
					canUse = false
				else
					canUse = true
				end
			end
		elseif itemId == "6_000002" then 
			canUse = true
		elseif itemId == "6_000003" then 
			canUse = _CheckLogic:IsEnoughPetSlot(userId, count)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast124"))
			end
		elseif itemId == "6_000004" then 
			canUse = _CheckLogic:IsEnoughPetSlot(userId, count * 11)
			
			if not canUse then
		
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast124"))
			end
		elseif itemId == "6_000005" or itemId == "6_000006" or itemId == "6_000007" or itemId == "6_000008" then 
			canUse = true
		elseif itemId == "6_000009" then 
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast144"))
			
			canUse = false
		elseif itemId == "7_000003" or itemId == "7_000004" or itemId == "7_000005" or itemId == "7_000006" or itemId == "7_000007" or itemId == "7_000008" or itemId == "7_000009" or
			itemId == "7_000010" or itemId == "7_000011" or itemId == "7_000012" or itemId == "7_000013" or itemId == "7_000014" or itemId == "7_000015" or itemId == "7_000016" or
			itemId == "7_000017" then 
			
			canUse = true
		elseif itemId == "6_000010" or itemId == "6_000011" or itemId == "6_000012" then 
			canUse = _CheckLogic:IsEnoughDecorationSlot(userId, 3 * count)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast146"))
			end
		elseif itemId == "6_000013" or itemId == "6_000014" or itemId == "6_000015" then 
			canUse = _CheckLogic:IsEnoughDecorationSlot(userId, count)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast146"))
			end
		elseif itemId == "6_000016" then 
			if count > 500 then
				canUse = false
				
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast133"))
				return canUse
			end
			
			local maxCount = 50 * count
			local countDivision = math.ceil(maxCount / 1000)
			local needSlot = #table.keys(_CharacterLogic.indexAndId) - 1 + countDivision
			
			canUse = _CheckLogic:IsEnoughETCSlot(userId, needSlot)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast122"))
			end
		elseif itemId == "6_000017" then 
			if count > 150 then
				canUse = false
				
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast133"))
				return canUse
			end
			
			local maxCount = 350 * count
			local countDivision = math.ceil(maxCount / 1000)
			local needSlot = #table.keys(_CharacterLogic.indexAndId) - 1 + countDivision
			
			canUse = _CheckLogic:IsEnoughETCSlot(userId, needSlot)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast122"))
			end
		elseif itemId == "6_000018" or itemId == "6_000019" or itemId == "6_000020" then 
			canUse = true
		elseif itemId == "6_000021" or itemId == "6_000022" or itemId == "6_000023" or itemId == "6_000024" or itemId == "6_000025" or itemId == "6_000026" or itemId == "6_000027" then 
			canUse = true
		elseif itemId == "6_000028" or itemId == "6_000029" or itemId == "6_000030" or itemId == "6_000031" or itemId == "6_000032" or itemId == "6_000033" or itemId == "6_000034" or itemId == "6_000035"
		 	or itemId == "6_000036" or itemId == "6_000037" or itemId == "6_000038" or itemId == "6_000039" or itemId == "6_000040" or itemId == "6_000041" then
			
			canUse = _CheckLogic:IsEnoughConsumeSlot(userId, count)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast122"))
			end
		elseif itemId == "8_000001" or itemId == "8_000002" then  
			canUse = true
		elseif itemId == "8_000003" then 
			canUse = _CheckLogic:IsEnoughConsumeCount(userId, count * 5, itemId)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast122"))
			end
		elseif itemId == "8_000004" then 
			canUse = _CheckLogic:IsEnoughConsumeCount(userId, count * 15, itemId)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast122"))
			end
		elseif itemId == "6_000044" then 
			return true
		elseif itemId == "6_000045" then 
			return true
		elseif itemId == "6_000046" then 
			canUse = _CheckLogic:IsEnoughArmorSlot(userId, count)
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast125"))
			end
		elseif itemId == "6_000047" then 
			return true
		elseif itemId == "6_000048" then 
			return true
		elseif itemId == "6_000049" then 
			return true
		elseif itemId == "6_000050" then 
			return true
		elseif itemId == "6_000051" then 
			return true
		elseif itemId == "8_000005" or itemId == "8_000006" then 
			return true
		elseif itemId == "8_000007" then 
			canUse = _CheckLogic:IsEnoughConsumeCount(userId, count * 20, "6_000001")
			
			if not canUse then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast122"))
			end
		elseif splitId[1] == "104" then
			return true
		end
		
		return canUse
	end

	@ExecSpace("Client")
	method void ShowItemListPopUp(table itemList)
		-- 아이템 획득 팝업을 표시
		_ItemListPopUp:Open(itemList, nil, "획득")
	end

	@ExecSpace("ServerOnly")
	method boolean TryUseDustPocket(string itemId, string userId, integer count)
		-- 소울 더스트 주머니 아이템을 사용 시도
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local playerStorage = playerEntity.PlayerStorageComponent
		local itemData = _ItemDataLogic.itemData[itemId]
		local fixedItem = itemData.fixedItem
		local category = itemData.category
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		if itemId == "6_000016" then 
			local randNum = _UtilLogic:RandomIntegerRange(10, 50)
			local soulTable = {}
			
			for i = 1, randNum do
				local index = _UtilLogic:RandomIntegerRange(1, #table.keys(_ItemDataLogic.soulDustTable))
				
				if isvalid(soulTable[index]) then
					soulTable[index] = soulTable[index] + 1
				else
					soulTable[index] = 1
				end
			end
		
			for i = 1, #table.keys(_ItemDataLogic.soulDustTable) do
				if isvalid(soulTable[i]) then
					playerStorage:RequestAddItemFromServer(_ItemDataLogic.soulDustTable[i], soulTable[i], _ItemDataLogic.soulDustTable[i], 0, userId, "CONSUMED_SOULDUST_PACK",itemId)
				end
			end
			
			self:ShowDustResults(soulTable, userId)
			self:RefreshInventory(userId)
		elseif itemId == "6_000017" then 
			local randNum = _UtilLogic:RandomIntegerRange(250, 350)
			local soulTable = {}
			
			for i = 1, randNum do
				local index = _UtilLogic:RandomIntegerRange(1, #table.keys(_ItemDataLogic.soulDustTable))
				
				if isvalid(soulTable[index]) then
					soulTable[index] = soulTable[index] + 1
				else
					soulTable[index] = 1
				end
				
				if i % 250 == 0 then
					wait(0.02)
				end
			end
			
			for i = 1, #table.keys(_ItemDataLogic.soulDustTable) do
				if isvalid(soulTable[i]) then
					playerStorage:RequestAddItemFromServer(_ItemDataLogic.soulDustTable[i], soulTable[i], _ItemDataLogic.soulDustTable[i], 0, userId, "CONSUMED_MANYSOULDUST_PACK",itemId)
				end
			end
			self:ShowDustResults(soulTable, userId)
			self:RefreshInventory(userId)
		end
		
		return true
	end

	@ExecSpace("Server")
	method void RequestUseSelectiveSoulPieceTicket(table selectedSouls)
		-- 선택형 소울 조각 티켓 사용 요청을 처리
		local user = _UserService:GetUserEntityByUserId(senderUserId)
		
		if not isvalid(user) then
			
			return
		end
		
		local count = 0
		
		for key, value in pairs(selectedSouls) do
			count += value
		end
		
		if user.PlayerStorageComponent:GetItemCount("6_000051") < count then
			_UIToast:ShowMessage("Invalid Request.", senderUserId)
			
			return
		else
			local info = {}
			local i = 1
			
			user.PlayerStorageComponent:RemoveItemById("6_000051", count, "CONSUME")
			for key, value in pairs(selectedSouls) do
				user.PlayerCharacterData:AddCharPieceCount(key, value, "6_000051")
				info[i] = {["id"] = tostring(key), ["itemType"] = "soulPiece", ["count"] = value}
				
				i += 1
			end
			
			self:ShowSelectiveSoulPieceTicketResult(info, senderUserId)
		end
	end

	@ExecSpace("Client")
	method void ShowSelectiveSoulPieceTicketResult(table info)
		-- 선택형 소울 조각 티켓 결과를 표시
		_ItemListPopUp:Open(info, nil, "획득")
	end

	@ExecSpace("ServerOnly")
	method boolean UseFieldConsumeItem(string itemId, integer count, string userId)
		-- 필드에서 소비 아이템을 사용
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		if not isvalid(playerEntity) then
			return false
		end
		local multiBattlePlayer = playerEntity.MultiBattlePlayer
		
		if itemId == "104_000026" then 
			_AbilityLogic:RequestExtendBaggageSlot(userId, count)
			return true
		end
		
		if isvalid(multiBattlePlayer) then
			multiBattlePlayer:OnUseFieldItem(itemId,count)
		end
		return true
	end

