@Logic
script ItemDataLogic extends Logic

	@HideFromInspector
	property table equipmentData = {}

	property table itemData = {}

	property table armorData = {}

	property table equipmentOptionData = {}

	property table weaponLevelUpData = {}

	property table decorationData = {}

	property table soulDustTable = {}

	property table soulPieceTable = {}

	property table weaponMesoTable = {}

	method void OnBeginPlay()
		-- 아이템 관련 데이터를 초기화
		local data = _DataService:GetTable("EquipmentData")
		
		local mergeId = nil
		for i = 1, data:GetRowCount() do
			local item = {}
			
			item.id = data:GetCell(i,"id")
			item.name = data:GetCell(i,"name")
		
			item.mergeLevel = tonumber(data:GetCell(i, "mergeLevel"))
			item.grade = data:GetCell(i, "grade")
			item.sellingPrice = tonumber(data:GetCell(i, "sellingPrice"))
			item.buyingPrice = tonumber(data:GetCell(i, "buyingPrice"))
			item.category = data:GetCell(i, "category")
			item.detailCategory = data:GetCell(i, "detailCategory")
			item.nextEquipment = data:GetCell(i, "nextEquipment")
			item.effectSound = data:GetCell(i, "effectSound")
			item.maxStar = tonumber(data:GetCell(i, "maxStar"))
			item.star = data:GetCell(i, "star")
			item.scale = data:GetCell(i, "scale")
			item.ruid = data:GetCell(i, "ruid")
			if self:IsClient() and Environment:IsPCPlatform() then
				local pcRUID = data:GetCell(i, "ruid_pc_only")
				if _UtilLogic:IsNilorEmptyString(pcRUID) == false then
					item.ruid = pcRUID
				end
			end
			item.outglow = data:GetCell(i, "outglow")
			item.mergeGroup = data:GetCell(i, "mergeGroup")
			item.mergeId = data:GetCell(i, "mergeId")
			item.minLevel = tonumber(data:GetCell(i,"minLevel"))
			item.maxLevel = tonumber(data:GetCell(i,"maxLevel"))
			
			self.equipmentData[item.id] = item
		end
		
		
		for k,v in pairs(self.equipmentData) do
			if _UtilLogic:IsNilorEmptyString(v.nextEquipment) == false then
				self.equipmentData[v.nextEquipment].previousEquipment = v.id
			end
		end
		
		data = _DataService:GetTable("ItemData")
		
		for i = 1, data:GetRowCount() do
			local item = {}
			
			item.id = data:GetCell(i,"id")
			item.name = data:GetCell(i,"name")
			item.grade = data:GetCell(i, "grade")
			item.description = data:GetCell(i, "description")
			item.sellingPrice = tonumber(data:GetCell(i, "sellingPrice"))
			item.buyingPrice = tonumber(data:GetCell(i, "buyingPrice"))
			item.category = data:GetCell(i, "category")
			item.scale = tonumber(data:GetCell(i, "scale"))
			item.minLevel = data:GetCell(i, "minLevel")
			item.ruid = data:GetCell(i, "ruid")
			item.outglow = data:GetCell(i, "outglow")
			item.fixedItem = data:GetCell(i,"fixedItem")
			item.offsetX = tonumber(data:GetCell(i, "offsetX"))
			item.offsetY = tonumber(data:GetCell(i, "offsetY"))
			item.notNoticeUse = data:GetCell(i, "notNoticeUse")
			item.expireDate = data:GetCell(i, "expireDate")
			local option = data:GetCell(i,"option")
			item.option = _UtilLogic:IsNilorEmptyString(option) and {} or _HttpService:JSONDecode(option)
			self.itemData[item.id] = item
			
			if _UtilLogic:Contains(item.id, "7_") then
				table.insert(self.soulPieceTable, item.id)
			elseif _UtilLogic:Contains(item.id, "9_") then
				if item.id ~= "9_000016" and item.id ~= "9_000017" then
					table.insert(self.soulDustTable, item.id)
				end
			end
		end
		
		
		data = _DataService:GetTable("EquipmentOptionDescriptionData")
		
		for i = 1, data:GetRowCount() do
			local option = {}
			option.name = data:GetCell(i,"name")
			option.option_1 = data:GetCell(i, "option_1")
			option.option_2 = data:GetCell(i, "option_2")
			option.option_3 = data:GetCell(i, "option_3")
			option.option_4 = data:GetCell(i, "option_4")
			option.option_5 = data:GetCell(i, "option_5")
			
			self.equipmentOptionData[option.name] = option
		end
		
		data = _DataService:GetTable("WeaponLevelUpData")
		
		for i = 1, data:GetRowCount() do
			local expData = {}
			expData.level = tonumber(data:GetCell(i, "level"))
			expData.sellPrice = tonumber(data:GetCell(i, "sellPrice"))
			expData.atk = tonumber(data:GetCell(i, "atk"))	
			expData.needExp = tonumber(data:GetCell(i, "needExp"))
			expData.total = tonumber(data:GetCell(i, "total"))
		
			self.weaponLevelUpData[expData.level] = expData
		end
		
		data = _DataService:GetTable("DecorationData")
		
		for i = 1, data:GetRowCount() do
			local decoration = {}
			
			decoration.id = data:GetCell(i,"id")
			decoration.ruid = data:GetCell(i,"ruid")
			decoration.category = data:GetCell(i, "category")
			decoration.color = string.sub(data:GetCell(i, "color"), 1, 7) 
			decoration.exception = data:GetCell(i, "exception")
			
			if not _UtilLogic:IsNilorEmptyString(data:GetCell(i, "offsetX")) then
				decoration.offsetX = tonumber(data:GetCell(i, "offsetX"))
			else
				decoration.offsetX = 0
			end
			if not _UtilLogic:IsNilorEmptyString(data:GetCell(i, "offsetY")) then
				decoration.offsetY = tonumber(data:GetCell(i, "offsetY"))
			else
				decoration.offsetY = 0
			end
			
			self.decorationData[decoration.id] = decoration
		end
		
		data = _DataService:GetTable("WeaponMesoPriceData")
		
		for i = 1, data:GetRowCount() do
			local weaponMesoInfo = {}
			
			weaponMesoInfo.level = tonumber(data:GetCell(i,"level"))
			weaponMesoInfo.sellingPrice = tonumber(data:GetCell(i,"sellingPrice"))
			
			self.weaponMesoTable[weaponMesoInfo.level] = weaponMesoInfo
		end
	end

	method table GetItemData(string id)
		-- 아이템 ID로 아이템 데이터를 조회
		
		if self.equipmentData[id] ~= nil then
			return self.equipmentData[id]
		end
		
		
		if self.itemData[id] ~= nil then
			return self.itemData[id]
		end
		
		return nil
	end

	method number GetWeaponMaxExp(number lv)
		-- 무기 레벨에 따른 최대 경험치를 반환
		if lv == 0 then
			return self.weaponLevelUpData[1].total
		end
		
		if lv > _GameConfig:GetConfig().MAX_ITEM_LEVEL then
			return math.maxinteger
		end
		
		if self.weaponLevelUpData[lv] == nil then
			return self.weaponLevelUpData[1].total
		end
		return self.weaponLevelUpData[lv].total
	end

	method table GetUniqueKeyListByFiltering(string type, Entity player)
		-- 특정 타입으로 필터링된 고유키 목록을 반환
		local uniqueKeyList = {}
		local storage = player.PlayerStorageComponent.storage
		
		for key, value in pairs(storage) do
			local itemData = self:GetItemData(value.originalId)
			if itemData.detailCategory == type then
				table.insert(uniqueKeyList, value.uniqueKey) 
			end
		end
		
		return uniqueKeyList
	end

	method string GetUniqueKeyBySlotNum(integer slotNum, Entity player)
		-- 슬롯 번호로 장착된 아이템의 고유키를 반환
		local uniqueKey = ""
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		
		for key, value in pairs(storage) do
			if value.equippedSlotNum == slotNum then
				uniqueKey = value.uniqueKey 
				break
			end
		end
		
		return uniqueKey
	end

	method string GetWeaponRuidByEquipmentData(string id)
		-- 장비 데이터에서 무기 RUID를 반환
		local ruid = _UtilLogic:Split(id, "_")
		
		if ruid[1] == "2" then
			return _ArmorSpecLogic.armorData[id].ruid
		elseif ruid[1] == "1" then
			if _UtilLogic:IsNilorEmptyString(self.equipmentData[id].ruid) then
				return _WeaponSpecLogic.weaponData[id].ruid 
			else
				return self.equipmentData[id].ruid
			end
		end
		
	end

	method table GetUniqueKeyListByCategory(string category, string userId)
		-- 카테고리별로 고유키 목록을 반환
		
		local user = _UserService:GetUserEntityByUserId(userId)
		local targetStorage = {}
		local uniqueKeyList = {}
		
		if category == "armor" or category == "accessory" then
			targetStorage = user.PlayerStorageComponent.storage
		elseif category == "pet" then
			targetStorage = user.PlayerPetStorageComponent.petInventory	
		end
		
		
		for key, value in pairs(targetStorage) do 
			local str = _UtilLogic:Split(value.originalId, "_")
			
			if str[1] == "2" and category == "armor" then
				table.insert(uniqueKeyList, value)
			end
		end
		
		local arrangeList = {}
		
		table.sort(uniqueKeyList, function(a, b)
			return a.inventoryNum < b.inventoryNum  
		end)
		
		for i = 1 , #uniqueKeyList do
			table.insert(arrangeList, uniqueKeyList[i].uniqueKey)
		end
		
		return arrangeList
	end

	method table GetWeaponLevelUpData(number lv)
		-- 무기 레벨업 데이터를 반환
		return self.weaponLevelUpData[lv]
	end

	method string GetItemCategory(string itemId)
		-- 아이템 ID로 카테고리를 반환
		if isvalid(self.itemData[itemId]) == false then return end
		
		local category = self.itemData[itemId].category
		
		if not isvalid(category) then
			local prefix = _UtilLogic:Split(itemId, "_")[1]
			
			if prefix == "1" then
				return "weapon"
			elseif prefix == "2" then
				return "armor"
			end
		end
		
		if category == "egg" then
			return "egg"
		elseif category == "scroll" then
			return "wealth"
		elseif category == "decoration" then
			return "decoration"
		elseif category == "consume" then
			return "consume"
		elseif category == "accessory" then
			return "accessory"
		else 
			return "etc"
		end
	end

	method string GetItemNameById(string itemId)
		-- 아이템 ID로 아이템 이름을 반환
		local data = self:GetItemData(itemId)
		if data == nil then
			return
		end
		return data.name
	end

	method string GetCategoryColorRUID(string itemId)
		-- 아이템 등급에 따른 색상 RUID를 반환
		
		local grade = "normal"
		
		if isvalid(self.equipmentData[itemId]) then
			grade = _UtilLogic:Split(self.equipmentData[itemId].grade, "_")[1]
		elseif isvalid(self.itemData[itemId]) then
			grade = self.itemData[itemId].grade
		end
		
		if grade == "normal" then
			return "f8410525a90f4e2e8be0ae22623944f3"
		elseif grade == "rare" then
			return "ba1e2518b27b4120b67f68d8a1052cac"
		elseif grade == "epic" then
			return "6dcc398f8a4742cbbcef50c1beea4ecb"
		elseif grade == "unique" then
			return "d63b74fe7d62434dba266585dbd7bba2"
		elseif grade == "legendary" then
			return "267e7186eac54d24a83968c66febc10c"
		end
	end

	method boolean CheckItemEquipped(string uniqueKey, Entity player, integer enum)
		-- 아이템이 장착되어 있는지 확인
		
		
		if enum == 1 or enum == 2 or enum == 5 then
			local storage = player.PlayerStorageComponent.storage
			for key , value in pairs(storage) do
				if key == uniqueKey then
					if value.equippedSlotNum > 0 then
						return true
					end
				end
			end
		else
			local petStorage = player.PlayerPetStorageComponent.petInventory
			for key , value in pairs(petStorage) do
				if key == uniqueKey then
					if value.equippedSlotNum > 0 then
						return true
					end
				end
			end
		end
		
		return false
	end

	method string GetCoinRUID(string type)
		-- 화폐 타입에 따른 RUID를 반환
		if type == "meso" then
			return "bdac712ae9564f6c88e1bb2c7387d61a"
		elseif type == "scroll" then
			return "065d2794b61842539640a7d71992809d"
		elseif type == "stone" then 
			return "f70af980ea3c40a986f7615d53501b5e"
		elseif type == "diamond" then
			return "cba4f8c4a4104443862d7db244848cf4"
		elseif type == "fieldGem" then
			return "c65ac390fbfd4e97963c711c05ebaac5"
		end
	end

	method string GetCategoryColorRUIDByGrade(string grade)
		-- 등급에 따른 카테고리 색상 RUID를 반환
		if grade == "normal" then
			return "f8410525a90f4e2e8be0ae22623944f3"
		elseif grade == "rare" then
			return "ba1e2518b27b4120b67f68d8a1052cac"
		elseif grade == "epic" then
			return "6dcc398f8a4742cbbcef50c1beea4ecb"
		elseif grade == "unique" then
			return "d63b74fe7d62434dba266585dbd7bba2"
		elseif grade == "legendary" then
			return "267e7186eac54d24a83968c66febc10c"
		end
	end

	method string GetAccessoryDetailCategory(string itemId)
		-- 액세서리의 세부 카테고리를 반환
		local splits = _UtilLogic:Split(itemId, "_")[1]
		
		if splits == "101" then
			return "ring"
		elseif splits == "102" then
			return "earring"
		elseif splits == "103" then
			return "necklace"
		end
	end

	method integer GetAccessoryEquipSlotNum(string itemId)
		-- 액세서리의 장착 슬롯 번호를 반환
		local detailCategory = self:GetAccessoryDetailCategory(itemId)
		
		if detailCategory == "ring" then
			return _GameEnum.EQUIPNUM_RING
		elseif detailCategory == "earring" then
			return _GameEnum.EQUIPNUM_EARRING
		elseif detailCategory == "necklace" then
			return _GameEnum.EQUIPNUM_NECKLACE
		end
	end

	method table GetFieldItemUniqueKeyList(integer categoryNum, string userId)
		-- 필드 아이템의 고유키 목록을 카테고리별로 반환
		local player = _UserService:GetUserEntityByUserId(userId)
		local storage = player.PlayerStorageComponent.storage
		local itemData = _ItemDataLogic.itemData
		local temp = {}
		
		
		
		for key, value in pairs(storage) do 
			if isvalid(itemData[value.originalId]) then
				if _CheckLogic:IsFieldItem(value.originalId) then
					if categoryNum == 1 then
						table.insert(temp, value.uniqueKey)
					elseif categoryNum == 2 then
						if itemData[value.originalId].category == "consume" then
							table.insert(temp, value.uniqueKey)
						end
					elseif categoryNum == 3 then
						if itemData[value.originalId].category == "ingredient" then
							table.insert(temp, value.uniqueKey)
						end
					elseif categoryNum == 4 then
						if itemData[value.originalId].category == "etc" or itemData[value.originalId].category == "magicStone" then
							table.insert(temp, value.uniqueKey)
						end
					end
				end
			end
		end
		
		return temp
	end

	method integer GetGradeNum(string grade)
		-- 등급 문자열을 숫자로 변환
		if grade == "normal" or grade == "B" then
			return 1
		elseif grade == "rare" or grade == "A" then
			return 2
		elseif grade == "epic" or grade == "S" then
			return 3
		elseif grade == "unique" or grade == "SS" then
			return 4
		elseif grade == "legendary" or grade == "SSS" then
			return 5
		end
		
		return 0
	end

	@ExecSpace("ClientOnly")
	method string GetCategoryRUID(string category)
		-- 카테고리에 따른 RUID를 반환
		if category == "material" or category == "magicStone" then
			return "0ed03b578a4148c6876ae0158158ea3d"
		elseif category == "etc" then
			return "e6842de3a1e14624b9abbb328e878e8f"
		elseif category == "ring" or category == "accessory" then
			return "0c7ad746be6d4b468b9ce61f44dfc5c4"
		elseif category == "earring" then
			return "a1ba298b9759433c9d6ef856fe7932a0"
		elseif category == "necklace" then
			return "3ee30c8fa960482e81f448a5f0585f22"
		elseif category == "chatBalloon" then
			return "30f4265a088846bfb9faefdcd6381748"
		elseif category == "damageSkin" then
			return "77f57b2a6a9e4db7a86da5a327d1e677"
		elseif category == "nameTag" then
			return "bd2317f490ae46d2ade4fda1e0e2e889"
		elseif category == "decoration" then
			return "629e86bc9590476fb2fd629a97b06676"
		elseif category == "pet" then
			return "87cf429145814827a1b159aac55234b3"
		elseif category == "shoes" then
			return "0a659c8e91944c598b5008e0e3d2aff9"
		elseif category == "suit" or category == "armor" then
			return "9e43df083ac14fdf9927c04fe947ad71"
		elseif category == "helmet" then
			return "01b29b2ec80b4b6b9836805b1dd3b628"
		elseif category == "glove" then
			return "3d24b6f557b5459195e6ad21f92ec7f5"
		elseif category == "consume" or category == "usable" then
			return "7c4e6cfd278b4b77be07a5791d6c3915"
		elseif category == "egg" or category == "soulEgg" then
			return "0b8b08a13e6b4e259221f661900836d2"
		elseif category == "weapon" then
			return "f8b9df6c92fd48dca8ff866d614fb36d"
		end
		
		return ""
	end

	@ExecSpace("ClientOnly")
	method string GetColorCodeByGrade(string grade)
		-- 등급에 따른 색상 코드를 반환
		if grade == "normal" or grade == "B" then
			return "#222630"
		elseif grade == "rare" or grade == "A" then
			return "#40652d"
		elseif grade == "epic" or grade == "S" then
			return "#2860b1"
		elseif grade == "unique" or grade == "SS" then
			return "#7d11bd"
		elseif grade == "legendary" or grade == "SSS" then
			return "#852821"
		end
		
		return "#FFFFFF"
	end

end