@Logic
script CheatLogic extends Logic

	property Entity cheatUI = "b7059f28-0f1b-48f4-9eee-aef7279e1929"

	property Entity inputUI = "ad03c136-d87f-4cf6-900c-4122225d087f"

	property boolean Life_Cheat = false

	property boolean Boss_Test_Cheat = false

	property TextComponent smiulateText = "78a255d5-a7f5-4add-b535-eab353c68e88"

	property Entity F7Button = "761939ad-d421-4dd8-80f0-a006eef6740e"

	@ExecSpace("Server")
	method void OnCheatKey(Entity user, string cheatKey, string inputText)
		-- 치트 키 입력 처리 (다양한 개발자 치트 명령 실행)
		if self:IsEnableCheat(senderUserId) == false then
			return
		end
		
		local showDefaultMessage = true
		
		if cheatKey == "SaveForceDB" then
			user.PlayerDBComponent:SaveAllData(false)
		elseif cheatKey == "Barricade" then
				for k,v in pairs(user.CurrentMap.Children) do
					if v.BarricadeComponent ~= nil then
							v.BarricadeComponent:DestroyStatue(user.PlayerComponent.UserId)
				local barricadeNum = 4
				if v.BarricadeComponent.barricadeNum % 4 ~= 0 then
					barricadeNum = v.BarricadeComponent.barricadeNum % 4
				end
				user.PlayerFieldMapComponent:UpdateBarricadeData(_MultiMapDataLogic.multiMapData[v.CurrentMapName].mapNum,barricadeNum)
				end
			end
		elseif cheatKey == "kiteReset" then
			local db = _DataStorageService:GetUserDataStorage(senderUserId)
			db:DeleteAndWait(_KiteFlyEventLogic.dbKey)
			user.KiteFlyPlayerComponent.time = 0
		elseif cheatKey == "BuffReset" then 	
			local multiPlayer = user.MultiBattlePlayer
			for k,v in pairs(user.PlayerInfoComponent.playerInfo.fieldBuff) do
				v.time = _LocalTimeLogic:GetElapsedSecond() + 1
				if isvalid(multiPlayer) then
					multiPlayer:SetBuff(v.id,v.time)
				end
			end
		
		elseif cheatKey == "BuffCheck" then  
			local multiplayer = user.MultiBattlePlayer
			_SystemMessageLogic:ShowMessage(string.format("현재 스피드는 %f%%입니다.", (multiplayer:GetBuffValue("Speed") + 1)* 100),"neg")	
			_SystemMessageLogic:ShowMessage(string.format("현재 공격력은 %f%% 입니다.", (multiplayer:GetBuffValue("Atk") + 1)* 100),"neg")	
			_SystemMessageLogic:ShowMessage(string.format("현재 경험치 버프는 %f%%입니다.", (multiplayer:GetBuffValue("EXP") + 1)* 100),"neg")	
			_SystemMessageLogic:ShowMessage(string.format("현재 치확증가량은 %f%% 입니다.", (multiplayer:GetBuffValue("Critical") + 1)* 100),"neg")	
			
			
			
		elseif cheatKey == "KiteNumberUp" then
			local kiteNumber = tonumber(inputText)
			local db = _DataStorageService:GetSortableDataStorage(_KiteFlyEventLogic.sortableDBKey)
			db:SetAndWait("count",kiteNumber)
			
			
		elseif cheatKey == "KiteCoolTimeDown" then
			local time =  _LocalTimeLogic:GetElapsed() - TimeSpan(0,19,0).Elapsed
			user.KiteFlyPlayerComponent.time = time
			
			local db = _DataStorageService:GetUserDataStorage(senderUserId)
			db:SetAndWait(_KiteFlyEventLogic.dbKey,_HttpService:JSONEncode({time = time}))
			
		elseif cheatKey == "AddCurrencyData_FieldGem" then
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_FIELDGEM, tonumber(inputText),senderUserId,"Cheat","")
			
		elseif cheatKey == "AddCurrencyData_Gold" then
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_MESO, 100000000000,senderUserId,"Cheat","")
		elseif cheatKey == "AddCurrencyData_Diamond" then
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_DIAMOND, 100000,senderUserId,"Cheat","")
		elseif cheatKey == "AddCurrencyData_Essence" then
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_ESSENCE, 50000,senderUserId,"Cheat","")
		elseif cheatKey == "AddCurrencyData_WeaponScroll" then
			_WealthLogic:RequestAddWealthFromServer(_GameConfig:GetConfig().WEALTHTYPE_SCROLL, 50000,senderUserId,"Cheat","")
		elseif cheatKey == "OpenAllStage" then
			user.DevelopPlayerComponent:OpenAllStage()
		elseif cheatKey == "GetAllWeapons" then
			user.DevelopPlayerComponent:GetAllWeapons()
		elseif cheatKey == "GetMergeTestWeapons" then
			user.DevelopPlayerComponent:GetMergeTestWeapons()
		elseif cheatKey == "GetBalanceTestWeapons" then
			-- user.DevelopPlayerComponent:GetBalanceTestWeapons()
		elseif cheatKey == "GetWeapons1" then
			user.DevelopPlayerComponent:GetWeapons1()
		elseif cheatKey == "GetWeapons2" then
			user.DevelopPlayerComponent:GetWeapons2()
		elseif cheatKey == "EquipAllWeapon" then
			user.DevelopPlayerComponent:EquipAllWeapon(user.PlayerComponent.UserId)
		elseif cheatKey == "DeleteAllEquipments" then
			user.DevelopPlayerComponent:DeleteAllEquipments()
		elseif cheatKey == "GetItem" then
			user.DevelopPlayerComponent:GetItem(inputText)
		elseif cheatKey == "AddAutoGatheringTime" then
			if user.PlayerAutoGathering.GatherRewardTable["lastAutoGatheringTime"].value == 0 then
				_UIToast:ShowMessage("탐색을 시작한 상태에서만 치트 가능합니다.")
				return
			end
			_TimerService:ClearTimer(user.PlayerAutoGathering.timer)
			user.PlayerAutoGathering:LoadData(user.PlayerAutoGathering.GatherRewardTable["lastAutoGatheringTime"].value - 30 * 60000, "Cheat")
		elseif cheatKey == "AddCharacteristicCoin" then
			user.PlayerCharacteristicData:AddCharacteristicPoint("Cheat")
		elseif cheatKey == "SpawnArmorItem" then
			if isvalid(_ArmorSpecLogic.armorData[inputText]) then
				user.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, inputText, 1, senderUserId,"Cheat","")
			else
				_UIToast:ShowMessage("올바르지 않은 방어구 아이디를 입력했습니다.")
			end
		elseif cheatKey == "GetAllPet" then
			user.DevelopPlayerComponent:GetAllPet()
		elseif cheatKey == "DeleteAllPet" then
			user.DevelopPlayerComponent:DeleteAllPet()
		elseif cheatKey == "TeleportPVP" then
			local target = _EntityService:GetEntityByPath("/maps/PvPMap/SpawnLocation")
			_TeleportService:TeleportToEntity(user,target)
		elseif cheatKey == "GetAllEggs" then
			user.DevelopPlayerComponent:GetAllEggs()
		elseif cheatKey == "AppearSuddenMission" then
			user.DevelopPlayerComponent:AppearSuddenMission(user.PlayerComponent.UserId)
		elseif cheatKey == "ApearTargetSuddenMissionInputText" then
			user.DevelopPlayerComponent:AppearTargetSuddenMission(inputText, user.PlayerComponent.UserId)
		elseif cheatKey == "AccountExpUp" then
			user.PlayerAccount:PlayerAccountExpUp(tonumber(inputText), false, "Cheat", user.PlayerComponent.UserId)
		elseif cheatKey == "GetBundle" then
			user.DevelopPlayerComponent:GetBundle(inputText)
		elseif cheatKey == "ChangeRewardedDate" then
			user.DevelopPlayerComponent:ChangeRewardedDate()
		elseif cheatKey == "SaveBackup" then
			user.PlayerDBComponent:SaveAllData(false)
			--_GameUtil:SendTestMessage(user.PlayerDBComponent.oldSaveData)
		elseif cheatKey == "SetCurrentDate" then
			user.DevelopPlayerComponent:SetCurrentDate(inputText)
		elseif cheatKey == "StartDateTimer" then
			user.DevelopPlayerComponent:StartDateTimer()
		elseif cheatKey == "InitDB" then
			user.DevelopPlayerComponent:InitDB()
		elseif cheatKey == "SimulateStage" then
			--user.DevelopPlayerComponent:SimulateStage(inputText)
		elseif cheatKey == "QuestClear" then
			user.DevelopPlayerComponent:ForceClearQuest(inputText)
		elseif cheatKey == "SetDecoration" then
			user.DevelopPlayerComponent:SetDecoration(inputText)
		elseif cheatKey == "OpenNewbiePlayMission"then
			user.DevelopPlayerComponent:OpenNewbiePlayMission()
		elseif cheatKey == "GetItemUsableEtc" then
			user.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, "7_000001", 1, user.PlayerComponent.UserId,"Cheat","")
			user.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, "8_000001", 1, user.PlayerComponent.UserId,"Cheat","")
		elseif cheatKey == "GetSoulPiece" then
			user.PlayerCharacterData:AddCharPieceCount(111001, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(111002, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(111003, 1000, "Cheat")
		
			user.PlayerCharacterData:AddCharPieceCount(121001, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(121002, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(121003, 1000, "Cheat")
		
			user.PlayerCharacterData:AddCharPieceCount(131001, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(131002, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(131003, 1000, "Cheat")
		
			user.PlayerCharacterData:AddCharPieceCount(141001, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(141002, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(141003, 1000, "Cheat")
		
			user.PlayerCharacterData:AddCharPieceCount(151001, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(151002, 1000, "Cheat")
			user.PlayerCharacterData:AddCharPieceCount(151003, 1000, "Cheat")
		elseif cheatKey == "GetNewbieMissionPlayPoint" then
			user.DevelopPlayerComponent:GetNewbieMissionPlayPoint()
		elseif cheatKey == "InitAccountLevelRank" then
			_DataStorageService:DeleteSortableDataStorageAsync("accountLevelRecord", function(errorCode, name)
				_RankingLogic:OnLoadAccountLevelRecord(_RankingLogic.accountLevelRecord)
				end)
		elseif cheatKey == "InitBattlePowerRecordRank" then
			_DataStorageService:DeleteSortableDataStorageAsync("battlePowerRecord", function(errorCode, name)
				_RankingLogic:OnLoadAccountLevelRecord(_RankingLogic.battlePowerRecord)
				end)
		elseif cheatKey == "InitLimitLandRank" then
			_DataStorageService:DeleteSortableDataStorageAsync("limitLandRecord1", function(errorCode, name)
				_RankingLogic:OnLoadAccountLevelRecord(_RankingLogic.limitLandRecord)
				_RankingLogic:OnLoadAccountLevelRecord(_RankingLogic.previousWeekLimitLandRecord)
				end)
			_DataStorageService:DeleteSortableDataStorageAsync("limitLandRecord2", function(errorCode, name)
				_RankingLogic:OnLoadAccountLevelRecord(_RankingLogic.limitLandRecord)
				_RankingLogic:OnLoadAccountLevelRecord(_RankingLogic.previousWeekLimitLandRecord)
				end)
			_DataStorageService:DeleteGlobalDataStorageAsync("globalDB", nil)
		elseif cheatKey == "AddDummyAccountRank" then
			local loop = tonumber(inputText)
			local accountLevelRecordDB = _DataStorageService:GetSortableDataStorage("accountLevelRecord")
			local version = "version1"
			
			for i = 1, loop do
				local rand = _UtilLogic:RandomIntegerRange(1, 10000)
				local tag = string.format("%s", string.format("dummy%d", rand))
				rand = _UtilLogic:RandomIntegerRange(1, 300)
				accountLevelRecordDB:SetByInfoAsync(DataStorageKeyInfo(tag, version, tag), rand, nil)
			end
			
			_TimerService:SetTimerOnce(function()
				_RankingLogic:LoadAccountLevelRecord()
				end, 5)
		elseif cheatKey == "AddDummyBattlePowerRank" then
			local loop = tonumber(inputText)
			local battlePowerRecordDB = _DataStorageService:GetSortableDataStorage("battlePowerRecord")
			local version = "version1"
			
			for i = 1, loop do
				local rand = _UtilLogic:RandomIntegerRange(1, 10000)
				local tag = string.format("%s", string.format("dummy%d", rand))
				rand = _UtilLogic:RandomIntegerRange(1, 50000)
				battlePowerRecordDB:SetByInfoAsync(DataStorageKeyInfo(tag, version, tag), rand, nil)
			end
			
			_TimerService:SetTimerOnce(function()
				_RankingLogic:LoadBattlePowerRecord()
				end, 5)
		elseif cheatKey == "AddDummyLimitLandRank" then
			local loop = tonumber(inputText)
			local limitLandRecordDB = _DataStorageService:GetSortableDataStorage(_RankingLogic.limitLandRecordDBName)
			local version = "version1"
			
			for i = 1, loop do
				local rand = _UtilLogic:RandomIntegerRange(1, 10000)
				local nickname = string.format("dummy%d", rand)
				local limitTime = TimeSpan(_GameConfig:GetConfig().TIMER_LIMITLAND * 1000)
				local remainTime = TimeSpan(_UtilLogic:RandomIntegerRange(1, 900) * 1000)
				
				local tag = string.format("%s/%s", nickname, tostring(limitTime - remainTime)) 
		
				rand = _UtilLogic:RandomIntegerRange(1, 6)
				limitLandRecordDB:SetByInfoAsync(DataStorageKeyInfo(nickname, version, tag), rand, nil)
			end
			
		
			_TimerService:SetTimerOnce(function()
				_RankingLogic:LoadLimitLandRecord()
			end, 5)
		elseif cheatKey == "SetStage" then
			user.DevelopPlayerComponent:SetStage(inputText)
		elseif cheatKey == "InitDailyMission" then
			user.DevelopPlayerComponent:InitDailyMission()
		elseif cheatKey == "DailyMissionAllComplete" then
			user.DevelopPlayerComponent:DailyMissionAllComplete()
		elseif cheatKey == "UpdateRank" then
			_RankingLogic:LoadLimitLandRecord()
			wait(1)
			_RankingLogic:LoadBattlePowerRecord()
			wait(1)
			_RankingLogic:LoadAccountLevelRecord()
			wait(1)
			_RankingLogic:TempLoadLimitLandRecord(nil)
			
			for _, user in pairs(_UserService.UserEntities) do
				if isvalid(user) then
					user.PlayerInfoComponent:CheckEnteredDate()
					user.PlayerInfoComponent:SetPlayerInfoInClient(_HttpService:JSONEncode(user.PlayerInfoComponent.playerInfo), user.PlayerComponent.UserId)
				end
			end
		elseif cheatKey == "RegistCollection" then
			local splitTable = _UtilLogic:Split(inputText, "/")
			local listId = splitTable[1]
			local materialNum = tonumber(splitTable[2])
			local count = tonumber(splitTable[3])
		
			local targetId = ""
			local collectionTable = _CollectionLogic.statusTable[listId]
		
			
			if not isvalid(collectionTable) then
				log_error("유효하지 않은 도감 Id를 입력했습니다.")
				return
			end
		
			if materialNum == 1 then
				if _UtilLogic:IsNilorEmptyString(collectionTable.material1_id) then
					log_error("유효하지 않은 슬롯 넘버를 입력했습니다.") return
				else
					targetId = collectionTable.material1_id
				end
			elseif materialNum == 2 then
				if _UtilLogic:IsNilorEmptyString(collectionTable.material2_id) then
					log_error("유효하지 않은 슬롯 넘버를 입력했습니다.") return
				else
					targetId = collectionTable.material2_id
				end	
			elseif materialNum == 3 then
				if _UtilLogic:IsNilorEmptyString(collectionTable.material3_id) then
					log_error("유효하지 않은 슬롯 넘버를 입력했습니다.") return
				else
					targetId = collectionTable.material3_id
				end
			elseif materialNum == 4 then
				if _UtilLogic:IsNilorEmptyString(collectionTable.material4_id) then
					log_error("유효하지 않은 슬롯 넘버를 입력했습니다.") return
				else
					targetId = collectionTable.material4_id
				end
			elseif materialNum == 5 then
				if _UtilLogic:IsNilorEmptyString(collectionTable.material5_id) then
					log_error("유효하지 않은 슬롯 넘버를 입력했습니다.") return
				else
					targetId = collectionTable.material5_id
				end
			else
		
			end
			
			local uniqueKey = _GameUtil:CreateGUID()
			for i = 1 , count do
				
				user.PlayerStorageComponent:RequestAddItemFromServer(uniqueKey, 1, targetId, 1, senderUserId, "", "")
				user.PlayerCollectionComponent:RegisterToCollectionTable(listId, targetId, materialNum, uniqueKey, "Cheat", 0)		
				
				if isvalid(user.PlayerStorageComponent.storage[uniqueKey]) then 
					user.PlayerStorageComponent:RequestRemoveItemFromServer(targetId, uniqueKey, senderUserId, true, "")
					break
				end
				if i%50 == 0 then
					wait(0.01)
				end
			end
		elseif cheatKey == "FullSP" then
			user.MultiBattlePlayer.sp = user.MultiBattlePlayer.maxSp
		elseif cheatKey == "SetClearedRecommendStage" then
			user.DevelopPlayerComponent:SetClearedRecommendStage(tonumber(inputText))
		elseif cheatKey == "GetTestItem" then
			user.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, "0_000001", 1, user.PlayerComponent.UserId, "test", "")
		elseif cheatKey == "GetAbilityLevelExp" then
			if not isvalid(tonumber(inputText)) then
				return
			end
			user.PlayerAbilityComponent:RequestAbilityLevelExpUp(tonumber(inputText), senderUserId, "", "")
		elseif cheatKey == "GetMagicalStones" then
			user.DevelopPlayerComponent:GetMagicalStones()
		elseif cheatKey == "GetAccessories" then
			user.DevelopPlayerComponent:GetAccessories(inputText)
		elseif cheatKey == "AllFieldMapVisit" then
			for i=1,8 do
				if i==1 then
					user.PlayerFieldMapComponent:UpdateData(i,0,2)
				else
					user.PlayerFieldMapComponent:UpdateData(i,0,1)
				end
			end
		elseif cheatKey == "CurrentMapOpen" then
			local currentMapNum = _MultiMapDataLogic.multiMapData[user.CurrentMapName].mapNum
			for i=1,#table.keys(user.PlayerFieldMapComponent.fieldMapData[currentMapNum]) - 1 do
				if user.PlayerFieldMapComponent.fieldMapData[currentMapNum][i] == 0 then
					user.PlayerFieldMapComponent:UpdateData(currentMapNum,i,1)
				end
			end
		elseif cheatKey == "ResetLimitLandRecord" then
			user.DevelopPlayerComponent:ResetLimitLandRecord()
		elseif cheatKey == "ChangeNameTag" then
			local users = _UserService.UserEntities
			local names = {"NewName"}
			local count = 1
			for i, user in pairs(users) do
				if isvalid(names[count]) then
					user.NameTagComponent.Name = names[count]
					_PartyLogic.nicknameTable[i] = names[count]
				else
					user.NameTagComponent.Name = "NewName2"
					_PartyLogic.nicknameTable[i] = "NewName2"
				end
				count += 1
			end
			self:OnCheatKeyOnClient(cheatKey, inputText, user.PlayerComponent.UserId)	
		else
			self:OnCheatKeyOnClient(cheatKey, inputText, user.PlayerComponent.UserId)	
		end
		
		if showDefaultMessage then
			_UIToast:ShowMessage(cheatKey,user.PlayerComponent.UserId)
		else
		end
		
		_WorldLog:LogAdminToolFlow(senderUserId,senderUserId,_WorldLog.FlowType_AdminToolFlow_Cheat,cheatKey,inputText,"")
	end

	@ExecSpace("Server")
	method void ToogleCheatUI()
		-- 치트 UI 토글 (서버에서 클라이언트로 호출)
		
		if self:IsEnableCheat(senderUserId) == false then
			return
		end
		self:OnToggleCheatUI(senderUserId)
	end

	@ExecSpace("Client")
	method void OnToggleCheatUI()
		-- 클라이언트에서 치트 UI 표시/숨김 토글
		if self:IsEnableCheat(_UserService.LocalPlayer.PlayerComponent.UserId) == false then
			return
		end
		self.cheatUI.Enable = not self.cheatUI.Enable 
		self.smiulateText.Entity.Enable = false
	end

	@ExecSpace("Client")
	method void OnCheatKeyOnClient(string cheatKey, string inputText)
		-- 클라이언트 전용 치트 명령 처리
		
		if self:IsEnableCheat(_UserService.LocalPlayer.PlayerComponent.UserId) == false then
			return
		end
		if cheatKey == "BattleLevelUp" then
			_UserService.LocalPlayer.BattlePlayer:LevelUp(false)
		elseif cheatKey == "KillMonster" then
			_BuffLogic:AttackAllMonsters(100)
		elseif cheatKey == "WaveForceClear" then
			_UserService.LocalPlayer.CurrentMap.BattleMap:ForceClear()
			_BuffLogic:AttackAllMonsters(100)
		elseif cheatKey == "ShuffleBuffCard" then
			_BattleUIManager.levelUpPopup:Shuffle(_UserService.LocalPlayer.BattlePlayer.lv)
		elseif cheatKey == "AddShield" then
			_UserService.LocalPlayer.BattlePlayer:AddShield()
		elseif cheatKey == "EvolutionWeapon" then
			_UserService.LocalPlayer.BattlePlayer:EvolutionWeapon()
		elseif cheatKey == "Replica" then
			_UserService.LocalPlayer.BattlePlayer:AddReplica()
		elseif cheatKey == "DisassembleWeapon" then
			_UserService.LocalPlayer.BattlePlayer:DisassembleWeapon()
		elseif cheatKey == "ShuffleAllWeapon" then
			_UserService.LocalPlayer.BattlePlayer:ShuffleAllWeapon()
		elseif cheatKey == "SpawnMonsterMore" then
			_WaveLogic.spawnMultiply = _WaveLogic.spawnMultiply  + 1
			log(string.format("몬스터 스폰 수 x %d",_WaveLogic.spawnMultiply))
		elseif cheatKey == "FullSP" then
			_UserService.LocalPlayer.BattlePlayer:AddSP(1000)
		elseif cheatKey == "EventBannerOpen" then
			--_UIGroupManager.eventBannerManager:Show()
		elseif cheatKey == "HP_Large_Plus" then
			_BuffLogic.appliedBuff.maxHp = 9999999
			_UserService.LocalPlayer.BattlePlayer:SetMaxHP(9999999)
			_UserService.LocalPlayer.BattlePlayer:SetHP(9999999)
		elseif cheatKey == "SetInvincible" then
			_UserService.LocalPlayer.BattlePlayer:ApplyInvincible(9999999)
		elseif cheatKey == "MonsterWaveSkill" then
			_UserService.LocalPlayer.CurrentMap.BattleMap:SpawnMonsterWaveSkill("model://097f0a46-880d-47c0-97d3-56652d1ff418", 5)
		elseif cheatKey == "Lifex2" then
			self.Life_Cheat = true
		elseif cheatKey == "HitDamageMyself" then
			if isvalid(_UserService.LocalPlayer.BattlePlayer) then
				_UserService.LocalPlayer.BattlePlayer:SetHP(_UserService.LocalPlayer.BattlePlayer.hp - _UserService.LocalPlayer.BattlePlayer.maxHp * 0.1)
			else
				_UIToast:ShowMessage("인게임에서만 사용할 수 있는 치트입니다.")
			end
		elseif cheatKey == "RecoverHpMyself" then
			if isvalid(_UserService.LocalPlayer.BattlePlayer) then
				_UserService.LocalPlayer.BattlePlayer:SetHP(_UserService.LocalPlayer.BattlePlayer.hp + _UserService.LocalPlayer.BattlePlayer.maxHp * 0.1)
			else
				_UIToast:ShowMessage("인게임에서만 사용할 수 있는 치트입니다.")
			end
		elseif cheatKey == "TeleportTraining" then
			_BattleUIManager.loadingUI:Show()
			_WaveLogic:SetChapter(3)
			_StageLogic:Teleport(_UserService.LocalPlayer,-1,"Training")
			_StageLogic.isInPlay = true
			_StageLogic:SendEvent(StageStartEvent())
			_UIGroupManager.uiStageMovePopup:Hide()
		
		elseif cheatKey == "AllWeaponSpecialBuff" then
			local user = _UserService.LocalPlayer
			for key, value in pairs(user.BattlePlayer.equipGun) do
				---@type BattleGunObject
				local gun = value.gun.BattleGunObject
				
				if gun.cardLevel < _GameConfig:GetConfig().WEAPONCARD_LV_MAX then
					for i = gun.cardLevel, _GameConfig:GetConfig().WEAPONCARD_LV_MAX - 1 do
						gun:CardLevelUp(false)
					end
				end
			end
		elseif cheatKey == "WaveToBoss" then
			
			self._T.forceClearEventId = _TimerService:SetTimerRepeat(function()
				if _TimerLogic.pause then
					return
				end
				_BuffLogic:AttackAllMonsters(100)
				_BattleUIManager.levelUpPopup:AutoSelect()
				for i = 1, 999 do
					_PoolingLogic:UpdateQueue()
				end
			 end,0.5)
			
			
			
			
			self._T.spawnLastBossEventId = _WaveLogic:ConnectEvent(WaveStartEvent,function(e) 
				if e.isBossWave then
					_TimerLogic.timeScale = 1
					 _WaveLogic:DisconnectEvent(SpawnLastBoss,self._T.spawnLastBossEventId)
					_TimerService:ClearTimer(self._T.forceClearEventId)
					
				end
				
			end)
			_TimerLogic.timeScale = 20
			_GameUtil.gemImmediatelyGain = true
		elseif cheatKey == "BossTest" then
			_CheatLogic.Boss_Test_Cheat = true
			
			for chapter,chapterData in pairs(_WaveLogic.chapterData) do
				chapterData[1] = chapterData[#chapterData]
			end
			for k,v in pairs(_StageLogic.stageData) do
				v.width = v.lastWidth
				v.height = v.lastHeight
			end
			
			
		elseif cheatKey == "MonsterForceSpawn" then
			_GameUtil.MONSTER_POOL_COUNT = 500
			
			for chapter,chapterData in pairs(_WaveLogic.chapterData) do
				for wave,waveData in pairs(chapterData) do
					if wave ~= "lastWave" then
						for _,group in pairs(waveData) do
							for _,v in pairs(group) do
								v.delay = 0
							end
						end
					end
				end
			end
		elseif cheatKey == "UIDebug" then
			_GameUtil.UI_DEBUG = not _GameUtil.UI_DEBUG
		elseif cheatKey == "SimulateStageDrops" then
			self.smiulateText.Text = ""
			self.smiulateText.Entity.Enable = true
			_UserService.LocalPlayer.DevelopPlayerComponent:SimulateStageDrops(inputText, 1000)
		elseif cheatKey == "ApplyBuff" then
			_BuffLogic:ApplyBuff(inputText)
		elseif cheatKey == "IngameExpUp" then
			_UserService.LocalPlayer.BattlePlayer:GainEXP(tonumber(inputText))
		elseif cheatKey == "ShowHp" then
			_OptionLogic.showHp = true
			local battlePlayer = _UserService.LocalPlayer.BattlePlayer
			local text = _UserService.LocalPlayer:GetChildByName("debug_text", true)
			if _UtilLogic:Contains(text.Parent.Name, "hp") then
				text.TextComponent.Text = string.format("%d / %d", battlePlayer.hp, battlePlayer.maxHp)
				text.Enable = true
			end
		elseif cheatKey == "ShowExp" then
			_OptionLogic.showExp = true
			if isvalid(_UserService.LocalPlayer.BattlePlayer) then
				_UserService.LocalPlayer.BattlePlayer:RefreshEXP()
			end
			_PlayerAccountLogic.expText.Enable = true
		elseif cheatKey == "OpenDailyMission" then
		
		elseif cheatKey == "MonsterHPBar" then
			
			
			self._T.addMonsterHP = function(e)
				---@type Entity
				local entity = e
				if entity.MonsterObject ~= nil then
					entity:AddComponent(MonsterTestHPBar)
				end
			end
			local map = _UserService.LocalPlayer.CurrentMap 
			self._T.searchMonster = function(entity) 
				if isvalid(entity) then
					for _,v in pairs(entity.Children) do
						---@type Entity
						local e = v
						self._T.addMonsterHP(e)
					end
				end
			end
			if isvalid(map) then
				self._T.searchMonster(map)
			end
			self._T.createMonsterEventId = _EntityService:ConnectEvent(EntityCreateEvent, function(e) 
				---@type Entity
				local entity = e.Entity
				self._T.addMonsterHP(entity)
			end)
			_UserService.LocalPlayer:ConnectEvent(BattleChapterEnd,function(e) 
				if self._T.createMonsterEventId ~= nil then
					_UserService.LocalPlayer:DisconnectEvent(EntityCreateEvent,self._T.createMonsterEventId)
				end
				self._T.createMonsterEventId = nil
			end)
			
		elseif cheatKey == "Gizmo" then
			
			if self._T.gizmoDrawMode == nil then
				self._T.gizmoDrawMode = false
			end
			self._T.gizmoDrawMode = not self._T.gizmoDrawMode
			
			if self._T.gizmoDrawMode == false then
				if self._T.createEventId ~= nil then
					_UserService.LocalPlayer:DisconnectEvent(EntityCreateEvent,self._T.createEventId)
					self._T.createEventId  = nil
				end
				local entites = _EntityService:GetEntitiesSpawnedByModelId("model://95bc8ca1-5118-4c28-b078-d1b4d4999f80")
				for k,v in pairs(entites) do
					v:Destroy()
				end		
				return
			end
			local width = 0.5
			self._T.drawGizmo = function(e)
				---@type TriggerComponent
				local trigger = e.PhysicsColliderComponent
				
			
				if trigger == nil then
					---@type PhysicsColliderComponent
				
					trigger = e.TriggerComponent
				end
		
				if trigger ~= nil and trigger.Enable then
					local color = Color.red
					if trigger.CollisionGroup == CollisionGroups.PlayerSkill then
						color = Color.green
					elseif trigger.CollisionGroup == CollisionGroups.NonShieldWeapon then
						color = Color.cyan
					elseif trigger.CollisionGroup == CollisionGroups.ShieldWeapon then
						color = Color.blue
					elseif trigger.CollisionGroup == CollisionGroups.MonsterWave then
						color = Color.magenta
					end
						
					local spawn = _SpawnService:SpawnByModelId("model://95bc8ca1-5118-4c28-b078-d1b4d4999f80","gizmo",Vector3.zero,e)
					local line = spawn.LineRendererComponent
					
					if trigger.ColliderType == ColliderType.Box then					
						local pos1 = trigger.ColliderOffset + Vector2(trigger.BoxSize.x * -0.5,trigger.BoxSize.y * -0.5)
						local pos2 = trigger.ColliderOffset + Vector2(trigger.BoxSize.x * 0.5,trigger.BoxSize.y * -0.5)
						local pos3 = trigger.ColliderOffset + Vector2(trigger.BoxSize.x * 0.5,trigger.BoxSize.y * 0.5)
						local pos4 = trigger.ColliderOffset + Vector2(trigger.BoxSize.x * -0.5,trigger.BoxSize.y * 0.5)
						
						line.Points:Add(LinePoint(pos1 ,color,width))
						line.Points:Add(LinePoint(pos2 ,color,width))
						line.Points:Add(LinePoint(pos3 ,color,width))
						line.Points:Add(LinePoint(pos4 ,color,width))
						line.Points:Add(LinePoint(pos1 ,color,width))
						
						
					elseif trigger.ColliderType == ColliderType.Circle then
					
						for i = 1, 11 do
							local angle = 2* math.pi * (i%10) / 10
							local pos = trigger.ColliderOffset + Vector2(trigger.CircleRadius * math.cos(angle),trigger.CircleRadius * math.sin(angle))
							line.Points:Add(LinePoint(pos ,color,width))					
						end		
					end
				end
			end
			local map = _UserService.LocalPlayer.CurrentMap 
			self._T.search = function(entity) 
				if isvalid(entity) then
					for _,v in pairs(entity.Children) do
						---@type Entity
						local e = v
						if e.TransformComponent ~= nil then
							self._T.drawGizmo(e)
							local s = e.TransformComponent.Scale
							self._T.search(e)
						end
					end
				end
			end
			if isvalid(map) then
				self._T.search(map)
			end
			self._T.createEventId = _EntityService:ConnectEvent(EntityCreateEvent, function(e) 
				---@type Entity
				local entity = e.Entity
				self._T.drawGizmo(entity)
				self._T.search(entity)
			end)
			_UserService.LocalPlayer:ConnectEvent(BattleChapterEnd,function(e) 
				if self._T.createEventId ~= nil then
					_UserService.LocalPlayer:DisconnectEvent(EntityCreateEvent,self._T.createEventId)
				end
				self._T.createEventId = nil
			end)
		elseif cheatKey == "Joystick" then
			local joystick = _EntityService:GetEntityByPath("/ui/DefaultGroup/Joystick")
			joystick.Enable = not joystick.Enable
			
		elseif cheatKey == "ClearAllBaggage" then
			local deleteUniqueKeyList = {}
			deleteUniqueKeyList = _ItemDataLogic:GetFieldItemUniqueKeyList(1, _UserService.LocalPlayer.PlayerComponent.UserId)
			for i = 1, #deleteUniqueKeyList do
				_UserService.LocalPlayer.PlayerStorageComponent:RequestRemoveItemByUniqueKey(deleteUniqueKeyList[i], _UserService.LocalPlayer.PlayerStorageComponent.storage[deleteUniqueKeyList[i]].count, "cheat")
			end
		elseif cheatKey == "ShowFieldExp" then
			if _MultiHUDManager.isShowFieldExpByCheat == false then
				_MultiHUDManager.isShowFieldExpByCheat = true
			else
				_MultiHUDManager.isShowFieldExpByCheat = false
			end
		elseif cheatKey == "ChangeNameTag" then
			local users = _UserService.UserEntities
			local names = {"NewName"}
			local count = 1
			local myName = ""
			for i, user in pairs(users) do
				if isvalid(names[count]) then
					user.NameTagComponent.Name = names[count]
					_PartyLogic.nicknameTable[i] = names[count]
					if user == _UserService.LocalPlayer then myName = names[count] end
				else
					user.NameTagComponent.Name = "NewName2"
					_PartyLogic.nicknameTable[i] = "NewName2"
					if user == _UserService.LocalPlayer then myName = "NewName2" end
				end
				count += 1
			end
			_PartyUILogic.partyHUD.PartyHUDComponent:Refresh()
			local origin = _MultiHUDManager.textLevel.TextComponent.Text
			local originToTable = _UtilLogic:Split(origin," ")
			_MultiHUDManager.textLevel.TextComponent.Text = originToTable[1].." "..originToTable[2].." "..myName
		end
	end

	method boolean IsEnableCheat(string ppsn)
		-- 치트 사용 가능 여부 확인 (현재 항상 true 반환)
		return true
	end

	@ExecSpace("ClientOnly")
	method void ToogleInputUI()
		-- 입력 UI 토글
		
		self.inputUI.Enable = not self.inputUI.Enable
	end

	method void MoveToBoss(string testMonsterID)
		-- 특정 보스 테스트를 위해 보스 맵으로 이동
		_GameSettingLogic:SetMode(_GameConfig:GetConfig().GAMEMODE_BASIC)
		_BattleUIManager.loadingUI:Show()
		
		local testChapter = -9999
			local chapterTable = _WaveLogic.chapterData[testChapter] 
			if chapterTable  ~= nil then
				_WaveLogic.chapterData[testChapter].lastWave = nil		
				table.clear(_WaveLogic.chapterData[testChapter])
				_WaveLogic.chapterData[testChapter] = nil
			end
			if _CheatLogic.Boss_Test_Cheat then
				_MonsterLogic.monsterData[testMonsterID].hp = 9999999999
			end
		
			_WaveLogic:AddChapterData(testChapter,1,1,testMonsterID,3,1,1,1,1,"boss","",10,1,0)
			_StageLogic.stageData[testChapter] = _StageLogic.stageData[10001]
			
			_BossBalanceLogic.currentBossId = testMonsterID
		
			_WaveLogic:SetChapter(testChapter)
			
		
		_StageLogic:Teleport(_UserService.LocalPlayer,_WaveLogic.currentChapter,"Test")
		_StageLogic.isInPlay = true
		_StageLogic:SendEvent(StageStartEvent())
		_UIGroupManager.uiStageMovePopup:Hide()
	end

	method void OnBeginPlay()
		-- 치트 로직 초기화 (서버에서는 테스트 오브젝트 스폰, 클라이언트에서는 F7 버튼 활성화)
		if self:IsServer() then
			
		else
			self.F7Button.Enable = true
		end
	end

	@ExecSpace("Server")
	method void CheatFieldAllOpen()
		-- 모든 필드 맵 열기 치트
		local user = _UserService:GetUserEntityByUserId(senderUserId)
		for i=1,8 do
			if i==1 then
				user.PlayerFieldMapComponent:UpdateData(i,0,2)
			else
				user.PlayerFieldMapComponent:UpdateData(i,0,1)
			end
		end
		user.DevelopPlayerComponent:ForceClearQuest("80")
		
	end

	@EventSender("Logic", "WaveLogic")
	handler HandleWaveStartEvent(WaveStartEvent event)
		-- 웨이브 시작 이벤트 처리 (보스 테스트 치트 활성화 시 보스 HP 조작)
		
		
		
		local isBossWave = event.isBossWave
		local waveNum = event.waveNum
		
		
		if self.Boss_Test_Cheat then
			
			_TimerLogic:SetTimerRepeat(function()
				_UserService.LocalPlayer.BattlePlayer:SetMaxHP(9999999)
				_UserService.LocalPlayer.BattlePlayer:SetHP(9999999)
			
				local currentMap = _UserService.LocalPlayer.CurrentMap
			---@type table<DestroyableObject>
			local monsters = currentMap:GetChildComponentsByTypeName("BossObject",true)
			
			for _, monster in pairs(monsters) do
			
					local maxHp = monster:GetMaxHp()
					if maxHp ~= nil then
						monster:SetDamage(maxHp* 0.1, Vector2.zero, true, "FingerSnap")			
					end
				
			end
				
		 end, 10,1, "CheatLogic.WaveStartEvent")
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력 이벤트 처리 (F7 키로 치트 UI 토글)
		
		local key = event.key
		
		
		if key == KeyboardKey.F7 then
			_CheatLogic:ToogleCheatUI()
		end
	end

	@EventSender("Entity", "ba7fb1e5-c7e1-4a13-85f8-5cd95e1c2c2f")
	handler HandleChatEvent(ChatEvent event)
		-- 채팅 이벤트 처리 (현재 빈 구현)
		
		local Message = event.Message
		local SenderName = event.SenderName
		local UserId = event.UserId
		
		if UserId == _UserService.LocalPlayer.PlayerComponent.UserId then
		
		end
	end

end