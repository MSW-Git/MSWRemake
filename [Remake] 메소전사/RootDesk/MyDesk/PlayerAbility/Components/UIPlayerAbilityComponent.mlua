@Component
script UIPlayerAbilityComponent extends UICommonPopup

	property Entity abilityLevel = "3b4cb67b-755d-4d3b-926c-5f8a4a687d27"

	property Entity abilityLevelGauge = "0d5e2b72-8172-4199-aa8f-1e34317790b8"

	property Entity abilityCurrentPoints = "d0efef51-37fe-483f-93ce-ad74d91c8627"

	property Entity ability_Status_Type_1 = "5bb592bf-e6c1-478b-a05c-b721b6d1a6ce"

	property Entity ability_Status_Type_2 = "cff3c211-8260-4677-b1b3-e6484291bd55"

	property Entity ability_Status_Type_3 = "a79bfe88-6d91-4db2-a32e-8afdc2dbe3b5"

	property Entity ability_Status_Type_4 = "a6a2c8ed-ba32-46b2-ac35-96cf9aa8e4bd"

	property Entity button_openAbility = "e0bf4a00-467a-430a-832f-1e1cbf66e2e5"

	property Entity button_Add_Type_1 = "6b1e8e13-33cb-4ad4-9086-c8de738895ea"

	property Entity button_Add_Type_2 = "9d59edcf-4637-40e7-92fe-99f888317f1b"

	property Entity button_Add_Type_3 = "205d69b6-a0b0-4ff0-a83f-cc4048a085ac"

	property Entity button_Add_Type_4 = "a781a32e-5fc1-4241-b5ee-89abb56a65fd"

	property Entity button_Request_Levelup = "828e4b4c-766f-4db1-9f41-4e3ef014bdc4"

	property Entity button_Request_PointReset = "86fa20b6-36fc-4907-a955-78a617a002af"

	property Entity button_Request_PointBack = "053afdb6-c158-44dc-9c89-f64a617af57f"

	property Entity button_closeAbility = "99d1ea31-d083-4095-bbd8-fbd411c8152f"

	property Entity button_Minus_Type_1 = "5d11ecf6-5a17-4d53-a03e-d1e68c8d5947"

	property Entity button_Minus_Type_2 = "ec0d0be3-00da-4f5d-9b3d-e0bab75e1f45"

	property Entity button_Minus_Type_3 = "9e32024e-68b6-4753-8135-0bb3e28f5b3d"

	property Entity button_Minus_Type_4 = "18b391e6-2d00-4a76-a070-1fa64628de4a"

	property Entity button_Add10_Type_1 = "d61f6fae-964e-4e1f-93bb-df425e5acfc6"

	property Entity button_Add10_Type_2 = "8c907c17-4163-4210-a453-78fa5649c82e"

	property Entity button_Add10_Type_3 = "7d4eb1e6-62cb-4b33-90d1-db907654658e"

	property Entity button_Add10_Type_4 = "80d6cc5d-5a77-494a-bb66-a7452edf55c2"

	property Entity button_Minus10_Type_1 = "0d67a561-461d-4427-bba3-639879e83003"

	property Entity button_Minus10_Type_2 = "6d021eef-b231-4f2d-8497-a00d795c9305"

	property Entity button_Minus10_Type_3 = "f1f4755b-fb18-46d4-8512-6f3ef0eec642"

	property Entity button_Minus10_Type_4 = "0c23eb15-38d6-40ef-87ad-577089a148c8"

	property Entity abilityUIButton_Lobby = "e0bf4a00-467a-430a-832f-1e1cbf66e2e5"

	property Entity abilityUIButton_MultiBattleMap = "f032c298-5adb-4141-bc9c-1058ab7b62f8"

	property TextComponent fieldStatusPoint_Type1 = "a81eac1a-ae5c-410c-9b38-cf33953ab96d"

	property TextComponent fieldStatusPoint_Type2 = "b02c8c85-4804-4f33-98c9-ab95ed0b4749"

	property TextComponent fieldStatusPoint_Type3 = "a347cb95-1f9b-4b27-b55f-f6a8bd6b7bc3"

	property TextComponent fieldStatusPoint_Type4 = "5da08e57-a64c-4081-8812-9a1733318818"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 버튼 이벤트 연결
		__base:OnBeginPlay()
		
		
		self.button_openAbility.Enable = true
		
		if self:IsClient() then
			local abilityCompo = _UserService.LocalPlayer.PlayerAbilityComponent
		
			self.button_openAbility:ConnectEvent(ButtonClickEvent, 
			function() 
				self:Show()
			end)
			
			self.button_closeAbility:ConnectEvent(ButtonClickEvent,	
			function()
				self:Hide()
			end)
		
			self.button_Add_Type_1:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 1, 1)
			end)
		
			self.button_Add_Type_2:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 2, 1)
			end)
		
			self.button_Add_Type_3:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 3, 1)
			end)
		
			self.button_Add_Type_4:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 4, 1)
			end)
			 
			self.button_Minus_Type_1:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 1, -1)
			end)
		
			self.button_Minus_Type_2:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 2, -1)
			end)
		
			self.button_Minus_Type_3:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 3, -1)
			end)
		
			self.button_Minus_Type_4:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 4, -1)
			end)
		
			self.button_Add10_Type_1:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 1, 10)
			end)
		
			self.button_Add10_Type_2:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 2, 10)
			end)
		
			self.button_Add10_Type_3:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 3, 10)
			end)
		
			self.button_Add10_Type_4:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 4, 10)
			end)
		
			self.button_Minus10_Type_1:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 1, -10)
			end)
		
			self.button_Minus10_Type_2:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 2, -10)
			end)
		
			self.button_Minus10_Type_3:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 3, -10)
			end)
		
			self.button_Minus10_Type_4:ConnectEvent(ButtonClickEvent,
			function()
				abilityCompo:ChangeToUsePoints(false, 4, -10)
			end)
		
			
			self.button_Request_Levelup:ConnectEvent(ButtonClickEvent,
			function()
				local totalToUsePoints = _AbilityLogic:GetToUseAbilityPoints()
					if totalToUsePoints <= 0 then
						_UIToast:ShowMessage(_LocalizeLogic:GetText("toast276"))
						return
					end
		
					for i = 1 , #abilityCompo.toUsePoints do
						if abilityCompo.toUsePoints[i] >= 1 then
							abilityCompo:RequestDecreasePoint(abilityCompo.toUsePoints[i], i, _UserService.LocalPlayer.PlayerComponent.UserId, "FieldStatusUpgrade")		
						end
					end
					_UIToast:ShowMessage(_LocalizeLogic:GetText("toast277"))
					_SoundService:PlaySound("85009f4dcc7d4536b732aa54b76d05c9", 1)
					_UserService.LocalPlayer.PlayerAbilityComponent:ChangeToUsePoints(true, 0, 0)		
			end)
			
			self.button_Request_PointBack:ConnectEvent(ButtonClickEvent,
			function()
					local totalToUsePoints = _AbilityLogic:GetToUseAbilityPoints()
					if totalToUsePoints <= 0 then
						_UIToast:ShowMessage(_LocalizeLogic:GetText("toast276"))
						return
					end
				_UserService.LocalPlayer.PlayerAbilityComponent:ChangeToUsePoints(true, 0, 0)		
			end)
		
			self.button_Request_PointReset:ConnectEvent(ButtonClickEvent,
			function()
				if _AbilityLogic:CheckExistInvestedStatusPoint(_UserService.LocalPlayer.PlayerComponent.UserId) == false then
					_UIToast:ShowMessage(_LocalizeLogic:GetText("toast279"))	
					return
				end
					
				if _AbilityLogic:GetToUseAbilityPoints() < 1 then
				_UIPopup:OpenPurchasePopup(
					_LocalizeLogic:GetText("popup48"), _LocalizeLogic:GetText("popup49"), _LocalizeLogic:GetText("popup50"), "diamond", 100, function() 
							_AbilityLogic:RequestResetPoint() 
							_UserService.LocalPlayer.PlayerAbilityComponent:ChangeToUsePoints(true, 0, 0)		
							end, 
								function() end
					)	
				end
		
			end)
			
		end
	end

	method void Show()
		-- 능력 UI를 표시하고 데이터 갱신
		if self.Entity.ContentLockComponent:CheckUIAvailable() == true then
			self:Refresh()
			__base:Show()
		end
	end

	method void Hide()
		-- 능력 UI를 숨기고 포인트 변경사항 초기화
		_UserService.LocalPlayer.PlayerAbilityComponent:ChangeToUsePoints(true, 0, 0)		
		__base:Hide()
	end

	method void Refresh()
		-- 능력 UI의 모든 요소를 갱신
		local ability = _UserService.LocalPlayer.PlayerAbilityComponent.ability
		
		self.abilityLevel.TextComponent.Text = ability["lvData"].lv 
		
		if ability["lvData"].lv < _AbilityLogic.abilityMaxLevel then
			self.abilityLevelGauge.SpriteGUIRendererComponent.FillAmount =  ability["lvData"].exp/_AbilityLogic.abilityExpData[ability["lvData"].lv].needToFillExp 
		else
			self.abilityLevelGauge.SpriteGUIRendererComponent.FillAmount =  1 
		end
		
		self:ChangeCurrentStatusPoint(ability["lvData"].cp )
		
		local effectSwitch = false
		if ability["lvData"].cp >= 1 then
			effectSwitch = true
		end
		self:AddButtonEffectSwitch(effectSwitch)
		
		self.ability_Status_Type_1.TextComponent.Text = string.format("%d", _AbilityLogic:GetStatusByAbilityType(1, ability["type_1"].lv)) 
		self.ability_Status_Type_2.TextComponent.Text = string.format("%d", _AbilityLogic:GetStatusByAbilityType(2, ability["type_2"].lv)) 
		self.ability_Status_Type_3.TextComponent.Text = string.format("%d", _AbilityLogic:GetStatusByAbilityType(3, ability["type_3"].lv)) 
		self.ability_Status_Type_4.TextComponent.Text = string.format("%d", _AbilityLogic:GetStatusByAbilityType(4, ability["type_4"].lv)) 
		
		self:RefreshFieldStatusCurrentAndLimitPoints(false)
		self:RefreshButtonState()
		self:SetMinutBtnStatus()
	end

	method void RefreshByChangePoints(boolean reset)
		-- 포인트 변경에 따른 UI 갱신
		local ability = _UserService.LocalPlayer.PlayerAbilityComponent.ability
		local toUsePoints = _UserService.LocalPlayer.PlayerAbilityComponent.toUsePoints 
		local totalToUsePoints = _AbilityLogic:GetToUseAbilityPoints()
		
		if totalToUsePoints < 1 then
			reset = true
		end
		
		if reset then 
			self:Refresh()	
		else
		
		
			self.abilityLevel.TextComponent.Text = ability["lvData"].lv 
		
			if ability["lvData"].lv < _AbilityLogic.abilityMaxLevel then
				self.abilityLevelGauge.SpriteGUIRendererComponent.FillAmount =  ability["lvData"].exp/_AbilityLogic.abilityExpData[ability["lvData"].lv].needToFillExp 
			else
				self.abilityLevelGauge.SpriteGUIRendererComponent.FillAmount =  1 
			end
		
		
		
			self:ChangeCurrentStatusPoint(ability["lvData"].cp - totalToUsePoints ) 
			self.ability_Status_Type_1.TextComponent.Text = string.format("%d<color=#B5FA4D>(+%d)</color>", _AbilityLogic:GetStatusByAbilityType(1, ability["type_1"].lv), _AbilityLogic:GetStatusByAbilityType(1, ability["type_1"].lv + toUsePoints[1]) - _AbilityLogic:GetStatusByAbilityType(1, ability["type_1"].lv) ) 
			self.ability_Status_Type_2.TextComponent.Text = string.format("%d<color=#B5FA4D>(+%d)</color>", _AbilityLogic:GetStatusByAbilityType(2, ability["type_2"].lv), _AbilityLogic:GetStatusByAbilityType(2, ability["type_2"].lv + toUsePoints[2]) - _AbilityLogic:GetStatusByAbilityType(2, ability["type_2"].lv) ) 
		 	self.ability_Status_Type_3.TextComponent.Text = string.format("%d<color=#B5FA4D>(+%d)</color>", _AbilityLogic:GetStatusByAbilityType(3, ability["type_3"].lv), _AbilityLogic:GetStatusByAbilityType(3, ability["type_3"].lv + toUsePoints[3]) -_AbilityLogic:GetStatusByAbilityType(3, ability["type_3"].lv) ) 
			self.ability_Status_Type_4.TextComponent.Text = string.format("%d<color=#B5FA4D>(+%d)</color>", _AbilityLogic:GetStatusByAbilityType(4, ability["type_4"].lv), _AbilityLogic:GetStatusByAbilityType(4, ability["type_4"].lv + toUsePoints[4])- _AbilityLogic:GetStatusByAbilityType(4, ability["type_4"].lv)) 
			self:RefreshButtonState()
		end
		self:RefreshFieldStatusCurrentAndLimitPoints(true)
		self:SetMinutBtnStatus()
	end

	method void RefreshButtonState()
		-- 버튼 상태를 갱신하고 활성화/비활성화 처리
		local totalToUsePoints = _AbilityLogic:GetToUseAbilityPoints()
		local ability = _UserService.LocalPlayer.PlayerAbilityComponent.ability
		local effectSwitch = true
		
		if totalToUsePoints == ability["lvData"].cp then
			effectSwitch = false
		end
		self:AddButtonEffectSwitch(effectSwitch)
		
		if totalToUsePoints >= 1 then
			self.button_Request_Levelup.SpriteGUIRendererComponent.ImageRUID = "fc7aab99a8e549e58d891d50f594ecd6" 
			self.button_Request_Levelup.TextComponent.FontColor = Color.FromHexCode("#ffffff")
			self.button_Request_Levelup.TextComponent.OutlineColor = Color.FromHexCode("#589334")
			
			self.button_Request_PointBack.SpriteGUIRendererComponent.ImageRUID = "ab05ba935aeb49448a9dda69998e20fa" 
			self.button_Request_PointBack.TextComponent.FontColor = Color.white
			self.button_Request_PointBack.TextComponent.OutlineColor = Color.FromHexCode("#416CB9")
		
		
			self.button_Request_PointReset.SpriteGUIRendererComponent.ImageRUID = "1b817e998fc340709279e8d9b92b4b8e" 
			self.button_Request_PointReset.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.button_Request_PointReset.TextComponent.OutlineColor = Color.FromHexCode("#616161")
			self.button_Request_PointReset:GetChildByName("icon_reset", true).SpriteGUIRendererComponent.OutlineColor = Color.FromHexCode("#616161")
			
		else
			self.button_Request_Levelup.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29" 
			self.button_Request_Levelup.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.button_Request_Levelup.TextComponent.OutlineColor = Color.FromHexCode("#616161")
		
			self.button_Request_PointBack.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29" 
			self.button_Request_PointBack.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.button_Request_PointBack.TextComponent.OutlineColor = Color.FromHexCode("#616161")
		
			self.button_Request_PointReset.SpriteGUIRendererComponent.ImageRUID = "c7b38a460c434e0aa6901e187062ff10" 
			self.button_Request_PointReset.TextComponent.FontColor = Color.FromHexCode("#ffffff")
			self.button_Request_PointReset.TextComponent.OutlineColor = Color.FromHexCode("#416cb9")
			self.button_Request_PointReset:GetChildByName("icon_reset", true).SpriteGUIRendererComponent.OutlineColor = Color.FromHexCode("#416cb9")
		
			
		end
		
		if _AbilityLogic:CheckExistInvestedStatusPoint(_UserService.LocalPlayer.PlayerComponent.UserId) == false then
			self.button_Request_PointReset.SpriteGUIRendererComponent.ImageRUID = "1b817e998fc340709279e8d9b92b4b8e" 
			self.button_Request_PointReset.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.button_Request_PointReset.TextComponent.OutlineColor = Color.FromHexCode("#616161")
			self.button_Request_PointReset:GetChildByName("icon_reset", true).SpriteGUIRendererComponent.OutlineColor = Color.FromHexCode("#616161")
		end
	end

	method void AddButtonEffectSwitch(boolean switch)
		-- 버튼 이팩트 표시 여부를 설정
		
		local switchTable = {switch, switch, switch, switch}
		local abilityLv = _UserService.LocalPlayer.PlayerAbilityComponent.ability["lvData"].lv
		local ability = _UserService.LocalPlayer.PlayerAbilityComponent.ability
		local statusData = _AbilityLogic.abilityStatusData
		local abilityData = _AbilityLogic.abilityExpData[abilityLv]
		local toUsePoint = _UserService.LocalPlayer.PlayerAbilityComponent.toUsePoints
		
		if ability["type_1"].lv + toUsePoint[1] >= abilityData.max_Attack_Level and switch then
			switchTable[1] = not switch
		end 
		
		if ability["type_2"].lv + toUsePoint[2] >= abilityData.max_Hp_Level and switch then
			switchTable[2] = not switch
		end 
		
		if ability["type_3"].lv + toUsePoint[3] >= abilityData.max_Mp_Level and switch then
			switchTable[3] = not switch
		end 
		
		if ability["type_4"].lv + toUsePoint[4] >= abilityData.max_ReductCooltime_Level and switch then
			switchTable[4] = not switch
		end 
		
		
		local ruid = "5e6ddfb6e9314f5c9c4f57fd576c94a2" 
		local alpha = 0.3
		
		if switchTable[1] == true then
			ruid = "7dc0a010da0a48539e4a9aa69184afc9"
			alpha = 1
		else
			ruid = "5e6ddfb6e9314f5c9c4f57fd576c94a2" 
			alpha = 0.3
		end
		self.button_Add_Type_1.Parent:GetChildByName("effect", true).Enable = switchTable[1]
		self.button_Add_Type_1.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add_Type_1.Children[1].SpriteGUIRendererComponent.Color.a = alpha
		self.button_Add10_Type_1.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add10_Type_1.Children[1].SpriteGUIRendererComponent.Color.a = alpha
		self.button_Add10_Type_1.TextComponent.FontColor.a = alpha
		
		if switchTable[2] == true then
			ruid = "7dc0a010da0a48539e4a9aa69184afc9"
			alpha = 1
		else
			ruid = "5e6ddfb6e9314f5c9c4f57fd576c94a2" 
			alpha = 0.3
		end
		self.button_Add_Type_2.Parent:GetChildByName("effect", true).Enable = switchTable[2]
		self.button_Add_Type_2.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add_Type_2.Children[1].SpriteGUIRendererComponent.Color.a = alpha
		self.button_Add10_Type_2.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add10_Type_2.Children[1].SpriteGUIRendererComponent.Color.a = alpha
		self.button_Add10_Type_2.TextComponent.FontColor.a = alpha
		
		if switchTable[3] == true then
			ruid = "7dc0a010da0a48539e4a9aa69184afc9"
			alpha = 1
		else
			ruid = "5e6ddfb6e9314f5c9c4f57fd576c94a2" 
			alpha = 0.3
		end
		self.button_Add_Type_3.Parent:GetChildByName("effect", true).Enable = switchTable[3]
		self.button_Add_Type_3.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add_Type_3.Children[1].SpriteGUIRendererComponent.Color.a = alpha
		self.button_Add10_Type_3.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add10_Type_3.Children[1].SpriteGUIRendererComponent.Color.a= alpha
		self.button_Add10_Type_3.TextComponent.FontColor.a = alpha
		
		if switchTable[4] == true then
			ruid = "7dc0a010da0a48539e4a9aa69184afc9"
			alpha = 1
		else
			ruid = "5e6ddfb6e9314f5c9c4f57fd576c94a2" 
			alpha = 0.3
		end
		self.button_Add_Type_4.Parent:GetChildByName("effect", true).Enable = switchTable[4]
		self.button_Add_Type_4.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add_Type_4.Children[1].SpriteGUIRendererComponent.Color.a = alpha
		self.button_Add10_Type_4.SpriteGUIRendererComponent.ImageRUID = ruid
		self.button_Add10_Type_4.Children[1].SpriteGUIRendererComponent.Color.a  = alpha
		self.button_Add10_Type_4.TextComponent.FontColor.a   = alpha
	end

	method void SetMinutBtnStatus()
		-- 마이너스 버튼의 활성화 상태를 설정
		local toUsePoint = _UserService.LocalPlayer.PlayerAbilityComponent.toUsePoints
		local switch = {false, false, false, false}
		
		if toUsePoint[1] >= 1 then
			switch[1] = true
			
			self.button_Minus_Type_1.SpriteGUIRendererComponent.ImageRUID =  "7dc0a010da0a48539e4a9aa69184afc9"
			self.button_Minus10_Type_1.SpriteGUIRendererComponent.ImageRUID =  "7dc0a010da0a48539e4a9aa69184afc9"
			
			self.button_Minus10_Type_1.TextComponent.FontColor.a = 1
			
			self.button_Minus_Type_1.Children[1].SpriteGUIRendererComponent.Color.a = 1
			self.button_Minus10_Type_1.Children[1].SpriteGUIRendererComponent.Color.a= 1
		else
			self.button_Minus_Type_1.SpriteGUIRendererComponent.ImageRUID ="5e6ddfb6e9314f5c9c4f57fd576c94a2"
			self.button_Minus10_Type_1.SpriteGUIRendererComponent.ImageRUID =  "5e6ddfb6e9314f5c9c4f57fd576c94a2"
		
			self.button_Minus10_Type_1.TextComponent.FontColor.a = 0.3
			
			self.button_Minus_Type_1.Children[1].SpriteGUIRendererComponent.Color.a= 0.3
			self.button_Minus10_Type_1.Children[1].SpriteGUIRendererComponent.Color.a = 0.3
		end 
		
		if toUsePoint[2] >= 1 then
			switch[2] = true
			self.button_Minus_Type_2.SpriteGUIRendererComponent.ImageRUID =  "7dc0a010da0a48539e4a9aa69184afc9"
			self.button_Minus10_Type_2.SpriteGUIRendererComponent.ImageRUID =  "7dc0a010da0a48539e4a9aa69184afc9"
		
		
			self.button_Minus10_Type_2.TextComponent.FontColor.a = 1
		
			self.button_Minus_Type_2.Children[1].SpriteGUIRendererComponent.Color.a = 1
			self.button_Minus10_Type_2.Children[1].SpriteGUIRendererComponent.Color.a= 1
		else
			self.button_Minus_Type_2.SpriteGUIRendererComponent.ImageRUID =  "5e6ddfb6e9314f5c9c4f57fd576c94a2"
			self.button_Minus10_Type_2.SpriteGUIRendererComponent.ImageRUID =  "5e6ddfb6e9314f5c9c4f57fd576c94a2"
		
			self.button_Minus10_Type_2.TextComponent.FontColor.a = 0.3
		
			self.button_Minus_Type_2.Children[1].SpriteGUIRendererComponent.Color.a = 0.3
			self.button_Minus10_Type_2.Children[1].SpriteGUIRendererComponent.Color.a= 0.3
		end 
		
		if toUsePoint[3] >= 1 then
			switch[3] = true
			self.button_Minus_Type_3.SpriteGUIRendererComponent.ImageRUID =  "7dc0a010da0a48539e4a9aa69184afc9"
			self.button_Minus10_Type_3.SpriteGUIRendererComponent.ImageRUID =  "7dc0a010da0a48539e4a9aa69184afc9"
		
			self.button_Minus10_Type_3.TextComponent.FontColor.a = 1
		
			self.button_Minus_Type_3.Children[1].SpriteGUIRendererComponent.Color.a = 1
			self.button_Minus10_Type_3.Children[1].SpriteGUIRendererComponent.Color.a= 1
		else
			self.button_Minus_Type_3.SpriteGUIRendererComponent.ImageRUID =  "5e6ddfb6e9314f5c9c4f57fd576c94a2"
			self.button_Minus10_Type_3.SpriteGUIRendererComponent.ImageRUID =  "5e6ddfb6e9314f5c9c4f57fd576c94a2"
		
			self.button_Minus10_Type_3.TextComponent.FontColor.a = 0.3
			
			self.button_Minus_Type_3.Children[1].SpriteGUIRendererComponent.Color.a= 0.3
			self.button_Minus10_Type_3.Children[1].SpriteGUIRendererComponent.Color.a= 0.3
		end 
		
		if toUsePoint[4] >= 1 then
			switch[4] = true
			self.button_Minus_Type_4.SpriteGUIRendererComponent.ImageRUID = "7dc0a010da0a48539e4a9aa69184afc9"
			self.button_Minus10_Type_4.SpriteGUIRendererComponent.ImageRUID = "7dc0a010da0a48539e4a9aa69184afc9"
		
			self.button_Minus10_Type_4.TextComponent.FontColor.a = 1
			self.button_Minus_Type_4.Children[1].SpriteGUIRendererComponent.Color.a= 1
			self.button_Minus10_Type_4.Children[1].SpriteGUIRendererComponent.Color.a = 1
		
		else
			self.button_Minus_Type_4.SpriteGUIRendererComponent.ImageRUID = "5e6ddfb6e9314f5c9c4f57fd576c94a2"
			self.button_Minus10_Type_4.SpriteGUIRendererComponent.ImageRUID = "5e6ddfb6e9314f5c9c4f57fd576c94a2"
		
			self.button_Minus10_Type_4.TextComponent.FontColor.a = 0.3
			
			self.button_Minus_Type_4.Children[1].SpriteGUIRendererComponent.Color.a= 0.3
			self.button_Minus10_Type_4.Children[1].SpriteGUIRendererComponent.Color.a = 0.3
		end 
	end

	method void ChangeCurrentStatusPoint(number value)
		-- 현재 스태터스 포인트 표시 및 색상 변경
		local colorCode = Color.FromHexCode("#FFFFFF")
		
		if value >= 1 then
			colorCode = Color.FromHexCode("#7DE9FC")
		end
		
		self.abilityCurrentPoints.TextComponent.FontColor = colorCode
		self.abilityCurrentPoints.TextComponent.Text = string.format("%d", value)
	end

	method void RefreshFieldStatusCurrentAndLimitPoints(boolean stateInPointChange)
		-- 필드 스태터스 현재/최대 포인트 표시 갱신
		local abilityLv = _UserService.LocalPlayer.PlayerAbilityComponent.ability["lvData"].lv
		local ability = _UserService.LocalPlayer.PlayerAbilityComponent.ability
		local statusData = _AbilityLogic.abilityStatusData
		local abilityData = _AbilityLogic.abilityExpData[abilityLv]
		local toUsePoint = _UserService.LocalPlayer.PlayerAbilityComponent.toUsePoints
		
		
		if stateInPointChange == false then
			self.fieldStatusPoint_Type1.Text = string.format("%d/%d", ability["type_1"].lv, abilityData.max_Attack_Level)
			self.fieldStatusPoint_Type2.Text = string.format("%d/%d", ability["type_2"].lv, abilityData.max_Hp_Level)
			self.fieldStatusPoint_Type3.Text = string.format("%d/%d", ability["type_3"].lv, abilityData.max_Mp_Level)
			self.fieldStatusPoint_Type4.Text = string.format("%d/%d", ability["type_4"].lv, abilityData.max_ReductCooltime_Level)
		else
			self.fieldStatusPoint_Type1.Text = string.format("%d/%d", ability["type_1"].lv+ toUsePoint[1], abilityData.max_Attack_Level)
			self.fieldStatusPoint_Type2.Text = string.format("%d/%d", ability["type_2"].lv+ toUsePoint[2], abilityData.max_Hp_Level)
			self.fieldStatusPoint_Type3.Text = string.format("%d/%d", ability["type_3"].lv+ toUsePoint[3], abilityData.max_Mp_Level)
			self.fieldStatusPoint_Type4.Text = string.format("%d/%d", ability["type_4"].lv+ toUsePoint[4], abilityData.max_ReductCooltime_Level)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleChangePlayerAbiltyData(ChangePlayerAbilityData event)
		-- 플레이어 능력 데이터 변경 이벤트 처리
		local ability = event.ability
		if self.isOpen then
			if _AbilityLogic:GetToUseAbilityPoints() >= 1 then
				self:RefreshByChangePoints(false)
			else
				self:Refresh()
			end
			
		end
		local cp = ability["lvData"].cp
		local switch = true
		if cp < 1 then
			switch = false
		end
		self.abilityUIButton_Lobby:GetChildByName("currentAbilityPoiint").Enable = switch
		self.abilityUIButton_MultiBattleMap:GetChildByName("currentAbilityPoiint").Enable =switch
		
		self.abilityUIButton_Lobby:GetChildByName("currentAbilityPoiint").TextComponent.Text = string.format("%d", cp)
		self.abilityUIButton_MultiBattleMap:GetChildByName("currentAbilityPoiint").TextComponent.Text = string.format("%d", cp)
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleDBLoadedEvent(DBLoadedEvent event)
		-- DB 로드 완료 이벤트 처리 및 UI 갱신
		local ppsn = event.ppsn
		if _UserService.LocalPlayer.PlayerAbilityComponent.dbLoaded == false then
			return
		end
		
		local cp = _UserService.LocalPlayer.PlayerAbilityComponent.ability["lvData"].cp
		local switch = true
		if cp < 1 then
			switch = false
		end
		self.abilityUIButton_Lobby:GetChildByName("currentAbilityPoiint").Enable = switch
		self.abilityUIButton_MultiBattleMap:GetChildByName("currentAbilityPoiint").Enable =switch
		
		self.abilityUIButton_Lobby:GetChildByName("currentAbilityPoiint").TextComponent.Text = string.format("%d", cp)
		self.abilityUIButton_MultiBattleMap:GetChildByName("currentAbilityPoiint").TextComponent.Text = string.format("%d", cp)
		
	end

end