	end

	method void ResetArmorSkill(Entity target)
		-- 모든 방어구 스킬 효과를 초기화하고 재적용
		self:Init()
		
		self:ApplyHelmetSkill(target.PlayerStorageComponent.equipArmorTable["helmet"], target, true)
		self:ApplySuitSkill(target.PlayerStorageComponent.equipArmorTable["suit"], target, true)
		self:ApplyGloveSkill(target.PlayerStorageComponent.equipArmorTable["glove"], target, true)
		self:ApplyShoesSkill(target.PlayerStorageComponent.equipArmorTable["shoes"], target, true)
		
	end

	method void Init()
		-- 방어구 스킬 효과 테이블 초기화
		
		
		self.originalFxTable["upRateMoveSpeedAfterDash"] = 0 
		
		self.originalFxTable["downRateMeleeDamage"] = 0
		self.originalFxTable["downRateMeleeEvade"] = 0
		
		self.originalFxTable["downRateProjectileDamage"] = 0
		self.originalFxTable["downRateProjectileEvade"] = 0
		
		self.originalFxTable["downRateBossDamage"] = 0
		self.originalFxTable["downRateBossEvade"] = 0
		self.originalFxTable["downRateDashCooltime"] = 0
		
		self.originalFxTable["healOnHitCritical"] = 0 
		
		self.originalFxTable["slowToMonster"] = false 
		self.originalFxTable["poisonToMonster"] = false 
		self.originalFxTable["guardianBallToPlayer"] = 0 
		self.originalFxTable["addWeaponSlotCard"] = false
		
		self.originalFxTable["knockbackPowerAroundPlayer"] = 0 
		
		self.originalFxTable["guardianBeanToPlayer"] = 0 
		self.originalFxTable["spawnCooltimeStickyPool"] = 0 
		self.originalFxTable["spawnHitMark"] = 0 
		self.originalFxTable["spawnHoneyUnderMaxHpPercent30"] = false 
		
		self.originalFxTable["upRateMoveSpeedOnHit"] = 0
		self.originalFxTable["spawnIgniteOnHit"] = 0 
		self.originalFxTable["cooltimeTempInvincible"] = 0 
		self.originalFxTable["selectiveDefense"] = 0
		
		
		self.originalFxTable["rebornAfterDead"] = 0
		self.originalFxTable["invincibleUnderHpPercent5"] = false 
		self.originalFxTable["regenHpUnderMaxHpPercent10"] = 0 
		self.originalFxTable["increaseMaxHpWheneverKillMonster20"] = 0
		
		self.originalFxTable["healWheneverWaveStart"] = 0 
		self.originalFxTable["healWheneverNoDamage15"] = 0 
		
		self.originalFxTable["dropGoldKillMonster"] = false 
		self.originalFxTable["dropGoldKillBoss"] = false 
		
		table.clear(self.fxTable)
		self.fxTable = _GameUtil:DeepCopyTable(self.originalFxTable)
		
		for key, value in pairs(self.fxTable) do
			local statType = tostring(type(value))
			
			if statType == "number" then
				self.fxTable[key] = 0
			elseif statType == "boolean" then
				self.fxTable[key] = false
			end
		end
		
		
	end

	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 스킬 테이블 설정
		self:Init()
		self.userId = self.Entity.PlayerComponent.UserId
	end

	@ExecSpace("Client")
	method void SetFxTableInClient(table fxTable)
		-- 클라이언트에서 효과 테이블 설정
		self.fxTable = fxTable
	end

	@ExecSpace("Server")
	method void SetFxTableInServer(table fxTable)
		-- 서버에서 효과 테이블 설정
		self.fxTable = fxTable
	end

	@ExecSpace("Client")
	method void CallSystemMessage(string systemMessage, string source)
		-- 시스템 메시지 표시 (전투 중일 때만)
		local currentMap = _UserService.LocalPlayer.CurrentMap
		
		if currentMap.CurrentMapName == "Town" then
			return
		end
		
		if isvalid(currentMap.BattleMap) then
			if currentMap.BattleMap.isEnd == true then
				return
			end
		elseif isvalid(currentMap.LimitMapComponent) then
			if currentMap.LimitMapComponent.isEnd == true then
				return
			end
		elseif isvalid(currentMap.RandomBossMapComponent) then
			if currentMap.RandomBossMapComponent.isEnd == true then
				return
			end
		end
		
		_SystemMessageLogic:ShowMessage(systemMessage, source)
		
	end

end