@Component
script PlayerArmorSkillComponent extends Component

	property table fxTable = {}

	property table originalFxTable = {}

	property string userId = ""

	@ExecSpace("Client")
	method void ApplyHelmetSkill(string id, Entity player, boolean reset)
		-- 헬멧 아이템의 스킬 효과 적용
		if id == "" or id == nil or not isvalid(player.BattlePlayer) then
			return
		end
		
		if player.BattlePlayer.armorSkillEnable == false then 
			return
		end
		
		local armorData = _ArmorSpecLogic.armorData[id]
		local grade = _ArmorSystemLogic:GetGradeById(armorData.grade)
		
		if armorData.name == "Helmet_Warrior" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.helmetWarriorLevel = 1 
					if grade == "epic" or grade == "unique" or grade == "legendary" then 
						if grade == "unique" or grade == "legendary" then 
							_BuffLogic.appliedBuff.helmetWarriorLevel = 2 
							if grade == "legendary" then 
								_BuffLogic.appliedBuff.helmetWarriorLevel = 3 
							end
						end
					end
				end
			end
		elseif armorData.name == "Helmet_Shark" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.helmetSharkLevel = 1
					if grade == "epic" or grade == "unique" or grade == "legendary" then 
						if grade == "unique" or grade == "legendary" then 
							_BuffLogic.appliedBuff.helmetSharkLevel = 2
							if grade == "legendary" then 
								_BuffLogic.appliedBuff.helmetSharkLevel = 3
							end
						end
					end
				end
			end
			
		elseif armorData.name == "Helmet_Angel" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.helmetAngelLevel = 1
						if grade == "unique" or grade == "legendary" then 
							_BuffLogic.appliedBuff.helmetAngelLevel = 2
						if grade == "legendary" then 
							_BuffLogic.appliedBuff.helmetAngelLevel = 3
						end
					end
				end
			end
		end
		
		
	end

	@ExecSpace("Client")
	method void ApplySuitSkill(string id, Entity player, boolean reset)
		-- 슈트 아이템의 스킬 효과 적용
		if id == "" or id == nil or not isvalid(player.BattlePlayer)  then
			return
		end
		
		if player.BattlePlayer.armorSkillEnable == false then 
			return
		end
		
		local armorData = _ArmorSpecLogic.armorData[id]
		local grade = _ArmorSystemLogic:GetGradeById(armorData.grade)
		
		local frontId = string.sub(id, 1, 5)
		local backId = tonumber(string.sub(id, 6, -1))
		
		if armorData.name == "Suit_Martial" then 
		
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.suitMartialLevel = 1
					if grade == "unique" or grade == "legendary" then 
						_BuffLogic.appliedBuff.suitMartialLevel = 2
						if grade == "legendary" then 
							_BuffLogic.appliedBuff.suitMartialLevel = 3
						end
					end
				end
			end
		
		
		elseif armorData.name == "Suit_Poor" then 
		
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.suitPoorLevel = 1
					if grade == "unique" or grade == "legendary" then 
						_BuffLogic.appliedBuff.suitPoorLevel = 2
						if grade == "legendary" then 
							_BuffLogic.appliedBuff.suitPoorLevel = 3
						end
					end
				end
			end
		
			_ArmorSkillLogic:ExcutePoorSuit(player)
		
		elseif armorData.name == "Suit_Shield" then 
		
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.suitShieldLevel = 1
					
					
					if grade == "unique" or grade == "legendary" then 
						_BuffLogic.appliedBuff.suitShieldLevel = 2
						
						
						if grade == "legendary" then 
							_BuffLogic.appliedBuff.suitShieldLevel = 3
						end
					end
				end
			end
			
		elseif armorData.name == "Suit_Chicken" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.suitChickenLevel = 1
					if grade == "unique" or grade == "legendary" then 
						_BuffLogic.appliedBuff.suitChickenLevel = 2
						if grade == "legendary" then 
							_BuffLogic.appliedBuff.suitChickenLevel = 3
						end
					end
				end
			end
		end
	end

	@ExecSpace("Client")
	method void ApplyGloveSkill(string id, Entity player, boolean reset)
		-- 장갑 아이템의 스킬 효과 적용
		if id == "" or id == nil or not isvalid(player.BattlePlayer)  then
			return
		end
		
		if player.BattlePlayer.armorSkillEnable == false then 
			return
		end
		
		local armorData = _ArmorSpecLogic.armorData[id]
		local grade = _ArmorSystemLogic:GetGradeById(armorData.grade)
		
		local frontId = string.sub(id, 1, 5)
		local backId = tonumber(string.sub(id, 6, -1))
		
		if armorData.name == "Glove_Wing" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					_BuffLogic.appliedBuff.gloveWingLevel = 1
					if grade == "unique" or grade == "legendary" then 
						_BuffLogic.appliedBuff.gloveWingLevel = 2
						if grade == "legendary" then 
							_BuffLogic.appliedBuff.gloveWingLevel = 3
						end
					end
				end
			end
		
			
		elseif armorData.name == "Glove_Flame" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					local systemMessage = string.format(_LocalizeLogic:GetText("systemMessage193"), _LocalizationService:GetText("Glove_Flame"))
					_BuffLogic.appliedBuff.gloveFlameLevel = 1
					if grade == "unique" or grade == "legendary" then 
						systemMessage = string.format(_LocalizeLogic:GetText("systemMessage194"), _LocalizationService:GetText("Glove_Flame"))
						_BuffLogic.appliedBuff.gloveFlameLevel = 2
						if grade == "legendary" then 
							systemMessage = string.format(_LocalizeLogic:GetText("systemMessage195"), _LocalizationService:GetText("Glove_Flame"))
							_BuffLogic.appliedBuff.gloveFlameLevel = 3
						end
					end
					self:CallSystemMessage(systemMessage, "equ")
				end
			end
		
		elseif armorData.name == "Glove_Weapon" then 
			if grade == "normal" or grade == "rare" or grade ==  "epic" or grade == "unique" or grade == "legendary" then 
				if grade == "epic" or grade == "unique" or grade == "legendary" then 
				else
				end
				if grade == "rare" or grade == "epic" or grade == "unique" or grade == "legendary" then
					local systemMessage = string.format(_LocalizeLogic:GetText("systemMessage196"), _LocalizationService:GetText("Glove_Weapon"))
					_BuffLogic.appliedBuff.gloveWeaponLevel = 1
					if grade == "unique" or grade == "legendary" then 
						systemMessage = string.format(_LocalizeLogic:GetText("systemMessage197"), _LocalizationService:GetText("Glove_Weapon"))
						_BuffLogic.appliedBuff.gloveWeaponLevel = 2
						if grade == "legendary" then 
							systemMessage = string.format(_LocalizeLogic:GetText("systemMessage198"), _LocalizationService:GetText("Glove_Weapon"))
							_BuffLogic.appliedBuff.gloveWeaponLevel = 3
						end
					end
					self:CallSystemMessage(systemMessage, "equ")
				end
			end
		end
	end

	@ExecSpace("Client")
