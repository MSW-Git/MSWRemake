@Component
script PlayerCharacterSlotButton extends Component

	property string index = ""

	property Entity parent = nil

	property Entity gague = nil

	property Entity gaugeCount = nil

	property boolean unlock = false

	property string star_ruid = "877d010d8bfe46bc881f26f1c7adc3ba"

	property string star_blank_ruid = "cdb4f75585614caa9647d7eb04545dfe"

	property string material_grayScale_id = "material://a58cbfd6-0988-4bd4-a30b-89e51565bef4"

	property string slider_ruid = "7ed0e6e6e26c44e792c0e405ca96a980"

	property string slider_lcok_ruid = "7ed0e6e6e26c44e792c0e405ca96a980"

	@ExecSpace("Client")
	method void Init(string index)
		-- 캐릭터 슬롯 버튼 초기화 및 UI 요소 설정
		
		
		
		
		local character = _UserService.LocalPlayer.PlayerCharacterData
		self.index = index
		
		
		local allCharTable = _CharacterLogic.characterTable[self.index] 
		self._T.stars = self.parent:GetChildByName("stars", true)
		self._T.state = self.parent:GetChildByName("state", true)
		local name = self.parent:GetChildByName("name", true)
		local level = self.parent:GetChildByName("level", true)
		local equipped = self.parent:GetChildByName("equipped", true)
		self._T.maxTier = self.parent:GetChildByName("maxTier", true)
		local pieceIcon = self.parent:GetChildByName("pieceIcon", true)
		self._T.pieceOutline = self.parent:GetChildByName("outline", true)
		self._T.lock = self.parent:GetChildByName("lock", true)
		
		self._T.lock.Enable = false
		self._T.stars:SetEnable(false)
		self._T.state:SetEnable(false)
		name:SetEnable(true)
		level:SetEnable(false)
		equipped:SetEnable(false)
		self._T.maxTier:SetEnable(false)
		
		
		pieceIcon.SpriteGUIRendererComponent.ImageRUID = allCharTable.pieceRUID
		self.parent.SpriteGUIRendererComponent.ImageRUID = allCharTable.illustRUID 
		
		
		local weaponId = allCharTable.exWeaponId[1]
		self.parent:GetChildByName("exWeaponIcon", true).SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[weaponId].type)
		name.TextComponent.Text = _LocalizationService:GetText("soul_name_"..self.index) 
		name.TextComponent.FontColor = Color.white
		
		if isvalid(character.charDeckStorage[tonumber(index)]) then 
			if character.charIndex == tonumber(self.index) then
				equipped:SetEnable(true)
			end
			local myCharTable = character.charDeckStorage[tonumber(index)]	
			local charLevel = myCharTable.level
			local tier = myCharTable.tier 
		
			level:SetEnable(true)
			level.TextComponent.Text = myCharTable.level 
			
			for i = 1 , #self._T.stars.Children do
				if tier >= i then
					self._T.stars:GetChildByName("star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = self.star_ruid
				else
					self._T.stars:GetChildByName("star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = self.star_blank_ruid
				end
			end
			self._T.stars:SetEnable(true)
			
			self.parent.SpriteGUIRendererComponent:ChangeMaterial("") 
			self.parent.SpriteGUIRendererComponent.Color.a = 1
		
		
		else 
			self.parent.SpriteGUIRendererComponent:ChangeMaterial(self.material_grayScale_id) 
			self.parent.SpriteGUIRendererComponent.Color.a = 0.5
			name.TextComponent.FontColor = Color.gray 
			
			self._T.state.TextComponent.Text = _LocalizationService:GetText("common_Not_Possesion") 
			self._T.state.TextComponent.FontColor = Color.gray
			self._T.state:SetEnable(true)
		end
		
		self:RefreshCharPieceCondition(tonumber(index))
	end

	@ExecSpace("Client")
	method void RefreshCharPieceCondition(number id)
		-- 캐릭터 조각 상태 갱신 및 UI 업데이트
		
		local character = _UserService.LocalPlayer.PlayerCharacterData
		local charLevel = 0
		local charTier = 0
		
		local charDeck = character.charDeckStorage[tonumber(id)]
		
		if isvalid(charDeck) then 
			charLevel = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(id)].level
			charTier = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(id)].tier
		end
		
		local maxPieceCount = _CharacterLogic:GetMaxPieceCount(charTier, math.floor(id), _UserService.LocalPlayer)
		
		if id == tonumber(self.index) then
			local charPieceTable = character.charPieceStorage
			self.gague.SliderComponent.Value = charPieceTable[tonumber(self.index)].count/maxPieceCount
			self.gaugeCount.TextComponent.Text = math.floor(charPieceTable[tonumber(self.index)].count).."/"..math.floor(maxPieceCount)
			self.gague.SliderComponent.FillRectImageRUID = "7ed0e6e6e26c44e792c0e405ca96a980"
			self.gague.Parent.Enable = true
		
			
			if isvalid(charDeck) then
				self._T.state.Enable = false
				self._T.lock.Enable = false
				if charDeck.tier < 5 then
					if charPieceTable[tonumber(self.index)].count >= maxPieceCount then
						self._T.pieceOutline.Enable = true
					else
						self._T.pieceOutline.Enable = false
					end
					self.parent:GetChildByName("maxTier", true):SetEnable(false)
				else 
					self.gague.Parent.Enable = false
					self.parent:GetChildByName("maxTier", true):SetEnable(true)
				end
			else
				self._T.state.Enable = true
				if charPieceTable[tonumber(self.index)].count >= maxPieceCount then
					self._T.lock.Enable = false
					self._T.pieceOutline.Enable = true
					self._T.state.TextComponent.Text = _LocalizationService:GetText("common_PossibleUnlock") 
					self._T.state.TextComponent.FontColor = Color.yellow
				else
					self._T.lock.Enable = true
					self._T.pieceOutline.Enable = false
					self._T.state.TextComponent.Text = _LocalizationService:GetText("common_Not_Possesion") 
					self._T.state.TextComponent.FontColor = Color.white	
					self.gague.SliderComponent.FillRectImageRUID = "4d3053287ce54dec9a07146e9ad80b6f"
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 부모 엔티티 및 UI 요소 참조 설정
		self.parent = self.Entity.Parent
		self.gague = self.Entity.Parent:GetChildByName("bar", true)
		self.gaugeCount = self.Entity.Parent:GetChildByName("pieceCount", true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐릭터 슬롯 버튼 클릭 시 캐릭터 정보 팝업 또는 획득 팝업 열기
		
		local Entity = event.Entity
		
		if not isvalid(_UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(self.index)]) then 
			_UIGroupManager.uiCharacterGroup:OpenGetCharacterPopUp(self.index) 
		else 
			_UIGroupManager.uiCharacterInfoPopup:OpenCharacterInformationPanel(self.index) 
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleChangeCharacterPieceCount(ChangeCharacterPieceCount event)
		-- 캐릭터 조각 개수 변경 이벤트 처리
		local table = event.table
		local id = event.id
		self:RefreshCharPieceCondition(id)
	end

end