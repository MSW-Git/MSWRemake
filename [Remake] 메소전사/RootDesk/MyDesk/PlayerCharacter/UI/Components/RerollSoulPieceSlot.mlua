@Component
script RerollSoulPieceSlot extends Component

	property number index = 0

	property integer count = 0

	property Entity btn_up = nil

	property Entity btn_down = nil

	property Entity btn_all = nil

	property Entity text_count = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 리롤 슬롯 UI 요소 초기화 및 이벤트 연결
		self.btn_up = self.Entity:GetChildByName("CountUp", true)
		self.btn_down = self.Entity:GetChildByName("CountDown", true)
		
		self.text_count = self.Entity:GetChildByName("Count", true)
		self._T.haveCount = self.Entity:GetChildByName("haveCount", true)
		
		self.btn_up:ConnectEvent(ButtonClickEvent, self.OnUpClick)
		self.btn_down:ConnectEvent(ButtonClickEvent, self.OnDownClick)
	end

	method void OnUpClick()
		-- 리롤 수량 증가 버튼 클릭 처리
		_UserService.LocalPlayer.PlayerCharacterData:AddRegistRerollTable(self.index)
	end

	method void OnDownClick()
		-- 리롤 수량 감소 버튼 클릭 처리
		_UserService.LocalPlayer.PlayerCharacterData:MinusRegistRerollTable(self.index)
	end

	method void RefreshCount(number count)
		-- 리롤 수량 표시 갱신
		local soulPieceData = _UserService.LocalPlayer.PlayerCharacterData.charPieceStorage[self.index]
		
		if soulPieceData ~= nil then
			self._T.haveCount.TextComponent.Text = math.floor(soulPieceData.count - count) 
			self.text_count.TextComponent.Text = tostring(math.floor(count)) 
		end
	end

	method void Init(number index)
		-- 리롤 슬롯 초기화 및 영혼 조각 이미지 설정
		self.index = index
		self.Entity:GetChildByName("sprite").SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[tostring(math.floor(index))].pieceLargeRUID
	end

end