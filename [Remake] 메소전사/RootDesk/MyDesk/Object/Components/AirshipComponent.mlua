@Component
script AirshipComponent extends Component

	property Vector2 landingPoint = Vector2(0,0)

	@ExecSpace("Server")
	method void SetRotation()
		-- 착륙지점을 향해 비행선의 회전각도를 설정
		local transform = self.Entity.TransformComponent
		
		local direction = self.landingPoint:Clone() - transform.Position:ToVector2()
		local angle = math.atan(direction.y, direction.x)
		local radian = math.deg(angle)
		transform.ZRotation = radian + 180
		self:SetRotationInClient(transform.ZRotation)
	end

	@ExecSpace("Client")
	method void SetRotationInClient(number zRotation)
		-- 클라이언트에서 비행선의 회전각도를 적용
		self.Entity.TransformComponent.ZRotation = zRotation
	end

	@ExecSpace("Client")
	method void SwitchCamera()
		-- 비행선 카메라로 전환
		_CameraService:SwitchCameraTo(self.Entity.CameraComponent)
	end

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 비행선 자동 삭제 타이머 설정
		local callback = function()
			if isvalid(self.Entity) then
				self.Entity:Destroy()
			end
		end
		
		_TimerService:SetTimerOnce(callback, 30)
	end

end