@Component
script StickyComponent extends Component

	property integer timer = 0

	property boolean used = false

	@ExecSpace("ClientOnly")
	method void Init(number lifeTime)
		-- 끈적한 함정 초기화 및 생명주기 설정
		self.used = false
		self.Entity.SpriteRendererComponent.Color.a = 0
		self.Entity.SpriteRendererComponent.SpriteRUID = "89a629e1eb4c4e3bb96dd59b59865812"
		
		self.Entity.SpriteRendererComponent.SortingLayer = _UserService.LocalPlayer.AvatarRendererComponent.SortingLayer
		self.Entity.SpriteRendererComponent.OrderInLayer = _UserService.LocalPlayer.AvatarRendererComponent.OrderInLayer - 1
		
		self.timer = _TimerLogic:SetTimerOnce(function()
			self.used = true
			self:AlphaDown()
			end, lifeTime, "StickyComponent.Init")
		
		self:AlphaUp()
	end

	@ExecSpace("Client")
	method void AlphaUp()
		-- 함정의 투명도를 점진적으로 올림
		local alphaUp = function()
			self.Entity.SpriteRendererComponent.Color.a = self.Entity.SpriteRendererComponent.Color.a + 0.1
		end
		
		for i = 1, 10 do
			_TimerLogic:SetTimerOnce(alphaUp, (i*1)/10, "StickyComponent.AlphaUp")	
		end
	end

	@ExecSpace("Client")
	method void AlphaDown()
		-- 함정의 투명도를 점진적으로 내리고 삭제
		local count = 0
		
		local alphaDown = function()
			count = count + 1
			self.Entity.SpriteRendererComponent.Color.a = self.Entity.SpriteRendererComponent.Color.a - 0.1
			if count >= 10 then
				_PoolingLogic:DestroyEntity(self.Entity)
			end
		end
		
		for i = 1, 10 do
			_TimerLogic:SetTimerOnce(alphaDown, (i*1)/10, "StickyComponent.AlphaDown")	
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 몬스터가 함정에 진입했을 때 슬로우 디버프 적용
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		if not isvalid(TriggerBodyEntity) or not TriggerBodyEntity.Enable then return end
		
		local monster = TriggerBodyEntity.MonsterObject
		
		if isvalid(monster) and self.used == false then
			self.used = true
			monster:ApplySpeedBuff(0.5, 5)
			self.Entity.SpriteRendererComponent.SpriteRUID = "7c9874902e824f0f8241e9296d9b33d2"
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerEndFrameEvent(SpriteAnimPlayerEndFrameEvent event)
		-- 스프라이트 애니메이션 종료 시 함정 삭제 처리
		
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		if self.Entity.Enable and self.Entity.SpriteRendererComponent.SpriteRUID == "7c9874902e824f0f8241e9296d9b33d2" then
			self.Entity.SpriteRendererComponent.SpriteRUID = "89a629e1eb4c4e3bb96dd59b59865812"
			_TimerLogic:ClearTimer(self.timer)
			self:AlphaDown()
		end
	end

end