		local itemCategory = _UtilLogic:Split(playerStorage.storage[uniqueKey].originalId, "_")[1]
		local item = playerStorage.storage[uniqueKey]
		local category = playerStorage:GetCategoryByUniqueKey(uniqueKey)
		
		if isvalid(item) then
			local grade = _ItemDataLogic.equipmentData[playerStorage.storage[uniqueKey].originalId].grade
			local maxLevel = 99999
			
