@Logic
script ItemReinforceLogic extends Logic

	property number requestedTime = 0

	property integer maxMergeStep = 10

	property Entity draggedItem = nil

	property integer maxItemLevel = 50

	@ExecSpace("Client")
	method void RequestItemMerge(Entity item1, Entity item2, Entity playerEntity)
		-- 두 아이템의 합성 요청을 처리
		if not isvalid(item1) or not isvalid(item2) then return end
		
		local storage = playerEntity.PlayerStorageComponent
		self.requestedTime = _UtilLogic.ServerElapsedSeconds
		
		local storageItem1, storageItem2 = item1.StorageItemComponent, item2.StorageItemComponent
		
		if not storageItem1.canMerge or not storageItem2.canMerge then return end
		
		storageItem1.canMerge = false
		storageItem2.canMerge = false
		
		if storageItem1.itemId == storageItem2.itemId and storageItem1.uniqueKey ~= storageItem2.uniqueKey then
		end
	end

	@ExecSpace("ServerOnly")
	method void RequestItemMergeInServer(string itemKey1, string itemKey2, Entity playerEntity)
		-- 서버에서 아이템 합성 요청을 처리
		self.requestedTime = _UtilLogic.ServerElapsedSeconds
		
		local playerStorage = playerEntity.PlayerStorageComponent
		local uniqueKey1, uniqueKey2 = playerStorage.storage[itemKey1].uniqueKey, playerStorage.storage[itemKey2].uniqueKey
		local droppedItemId1, droppedItemId2 = playerStorage.storage[itemKey1].originalId, playerStorage.storage[itemKey2].originalId
		
		if droppedItemId1 == droppedItemId2 and uniqueKey1 ~= uniqueKey2 then
		end
		
	end

	@ExecSpace("ServerOnly")
	method boolean Merge(string itemKey1, string itemKey2, Entity playerEntity)
		-- 아이템 합성 로직 실행 및 성공/실패 처리
		local playerStorage = playerEntity.PlayerStorageComponent
		local itemId1, itemId2 = playerStorage.storage[itemKey1].originalId, playerStorage.storage[itemKey2].originalId
		local itemData1, itemData2 = _ItemDataLogic.equipmentData[itemId1], _ItemDataLogic.equipmentData[itemId2] 
		local originalId = itemData1.id 
		local mergeLevel = itemData1.mergeLevel 
		local userId = playerEntity.PlayerComponent.UserId 
		local nextEquipment = itemData1.nextEquipment
		local newId = itemData1.nextEquipment 
		
		if mergeLevel == nil or _UtilLogic:IsNilorEmptyString(mergeLevel) then 
			return false
		end
		
		if not isvalid(_ItemDataLogic.equipmentData[tostring(nextEquipment)]) then 
			return false
		end
		
		
		local mergeSuccess = false
		local rand = _UtilLogic:RandomIntegerRange(1, 100000)
		local percent = _ItemDataLogic.equipmentData[itemId1].mergePercent
		
		local equipNum = playerStorage.storage[itemKey1].equippedSlotNum 
		if equipNum == 0 then
			equipNum = playerStorage.storage[itemKey2].equippedSlotNum 
		end
		
		local level = 0
		
		if playerStorage.storage[itemKey1].level > playerStorage.storage[itemKey2].level then
			level = playerStorage.storage[itemKey1].level
		else
			level = playerStorage.storage[itemKey2].level
		end
		
		percent = tonumber(percent)
		
		if rand <= percent then
			mergeSuccess = true
		end
		
		
		playerStorage:UnEquip(itemKey1) 
		playerStorage:UnEquip(itemKey2)
		
		if mergeSuccess then 
			local guid = _GameUtil:CreateGUID()
			
			self:SendSuccessMergeEvent(itemKey1,itemKey2, tostring(newId), equipNum, level, nextEquipment, guid, userId)
		else
			self:DestroyItemEntity(itemKey1, true, userId)
			_UIToast:ShowMessage("무기 결합에 실패했습니다! 하나의 재료 무기가 파괴되었습니다.", userId)
		end
		
		
		
		return true
	end

	@ExecSpace("Client")
	method void DestroyItemEntity(string itemKey, boolean playDestroyEffect)
		-- 아이템 엔티티를 삭제하고 선택적으로 효과 재생
		local playerStorage = _UserService.LocalPlayer.PlayerStorageComponent
			
		for k, v in pairs(_StorageLogic.townStorage.Children) do
			if isvalid(v) and v.StorageItemComponent.uniqueKey == itemKey then
				if playDestroyEffect then
					self:PlayMergeEffect(v.TransformComponent.WorldPosition, false)
				end
				v:Destroy()
				
				return
			end	
		end
	end

	@ExecSpace("Client")
	method void SpawnItemEntity(string itemKey, string newId, integer equipNum, integer level, string nextEquipment, string guid)
		-- 합성 성공 시 새로운 아이템 엔티티를 생성
		local playerStorage = _UserService.LocalPlayer.PlayerStorageComponent
		local pos = Vector3.zero
		local worldPos = Vector3.zero
		local parent = nil
		local newItemId = _ItemDataLogic.itemData[newId]
		local modelId = _EntryService:GetModelIdByName("Model_Equipment")
		local tempTable = {}
		
		for k, v in pairs(_StorageLogic.townStorage.Children) do
			local isClonedItem = false
			
			if not isClonedItem and isvalid(v) and v.StorageItemComponent.uniqueKey == itemKey then
				pos = Vector3(playerStorage.storage[itemKey].posX,playerStorage.storage[itemKey].posY,0) 
				worldPos = v.TransformComponent.Position
				parent = v.Parent
				
				local newItem = _SpawnService:SpawnByModelId(modelId, guid, pos, parent)
				newItem.StorageItemComponent:Init(newId, guid)
				local randX, randY = _UtilLogic:RandomIntegerRange(50, 100) / 10, _UtilLogic:RandomIntegerRange(50, 100) / 10
				newItem.KinematicbodyComponent.MoveVelocity = Vector2(randX, randY)
				
				self:DestroyItemEntity(itemKey, false)
				playerStorage:SetOldItem(guid)
				playerStorage:SetPos(guid, pos,false)
				
				if equipNum > 0 then
					playerStorage:Equip(guid, equipNum)
		
				end
				
				playerStorage:SetStorageData(false)
				
				_UIToast:ShowMessage("무기 결합에 성공했습니다!")
				self:PlayMergeEffect(newItem.TransformComponent.WorldPosition, true)
		
				_StorageLogic:InsertNewItemToStorageItemTable(newItem)
				break
			end	
		end
	end

	@ExecSpace("Client")
	method void PlayMergeEffect(Vector3 worldPos, boolean isSuccess)
		-- 합성 성공/실패에 따른 이팩트 재생
		if isSuccess then
			_EffectService:PlayEffect("9699954fd785421bb684b3515a325e64", _UserService.LocalPlayer.CurrentMap, worldPos - Vector3(0, 0.5, 0), 0, Vector3.one)
		else
			_EffectService:PlayEffect("cbef481f377040dcaab3520aa94f7ae7", _UserService.LocalPlayer.CurrentMap, worldPos, 0, Vector3.one)
		end
	end

	@ExecSpace("Client")
	method void RequestItemLevelUp(string uniqueKey, Entity playerEntity)
		-- 아이템 레벨업 요청
	end

	@ExecSpace("ServerOnly")
	method void RequestItemLevelUpInServer(string uniqueKey, Entity playerEntity)
		-- 서버에서 아이템 레벨업 요청 처리 및 비용 차감
		--[[
		self.requestedTime = _UtilLogic.ServerElapsedSeconds
		
