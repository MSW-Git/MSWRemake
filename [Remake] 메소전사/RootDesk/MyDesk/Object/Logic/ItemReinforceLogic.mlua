				_UIToast:ShowMessage(string.format("더 이상 강화할 수 없습니다. 현재 등급의 최대 강화 레벨은 %d입니다.", maxLevel), playerEntity.PlayerComponent.UserId)
				
				return
			end
			
			local needGold = _ItemDataLogic.weaponLevelUpData[item.level].needGold
			local needScroll = _ItemDataLogic.weaponLevelUpData[item.level].needScroll
			
