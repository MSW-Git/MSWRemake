		end]]--
	end

	@ExecSpace("ServerOnly")
	method void ItemLevelUp(string uniqueKey, boolean showEffect, Entity playerEntity)
		-- 아이템 레벨을 1 올리고 클라이언트에 동기화
		local playerStorage = playerEntity.PlayerStorageComponent
		
		playerStorage.storage[uniqueKey].level = playerStorage.storage[uniqueKey].level + 1
		
		if showEffect == true then
			playerStorage:SyncStorageInClient(uniqueKey, playerStorage.storage[uniqueKey], playerEntity.PlayerComponent.UserId)
			if playerStorage.storage[uniqueKey].equippedSlotNum > 0 then 
				playerStorage:ApplyArmorStatus(false)	
			end
		end
		
		self:SendLevelUpEventInClient(uniqueKey, showEffect, playerEntity.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SendLevelUpEventInClient(string uniqueKey, boolean showEffect)
		-- 레벨업 이벤트를 클라이언트에 전송
		local playerStorage = _UserService.LocalPlayer.PlayerStorageComponent
		local category = playerStorage:GetCategoryByUniqueKey(uniqueKey)
		
		self:SendEvent(ItemLevelUpEvent(playerStorage.storage[uniqueKey].level, uniqueKey, category, showEffect))
	end

	@ExecSpace("ServerOnly")
	method void SendCreateEggEvent(Entity playerEntity, string guid, string newId, string entityId)
		-- 서버에서 알 생성 이벤트를 클라이언트로 전송
		self:SendCreateEggEventInClient(guid, newId, entityId, playerEntity, playerEntity.PlayerComponent.UserId)
	end

	@ExecSpace("Client")
	method void SendCreateEggEventInClient(string guid, string newId, string entityId, Entity playerEntity)
		-- 클라이언트에서 알 생성 이벤트를 로컬 플레이어에게 전송
		_UserService.LocalPlayer:SendEvent(CreatedEggCauseMergeEvent(guid, newId, entityId, playerEntity))
	end

	@ExecSpace("Client")
	method void SendSuccessMergeEvent(string itemKey1, string itemKey2, string newId, integer equipNum, integer level, string nextEquipment, string guid)
		-- 합성 성공 이벤트 처리 및 새 아이템 생성
		self:SpawnItemEntity(itemKey1, newId, equipNum, level, nextEquipment, guid)
		self:DestroyItemEntity(itemKey2, false)
		
		
		
	end

end