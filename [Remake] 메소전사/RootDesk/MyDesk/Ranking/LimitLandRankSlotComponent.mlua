@Component
script LimitLandRankSlotComponent extends Component

	property Entity rank = nil

	property Entity name = nil

	property Entity score = nil

	property Entity recordedTime = nil

	property integer rankNum = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 리미트랜드 랭킹 슬롯 UI 요소들 초기화
		self.rank = self.Entity:GetChildByName("Text_rank")
		self.name = self.Entity:GetChildByName("Text_name")
		self.score = self.Entity:GetChildByName("Text_score")
		self.recordedTime = self.Entity:GetChildByName("Text_recordedTime")
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(integer rank)
		-- 지정된 순위에 따라 리미트랜드 랭킹 슬롯 데이터 설정
		self.rankNum = rank
		local info = _RankingLogic.limitLandRecord[rank]
		
		if isvalid(info) then
			self.Entity.Enable = true
		else
			self.Entity.Enable = false
			
			return
		end
		
		local tag = _UtilLogic:Split(info.tag, "/")
		local nickname = tag[1]
		local recordedTime = tag[2]
		
		self.rank.TextComponent.Text = string.format("%d", rank)
		self.name.TextComponent.Text = string.format("%s", nickname)
		self.score.TextComponent.Text = string.format("%d", info.value)
		self.recordedTime.TextComponent.Text = string.format("%s", recordedTime)
	end

end