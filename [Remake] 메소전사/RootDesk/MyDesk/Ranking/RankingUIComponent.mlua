@Component
script RankingUIComponent extends UICommonPopup

	property LimitLandRankUIComponent limitLandLeaderBoard = "8e8dde7d-3ed5-4c7f-8483-8e8177181a78"

	property BattlePowerRankUIComponent battlePowerLeaderBoard = "d51bc266-2920-4d4b-88e0-9079e3777554"

	@HideFromInspector
	property string currentPanel = "battlePower"

	property Entity bestRecordPanel = "a8a22f1b-f12b-4171-a2f7-482a1d089b10"

	property Entity weeklyLimitLandPanel = "b4a70423-61f8-4eee-83f8-1b55f6983fb8"

	@HideFromInspector
	property PlayerInfoComponentRef playerInfo = nil

	property Entity previousRankingButton = "52ef82a4-b0a3-432d-9de8-1b17392480fe"

	property Entity nextRankingButton = "35142a45-878e-4de4-b649-51fb5126d74b"

	property Entity rewardButton = "8c80e7ef-744a-42ff-94a8-680ca689d1c0"

	@HideFromInspector
	property number lastClickedTime = 0

	property AccountLevelRankUIComponent accountLevelLeaderboard = "be25ce5a-d4b4-4bfa-a4ec-1c2023f19dbd"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 랭킹 UI 컴포넌트 초기화 및 이벤트 연결
		__base:OnBeginPlay()
		
		self.playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		
		self.Entity:GetChildByName("ExitButton",true):ConnectEvent(ButtonClickEvent, function()
				self:Hide()
			end)
		
		self.rewardButton:ConnectEvent(ButtonClickEvent, function()
				if self.lastClickedTime + 1 > _UtilLogic.ServerElapsedSeconds then
					_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
					
					return
				end
				
				self:RequestGetReward()
				self.lastClickedTime = _UtilLogic.ServerElapsedSeconds
			end)
	end

	@ExecSpace("ClientOnly")
	method void SetBestRecord()
		-- 플레이어의 최고 기록을 UI에 설정
		local playerInfo = self.playerInfo.playerInfo
		
		local battlePowerText = self.bestRecordPanel:GetChildByName("BattlePowerText", true)
		local waveText = self.bestRecordPanel:GetChildByName("LimitLandRecordText", true)
		local clearedTimeText = self.bestRecordPanel:GetChildByName("LimitLandClearedTimeText", true)
		
		battlePowerText.TextComponent.Text = string.format("%d", playerInfo.bestBattlePower)
		waveText.TextComponent.Text = playerInfo.bestLimitLandWave
		
		
		if _UtilLogic:Contains(playerInfo.limitLandRecordedTime, ".") then
			clearedTimeText.TextComponent.Text = playerInfo.limitLandRecordedTime
		else
			clearedTimeText.TextComponent.Text = playerInfo.limitLandRecordedTime .. ".000"
		end
		
		if playerInfo.bestLimitLandWave == 0 then
			waveText.TextComponent.Text = ""
			clearedTimeText.TextComponent.Text = ""
		end
	end

	@ExecSpace("ClientOnly")
	method void SetWeeklyLimitLandRecord()
		-- 주간 리미트랜드 기록을 UI에 설정
		local playerInfo = self.playerInfo.playerInfo
		local rankTable = _RankingLogic.previousWeekLimitLandRecord
		local rank = 0
		
		local waveText = self.weeklyLimitLandPanel:GetChildByName("LimitLandRecordText", true)
		local clearedTimeText = self.weeklyLimitLandPanel:GetChildByName("LimitLandClearedTimeText", true)
		local myRankText = self.weeklyLimitLandPanel:GetChildByName("MyWeeklyLimitLandRankText", true)
		
		waveText.TextComponent.Text = playerInfo.prevLimitLandWave
		
		if _UtilLogic:Contains(playerInfo.prevLimitLandRecordedTime, ".") then
			clearedTimeText.TextComponent.Text = playerInfo.prevLimitLandRecordedTime
		else
			clearedTimeText.TextComponent.Text = playerInfo.prevLimitLandRecordedTime .. ".000"
		end
		
		for i = 1, #table.keys(rankTable) do
			if rankTable[i].key == _UserService.LocalPlayer.PlayerComponent.UserId then
				rank = i
			end
		end
		
		if rank == 0 or playerInfo.prevLimitLandWave == 0 then
			myRankText.TextComponent.Text = _LocalizeLogic:GetText("etcStr144")
			waveText.TextComponent.Text = ""
			clearedTimeText.TextComponent.Text = ""
		else
			local ratio = rank / #table.keys(rankTable) * 100
			
			if rank <= 3 then
				myRankText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr145"), rank)
			else
				myRankText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr146"), rank, ratio)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 랭킹 UI 전체를 갱신
		self:SetBestRecord()
		self:SetWeeklyLimitLandRecord()
		self:SetRankingPanel()
	end

	@ExecSpace("ClientOnly")
	method void SetRankingPanel()
		-- 현재 선택된 랭킹 패널에 따라 UI 표시 상태 설정
		if self.currentPanel == "battlePower" then
			self.battlePowerLeaderBoard.Entity.Enable = true
			self.limitLandLeaderBoard.Entity.Enable = false
			self.accountLevelLeaderboard.Entity.Enable = false
			
			self.previousRankingButton.Enable = false
			self.nextRankingButton.Enable = true
		elseif self.currentPanel == "accountLevel" then
			self.accountLevelLeaderboard.Entity.Enable = true
			self.limitLandLeaderBoard.Entity.Enable = false
			self.battlePowerLeaderBoard.Entity.Enable = false
			
			self.previousRankingButton.Enable = true
			self.nextRankingButton.Enable = true
		elseif self.currentPanel == "weeklyLimitLand" then
			self.limitLandLeaderBoard.Entity.Enable = true
			self.battlePowerLeaderBoard.Entity.Enable = false
			self.accountLevelLeaderboard.Entity.Enable = false
			
			self.previousRankingButton.Enable = true
			self.nextRankingButton.Enable = false
		end
	end

	method void Show()
		-- 랭킹 UI를 화면에 표시
		__base:Show()
		
		self.nextRankingButton.Enable = true
		self.previousRankingButton.Enable = false
		
		self.currentPanel = "battlePower"
		self:Refresh()
	end

	method void Hide()
		-- 랭킹 UI를 화면에서 숨김
		__base:Hide()
		
	end

	@ExecSpace("Client")
	method void RequestGetReward()
		-- 주간 리미트랜드 보상 요청 처리
		local currentDate = _LocalTimeLogic:GetKST()
		local dayOfWeek = currentDate:ToFormattedString("dddd")
		local playerInfo = self.playerInfo.playerInfo
		local locale = _LocalizationService.CurrentLocaleId
		
		if playerInfo.prevLimitLandWave == 0 then return end
		if (dayOfWeek == "Sunday" and currentDate.Hour >= 23 and currentDate.Minute >= 30) or
			(dayOfWeek == "Monday" and currentDate.Hour <= 23 and currentDate.Minute <= 59) then
			if locale == "ko" then
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast316"))
			else
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast316") .. _LocalizeLogic:GetText("AdminTool_133")) 
			end
			
			return
		end
		
		local rewardedDate = playerInfo.rewardedWeeklyBestLimitLandDate
		
		if rewardedDate ~= "" then
			rewardedDate = DateTime(rewardedDate)
		
			if _LocalTimeLogic:GetSeasonWeek(rewardedDate) == _LocalTimeLogic:GetCurrentSeasonWeek() then
				_UIPopup:Open("", _LocalizeLogic:GetText("popup31"), nil, nil)
				
				return
			end
		end
		
		_RewardLogic:GetWeeklyLimitLandReward()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "b39e562a-a7fc-4edd-917f-3dece606145d")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 랭킹 UI 열기 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		self:ShowByButtonClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "52ef82a4-b0a3-432d-9de8-1b17392480fe")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 이전 랭킹 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if self.currentPanel == "weeklyLimitLand" then
			self.currentPanel = "accountLevel"
		else
			self.currentPanel = "battlePower"
		end
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "35142a45-878e-4de4-b649-51fb5126d74b")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 다음 랭킹 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if self.currentPanel == "battlePower" then
			self.currentPanel = "accountLevel"
		else
			self.currentPanel = "weeklyLimitLand"
		end
		
		self:Refresh()
	end

end