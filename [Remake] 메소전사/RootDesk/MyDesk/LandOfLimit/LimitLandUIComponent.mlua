@Component
script LimitLandUIComponent extends UICommonPopup

	property Entity exitButton = "f138747c-0863-45bc-85b6-3718ce6a18ca"

	property Entity todayEnteredText = "76475081-d5af-49e0-b64a-2fe8676e55e9"

	property number lastEnteredTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 리미트랜드 UI 컴포넌트 초기화
		__base:OnBeginPlay()
		
		self.exitButton:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
			
				self:Hide()
			end)
	end

	method void Refresh()
		-- 리미트랜드 UI 정보를 새로고침
		local playerEntity = _UserService.LocalPlayer
		local playerInfo = playerEntity.PlayerInfoComponent.playerInfo
		
		self.todayEnteredText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr73"), playerInfo.enteredLimitLandCount)
	end

	method void Show()
		-- 리미트랜드 UI를 표시
		if self.Entity.ContentLockComponent:CheckUIAvailable() then
			_UserService.LocalPlayer.PlayerInfoComponent:RequestRefreshPlayerInfo()
			__base:Show()
			_UIOpenQuestLogic:CheckQuestInProgress("limitLand",self.Entity)
			
			local myPlayer = _UserService.LocalPlayer.MyPlayer
			myPlayer:CheckAndShowRecommendPopUp("openLimitLandUI")
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "14cf12ab-6cae-434d-a338-da0e15f9a382")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 리미트랜드 입장 버튼 클릭 시 입장 처리 및 시간 제한 확인
		
		local Entity = event.Entity
		if not Environment:IsPlay() then return end
		if _BattleUIManager.loadingUI.Entity.Enable then return end
		if isvalid(_UserService.LocalPlayer.CurrentMap.BattleMap) then return end
		local currentDate = _LocalTimeLogic:GetKST()
		local dayOfWeek = currentDate:ToFormattedString("dddd")
		
		if (dayOfWeek == "Sunday" and currentDate.Hour >= 23 and currentDate.Minute >= 30) or
			(dayOfWeek == "Monday" and currentDate.Hour <= 00 and currentDate.Minute <= 30) then
			
			_UIPopup:Open("", _LocalizeLogic:GetText("toast316"), nil, nil)
			
			return
		end
		
		if self.lastEnteredTime + 1 > _UtilLogic.ServerElapsedSeconds then 
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
			return 
		end
		
		_GameLogic:TryEnterLimitLand(_UserService.LocalPlayer)
		self:Hide()
		self.lastEnteredTime = _UtilLogic.ServerElapsedSeconds
	end

end