@Component
script PartyListSlotComponent extends Component

	property integer partyId = 0

	property Entity partyListUI = nil

	@ExecSpace("ClientOnly")
	method void SetSlot(integer index)
		-- 파티 리스트 슬롯에 파티 정보 설정 및 표시
		self.partyId = index
		local party = _PartyLogic.partyTable[index]
		
		if not isvalid(party) then
		
			return
		end
		
		
		local partyNameText = self.Entity:GetChildByName("PartyNameText")
		local memberText = self.Entity:GetChildByName("MemberText")
		local avgLevelText = self.Entity:GetChildByName("AvgLevelText")
		local disableStatus = self.Entity:GetChildByName("img_dis")
		
		local partyInfo = party
		
		if partyInfo.status == 0 then
			if partyInfo.max <= _PartyLogic:GetPartyMemberCount(index) then
				disableStatus.Enable = true
			else
				disableStatus.Enable = false
			end
		else
			disableStatus.Enable = true
		end
		
		partyNameText.TextComponent.Text = partyInfo.name
		partyNameText.TextComponent.FontColor = Color.white
		if index == _UserService.LocalPlayer.PlayerFieldMapComponent.partyIndex then
			partyNameText.TextComponent.FontColor = Color.FromHexCode("#B5FA4D")
		end
		memberText.TextComponent.Text = string.format("%d/%d", _PartyLogic:GetPartyMemberCount(index), partyInfo.max)
		avgLevelText.TextComponent.Text = string.format("%d", _PartyLogic:GetAverageLevel(index))
		
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 부모 파티 리스트 UI 참조 설정
		self.partyListUI = self.Entity.Parent.Parent
	end

	@ExecSpace("ClientOnly")
	method void Clear()
		-- 슬롯 내용을 초기화하고 비활성화
		self.partyId = 0
		
		local disableStatus = self.Entity:GetChildByName("img_dis")
		local partyNameText = self.Entity:GetChildByName("PartyNameText")
		local memberText = self.Entity:GetChildByName("MemberText")
		local avgLevelText = self.Entity:GetChildByName("AvgLevelText")
		
		partyNameText.TextComponent.Text = ""
		memberText.TextComponent.Text = ""
		avgLevelText.TextComponent.Text = ""
		disableStatus.Enable = true
		
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 슬롯 클릭 시 파티 상세 정보 UI 표시
		
		local Entity = event.Entity
		local partyInfoUI = _PartyUILogic:GetPartyInfoUI().PartyInfoUIComponent
		
		if isvalid(partyInfoUI) and isvalid(_PartyLogic.partyTable[self.partyId]) then
			partyInfoUI:SetPartyId(self.partyId)
			partyInfoUI:Show()
		end
	end

end