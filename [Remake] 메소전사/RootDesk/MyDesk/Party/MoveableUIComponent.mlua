@Component
script MoveableUIComponent extends Component

	property Entity touchEntity = nil

	property boolean isDragged = false

	property Entity parentEntity = nil

	property boolean isHover = false

	property Vector2 lastMousePos = Vector2(0,0)

	property Vector3 lastPos = Vector3(0,0,0)

	@ExecSpace("ClientOnly")
	method void SetTouchEntity(Entity entity, Entity parent)
		-- 드래그 가능한 UI 엔티티와 부모 엔티티 설정 및 이벤트 연결
		self.touchEntity = entity
		self.parentEntity = parent
		
		parent.UITransformComponent.AlignmentOption = AlignmentType.BottomLeft
		parent.UITransformComponent.Pivot = Vector2(0.5, 0.5)
		
		self.touchEntity:ConnectEvent(ButtonStateChangeEvent, function(event)
			local state = event.state
			
			if state == ButtonState.Pressed and not self.isDragged then
				_InputService:CursorLockMode(CursorLockMode.Confined)
				self.isDragged = true
				self.lastMousePos = _InputService:GetCursorPosition()
				self.lastPos = parent.UITransformComponent.Position
			end
			
			if state == ButtonState.Released and self.isDragged then
				_InputService:CursorLockMode(CursorLockMode.None)
				self.isDragged = false
			end
		end)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 드래그 중일 때 마우스 위치에 따라 UI 위치 업데이트
		if self.isDragged and isvalid(self.parentEntity) then
			local pos = _InputService:GetCursorPosition()
			
			local diff = pos - self.lastMousePos
			self.lastMousePos = pos:Clone()
			self.parentEntity.UITransformComponent.Position = self.lastPos + diff:ToVector3()
			self.lastPos = self.parentEntity.UITransformComponent.Position:Clone()
		end
	end

end