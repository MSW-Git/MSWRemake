@Component
script PetRandomPickUIComponent extends Component

	property Entity exitButton = "1e79cb3d-65a3-448e-b812-2562c91fe9c3"

	@ExecSpace("ClientOnly")
	method void Open()
		-- 펫 랜덤 뽑기 UI를 열기
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 펫 랜덤 뽑기 UI를 닫기
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 종료 버튼에 닫기 이벤트 연결
		self.exitButton:ConnectEvent(ButtonClickEvent, self.Close)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "036f86c2-6914-4110-9e9e-97a7d8f54c57")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 1회 펫 뽑기 버튼 클릭 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		_UIPopup:Open("",_LocalizeLogic:GetText("popup23"), function()
				_PetLogic:RequestRandomPickPet(_UserService.LocalPlayer.PlayerComponent.UserId, 1)
			end, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5794f041-2728-4176-b67d-75d35078eea3")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 10회 펫 뽑기 버튼 클릭 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		_UIPopup:Open("", _LocalizeLogic:GetText("popup24"), function()
				_PetLogic:RequestRandomPickPet(_UserService.LocalPlayer.PlayerComponent.UserId, 10)
			end, nil)
	end

end