@Component
script RandomPickEggComponent extends Component

	@HideFromInspector
	property string id = ""

	@ExecSpace("ClientOnly")
	method void SetId(string id)
		-- 펫 ID를 설정하고 등급에 따라 이펙트 색상을 변경
		self.id = id
		
		local data = _PetLogic.petData[self.id]
		local grade = data.grade
		local effect = self.Entity:GetChildByName("Effect")
		
		if grade == "S" then
			effect.SpriteGUIRendererComponent.Color = Color.red
		elseif grade == "A" then
			effect.SpriteGUIRendererComponent.Color = Color.green
		else
			effect.SpriteGUIRendererComponent.Color = Color.white
		end
	end

	@ExecSpace("ClientOnly")
	method void SetImage()
		-- 펫 데이터에서 이미지 RUID를 가져와 스프라이트에 설정
		local data = _PetLogic.petData[self.id]
		self.Entity.SpriteGUIRendererComponent.ImageRUID = data.ruid
	end

end