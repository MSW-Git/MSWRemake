@Component
script HealingPetComponent extends Component

	@HideFromInspector
	property TransformComponent transformComponent = nil

	@HideFromInspector
	property integer timer = 0

	property number healInterval = 5

	property number seconds = 0

	@HideFromInspector
	property number healAmount = 5

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 힐링 펫 컴포넌트 초기화 및 렌더링 순서 설정
		self.transformComponent = self.Entity.TransformComponent
		self.Entity.SpriteRendererComponent.OrderInLayer = _UserService.LocalPlayer.AvatarRendererComponent.OrderInLayer - 1
	end

	@ExecSpace("ClientOnly")
	method void StartHeal()
		-- 힐링 타이머를 시작하고 쿨다운 시각적 효과 설정
		_TimerLogic:ClearTimer(self.timer)
		self.timer = _TimerLogic:SetTimerRepeat(function()
				if not isvalid(self) then 
					_TimerLogic:ClearTimer(self.timer)
					return
				end
				self:Heal()
			end, self.healInterval, 5, "HealingPetComponent.StartHeal")
		
		local timer = 0
		timer = _TimerLogic:SetTimerRepeat(function()
				if not isvalid(self) or not isvalid(self.Entity) then 
					_TimerLogic:ClearTimer(timer)
				end
			
				if isvalid(self) then
					local color = math.abs(self.seconds - self.healInterval) / self.healInterval
					self.seconds = self.seconds + 1
					
					if self.seconds % self.healInterval == 0 then
						self.seconds = 0 
					end
				else
					_TimerLogic:ClearTimer(timer)
				end
			end, 1, 5, "HealingPetComponent.StartHeal_cooltimeAlpha")
	end

	@ExecSpace("ClientOnly")
	method void Heal()
		-- 플레이어의 HP를 회복시키고 힐링 이팩트 재생
		local player = _UserService.LocalPlayer
		local battlePlayer = player.BattlePlayer
		if battlePlayer.hp < battlePlayer.maxHp then
			local healAmount = battlePlayer.maxHp * (self.healAmount / 100)
			
			if healAmount > battlePlayer.maxHp - battlePlayer.hp then
				healAmount = battlePlayer.maxHp - battlePlayer.hp
			end
		
			battlePlayer:SetHP(battlePlayer.hp + healAmount)
			_EffectService:PlayEffectAttached("0578cb95b5c244e8a0043a6b3d2e23a6", self.Entity, Vector3(0, 0.75, 0), 0, Vector3(0.5, 0.5, 1))
			_EffectService:PlayEffectAttached("2cdfa53899d2462cb051e958a70b4747", player, Vector3.zero, 0, Vector3.one)
			_DamageSkinService:Play(player, "b6b059a7ec8c44ad966363ed20f3926b", 0, {healAmount}, DamageSkinTweenType.Volcano, false)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnDestroy()
		-- 컴포넌트 파괴 시 타이머 정리
		_TimerLogic:ClearTimer(self.timer)
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleChangedLookAtEvent(ChangedLookAtEvent event)
		-- 플레이어의 시선 방향에 따라 힐링 펫의 위치와 스케일 조정
		
		local LookAtX = event.LookAtX
		if LookAtX > 0 then
			self.transformComponent.Position.x = math.abs(self.Entity.TransformComponent.Position.x) * (-1)
			self.transformComponent.Scale.x = -1
		else
			self.transformComponent.Position.x = math.abs(self.Entity.TransformComponent.Position.x)
			self.transformComponent.Scale.x = 1
		end
	end

end