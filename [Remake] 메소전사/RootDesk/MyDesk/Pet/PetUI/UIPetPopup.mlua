@Component
script UIPetPopup extends UICommonPopup

	property Entity petButton = "33ce4859-9c58-4951-b9b8-da0c9ffc192c"

	property Entity contentPanel = "4272846e-724d-41b8-8b81-2751b2df086b"

	property Entity exitButton = "39c06f0f-3330-413f-a221-416a02af388a"

	property Entity equipPetSlot1 = "bf5910e5-03fa-4216-bcec-c2a621f07c40"

	property Entity equipPetSlot2 = "1f4d20f6-ffe8-429d-9756-3dc6a23aae65"

	property Entity equipPetSlot3 = "91e06bc2-7507-4184-a19c-6e81e24997b3"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 펫 팝업 UI 초기화
		__base:OnBeginPlay()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 펫 슬롯 상태를 갱신하고 장착된 펫 정보 표시
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		local characteristic = _UserService.LocalPlayer.PlayerCharacteristicData
		
		local temp = {self.equipPetSlot1, self.equipPetSlot2, self.equipPetSlot3}
		
		if isvalid(characteristic.charStorage["PetType"]) then
			for i = 1, #temp do
				if characteristic.charStorage["PetType"].level >= i - 1 then
					temp[i].Enable = false
					temp[i].Parent:GetChildByName("Empty",true).Enable = true
				else
					temp[i].Enable = false
					temp[i].Parent:GetChildByName("Empty",true).Enable = false
				end
			end
		end
		
		self.equipPetSlot1.PetSlotComponent:SetUniqueKey("")
		self.equipPetSlot2.PetSlotComponent:SetUniqueKey("")
		self.equipPetSlot3.PetSlotComponent:SetUniqueKey("")
		
		for key, value in pairs(petInventory.petInventory) do
			if value.equippedSlotNum > 0 then
				if value.equippedSlotNum == 1 then
					self.equipPetSlot1.PetSlotComponent:SetUniqueKey(value.uniqueKey)
					self.equipPetSlot1.Enable = true
					self.equipPetSlot1.Parent:GetChildByName("Empty", true).Enable = false
				elseif value.equippedSlotNum == 2 then
					self.equipPetSlot2.PetSlotComponent:SetUniqueKey(value.uniqueKey)
					self.equipPetSlot2.Enable = true
					self.equipPetSlot2.Parent:GetChildByName("Empty", true).Enable = false
				elseif value.equippedSlotNum == 3 then
					self.equipPetSlot3.PetSlotComponent:SetUniqueKey(value.uniqueKey)
					self.equipPetSlot3.Enable = true
					self.equipPetSlot3.Parent:GetChildByName("Empty", true).Enable = false
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 펫 슬롯 컴포넌트들을 초기화하고 펫 UI 활성화
		
		self.equipPetSlot1.PetSlotComponent:Init()
		self.equipPetSlot2.PetSlotComponent:Init()
		self.equipPetSlot3.PetSlotComponent:Init()
		
		_PetUILogic.petUI.Enable = true
		_PetUILogic.petList.Enable = true
		table.clear(_PetUILogic.petLevelUpList.checkedPets)
	end

	method void Show()
		-- 펫 팝업을 표시하고 초기화 및 갱신 수행
		
		
		self:Init()
		self:Refresh()
		
		_PetUILogic:RefreshPetList()
		_PetUILogic:SetPetListEnable(true)
		
		
		__base:Show()
	end

	method void OnFinishHide()
		-- 팝업 숨김 완료 시 처리 (현재 비어있음)
		return
	end

	method void Hide()
		-- 팝업을 숨기고 기본 숨김 처리 수행
		
		 __base:Hide()
	end

	method void SetEquipSlotOutline(boolean turnOn)
		-- 펫 장착 슬롯 아웃라인 표시 설정
		local temp = {self.equipPetSlot1, self.equipPetSlot2, self.equipPetSlot3}
		
		if turnOn == true then
			for i = 1, #temp do 
				if _UtilLogic:IsNilorEmptyString(temp[i].PetSlotComponent.currentUniqueKey) then 
					temp[i].PetSlotComponent:RequestEquip()
					return
				end
			end
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast230"))
			_PetUILogic.selectableEquipSlot = false
			_PetUILogic.selectedUniqueKey = ""	
		end
	end

	@ExecSpace("Client")
	method void TurnOn()
		-- 팝업을 활성화하고 초기화 및 갱신 수행
		self:Init()
		self:Refresh()
		_PetUILogic:RefreshPetList()
		_PetUILogic:SetPetListEnable(true)
		
		self.Entity:SetEnable(true)
	end

	@ExecSpace("Client")
	method void TurnOff()
		-- 팝업을 비활성화하고 펫 리스트 숨김
		self.Entity:SetEnable(false)
		_PetUILogic.petList:SetEnable(false)
	end

	@EventSender("Entity", "39c06f0f-3330-413f-a221-416a02af388a")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 나가기 버튼 클릭 시 펫 정보 UI 비활성화
		
		local Entity = event.Entity
		_PetUILogic.petInformation:SetEnable(false) 
	end

end