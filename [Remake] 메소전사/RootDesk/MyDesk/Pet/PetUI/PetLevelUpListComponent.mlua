@Component
script PetLevelUpListComponent extends Component

	property Entity itemEntity = "18eee06e-ca53-43ab-b7d9-37ca1532ed17"

	property Entity contentPanel = "42ae6cbd-4687-4c9f-9eb9-24982c17bc25"

	property Entity exitButton = "caf19eed-280e-47f7-8c84-dd9091f629b3"

	property Entity descriptionPanel = "6b5c4292-6440-421d-83ad-4e07a41089ff"

	property Entity levelUpButton = "8a465e49-8cd8-4817-9d98-4d1cb5199deb"

	property string currentUniqueKey = ""

	property string currentId = ""

	property Entity petInfo = "32aedc7e-cf77-4e7f-a4bc-cf8ef0bd52eb"

	@HideFromInspector
	property table checkedPets = {}

	property Entity expBar = "50e3686c-cd48-4fd9-beab-9128d3996f72"

	property Entity expBar_CurrentLevel = "8a621f1f-befa-4cf5-87a5-d1b82a50e3c7"

	@HideFromInspector
	property number needExp = 0

	property Entity predictExpBar = "1a28258e-a5dd-4dc1-9a3d-455222c6b810"

	property Entity predictBar_NextLevel = "9d686444-e41b-4739-a160-d597fa2f99ab"

	@HideFromInspector
	property integer predictLevel = 0

	property Entity petGradePanel = "6b5c4292-6440-421d-83ad-4e07a41089ff"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 펫 레벨업 리스트 그리드뷰 초기화 및 종료 버튼 연결
		local gridView = self.contentPanel.GridViewComponent
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		
		gridView.TotalCount = petInventory:GetAllPetCount() - 1
		gridView.ItemEntity = self.itemEntity
		gridView.OnRefresh = function(index, entity)
			local tempTable = _StorageLogic:GetItemListByCategory("pet", "grade")
			local targetIndex = 0
			for i = 1, #tempTable do
				if tempTable[i] == self.currentUniqueKey then
					targetIndex = i
					break
				end
			end
			
			if targetIndex > 0 then
				table.remove(tempTable, targetIndex)
			end
		
			entity.PetLevelUpListSlotComponent:SetSlot(tempTable[index + 1])
		end
		gridView:Refresh(true, true)
		
		self.exitButton:ConnectEvent(ButtonClickEvent, function()
				table.clear(self.checkedPets)
				_PetUILogic.petList:SetDescriptionPanel(self.currentUniqueKey)
		
				_PetUILogic.petLevelUpUI.Parent.PetLevelUpPopup:Hide() 
		
			end)
		self.petGradePanel = self.descriptionPanel:GetChildByName("PetGradePanel", true)
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 펫 레벨업 리스트 새로고침
		local gridView = self.contentPanel.GridViewComponent
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		
		gridView.TotalCount = petInventory:GetAllPetCount() - 1
		gridView:Refresh(true, true)
	end

	@ExecSpace("ClientOnly")
	method void SetDescriptionPanel(string uniqueKey)
		-- 선택된 펫의 상세 정보를 설명 패널에 표시
		if uniqueKey == "" then
			self.petGradePanel:GetChildByName("PetTitleText", true).TextComponent.Text = ""
			self.descriptionPanel:GetChildByName("DescriptionText_2", true).TextComponent.Text = ""
			self.descriptionPanel:SetEnable(false)
		else
			local playerStorage = _UserService.LocalPlayer.PlayerPetStorageComponent
			local petId = playerStorage.petInventory[uniqueKey].originalId
			local petData = _PetLogic.petData[petId]
			_UIGroupManager:SetItemSlot( self.descriptionPanel:GetChildByName("displaySlot_2_N", true), 3, uniqueKey, "")
			self.petGradePanel:GetChildByName("PetTitleText", true).TextComponent.Text = _LocalizeLogic:GetPetName(petId)
			self.descriptionPanel:GetChildByName("DescriptionText_2", true).TextComponent.Text = _PetLogic:GetDescription(uniqueKey, petData, true, true) 
			self.descriptionPanel:SetEnable(true)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetPetInfo(string uniqueKey)
		-- 레벨업 대상 펫 정보 설정
		self.currentUniqueKey = uniqueKey
		
		
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		self.currentId = petInventory.petInventory[self.currentUniqueKey].originalId
		
		self:SetExpBar()
	end

	@ExecSpace("ClientOnly")
	method void SetExpBar()
		-- 현재 및 예상 경험치 바 설정
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		local grade = _PetLogic.petData[self.currentId].grade
		local needExp = _PetLogic.petLevelUpData[grade].needExp_3
		
		if petInventory.petInventory[self.currentUniqueKey].level == 1 then
			needExp = _PetLogic.petLevelUpData[grade].needExp_2
		elseif petInventory.petInventory[self.currentUniqueKey].level >= 2 then
			needExp = _PetLogic.petLevelUpData[grade].needExp_3
		end
		
		self.expBar.SpriteGUIRendererComponent.FillAmount = petInventory.petInventory[self.currentUniqueKey].exp / needExp
		self.expBar.TextComponent.Text = 
		string.format(_LocalizeLogic:GetText("etcStr117"), petInventory.petInventory[self.currentUniqueKey].exp / needExp * 100, petInventory.petInventory[self.currentUniqueKey].level)
		
		self.expBar_CurrentLevel.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr11"), petInventory.petInventory[self.currentUniqueKey].level)
		
		
		local predictNeedExp = _PetLogic.petLevelUpData[grade].needExp_3
		
		if self.predictLevel == 1 then
			predictNeedExp = _PetLogic.petLevelUpData[grade].needExp_2
		elseif self.predictLevel == 2 or self.predictLevel == 3 then
			predictNeedExp = _PetLogic.petLevelUpData[grade].needExp_3
		end
		
		if self.needExp == 0 then 
			self.needExp = predictNeedExp
			self.predictLevel = self.predictLevel + 1
		end
		
		
		self.predictExpBar.SpriteGUIRendererComponent.FillAmount = (predictNeedExp - self.needExp) / predictNeedExp
		if self.needExp == predictNeedExp and self.predictLevel > 2 then
			self.predictExpBar.SpriteGUIRendererComponent.FillAmount = 1
		end
		
		self.predictExpBar.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr118"), (predictNeedExp - self.needExp) / predictNeedExp * 100, self.predictLevel)
		
		self.predictBar_NextLevel.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr11"), self.predictLevel)
		
		if petInventory.petInventory[self.currentUniqueKey].level > 2 then 
			self.expBar.SpriteGUIRendererComponent.FillAmount = 1
			self.predictExpBar.SpriteGUIRendererComponent.FillAmount = 0
		self.expBar.TextComponent.Text = _LocalizeLogic:GetText("etcStr207")
			self.predictExpBar.TextComponent.Text = _LocalizeLogic:GetText("etcStr207")
		end
	end

	@ExecSpace("ClientOnly")
	method void SetEnable(boolean onOff)
		-- 펫 레벨업 리스트 활성화/비활성화
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		
		if petInventory.petInventory[self.currentUniqueKey].level >= 3 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast225"))
			
			return
		end
		
		table.clear(self.checkedPets)
		
		if onOff then 
			self:CalcPredictExp()
			_PetUILogic.petList:SetEnable(true)
			_PetUILogic.petUI.Enable = false
			_PetUILogic.petLevelUpUI.Parent.PetLevelUpPopup:Init(self.currentUniqueKey)
			
			self:Refresh()
		else
			table.clear(self.checkedPets)
		end
	end

	@ExecSpace("ClientOnly")
	method boolean IsExceedExp()
		-- 선택된 펫들의 경험치가 레벨업에 필요한 경험치를 초과하는지 확인
		local sum = 0
		local petStorage = _UserService.LocalPlayer.PlayerPetStorageComponent
		local grade = _PetLogic.petData[self.currentId].grade
		local level = petStorage.petInventory[self.currentUniqueKey].level
		local exp = petStorage.petInventory[self.currentUniqueKey].exp
		local needExp = 0
			
		if level == 1 then
			needExp = _PetLogic.petLevelUpData[grade].needExp_2 + _PetLogic.petLevelUpData[grade].needExp_3 - exp
		elseif level == 2 then
			needExp = _PetLogic.petLevelUpData[grade].needExp_3 - exp
		elseif level == 3 then
			return true
		end
		
		for petData, uniqueKey in pairs(self.checkedPets) do
			if uniqueKey ~= "" and isvalid(petData) then
				local id = petStorage.petInventory[uniqueKey].originalId
				local slotLevel = petStorage.petInventory[uniqueKey].level
				local slotExp = petStorage.petInventory[uniqueKey].exp
				local slotGrade = _PetLogic.petData[id].grade
				
				if slotLevel == 1 then
					sum = sum + _PetLogic.petData[id].exp + slotExp * 0.7
				else
					sum = sum + _PetLogic.petData[id].exp + slotExp
					
					if slotLevel == 2 then
						sum = sum + _PetLogic.petLevelUpData[slotGrade].needExp_2 + slotExp * 0.7
					elseif slotLevel == 3 then
						sum = sum + _PetLogic.petLevelUpData[slotGrade].needExp_2 + _PetLogic.petLevelUpData[slotGrade].needExp_3 + slotExp * 0.7
					end
				end
				
				if sum >= needExp then
					return true
				end
			end
		end
		
		return false
	end

	@ExecSpace("ClientOnly")
	method void CalcPredictExp()
		-- 선택된 펫들의 경험치를 계산하여 예상 레벨 및 경험치 바 업데이트
		local sum = 0
		local petStorage = _UserService.LocalPlayer.PlayerPetStorageComponent
		local grade = _PetLogic.petData[self.currentId].grade
		local level = petStorage.petInventory[self.currentUniqueKey].level
		local exp = petStorage.petInventory[self.currentUniqueKey].exp
		
		for petData, uniqueKey in pairs(self.checkedPets) do
			if uniqueKey ~= "" and isvalid(petData) then
				local id = petStorage.petInventory[uniqueKey].originalId
				local slotLevel = petStorage.petInventory[uniqueKey].level
				local slotExp = petStorage.petInventory[uniqueKey].exp 
				local slotGrade = _PetLogic.petData[id].grade
				
				if slotLevel == 1 then
					sum +=  _PetLogic.petData[id].exp + (slotExp * 0.7)
				elseif slotLevel == 2 then
					sum = sum + _PetLogic.petLevelUpData[slotGrade].needExp_2 + (slotExp * 0.7)
				elseif slotLevel == 3 then
					sum = sum + _PetLogic.petLevelUpData[slotGrade].needExp_2 + _PetLogic.petLevelUpData[slotGrade].needExp_3 + (slotExp * 0.7)
				end
			end
		end
		local total = sum + exp 
		
		if level == 1 then
			total = total - _PetLogic.petLevelUpData[grade].needExp_2 
			
			if total <= 0 then
				self.predictLevel = level
			else
				total = total - _PetLogic.petLevelUpData[grade].needExp_3 
				
				if total <= 0 then
					self.predictLevel = level + 1
				else
					self.predictLevel = level + 2
				end
			end
		elseif level == 2 then
			total = total - _PetLogic.petLevelUpData[grade].needExp_3
			
			if total <= 0 then
				self.predictLevel = level
			else
				self.predictLevel = level + 1
			end
		end
		
		self.needExp = total * (-1) 
		
		self:SetExpBar() 
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "8a465e49-8cd8-4817-9d98-4d1cb5199deb")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 레벨업 버튼 클릭 시 확인 팝업 표시 후 레벨업 요청
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		local Entity = event.Entity
		local canRequest = false
		
		if #self.checkedPets > 0 then
			canRequest = true
		end
		if canRequest then
			_UIPopup:Open(_LocalizeLogic:GetText("popup25"), string.format(_LocalizeLogic:GetText("popup26"), _LocalizeLogic:GetPetName(self.currentId)), function()
					_PetUILogic.petLevelUpList:SetDescriptionPanel("")
					_PetLogic:RequestPetLevelUp(_UserService.LocalPlayer.PlayerComponent.UserId, _UtilLogic:TableToString(self.checkedPets), self.currentUniqueKey)
		
					table.clear(self.checkedPets)
		
					self.predictLevel = 0
				end, nil)
		else
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast226"))
		end
	end

end