@Component
script PetListComponent extends Component

	@HideFromInspector
	property Entity itemEntity = "3141e928-b007-4fc8-9e31-dce66a55e0f7"

	@HideFromInspector
	property Entity contentPanel = "7daa4e55-82eb-4357-9158-8f056e0145d2"

	property Entity exitButton = "39c06f0f-3330-413f-a221-416a02af388a"

	property Entity descriptionPanel = "6da7fe19-7b5e-42b3-8977-8f8f3988c999"

	@HideFromInspector
	property Entity petGradePanel = nil

	@HideFromInspector
	property Entity equipButton = nil

	@HideFromInspector
	property Entity levelUpButton = nil

	@HideFromInspector
	property string currentUniqueKey = ""

	@HideFromInspector
	property string currentId = ""

	property Entity petInformationPanel = "3b9bb7f1-3580-4db9-9d82-c8a129665976"

	property Entity infoSlot = "7d4d75f4-ff7b-43ca-9d48-5a129354ac83"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 펫 리스트 그리드뷰 초기화 및 정렬 옵션 설정, 종료 버튼 연결
		
		
		local gridView = self.Entity.GridViewComponent
		gridView.ItemEntity = self.Entity:GetChildByName("Slot") 
		gridView.OnRefresh = function(index, entity)
			local player = _UserService.LocalPlayer
			local petInventory = player.PlayerPetStorageComponent
			local sortingOption = _UIGroupManager.playerStatusPopup.UIPlayerStatusPopup.sortingOption
			
			if sortingOption == 0 then
				sortingOption = "grade"
			elseif sortingOption == 1 then
				sortingOption = "level"
			elseif sortingOption == 2 then
				sortingOption = "grade"
			elseif sortingOption == 3 then
				sortingOption = "id"
			end
			
			local tempTable = _StorageLogic:GetItemListByCategory("pet", sortingOption)
			entity.PetListSlotComponent:SetSlot(tempTable[index + 1])
		end
		gridView:Refresh(true, true)
		
		self.exitButton:ConnectEvent(ButtonClickEvent, function()
				
				_PetUILogic.petGroup:Hide()
			end)
		
		self.equipButton = self.descriptionPanel:GetChildByName("EquipPetButton")
		self.levelUpButton = self.descriptionPanel:GetChildByName("PetLevelUpButton")
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 펫 리스트 새로고침 및 저장고 슬롯 수 표시 업데이트
		local gridView = self.Entity.GridViewComponent
		local player = _UserService.LocalPlayer
		local petInventory = player.PlayerPetStorageComponent
		local playerInfo = player.PlayerInfoComponent.playerInfo
		
		gridView.TotalCount = petInventory:GetAllPetCount()
		gridView:Refresh(true, true)
		
		
		if isvalid(playerInfo.petStorageSlot) then
			_UIGroupManager.uiPlayerStatusPopup.storageCount.Text = 
			math.floor(gridView.TotalCount).."/"..math.floor(_GameConfig:GetConfig().LIMIT_PETSLOT + playerInfo.petStorageSlot)
		end
		
		if gridView.TotalCount >= petInventory.maxStorageSlotNum then
			_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.FromHexCode("#FF6868")
		else
			_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.white
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetEnable(boolean onOff)
		-- 펫 리스트 활성화/비활성화 및 설명 패널 초기화
		self.Entity.Enable = onOff
		
		if onOff then
			self:Refresh()
		else
			self:SetDescriptionPanel("")
		end
	end

	@ExecSpace("ClientOnly")
	method void SetDescriptionPanel(string uniqueKey)
		-- 선택된 펫의 상세 정보를 설명 패널에 표시
		
		
		if uniqueKey == "" then
			self.descriptionPanel:GetChildByName("PetTitleText", true).TextComponent.Text = ""
			self.descriptionPanel:GetChildByName("LevelText", true).TextComponent.Text = ""
			self.descriptionPanel:GetChildByName("DescriptionText", true).TextComponent.Text = ""
			self.equipButton.Enable = false
			self.levelUpButton.Enable = false
			self.currentUniqueKey = ""
			self.currentId = ""
		else
		
			self.infoSlot.PetListSlotComponent:SetSlot(uniqueKey)
			
			local playerStorage = _UserService.LocalPlayer.PlayerPetStorageComponent
			local petId = playerStorage.petInventory[uniqueKey].originalId
			
			local petData = _PetLogic.petData[petId]
			local grade = petData.grade
			local needExp = _PetLogic.petLevelUpData[grade].needExp_3
			
			
			self.currentUniqueKey = uniqueKey
			self.currentId = petId
			
			if _PetLogic:CheckPetEquipped(uniqueKey) == true and isvalid(self.equipButton) then 
				self.equipButton.TextComponent.Text = _LocalizeLogic:GetText("popup8")
			else
				self.equipButton.TextComponent.Text = _LocalizeLogic:GetText("common_Equip")
			end
			
			self.descriptionPanel:GetChildByName("ExpBarGauge", true).SliderComponent.Value = playerStorage.petInventory[self.currentUniqueKey].exp / needExp 
			if playerStorage.petInventory[self.currentUniqueKey].level > 2 then
				self.descriptionPanel:GetChildByName("ExpBarGauge", true).SliderComponent.Value = 1
			end
			self.descriptionPanel:GetChildByName("petLevelText", true).TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr11"), playerStorage.petInventory[self.currentUniqueKey].level)
			
			self.descriptionPanel:GetChildByName("textPetName", true).SpriteGUIRendererComponent.Color = Color.FromHexCode(_PetLogic:GetCategoryPanelColor(petId))
			self.descriptionPanel:GetChildByName("textPetName", true).TextComponent.Text = _LocalizeLogic:GetPetName(petId)
		
			self.descriptionPanel:GetChildByName("DescriptionText", true).TextComponent.Text = _PetLogic:GetDescription(uniqueKey, petData, true, false)
			
			self.descriptionPanel:GetChildByName("upArrow" , true):SetEnable(false)
			
			_PetUILogic.petLevelUpList:SetPetInfo(uniqueKey)
		
			self.equipButton.Enable = true
			self.levelUpButton.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "822b4d7a-bd42-4e23-a03a-a4c228e19ae5")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 펫 장착/해제 버튼 클릭 처리
		
		local Entity = event.Entity
		local petData = _PetLogic.petData[self.currentId] 
		self.petInformationPanel.PetInformationPopup:Hide()
		
		if _PetLogic:CheckPetEquipped(self.currentUniqueKey) == true then 
			_UserService.LocalPlayer.PlayerPetStorageComponent:UnEquipPet(self.currentUniqueKey) 
		else 
			_PetUILogic.selectableEquipSlot = true
			_PetUILogic.selectedUniqueKey = self.currentUniqueKey
			_PetUILogic.petInformationUI:SetEquipSlotOutline(true)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "92063dea-4429-4370-a1c7-44d514de568b")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 펫 레벨업 버튼 클릭 시 레벨업 리스트 활성화
		
		local Entity = event.Entity
		_PetUILogic.petLevelUpList:SetEnable(true)
		
	end

end