	method number GetRuidTime(string ruid)
		-- RUID에 따른 애니메이션 재생 시간 반환
		if _UtilLogic:IsNilorEmptyString(ruid) then
			return 1
		end
		if self.ruidData[ruid] ~= nil then
			return self.ruidData[ruid]
		end
		
		return 1
	end

	method string ParseItemType(string itemId)
		-- 아이템 ID에서 타입 부분 추출
		if itemId ~= nil then
			local sepIdx, _ = itemId:find("_", 1, true)
			if sepIdx ~= nil and sepIdx > 1 then
				return itemId:sub(1, sepIdx - 1)
			end
		end
		
		return nil
	end

	method boolean GetBoolValue(integer number, integer n)
		-- 숫자의 n번째 자릿수가 0보다 큰지 확인
		if number == nil then
			return false
		end
		
		if number < 0 then
			return true
		end
		
		local str = tostring(number) 
		local length = #str 
		
		
		if n > 0 and n <= length then
			return tonumber(str:sub(length - n + 1 , length - n + 1)) > 0 
		end
		
		 return false
	end

	method number SetBoolValue(number number, integer n, integer newDigit)
		-- 숫자의 n번째 자릿수 값 설정
		
		if number == nil then 
			number = 0
		end
		
		local str = tostring(number) 
		local length = #str
		
		
		if n > 0 and n <= length + 1 then 
		
		   local leftPart = str:sub(1, length - n )
		   local rightPart = str:sub(length - n + 2, length) 
			
		   return tonumber(leftPart .. newDigit .. rightPart) 
		
		
		elseif n == length + 1 then
			
		   return tonumber(str .. newDigit)
		
		end
		
		return number
		
	end

