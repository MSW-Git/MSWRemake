	@ExecSpace("ClientOnly")
	method Vector2 UIPosToScreenPos(Vector2 uiPos)
		-- UI 좌표를 스크린 좌표로 변환
		local uiX = uiPos.x
		local uiY = uiPos.y
		local ratio = _UILogic.ScreenHeight / 1080
		
		local scrX = uiX * ratio + _UILogic.ScreenWidth * 0.5
		local scrY = uiY * ratio + _UILogic.ScreenHeight * 0.5
		return Vector2(scrX, scrY)
	end

	@ExecSpace("ClientOnly")
	method Vector2 ScreenPosToUIPos(Vector2 screenPos)
		-- 스크린 좌표를 UI 좌표로 변환
		local scrX = screenPos.x - _UILogic.ScreenWidth * 0.5
		local scrY = screenPos.y - _UILogic.ScreenHeight * 0.5
		local ratio = 1080 / _UILogic.ScreenHeight
		
		local uiX = scrX * ratio
		local uiY = scrY * ratio
		
		return Vector2(uiX, uiY)
	end

	@ExecSpace("ClientOnly")
	method Vector2 WorldPosToScreenPos(Vector2 worldPos)
		-- 월드 좌표를 스크린 좌표로 변환
		local screenPos = Vector2(0, 0)
		local screenWidth = _UILogic.ScreenWidth
		local screenHeight = _UILogic.ScreenHeight
		
		local worldPosMin = _UILogic:ScreenToWorldPosition(Vector2(0, 0))
		local worldPosMax = _UILogic:ScreenToWorldPosition(Vector2(screenWidth, screenHeight))
		
		local diffX = worldPosMax.x - worldPosMin.x
		local diffY = worldPosMax.y - worldPosMin.y
		
		screenPos.x = (worldPos.x - worldPosMin.x) * screenWidth / diffX 
		screenPos.y = (worldPos.y - worldPosMin.y) * screenHeight / diffY 
		
		return screenPos
	end

	method boolean IsNullOrWhitespace(string str)
		-- 문자연이 null이거나 공백만 있는지 확인
		    return str == nil or str:match("^%s*$") ~= nil
		
	end

	method number GetWeaponCollectionNumber(string number, number n)
		-- 무기 컴렉션 숫자에서 n번째 그룹 값 추출
		if _UtilLogic:IsNilorEmptyString(number) then
			return 0
		end
		
		local stringValue = number
		
		local first = stringValue:sub(1, 3) 
		local second = stringValue:sub(4, 6) 
		local third = stringValue:sub(7, 9) 
		local fourth = stringValue:sub(10, 12)
		local fifth = stringValue:sub(13, 15)
		return tonumber(stringValue:sub(n*3 -2, n*3))
	end

	@ExecSpace("ClientOnly")
	method number GetScreenRectSizeX()
		-- 스크린 사각형 크기 X 반환
		 self:ReCalcRectSize()
		
		return self.RectSizeX
	end

	@ExecSpace("ClientOnly")
	method number GetScreenRectSizeY()
		-- 스크린 사각형 크기 Y 반환
		 self:ReCalcRectSize()
		
		return self.RectSizeY
	end

	@ExecSpace("ClientOnly")
	method void ReCalcRectSize()
		-- 스크린 사각형 크기 재계산
		if _UILogic.ScreenWidth ~= self.WidthCache or _UILogic.ScreenHeight ~= self.HeightCache then
			self.WidthCache = _UILogic.ScreenWidth
			self.HeightCache = _UILogic.ScreenHeight 
			
			self.RectSizeX = self.FullScreenStretchImage.RectSize.x
			self.RectSizeY = self.FullScreenStretchImage.RectSize.y
		end
	end

	@ExecSpace("ClientOnly")
	method Vector2 UIPosToScreenPosByRect(Vector2 uiPos)
		-- 사각형 기준 UI 좌표를 스크린 좌표로 변환
		local uiX = uiPos.x
		local uiY = uiPos.y
		local ratio = _UILogic.ScreenHeight / self:GetScreenRectSizeY()
		
		local scrX = uiX * ratio + _UILogic.ScreenWidth * 0.5
		local scrY = uiY * ratio + _UILogic.ScreenHeight * 0.5
		
		return Vector2(scrX, scrY)
	end

	@ExecSpace("ClientOnly")
	method Vector2 ScreenPosToUIPosByRect(Vector2 screenPos)
		-- 사각형 기준 스크린 좌표를 UI 좌표로 변환
		local scrX = screenPos.x - _UILogic.ScreenWidth * 0.5
		local scrY = screenPos.y - _UILogic.ScreenHeight * 0.5
		local ratio = self:GetScreenRectSizeY() / _UILogic.ScreenHeight
		
		local uiX = scrX * ratio
		local uiY = scrY * ratio
		
		return Vector2(uiX, uiY)
	end

	method string GetMultiMapKey(Vector2 position)
		-- 멀티 맵 위치 키 생성
		local keyX = math.ceil(position.x / 10)
		local keyY = math.ceil(position.y / 10)
		local currentKey = string.format("%d,%d",keyX,keyY)
		return currentKey
	end

	@ExecSpace("Server")
	method void DestroyInServer(Entity entity)
		-- 서버에서 엔티티 제거
		if isvalid(entity) then
			entity:Destroy()
		end
	end

	method string GetOptimalFloatStr(number num)
		-- 소수점 숫자를 최적화된 문자열로 변환
		local newStr = string.format("%.5f", num)
		
		while true do
			local lastChar = _UtilLogic:SubString(newStr, #newStr, 1)
			
			if lastChar == "0" then
				newStr = _UtilLogic:SubString(newStr, 1, #newStr - 1)
			elseif lastChar == "." then
				newStr = _UtilLogic:SubString(newStr, 1, #newStr - 1)
				
				break
			else
				break
			end
		end
		
		return newStr
	end

	method table GetNumberSplitByComma(string data)
		-- 콤마로 구분된 문자열을 숫자 배열로 변환
		local num = {}
		local split = _UtilLogic:Split(data,",")
		
		for _,v in pairs(split) do
			table.insert(num,tonumber(v))
		end
		
		return num
	end

end