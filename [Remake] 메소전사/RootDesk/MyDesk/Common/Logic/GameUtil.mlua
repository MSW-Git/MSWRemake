		if getGrade[1] == "normal" then
			return "#222630"
		elseif  getGrade[1] == "rare" then	
			return "#40652d"
		elseif  getGrade[1] == "epic" then 
			return "#2860b1"
		elseif  getGrade[1] == "unique" then
			return "#7d11bd"
		elseif  getGrade[1] == "legendary" then
			return "#852821"
		else
			return "#000000"
		end
	end

