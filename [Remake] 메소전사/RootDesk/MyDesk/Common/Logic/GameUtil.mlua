	end

	method string SetNumValueTen(string number, integer n)
		-- 15자리 숫자 문자열의 n번째 그룹 값 증가
		
		
		if _UtilLogic:IsNilorEmptyString(number) then
			local value = ""
			if n == 1 then
				value = "001000000000000"
			elseif n == 2 then
				value = "000001000000000"
			elseif n == 3 then
				value = "000000001000000"
			elseif n == 4 then
				value = "000000000001000"
			elseif n == 5 then
				value = "000000000000001"
			end
			return value
		else
			local stringValue = number
		
			local first = stringValue:sub(1, 3) 
			local second = stringValue:sub(4, 6) 
			local third = stringValue:sub(7, 9) 
			local fourth = stringValue:sub(10, 12)
			local fifth = stringValue:sub(13, 15)
			
			if n == 1 then
				first = tonumber(first)
				first = first + 1
				first = string.format("%03d", first)
			elseif n == 2 then
				second = tonumber(second)
				second = second + 1
				second = string.format("%03d", second)
			elseif n == 3 then
				third = tonumber(third)
				third = third + 1
				third = string.format("%03d", third)
			elseif n == 4 then
				fourth = tonumber(fourth)
				fourth = fourth + 1
				fourth = string.format("%03d", fourth)
			elseif n == 5 then
				fifth = tonumber(fifth)
				fifth = fifth + 1
				fifth = string.format("%03d", fifth)
			end
		
			stringValue = first..second..third..fourth..fifth
			
			return stringValue
		end
		
		
	end

	method boolean GetNumberValueTen(string listId, integer n, Entity player)
		-- 컶렉션 수집 조건 달성 여부 확인
		local collection = _CollectionLogic.statusTable[listId]
		local number = player.PlayerCollectionComponent.eCollectionTable[listId]
		local targetNum = 0
		local value = false
		
		if _UtilLogic:IsNilorEmptyString(number) then
			return false
		end
		
		if n == 1 then
			number = tonumber(number:sub(1,3))
			targetNum = collection.material1_count
		elseif n == 2 then
			number = tonumber(number:sub(4,6))
			targetNum = collection.material2_count
		elseif n == 3 then
			number = tonumber(number:sub(7,9))
			targetNum = collection.material3_count
		elseif n == 4 then
			number = tonumber(number:sub(10,12))
			targetNum = collection.material4_count
		elseif n == 5 then
			number = tonumber(number:sub(13,15))
			targetNum = collection.material5_count
		end
		
		
		
		
		if number >= targetNum then
			value = true
		else
			value = false
		end
		
		return value
		
	end

