	method number LerpAngle(number a, number b, number t)
		-- 각도 선형 보간
		local delta = ((b - a) % 360 + 540) % 360 - 180
		return a + delta * t
	end

	method Vector2 ClampMagnitude(Vector2 vector, number maxLength)
		-- 벡터 크기를 최대값으로 제한
		local length = Vector2.Magnitude(vector)
		if length > maxLength then
		    return Vector2.Normalize(vector) * maxLength
		else
		    return vector
		end
	end

	method table GetNumberSplitBySlash(string data)
		-- 슬래시로 구분된 문자열을 숫자 배열로 변환
		local num = {}
		local split = _UtilLogic:Split(data,"/")
		
		for _,v in pairs(split) do
			table.insert(num,tonumber(v))
		end
		
		return num
	end

	method table GetStringTableSplitBySlash(string data, boolean number)
		-- 슬래시와 언더스코어로 구분된 문자열을 테이블로 변환
		local stringData = {}
		local split = _UtilLogic:Split(data,"/")
		
		for _,v in pairs(split) do
			local eachSplit = _UtilLogic:Split(v,"_")
			local eachData = {}
			eachData[1] = eachSplit[1]
			for i = 2, #eachSplit do
				if number then
					eachData[i] = tonumber(eachSplit[i])
				else
					eachData[i] = eachSplit[i]
				end
			end
			table.insert(stringData,eachData)
		end
		
		return stringData
	end

	method string CreateGUID()
		-- 고유 식별자(GUID) 생성
		
		local _sub = string.sub
		local _fmt = string.format
		
		local time_low = os.time()
		math.randomseed( time_low )
		
		local time_mid = _UtilLogic:RandomIntegerRange(0, 65535)
		
		local time_hi = _UtilLogic:RandomIntegerRange(0, 65535 )
		time_hi = self:padbits( self:num2bs(time_hi), 16 )
		time_hi = _sub( time_hi, 1, 12 )
		local time_hi_and_version = self:bs2num( time_hi .. "0100" )
		
		local clock_seq_hi_res = _UtilLogic:RandomIntegerRange(0,255)
		clock_seq_hi_res = self:padbits( self:num2bs(clock_seq_hi_res), 8 )
		clock_seq_hi_res = _sub( clock_seq_hi_res, 1, 6) .. "01"
		
		local clock_seq_low = _UtilLogic:RandomIntegerRange(0,255)
		clock_seq_low = self:padbits( self:num2bs(clock_seq_low), 8 )
		
		local clock_seq = self:bs2num(clock_seq_hi_res .. clock_seq_low)
		
		local node = {}
		node[1]= (128 + _UtilLogic:RandomIntegerRange(0,127) )
		for i=2,6 do
			node[i] = _UtilLogic:RandomIntegerRange(0,255)
		end
		
		local guid = ""
		guid = guid .. self:padbits(_fmt("%X",time_mid), 8)
		for i=1,4 do
			guid = guid .. self:padbits(_fmt("%X",node[i]), 2)
		end
		
		
		
		guid = guid .. self:padbits(_fmt("%X",time_mid), 4) 
		guid = guid .. self:padbits(_fmt("%X",time_hi_and_version), 4) 
		guid = guid .. self:padbits(_fmt("%X",clock_seq), 4)
		
		for i=1,2 do
			guid = guid .. self:padbits(_fmt("%X",node[i]), 2)
		end
		
		return guid
	end

	method string num2bs(number num)
		-- 숫자를 이진 문자열로 변환
		local _mod = math.fmod or math.mod
		local _floor = math.floor
		local result = ""
		if(num == 0) then return "0" end
		while(num  > 0) do
			 result = _mod(num,2) .. result
			 num = _floor(num*0.5)
		end              
		return result
	end

	method number bs2num(string num)
		-- 이진 문자열을 숫자로 변환
		local _sub = string.sub
			local index, result = 0, 0
			if(num == "0") then return 0; end
			for p=#num,1,-1 do
				local this_val = _sub( num, p,p )
				if this_val == "1" then
					result = result + ( 2^index )
				end
				index=index+1
			end
			return result
	end

	method any padbits(string num, number bits)
		-- 비트 문자열에 패딩 추가
		if #num == bits then return num end
			if #num > bits then  end
			local pad = bits - #num
			for i=1,pad do
				num = "0" .. num
			end
			return num
	end

	method table DeepCopyTable(table orig)
		-- 테이블 깊은 복사
		local copy
		
		if type(orig) == 'table' then
			copy = {}
			for orig_key, orig_value in pairs(orig) do
				copy[self:DeepCopyTable(orig_key)] = self:DeepCopyTable(orig_value)
			end
			setmetatable(copy, self:DeepCopyTable(getmetatable(orig)))
		else
			copy = orig
		end
		
		return copy
	end

	method number AngleLerp(number angle1, number angle2, number t)
		-- 각도 선형 보간 (라디안 단위)
		  local angleDifference = angle2 - angle1
		
		  if angleDifference > math.pi then
		     angleDifference = angleDifference - (2 * math.pi)
		  elseif angleDifference < -math.pi then
		     angleDifference = angleDifference + (2 * math.pi)
		  end
		
		  local slerpAngle = angle1 + t * angleDifference
		
		  return math.deg(slerpAngle)
	end

	method number PingPong(number value, number length)
		-- 핑폰 애니메이션 계산
		 local t = value / length
		 local pingPong = math.floor(t) % 2
		 local normalized = t - math.floor(t)
		  
		 if pingPong == 1 then
		    normalized = 1 - normalized
		 end
		  
		 return normalized * length
	end

	method void ShuffleTable(table t)
		-- 테이블 요소 랜덤 섮기
		local iterations = #t
		local j
		    
		for i = iterations, 2, -1 do
		   j = _UtilLogic:RandomIntegerRange(1,i)
		   t[i], t[j] = t[j], t[i]
		end
	end

	method table TrimTable(table t)
		-- 테이블에서 중복 요소 제거
		local result = {}
		local seen = {}
		for _, v in ipairs(t) do
			if not seen[v] then
				table.insert(result, v)
				seen[v] = true
			end
		end
		
		return result
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 화면 해상도 변경 감지 및 이벤트 발생
		if self.screenWidth ~= _UILogic.ScreenWidth or self.screenHeight ~= _UILogic.ScreenHeight then
			self.screenWidth = _UILogic.ScreenWidth
			self.screenHeight = _UILogic.ScreenHeight
			self:SendEvent(OnChangeScreenResolution(self.screenWidth,self.screenHeight))
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 유틸 초기화 및 RUID 데이터 로드
		self.screenWidth = _UILogic.ScreenWidth
		self.screenHeight = _UILogic.ScreenHeight
		
		
		local dataName = "RuidTime" 
		local data = _DataService:GetTable(dataName)
		for i = 1, data:GetRowCount() do
			local ruid = data:GetCell(i,"ruid")
			local duration = tonumber(data:GetCell(i,"duration"))
			if _UtilLogic:IsNilorEmptyString(ruid) == false then
				self.ruidData[ruid] = duration
			end
		end
	end

	method Vector3 GetUIWorldPosition(Entity entity)
		-- UI 엔티티의 월드 좌표 계산
		local rectTransform = entity.UITransformComponent
		local parentRectTransform = entity.Parent.UITransformComponent
		
		local parentSize = parentRectTransform.RectSize
		local normalizedAnchorPosition = Vector2(rectTransform.anchoredPosition.x / parentSize.x, rectTransform.anchoredPosition.y / parentSize.y)
		local pivotOffset = Vector2(parentRectTransform.Pivot.x - 0.5, parentRectTransform.Pivot.y - 0.5)
		local pivotWorldOffset = Vector3(pivotOffset.x * parentSize.x, pivotOffset.y * parentSize.y, 0)
		
		local worldParentPosition = parentRectTransform.Position
		local worldPosition = worldParentPosition + pivotWorldOffset + Vector3(normalizedAnchorPosition.x * parentSize.x, normalizedAnchorPosition.y * parentSize.y, 0)
		
		
		function Vector3_Scale(v1, v2)
		    return {x = v1.x * v2.x, y = v1.y * v2.y, z = v1.z * v2.z}
		end
		
		local parent = entity.Parent
		while isvalid(parent.UITransformComponent) and parent.UIGroupComponent ==nil do
			   worldPosition = Vector3_Scale(worldPosition - parent.UITransformComponent.Position, parent.UITransformComponent.Scale) + parent.UITransformComponent.Position
		       parent = parent.Parent
		end
		return worldPosition
	end

	method void GetUIScreenPosition(Entity entity)
		-- UI 엔티티의 스크린 좌표 계산 (미구현)
		
