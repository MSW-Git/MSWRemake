@Logic
script DataStructLogic extends Logic

	method LuaQueue GetQueue()
		-- Lua 큐 자료구조 생성
		local queue = { head = 0, tail = 0, Enqueue = true, Dequeue = true, Peek = true, IsEmpty = true, Count = true, Clear = true,
			array = {
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true,
				true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true, true
			}
		}
		local mt = self._T.queueMeta
		table.clear(queue.array)
		
		if mt == nil then
			self:InitMetatable()
			mt = self._T.queueMeta
		end
		
		function queue:Enqueue(value)
			self.array[self.tail] = value
			self.tail += 1
		end
		
		function queue:Dequeue()
			if self.tail - self.head == 0 then
				return nil
			end
			local value = self.array[self.head]
			self.array[self.head] = nil
			self.head += 1
			if self.head == self.tail then
				self.head = 0
				self.tail = 0
			end
			
			return value
		end
		
		function queue:Peek()
			if self.tail - self.head == 0 then
				return nil
			end
			local rtn = self.array[self.head]
			return rtn
		end
		
		function queue:IsEmpty()
			return self.head == self.tail
		end
		
		function queue:Count()
			return self.tail - self.head
		end
		
		function queue:Clear()
			table.clear(self)
		end
		
		---@type LuaQueue
		local rtn = setmetatable(queue, mt)
		return rtn
	end

	method void InitMetatable()
		-- 큐와 스택의 메타테이블 초기화
		self._T.queueMeta = {
			__newindex = function(t, k, v)
			end,
			__len = function(t)
				local rtn = t:Count()
				return rtn
			end,
			__tclear = function(t)
				for i = t.head, t.tail do
					t.array[i] = nil
				end
				t.head = 0
				t.tail = 0
			end,
			__pairs = function(t)
				local iter = function(t, i)
					if i < t.tail then
						i += 1
						return i, t.array[i - 1]
					end
				end
				return iter, t, t.head
			end,
			__ipairs = true
		}
		
		self._T.queueMeta.__ipairs = self._T.queueMeta.__pairs
		
		self._T.stackMeta =
		{
			__newindex = function(t, k, v)
			end,
			
			__len = function(t)
				local rtn = t:Count()
				return rtn
			end,
			
			__tclear = function(t)
				for i = 1, t.head do
					t.array[i] = nil
				end
				t.head = 1
			end,
			
			__pairs = function(t)
				local iter = function(t, i)
					if i < t.head then
						i += 1
						return i, t.array[i]
					end
				end
				return iter, t, 0
			end,
			__ipairs = true
		}
		
		self._T.stackMeta.__ipairs = self._T.stackMeta.__pairs
	end

	method LuaStack GetStack()
		-- Lua 스택 자료구조 생성
		local stack = { array = {}, head = 1, Push = true, Pop = true, Peek = true, IsEmpty = true, Count = true, Clear = true}
		local mt = self._T.stackMeta
		
		if mt == nil then
			self:InitMetatable()
			mt = self._T.stackMeta
		end
		
		function stack:Push(value)
			self.array[self.head] = value
			self.head += 1
		end
		
		function stack:Destack()
			if self.head == 1 then
				return nil
			end
			self.head -= 1
			local value = self.array[self.head]
			self.array[self.head] = nil
			
			return value
		end
		
		function stack:Peek()
			if self.head == 1 then
				return nil
			end
			local rtn = self.array[self.head - 1]
			return rtn
		end
		
		function stack:IsEmpty()
			return self.head == 1
		end
		
		function stack:Count()
			return self.head - 1
		end
		
		function stack:Clear()
			table.clear(self)
		end
		
		---@type LuaStack
		local rtn = setmetatable(stack, mt)
		
		return rtn
	end

end