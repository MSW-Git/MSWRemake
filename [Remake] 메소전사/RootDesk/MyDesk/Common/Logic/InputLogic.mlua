@Logic
script InputLogic extends Logic

	property boolean uiAlpha = false

	property Vector2 joystickValue = Vector2(0,0)

	property Joystick joystick = "3b59b42d-0c12-44d8-83bb-856baea90643"

	method void OnChangeJoystickValue(Vector2 value)
		-- 조이스틱 값 변경 시 호출
		self.joystickValue = value
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력 이벤트 처리
		
		local key = event.key
		
		if key == KeyboardKey.Tab then
			if isvalid(_UserService.LocalPlayer.BattlePlayer) then
				_BattleUIManager:OnStatButtonClick()
			end
		elseif key == KeyboardKey.B then
			if _ResultUILogic.resultUI.Entity.Enable then
				_ResultUILogic.resultUI.goHomeButton:SendEvent(ButtonClickEvent())
			elseif _BattleUIManager.limitLandResultUI.Entity.Enable then
				_BattleUIManager.limitLandResultUI:SetEnable(false, false)
			end
		end
		
	end

end