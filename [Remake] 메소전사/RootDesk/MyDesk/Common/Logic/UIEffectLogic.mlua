@Logic
script UIEffectLogic extends Logic

	property Entity parentGroup = "0beca33c-fe99-492d-895d-7459e4e95b80"

	method void PlayEffect(string ruid, Vector3 pos, Vector3 scale)
		-- UI 이팩트 재생
		_PoolingLogic:SpawnModelAsync("model://uisprite",pos,self.parentGroup,function(_entity) 
				---@type Entity
				local entity = _entity
				entity.TransformComponent.Scale = scale
				entity.TransformComponent.WorldPosition = pos
				local spriteGUI = entity.SpriteGUIRendererComponent
				spriteGUI.PreserveSprite = PreserveSpriteType.NativeSize
				spriteGUI.ImageRUID = ""
				spriteGUI.ImageRUID = ruid
				local duration = _GameUtil:GetRuidTime(ruid)
				_TimerService:SetTimerOnce(function() 
						_PoolingLogic:DestroyEntity(entity)
				end,duration - 0.02)
				
		end)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 이팩트 로직 초기화
		self.parentGroup.UIGroupComponent.GroupOrder = 9999
	end

	method void PlayEffectAttached(string ruid, Entity parent, Vector3 scale)
		-- 부모 엔티티에 붙인 UI 이팩트 재생
		_PoolingLogic:SpawnModelAsync("model://uisprite",Vector3.zero,parent,function(_entity) 
				---@type Entity
				local entity = _entity
				entity.TransformComponent.Scale = scale
				entity.TransformComponent.Position = Vector3.zero
				local spriteGUI = entity.SpriteGUIRendererComponent
				spriteGUI.PreserveSprite = PreserveSpriteType.NativeSize
				spriteGUI.ImageRUID = ""
				spriteGUI.ImageRUID = ruid
				local duration = _GameUtil:GetRuidTime(ruid)
				_TimerService:SetTimerOnce(function() 
						_PoolingLogic:DestroyEntity(entity)
				end,duration - 0.02)
				entity:AttachTo(self.parentGroup)
		end)
	end

end