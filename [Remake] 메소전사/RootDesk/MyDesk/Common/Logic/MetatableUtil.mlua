@Logic
script MetatableUtil extends Logic

	method any SupportLenWithPairs(table originalTable)
		-- 테이블에 길이 연산자와 pairs 지원 추가
		local mt = {}
		mt.__innerTable = {}
		mt.__count = 0
		
		local lenFunction = function(t)
			return mt.__count or 0
		end
		
		local newIndexFunction = function(t, k, v)
			local it = mt.__innerTable
			if (it[k] == nil) ~= (v == nil) then
				if v then
					mt.__count += 1
				else
					mt.__count -= 1
				end
			end
			it[k] = v
		end
		
		local indexFunction = function (t, k)
			return mt.__innerTable[k]
		end
		
		local pairsFunction = function (t, k)
			return pairs(mt.__innerTable)
		end
		
		local clearFunction = function (t)
			mt.__count = 0
			table.clear(mt.__innerTable)
		end
		
		mt.__len = lenFunction
		mt.__newindex = newIndexFunction
		mt.__index = indexFunction
		mt.__pairs = pairsFunction
		mt.__tclear = clearFunction
		
		return setmetatable(originalTable, mt)
	end

	method any ReadonlyTable(table originalTable)
		-- 읽기 전용 테이블 래퍼 생성
		local wrapperTable = {}
		local mt = {}
		mt.__innerTable = originalTable
		
		local lenFunction = function(t)
			return #mt.__innerTable
		end
		
		local newIndexFunction = function(t, k, v)
		end
		
		local indexFunction = function (t, k)
			return mt.__innerTable[k]
		end
		
		local pairsFunction = function (t, k)
			return pairs(mt.__innerTable)
		end
		
		local clearFunction = function (t)
		end
		
		mt.__len = lenFunction
		mt.__newindex = newIndexFunction
		mt.__index = indexFunction
		mt.__pairs = pairsFunction
		mt.__tclear = clearFunction
		
		return setmetatable(wrapperTable, mt)
	end

end