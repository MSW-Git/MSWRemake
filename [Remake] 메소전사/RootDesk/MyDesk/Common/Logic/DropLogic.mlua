@Logic
script DropLogic extends Logic

	@ExecSpace("Client")
	method void DropItem(Entity playerEntity, Entity dropMonster, integer monsterType)
		-- 몬스터 처치 시 아이템 드롭 처리
		local currentMap = dropMonster.CurrentMap
		
		if isvalid(currentMap.LimitMapComponent) then return end
		
		local playerDropCompo = playerEntity.PlayerDropsComponent
		local battleMap = currentMap.BattleMap
		local dropIndex = battleMap.monsterIndex
		
		local config = _GameConfig:GetConfig()
		
		if monsterType == config.MONSTERTYPE_ELITE then
			dropIndex = battleMap.eliteIndex
		elseif monsterType == config.MONSTERTYPE_BOSS then
			dropIndex = battleMap.bossIndex
			
			if dropMonster.MonsterObject.monsterId ~= currentMap.BattleMap.bossInfo.id then
				return
			end
		end
		
		local dropFunction = function(dropInfo) 
			if not isvalid(dropInfo) or dropInfo == {} then
				return
			end
				
			local str = _UtilLogic:Split(dropInfo, ",")
			
			for key, value in pairs(str) do
				local splits = _UtilLogic:Split(value, "/") 
				local id = splits[1]
				local count = tonumber(splits[2])
				local effect = splits[3]
				local ruid = "0c683dae204f4e659de33a4736cddc29"
				
				for i = 1, count do
					local offset = Vector3((_UtilLogic:RandomDouble() - 0.5) * 1.5, (_UtilLogic:RandomDouble() - 0.5) * 1.5, 0)
					local droppedItem = _PoolingLogic:SpawnModel("model://b0b9dbac-d66d-478e-812a-6ca386e4f3f7", dropMonster.TransformComponent.WorldPosition, dropMonster.CurrentMap)
					droppedItem.DroppedItemComponent:Init(id, _GameUtil:CreateGUID())
					local to = battleMap:ConvertPositionByBound(dropMonster.TransformComponent.WorldPosition + offset)
					_Tweener:MoveTo(droppedItem,to, 0.5, 0,EaseType.SineEaseIn,nil, "DropLogic_DropItem")
					
					if effect ~= "" then
						if effect == "best" then
							ruid = "0c683dae204f4e659de33a4736cddc29"
						elseif effect == "good" then
							ruid = "9120932f26594fbb99a9e2c7c5c969cc"
						end
						_EffectService:PlayEffectAttached(ruid, droppedItem, Vector3.zero, 0, Vector3.one)
						_EffectService:PlayEffectAttached("5240ec91d86b4ed8aaba9ec0cca80548", droppedItem, Vector3.zero, 0, Vector3.one, true, {["Alpha"] = 0.5})
					end
				end
			end
			
		end
		
		if dropMonster.MonsterObject.monsterId == _WaveLogic:GetLastBossId() then
			for key, value in pairs(playerDropCompo.dropTable) do 
				for k, v in pairs(value) do
					if v ~= nil and v ~= {} then
						dropFunction(v)
					end
				end
			end
		
			if playerDropCompo.dropTable[monsterType] ~= nil then
				playerDropCompo.dropTable[monsterType][dropIndex] = nil
				playerDropCompo:RequestRemoveDropData(monsterType, dropIndex)	
				playerDropCompo:RequestClearDropTable()
			else
			end
		else
			local monsterDropTable = playerDropCompo.dropTable[monsterType]
		
			if monsterDropTable~=nil then
				local dropData = monsterDropTable[dropIndex]
				
				if dropData ~= nil and dropData ~= {} then
					dropFunction(dropData)
					playerDropCompo.dropTable[monsterType][dropIndex] = nil
					playerDropCompo:RequestRemoveDropData(monsterType, dropIndex)
				end	
			end
		end
	end

end