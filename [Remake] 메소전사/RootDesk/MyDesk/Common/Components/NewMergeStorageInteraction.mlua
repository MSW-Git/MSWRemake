@Component
script NewMergeStorageInteraction extends Component

	property boolean enter = false

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 병합 저장소 상호작용 시 플레이어를 위아래로 텔레포트
		
		local InteractionEntity = event.InteractionEntity
		
		if InteractionEntity == _UserService.LocalPlayer then
			self.enter = not self.enter
			if self.enter then
				_TeleportService:TeleportToMapPosition(InteractionEntity,InteractionEntity.TransformComponent.WorldPosition + Vector3(0,2,0),InteractionEntity.CurrentMapName)
			else
				
				_TeleportService:TeleportToMapPosition(InteractionEntity,InteractionEntity.TransformComponent.WorldPosition + Vector3(0,-2,0),InteractionEntity.CurrentMapName)
			end
		end
	end

end