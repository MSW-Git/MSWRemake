@Component
script CloudTweener extends Component

	property Vector3 from = Vector3(0,0,0)

	property Vector2 leftBottom = Vector2(0,0)

	property Vector2 rightTop = Vector2(0,0)

	property Vector2 speed = Vector2(0.2,0.1)

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 구름 애니메이션을 위한 초기 설정
		self._T.transform = self.Entity.TransformComponent
		self.from = self._T.transform.Position:Clone()
		self.leftBottom = self.Entity.CurrentMap.MapComponent.LeftBottom
		self.rightTop = self.Entity.CurrentMap.MapComponent.RightTop
		self._T.mapSize = (self.rightTop - self.leftBottom):ToVector3()
		
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 구름을 지정된 속도로 이동시키고 경계를 벗어나면 초기 위치로 리셋
		local _T = self._T
		
		_T.transform:Translate(self.speed.x * delta,self.speed.y * delta)
		if _T.transform.Position.x > self.rightTop.x and _T.transform.Position.y > self.rightTop.y then
			
			_T.transform.Position = self.from - self._T.mapSize
		end
	end

end