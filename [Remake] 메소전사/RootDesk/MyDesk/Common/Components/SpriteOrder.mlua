@Component
script SpriteOrder extends Component

	property boolean dynamic = false

	property any orderUpdate = nil

	property number offsetY = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스프라이트 렌더링 순서를 설정하고 초기화
		local avatarRenderer = _UserService.LocalPlayer.AvatarRendererComponent
		local spriteRenderer = self.Entity.SpriteRendererComponent
		spriteRenderer.OrderInLayer = avatarRenderer.OrderInLayer
		spriteRenderer.SortingLayer = avatarRenderer.SortingLayer
		
		self._T.transform = self.Entity.TransformComponent
		self._T.orderYRatio = _GameUtil.orderYRatio
		self._T.offsetY = self.offsetY
		
		if self.dynamic then
			self:OrderUpdate()
		else
			self:OrderUpdate()
			self.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 스프라이트 순서를 업데이트
		self:OrderUpdate()
	end

	@ExecSpace("ClientOnly")
	method void OrderUpdate()
		-- Y 위치에 따라 스프라이트의 Z 순서를 계산하여 설정
		local _T = self._T
		local transform = _T.transform
		local worldPos = transform.WorldPosition
		worldPos.z = (worldPos.y  + _T.offsetY) * _T.orderYRatio
	end

end