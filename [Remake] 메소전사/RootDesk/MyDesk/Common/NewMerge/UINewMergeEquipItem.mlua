@Component
script UINewMergeEquipItem extends UINewMergeItem

	method void InitSprite()
		-- 장착 슬롯 UI 스프라이트 초기화
		__base:InitSprite()
		self.itemEntity.Parent.Enable = false
		self.mergeLvTag.Entity.Enable = false
		if self._T.originalRUID == nil then
			self._T.originalRUID = self.Entity.SpriteGUIRendererComponent.ImageRUID
		else
			self.Entity.SpriteGUIRendererComponent.ImageRUID = self._T.originalRUID
		end
		if isvalid(self._T.empty == false) then
			self._T.empty = self.Entity:GetChildByName("empty")
		end
		
		local slotText = self.Entity:GetChildByName("slotNumber",true)
		if isvalid(slotText) then
			slotText.TextComponent.Text = string.format("%d",self.equipSlot)
		end
		self:RefreshLockIcon()
		
		self.Entity:GetChildByName("guideEquip",true):AttachTo(self.Entity)
	end

	method void SetLockIconEnable(boolean enable)
		-- 잠김 아이콘 표시/숨김 설정
		if isvalid(self._T.iconLock) == false then
			self._T.iconLock = self.Entity:GetChildByName("lock", true)
		end
		self._T.iconLock.Enable = enable
		if isvalid(self._T.empty) then
			self._T.empty.Enable = not enable
		end
	end

	method void RefreshLockIcon()
		-- 캐릭터 장착 가능 슬롯 수에 따른 잠김 상태 업데이트
		local canEquipCount = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		self:SetLockIconEnable(self.equipSlot > canEquipCount )
		
	end

	method void SetGradeUI(string grade)
		-- 아이템 등급에 따른 UI 설정
		__base:SetGradeUI(grade)
		
	end

	method void SetWeaponID(string uniqueKey, table storageData)
		-- 장착된 무기 정보로 UI 설정
		__base:SetWeaponID(uniqueKey,storageData)
		if _UtilLogic:IsNilorEmptyString(uniqueKey) == false then
			self.itemEntity.Parent.Enable = true
			self:SetGradeUI(self.itemData.grade)
		else
			self.itemEntity.Parent.Enable = false
		end
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 장착 슬롯 클릭 시 장착/해제 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		local canEquipCount = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		if canEquipCount < self.equipSlot then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast63"))
			return
		end
		
		if self.mergePopup.slotSelectState then
				local selectedItem = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.mergePopup.currentUniqueKey]
			
				if  isvalid(selectedItem) == false then
					self.mergePopup:SetEquipGuidePanel(false)			
					return
				end
				_UserService.LocalPlayer.PlayerStorageComponent:Equip(self.mergePopup.currentUniqueKey,self.equipSlot)
				self.mergePopup:SetEquipGuidePanel(false)	
			return
		end
		local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.uniqueKey]
		
		if item == nil then
			return
		end
		
		_UIPopup:Open(_LocalizeLogic:GetText("popup8"), _LocalizeLogic:GetText("popup9"),function() 
				_UserService.LocalPlayer.PlayerStorageComponent:UnEquip(self.uniqueKey)
		end,function() end)
	end

	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 호버 상태 변경 시 장착 가이드 표시
		
		local state = event.state
		if self.mergePopup.selectedDragItem == nil then
			return
		end
		local canEquipCount = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		if canEquipCount < self.equipSlot then
			return
		end
		
		
		if state == ButtonState.Hover then
			self.mergePopup:OnHoverEquipSlot(self.equipSlot,true)
		else
			self.mergePopup:OnHoverEquipSlot(self.equipSlot,false)
		end
	end

end