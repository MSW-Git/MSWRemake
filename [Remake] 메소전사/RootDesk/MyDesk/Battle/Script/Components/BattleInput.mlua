@Component
script BattleInput extends Component

	property number lastKeyPressedTime = 0

	method void OnKeyDown(any key)
		-- 키 입력 처리 (레벨업 팝업 및 게임 조작)
		
		if _TimerLogic.pause and _UIGroupManager.uiLevelupPopup.isShow then
			if key == KeyboardKey.Alpha1 or key == KeyboardKey.Keypad1 then
				if _UIGroupManager.uiLevelupPopup.card1.Enable then
					_UIGroupManager.uiLevelupPopup.card1.UILevelUpButton:OnClickButton()
				end
				
			elseif key == KeyboardKey.Alpha2 or key == KeyboardKey.Keypad2 then
				if _UIGroupManager.uiLevelupPopup.card2.Enable then
					_UIGroupManager.uiLevelupPopup.card2.UILevelUpButton:OnClickButton()
				end
			elseif key == KeyboardKey.Alpha3 or key == KeyboardKey.Keypad3 then
				if _UIGroupManager.uiLevelupPopup.card3.Enable then
					_UIGroupManager.uiLevelupPopup.card3.UILevelUpButton:OnClickButton()
				end	
			end
			
			return
		end
		
		
		
		if key == KeyboardKey.Space then
			local battlePlayer = _UserService.LocalPlayer.BattlePlayer
			if isvalid(battlePlayer) then
				battlePlayer:Dash()
			end
		elseif key == KeyboardKey.Escape then
			self:OnKeyDownESC()
		elseif key == KeyboardKey.E then
			self:OnKeyDownE()
		end
		
		if key == KeyboardKey.LeftArrow or key == KeyboardKey.RightArrow or key == KeyboardKey.UpArrow or key == KeyboardKey.DownArrow or
				key == KeyboardKey.W or key == KeyboardKey.S or key == KeyboardKey.A or key == KeyboardKey.D then
			
			
			self.lastKeyPressedTime = _TimerLogic.ElapsedSeconds
		end
	end

	method void OnKeyDownESC()
		-- ESC 키 처리 (게임 일시정지/재개)
		if _BattleUIManager.bossAlertUI.isPlaying then return end
			if _BattleUIManager.levelUpPopup.isShow then return end
			if _OptionLogic.optionUI.Entity.Enable then return end
			
			if _TimerLogic.pause then
				_BattleUIManager:Resume()
			else
				_BattleUIManager:Pause()
			end
	end

	method void OnKeyDownE()
		-- E 키 처리 (차지 스킬 사용)
		local battlePlayer = _UserService.LocalPlayer.BattlePlayer
			if isvalid(battlePlayer) then
				battlePlayer:UseChargeSkill()
			end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키 다운 이벤트 핸들러
		
		local key = event.key
		
		self:OnKeyDown(key)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyUpEvent(KeyUpEvent event)
		-- 키 업 이벤트 핸들러
		
		if _TimerLogic.pause then
			return
		end
		
		local key = event.key
		
		if key == KeyboardKey.LeftControl then
			
		elseif key == KeyboardKey.LeftShift then
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "TimerLogic")
	handler HandleTimerChange(TimerChange event)
		-- 타이머 변경 이벤트 핸들러 (플레이어 컨트롤 활성화/비활성화)
		
		local pause = event.pause
		
		
		_UserService.LocalPlayer.PlayerControllerComponent.Enable = not pause
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyHoldEvent(KeyHoldEvent event)
		-- 키 홀드 이벤트 핸들러 (마지막 키 입력 시간 갱신)
		
		local key = event.key
		
		
		if key == KeyboardKey.LeftArrow or key == KeyboardKey.RightArrow or key == KeyboardKey.UpArrow or key == KeyboardKey.DownArrow or
				key == KeyboardKey.W or key == KeyboardKey.S or key == KeyboardKey.A or key == KeyboardKey.D then
			self.lastKeyPressedTime = _TimerLogic.ElapsedSeconds
		end
	end

end