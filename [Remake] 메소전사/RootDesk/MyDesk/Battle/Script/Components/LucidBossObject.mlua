@Component
script LucidBossObject extends BossObject

	property string changeRUID = "da2b5984f385427f90ed28c6e0f26505"

	property string afterMonster = "Boss_Lucid_mini"

	property number afterMonsterCount = 4

	property number afterMonsterDurationMin = 1

	property number afterMonsterDurationMax = 2

	property string reChangeRUID = "e9bd71d1ec0046cba8ac61965298adb5"

	property number changeSkillCool = 0

	property string waveSkill = "model://494d1add-e444-4fdb-a1f5-416b6b2488d5"

	method void UpdateMove()
		-- 루시드 보스의 이동 및 텔레포트 스킬 처리
		
		if self.isUsingSkill then
			return
		end
		if self.Entity.Enable == false then
			return
		end
		
		
		
		self.changeSkillCool = self.changeSkillCool - 1
		if self.changeSkillCool < 0 then
			local diff = self:GetPositionVec2() - _UserService.LocalPlayer.BattlePlayer:GetPositionVec2()
			if Vector2.Magnitude(diff) > 8 then
				self.changeSkillCool = 1
				self:ApplySpeedFactorByKey("SkillStop", 0)
				self._T.spriteRenderer.SpriteRUID = self.changeRUID
				
				self.isUsingSkill = true
					
				_TimerLogic:SetTimerOnce(function() 
				
					self.Entity.Enable = false
				
					self:SpawnMonster()
				end,self.afterMonsterDurationMin, "LucidBossObject.MoveUpdate")
				
				
				
				return
			end
		end
			
		
		__base:UpdateMove()
		
	end

	method void SpawnMonster()
		-- 웨이브 스킬 생성 후 해당 위치로 텔레포트
		local pos = self:GetPosition()
		
		local playerPos = _UserService.LocalPlayer.BattlePlayer:GetPositionVec2()
		
		local diff = pos:ToVector2() - playerPos
		
		if Vector2.Magnitude(diff) > 5 then
			pos = (playerPos + Vector2.Normalize(diff) * 5):ToVector3()
		end
		
		local wave = _PoolingLogic:SpawnModel(self.waveSkill,pos,self.Entity.CurrentMap)
		wave.MonsterWaveSkill:StartWave(pos,_UserService.LocalPlayer, self.damageRatio,true)
		
		local duration = 0.5 + 0.5 * _UtilLogic:RandomDouble() * (self.afterMonsterDurationMax - self.afterMonsterDurationMin)
		
		_TimerLogic:SetTimerOnce( function()
			
			local monsterPos = wave.TransformComponent.WorldPosition:ToVector2()
			
			self:SetPosition(monsterPos)
			self.Entity.Enable = true
			
			wave.MonsterWaveSkill:Dead()			
			self._T.spriteRenderer.SpriteRUID = self.reChangeRUID
			
				_TimerLogic:SetTimerOnce(function() 
				self.Entity.Enable = true
				self:ApplySpeedFactorByKey("SkillStop", 1)
				self.isUsingSkill = false		
				self._T.spriteRenderer.SpriteRUID = self.stand
				
				
			end,0.3 , "LucidBossObject.SpawnMonster_skillFinish")
				
		end ,duration, "LucidBossObject.SpawnMonster_waveFinish")
			
		
		
	end

	method void Init(string monsterId, boolean isAfterMonster, boolean respawn, number life)
		-- 루시드 보스 초기화 및 리소스 프리로드
		__base:Init(monsterId,isAfterMonster,respawn,life)
		_ResourceService:PreloadAsync({"b76f8fbf1fb24f2494f56543ffaadddc"},function() end)
	end

	method void OnChangePhase(number phase)
		-- 페이즈 변경 시 스테미나 시스템 변경 및 맵 전환
		__base:OnChangePhase(phase)
		
		
		if _GameSettingLogic.mode ~= _GameConfig:GetConfig().GAMEMODE_BASIC then
			return
		end
		if phase == 2 then
			self._T.lucidSysMsgEventId = _TimerLogic:SetTimerRepeat(function() 
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage26"), "neg")
			end,5,0,"LucidBossObject.OnChangePhase")
			
			
			
			_UserService.LocalPlayer.BattlePlayer.staminaRecoverySpeed = 0 
			_UserService.LocalPlayer.BattlePlayer.stamina = 0
			_UserService.LocalPlayer.BattlePlayer.maxStamina = math.maxinteger
			self.Entity.CurrentMap.BattleMap:ChangeBossMap("b76f8fbf1fb24f2494f56543ffaadddc","8a9bdde4710647068a5fb41c6954c2f5","8f171d16dc1e44d6a44baa9f9a28358b",3,Color.white)
		end
	end

	method void Dead(boolean dropExp)
		-- 루시드 보스 사망 시 시스템 메시지 타이머 정리
		__base:Dead(dropExp)
		
		if self._T.lucidSysMsgEventId  ~= nil then
			_TimerService:ClearTimer(self._T.lucidSysMsgEventId)
		end
	end

end