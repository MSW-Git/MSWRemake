@Component
script AfterMonsterSpawner extends Component

	property string afterMonster = ""

	property number life = 0

	property string effectRuidSpawn = "6a39036e76c547a79e2a10e65719b7b6"

	property string effectRuidDead = "2048a0a4e8b24827929300b41bacfd54"

	property Vector3 offset = Vector3(0,0,0)

	@ExecSpace("ClientOnly")
	method void OnDestroy()
		-- 컴포넌트 파괴 시 정리 작업 (현재 빈 구현)
		
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스킬 이펙트 종료 후 몬스터 생성 및 생명주기 관리
		if self.Entity.CurrentMap.MultiBattleMap ~= nil then
			return
		end
		
		
		local parent = self:GetParentEntity(self.Entity.Parent)
		if isvalid(parent) == false then
			return
		end
		parent:ConnectEvent(SkillEffectStart,function(e)
				
		end)
		parent:ConnectEvent(SkillEffectEnd,function(e) 
				
			if _UtilLogic:IsNilorEmptyString(self.afterMonster) == false then
				local monsterData = _MonsterLogic:GetMonsterData(self.afterMonster)
				local pos = self.Entity.TransformComponent.WorldPosition + self.offset
				local afterMonster = _PoolingLogic:SpawnModel(monsterData.model, pos,self.Entity.CurrentMap)	
			
				if _UtilLogic:IsNilorEmptyString(self.effectRuidSpawn) == false then
					_EffectService:PlayEffect(self.effectRuidSpawn,self.Entity,pos,0,Vector3.one)
				end
				
				local monster = afterMonster.MonsterObject
				monster:Init(self.afterMonster, true,false,1)
				monster:SetTarget(_UserService.LocalPlayer)
				monster:SetPosition(pos:ToVector2())
				monster:SetVelocity(Vector2.zero)
					if self.life > 0 then
						_TimerLogic:SetTimerOnce( function()
								if monster.isDead then 
									return
								end
								if _UtilLogic:IsNilorEmptyString(self.effectRuidDead) == false then
									_EffectService:PlayEffect(self.effectRuidDead,self.Entity,afterMonster.TransformComponent.Position,0,Vector3.one)
								end
								monster:Dead(false)
						end ,self.life, "AfterMonsterSpawner.OnBeginPlay_deadTimer")
					end
			end		
		end)
	end

	method Entity GetParentEntity(Entity parent)
		-- 스킬 이펙트 오브젝트를 가진 부모 엔티티 재귀 탐색
		if parent.MapComponent ~= nil then
			return nil
		end
		if parent.SkillEffectObject ~= nil then
			return parent
		end
		return self:GetParentEntity(parent.Parent)
	end

end