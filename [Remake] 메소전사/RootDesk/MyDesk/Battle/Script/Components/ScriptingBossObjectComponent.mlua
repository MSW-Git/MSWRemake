@Component
script ScriptingBossObjectComponent extends BossObject

	property string attack2 = ""

	property string attack3 = ""

	property string attack4 = ""

	property string skill1 = ""

	property string skill2 = ""

	property string skill3 = ""

	property string skillAfter = ""

	property string skillAfter2 = ""

	property table skillSet = {}

	property boolean isKnockDown = false

	property integer usingSkillCount = 1

	property integer knockDownCount = 0

	property string attack1BulletId = ""

	property string attack2BulletId = ""

	property string attack3BulletId = ""

	property string attack4BulletId = ""

	@HideFromInspector
	property number attackedTime = 0

	method void Init(string monsterId, boolean isAfterMonster, boolean respawn, number life)
		-- 스크립트 보스 초기화 (넘어짐 비율 설정, 페이즈 확인)
		
		__base:Init(monsterId, isAfterMonster, respawn, life)
		
		self.isKnockDown = false
		self._T.knockDownRatio = {}
		self.usingSkillCount = 1
		
		for i = 1, self.knockDownCount do
			self._T.knockDownRatio[i] = _UtilLogic:RandomIntegerRange(10, 90) 
		end
		
		self.isInited = true
		self:CheckPhase()
	end

	method void CheckPhase()
		-- HP 비율에 따른 페이즈 확인 및 스킬 세트 설정, 넘어짐 처리
		local hpRatio = self.hp / self._T.maxHp * 100
		
		table.clear(self.skillSet)
		
		
		
		
		table.insert(self.skillSet, function() self:Attack3() end)
		table.insert(self.skillSet, function() self:Attack4() end)
		table.insert(self.skillSet, function() self:Teleport() end)
		
		if hpRatio <= 35 then
			self.phase = 3
			table.insert(self.skillSet, function() self:Attack1() end)
			table.insert(self.skillSet, function() self:Attack2() end)
		elseif hpRatio <= 70 then
			self.phase = 2
			table.insert(self.skillSet, function() self:Attack2() end)
		else
			self.phase = 1
		end
		
		if self.isKnockDown then return end
		
		for key, value in pairs(self._T.knockDownRatio) do
			if value == math.floor(hpRatio) then
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage27"), "")
				
				self.isKnockDown = true 
				self:Stop()
				self._T.spriteRenderer.SpriteRUID = self.stand
				local effect = _EffectService:PlayEffectAttached("f6831cf8bf8d419e8819e0c4798b28e2", self.Entity, Vector3(0, 1,0), 0, Vector3.one, true)
				
				_TimerLogic:SetTimerOnce(function()
						self.isKnockDown = false
						self:Move()
						self._T.spriteRenderer.SpriteRUID = self.move
						_EffectService:RemoveEffect(effect)
						
						end, 7, "ScriptingBossObjectComponent.CheckPhase")
				
				break
			end
		end
	end

	method void UpdateMove()
		-- 이동 업데이트 (부모 클래스 호출)
		__base:UpdateMove()
	end

	@ExecSpace("ClientOnly")
	method void Attack1()
		-- 첫 번째 공격 패턴 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Attack2()
		-- 두 번째 공격 패턴 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Attack3()
		-- 세 번째 공격 패턴 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Attack4()
		-- 네 번째 공격 패턴 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Disappear()
		-- 사라지기 애니메이션 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Appear()
		-- 나타나기 애니메이션 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Teleport()
		-- 텔레포트 스킬 (상속 클래스에서 구현)
		
	end

	@ExecSpace("ClientOnly")
	method void Stop()
		-- 보스 이동 정지 및 대기 상태로 전환
		local _T = self._T
		
		_TimerLogic:ClearTimer(_T.moveTimer)
		_T.spriteRenderer.SpriteRUID = self.stand
		self:SetVelocity(Vector2.zero)
		
		self.Entity.MovementComponent:Stop()
	end

	@ExecSpace("ClientOnly")
	method void UseUniqueSkill()
		-- 고유 스킬 사용 (스킬 세트에서 랜덤 선택)
		if self.isKnockDown then return end
		
		self:Stop()
		
		local rand = _UtilLogic:RandomIntegerRange(1, #self.skillSet)
		
		self.skillSet[rand]()
		
		self.attackedTime = _UtilLogic.ServerElapsedSeconds
	end

	@ExecSpace("ClientOnly")
	method void Move()
		-- 보스 이동 처리 (타겟 추적, 방향 설정, 상태 효과 고려)
		local _T = self._T
		
		_TimerLogic:ClearTimer(_T.moveTimer)
		
		self.isUsingSkill = false
		_T.spriteRenderer.SpriteRUID = self.move
		if self.isDead then
			return
		end
		
		if _T.isStunned or _T.isFlated or _T.inStorm then return end
		if self.isKnockDown then return end
		
		local target = self.target
		if not isvalid(target) then return end
		
		if isvalid(target.SkillEffectObject) and target.Enable == false then
			if _T.attractEffect ~= 0 then
				self:TurnOffAttract()
			end
			return
		end
		
		if _T.moveStopTime > _G.ElapsedSeconds then
			return
		end
		
		local pos = self:GetPositionVec2()
		local targetPos = _TargetCacheLogic:GetTargetPosition(target)
		local diff = targetPos - pos
		local dir = diff:Normalize()
		self:SetVelocity(dir * self.speed)
		
		if dir.x < 0 ~= self._T.isFaceLeft then
			_T.spriteRenderer.FlipX = _T.isFaceLeft
			_T.isFaceLeft = not _T.isFaceLeft
		end
		
		_T.spriteRenderer.SpriteRUID = self.move
	end

end