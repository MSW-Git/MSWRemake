@Component
script RaidBattlePlayer extends BattlePlayer

	@ExecSpace("ClientOnly")
	method boolean GainEXP(number exp)
		-- 레이드 모드에서는 경험치 획득 비활성화
		return false
	end

	@ExecSpace("ClientOnly")
	method void LevelUp(boolean notLevelUp)
		-- 레이드 모드에서는 레벨업 비활성화
		
	end

	method void Init()
		-- 레이드 배틀 플레이어 초기화 (부모 초기화 후 최대 장비 슬롯 추가)
		__base:Init()
		for i = 1, _GameConfig:GetConfig().MAX_EQUIPMENT_CNT do
			self.Entity.BattlePlayer:AddWeapon("")
		end
	end

end