@Component
script AIPlayer extends Component

	property BattlePlayer battlePlayer = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- AI 플레이어 초기화 및 자동 행동 패턴 설정
		self.Entity.PlayerStorageComponent.storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		self.Entity.PlayerCharacterData.charIndex = _UserService.LocalPlayer.PlayerCharacterData.charIndex
		self.Entity.PlayerCharacterData.charStatusTable["maxHp"] =  _UserService.LocalPlayer.PlayerCharacterData.charStatusTable["maxHp"]
		self.Entity:AddComponent("BattlePlayer")
		self.battlePlayer = self.Entity.BattlePlayer
		
		self.battlePlayer:Init()
		self.Entity.TriggerComponent.CollisionGroup = CollisionGroups.Monster
		self.Entity.TriggerComponent.Enable = true
		self.Entity.MovementComponent:SetPosition(Vector2(5,0))
		
		
		
		local updateId = 0
		updateId = _TimerLogic:SetTimerRepeat(function() 
				if isvalid(self.Entity) == false or self.battlePlayer.isDead then
					_TimerLogic:ClearTimer(updateId)
					return
				end
				if _TimerLogic.pause then
					self.Entity.MovementComponent:Stop()
					return
				end
				local diff = _UserService.LocalPlayer.TransformComponent.Position - self.Entity.TransformComponent.Position
				diff.z = 0
				local dir = Vector3.Normalize(diff):ToVector2()		
				
				self.Entity.MovementComponent:MoveToDirection(dir,1)
				self.Entity.PlayerControllerComponent.LookDirectionX = dir.x > 0 and 1 or -1
				self.Entity.StateComponent:ChangeState("MOVE")
			
				if _UtilLogic:RandomIntegerRange(0,100) < 10 then
						self.battlePlayer:Dash()
				end
				
		end,1,1,"AIPlayer.OnBeginPlay")
		
		self.battlePlayer:AddWeapon("")
		
	end

end