@Component
script SkillScaleTweener extends Component

	property Vector3 from = Vector3(0,0,0)

	property Vector3 to = Vector3(0,0,0)

	property number duration = 1

	property string ease = "Linear"

	property boolean pingpong = false

	property number pingpongCount = 1

	property boolean loop = false

	property boolean isPlaying = false

	method void Play()
		-- 스케일 트위닝 시작
		self._T.transform.Scale = self.from
		self._T.time = 0
		self.isPlaying = true
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임 스케일 트위닝 업데이트
		if _TimerLogic.pause then
			return
		end
		if self.isPlaying == false then
			return
		end
		delta = delta * _TimerLogic.timeScale
		
		self._T.time = self._T.time + delta
		local timeValue = self._T.time
		
		if self.pingpong then
			timeValue = _GameUtil:PingPong(self._T.time,self.duration)
		elseif self.loop then
			timeValue = self._T.time % self.duration
		end
		
		local value = _TweenLogic:Ease(0,1,self.duration,self._T.ease,timeValue)
		self._T.transform.Scale = value * self.to + (1-value) * self.from
		if self.pingpong == false then
			if self._T.time > self.duration then
				self:Stop()
			end
		elseif self.pingpongCount then
			if self.pingpongCount > 0 then
				local cnt = self._T.time / (self.duration * 2)
				if cnt > self.pingpongCount then
					self:Stop()
				end
			end
		end
	end

	method void Stop()
		-- 스케일 트위닝 정지
		self._T.isPlaying = false
		self._T.transform.Scale = self.to
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스킬 이펙트 이벤트와 연결하여 자동 재생
		self._T.ease = EaseType.CastFrom(self.ease)
		self._T.transform = self.Entity.TransformComponent
		self.Entity.Parent:ConnectEvent(SkillEffectStart,function(e)
				self:Play()
		end)
		self.Entity.Parent:ConnectEvent(SkillEffectEnd,function(e) 
				self:Stop()
		end)
		
		if self._T.isPlaying == false then
			self:Play()
		end
	end

end