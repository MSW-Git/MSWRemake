@Component
script SplitBossObject extends BossObject

	property number splitLife = 3

	property table bossGroup = {}

	property table bossGroupInfo = {}

	method void Dead(boolean dropExp)
		-- 분열 보스 사망 시 더 작은 보스들로 분열
		if self.splitLife  > 0 then
			for i = 1, 2 do
				local monsterData = _MonsterLogic:GetMonsterData(self.monsterId)
				
				local afterMonster = _PoolingLogic:SpawnModel(monsterData.model, self.Entity.TransformComponent.Position + Vector3(-0.3 + i*0.2,0,0), self.Entity.CurrentMap)	
				afterMonster.SplitBossObject.bossGroup = self.bossGroup
				afterMonster.SplitBossObject.bossGroupInfo = self.bossGroupInfo
				afterMonster.MonsterObject:Init(self.monsterId, false,false,1)
				afterMonster.MonsterObject:SetTarget(_UserService.LocalPlayer)
				afterMonster.SplitBossObject.splitLife = self.splitLife - 1
				
				
			end
		end
		
		if self.bossGroupInfo.killCount == nil then
			self.bossGroupInfo.killCount = 0
		end
		
		self.bossGroupInfo.killCount = self.bossGroupInfo.killCount + 1 
		if self.bossGroupInfo.killCount == 15 then
			_WaveLogic:SetDelayClearState(false)
		end
		__base:Dead(dropExp)
		
		
	end

	@ExecSpace("Client")
	method void DropItem()
		-- 분열 보스는 아이템 드롭하지 않음
		
	end

	method void SetDamage(number damage, Vector2 knockback, boolean isCritical, string weaponUniqueKey)
		-- 분열 보스 그룹 전체 HP 관리 및 데미지 처리
		local _T = self._T
		if _T.currentMap.BattleMap.isEnd then return end
		
		local originHP = self.hp 
		
		__base:SetDamage(damage,knockback,isCritical,weaponUniqueKey)
		
		local backHP = math.max(0,  self.hp)
		
		local realDamage = originHP - backHP
		
		local maxHp = self:GetMaxHp() * (2^4 - 1)
		
		if self.bossGroupInfo.damage == nil then
			self.bossGroupInfo.damage = 0
		end
		self.bossGroupInfo.damage = self.bossGroupInfo.damage + realDamage
		
		_MonsterLogic:SendEvent(BossInfoChange(maxHp - self.bossGroupInfo.damage,maxHp,true,damage,self.monsterId))
	end

	method void Init(string monsterId, boolean isAfterMonster, boolean respawn, number life)
		-- 분열 보스 초기화 및 그룹 등록
		table.insert(self.bossGroup,self.Entity)
		__base:Init(monsterId,isAfterMonster,respawn,life)
		self.Entity.TransformComponent.Scale = Vector3((self.splitLife+2)/2,(self.splitLife+2)/2,1)
		_WaveLogic:SetDelayClearState(true)
	end

	method void CheckLastBoss()
		-- 마지막 분열 보스인지 확인
		if self.life  == 0 then
			__base:CheckLastBoss()
		end
	end

end