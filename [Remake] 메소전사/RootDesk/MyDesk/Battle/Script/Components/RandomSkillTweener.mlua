@Component
script RandomSkillTweener extends SkillTweener

	property Vector2 randomToMin = Vector2(0,0)

	property Vector2 randomToMax = Vector2(0,0)

	method void Play()
		-- 랜덤한 목표 위치로 트위닝 시작
		self.to = Vector3(_UtilLogic:RandomDouble() *(self.randomToMax.x - self.randomToMin.x) + self.randomToMin.x,
		_UtilLogic:RandomDouble() *(self.randomToMax.y - self.randomToMin.y) + self.randomToMin.y,0)
		
		__base:Play()
	end

end