@Logic
script BossBalanceLogic extends Logic

	property boolean isBossWave = false

	property number damageCount = 0

	property number chapter = 0

	property number startTime = 0

	property string currentBossId = ""

	property number bossDamageCount = 0

	property number bossStartTime = 0

	method table GetResult()
		-- 보스 전투 결과 데이터 반환 (피격 횟수, 소요 시간 등)
		local result = {}
		result.hit = self.damageCount
		result.time = _TimerLogic.ElapsedSeconds - self.startTime
		result.hit2 = self.bossDamageCount
		result.time2 = _TimerLogic.ElapsedSeconds - self.bossStartTime
		return result
	end

	@EventSender("Logic", "WaveLogic")
	handler HandleWaveStartEvent(WaveStartEvent event)
		-- 웨이브 시작 시 보스 전투 상태 추적 시작
		
		local isBossWave = event.isBossWave
		local waveNum = event.waveNum
		
		
		
		if waveNum == 1 then
			
			self.startTime = _TimerLogic.ElapsedSeconds
		end
		
		if isBossWave  then
			self.isBossWave = isBossWave
			self.bossStartTime = _TimerLogic.ElapsedSeconds
			self.bossDamageCount = 0
		else
			self.isBossWave = false
		end
		
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerHitEvent(PlayerHitEvent event)
		-- 플레이어 피격 시 데미지 카운트 증가
		
		local damage = event.damage
		
		self.damageCount = self.damageCount + 1
		self.bossDamageCount = self.bossDamageCount + 1
		
		
		
		
	end

	@EventSender("Logic", "StageLogic")
	handler HandleStageStartEvent(StageStartEvent event)
		-- 스테이지 시작 시 카운터 초기화
		
		self.damageCount = 0
		self.chapter = _WaveLogic.currentChapter
	end

end