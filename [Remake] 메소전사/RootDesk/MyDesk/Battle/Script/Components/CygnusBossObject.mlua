@Component
script CygnusBossObject extends BossObject

	property table equipGun = {}

	property number stage = 70

	property string afterBossMonster = "Boss_Avatar"

	property string effectRuidSpawn = ""

	property number deadCnt = 0

	method void UpdateMove()
		-- 기본 보스 이동 로직 실행
		__base:UpdateMove()
		
	end

	method void Init(string monsterId, boolean isAfterMonster, boolean respawn, number life)
		-- 시그너스 보스 초기화
		__base:Init(monsterId,isAfterMonster,respawn,life)
		
		
		
	end

	method void AddGun(string id, number slot, string uniqueKey)
		-- 보스 전용 무기 장착 및 설정
		
		local gunData = _WeaponSpecLogic:GetWeaponSpec(id)
		if gunData == nil then
			return
		end
		local angle = _UtilLogic:RandomDouble() * math.pi * 2
		local offsetPos = Vector3(math.cos(angle),math.sin(angle),0) * 1
		
		local gun = _SpawnService:SpawnByModelId(gunData.model,"gun",self._T.transform.Position + offsetPos,self.Entity.CurrentMap)
		gun.BattleGunObject:SetPlayer(self.Entity,slot,gunData, uniqueKey,false)
		gun.BattleGunObject:SetOriginalRange(gunData.range)
		gun.BattleGunObject.isBossWeapon = true
		gun.SpriteRendererComponent.SpriteRUID = gunData.ruid
		gun.TriggerComponent.CollisionGroup = CollisionGroups.Monster
		local equipGun = {}
		equipGun.gun = gun
		equipGun.id = id
		equipGun.uniqueKey = uniqueKey
		equipGun.isPhysicalWeapon = gun.BattleGunObject.physicalWeapon
		
		self.equipGun[slot] = equipGun
		
		for k,v in pairs(self.equipGun) do
			v.gun.BattleGunObject.angleOffset = -20 + (slot - 1) * -15
		end
	end

	method void Dead(boolean dropExp)
		-- 시그너스 보스 사망 시 후속 보스 스폰 및 대화 이벤트 처리
		
		if _GameSettingLogic.mode ~= _GameConfig:GetConfig().GAMEMODE_BASIC then
			__base:Dead(dropExp)
			return
		end
		
		self.isDead = true
		local spawnNextBoss = function()
				
				local pos = self.Entity.TransformComponent.WorldPosition:Clone()
				if _UtilLogic:IsNilorEmptyString(self.effectRuidSpawn) == false then
						_EffectService:PlayEffect(self.effectRuidSpawn,self.Entity,pos,0,Vector3.one * 4)
				end
				
			
				
				self:MoveStop()
				self.Entity.Enable = false
			
			
				_TimerLogic:SetTimerOnce(function() 
						if _UtilLogic:IsNilorEmptyString(self.afterBossMonster) == false then
								self.Entity.CurrentMap.BattleMap:ChangeBossMap("","","8f171d16dc1e44d6a44baa9f9a28358b",0,Color.black)
		
								self.Entity.CurrentMap.SoundComponent.AudioClipRUID = ""
						
								local monsterData = _MonsterLogic:GetMonsterData(self.afterBossMonster)
								
								local afterMonster = _PoolingLogic:SpawnModel(monsterData.model, pos,self.Entity.CurrentMap)	
							
								
								local monster = afterMonster.AvatarBossObject
								monster:Init(self.afterBossMonster, false,false,1)
								monster:SetTarget(_UserService.LocalPlayer)
								_UserService.LocalPlayer.BattlePlayer:ApplyInvincible(0)
					
					
								monster.onDead = function(pos)
						
									self:SetPosition(pos)
									__base:Dead(false)
						
									
								end
							end		
							
					end,0.2, "CygnusBossObject.Dead")
				
				
		
					_TimerLogic:Resume()
									
			
					
		end
		
		if _UserService.LocalPlayer.PlayerInfoComponent.playerInfo.stageStep < self.stage then
				_TimerLogic:Pause()
				
				_DialogDataLogic:StartScene("boss_cygnus","normal",spawnNextBoss)
		else
			spawnNextBoss()
		end
		
		
	end

end