@Component
script BattlePlayer extends Component

	property table equipGun = {}

	property Entity target = "a92d4e12-1d4b-4591-a0ff-dc05131adf9c"

	property integer lv = 0

	property number exp = 0

	@TargetUserSync
	property number hp = 100

	@TargetUserSync
	property number maxHp = 100

	property boolean isDead = false

	@HideFromInspector
	property number stamina = 60

	@HideFromInspector
	property number maxStamina = 60

	@HideFromInspector
	property boolean isDashingNow = false

	@HideFromInspector
	property number staminaRecoverySpeed = 17.5

	@HideFromInspector
	property number needDashStamina = 60

	@HideFromInspector
	property EntityRef collectingPet = nil

	property number unDamagedTime = 1

	@HideFromInspector
	property EntityRef diggingPet = nil

	property number bonusExpRate = 0

	property boolean bonusLvUpHeal = false

	@HideFromInspector
	property integer hpRecoverTimer = 0

	@HideFromInspector
	property boolean isInvincible = false

	@HideFromInspector
	property number dashExplodeTime = 0

	@HideFromInspector
	property boolean activateOvercome = false

	@HideFromInspector
	property integer overcomeTimer = 0

	@HideFromInspector
	property boolean appliedReflect = false

	@HideFromInspector
	property integer warmUpTimer = 0

	property integer killCount = 0

	@HideFromInspector
	property boolean appliedShield = false

	@HideFromInspector
	property integer shieldCount = 0

	property number burnTime = 0

	@HideFromInspector
	property integer meditationTimer = 0

	@HideFromInspector
	property EntityRef gatheringPet = nil

	property table pets = {}

	property table birdEyeTargets = {}

	property number usedRebornByAngelSuit = 0

	property table repeatTimerTable = {}

	@TargetUserSync
	property number sp = 0

	property number maxSp = 200

	property UILevelUpPopup levelupPopup = "2f9bc163-5c61-4175-b386-71c49bc0094c"

	@HideFromInspector
	property boolean isSuperMode = false

	property number shieldGauge = 0

	@HideFromInspector
	property number clearedTime = 0

	@HideFromInspector
	property boolean isHoldingProfessionalWeapon = false

	property UILevelUpPopup uiLevelUp = "2f9bc163-5c61-4175-b386-71c49bc0094c"

	property number hitCountForLog = 0

	property boolean getBossShield = false

	@HideFromInspector
	property table hitInfo = {}

	property boolean willReturnTown = false

	property integer usedDashCount = 0

	property integer usedSoulBoomCount = 0

	property integer selectedBuffCount = 0

	property integer monsterAttackCount = 0

	property integer lootedPotionCount = 0

	property integer killedWaveMonsterCount = 0

	property integer destroyedOrbCount = 0

	property boolean armorSkillEnable = true

	method void OnBeginPlay()
		-- 배틀 플레이어 초기화 및 로컬 플레이어 전용 설정
		if self:IsServer() then
			return
		end
		self._T.cardIndex = 1
		self._T.hitCount = 0
		self._T.hitIndex = 1
		self._T.leftInvincibleTime  = 0
		
		if self.Entity ~= _UserService.LocalPlayer then
			self.Enable = false
			return
		end
		self:Init()
		self:InitLocalPlayerEvent()
		
		if isvalid(self.Entity.CurrentMap.LimitMapComponent) then
			self.Entity.CurrentMap.LimitMapComponent:InitPlayer()
		
		elseif isvalid(self.Entity.CurrentMap.RandomBossMapComponent) then
			self.Entity.CurrentMap.RandomBossMapComponent:InitPlayer()
		end
		
		self.uiLevelUp.initted = false
	end

	@ExecSpace("ClientOnly")
	method boolean GainEXP(number exp)
		-- 경험치 획득 및 레벨업 처리 (펫 보너스 포함)
		if self.lv == 0 then
			return false
		end
		
		if _TimerLogic.pause then
			return false
		end
		
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_BENCHMARK then
			return true
		end
		
		local maxLV = _GameConfig:GetConfig().MAX_INGAME_LV
		if self.lv >= maxLV then return true end
		
		self.exp = self.exp + exp * (1 + self.bonusExpRate + _PetLogic:GetTotalExpBonus() / 100) 
		
		local maxExp = self:GetMaxEXP(self.lv)
		
		if self.exp > maxExp and not _BattleUIManager.levelUpPopup.isShow then
			self:LevelUp(false)
		end
		
		
		self:RefreshEXP()
		
		return true
	end

	method table EquipGun(number slot, string id, string uniqueKey, boolean replica)
		-- 무기 장착 및 중복 무기 레벨업 처리
		if replica == false then
			for k,v in pairs(self.equipGun) do
		
				if v.uniqueKey == uniqueKey then
					v.gun.BattleGunObject:CardLevelUp()
		
					_BuffLogic.selectedCard[self._T.cardIndex] = id .. "(reinforce)"
		
					
					self._T.cardIndex += 1
			
					return nil
				end
			end
		end
		
		local gunData = _WeaponSpecLogic:GetWeaponSpec(id)
		if gunData == nil then
			return nil
		end
		local angle = _UtilLogic:RandomDouble() * math.pi * 2
		local offsetPos = Vector3(math.cos(angle),math.sin(angle),0) * 1
		
		local gun = _SpawnService:SpawnByModelId(gunData.model,"gun",self:GetPosition() + offsetPos,self.Entity.CurrentMap)
		gun.BattleGunObject:SetPlayer(self.Entity,slot,gunData, uniqueKey,false)
		gun.BattleGunObject:SetOriginalRange(gunData.range)
		gun.SpriteRendererComponent.SpriteRUID = gunData.ruid
		local equipGun = {}
		equipGun.gun = gun
		equipGun.id = id
		equipGun.groupId = gunData.mergeId
		equipGun.uniqueKey = uniqueKey
		equipGun.isPhysicalWeapon = gun.BattleGunObject.physicalWeapon
		self.equipGun[slot] = equipGun
		
		for k,v in pairs(self.equipGun) do
			v.gun.BattleGunObject.angleOffset = -20 + (slot - 1) * -15
		end
		self.Entity:SendEvent(EquipGunChange(uniqueKey))
		_BuffLogic.selectedCard[self._T.cardIndex] = id .. "(equip)"
		self._T.cardIndex += 1
		
		_DPSLogic:AddDamage(uniqueKey, 0)
		
		
		return equipGun
	end

	method void UnequipGun(number slot)
		-- 지정된 슬롯의 무기 장착 해제 및 파괴
		if self.equipGun[slot]  == nil then
			return
		end
		self.equipGun[slot].gun:Destroy()
		self.equipGun[slot] = nil
		
	end

	method void UseChargeSkill()
		-- 차지 스킬(소울붐) 사용 및 주변 몬스터 넘백/스턴 처리
		if _BuffLogic.appliedBuff.chargingSkill == false then
			
			return
		end
		
		if self.sp < self.maxSp then
			return
		end
		local overlaps = self:GetOverlaps(tostring(CollisionGroups.Player), self:GetPositionVec2(), 10)
		local monsters = {}
		local soulBoomTrigger = _PoolingLogic:SpawnModel("model://4801f774-b4fd-4989-8d03-b9cb12a60fd4",self._T.transform.Position,self.Entity.CurrentMap)
		for _, trigger in pairs(overlaps) do
			---@type Entity
			local entity = trigger.Entity
			local monster = entity.MonsterObject
			
			if isvalid(monster) then
				table.insert(monsters,monster)
				local isCritical = false
				local diff = monster:GetPositionVec2() - self._T.transform.Position:ToVector2()
				diff:Normalize()
				monster:SetKnockback(diff * 10, 0.5, true)
				continue		
			end
			
			local destroyObject = entity.DestroyableObject
			local waterDrop = entity.WaterDropObject
			if isvalid(destroyObject) and isvalid(waterDrop) == false then
				destroyObject:SetDamage(destroyObject.hp,Vector2.zero,false,"")
				continue
			end
		
		end
		
		_TimerLogic:SetTimerOnce(function() 
			_PoolingLogic:DestroyEntity(soulBoomTrigger)
			for k,v in pairs(monsters) do
				---@type MonsterObject
				local monster = v
				monster:ApplyStun(1)
			end
		end,0.5, "BattlePlayer_UseChargeSkill")
		
		
		
		
		self:SetSP(0)
		self._T.skillKeydown = false
		self.Entity.CameraComponent:ShakeCamera(1,0.5)
		_BattleUIManager:PlayUIEff("model://e6db2286-dc84-4efe-bf24-048398c985ea",1)
		
		_EffectService:PlayEffect("9e464456b7b44512ac2ce182625d61e4",self.Entity,self:GetPosition(),0,Vector3.one*3,false)
		_EffectService:PlayEffect("2bed7bc1479c405a99ad97165a9d899f",self.Entity,self:GetPosition(),0,Vector3.one*3,false)
		
		self.Entity.AvatarRendererComponent:PlayEmotion(EmotionalType.Hot,1)
		self.usedSoulBoomCount += 1
		
		
		if _BuffLogic.appliedBuff.guts then
			_EffectService:PlayEffectAttached("0df582530d1442e1bc480690c04d3e37", self.Entity, Vector3(0, -1, 0), 0, Vector3.one * 3)
			local simulator = _CollisionService:GetSimulator(self.Entity)
			local currentPos = self._T.transform.Position
			local overlaps = simulator:OverlapCircleAll(tostring(CollisionGroups.PlayerSkill), currentPos:ToVector2(), 8)
				
			for i = 1, #overlaps do
				local entity = overlaps[i].Entity
				
				local monster = entity.MonsterObject
				if monster ~= nil then
					local isCritical = false
					local diff = monster:GetPositionVec2() - self:GetPositionVec2()
					diff:Normalize()
					monster:SetKnockback(diff * 10,0.1,true)
				end
			end
		end
		
		self.Entity:SendEvent(UseChargingSkillEvent())
	end

	method void StartChargeSkill()
		-- 차지 스킬 차징 시작 및 이팩트 재생
		self._T.skillStartTime = _UtilLogic.ElapsedSeconds
		self._T.skillKeydown = true
		_EffectService:PlayEffectAttached("c24fa228cb3a48eda4e0fcbd62299b94",self.Entity,Vector3.zero,0,Vector3.one)
		for k,v in pairs(self.equipGun) do
			v.gun.BattleGunObject:StartChargeSkill(self._T.skillAvatar)
		end
		_TimerLogic:SetTimerOnce(function()
				if self._T.skillKeydown then
					_EffectService:PlayEffectAttached("2117a8011b6b4ecd97d4a69a415edc72",self.Entity,Vector3.zero,0,Vector3.one)
				end
		end,1, "BattlePlayer.StartChargeSkill")
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 플레이어 상태 업데이트 (스태미나, 무적, 화상 등)
		delta = delta * _TimerLogic.timeScale
		if self._T.transform == nil then
			self._T.transform = self.Entity.TransformComponent
		end
		
		self._T.position = self._T.transform.Position
		self._T.positionVec2 = self._T.position:ToVector2()
		
		
		
		if _TimerLogic.pause then return end
		self._T.staminaBarSprite.TiledSize.x = 8 * self.stamina / self.maxStamina
		
		
		
		
		if Vector2.Magnitude(self.Entity.KinematicbodyComponent.MoveVelocity) > 0 then
			self._T.moveVelopcity = self.Entity.KinematicbodyComponent.MoveVelocity
		end
		
		if self.stamina < self.maxStamina and not self.isDashingNow then
			self:IncreaseStamina(delta * (self.staminaRecoverySpeed * _BuffLogic:GetStaminaRecovery()))
		end
		
		if self.isInvincible then
			self._T.leftInvincibleTime = self._T.leftInvincibleTime - delta
			if self._T.leftInvincibleTime <= 0 then
				if isvalid(self._T.invincibleEffectSerial) then
					_EffectService:RemoveEffect(self._T.invincibleEffectSerial)
				end
				self.isInvincible = false
			end
		end
		
		
		self:CheckHpCondition()
		
		if self.burnTime >= 0 then
			self.burnTime = self.burnTime - delta
		else
			if self.burnTime ~= -3 then
				self.burnTime = -3
				self:TurnOffBurn()
			end
		end
		
	end

	method void Dash()
		-- 대시 스킬 사용 (스태미나 소모, 무적 상태, 넘백 효과)
		if self.stamina < self.needDashStamina then
			return
		end
		
		if self.Entity.KinematicbodyComponent.MoveVelocity:Magnitude() == 0 then
			return
		end
		
		
		if not self.Entity.PlayerControllerComponent.Enable then return end
		
		self._T.lastDashTime = _UtilLogic.ElapsedSeconds
		
		local option = { ["FlipX"] = true, ["PlayRate"] = 2 }
		local moveDelta = self.Entity.KinematicbodyComponent.MoveVelocity:Normalize() * 3 * 1.5
		self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(3 * 1.5)
		local duration =  0.06
		if self:IsEnableSuperDash() then
			moveDelta = moveDelta * self:GetSuperDashSpeed()
			self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(3 * 1.5 * 2)
		end
		local lookDirection = self.Entity.PlayerControllerComponent.LookDirectionX
		
		if lookDirection < 0 then
			option.FlipX = false
		else
			option.FlipX = true
		end
		
		if moveDelta.x < 0 then
			option.FlipX = false
		end
		
		_EffectService:PlayEffectAttached("d78c0195e5b9452fbc01aef903ff590a",self.Entity,Vector3.zero,0,Vector3.one, false, option)
		self:ApplyInvincible(0.3)
		self.isDashingNow = true
		self.stamina = self.stamina - self.needDashStamina
		
		self.Entity.PlayerControllerComponent.Enable = false
		self.Entity.KinematicbodyComponent.MoveVelocity = moveDelta
		
		_TimerLogic:SetTimerOnce(function()
				self.Entity.PlayerControllerComponent.Enable = true
			
				local overlaps = self:GetOverlaps(tostring(CollisionGroups.PlayerSkill), self._T.transform.WorldPosition:ToVector2(), 4.5)
				local pos = self._T.transform.Position:ToVector2()
				for _, trigger in pairs(overlaps) do
					---@type Entity
					local entity = trigger.Entity
					
					if isvalid(entity.MonsterObject) then
						local monster = entity.MonsterObject
						local diff = monster:GetPositionVec2() - pos
						local dist = math.max(1, Vector2.Magnitude(diff))
						local force = diff:Normalize() * 60
					
						monster:SetKnockback(force, 0.02, true)
					end
				end
		end, 0.2, "BattlePlayer.Dash_knockback")
		
		_TimerLogic:SetTimerOnce(function()
				self.isDashingNow = false 
				self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(1)
				local animEvent = BodyActionStateChangeEvent()
				animEvent.needResetAction = true
				animEvent.ActionState = MapleAvatarBodyActionState.Walk
				self.Entity:SendEvent(animEvent)
		end, 0.3, "BattlePlayer.Dash_actionInit")
		
		local animEvent = BodyActionStateChangeEvent()
		animEvent.needResetAction = true
		animEvent.ActionState = MapleAvatarBodyActionState.Fly
		self.Entity:SendEvent(animEvent)
		self.usedDashCount += 1
		
		
		
		
		_TimerLogic:SetTimerOnce(function()
				_EffectService:PlayEffectAttached("e95dc8def28745c8b8d436ccbfb4c949",self.Entity,Vector3.zero,0,Vector3.one * 1.5)
			end, duration, "BattlePlayer.Dash_PlayerEffect")
		
		if _BuffLogic.appliedBuff.trickery then
			self:UntargetedDash()
			_TimerLogic:SetTimerOnce(function()
					self:SetTargetAfterDash()
				end, 2, "BattlePlayer.Dash_trickeryReset")
		end
		
		
		self.Entity:SendEvent(UseDashEvent())
	end

	@ExecSpace("ClientOnly")
	method void LevelUp(boolean notLevelUp)
		-- 레벨업 시 버프 선택 UI 표시 및 처리
		if _UserService.LocalPlayer.CurrentMapName == "Town" then return end
		if isvalid(_UserService.LocalPlayer.CurrentMap.RandomBossMapComponent) then return end
		if self.isDead then return end
		
		_BattleUIManager.levelUpPopup:Show(self.lv,
			function(itemName,selectedWeaponKey,cardCount) 
				if _UtilLogic:IsNilorEmptyString(itemName) or itemName == "" then
						return
				end
				self.Entity:SendEvent(LevelUpBuff(itemName,selectedWeaponKey))
				self:PlayLevelUpEff()
				if not isvalid(notLevelUp) or notLevelUp == false then 
					self.exp = self.exp - self:GetMaxEXP(self.lv)
					self.lv = self.lv + 1
					self.Entity:SendEvent(BattlePlayerInfoChange(self.exp, self.lv))
					
					if self.exp > self:GetMaxEXP(self.lv) then
						_TimerService:SetTimerOnce(function()
							if _BattleUIManager.levelUpPopup.isShow then return end
							self:LevelUp(false)
						end, 0.01)
					end
					
					if self.lv >= 2 then 
						if self.bonusLvUpHeal then 
							_TimerLogic:SetTimerOnce(function()
								if isvalid(self) then
									self:SetHP(math.min(self.maxHp, self.hp + self.maxHp * 0.01))
									_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage6"), "pos")
								end
							end, 0.06, "BattlePlayer.LevelUp.RecoveryHpFromCharacteristic")
						end
						_ArmorSkillLogic:ExcuteChickenSuit(self.Entity) 
						self.selectedBuffCount += 1
					end
				end
				
				
				if itemName == "weapon" then
					for i = 1,cardCount do
						self:AddWeapon(selectedWeaponKey)
					end
				else
					local itemId = tonumber(itemName)
					_BuffLogic:ApplyBuff(itemName)
					_BuffLogic.selectedCard[self._T.cardIndex] = itemName
					self._T.cardIndex += 1
				end
		end)
		
		
	end

	method void RefreshEXP()
		-- 경험치 정보 UI 업데이트 이벤트 발송
		local maxExp = self:GetMaxEXP(self.lv)
		
		self.Entity:SendEvent(BattlePlayerInfoChange(self.exp, self.lv))
	end

	method number GetMaxEXP(number lv)
		-- 레벨별 최대 경험치 계산 (캐시 사용)
		local cacheTable = self._T.maxExpCache
		if cacheTable == nil then
			return 0
		end
		if cacheTable[lv] then
		
			return cacheTable[lv]
		end
		
		local maxLV = _GameConfig:GetConfig().MAX_INGAME_LV
		local progress = lv / maxLV
		local factor = 0.6
		local scaledProgress = progress ^ factor
		
		local needExp = scaledProgress / (scaledProgress + (1 - progress) ^ factor) * _GameConfig:GetConfig().INGAME_MAX_EXP_RATIO
		
		cacheTable[lv] = needExp
		
		return needExp 
	end

	method void SetDamage(number damage, Vector2 knockback, number criticalRate, number criticalRatio, string attackType, Entity target)
		-- 플레이어 피해 처리 (무적, 실드, 넘백 등 고려)
		if self.Entity.CurrentMap.BattleMap.isAppearingBoss then return end 
		
		self._T.hitCount = self._T.hitCount + 1
		
		
		if self.isDead then 
			return
		end
		
		if self.isInvincible or self.isSuperMode then 
			return 
		
		end
		
		if self.shieldCount >= 1 and attackType ~= "debuff" then 
			self:SetKnockback(knockback,0.2)
			self:DestroyShield()
			return
		end
		
		self._T.noneHitTime = 0 
		
		local hitRatio = _BuffLogic:GetHitDamage() 
		
		if hitRatio ~= 0 then
			damage = damage * hitRatio
		end
		
		self._T.lastDamageTime = _UtilLogic.ServerElapsedSeconds
		
		if attackType ~= "debuff" then
			self:ApplyInvincible(self.unDamagedTime)
		end
		
		local rand = _UtilLogic:RandomIntegerRange(1, 10000)
		local evade = _BuffLogic:GetEvade() * 10000
		
		if rand < evade and attackType ~= "debuff" then 
			_DamageSkinService:PlayTextDamage(self.Entity, "0b719292f10f412bb7a07191e1f01a0e", DamageSkinTextType.Miss, DamageSkinTweenType.Default, Vector2.zero)
			return
		end
		
		local calcDamage = damage
		local isCritical = _UtilLogic:RandomDouble() < criticalRate
		
		if isCritical then
			calcDamage = damage * criticalRatio
		end
		
		if isvalid(target) then
			if isvalid(target.MonsterObject) then	
				if target.MonsterObject.isBoss then
					calcDamage = _ArmorSkillLogic:ExcuteMartialSuit(self.Entity, calcDamage)
				end
			elseif isvalid(target.SkillEffectObject) then
				if target.SkillEffectObject.isBossSkill then
					calcDamage = _ArmorSkillLogic:ExcuteMartialSuit(self.Entity, calcDamage)
				end
			end
		end
		
		
		if attackType == "melee" then
			calcDamage = calcDamage + (calcDamage * _BuffLogic:GetReductMeleeDamage()) 
		
		elseif attackType == "projectile" then
			calcDamage = calcDamage + (calcDamage * _BuffLogic:GetReductProjectileDamage()) 
		end
		
		if calcDamage == 0 then
		end
		self:SetHP(self.hp - calcDamage) 
		
		_DamageSkinService:Play(self.Entity,"0b719292f10f412bb7a07191e1f01a0e",0,{math.floor(calcDamage)},DamageSkinTweenType.Default,isCritical)
		
		if self.hp <= 0 then 
		
			if self.usedRebornByAngelSuit > 0 then 
				self.usedRebornByAngelSuit = self.usedRebornByAngelSuit - 1
		
				self:ClearTimerCauseDie()
				self:ForceOffInvincible()
				self:ApplyInvincible(5)
				self.Entity.StateComponent:ChangeState("DEAD")
				self.Entity.PlayerControllerComponent.Enable = false
				
		
				local reborn = function()
					local regenRate = 0
					local str = ""
					
					if _BuffLogic.appliedBuff.helmetAngelLevel == 1 then
						str = string.format(_LocalizeLogic:GetText("systemMessage2"), _LocalizeLogic:GetText("Helmet_Angel"))
					
						_SystemMessageLogic:ShowMessage(str, "equ")
						_EffectService:PlayEffectAttached("64b8f9ee7c4f43ef98f77296c4ef145b", self.Entity, Vector3.zero, 0, Vector3(2,2,2), false)
						regenRate = 0.1
					elseif _BuffLogic.appliedBuff.helmetAngelLevel == 2 then
						str = string.format(_LocalizeLogic:GetText("systemMessage3"), _LocalizeLogic:GetText("Helmet_Angel"))
						_EffectService:PlayEffectAttached("c6f54657879448b496daecc8a15c2918", self.Entity, Vector3.zero, 0, Vector3(2,2,2), false)
						
						_SystemMessageLogic:ShowMessage(str, "equ")
						regenRate = 0.25
					elseif _BuffLogic.appliedBuff.helmetAngelLevel == 3 then
						str = string.format(_LocalizeLogic:GetText("systemMessage4"), _LocalizeLogic:GetText("Helmet_Angel"))
						_EffectService:PlayEffectAttached("c6f54657879448b496daecc8a15c2918", self.Entity, Vector3.zero, 0, Vector3(2,2,2), false)
						
						_SystemMessageLogic:ShowMessage(str, "equ")
						regenRate = 0.5
					end
		
					self:SetHP(self.maxHp * regenRate)
		
					self.isDead = false
					self.Entity.StateComponent:ChangeState("IDLE")
					
					self.Entity.PlayerControllerComponent.Enable = true
					
					
				end
				
				_TimerLogic:SetTimerOnce(reborn, 2, "BattlePlayer.SetDamage_reborn")
				return
			end
			
			if _BuffLogic.originalStat.poisonedChalice then 
				self:ClearTimerCauseDie()
				_BuffLogic:ResurrectByChalice()
				
				return
			end
			
		
			if _BuffLogic.originalStat.sacrifice and isvalid(self.equipGun) and #table.keys(self.equipGun) >= 1 then 
				rand = _UtilLogic:RandomIntegerRange(1, #self.equipGun)
				for key, value in pairs(self.equipGun) do
					if key == rand then
						if isvalid(value.gun) then
							if isvalid(value.gun.BattleGunObject) then
								value.gun.BattleGunObject:ClearTimer()
							end
							value.gun:Destroy()
							table.remove(self.equipGun, key)
							
							self:ApplyInvincible(3)
							local str = string.format(_LocalizeLogic:GetText("systemMessage5"), _LocalizationService.LocalTranslator:GetText(_WeaponSpecLogic.weaponData[value.id].type))
							_SystemMessageLogic:ShowMessage(str, "pos")
							_BattleUIManager.playerWeaponPanel.PlayerWeaponStatusUIComponent:Init()
							_BattleUIManager.levelUpPopup.playerWeaponPanel.PlayerWeaponStatusUIComponent:Init()
							_BattleUIManager.playerWeaponPanel.PlayerWeaponStatusUIComponent:Refresh()
							_BattleUIManager.levelUpPopup.playerWeaponPanel.PlayerWeaponStatusUIComponent:Refresh()
						end
		
						break
					end
				end
				
				self:SetHP(1)
				self.Entity:SendEvent(BattlePlayerHPChange(self.hp,self.maxHp))
				
				
				return
			end
		
			self:ClearTimerCauseDie()
		
			
			_TimerLogic:Pause()
			
			if _UserService.LocalPlayer.PlayerStorageComponent:ShowResurrectPopUp() then 
				return
			end
			self:Dead(false)
			return
		end
		
		
		local animEvent = BodyActionStateChangeEvent()
		animEvent.needResetAction = true
		animEvent.ActionState = MapleAvatarBodyActionState.Hit
		self.Entity:SendEvent(animEvent)
		
		self.Entity:SendEvent(PlayerHitEvent(damage))
		self.hitCountForLog = self.hitCountForLog + 1
		
		self:SetKnockback(knockback, 0.2)
	end

	method void SetKnockback(Vector2 knockback, number time)
		-- 플레이어 넘백 효과 적용 및 일시적 조작 비활성화
		if Vector2.Magnitude(knockback) > 0 then
			self.Entity.PlayerControllerComponent.Enable = false
			
			_Tweener:PlayTween(1,0,0.2,0,EaseType.BounceEaseIn,
				function(value) 
					self.Entity.KinematicbodyComponent.MoveVelocity = knockback * value
				end,
				function() 
					self.Entity.PlayerControllerComponent.Enable = true
				end, "BattlePlayer_SetKnockback")
		end
		
	end

	@ExecSpace("Client")
	method void Dead(boolean forceDead)
		-- 플레이어 사망 처리 및 결과 UI 표시
		if not forceDead and self.isInvincible and self.hp > 0 then return end
		if self.isDead then return end
		
		_UserService.LocalPlayer:SendEvent(BattlePlayerDeadEvent())
		
		self:SetHP(0)
		self.isDead = true
		
		self.Entity.StateComponent:ChangeState("DEAD")
		self.Entity.PlayerControllerComponent.Enable = false
		
		for key, value in pairs(self.equipGun) do
			self:UnequipGun(key)
		end
		
		self.willReturnTown = true
		if self:IsClient() then
			_SuddenMissionLogic:CheckMissionClear()
		end
		
		
		_TimerService:SetTimerOnce(function()
				self:OnEndBattle(false)
			end, 5)
	end

	@ExecSpace("ClientOnly")
	method void OnEndBattle(boolean clear)
		-- 배틀 종료 처리 및 일일 미션 업데이트
		if self.clearedTime + 5 > _UtilLogic.ServerElapsedSeconds then
			
			return
		end
		
		self.willReturnTown = true
		for k,v in pairs(self._T.shield) do
			v:Destroy()
		end
		table.clear(self._T.shield)
		
		_StageLogic.isInPlay = false
		
		
		_BattleUIManager:InitTimer()
		_BattleUIManager.bossInfo.Enable = false
		
		local battleMap = self.Entity.CurrentMap.BattleMap
		
		if isvalid(battleMap) == false then
			return
		else
			if battleMap.isEnd then
				return
			end
		end
		local wave = battleMap.wave
		
		
		local myPlayer = _UserService.LocalPlayer.MyPlayer
		
		if not clear then
			if isvalid(myPlayer.failCount[battleMap.chapter]) then
				myPlayer.failCount[battleMap.chapter] += 1
			else
				myPlayer.failCount[battleMap.chapter] = 1
			end
		end
		
		myPlayer.lastBattleMapChapter = battleMap.chapter
		myPlayer.isClearedBattleMap = clear
		myPlayer.previousGameMode = _GameSettingLogic.mode
		
		_UserService.LocalPlayer:SendEvent(BattleChapterEnd(clear,wave))
		
		local dailyMissionCompo = self.Entity.PlayerDailyMissionComponent
		
		dailyMissionCompo:SendMissionUpdateEventInServer("useDash", "", self.usedDashCount)
		dailyMissionCompo:SendMissionUpdateEventInServer("useSoulBoom", "", self.usedSoulBoomCount)
		dailyMissionCompo:SendMissionUpdateEventInServer("selectBuff", "", self.selectedBuffCount)
		for key, value in pairs(_DPSLogic.attackCount) do
			self.monsterAttackCount += value
		end
		dailyMissionCompo:SendMissionUpdateEventInServer("attackMonster", "", self.monsterAttackCount)
		
		if battleMap.stageData.step >= self.Entity.PlayerInfoComponent.minRecommendStage then
			for key, value in pairs(_MonsterLogic.killedMonsters) do
				dailyMissionCompo:SendMissionUpdateEventInServer("killMonster", key, value)
			end
		end
		
		for key, value in pairs(_MonsterLogic.killedMonsters) do
			dailyMissionCompo:SendMissionUpdateEventInServer("killSelectedMonster", key, value)
		end
		
		dailyMissionCompo:SendMissionUpdateEventInServer("lootPotion", "", self.lootedPotionCount)
		dailyMissionCompo:SendMissionUpdateEventInServer("killFlyingMonster", tostring(battleMap.stageData.step), self.killedWaveMonsterCount)
		dailyMissionCompo:SendMissionUpdateEventInServer("destroyOrb", "", self.destroyedOrbCount)
		
		self.usedDashCount = 0 
		self.usedSoulBoomCount = 0
		self.selectedBuffCount = 0
		self.monsterAttackCount = 0
		self.lootedPotionCount = 0
		self.killedWaveMonsterCount = 0
		self.destroyedOrbCount = 0
	end

	@ExecSpace("Server")
	method void MoveTown(string flowType, string limitLandWave)
		-- 마을로 이동 및 플레이어 상태 초기화
		_StageLogic.isInPlay = false
		self.Entity.PlayerComponent:Respawn()
		_TeleportService:TeleportToEntity(self.Entity,_GameUtil.townMap)
		self.Entity.KinematicbodyComponent:SetPosition(Vector2(_UtilLogic:RandomIntegerRange(-20, 20) / 10, _UtilLogic:RandomIntegerRange(-20, 20) / 10))
		self.Entity.PlayerDropsComponent:Init()
		self:OffLevelUpPopup(self.Entity.PlayerComponent.UserId)
		_DecorationLogic:LoadOtherUsersDecoration(self.Entity.PlayerComponent.UserId)
		self.Entity.MyPlayer.currentStage = limitLandWave
		
		_WorldLog:LogPlayFlow(senderUserId,flowType,"")
	end

	method void SetHP(number hp)
		-- 플레이어 체력 설정 (실드 스이트 효과 고려)
		if _BuffLogic.appliedBuff.suitShieldLevel >= 1 then
			if hp > self.maxHp then 
				local addGauge  = hp - self.maxHp
				self:SetShieldGauge(self.shieldGauge + addGauge) 
				local str = string.format(_LocalizeLogic:GetText("systemMessage13"), _LocalizationService:GetText("Suit_Shield"))
				
				_SystemMessageLogic:ShowMessage(str, "equ")
		
			end
			if hp < self.hp and self.shieldGauge > 0 then  
				local damage = self.hp - hp
				if damage > self.shieldGauge then
					hp = hp + self.shieldGauge
					self:SetShieldGauge(0)
				else 
		
					self:SetShieldGauge(self.shieldGauge - damage)
					hp = self.hp
				end
				self:PlayShieldSuitKnockback() 
			end
		
		end
		
		hp = math.min(self.maxHp,hp)
		
		if hp < 0 then
			hp = 0
		end
		
		self.hp = hp
		self.Entity:SendEvent(BattlePlayerHPChange(self.hp,self.maxHp))
	end

	method void SetMaxHP(number maxHP)
		-- 플레이어 최대 체력 설정
		self.maxHp = maxHP
		
		
	end

	method void SetTargetAfterDash()
		-- 대시 후 모든 몬스터의 타겟을 플레이어로 재설정
		local curentMap = self.Entity.CurrentMap
		local monsters = curentMap:GetChildComponentsByTypeName("MonsterObject")
		
		for key, monster in pairs(monsters) do
			monster:SetTarget(_UserService.LocalPlayer)
		end
	end

	method void IncreaseStamina(number amount)
		-- 스태미나 증가 (최대치 제한)
		self.stamina = self.stamina + amount
		
		if self.stamina > self.maxStamina then
			self.stamina = self.maxStamina
		end
	end

	@ExecSpace("ClientOnly")
	method void AddWeapon(string uniqueKey)
		-- 무기 추가 (랜덤 또는 지정된 무기)
		if _UtilLogic:IsNilorEmptyString(uniqueKey) then
			local guns = {}
			if self._T.equipedWeapon ~= nil and  #self._T.equipedWeapon > 0 then
				table.clear(guns)
				for k,v in pairs(self._T.equipedWeapon) do
					local found = false
					
					for key, value in pairs(self.equipGun) do 
						if value.gun.BattleGunObject.uniqueKey == v.uniqueKey then
							found = true
							break
						end
					end
					
					if not found then
						table.insert(guns,v)
					end
				end
			end	
			
			if #guns > 0 then
				local rand = _UtilLogic:RandomIntegerRange(1,#guns)
		
				self:EquipGun(#self.equipGun + 1,guns[rand].originalId, guns[rand].uniqueKey,false)
			end
		else
			self:EquipGun(#self.equipGun + 1, _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId, uniqueKey,false)
		end
	end

	method integer GetEquippedWeaponCount()
		-- 장착된 무기 개수 반환
		if not isvalid(self._T.equipedWeapon) then
			return 0
		end
		
		
		return #self._T.equipedWeapon
		
	end

	method void RecoverHp()
		-- 체력 회복 버프 적용 및 메시지 표시
		if isvalid(self) and _BuffLogic.appliedBuff.hpRecovery > 0 then
			local str = string.format(_LocalizeLogic:GetText("systemMessage15"), _BuffLogic.appliedBuff.hpRecovery)
			_SystemMessageLogic:ShowMessage(str, "pos")
			
			self:SetHP(self.hp + self.maxHp * (_BuffLogic.appliedBuff.hpRecovery / 100))
			if self.hp > self.maxHp then
				self:SetHP(self.maxHp)
			end
		end
	end

	@ExecSpace("Client")
	method void Absorb()
		-- 흡수 버프로 체력 회복 및 메시지 표시
		if self.hp >= self.maxHp then return end
		
		local ratio = _BuffLogic:GetAbsorption() / 100
		
		if isvalid(self) then
			self:SetHP(self.hp + self.maxHp * ratio)
			_SystemMessageLogic:ShowMessage(string.format(_LocalizeLogic:GetText("systemMessage18"), ratio * 100), "pos")
			if self.hp > self.maxHp then
				self:SetHP(self.maxHp)
			end
		end
	end

	method void SetMonsterKonckbackRange(Vector2 currentPosToVector2, number range, number force, number duration)
		-- 지정된 범위 내 모든 몬스터에게 넘백 효과 적용
		
		
		local simulator = _CollisionService:GetSimulator(self.Entity)
		local overlaps = simulator:OverlapCircleAll(tostring(CollisionGroups.PlayerSkill), currentPosToVector2, range)
			
		for i = 1, #overlaps do
			local entity = overlaps[i].Entity
			local monster = entity.MonsterObject
			if monster ~= nil then
				local isCritical = false
				local diff = monster:GetPositionVec2() - currentPosToVector2
				diff:Normalize()
				monster:SetKnockback(diff * force,duration,true)
		
			end
		end
	end

	method void SpawnSticky()
		-- 슬라임 신발 효과로 주변에 끈적한 오브젝트 생성
		local numObjectsToSpawn = 8
		local lifeTime = 7
		local spawnRadius = 3
		local playerPosition = self._T.transform.Position:Clone()
		
		local lv =  _BuffLogic.appliedBuff.shoesSlimeLevel
		
		if lv == 1 then
			
		elseif lv == 2 then	
			numObjectsToSpawn = 16
		elseif lv == 3 then
			numObjectsToSpawn = 32
		end
		
		for i = 1 , numObjectsToSpawn do
			
		 	local angle = (math.pi * 2 / numObjectsToSpawn) * i
			
		    local xOffset = math.cos(angle) * spawnRadius
		    local yOffset = math.sin(angle) * spawnRadius
		
		    local spawnX = playerPosition.x + xOffset
		    local spawnY = playerPosition.y + yOffset
			
			local sticky = _PoolingLogic:SpawnModel("model://95a63f5d-2fd2-4e6d-bf84-42745b0adbb2", Vector3(spawnX, spawnY, 0), self.Entity.Parent)
			sticky.SpriteRendererComponent.Color.a = _OptionLogic.myEffectTransparency
			sticky.StickyComponent:Init(lifeTime)
		end
		
	end

	method void SpawnMine()
		-- 폭탄 신발 효과로 지뢰 오브젝트 생성
		if _WaveLogic:GetAverageWave() == false then return end
		
		local targetDistance = 8
		local rate = 0
		
		if _BuffLogic.appliedBuff.shoesBombLevel >= 1 then	
			rate = 0.3
			if _BuffLogic.appliedBuff.shoesBombLevel >= 3 then
				rate = 0.6
			end
		end
		
		local currentPos = self._T.transform.Position:Clone()
		
		self._T.stickySpawnedPos = currentPos
		local mine = _PoolingLogic:SpawnModel("model://2ddfaaa8-8a11-4dca-84c5-ecc5a845926a", currentPos, self.Entity.Parent)
		mine.SpriteRendererComponent.Color.a = _OptionLogic.myEffectTransparency
		mine.MineComponent:Init()
		
		local waveData = _WaveLogic.chapterData[_WaveLogic.currentChapter]
		local averageMonster = _WaveLogic:GetAverageWave().monster
		local hp = 0
		
		if isvalid(_MonsterLogic.monsterData[averageMonster]) then
			hp = _MonsterLogic.monsterData[averageMonster].hp
		else
			hp = averageMonster.hp
		end
		
		mine.MineComponent:SetDamage(hp * rate)
	end

	method void ApplyInvincible(number duration)
		-- 무적 상태 적용 및 이팩트 재생
		if duration < self._T.leftInvincibleTime then return end 
		if self.Entity ~= _UserService.LocalPlayer then return end
		
		self._T.leftInvincibleTime = duration
		
		if self._T.invincibleEffectSerial ~= nil then
			_EffectService:RemoveEffect(self._T.invincibleEffectSerial)
			self._T.invincibleEffectSerial = nil
		end
		
		if duration > 1 then
			self._T.invincibleEffectSerial = _EffectService:PlayEffectAttached("cc89658b5e734441b2b209a70cb96767", self.Entity, Vector3.zero, 0, Vector3.one, true)
		end
		
		self.isInvincible = true
	end

	method void ApplyOvercome()
		-- 극복 버프 적용 (20초 후 최대 체력 30% 증가)
		_TimerLogic:ClearTimer(self.overcomeTimer)
		
		
		self.activateOvercome = true
		self._T.overComeTimers = {}
		
		for i = 1, 19 do
			table.insert(self._T.overComeTimers, _TimerLogic:SetTimerOnce(function()
				_SystemMessageLogic:ShowMessage(string.format(_LocalizeLogic:GetText("systemMessage20"), 20 - i), "tim")
				end, i - 1, "BattlePlayer.ApplyOvercome_countMessage")
				)
		end
		
		self.overcomeTimer = _TimerLogic:SetTimerOnce(function()
				if self.isDead then return end
				_BuffLogic.appliedBuff.maxHp = _BuffLogic.appliedBuff.maxHp + 0.3
				self.maxHp = _BuffLogic:GetMaxHp()
				self:SetHP(_BuffLogic:GetMaxHp())
				self.activateOvercome = false
				self.Entity:SendEvent(ChangeMaxHpEvent())
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage21"), "pos")
			end, 20, "BattlePlayer.ApplyOvercome_resultMessage")
	end

	method void ApplyReflect()
		-- 반사 버프 적용 (40초 지속)
		self.appliedReflect = true
		_TimerLogic:SetTimerOnce(function()
				if isvalid(self) then
					self.appliedReflect = false
				end
			end, 40, "BattlePlayer.ApplyReflect_reset")
	end

	@ExecSpace("ClientOnly")
	method void AddKillCount()
		-- 몬스터 처치 카운트 증가 및 관련 버프 처리
		self.killCount = self.killCount + 1
		
		_ArmorSkillLogic:ExcuteSharkHelmet(self.Entity)
		if self.killCount % 10 == 0 then
			if _BuffLogic.appliedBuff.ecstasy and _BuffLogic.ecstasyCount < 200 then 
				_BuffLogic.appliedBuff.attackSpeed = _BuffLogic.appliedBuff.attackSpeed + 0.01
				_BuffLogic.ecstasyCount += 1
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage19"), "pos")
				self.Entity:SendEvent(ChangeAttackSpeedEvent())
				_BuffLogic:SendEvent(ApplyBuffEvent("100022"))
			end
		end
	end

	method void ApplyShield()
		-- 실드 버프 적용 및 이팩트 재생
		if _BuffLogic.appliedBuff.shield <= 0 then return end
		if self.shieldCount >= 1 then return end
		
		self.shieldCount = 1
		self.appliedShield = true
		self._T.shieldEffect = _EffectService:PlayEffectAttached("9dfbeeb17b8349dfaa6b66fdb01a110b", self.Entity, Vector3(0, 1, 0), 0, Vector3.one, true)
		
		_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage22"), "pos")
	end

	method void DestroyShield()
		-- 실드 파괴 시 넘백 효과 및 추가 데미지 처리
		if _BuffLogic.appliedBuff.shield <= 0 then return end
		
		_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage24"), "pos")
		self:SetMonsterKonckbackRange(self:GetPositionVec2(), 6.5, 20, 0)
		_EffectService:RemoveEffect(self._T.shieldEffect)
		self.shieldCount = 0
		
		if _BuffLogic.appliedBuff.shield > 1 then
			
			local simulator = _CollisionService:GetSimulator(self.Entity)
			local transform = self._T.transform
			_EffectService:PlayEffect("005e8b598bbe4800ae20ce7ca467e89f", self.Entity, self._T.transform.Position, 0, Vector3.one * 2)
			
			local overlaps = simulator:OverlapCircleAll(tostring(CollisionGroups.PlayerSkill), transform.WorldPosition:ToVector2(), 0.7)
			
			for i = 1, #overlaps do
				local entity = overlaps[i].Entity
				if isvalid(entity.MonsterObject) then
					entity.MonsterObject:SetDamage(entity.MonsterObject:GetMaxHp()/3., Vector2.one, false, "Shield")
				end
			end
		end
	end

	method table GetEquipPossibleGuns()
		-- 장착 가능한 무기 목록 반환 (최대 레벨 제외)
		local guns = {}
		local weaponCardMaxLV = _GameConfig:GetConfig().WEAPONCARD_LV_MAX
		
		if self._T.equipedWeapon ~= nil and  #self._T.equipedWeapon > 0 then
			table.clear(guns)
			for k,v in pairs(self._T.equipedWeapon) do
				local found = false
				
				for key, value in pairs(self.equipGun) do 
					---@type BattleGunObject
					local battleGun = value.gun.BattleGunObject			
					if battleGun.cardLevel == weaponCardMaxLV and battleGun.uniqueKey == v.uniqueKey then
						found = true
						break
					end
				end
				
				if not found then
					table.insert(guns,v)
				end
			end
		end	
		_GameUtil:ShuffleTable(guns)
		
		return guns
	end

	@ExecSpace("Client")
	method void OffLevelUpPopup()
		-- 레벨업 팝업 UI 비활성화
		_BattleUIManager.levelUpPopup:Hide("", 1,1)
		
		
	end

	@ExecSpace("ClientOnly")
	method void DestroyPets()
		-- 모든 펫 엔티티 파괴 및 목록 정리
		for _, entity in pairs(self.pets) do
			entity:Destroy()
		end
		
		table.clear(self.pets)
	end

	@ExecSpace("Client")
	method void ApplyBurnEffect(number damage, number duration)
		-- 화상 효과 적용 및 지속 데미지 처리
		if self.burnTime <= -3 then
			self.burnTime = duration
		elseif self.burnTime <= duration then
			self.burnTime = duration
		end
		
		if self._T.burnEffect == nil then
			self._T.burnEffect = _EffectService:PlayEffectAttached("8778c55a35134503a0bae82de379b0f0",self.Entity,Vector3.zero,0,Vector3(0.2,0.7,0),true)
			
		end
		
		if self._T.burnTimer == 0 then
			local burn = function()
				self:SetDamage(damage,Vector2.zero,0,1,"skill", self.Entity)
			end
			self._T.burnTimer = _TimerLogic:SetTimerRepeat(burn,0.3,0.3, "BattlePlayer.ApplyBurnEffect")
		end
	end

	@ExecSpace("Client")
	method void TurnOffBurn()
		-- 화상 효과 종료 및 타이머 정리
		if isvalid(self.Entity) then
			_TimerLogic:ClearTimer(self._T.burnTimer)
			self._T.burnTimer = 0
			_EffectService:RemoveEffect(self._T.burnEffect)
			
			self._T.burnEffect = nil
		end
	end

	method void UntargetedDash()
		-- 모든 몬스터의 타겟을 제거 (대시 시 은신 효과)
		local curentMap = self.Entity.CurrentMap
		local monsters = curentMap:GetChildComponentsByTypeName("MonsterObject")
		
		for key, monster in pairs(monsters) do
			monster:SetTarget(nil)
		end
	end

	method void ApplyMeditation()
		-- 명상 버프 적용 (현재 빈 구현)
		
	end

	method void AddShield()
		-- 회전하는 실드 오브젝트 추가 및 배치
		local shield = _SpawnService:SpawnByModelId("model://5bc47a17-3c16-4dd7-9199-79d252678020","shield",Vector3.zero,self.Entity)
		table.insert(self._T.shield,shield)
		local shieldCnt = #self._T.shield
		local eachAngle = 360 / shieldCnt
		for k,v in pairs(self._T.shield) do
			v.ShieldObject.angleOffset = k * eachAngle
		end
		
		
		_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage16"), "pos")
	end

	method void EvolutionWeapon()
		-- 랜덤 무기 하나를 다음 단계로 진화
		local random = {}
		for i = 1, #self.equipGun do
			table.insert(random,i)
		end
		_GameUtil:ShuffleTable(random)
		
		for i = 1, #random do
			local rand = random[i]
			local weaponId = self.equipGun[rand].id
			local uniqueKey = self.equipGun[rand].uniqueKey
			local itemData = _ItemDataLogic.equipmentData[weaponId]
			local nextWeaponId = itemData.nextEquipment
			if _UtilLogic:IsNilorEmptyString(nextWeaponId) == false then
				self:UnequipGun(rand)
				self:EquipGun(rand,nextWeaponId,uniqueKey,false)
				return
			end	
		end
		
		_UIToast:ShowMessage(_LocalizeLogic:GetText("toast10"))
	end

	method void EvolutionWeaponsAll()
		-- 모든 무기를 최종 단계로 진화
		for index = 1, #self.equipGun do
			local weaponId = self.equipGun[index].id
			local uniqueKey = self.equipGun[index].uniqueKey
			local itemData = _ItemDataLogic.equipmentData[weaponId]
			local nextWeaponId = itemData.nextEquipment
			while not _UtilLogic:IsNilorEmptyString(nextWeaponId) do
				itemData = _ItemDataLogic.equipmentData[nextWeaponId]
				nextWeaponId = itemData.nextEquipment
			end
			
			self:UnequipGun(index)
			self:EquipGun(index,itemData.id,uniqueKey,false)
		end
	end

	method void AddReplica()
		-- 랜덤 무기의 복제본 추가
		local rand = _UtilLogic:RandomIntegerRange(1,#self.equipGun)
		local weaponId = self.equipGun[rand].id
		local uniqueKey = self.equipGun[rand].uniqueKey
		local slot = #self.equipGun + 1
		self:EquipGun(slot,weaponId,uniqueKey,false)
		self.equipGun[slot].gun.BattleGunObject:SetReplica()
	end

	method void DisassembleWeapon()
		-- 랜덤 무기 하나를 이전 단계로 분해
		local random = {}
		for i = 1, #self.equipGun do
			table.insert(random,i)
		end
		_GameUtil:ShuffleTable(random)
		
		for i = 1, #random do
			local rand = random[i]
			local weaponId = _ItemDataLogic.equipmentData[self.equipGun[rand].id].previousEquipment	
			if _UtilLogic:IsNilorEmptyString(weaponId) == false then
				local uniqueKey = self.equipGun[rand].uniqueKey
				self:UnequipGun(rand)
		
				self:EquipGun(rand,weaponId,uniqueKey,false) 
				self:EquipGun(#self.equipGun+1,weaponId,uniqueKey,false) 
				return
			end	
		end
		
		_UIToast:ShowMessage(_LocalizeLogic:GetText("toast11"))
		
	end

	method void RefreshWeaponAngle()
		-- 무기 개수에 따른 각도 간격 재설정
		local weaponCnt = #self.equipGun
		if weaponCnt < 12 then
			weaponCnt = 12
		end
		local eachAngle = 360/weaponCnt
		for k,v in pairs(self.equipGun) do
			v.gun.BattleGunObject.slotAngle = eachAngle 
		end
	end

	method void ShuffleAllWeapon()
		-- 모든 무기 제거 후 랜덤으로 재장착
		local slot = #self.equipGun
		for i = 1, slot do
			self:UnequipGun(i)
		end
		
		for i = 1, slot do
			self:AddWeapon("")
		end
	end

	method Vector3 GetPosition()
		-- 플레이어의 3D 위치 반환
		if self._T.transform == nil then
			self._T.transform = self.Entity.TransformComponent
		end
		return self._T.transform.Position
	end

	method Vector2 GetPositionVec2()
		-- 플레이어의 2D 위치 반환
		return self._T.positionVec2
	end

	@ExecSpace("ClientOnly")
	method void SpawnPets()
		-- 장착된 펫들을 타입별로 생성 및 배치
		local petStorage = self.Entity.PlayerPetStorageComponent
		
		
		local offsetX = 0.4
		
		for key, value in pairs(petStorage.petInventory) do
			if value.equippedSlotNum > 0 then
				local petData = _PetLogic.petData[value.originalId]
				---@type Entity
				local pet = nil
				
				if petData.petType == "CollectingPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_CollectingPet"), "CollectingPet", Vector3(offsetX, -0.1, 0), self.Entity)
				elseif petData.petType == "DiggingPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_DiggingPet"), "DiggingPet", self._T.transform.Position + Vector3(offsetX, -0.1, 0), self.Entity.Parent)
				elseif petData.petType == "GatheringPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_GatheriingPet"), "GatheringPet", Vector3(offsetX, -0.1, 0), self.Entity)
				elseif petData.petType == "HealingPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_HealingPet"), "HealingPet", Vector3(offsetX, -0.1, 0), self.Entity)
				elseif petData.petType == "SlowingPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_SlowingPet"), "SlowingPet", Vector3(offsetX, -0.1, 0), self.Entity)
				elseif petData.petType == "StunningPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_StunningPet"), "StunningPet", Vector3(offsetX, -0.1, 0), self.Entity)
				elseif petData.petType == "PoisoningPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_PoisoningPet"), "PoisoningPet", Vector3(offsetX, -0.1, 0), self.Entity)
				elseif petData.petType == "BonusPet" then
					pet = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("Model_BonusPet"), "BonusPet", Vector3(offsetX, -0.1, 0), self.Entity)
				end
				
				if pet ~= nil then
					pet.SpriteRendererComponent.SpriteRUID = petData.moveRUID
					_PetLogic:InitPetComponent(pet, petData, value.uniqueKey)
				end
				
				table.insert(self.pets, pet)
				
				offsetX = offsetX + 0.4
			end
		end
	end

	method void UnEquipRandomWeapon()
		-- 랜덤 무기 하나 장착 해제
		local random = {}
		for i = 1, #self.equipGun do
			table.insert(random,i)
		end
		_GameUtil:ShuffleTable(random)
		self:UnequipGun(random[1])
	end

	method void StartBuffWindFairy(number interval)
		-- 바람 요정 버프 시작 (주기적 넘백 효과)
		self._T.windFunc = _TimerLogic:SetTimerRepeat(function()
				if not isvalid(self) then
					_TimerLogic:ClearTimer(self._T.windFunc)
					return
				end
				local option = {["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
				_EffectService:PlayEffectAttached("f9ba085c0a46422f8bc5e610073e380c",self.Entity,Vector3(0,-1,0),0,Vector3.one,false,option)
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage25"), "pos")
			
				_TimerLogic:SetTimerOnce(function() 
						if not isvalid(self) then
							_TimerLogic:ClearTimer(self._T.windFunc)
							return
						end
						self:SetMonsterKonckbackRange(self:GetPositionVec2(),6.5,20,0)
				end,0.5, "BattlePlayer.StartBuffWindFairy_innerKnockback")
				
		end,interval,interval * 0.5, "BattlePlayer.StartBuffWindFairy")
	end

	@ExecSpace("Client")
	method void CheckHpCondition()
		-- 체력 상태에 따른 버프 및 디버프 처리
		if isvalid(self) then
			if self.hp <= 0 and  self.willReturnTown then
				
			end
		end
		
		if isvalid(self) and _BuffLogic.appliedBuff.warmUp and self.Entity.CurrentMap.BattleInput.lastKeyPressedTime + 0.3 < _TimerLogic.ElapsedSeconds
			and not _BattleUIManager.bossAlertUI.isPlaying and not self.isInvincible then 
			
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage11"), "neg")
			self:SetDamage(self.maxHp * 0.03, Vector2.zero, 0, 1, "skill", self.Entity)
		end
		
		if self.activateOvercome then 
			if self.hp > 1 then
				self:SetHP(1)
			end
		end
		
		_ArmorSkillLogic:ExcuteWarriorHelmet(self.Entity)
		
		
		if self.hp <= self.maxHp * 0.2 then
			if  _BuffLogic.appliedBuff.adrenaline and self._T.checkAdrenaline == false then  
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage14"), "pos")
				self._T.checkAdrenaline = true
				_BuffLogic.appliedBuff.totalDamage = _BuffLogic.appliedBuff.totalDamage + 0.2
				self.Entity:SendEvent(ChangeTotalDamageEvent())
				
			end
		else
			if self._T.checkAdrenaline == true then
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage17"), "")
				self._T.checkAdrenaline = false
				_BuffLogic.appliedBuff.totalDamage = _BuffLogic.appliedBuff.totalDamage - 0.2
				
				self.Entity:SendEvent(ChangeTotalDamageEvent())
			end
		end
	end

	method table GetOverlaps(string collisionGroupName, Vector2 pos, number range)
		-- 지정된 범위 내 충돌 오브젝트 목록 반환
		local simulator = _CollisionService:GetSimulator(self.Entity)
		return simulator:OverlapCircleAll(collisionGroupName, pos, range)
	end

	method boolean ApplySelectiveDefense(Entity target)
		-- 선택적 방어 적용 (플레이어 방향에 따른 방어 성공 여부)
		if not isvalid(target) then return end
		if not isvalid(target.TransformComponent) then return end
		
		local playerLookX = self.Entity.PlayerControllerComponent.LookDirectionX
		local playerPosX = self.Entity.TransformComponent.WorldPosition.x
		local targetPosX = target.TransformComponent.WorldPosition.x
		local defenseSuccess = false
		
		if playerPosX >= targetPosX then
			if playerLookX > 0 then
				defenseSuccess = false
			else
				defenseSuccess = true
				_EffectService:PlayEffectAttached("f334672fa1774d93bcab676e1d51ae50", self.Entity, Vector3(0,-0.5,0), 0, Vector3(-1,1,1),false)
			end
		else
			if playerLookX > 0 then
				defenseSuccess = true
				_EffectService:PlayEffectAttached("f334672fa1774d93bcab676e1d51ae50", self.Entity, Vector3(0,-0.5,0), 0, Vector3(1,1,1),false)
			else
				defenseSuccess = false
			end
		end
		
		return defenseSuccess
	end

	method void ApplyRepeatEffect()
		-- 신발 아이템의 반복 효과 적용 (슬라임, 폭탄)
		
		
		if _BuffLogic.appliedBuff.shoesSlimeLevel >= 1 then
			local spawnStickyPool = function()
				self:SpawnSticky()
			end
			table.insert(self.repeatTimerTable, _TimerLogic:SetTimerRepeat(spawnStickyPool, 10, 0, "BattlePlayer.ApplyRepeatEffect_SpawnSticky"))
		end 
		
		if _BuffLogic.appliedBuff.shoesBombLevel >= 1 then
			local cooltime = 20
		
			if _BuffLogic.appliedBuff.shoesBombLevel >= 2 then
				cooltime = 15
			end
		
			local spawnMine = function()
				self:SpawnMine()
			end
			table.insert(self.repeatTimerTable, _TimerLogic:SetTimerRepeat(spawnMine, cooltime, cooltime, "BattlePlayer.ApplyRepeatEffect_SpawnMine"))
		end 
	end

	method void ApplyGuardianBall()
		-- 축구공 신발 효과로 가디언 볼 생성
		local angleIndex = {45,180}
		
		if _BuffLogic.appliedBuff.shoesFootballLevel >= 1 then
			for i = 1 , _BuffLogic.appliedBuff.shoesFootballLevel do
				if i < 3 then 
					local guardianBall = _SpawnService:SpawnByModelId("model://e181d719-0f62-47c6-9c90-c2416dfdfb89", "guardianBall"..tostring(math.floor(i)), Vector3.zero, self.Entity.CurrentMap)
					guardianBall.SatellitelComponent.angle = angleIndex[i]
					guardianBall.SatellitelComponent.type = "ball"
					guardianBall.SatellitelComponent:Init(_BuffLogic.appliedBuff.shoesFootballLevel)
				end
				
			end
		end
	end

	method void Init()
		-- 배틀 플레이어 초기화 (체력바, 스태미나바, 버프, 펫 등)
		self.Enable = true
		self.willReturnTown = false
		
		local statusTable = self.Entity.PlayerCharacterData.statusTable
		
		self:SetMaxHP(statusTable["maxHp"]) 
		
		
		self:SetSP(0)	
		
		local offset = -0.33
		
		self._T.cardIndex = 1
		self._T.hitCount = 0
		self._T.hitIndex = 1
		
		self._T.hpBar = _SpawnService:SpawnByModelId("model://266eced9-f3a6-4986-b3b0-d8c53297786c","hp",Vector3(offset,-0.3,0),self.Entity)
		self._T.hpBar:GetChildByName("gauge_shield", true):SetEnable(false)
		
		local transform = self.Entity.TransformComponent
		---@type SpriteRendererComponent
		local hpBarSprite = self._T.hpBar.SpriteRendererComponent
		---@type Entity
		local text = self._T.hpBar:GetChildByName("debug_text", true)
		text.Enable = false
		hpBarSprite.SortingLayer = "Foreground"
		
		---@type SpriteRendererComponent
		local back = self._T.hpBar:GetChildByName("exp_back", true).SpriteRendererComponent
		back.SortingLayer = "Foreground"
		
		self.Entity:ConnectEvent(BattlePlayerHPChange,function(e)
				if not isvalid(text) then
					text = self._T.hpBar:GetChildByName("debug_text", true)
				end
			
				if hpBarSprite.TiledSize.x < 0.1 and e.hp > 0 then
					hpBarSprite.TiledSize.x = 0.1
				end
			
				if (e.hp > 0 and  e.maxHp >= 0)  or e.hp <= 0 then
					hpBarSprite.TiledSize.x = 8 * math.min(1, e.hp / e.maxHp)
				
				
				end
			
				self._T.hpBar.SpriteRendererComponent.DrawMode = SpriteDrawMode.Simple 
				_TimerService:SetTimerOnce(function()
					if not isvalid(self) then return end
					self._T.hpBar.SpriteRendererComponent.DrawMode = SpriteDrawMode.Tiled
				end, 0.02)
			
				if _OptionLogic.showHp then
					text.TextComponent.Text = string.format("%d / %d", e.hp, e.maxHp)
					text.Enable = true
				end
			
		end)
		
		
		self._T.staminaBar = _SpawnService:SpawnByModelId("model://266eced9-f3a6-4986-b3b0-d8c53297786c","stamina",Vector3(offset,-0.415,0),self.Entity)
		self._T.staminaBar:GetChildByName("gauge_shield", true):SetEnable(false)
		self._T.staminaBar:GetChildByName("debug_text", true).Enable = false
		self._T.staminaBarSprite = self._T.staminaBar.SpriteRendererComponent
		self._T.staminaBarSprite.SpriteRUID = "9a8d65adab74400bb113444894f047cf"
		self._T.staminaBarSprite.SortingLayer = "Foreground"
		self._T.staminaBarSprite.OrderInLayer = self.Entity.AvatarRendererComponent.OrderInLayer - 1
		---@type SpriteRendererComponent
		local back = self._T.staminaBar:GetChildByName("exp_back", true).SpriteRendererComponent
		back.SortingLayer = "Foreground"
		back.OrderInLayer = self.Entity.AvatarRendererComponent.OrderInLayer - 2
		
		
		self._T.hpBar.TransformComponent.Scale.y = 0.8
		self._T.staminaBar.TransformComponent.Scale.y = 0.8
		
		_BuffLogic:Init()
		self.Entity.PlayerCharacteristicData:ApplyPlayerCharacteristics()
		self.Entity.PlayerArmorSkillComponent:ResetArmorSkill(self.Entity)
		
		_ArmorSkillLogic:Init()
		_ArmorSkillLogic:ExcuteWeaponGlove(self.Entity)
		
		if _BuffLogic.appliedBuff.helmetAngelLevel >= 1 then 
		
			self.usedRebornByAngelSuit = 1
		end
		
		
		self._T.shield = {}
		self._T.leftBottom = self.Entity.CurrentMap.BattleMap.leftBottom
		self._T.rightTop = self.Entity.CurrentMap.BattleMap.rightTop
		self._T.lastDashTime = 0
		self._T.lastDamageTime = 0
		self._T.equipedWeapon = self.Entity.PlayerStorageComponent:GetAllEquippedWeapon()
		self._T.stickySpawnedPos = Vector3.zero
		self._T.moveVelopcity = Vector2(1,0)
		self._T.leftInvincibleTime = 0 
		self._T.noneHitTime = 0
		self._T.appliedRegenHpUnderMaxHpPercent10 = false 
		
		if isvalid(self._T.gravityField) then
			self._T.gravityField:Destroy()
		end
		
		self._T.transform = self.Entity.TransformComponent
		self._T.position = self._T.transform.Position
		self._T.positionVec2 = self._T.transform.Position:ToVector2()
		
		self._T.checkAdrenaline = false
		self._T.maxExpCache = {}
		self:RefreshEXP()
		
		self:SetHP(self.maxHp)
		self:SetShieldGauge(0)
		
		self.levelupPopup.useRerollButton = false
		
		self.Entity.PlayerControllerComponent:RemoveActionKey(KeyboardKey.LeftControl)
		
		self:SpawnPets()
		self:ApplyRepeatEffect()
		self:ApplyGuardianBall()
		
		self.hpRecoverTimer = _TimerLogic:SetTimerRepeat(function() 
			if _BuffLogic.appliedBuff.hpRecovery > 0 then
				self:RecoverHp() 
			end
			end, _BuffLogic.appliedBuff.hpRecoveryCooltime, _BuffLogic.appliedBuff.hpRecoveryCooltime, "BattlePlayer.Init_RecoverHp") 
		
		
		self:SetMovementSpeed(self:GetSpeed())
		self.Entity:SendEvent(ChangeSpeedEvent())
		
		
		for k,v in pairs(self.equipGun) do
			v.gun.TriggerComponent.Enable = false
		end
		
		self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(1)
		self.Entity.KinematicbodyComponent.MoveVelocity = Vector2.zero
		
	end

	method number GetEquipCardLevel(string uniqueKey)
		-- 지정된 무기의 카드 레벨 반환
		for k,v in pairs(self.equipGun) do
			if v.uniqueKey == uniqueKey then
				return v.gun.BattleGunObject.cardLevel		
			end
		end
		return 0
	end

	method boolean IsPhysicalWeapon(string uniqueKey)
		-- 지정된 무기가 물리 무기인지 확인
		for k,v in pairs(self.equipGun) do
			if v.uniqueKey == uniqueKey then
				return v.gun.BattleGunObject.physicalWeapon		
			end
		end
		return false
	end

	method void AddSP(number sp)
		-- SP 증가 (롤러 신발 보너스 포함)
		if _BuffLogic.appliedBuff.chargingSkill == false then
			
			return
		end
		
		local maxSp = self.maxSp
		if self.sp >= maxSp then
			return
		end
		
		local extraRate = 1
		if _BuffLogic.appliedBuff.shoesRollerLevel == 1 then
			extraRate = 2	
		elseif _BuffLogic.appliedBuff.shoesRollerLevel == 2 then
			extraRate = 3
		end
		
		local nextSp = self.sp + sp * extraRate
		self:SetSP(maxSp < nextSp and maxSp or nextSp)
	end

	method void SetSP(number sp)
		-- SP 설정 및 UI 업데이트 이벤트 발송
		self.sp = sp
		self.Entity:SendEvent(BattlePlayerSPChange(sp,self.maxSp,false))
	end

	method void SetMovementSpeed(number speed)
		-- 플레이어 이동 속도 설정 (슈퍼 모드 제외)
		if self.isSuperMode then return end
		
		speed = speed * _GameConfig:GetConfig().SPEED_MASTER * 1.3
		self.Entity.MovementComponent.InputSpeed = speed
		self.Entity.AvatarRendererComponent.PlayRate = speed
	end

	method void OnDestroy()
		-- 배틀 플레이어 파괴 시 UI 요소 정리
		if self:IsClient() then
			if isvalid(self._T.hpBar) then
				self._T.hpBar:Destroy()
			end
			if isvalid(self._T.staminaBar) then
			self._T.staminaBar:Destroy()
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SpawnSeaWave()
		-- 바다 파도 스킬 생성 (주기적 넘백 효과)
		_TimerLogic:SetTimerRepeat(function()
			local rand = _UtilLogic:RandomIntegerRange(1, 2)
			local flipX = false
			local pos = self._T.transform.WorldPosition:ToVector2():Clone()
			local direction = 1
			
		
			if rand == 1 then
				flipX = true
				pos = pos + Vector2(3, 0)
			else
				pos = pos - Vector2(3, 0)
				direction = -1
			end
			
			local options = {["FlipX"] = flipX, ["PlayRate"] = 1.3, ["Color"] = Color(1, 1, 1, _OptionLogic.myEffectTransparency)}
			
			_EffectService:PlayEffect("fc17c89463fb449089385902335872a5", self.Entity, self.Entity.TransformComponent.Position + Vector3(0, -1, 0), 0, Vector3.one * 3.5, false, options)
			
			local overlaps = self:GetOverlaps(tostring(CollisionGroups.PlayerSkill), pos, 5)
			
			for key, value in pairs(overlaps) do
				---@type Entity
				local entity = value.Entity
				local monster = entity.MonsterObject
				if isvalid(monster) and monster:IsInMapBound() then
					monster:SetKnockback(Vector2(direction * 6, 0), 1, true)
					monster.isInSeaWave = true
					_TimerLogic:SetTimerOnce(function()
										if isvalid(monster) then
											monster.isInSeaWave = false
										end
									end, 1.5, "BattlePlayer.Seawave_finish")
				end
			end
				
		end, 3, 3, "BattlePlayer.SpawnSeaWave")
	end

	@ExecSpace("ClientOnly")
	method void SpawnGravityField()
		-- 중력장 오브젝트 생성 (중복 생성 방지)
		if isvalid(self._T.gravityField) then return end
		
		---@type Entity
		self._T.gravityField = _SpawnService:SpawnByModelId(_EntryService:GetModelIdByName("PlayerSkill_GravityField"), "gravityField", Vector3.zero, self.Entity)
		self._T.gravityField.SpriteRendererComponent.Color.a = _OptionLogic.myEffectTransparency
		self._T.gravityField.SpriteRendererComponent.SortingLayer = self.Entity.AvatarRendererComponent.SortingLayer
		self._T.gravityField.SpriteRendererComponent.OrderInLayer = -1
	end

	@ExecSpace("ClientOnly")
	method void SetSuperMode(boolean onOff)
		-- 슈퍼 모드 설정 (크기 증가, 무적, 속도 증가)
		if onOff then
			if self:GetSpeed() < 5 then
				self:SetMovementSpeed(5)
			end
			self.isSuperMode = true
			self.Entity.TransformComponent.Scale = Vector3(2, 2, 1)
			self.Entity.AvatarRendererComponent:ChangeMaterial("material://f00d9cbb-576f-43df-82ae-f0087185716b")
			
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage8"), "pos")
			self:ApplyInvincible(20)
		else
			if self.isSuperMode then
				
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage9"), "")
			end
			self.isSuperMode = false
			self:SetMovementSpeed(self:GetSpeed())
			self.Entity.TransformComponent.Scale = Vector3.one
			self.Entity.AvatarRendererComponent:ChangeMaterial("")
		end
	end

	@ExecSpace("ClientOnly")
	method void UseImprison()
		-- 감옥 스킬 사용 (주기적으로 몬스터 근처에 감옥 생성)
		local timer = _TimerLogic:SetTimerRepeat(function()
				local stop = false
		
				for i = 1, 5 do
					local rand = Vector2(_UtilLogic:RandomIntegerRange(-3, 3), _UtilLogic:RandomIntegerRange(-3, 3))
					local overlaps = self:GetOverlaps(tostring(CollisionGroups.PlayerSkill), rand, 5)
		
					
					for _, trigger in pairs(overlaps) do
						---@type Entity
						local entity = trigger.Entity
						
						if isvalid(entity.MonsterObject) then
							stop = true
						end
					end
					
					if stop then 
						local imprison = _PoolingLogic:SpawnModel(_EntryService:GetModelIdByName("PlayerSkill_Imprison"), rand:ToVector3() + self._T.transform.Position, self.Entity.CurrentMap)
						imprison.ImprisonComponent:Init()
						
						break 
					end
				end
			end, 15, 0, "BattlePlayer.UseImprison")
	end

	method boolean IsMeleeWeapon(string uniqueKey)
		-- 지정된 무기가 근접 무기인지 확인
		for k,v in pairs(self.equipGun) do
			if v.uniqueKey == uniqueKey then
				return v.gun.BattleGunObject.isMeleeWeapon		
			end
		end
		return false
	end

	method void SetShieldGauge(number value)
		-- 실드 게이지 설정 (실드 스이트 레벨에 따른 제한)
		if _BuffLogic.appliedBuff.suitShieldLevel < 3 then
			value = math.min(self.maxHp * 1/2, value)
		elseif _BuffLogic.appliedBuff.suitShieldLevel == 3 then
			value = math.min(self.maxHp, value)
		else
			return
		end
		
		local entity = self._T.hpBar:GetChildByName("gauge_shield", true) 
		entity.SpriteRendererComponent.SpriteRUID = "2cc7186b484743788ba7761ac4d4f123"
		entity.SpriteRendererComponent.SortingLayer = "Foreground"
		local uiEntity = _BattleUIManager.levelUpPopup.shieldBar
		local uiEntity2 = _BattleUIManager.hpPanel:GetChildByName("gauge_shield", true)
		
		self.shieldGauge = value
		entity.SpriteRendererComponent.TiledSize.x = 8 * self.shieldGauge / self.maxHp
		uiEntity.SpriteGUIRendererComponent.FillAmount = self.shieldGauge / self.maxHp
		uiEntity2.SpriteGUIRendererComponent.FillAmount = self.shieldGauge / self.maxHp
		
		if self.shieldGauge <= 0 then
			entity:SetEnable(false)
			uiEntity.Enable = false
			uiEntity2.Enable = false
		else
			entity:SetEnable(true)
			uiEntity.Enable = true
			uiEntity2.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void ForceOffInvincible()
		-- 무적 상태 강제 해제 및 이팩트 제거
		_EffectService:RemoveEffect(self._T.invincibleEffectSerial)
		self._T.invincibleEffectSerial = nil
		self.isInvincible = false
	end

	method void ApplyBossShield()
		-- 보스 실드 적용 (무술 스이트 효과)
		
		
		if self.getBossShield == true then 
			return 
		end
		self.getBossShield = true
		
		local option = {["Color"] = Color(1,1,1,_OptionLogic.myEffectTransparency)}
		self._T.bossShieldEffect = _EffectService:PlayEffectAttached("19694b839af642fa9c70e73280cc7be9", self.Entity, Vector3(0, 0.5, 0), 0, Vector3.one, true, option)
		
		local str = string.format(_LocalizeLogic:GetText("systemMessage7"), _LocalizationService:GetText("Suit_Martial"))
		_SystemMessageLogic:ShowMessage(str, "equ")
	end

	method void DestroyBossShield()
		-- 보스 실드 파괴 및 무술 실드 생성
		self.getBossShield = false
		_EffectService:RemoveEffect(self._T.bossShieldEffect)
		_ArmorSkillLogic:SpawnMartialShield()
	end

	method void AddHitInfo(string rangeType, integer damage, string attacker, string skillId)
		-- 피격 정보 기록 (무적 및 사망 상태 제외)
		if self.isInvincible then return end
		if self.isDead then return end
		
		self.hitInfo[self._T.hitIndex] = {["type"] = rangeType, ["damage"] = tostring(damage), ["attacker"] = attacker, ["skillId"] = skillId}
		self._T.hitIndex += 1
	end

	method void InitLocalPlayerEvent()
		-- 로컬 플레이어 전용 이벤트 리스너 초기화
		_StageLogic:ConnectEvent(StageEndEvent,function(e) 
			self:DestroyPets()
			if isvalid(self._T.gravityField) then
				self._T.gravityField:Destroy()
			end
			_BattleUIManager.bossAlertUI:ForceClose()
			_BattleUIManager:OffBattleUI()
			self.Entity.PlayerArmorSkillComponent:ResetArmorSkill(self.Entity)
		end)
		_TimerLogic:ConnectEvent(TimerChange,function(e) 
			local pause = e.pause
			
			if pause then
				self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(0)
				self.Entity.KinematicbodyComponent.MoveVelocity = Vector2.zero
			else
				self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(1)
			end
		end)
		_MonsterLogic:ConnectEvent(BossDead,function(e) 
			if not isvalid(_UserService.LocalPlayer) then return end
		
			if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_BASIC then
				if _WaveLogic.delayClearState then
					return
				end
				_UserService.LocalPlayer.CurrentMap.BattleMap:ForceClear()
				_TimerLogic:ClearTimer(self.warmUpTimer)
				_TimerLogic:ClearTimer(self.overcomeTimer)
				self:ApplyInvincible(99999999)
			end
			
		
		end)
		self.Entity:ConnectEvent(ChangeSpeedEvent,function(e) 
			self:SetMovementSpeed(self:GetSpeed())
		end)
		self.Entity:ConnectEvent(ChangeMaxHpEvent,function(e) 
			local ratio = self.hp / self.maxHp
			self:SetMaxHP(_BuffLogic:GetMaxHp())
			self:SetHP(self.maxHp * ratio)
		end)
	end

	method void PlayShieldSuitKnockback()
		-- 실드 스이트 넘백 효과 재생 (레벨 2 이상)
		if  _BuffLogic.appliedBuff.suitShieldLevel >= 2 then
			local overlaps = self:GetOverlaps(tostring(CollisionGroups.PlayerSkill), self._T.transform.WorldPosition:ToVector2(), 3.5)
			local countingMob = 0
		
			for i = 1, #overlaps do
				local entity = overlaps[i].Entity
				if isvalid(entity.MonsterObject) then
					if not entity.MonsterObject.isBoss then
						local diff = entity.MonsterObject:GetPositionVec2() - self._T.transform.Position:ToVector2()
						local force = diff:Normalize() * 50
						entity.MonsterObject:SetKnockback(force, 0.01, true)
						countingMob += 1
					end
				end
			end
			
			if countingMob >= 1 then
				local str = string.format(_LocalizeLogic:GetText("systemMessage12"), _LocalizationService:GetText("Suit_Shield"))
				_SystemMessageLogic:ShowMessage(str, "equ")
				
				_SoundService:PlaySound("786d57a118974db2881cbac229db98db", 1)
				_EffectService:PlayEffect("f9484069e4fe419bb355edb4146ccb02", self.Entity, self._T.transform.Position, 0, Vector3.one, false)
			end
		
		else
			return
		end
	end

	@ExecSpace("ClientOnly")
	method void ClearTimerCauseDie()
		-- 사망 시 극복 버프 관련 타이머 정리
		if self.overcomeTimer ~= 0 and self.activateOvercome then
			
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage10"), "neg")
			_TimerLogic:ClearTimer(self.overcomeTimer)
			for key, value in pairs(self._T.overComeTimers) do
				_TimerLogic:ClearTimer(value)
			end
			self.activateOvercome = false
		end
	end

	@ExecSpace("Client")
	method void ResurrectByTicket()
		-- 부활 티켓으로 플레이어 부활 처리
		local player = _UserService.LocalPlayer
		
		self:ForceOffInvincible()
		self:ApplyInvincible(5)
		
		player.StateComponent:ChangeState("DEAD")
		player.PlayerControllerComponent.Enable = false
		
		
		local reborn = function()
			if not isvalid(self) then return end
			
			_EffectService:PlayEffectAttached("c6f54657879448b496daecc8a15c2918", player, Vector3.zero, 0, Vector3(2,2,2), false)
			
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage23"), "pos")
		
			self:SetHP(self.maxHp)
			self.isDead = false
			
			player.StateComponent:ChangeState("IDLE")
			player.PlayerControllerComponent.Enable = true
			
			local animEvent = BodyActionStateChangeEvent()
			animEvent.needResetAction = true
			animEvent.ActionState = MapleAvatarBodyActionState.Walk
			player:SendEvent(animEvent)
		end
		
		_TimerLogic:SetTimerOnce(reborn, 2, "BattlePlayer.Dead_ResurrectByTicket")
		_TimerLogic:Resume()
	end

	@ExecSpace("Client")
	method void PlayLevelUpEff()
		-- 레벨업 이팩트 및 사운드 재생
		local lvUpEff =	_PoolingLogic:SpawnModel("model://ea815d5c-5797-4d3c-afe9-0c4e4a1eeccb",Vector3.zero,self.Entity)
				lvUpEff.SkillEffectObject:Init(0, true, "LevelUp", "")
				_SoundService:PlaySound("c198d87b06b24707864b1ac73345cca8", _SoundLogic.effectRatio)
					
	end

	method boolean IsEnableSuperDash()
		-- 슈퍼 러쉬 버프 활성 여부 확인
		return _BuffLogic.appliedBuff.superRush
	end

	method number GetSuperDashSpeed()
		-- 슈퍼 대시 속도 배율 반환
		return 2
	end

	method number GetSpeed()
		-- 버프가 적용된 플레이어 속도 반환
		return _BuffLogic:GetSpeed()
	end

end