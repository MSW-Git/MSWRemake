@Component
script ReflectionObject extends Component

	property Vector2 dir = Vector2(-1,0)

	method void OnTrigger(Entity TriggerBodyEntity)
		-- 스킬 이펙트의 반사 처리
		local skillEffect = TriggerBodyEntity.SkillEffectObject
		
		if skillEffect ~= nil then
			if skillEffect.reflectOnWall then
				if skillEffect.useDir then
					local selfPos = self.Entity.TransformComponent.Position 
					local skillPos = TriggerBodyEntity.TransformComponent.Position
					
					skillEffect.dir.x = skillEffect.dir.x * self.dir.x
					skillEffect.dir.y = skillEffect.dir.y * self.dir.y
		
					skillEffect:RebuildUpdateVelocityFunc()
				else
					local x = math.cos(math.rad(skillEffect.angle))
					local y = math.sin(math.rad(skillEffect.angle))
					x = x * self.dir.x
					y = y * self.dir.y
					local angle = math.deg(math.atan(y,x))
					skillEffect:SetAngle(angle,false)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		
	end

end