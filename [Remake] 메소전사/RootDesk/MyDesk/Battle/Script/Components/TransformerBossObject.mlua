@Component
script TransformerBossObject extends BossObject

	property string transformerTargetMonster = "King Sage Cat Transformer"

	method void OnChangePhase(number phase)
		-- 페이즈 변경 시 다른 몬스터로 변신
		__base:OnChangePhase(phase)
		
		if phase == 2 then
			
			if _UtilLogic:IsNilorEmptyString(self.transformerTargetMonster) then
				return
			end
			
			local monsterData = _MonsterLogic:GetMonsterData(self.transformerTargetMonster)
			
			self.stand = monsterData.stand_ruid
			self.move = monsterData.move_ruid
			self._T.moveRuid = self.move
			self.attack = monsterData.attack_ruid
			self.hit = monsterData.hit_ruid
			self.die = monsterData.die_ruid
			
			local offset = monsterData.ColliderOffset
			local radius = monsterData.CircleRadius
			self._T.triggerComponent.ColliderOffset = offset
			self._T.triggerComponent.CircleRadius = radius
			self._T.collider.ColliderOffset = offset
			self._T.collider.CircleRadius = radius
			
		else	
			self.stand = self._T.monsterData.stand_ruid
			self.move = self._T.monsterData.move_ruid
			self._T.moveRuid = self.move
			self.attack = self._T.monsterData.attack_ruid
			self.hit = self._T.monsterData.hit_ruid
			self.die = self._T.monsterData.die_ruid
			
			local offset = self._T.monsterData.ColliderOffset
			local radius = self._T.monsterData.CircleRadius
			self._T.triggerComponent.ColliderOffset = offset
			self._T.triggerComponent.CircleRadius = radius
			self._T.collider.ColliderOffset = offset
			self._T.collider.CircleRadius = radius
			
		end
	end

end