@Component
script SkillBlinkTweener extends Component

	property number from = 0.1

	property number to = 0.2

	property number speed = 10

	@HideFromInspector
	property boolean isPlaying = false

	method void Play()
		-- 깜빡임 트위닝 시작
		self._T.time = 0
		self.isPlaying = true
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임 알파값 깜빡임 처리
		if _TimerLogic.pause then
			return
		end
		if self.isPlaying == false then
			return
		end
		
		self._T.time = self._T.time + delta
		local timeValue = self._T.time
		self._T.spriteRendrer.Color.a = self.from + (self.to - self.from) * (math.sin(timeValue * self.speed) + 1) / 2
		
	end

	method void Stop()
		-- 깜빡임 트위닝 정지
		self._T.isPlaying = false
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스킬 이펙트 이벤트와 연결하여 자동 재생
		self._T.spriteRendrer = self.Entity.SpriteRendererComponent
		local parent = self:GetParentEntity(self.Entity.Parent)
		if isvalid(parent) == false then
			return
		end
		parent:ConnectEvent(SkillEffectStart,function(e)
				self:Play()
		end)
		parent:ConnectEvent(SkillEffectEnd,function(e) 
				self:Stop()
		end)
		
		if self._T.isPlaying == false then
			self:Play()
		end
		self._T.parent = parent
	end

	method Entity GetParentEntity(Entity parent)
		-- 스킬 이펙트 부모 엔티티 찾기
		if parent.MapComponent ~= nil then
			return nil
		end
		if parent.SkillEffectObject ~= nil then
			return parent
		end
		return self:GetParentEntity(parent.Parent)
	end

	@EventSender("Logic", "TimerLogic")
	handler HandleTimerChange(TimerChange event)
		-- 타이머 일시정지/재개 시 스프라이트 재생 속도 동기화
		
		local pause = event.pause
		
		local sprite = self.Entity.SpriteRendererComponent
		if sprite ~= nil then
			sprite.PlayRate = pause and 0 or 1
		end
	end

end