@Logic
script WeaponSpecLogic extends Logic

	property table weaponData = {}

	property table weaponColor = {"#ffffff","#9bd522","#36baff","#e362ff","#ff524e"}

	property table weaponLevelUpData = {}

	property table weaponExpColor = {Color(255/255,255/255,255/255,255/255),Color(80/255,205/255,12/255,255/255),Color(11/255,110/255,204/255,255/255),Color(155/255,61/255,217/255,255/255),Color(253/255,30/255,25/255,255/255),Color(0/255,0/255,0/255,255/255)}

	property boolean useOutglow = false

	property table categorySlotColorBG = {"f8410525a90f4e2e8be0ae22623944f3","ba1e2518b27b4120b67f68d8a1052cac","6dcc398f8a4742cbbcef50c1beea4ecb","d63b74fe7d62434dba266585dbd7bba2","267e7186eac54d24a83968c66febc10c"}

	property table slotColorBG = {"2502dac4d15a46f4ab26445abd1cc7f9","ee76a77c3f60420786df557ca6cb29ba","8cd3e973b6f04b67a5d425eaed80e916","401b646213b241c59f4ebc3712e7aad6","87f20108334748dc94da9983a1e7e96c"}

	property table outGlowColorRUID = {"#ffffff","#9bd522","#36baff","#e362ff","#ff524e"}

	property table weaponIconData = {}

	property table weaponSlotRuidByGrade = {"2502dac4d15a46f4ab26445abd1cc7f9","ee76a77c3f60420786df557ca6cb29ba","8cd3e973b6f04b67a5d425eaed80e916","401b646213b241c59f4ebc3712e7aad6","87f20108334748dc94da9983a1e7e96c"}

	property table weaponSlotLvRuidByGrade = {"f8410525a90f4e2e8be0ae22623944f3","ba1e2518b27b4120b67f68d8a1052cac","6dcc398f8a4742cbbcef50c1beea4ecb","d63b74fe7d62434dba266585dbd7bba2","267e7186eac54d24a83968c66febc10c"}

	property table weaponBackColor = {"#222630","#40652d","#2860b1","#7d11bd","#852821"}

	property table weaponMergeEff = {"cd6cebcd9d0e410787aa2007c5dcc93a","838be99e6fd142688be755809d6f64d8","1384c69453dd4192ac2e8a53db2ec46b","3005d407de9e4aadbb2d3ff295ed1093","963467dd82fc4c7e9b54dc8a12537e91"}

	property boolean isDataInit = false

	method void OnBeginPlay()
		-- 무기 스펙 데이터 초기화
		self:DataInit()
	end

	method void DataInit()
		-- 무기 데이터와 카테고리 아이콘 데이터를 로드하여 초기화
		if self.isDataInit then
			return
		end
		
		self.isDataInit = true
		local data = _DataService:GetTable("WeaponSpec")
		
		for i = 1, data:GetRowCount() do
			local gun = {}
			gun.id = data:GetCell(i,"id")	
			gun.model = data:GetCell(i,"model")
			gun.name = data:GetCell(i,"name")
			gun.grade = data:GetCell(i, "grade")
			gun.ruid = data:GetCell(i,"ruid")
			if self:IsClient() and Environment:IsPCPlatform() then
				gun.ruid = data:GetCell(i,"ruid_pc_only")
			end
			gun.class = data:GetCell(i, "class")
			gun.attribute = data:GetCell(i, "attribute")
		
			local outglow = data:GetCell(i,"outglow")
			if _UtilLogic:IsNilorEmptyString(outglow) == false then
				gun.outglow = data:GetCell(i,"outglow")
			else
				gun.outglow = ""
			end
			gun.type = data:GetCell(i,"type")
			gun.bullet = data:GetCell(i,"bullet")
			gun.coolTime = tonumber(data:GetCell(i,"coolTime"))
			gun.fireEffect = data:GetCell(i,"fireEffect")
			gun.damage = tonumber(data:GetCell(i,"damage"))
			gun.specialBuffDamageRate = tonumber(data:GetCell(i,"specialBuffDamageRate"))
			gun.criticalRate = tonumber(data:GetCell(i,"criticalRate"))
			gun.criticalDamage = tonumber(data:GetCell(i,"criticalDamage"))
			gun.range = tonumber(data:GetCell(i,"range"))
			gun.bulletCount = tonumber(data:GetCell(i,"bulletCount"))
			gun.bulletAngle = tonumber(data:GetCell(i,"bulletAngle"))
			gun.pierceCount = tonumber(data:GetCell(i,"pierceCount"))
			gun.knockback = tonumber(data:GetCell(i,"knockback"))
			gun.bulletDelay = tonumber(data:GetCell(i,"bulletDelay"))
			gun.stunDuration = tonumber(data:GetCell(i,"stunDuration"))
			gun.cardDescription = data:GetCell(i,"cardDescription")
				
			gun.graph_attack = tonumber(data:GetCell(i,"graph_attack"))
			gun.graph_speed = tonumber(data:GetCell(i,"graph_speed"))
			gun.graph_util = tonumber(data:GetCell(i,"graph_util"))
			gun.graph_multihit = tonumber(data:GetCell(i,"graph_multihit"))
			gun.graph_accuracy = tonumber(data:GetCell(i,"graph_accuracy"))
			
			gun.boxDamage = tonumber(data:GetCell(i,"boxDamage"))
			
			
			gun.mana = tonumber(data:GetCell(i,"mana"))
			gun.spawnDuration = tonumber(data:GetCell(i,"spawnDuration"))
			gun.fieldCoolTime = tonumber(data:GetCell(i,"fieldCoolTime"))
			gun.fieldRatio = tonumber(data:GetCell(i, "fieldRatio"))
			
			self.weaponData[gun.id] = gun
		end
		
		data = _DataService:GetTable("WeaponCategoryIcon") 
		
		for i = 1 , data:GetRowCount() do
			
			local icon = {}
			
			icon.category = data:GetCell(i, "category")
			icon.ruid = data:GetCell(i, "ruid")
			
			self.weaponIconData[icon.category] = icon
		end
		
		
		
		_ResourceService:PreloadAsync(self.weaponMergeEff,function() end)
	end

	method table GetWeaponSpec(string id)
		-- 무기 ID로 무기 스펙 데이터 반환
		return self.weaponData[id]
	end

	method Color GetColorByStar(number star)
		-- 별 등급에 따른 무기 색상 반환
		return Color.FromHexCode(self.weaponColor[star + 1])
	end

	method Color GetColorByGrade(string grade)
		-- 무기 등급에 따른 색상 반환
		
		local color = Color.white
		
		if grade == "normal" then
			color = Color.FromHexCode(self.weaponColor[1])
		elseif grade == "rare" then
			color = Color.FromHexCode(self.weaponColor[2])
		elseif grade == "epic" then
			color = Color.FromHexCode(self.weaponColor[3])
		elseif grade == "unique" then
			color = Color.FromHexCode(self.weaponColor[4])
		elseif grade == "legendary" then
			color = Color.FromHexCode(self.weaponColor[5])
		end
		
		return color
	end

	method string GetHUDWeaponSlotByGrade(string grade)
		-- 무기 등급에 따른 HUD 슬롯 배경 RUID 반환
		local ruid = ""
		
		if grade == "normal" then
		
			ruid = self.slotColorBG[1]
		elseif grade == "rare" then
		
			 ruid = self.slotColorBG[2]
		elseif grade == "epic" then
		
			ruid = self.slotColorBG[3]
		elseif grade == "unique" then
		
			ruid = self.slotColorBG[4]
		elseif grade == "legendary" then
		
			ruid = self.slotColorBG[5]
		end
		
		return ruid
	end

	method string GetHexColorByGrade(string grade)
		-- 무기 등급에 따른 헥스 색상 코드 반환
		local color = "#ffffff"
		
		if grade == "normal" then
			color = self.outGlowColorRUID[1]
		elseif grade == "rare" then
			color = self.outGlowColorRUID[2]
		elseif grade == "epic" then
			color = self.outGlowColorRUID[3]
		elseif grade == "unique" then
			color = self.outGlowColorRUID[4]
		elseif grade == "legendary" then
			color = self.outGlowColorRUID[5]
		end
		
		
		return color
	end

	method string GetWeaponCategoryIcon(string category)
		-- 무기 카테고리에 따른 아이콘 RUID 반환
		
		if isvalid(self.weaponIconData[category]) then
			return self.weaponIconData[category].ruid
		else
			return ""	
		end
		
	end

	method string GetHUDCategorySlotByGrade(string grade)
		-- 무기 등급에 따른 카테고리 슬롯 배경 RUID 반환
		local ruid = ""
		
		if grade == "normal" then
		
			ruid = self.categorySlotColorBG[1]
		elseif grade == "rare" then
		
			 ruid = self.categorySlotColorBG[2]
		elseif grade == "epic" then
		
			ruid = self.categorySlotColorBG[3]
		elseif grade == "unique" then
		
			ruid = self.categorySlotColorBG[4]
		elseif grade == "legendary" then
		
			ruid = self.categorySlotColorBG[5]
		end
		
		return ruid
	end

	method string GetWeaponSlotRUIDByGrade(string grade)
		-- 무기 등급에 따른 슬롯 RUID 반환
		local index = 1
		if grade == "normal" then
			 index = 1
		elseif grade == "rare" then
			 index = 2
		elseif grade == "epic" then
			 index = 3
		elseif grade == "unique" then
			 index = 4
		elseif grade == "legendary" then
			 index = 5
		end
		return self.weaponSlotRuidByGrade[index]
	end

	method string GetWeaponLevelSlotRUIDByGrade(string grade)
		-- 무기 등급에 따른 레벨 슬롯 RUID 반환
		local index = 1
		if grade == "normal" then
			 index = 1
		elseif grade == "rare" then
			 index = 2
		elseif grade == "epic" then
			 index = 3
		elseif grade == "unique" then
			 index = 4
		elseif grade == "legendary" then
			 index = 5
		end
		return self.weaponSlotLvRuidByGrade[index]
	end

	method string GetHexBackColorByGrade(string grade)
		-- 무기 등급에 따른 배경 헥스 색상 코드 반환
		local color = "#ffffff"
		
		if grade == "normal" then
			color = self.weaponBackColor[1]
		elseif grade == "rare" then
			color = self.weaponBackColor[2]
		elseif grade == "epic" then
			color = self.weaponBackColor[3]
		elseif grade == "unique" then
			color = self.weaponBackColor[4]
		elseif grade == "legendary" then
			color = self.weaponBackColor[5]
		end
		
		return color
	end

	method Color GetColorBackByGrade(string grade)
		-- 무기 등급에 따른 배경 Color 객체 반환
		return  Color.FromHexCode(self:GetHexBackColorByGrade(grade))
	end

	method number GetEXPAmount(table storageData)
		-- 무기의 현재 경험치 비율을 계산하여 반환
		local totalExp = _ItemDataLogic:GetWeaponMaxExp(storageData.level + 1)
		local minExp = _ItemDataLogic:GetWeaponMaxExp(storageData.level)
		if minExp == 1 then
			minExp = 0
		end
		
		local mergeExp = storageData.mergeExp
		if mergeExp == nil or mergeExp == 0 then
			mergeExp =  minExp
		end
		
		if totalExp == nil or minExp == nil then
			return 0
		elseif storageData.level > 1 then
			return (mergeExp - minExp)/(totalExp - minExp)
		end
		
		return 0
	end

	method string GetMergeEffect(string grade)
		-- 무기 등급에 따른 합성 효과 RUID 반환
		local index = 1
		if grade == "normal" then
			 index = 1
		elseif grade == "rare" then
			 index = 2
		elseif grade == "epic" then
			 index = 3
		elseif grade == "unique" then
			 index = 4
		elseif grade == "legendary" then
			 index = 5
		end
		return self.weaponMergeEff[index]
	end

end