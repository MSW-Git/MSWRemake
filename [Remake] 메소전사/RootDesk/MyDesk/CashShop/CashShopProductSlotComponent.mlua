@Component
script CashShopProductSlotComponent extends Component

	property Entity nameText = nil

	property Entity sprite = nil

	property Entity cautionText = nil

	property Entity priceText = nil

	property Entity diamondIcon = nil

	property Entity limitText = nil

	property CashShopUIComponent cashShopUI = "7b5fa4aa-7adc-4def-ba00-23f3efc06ef0"

	property string productId = ""

	property Entity infoButton = nil

	property table itemInfos = {}

	property Entity worldCoinIcon = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 캐시샵 상품 슬롯 UI 컴포넌트들을 초기화
		self.nameText = self.Entity:GetChildByName("ProductNameText")
		self.sprite = self.Entity:GetChildByName("ProductSprite")
		self.cautionText = self.Entity:GetChildByName("ProductCautionText")
		self.limitText = self.Entity:GetChildByName("ProductLimitText")
		self.priceText = self.Entity:GetChildByName("ProductPriceText")
		self.diamondIcon = self.priceText:GetChildByName("Icon_world_dia")
		self.worldCoinIcon = self.priceText:GetChildByName("Icon_world_coin")
		self.infoButton = self.Entity:GetChildByName("ProductInfoButton")
		self.infoButton.Enable = false
		
		self.Entity:ConnectEvent(ButtonClickEvent, function()
			self:OpenContainsListPopUp()
			end)
		self.priceText:ConnectEvent(ButtonClickEvent, function()
			self:OpenPurchasePopUp()
			end)
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string id)
		-- 상품 슬롯에 아이템 정보를 설정하고 UI 업데이트
		local data = _CashShopLogic.cashItemData[id]
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		local historyKey = string.format("purchasedHistory,%s", data.id)
		local purchasedCount = 0
		
		self.itemInfos = {}
		
		if isvalid(playerInfo.playerInfo[historyKey]) then
			local values = _UtilLogic:Split(playerInfo.playerInfo[historyKey], ",")
			purchasedCount = tonumber(values[2])
		end
		
		self.productId = id
		
		self.nameText.TextComponent.Text = _LocalizeLogic:GetCashItemName(id)
		self.sprite.SpriteGUIRendererComponent.ImageRUID = data.ruid
		self.sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(data.offsetX, data.offsetY)
		
		local cautionStr = ""
		local limitStr = ""
		local canPurchase = true
		
		if data.initInterval == "day" then
			cautionStr = _LocalizeLogic:GetText("etcStr38")
			limitStr = string.format(_LocalizeLogic:GetText("etcStr41"), data.limitPurchaseCount - purchasedCount, data.limitPurchaseCount)
		elseif data.initInterval == "week" then
			cautionStr = _LocalizeLogic:GetText("etcStr39")
			limitStr = string.format(_LocalizeLogic:GetText("etcStr42"), data.limitPurchaseCount - purchasedCount, data.limitPurchaseCount)
		elseif data.initInterval == "month" then
			cautionStr = _LocalizeLogic:GetText("etcStr40")
			limitStr = string.format(_LocalizeLogic:GetText("etcStr43"), data.limitPurchaseCount - purchasedCount, data.limitPurchaseCount)
		else
			if data.limitPurchaseCount > 0 then
				limitStr = string.format(_LocalizeLogic:GetText("etcStr44"), data.limitPurchaseCount - purchasedCount, data.limitPurchaseCount)
			end
		end
		
		
		if data.limitPurchaseCount - purchasedCount <= 0 then
			canPurchase = false
		else
			canPurchase = true
		end
		
		if data.limitPurchaseCount > 0 and purchasedCount >= data.limitPurchaseCount then
			self.Entity.SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4")
			self.sprite.SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4")
			self.infoButton.SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4")
			self.priceText.SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4")
		else
			self.Entity.SpriteGUIRendererComponent:ChangeMaterial("")
			self.sprite.SpriteGUIRendererComponent:ChangeMaterial("")
			self.infoButton.SpriteGUIRendererComponent:ChangeMaterial("")
			self.priceText.SpriteGUIRendererComponent:ChangeMaterial("")
		end
		
		self.cautionText.TextComponent.Text = cautionStr
		self.limitText.TextComponent.Text = limitStr
		if canPurchase then
			self.limitText.TextComponent.FontColor = Color.FromHexCode("#6FAF0A")
		else
			self.limitText.TextComponent.FontColor = Color.FromHexCode("#888888")
		end
		self.priceText.TextComponent.Text = string.format("%d", data.price)
		
		local iconRenderer = self.diamondIcon.SpriteGUIRendererComponent
		
		if data.wealthType == "diamond" then
			iconRenderer = self.diamondIcon.SpriteGUIRendererComponent
			iconRenderer.ImageRUID = _GameConfig:GetConfig().RUID_DIAMOND
			iconRenderer.LocalPosition = Vector2.zero
			
			self.diamondIcon.Enable = true
			self.worldCoinIcon.Enable = false
		elseif data.wealthType == "worldCoin" then
			iconRenderer = self.worldCoinIcon.SpriteGUIRendererComponent
			iconRenderer.ImageRUID = "a8f3146382c07494d8dbce9b93c1a5c3"
			iconRenderer.LocalPosition = Vector2.zero
			
			self.diamondIcon.Enable = false
			self.worldCoinIcon.Enable = true
		end
		
		if data.rewardType == "bundle" then
			local str = ""
			local bundleData = _RewardLogic:FindBundleData(data.rewardId)
			local index = 1
			local itemInfos = {}
			
			for _, bundleItemData in pairs(bundleData.bundleItemDatas) do
				local itemType = bundleItemData.itemType
				
				if str ~= "" then
					str = str .. "\n"
		
				end
				
				if itemType == "meso" then
					str = string.format(_LocalizeLogic:GetText("etcStr33"), str, bundleItemData.itemNum)
				elseif itemType == "weaponScroll" then
					str = string.format(_LocalizeLogic:GetText("etcStr34"), str, bundleItemData.itemNum)
				elseif itemType == "essence" then
					str = string.format(_LocalizeLogic:GetText("etcStr35"), str, bundleItemData.itemNum)
				elseif itemType == "diamond" then
					str = string.format(_LocalizeLogic:GetText("etcStr36"), str, bundleItemData.itemNum)
				elseif itemType == "item" then
					local itemData = _ItemDataLogic.itemData[bundleItemData.itemId]
					
					if not isvalid(itemData) or itemData == "" then
						itemData = _ItemDataLogic.equipmentData[bundleItemData.itemId]
					end
					
					local itemName = itemData.name
					str = _LocalizationService:GetTextFormat("etcStr37", str, _LocalizeLogic:GetItemName(bundleItemData.itemId), tostring(bundleItemData.itemNum))
				end
				
				itemInfos[index] = {["id"] = bundleItemData.itemId, ["itemType"] = itemType, ["count"] = bundleItemData.itemNum}
				
				index += 1
			end
			
			self.itemInfos = itemInfos
		elseif data.rewardType == "item" or data.rewardType == "egg" then
			self.itemInfos = {["id"] = data.rewardId, ["itemType"] = data.rewardType, ["count"] = data.rewardNum}
		end
	end

	@ExecSpace("ClientOnly")
	method void OpenContainsListPopUp()
		-- 상품에 포함된 아이템 목록 팝업을 표시
		if isvalid(self.itemInfos) then
			if isvalid(self.itemInfos[1]) then
				_ItemListPopUp:Open(self.itemInfos, nil, _LocalizeLogic:GetText("confirmPopup1"))
			elseif isvalid(_ItemDataLogic.itemData[self.itemInfos.id]) then
				local desc = _LocalizeLogic:GetItemDesc(self.itemInfos.id)
				_UIOnlyConfirmPopUp:Open(desc, _LocalizeLogic:GetText("confirmPopup1"), nil)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OpenPurchasePopUp()
		-- 상품 구매 확인 팝업을 표시하고 구매 처리
		if _UtilLogic.ServerElapsedSeconds < self.cashShopUI.buttonClickedTime + 1 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
			
			return 
		end
		if _UtilLogic.ServerElapsedSeconds < self.cashShopUI.purchaseRequestedTime + 1 then return end
		
		local data = _CashShopLogic.cashItemData[self.productId]
		
		if not _CashShopLogic:CheckCanPurchaseProductOnClient(data) then
			return
		end
		
		local callback = function()
			_CashShopLogic:RequestPurchaseProduct(data.id)
			self.cashShopUI.purchaseRequestedTime = _UtilLogic.ServerElapsedSeconds
		end
		
		if data.wealthType == "diamond" then
			_UIPopup:Open("",string.format(_LocalizeLogic:GetText("popup2"), _LocalizeLogic:GetCashItemName(data.id)), callback, nil)
		elseif data.wealthType == "worldCoin" then
			if data.limitPurchaseCount >= 0 then
				local str = ""
				local str2 = ""
				
				if data.initInterval == "account" then
					str = string.format(_LocalizeLogic:GetText("etcStr23"), data.limitPurchaseCount)
					str2 = string.format(_LocalizeLogic:GetText("etcStr24"))
				elseif data.initInterval == "day" then
					str = string.format(_LocalizeLogic:GetText("etcStr25"), data.limitPurchaseCount)
					str2 = string.format(_LocalizeLogic:GetText("etcStr26"))
				elseif data.initInterval == "week" then
					str = string.format(_LocalizeLogic:GetText("etcStr27"), data.limitPurchaseCount)
					str2 = string.format(_LocalizeLogic:GetText("etcStr28"))
				elseif data.initInterval == "month" then
					str = string.format(_LocalizeLogic:GetText("etcStr29"), data.limitPurchaseCount)
					str2 = string.format(_LocalizeLogic:GetText("etcStr30"))
				end
				
				str = string.format(_LocalizeLogic:GetText("etcStr31"), str, _LocalizeLogic:GetCashItemName(data.id), str2)
				
				str = string.format(_LocalizeLogic:GetText("etcStr32"), str, _LocalizeLogic:GetCashItemName(data.id))
				
				_UIPopup:Open("",str, function() 
						_WorldShopService:PromptPurchase(data.id)
					end, nil)
			else
				_WorldShopService:PromptPurchase(data.id)
				_CashShopLogic.cashShopUI.purchaseRequestedTime = _UtilLogic.ServerElapsedSeconds
			end
		end
		
		
		self.cashShopUI.buttonClickedTime = _UtilLogic.ServerElapsedSeconds
	end

end