@Component
script RandomBossUIComponent extends UICommonPopup

	property Entity exitButton = "c3b6815c-3035-4b1b-83b2-d944e621ad38"

	property Entity wealthText = "0664004c-aacb-4265-9ef7-305a78724953"

	property Entity todayEnteredText = "301cf1fe-a57f-4b05-b92b-5a2dbbf354ba"

	property string canEnterRGBA = ""

	property string cantEnterRGBA = ""

	property number lastEnteredTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 이벤트 연결
		__base:OnBeginPlay()
		
		self.exitButton:ConnectEvent(ButtonClickEvent, function()
				self:Hide()
			end)
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 랜덤 보스 UI 정보를 최신 상태로 갱신
		local playerEntity = _UserService.LocalPlayer
		local playerInfo = playerEntity.PlayerInfoComponent.playerInfo
		
		self.todayEnteredText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr142"), playerInfo.enteredRandomBossCount, _GameConfig:GetConfig().RANDOMBOSS_POSSIBLECOUNT)
		
		if playerInfo.enteredRandomBossCount == 0 then
			self.wealthText.TextComponent.Text = _LocalizeLogic:GetText("randomBossStr1")
			self.wealthText.TextComponent.FontColor = _ColorLogic:GetColorFromRGBAString(self.canEnterRGBA)
		else
			self.wealthText.TextComponent.Text = string.format("%d / %d", playerEntity.PlayerCurrencyData.gold, _RandomBossLogic:GetEnterCost(playerEntity))
			
			if _RandomBossLogic:IsCanEnter(playerEntity) and _RandomBossLogic:IsCanEnterByMeso(playerEntity) then
				self.wealthText.TextComponent.FontColor = _ColorLogic:GetColorFromRGBAString(self.canEnterRGBA)
			else
				self.wealthText.TextComponent.FontColor = _ColorLogic:GetColorFromRGBAString(self.cantEnterRGBA)
				
				if not _RandomBossLogic:IsCanEnter(playerEntity) then
					self.todayEnteredText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr143"))
				end
			end
		end
		
	end

	method void Show()
		-- 랜덤 보스 UI를 화면에 표시
		if self.Entity.ContentLockComponent:CheckUIAvailable() then
			self:Refresh()
			__base:Show()
			_UIOpenQuestLogic:CheckQuestInProgress("randomBoss",self.Entity)
			_UserService.LocalPlayer.PlayerInfoComponent:RequestRefreshPlayerInfo()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "bf194dd2-dbd7-4a10-88c2-7b49e5c3a317")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 랜덤 보스 입장 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if not Environment:IsPlay() then return end
		if _BattleUIManager.loadingUI.Entity.Enable then return end
		if isvalid(_UserService.LocalPlayer.CurrentMap.BattleMap) then return end
		if self.lastEnteredTime + 1 > _UtilLogic.ServerElapsedSeconds then 
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
			return 
		end
		
		_GameLogic:TryEnterRandomBossMap(_UserService.LocalPlayer)
		self.lastEnteredTime = _UtilLogic.ServerElapsedSeconds
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "70a5180c-a300-44b0-a555-e0e06fc738a5")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 랜덤 보스 UI 열기 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if not Environment:IsPlay() then return end
		
		self:Show()
	end

end