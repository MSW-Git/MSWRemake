@Logic
script NPCLogic extends Logic

	property table npcData = {}

	method void OnBeginPlay()
		-- NPC 데이터 테이블을 로드하여 NPC 정보를 초기화
		local data = _DataService:GetTable("NPCData")
		
		for i = 1, data:GetRowCount() do
			local npc = {}
			npc.id = data:GetCell(i,"id")
			npc.name = data:GetCell(i, "name")
			npc.ruid = data:GetCell(i, "ruid")
			npc.text = data:GetCell(i, "text")
			npc.interaction = data:GetCell(i, "interaction")
		
			self.npcData[npc.id] = npc
		end
	end

end