	@ExecSpace("ClientOnly")
	@EventSender("Logic", "MonsterLogic")
	handler HandleBossDead(BossDead event)
		-- 보스 사망 이벤트 처리
		if isvalid(_UserService.LocalPlayer.CurrentMap.RandomBossMapComponent) then return end
		if not isvalid(self.currentMission) then return end
		
		if _WaveLogic:GetLastWave(_UserService.LocalPlayer.CurrentMap.BattleMap.chapter) == _UserService.LocalPlayer.CurrentMap.BattleMap.wave and self.occurred then
			self.killedBoss = true
			if self.currentMission.successCondition == "KILL BOSS" then
				self.currentObjectiveNum = self.currentObjectiveNum + 1
			else
				self:CheckMissionClear()
				self:Fail()
			end
			self:CheckMissionClear()
		end
	end

