	handler HandleGetPotionEvent(GetPotionEvent event)
		-- 포션 획득 이벤트 처리
		if not isvalid(self.currentMission) then return end
		
		if self.currentMission.successCondition == "POTION" and self.occurred then
			self.currentObjectiveNum = self.currentObjectiveNum + 1
			_BattleUIManager.suddenMissionUI:Refresh()
			self:CheckMissionClear()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "BuffLogic")
	handler HandleInittedBuffEvent(InittedBuffEvent event)
		-- 버프 초기화 이벤트 처리
		if self.willStartWave == 0 then return end
		if self.occurred then return end
		if not isvalid(self.currentMission) then return end
		
		if self.willStartWave == 1 then
			self:AppearMission()
		end
		
	end

end