	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleUseChargingSkillEvent(UseChargingSkillEvent event)
		-- 차징 스킬 사용 이벤트 처리
		if self.occurred then
			if not isvalid(self.currentMission) then return end
			
			if self.currentMission.successCondition == "USE CHARGING" or self.currentMissionId == "23" then
				self.useChargingCount = self.useChargingCount + 1
				self.currentObjectiveNum = self.currentObjectiveNum + 1
				_BattleUIManager.suddenMissionUI:Refresh()
				self:CheckMissionClear()
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEquipGunChange(EquipGunChange event)
		-- 무기 장착 변경 이벤트 처리
		local uniqueKey = event.uniqueKey
		local player = _UserService.LocalPlayer
		local battlePlayer = player.BattlePlayer
		
		if not self.isSelectedExpertWeapon then return end
		if not isvalid(self.currentMission) or not isvalid(self.currentMission.occurCondition) then
			self:SelectMission()
			
			return
		end
		
		if self.currentMissionId == "3" then 
			self.currentObjectiveNum = #table.keys(battlePlayer.equipGun)
			_BattleUIManager.suddenMissionUI:Refresh()
		elseif self.currentMissionId == "11" then 
			local allPhysicalWeapon = true
			
			for key, value in pairs(battlePlayer.equipGun) do
				if not value.isPhysicalWeapon then
					allPhysicalWeapon = false
					
					break
				end
			end
			
			if not allPhysicalWeapon then
				self:Fail()
			end
		elseif self.currentMissionId == "13" then 
			local allMagicalWeapon = true
			
			for key, value in pairs(battlePlayer.equipGun) do
				if value.isPhysicalWeapon then
					allMagicalWeapon = false
					
					break
				end
			end
			
			if not allMagicalWeapon then
				self:Fail()
			end
		end
		
		self:CheckMissionClear()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleAttackMonsterEvent(AttackMonsterEvent event)
		-- 몬스터 공격 이벤트 처리
		local currentMission = self.currentMission
		if not isvalid(currentMission) then return end
		
		if currentMission.successCondition == "ATTACK COUNT" and self.occurred then
			self.currentObjectiveNum = self.currentObjectiveNum + 1
			_BattleUIManager.suddenMissionUI:Refresh()
			self:CheckMissionClear()
		end
	end

