@Component
script AccessorySlotComponent extends Component

	property string uniqueKey = ""

	property string id = ""

	property integer slotNum = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 액세서리 슬롯 초기화 및 클릭 이벤트 설정
		local slot = self.Entity:GetChildByName("SlotEntity")
		
		slot:ConnectEvent(ButtonClickEvent, function()
			if not _UtilLogic:IsNilorEmptyString(self.uniqueKey) then
				_UIGroupManager.uiPlayerStatusPopup.accessoryInfo:SetItemId(self.uniqueKey, self.id)
				_UIGroupManager.uiPlayerStatusPopup.accessoryInfo:Show()
				
			else
				
				_UIToast:ShowMessage(_LocalizeLogic:GetText("toast1"))
			end
		end)
		
		self:SetSlot("", "")
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string uniqueKey, string id)
		-- 액세서리 슬롯에 아이템 설정
		self.uniqueKey = uniqueKey
		self.id = id
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 액세서리 슬롯 UI 갱신 (아이템 정보에 따른 표시)
		local slot = self.Entity:GetChildByName("SlotEntity")
		local slotBgRenderer = slot.SpriteGUIRendererComponent
		local sprite = slot:GetChildByName("Sprite")
		local categoryPanel = slot:GetChildByName("Category")
		local levelPanel = slot:GetChildByName("LevelPanel")
		local gradeEntity = slot:GetChildByName("Grade_Alphabet")
		local gradeEffect = slot:GetChildByName("Effect")
		
		gradeEffect.Enable = false
		
		if _UtilLogic:IsNilorEmptyString(self.uniqueKey) then
			self.Entity:GetChildByName("Empty").Enable = true
			slot.Enable = false
			
			slotBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			sprite.SpriteGUIRendererComponent.ImageRUID = ""
			levelPanel:GetChildByName("LevelText").TextComponent.Text = ""
			gradeEntity.Enable = false
		else
			self.Entity:GetChildByName("Empty").Enable = false
			
			local itemData = _ItemDataLogic.itemData[self.id]
			local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.uniqueKey]
			
			if itemData.grade == "normal" then
				slotBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			elseif itemData.grade == "rare" then
				slotBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
			elseif itemData.grade == "epic" then
				slotBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
			elseif itemData.grade == "unique" then
				slotBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
			elseif itemData.grade == "legendary" then
				slotBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
			end
			categoryPanel.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
			categoryPanel:GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryRUID(_ItemDataLogic:GetAccessoryDetailCategory(item.originalId))
			
			sprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
			sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
			levelPanel:GetChildByName("LevelText").TextComponent.Text = string.format("%d", item.level)
			
			gradeEntity.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(item.grade)
			
			if item.grade == "SSS" then
				gradeEffect.Enable = true
			end
			
			gradeEntity.Enable = true
			slot.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 액세서리 슬롯 초기화 (빈 슬롯 상태로 설정)
		self.uniqueKey = ""
		self.id = ""
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEquipEvent(EquipEvent event)
		-- 장비 착용/해제 이벤트 처리
		
		local slotNum = event.slotNum
		local isEquip = event.isEquip
		local uniqueKey = event.uniqueKey
		
		if slotNum == self.slotNum then
			if isEquip then
				self:SetSlot(uniqueKey, _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId)
			else
				self:Init()
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 빈 슬롯 클릭 시 토스트 메시지 표시
		
		local Entity = event.Entity
		
		if  _UtilLogic:IsNilorEmptyString(self.uniqueKey) then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast1"))
		end
	end

end