@Component
script KiteComponent extends Component

	property number life = 60

	property boolean kiteExist = false

	property number speed = 1

	property TransformComponent kiteTransform = nil

	property number angleCoolTime = 0

	property number angle = 0

	property number seed = 0

	property number index = 0

	property boolean isBlueDragon = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 연 컴포넌트 초기화
		
		
		self:Init()
		
			
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 연의 움직임과 생명주기를 업데이트
		self._T.lifeCoolTime = self._T.lifeCoolTime  - delta
		
		
		local transform = self.Entity.TransformComponent
		local angleOffset = -15
		local angle = math.rad(self.kiteTransform.ZRotation+angleOffset)
		
		
		local speed = self.speed
		if self._T.lifeCoolTime < 30 then
			speed = speed * 1.5
		end
		local deltaX = speed * math.sin(angle+180) * delta
		local deltaY = speed * math.cos(angle) * delta
		
		
		transform:Translate(deltaX,deltaY)
		
		
		self.angleCoolTime = self.angleCoolTime - delta
		if self._T.lifeCoolTime >  30 then
			if self.angleCoolTime < 0 then
				self.angleCoolTime = self:GetRandom() * 1 + 1		
				self.angle = self.angle  + (self:GetRandom()*2-1)  * math.pi 
			end
		end
		
		
		self.kiteTransform.ZRotation = _GameUtil:AngleLerp(angle,self.angle,delta*0.25) - angleOffset
		
		
		---@type TransformComponent
		local shadowTransform = self._T.shadow
		if self.isBlueDragon then 
			shadowTransform.ZRotation = 0
		else
			shadowTransform.ZRotation = self.kiteTransform.ZRotation
		end
		
		
		shadowTransform.WorldPosition = self.Entity.TransformComponent.Position - Vector3(-0.3,1.5,0)
	end

	method void Reset(number seed)
		-- 연의 상태를 초기화
		self.kiteTransform.Position.y = 0
		self.seed = seed
		self.index = 0
	end

	method void Init()
		-- 연 컴포넌트의 초기 설정
		if self.kiteTransform == nil then
			
			local childKite = self.Entity:GetChildByName("Kite",true)
			if isvalid(childKite) == false then
				self.Enable = false
				return
			end
		
			childKite.Visible = false
			self.kiteTransform = childKite.TransformComponent
			self.angle =  (self:GetRandom()*2-1)* math.pi 
			self.speed =self:GetRandom()* 0.5 + 1
			
			
			local shadow = childKite:Clone("shadow")
			shadow:AttachTo(self.Entity)
			shadow.SpriteRendererComponent.OrderInLayer = -1
			shadow.SpriteRendererComponent.Color = Color(0,0,0,0.3)
			
			self._T.shadow = shadow.TransformComponent
		end
		self._T.lifeCoolTime = self.life
		
		
	end

	method number GetRandom()
		-- 시드 기반 랜덤 값을 생성
		local value =  _KiteFlyEventLogic:GetRandomValue(self.seed,self.index) 
		self.index = self.index + 1
		return value
	end

	method void SetBlueDragon(boolean enable)
		-- 블루드래곤 연 모드를 설정
		self.Entity.SpriteRendererComponent.Enable = enable
		self.isBlueDragon = enable
		self.kiteTransform.Entity.Visible = not enable
		
		---@type TransformComponent
		local shadow = 	self._T.shadow 
		
		shadow.Entity.SpriteRendererComponent.SpriteRUID = enable and "2cc79c68ff6f44528382ef786849e7d5" or "6012f905a069489682f5d381e6996e5e"
	end

end