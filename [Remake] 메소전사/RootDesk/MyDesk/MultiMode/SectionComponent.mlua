@Component
script SectionComponent extends Component

	property number sectionNum = 0

	method void OnBeginPlay()
		-- 섹션 컴포넌트 초기화
		self.Entity.Visible = false
		self.Entity.Children[1]:RemoveComponent(TriggerComponent)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 섹션에 진입했을 때 데이터 업데이트
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		if TriggerBodyEntity == _UserService.LocalPlayer then
			local mapNum = _MultiMapDataLogic.multiMapData[self.Entity.CurrentMapName].mapNum
			if _UserService.LocalPlayer.PlayerFieldMapComponent.fieldMapData[mapNum][self.sectionNum] == 0 then
				TriggerBodyEntity.PlayerFieldMapComponent:UpdateData(mapNum,self.sectionNum,1)
			end
		end
	end

end