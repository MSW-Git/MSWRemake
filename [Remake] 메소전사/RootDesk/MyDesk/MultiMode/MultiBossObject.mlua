@Component
script MultiBossObject extends BossObject

	property number speed = 0

	method void OnBeginPlay()
		-- 멀티모드 보스 객체 초기화 및 AI 행동 설정
		if self:IsClient() then
			__base:OnBeginPlay()
			self.isInited = true
		else
			_TimerService:SetTimerRepeat(function() 
					local target = nil
					local users = _UserService:GetUsersByMapComponent(self.Entity.CurrentMap.MapComponent)
					local maxDist = 99999
					for k,v in pairs(users) do
						local diff = v.TransformComponent.Position - self.Entity.TransformComponent.Position
						diff.z = 0
						local dist = Vector3.Magnitude(diff)
						if Vector3.Magnitude(diff) < maxDist then
							maxDist = dist
								target = v
						end
					end
					if isvalid(target) then
						local skillTable = {"1","5","17","18","45","109","114","125","126","134","136","137"}
						local skillId = _MonsterSkillLogic.skillData[skillTable[_UtilLogic:RandomIntegerRange(1,#skillTable)]].id
						self:OnUseSkill(skillId,self.Entity.TransformComponent.Position,target,_UtilLogic:RandomIntegerRange(0,math.maxinteger))
					end
					
			end,1,1)
		end
	end

	method void UpdateMove()
		
	end

	method Vector3 GetPosition()
		return Vector3.zero
	end

	method void RefreshPostion()
		
	end

	@ExecSpace("Client")
	method void UseSkill(string skillId, Vector3 pos, Entity target)
		__base:UseSkill(skillId,pos,target)
	end

end