@Logic
script MultiMapDataLogic extends Logic

	property table multiMapData = {}

	property table barricadeData = {}

	method void OnBeginPlay()
		-- 멀티맵 데이터 및 바리케이드 데이터 초기화
		local data = _DataService:GetTable("MultiMapData")
		
		for i = 1, data:GetRowCount() do
			local key = data:GetCell(i,"mapName")
			if self.multiMapData[key] == nil then
				self.multiMapData[key] = {}
			end
			
			self.multiMapData[key].mapNum = tonumber(data:GetCell(i,"mapNum"))
			self.multiMapData[key].mapDescription = data:GetCell(i,"mapDescription")
			self.multiMapData[key].destinationPath = data:GetCell(i,"destinationPath")
			self.multiMapData[key].minimapImage = data:GetCell(i,"minimapImage")
			self.multiMapData[key].sectionNum = tonumber(data:GetCell(i,"sectionNum"))
			self.multiMapData[key].weakSection = _UtilLogic:Split(data:GetCell(i,"weakSection"),"/")
			self.multiMapData[key].npcLocation = data:GetCell(i,"merchantDestinationPath")
			self.multiMapData[key].fieldmapImage = data:GetCell(i,"fieldmapImage")
		end
		
		local barricadeData = _DataService:GetTable("BarricadeData")
		
		for i=1, barricadeData:GetRowCount() do
			local key = tonumber(barricadeData:GetCell(i,"id"))
			if self.barricadeData[key] == nil then
				self.barricadeData[key] = {}
			end
			
			self.barricadeData[key].itemId = barricadeData:GetCell(i,"itemId")
			self.barricadeData[key].level = tonumber(barricadeData:GetCell(i,"level"))
			self.barricadeData[key].price = tonumber(barricadeData:GetCell(i,"price"))
			self.barricadeData[key].name = barricadeData:GetCell(i,"name")
		end
	end

	method string GetMapNameByNum(number num)
		-- 맵 번호로 맵 이름 조회
		for key, data in pairs(self.multiMapData) do
			if data.mapNum == num then
				return key
			end
		end
	end

	method string GetMapName(string userId)
		-- 사용자 ID로 현재 맵 이름 조회
		local user = _UserService:GetUserEntityByUserId(userId)
		
		if isvalid(user) then
			for key, value in pairs(self.multiMapData) do
				if key == user.CurrentMap.Name then
					return value.mapDescription
				end
			end
		else
			return "다른 지역"
		end
	end

	method number GetCurrentMapId()
		-- 현재 맵의 ID 반환
		local currentMapname = _UserService.LocalPlayer.CurrentMapName
		return self.multiMapData[currentMapname].mapNum
	end

end