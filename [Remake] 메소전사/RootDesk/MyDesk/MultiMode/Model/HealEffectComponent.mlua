@Component
script HealEffectComponent extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerStartFrameEvent(SpriteAnimPlayerStartFrameEvent event)
		-- 힐 이펙트 애니메이션 시작 시 사운드 재생
		
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		if self.Entity.Enable == false then return end
		if self.Entity.Parent ~= _UserService.LocalPlayer then return end
		
		_SoundService:PlaySound("38c1a47d4fff4c39afffc81eea4122bd",1)
	end

end