@Component
script MultiBattleInput extends BattleInput

	property table weaponKeyboardKey = {KeyboardKey.Alpha1,KeyboardKey.Alpha2,KeyboardKey.Alpha3,KeyboardKey.Alpha4,KeyboardKey.Alpha5,KeyboardKey.Alpha6}

	property table weaponKeyboardKeyNumpad = {KeyboardKey.Keypad1,KeyboardKey.Keypad2,KeyboardKey.Keypad3,KeyboardKey.Keypad4,KeyboardKey.Keypad5,KeyboardKey.Keypad6}

	method void OnKeyDown(any key)
		-- 멀티배틀 전용 키 입력 처리
		__base:OnKeyDown(key)
		
		local multiBattlePlayer = _UserService.LocalPlayer.MultiBattlePlayer
		if isvalid(multiBattlePlayer) == false then
			return
		end
		
		for k,v in pairs(self.weaponKeyboardKey) do
			if key == v then
				multiBattlePlayer:CheckUseMultiSkill(k)	
				return
			end
		end
		for k,v in pairs(self.weaponKeyboardKeyNumpad) do
			if key == v then
				multiBattlePlayer:CheckUseMultiSkill(k)	
				return
			end
		end
		
		if key == KeyboardKey.F then
			
			multiBattlePlayer:ToggleAutoSkill()
			if multiBattlePlayer.autoSkill then
				_SoundService:PlaySound("5c127e4b02da4e65b4f46d30f885390c",1)
			else	
				_SoundService:PlaySound("a9a2d2fc4a7c43198f888330fb37c349",1)
			end
			
		elseif key == KeyboardKey.R then
			
			multiBattlePlayer:UseChargeSkill()
		end
		
		
		
		if key == KeyboardKey.Alpha7 or key == KeyboardKey.Keypad7 then
			_UserService.LocalPlayer.MultiBattlePlayer:OnUseQuickSlot(1,true,false)	
		end
		
		if key == KeyboardKey.Alpha8 or key == KeyboardKey.Keypad7 then
			_UserService.LocalPlayer.MultiBattlePlayer:OnUseQuickSlot(2,true,false)	
		end
		if key == KeyboardKey.B then
			if _UserService.LocalPlayer.PlayerControllerComponent.Enable then
				_UIGroupManager.baggageUI:Toggle()
		
			end
		end
	end

	method void OnKeyDownESC()
		
	end

	method void OnKeyDownE()
		
	end

end