@Logic
script TutorialLogic extends Logic

	property UITransformComponent TopRight = "53070bcd-ba4a-421b-948e-2322276496d7"

	property UITransformComponent TopLeft = "590f64b2-5216-4d24-8cd3-1a6fee52e2fd"

	property UITransformComponent BottomLeft = "fbdab969-7842-44cb-b53b-c73f9ac02c6f"

	property UITransformComponent BottomRight = "85e1c0e0-cfea-4744-9ab5-e6a0afeedcd0"

	property Entity parent = "d6ea22b9-c13b-4291-bab5-414b8dcef43c"

	property Entity tip = "f9a7ac71-fc28-42b8-8d2e-dfbbe488eae3"

	property Entity target = "d6ea22b9-c13b-4291-bab5-414b8dcef43c"

	property Entity group = "4942a850-7b34-4c18-a612-f7fdca15ce69"

	property UITransformComponent Highlighting = "42343540-e96c-44d2-910b-3b0248056d5f"

	property UITransformComponent Guide = "1fd8aac7-40d1-4a3f-9011-afa102274a67"

	property TextComponent GuideText = "269d82a0-cc9c-4d02-9ecd-368f7f368719"

	property SpriteGUIRendererComponent GuideIllust = "912ca511-b35f-40b8-93a8-957388dc3374"

	property boolean autoNext = false

	property Entity button = "38de4074-d367-4046-8b66-d37dca3c6186"

	property table tutorialStep = {}

	method void ShowMask(Entity target, string text, string illust, string alignment, boolean autoNext, number offsetX, number offsetY, any callback)
		-- 튜토리얼 마스크를 표시하고 가이드 UI를 대상 위치에 배치
		self.button.Enable = autoNext
		
		self._T.callback = callback
		self.target = target
		local parent = self:MirroringUIParent(target)
		local targetUI = target.UITransformComponent
		
		local width = math.abs(targetUI.RectSize.x)
		local height = math.abs(targetUI.RectSize.y)
		self:SetTargetPosition(self.TopRight.Entity,parent)
		self:SetTargetPosition(self.BottomRight.Entity,parent)
		self:SetTargetPosition(self.BottomLeft.Entity,parent)
		self:SetTargetPosition(self.TopLeft.Entity,parent)
		self:SetTargetPosition(self.Guide.Entity,parent)
		
		self.TopRight.anchoredPosition =  Vector2(-0.5 * width,height * 0.5) 
		self.BottomRight.anchoredPosition =  Vector2(0.5 * width,height * 0.5) 
		self.BottomLeft.anchoredPosition = Vector2(0.5 * width,-height * 0.5) 
		self.TopLeft.anchoredPosition = Vector2(-0.5 * width,-height * 0.5) 
		
		local SetPostion = function(entity,alignment,pivot)
			entity.UITransformComponent.AlignmentOption = alignment
			entity.UITransformComponent.Pivot = pivot
			entity.UITransformComponent.anchoredPosition = Vector2.zero + Vector2(offsetX,offsetY)
		end
		
		if alignment == "TopRight" then
			self.Guide.Entity:AttachTo(self.TopRight.Entity)
			SetPostion(self.Guide.Entity,AlignmentType.BottomLeft,self.TopRight.Pivot)
			self.Guide.Entity:AttachTo(parent)
			
		elseif alignment == "BottomRight" then
			self.Guide.Entity:AttachTo(self.BottomRight.Entity)
			SetPostion(self.Guide.Entity,AlignmentType.TopLeft,self.BottomRight.Pivot)
			self.Guide.Entity:AttachTo(parent)
			
		elseif alignment == "BottomLeft" then
			self.Guide.Entity:AttachTo(self.BottomLeft.Entity)
			SetPostion(self.Guide.Entity,AlignmentType.TopRight,self.BottomLeft.Pivot)
			self.Guide.Entity:AttachTo(parent)
			
		elseif alignment == "TopLeft" then
			self.Guide.Entity:AttachTo(self.TopLeft.Entity)
			SetPostion(self.Guide.Entity,AlignmentType.BottomRight,self.TopLeft.Pivot)
			self.Guide.Entity:AttachTo(parent)
		end
		
		self.GuideIllust.ImageRUID = illust
		self.GuideText.Text = text
		self.group.Enable = true
		
	end

	method Vector2 GetAnchoredPosition(Entity target)
		-- 대상 엔티티의 앵커 위치를 계산하여 반환
		self.tip:AttachTo(target)
		self.tip.UITransformComponent.anchoredPosition = Vector2.zero
		self.tip:AttachTo(self.parent)
		return self.tip.UITransformComponent.anchoredPosition
	end

	method void SetTargetPosition(Entity target, Entity parent)
		-- 대상 엔티티를 부모에 연결하고 위치와 스케일 초기화
		target:AttachTo(parent)
		target.UITransformComponent.anchoredPosition = Vector2.zero
		target.UITransformComponent.Scale = Vector3.one
	end

	method Entity MirroringUIParent(Entity target)
		-- 대상 UI의 부모 계층을 복제하여 튜토리얼용 미러링 UI 생성
		local parents = {}
		
		self._T.getParent = function(entity)
			if entity.UIGroupComponent ~= nil then
				return nil
			end
			table.insert(parents,entity)
			self._T.getParent(entity.Parent)
		end
		
		self._T.getParent(target)
		
		local result = self.parent
		
		local uiUpdate = {}
		
		
		for i = 1, #parents do
			---@type Entity
			local entity = parents[#parents - i + 1]
			if isvalid(entity) then
				local empty = _SpawnService:SpawnByModelId("model://uiempty",entity.Name,entity.TransformComponent.Position,result)
				local emptyUI = empty.UITransformComponent
				local entityUI = entity.UITransformComponent	
				local updateUI = function()
					emptyUI.anchoredPosition = entityUI.anchoredPosition
					
					
					emptyUI.RectSize = entityUI.RectSize
					emptyUI.AlignmentOption = entityUI.AlignmentOption
					emptyUI.OffsetMax = entityUI.OffsetMax
					emptyUI.OffsetMin = entityUI.OffsetMin
					emptyUI.Pivot = entityUI.Pivot
					emptyUI.Scale = entityUI.Scale
					
					
					emptyUI.ZRotation = entityUI.ZRotation
					emptyUI.AnchorsMin = entityUI.AnchorsMin		
					emptyUI.AnchorsMax = entityUI.AnchorsMax
				end
				table.insert(uiUpdate,updateUI)
				
				result = empty
			end
		end
		
		local updateHighlight = function() 
			self.Highlighting.Entity:AttachTo(result)
			self.Highlighting.OffsetMin = Vector2.zero
			self.Highlighting.OffsetMax = Vector2.zero
		end
		table.insert(uiUpdate,updateHighlight)
		updateHighlight()
		
		self._T.uiUpdateEventId = _TimerService:SetTimerRepeat(function() 
			
			for k,v in pairs(uiUpdate) do
				v()
			end
		
		end,0.1)
		
		
		
		return result
	end

	method void HideMask()
		-- 튜토리얼 마스크를 숨기고 관련 UI 요소들을 정리
		if self._T.uiUpdateEventId ~= nil then
			_TimerService:ClearTimer(self._T.uiUpdateEventId)
		end
		self.TopRight.Entity:AttachTo(self.group)
		self.BottomRight.Entity:AttachTo(self.group)
		self.BottomLeft.Entity:AttachTo(self.group)
		self.TopLeft.Entity:AttachTo(self.group)
		self.Guide.Entity:AttachTo(self.group)
		self.Highlighting.Entity:AttachTo(self.group)
		for k,v in pairs(self.parent.Children) do
			v:Destroy()
		end
		self.group.Enable = false
		self.target = nil
		
		if self._T.callback ~= nil then
			self._T.callback()
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 튜토리얼 단계 데이터를 로드하여 메모리에 저장
		local data = _DataService:GetTable("TutorialStep")
		
		for i = 1, data:GetRowCount() do
			local id = data:GetCell(i,"id")
			local target = data:GetCell(i,"target")
			local text = data:GetCell(i,"text")
			local ruid = data:GetCell(i,"ruid")
			local alignment = data:GetCell(i,"alignment")
			local autoNext = data:GetCell(i,"autoNext") == "true" or data:GetCell(i,"autoNext") == "TRUE"
			local highlight = data:GetCell(i,"highlight") == "true" or data:GetCell(i,"highlight") == "TRUE"
			local mask = data:GetCell(i,"mask") == "true" or data:GetCell(i,"mask") == "TRUE"
			local offsetX = data:GetCell(i,"offsetX")
			if _UtilLogic:IsNilorEmptyString(offsetX) then offsetX = 0 else offsetX = tonumber(offsetX) end
			local offsetY = data:GetCell(i,"offsetY")
			if _UtilLogic:IsNilorEmptyString(offsetY) then offsetY = 0 else offsetY = tonumber(offsetY) end
			local option = data:GetCell(i,"option")
			local localizationKey = data:GetCell(i,"localizationKey")
			
			local eachData = {}
			eachData.id = id
			eachData.target = target
			eachData.text = text
			eachData.ruid = ruid
			eachData.alignment = alignment
			eachData.autoNext = autoNext
			eachData.option = option	
			eachData.highlight = highlight		
			eachData.mask = mask	
			eachData.offsetX = offsetX
			eachData.offsetY = offsetY	
			eachData.localizationKey = localizationKey
			if self.tutorialStep[id] == nil then
				self.tutorialStep[id] = {}
			end	
			table.insert(self.tutorialStep[id],eachData)
		end
	end

	@ExecSpace("Client")
	method void StartTutorial(string key, any callback)
		-- 지정된 키의 튜토리얼을 시작하고 단계별로 진행
		local data = self.tutorialStep[key]
		if data == nil then
			return
		end
		
		self._T.startTutorial = function(index)
			local step = data[index]
			local targetPath = step.target
			local target = nil
			
			target = _EntityService:GetEntityByPath(targetPath)
			if isvalid(target) then
				self.Highlighting.Enable = step.highlight
				self.TopLeft.Entity.Visible = step.mask
				self.TopRight.Entity.Visible = step.mask
				self.BottomLeft.Entity.Visible = step.mask
				self.BottomRight.Entity.Visible = step.mask
				
				self:ShowMask(target,_LocalizationService:GetText(step.localizationKey),step.ruid,step.alignment,step.autoNext,step.offsetX,step.offsetY,function()
					
					if #data > index then
						 self._T.startTutorial(index + 1)
					else
						if callback ~= nil then
							callback()
						end
					end			
				end)
				
				if step.option == "menu" then
					if _HUDManager.panelExpandMenu.Enable == false then
						_HUDManager.panelExpandMenu.UICommonPopup:Show()
					end			
				elseif step.option == "soul_111001" then
					_UIGroupManager.uiCharacterGroup.charListSlot.Parent.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Vertical,0)
				elseif step.option == "soul_151001" then
					_UIGroupManager.uiCharacterGroup.charListSlot.Parent.ScrollLayoutGroupComponent:SetScrollNormalizedPosition(UITransformAxis.Vertical,0)
					if isvalid(_UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[151001]) == false then
						target:ConnectEvent(ButtonClickEvent,function()
							_TutorialLogic:HideMask()
							callback = function()
								self:StartTutorial("soul_151001_unavailable", function() end)
							end
						end)
					else
						target:ConnectEvent(ButtonClickEvent,function()
							_TutorialLogic:HideMask()
						end)
					end
				end
				
				if step.autoNext == false then
					if step.option == "Merge" then
						self._T.changeItemEventId = _UserService.LocalPlayer:ConnectEvent(OnChangeNewMergeItem,function(e)
						if e.itemData == nil then
							return
						end
						if e.itemData.level == 1 then
							return						
						end
						_UserService.LocalPlayer:DisconnectEvent(OnChangeNewMergeItem,self._T.changeItemEventId)
						 _TutorialLogic:HideMask()
							
						end)
					elseif step.option == "stageMove" then
						self._T.stageMoveEventId = _StageLogic:ConnectEvent(StageStartEvent,function()
							_StageLogic:DisconnectEvent(StageStartEvent,self._T.stageMoveEventId)
							 _TutorialLogic:HideMask()
						end)
					end		
				end
			end	
		end
		self._T.startTutorial(1)
	end

	@EventSender("Entity", "38de4074-d367-4046-8b66-d37dca3c6186")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 튜토리얼 버튼 클릭 시 대상 버튼의 클릭 이벤트를 발생시키고 마스크 숨김
		
		local Entity = event.Entity
		if isvalid(self.target) == false then
			return
		end
		local button = self.target
		if isvalid(button) then
			self.target:SendEvent(ButtonClickEvent(self.target))
			self:HideMask()
		end
	end

end