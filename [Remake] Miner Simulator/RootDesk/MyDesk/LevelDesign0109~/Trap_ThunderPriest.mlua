@Component
script Trap_ThunderPriest extends Component

	property string LightningRUID = "125f3181573642a5afe96dbefaaee665"

	property string spawnSound = "aea2a4bff03e4243bd0c4d0dada84f01"

	property number Cooltime = 10

	property boolean playerInTrigger = false

	property boolean OnAttack = false

	property number minBulletSpeed = 0

	property number maxBulletSpeed = 0

	property number damage = 0

	property number bulletLifetime = 0

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 원본 스프라이트 저장 및 범위 표시 활성화
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		self.Entity:GetChildByName("Range").Enable = true
	end

	@ExecSpace("Client")
	method void Lightning()
		-- 플레이어가 범위 내에 있을 때 번개 공격 실행 및 반복 공격 시작
		if self.playerInTrigger then
			self.Entity.SpriteRendererComponent.SpriteRUID = self.LightningRUID
			self.OnAttack = true
			self:RepeatLightning()
			_SoundService:PlaySound(self.spawnSound, 1)
		end
	end

	@ExecSpace("ClientOnly")
	method void RepeatLightning()
		-- 쿨타임마다 번개 공격을 반복하는 타이머 설정
		local playLightning = function()
			self:Lightning()
		end
		
		self._T.repeatTimer = _TimerService:SetTimerRepeat(playLightning, self.Cooltime, self.Cooltime)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEmbededSpriteAnimPlayerChangeFrameEvent(EmbededSpriteAnimPlayerChangeFrameEvent event)
		-- 스프라이트 애니메이션 프레임 변화 시 번개 복원 및 투사체 생성 처리
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.OnAttack and FrameIndex == 14 then
			self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			self.OnAttack = false
		elseif FrameIndex == 7 then
			local projectile = _SpawnService:SpawnByModelId("model://c8aa0b4e-32a4-4905-bb34-7ff670e3703e", "Projectile", Vector3(-0.45, 0.95, 0), self.Entity)
			projectile.TrapGuardianBullet.speed = _UtilLogic:RandomIntegerRange(self.minBulletSpeed, self.maxBulletSpeed)
			projectile.TrapGuardianBullet.damage = self.damage
			projectile.TrapGuardianBullet.lifeTime = self.bulletLifetime
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 트리거 범위에 진입 시 번개 공격 시작
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			self.playerInTrigger = true
			if not self.OnAttack then
				_TimerService:ClearTimer(self._T.repeatTimer)
				self:Lightning()
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 트리거 범위를 벗어나면 번개 공격 중지
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			self.playerInTrigger = false
			_TimerService:ClearTimer(self._T.repeatTimer)
		end
	end

end