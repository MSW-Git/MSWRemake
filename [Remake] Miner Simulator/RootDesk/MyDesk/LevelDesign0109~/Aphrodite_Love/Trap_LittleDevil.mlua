@Component
script Trap_LittleDevil extends Component

	property string spawnModelId = "model://b97d1cca-3b45-49fc-a09a-bb667956bc77"

	property string type = ""

	property number cooltime = 0

	property number dirX = 0

	property number dirY = 0

	property number arrowSpeed = 0

	property number arrowLifetime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 악마 기믹은 좌우로만 배치 (대각배치하면 스폰 로직 꼬임)
		local shot = function()
			self:SpawnArrow()
		end
		_TimerService:SetTimerRepeat(shot, self.cooltime, self.cooltime)
	end

	@ExecSpace("ClientOnly")
	method void SpawnArrow()
		-- 좌우 방향에 따라 악마 화살 생성 위치 설정 및 발사
		local spawnPos = Vector3(0,0,0)
		if self.Entity.SpriteRendererComponent.FlipX then -- 왼쪽
			spawnPos = Vector3(- 0.7, 0, 0)
		else -- 오른쪽
			spawnPos = Vector3(0.7, 0, 0)
		end
		
		local arrow = _SpawnService:SpawnByModelId(self.spawnModelId, "arrow", spawnPos, self.Entity)
		arrow.SpriteRendererComponent.SortingLayer = "Foreground"
		arrow.Trap_DevilBullet:Init(self.dirX, self.dirY, self.arrowSpeed)
		
		local destroy = function()
			if isvalid(arrow) then
				arrow:Destroy()
			end
		end
		_TimerService:SetTimerOnce(destroy, self.arrowLifetime)
	end

end