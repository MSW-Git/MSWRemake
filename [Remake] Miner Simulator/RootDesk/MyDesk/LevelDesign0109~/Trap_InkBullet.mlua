@Component
script Trap_InkBullet extends Component

	property number lifetime = 0

	property Vector2 dirVec = Vector2(0,0)

	property number damage = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 묵물 발사체 수명 타이머 설정
		local destroy = function()
			if isvalid(self.Entity) then
				_EntityService:Destroy(self.Entity)
			end
		end
		_TimerService:SetTimerOnce(destroy, self.lifetime)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 지정된 방향벡터로 매 프레임 이동
		self.Entity.TransformComponent:Translate(self.dirVec.x * delta, self.dirVec.y * delta)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어에게 묵물 발사체가 닿아 데미지 전달 후 자기 파괴
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:HitBySquid()
			_EntityService:Destroy(self.Entity)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleFootholdCollisionEvent(FootholdCollisionEvent event)
		-- 묵물 발사체가 지면이나 장애물과 충돌 시 2초 후 자동 제거
		-- Parameters
		local FootholdNormal = event.FootholdNormal
		local ImpactDir = event.ImpactDir
		local ImpactForce = event.ImpactForce
		local ReflectDir = event.ReflectDir
		local Rigidbody = event.Rigidbody
		--------------------------------------------------------
		local destroy = function()
			_EntityService:Destroy(self.Entity)
		end
		_TimerService:SetTimerOnce(destroy, 2)
	end

end