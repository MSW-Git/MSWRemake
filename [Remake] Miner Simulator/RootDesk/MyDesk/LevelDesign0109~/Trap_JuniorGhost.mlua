@Component
script Trap_JuniorGhost extends Component

	property string deadRUID = "1a8cc531541b41839418c5f985f52b38"

	property number TrapDamage = 0

	property boolean dead = false

	property number speed = 0

	@ExecSpace("Client")
	method void Destroy()
		-- 유니어 고스트를 사망 상태로 전환하여 사망 애니메이션 실행
		self.dead = true
		self.Entity.SpriteRendererComponent.SpriteRUID = self.deadRUID
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 유니어 고스트 초기화 (현재 비활성화)
		--[[local alphaUp = function()
			self.Entity.SpriteRendererComponent.Color.a = self.Entity.SpriteRendererComponent.Color.a + 0.01
		end
		
		for i = 1, 100 do
			_TimerService:SetTimerOnce(alphaUp, i * 5 / 100)	
		end]]--
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 사망하지 않았을 때 좌측으로 지속적으로 이동
		if not self.dead then
			self.Entity.TransformComponent:Translate(self.speed * delta * -1, 0 )
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 유니어 고스트에 접촉 시 게임오버 처리
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity ~= _UserService.LocalPlayer then
			return
		end
		
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and not self.dead and isvalid(self.Entity.CurrentMap.TempleHadesManager) then
			self.Entity.SpriteRendererComponent.SpriteRUID = self.deadRUID
			self.Entity.CurrentMap.TempleHadesManager.gameOver = true
			_UserService.LocalPlayer.RigidbodyComponent.Enable = false
			_UserService.LocalPlayer.MovementComponent.Enable = false
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEmbededSpriteAnimPlayerChangeFrameEvent(EmbededSpriteAnimPlayerChangeFrameEvent event)
		-- 사망 애니메이션 완료 시 엔티티 삭제
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if (self.Entity.SpriteRendererComponent.SpriteRUID == self.deadRUID) and (FrameIndex == TotalFrameCount) then
			_EntityService:Destroy(self.Entity)
		end
	end

end