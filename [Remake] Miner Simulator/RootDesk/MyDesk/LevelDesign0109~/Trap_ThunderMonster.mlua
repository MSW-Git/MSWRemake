@Component
script Trap_ThunderMonster extends Component

	property number Cooltime = 0

	property string LightningRUID = "27101c74c45d4158a905369c3a635d05"

	property string spawnSoundRUID = "a70d9a2beecb49cbbf7e773fc6eca761"

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 번개 먬스터 초기화 및 주기적 번개 공격 타이머 설정
		local playLightning = function()
			self.Entity.SpriteRendererComponent.SpriteRUID = self.LightningRUID
		end
		
		_TimerService:SetTimerRepeat(playLightning, self.Cooltime, 10)
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID 
	end

	@ExecSpace("Client")
	method void Lightning()
		-- 좌우로 확산되는 번개 발사체 생성
		local rBullet = _SpawnService:SpawnByModelId("model://0ee32f39-219c-4603-97ff-c929a4867d86", "Bullets", Vector3(0, 0.45, 1), self.Entity)
		rBullet.Trap.damage = self.damage
		
		local lBullet = _SpawnService:SpawnByModelId("model://0ee32f39-219c-4603-97ff-c929a4867d86", "Bullets", Vector3(0, 0.45, 1), self.Entity)
		lBullet.Trap.damage = self.damage
		
		rBullet.Trap_ThunderMonsterBullet.onRight = 1
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEmbededSpriteAnimPlayerChangeFrameEvent(EmbededSpriteAnimPlayerChangeFrameEvent event)
		-- 번개 애니메이션 프레임에 따라 발사체 생성 및 스프라이트 전환
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.Entity.SpriteRendererComponent.SpriteRUID == self.LightningRUID then
			if FrameIndex == 10 then
				self:Lightning()
			end
			if FrameIndex == TotalFrameCount then
				self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			end
		end
	end

end