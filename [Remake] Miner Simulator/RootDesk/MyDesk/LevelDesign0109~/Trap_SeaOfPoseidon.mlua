@Component
script Trap_SeaOfPoseidon extends Component

	property number DecreaseMpValue = 0

	property number DecreaseHpValue = 0

	@ExecSpace("Client")
	method void InToTheWater(boolean diving)
		-- 물에 진입하면 페널티 시작
		--[[
		_UserService.LocalPlayer.AvatarRendererComponent.OrderInLayer = -5
		
		local DecreaseMpPerMinute = function()
			if not _UserService.LocalPlayer.PlayerIngameData.isIngame then -- 만약 게임에서 이탈했다면, 타이머 해제
				--_TimerService:ClearTimer(self._T.funcTimer)	
			end
		
			if _UserService.LocalPlayer.PlayerIngameData.MP > 0 then -- 플레이어의 MP가 남아있다면,
				 _UserService.LocalPlayer.PlayerIngameData:UseMP(self.DecreaseMpValue)
			else
				_UserService.LocalPlayer.PlayerIngameData:Hit(self.DecreaseHpValue)
			end
		end
		
		self._T.funcTimer = _TimerService:SetTimerRepeat(DecreaseMpPerMinute, 1, 0)
		]]----[[
		--[[
		_UserService.LocalPlayer.PlayerStateAtStage:Diving(diving)
		
		if diving then
			_UserService.LocalPlayer.PlayerStateAtStage.playerInWater = diving	
			_UserService.LocalPlayer.RigidbodyComponent.IsBlockVerticalLine = true
			_UserService.LocalPlayer.AvatarRendererComponent.SortingLayer = "Layer2"
			_UserService.LocalPlayer.AvatarRendererComponent.OrderInLayer = 1
			local nameTag = _SpawnService:SpawnByModelId("model://0f543aca-7a60-4839-98d5-a220bd308c4d", "nameTag", Vector3.zero, _UserService.LocalPlayer)
			nameTag.NameTagComponent.NameTagRUID = _UserService.LocalPlayer.NameTagComponent.NameTagRUID
			nameTag.NameTagComponent.Name = _UserService.LocalPlayer.PlayerComponent.Nickname
			_UserService.LocalPlayer.NameTagComponent.Enable = false
			_UserService.LocalPlayer.RigidbodyComponent.IsBlockVerticalLine = true
			self.Entity.CurrentMap.SoundComponent.AudioClipRUID = "ade75165d86c409aa50a1115722ceb54"
			self.Entity.CurrentMap.SoundComponent.Enable = true
		else
			_UserService.LocalPlayer.PlayerStateAtStage.playerInWater = diving	
			_UserService.LocalPlayer.RigidbodyComponent.IsBlockVerticalLine = false
			_UserService.LocalPlayer.AvatarRendererComponent.SortingLayer = "Player"
			_UserService.LocalPlayer.AvatarRendererComponent.OrderInLayer = 3
			_TimerService:ClearTimer(self._T.funcTimer)
			_TimerService:ClearTimer(self._T.spawnTimer)
			_UserService.LocalPlayer.RigidbodyComponent.IsBlockVerticalLine = false
			self.Entity.CurrentMap.SoundComponent:Stop()
			if isvalid(_UserService.LocalPlayer:GetChildByName("nameTag")) then
				_UserService.LocalPlayer:GetChildByName("nameTag"):Destroy()
				_UserService.LocalPlayer.NameTagComponent.Enable = true
				self.Entity.CurrentMap.SoundComponent.Enable = false
			end
		end
		
		local SpawnBubble = function()
			self:SpawnBubble()
		end
		self._T.spawnTimer = _TimerService:SetTimerRepeat(SpawnBubble, 8, 4)
		]]--
	end

	@ExecSpace("Client")
	method void SpawnBubble()
		-- 플레이어 위치에서 물방울을 생성하여 상승 애니메이션 실행
		
		local spawnVector = Vector3(_UserService.LocalPlayer.TransformComponent.WorldPosition.x, _UserService.LocalPlayer.TransformComponent.WorldPosition.y + 0.15, 0)
		local BubbleEntity = _SpawnService:SpawnByModelId("model://649ed171-bfcc-4044-ba2a-1841a1f8782e", "AirBubble", 
		_UserService.LocalPlayer.TransformComponent.WorldPosition, self.Entity.CurrentMap)
		
		local destroyBubble = function()
			if isvalid(BubbleEntity) then
				BubbleEntity:Destroy()
			end
		end
		
		_TimerService:SetTimerOnce(destroyBubble, 10)
		
		local moveRight = function()
			if isvalid(BubbleEntity) then
				BubbleEntity.TransformComponent:Translate(0.01, 0.01)
			end
		end
		
		local moveLeft = function()
			if isvalid(BubbleEntity) then
				BubbleEntity.TransformComponent:Translate(-0.01, 0.01)
			end
		end
		
		for i = 1, 100 do
			if i % 2 == 1 then
				_TimerService:SetTimerOnce(moveRight, (i*10) / 100) -- 5초 동안
			else 
				_TimerService:SetTimerOnce(moveLeft, (i*10) / 100)
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 포세이돈의 바다 트랩 영역에 진입했을 때 다이빙 상태로 전환
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:Diving(true)
			--self:InToTheWater(true)
		end
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 물방울이나 플레이어가 바다 트랩 영역에서 벗어날 때 처리
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.Name == "AirBubble" then -- 물방울이 물에서 벗어나면 제거
			_EntityService:Destroy(TriggerBodyEntity)
		end
		
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:Diving(false)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 플레이어가 물 속에 머무를 때 렌더링 레이어와 중력 조정
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and not _UserService.LocalPlayer.PlayerStateAtStage.playerInCenterSpaceInWater then
			if TriggerBodyEntity.AvatarRendererComponent.SortingLayer ~= "Layer2" then
				TriggerBodyEntity.AvatarRendererComponent.SortingLayer = "Layer2"
			end
			if TriggerBodyEntity.AvatarRendererComponent.OrderInLayer ~= 1 then
				TriggerBodyEntity.AvatarRendererComponent.OrderInLayer = 1
			end
			if TriggerBodyEntity.RigidbodyComponent:IsOnGround() == false and TriggerBodyEntity.RigidbodyComponent.RealMoveVelocity.y < 0 then
				TriggerBodyEntity.RigidbodyComponent.Gravity = 0.8
			end
		end
		
	end

end