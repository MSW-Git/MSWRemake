@Component
script GraveStone extends Component

	property number SpawnCooltime = 0

	property string SpawnModelId = ""

	property Entity ghostEntity = nil

	property string spawnRUID = "c95cfe5026c644ab8febedd368980a8e"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 고스트가 존재하지 않을 때 스폰 타이머 카운트다운
		if not isvalid(self.ghostEntity) then
			self._T.timer = self._T.timer - delta
			if self._T.timer - delta <= 0 then
				self.Entity.SpriteRendererComponent.SpriteRUID = self.spawnRUID
				self._T.timer =  999
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 묘비 초기화 및 스폰 타이머 설정
		wait(5)
		self._T.timer = self.SpawnCooltime
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID
	end

	@ExecSpace("Client")
	method void SpawnGhost()
		-- 묘비에서 고스트 엔티티 생성 및 타이머 재설정
		
		self.ghostEntity = _SpawnService:SpawnByModelId(self.SpawnModelId, "ghost", 
		Vector3(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y, 0), self.Entity.CurrentMap)
		
		self._T.timer = self.SpawnCooltime
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEmbededSpriteAnimPlayerChangeFrameEvent(EmbededSpriteAnimPlayerChangeFrameEvent event)
		-- 스폰 애니메이션 완료 시 고스트 생성 및 원래 스프라이트로 복귀
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.Entity.SpriteRendererComponent.SpriteRUID == self.spawnRUID and FrameIndex == TotalFrameCount then
			self:SpawnGhost()
			self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
		end
	end

end