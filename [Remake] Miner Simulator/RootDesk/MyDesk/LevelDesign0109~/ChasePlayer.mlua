@Component
script ChasePlayer extends Component

	property number detectRange = 0

	property number speed = 0

	property number patrolTime = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 플레이어와의 거리를 계산하여 추격 모드 전환 판단
		if self.Entity.Trap_JuniorGhost.dead then
			return 
		end
		self._T.Proximity = _UserService.LocalPlayer.TransformComponent.WorldPosition - self.Entity.TransformComponent.WorldPosition
		self._T.Proximity.z = 0
		self._T.dist = Vector3.Magnitude(self._T.Proximity)
		
		if self.detectRange >= self._T.dist then
			self:ChasePlayer(delta, true)
			_TimerService:ClearTimer(self._T.patrolTimer)
		else
			self:ChasePlayer(delta, false)
		end 
		
	end

	@ExecSpace("Client")
	method void ChasePlayer(number delta, boolean chaseMode)
		-- 추격 모드에 따라 플레이어 추격 또는 원점 복귀 이동
		local targetUser = _UserService.LocalPlayer
		local targetPos = Vector2(targetUser.TransformComponent.WorldPosition.x, targetUser.TransformComponent.WorldPosition.y)
		local startPos = Vector2(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y)
		
		if chaseMode then
			if math.abs(targetPos.x - startPos.x) < 0.15 then
				return
			end	
			
		else
			if math.abs(self._T.originPos.x - startPos.x) < 0.01 and math.abs(self._T.originPos.y - startPos.y) < 0.01 then
				self.Entity.TransformComponent.WorldPosition.x = self._T.originPos.x
				self.Entity.TransformComponent.WorldPosition.y = self._T.originPos.y
			
				--self.patrolMode = true
				return
			end
			targetPos = self._T.originPos
		end
		
		if targetPos.x > startPos.x then -- 유저가 나보다 오른쪽에 있다면
			self:FlipX(true)
		else
			self:FlipX(false)
		end
		
		local dist = targetPos - startPos
		local moveVector = Vector2.Normalize(dist)
		
		self.Entity.TransformComponent:Translate(moveVector.x * delta * self.speed, moveVector.y * delta * self.speed)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 초기 스폰 위치를 원점으로 저장
		self._T.originPos = Vector2(self.Entity.TransformComponent.WorldPosition.x , self.Entity.TransformComponent.WorldPosition.y)
	end

	@ExecSpace("Client")
	method void FlipX(boolean dirX)
		-- 이동 방향에 따라 스프라이트 좌우 반전 제어
		if dirX then
			self.Entity.SpriteRendererComponent.FlipX = true
		else
			self.Entity.SpriteRendererComponent.FlipX = false
		end
	end

end