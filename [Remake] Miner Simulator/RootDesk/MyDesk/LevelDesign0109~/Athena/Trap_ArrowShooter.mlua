@Component
script Trap_ArrowShooter extends Component

	property string bulletId = ""

	property string shotEffectRUID = ""

	property number shotCooltime = 0

	property number arrowLifeTime = 0

	property number shotReadyTime = 0

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 화살 발사기 초기화 및 주기적 발사 타이머 설정
		if not self.Entity.SpriteRendererComponent.FlipX then
			self.Entity:GetChildByName("readyEffect").TransformComponent.Position.x = - self.Entity:GetChildByName("readyEffect").TransformComponent.Position.x
		end
		local arrowShot = function()
			self:Shot()
		end
		_TimerService:SetTimerRepeat(arrowShot, self.shotCooltime, self.shotCooltime)
	end

	@ExecSpace("Client")
	method void Shot()
		-- 화살 발사 준비 효과 표시 후 일정 시간 뒤 화살 생성 및 발사
		self.Entity:GetChildByName("readyEffect").Enable = true
		
		local dir = Vector2(0, 0)
		
		local shot = function()
			self.Entity:GetChildByName("readyEffect").Enable = false
			
			_EffectService:PlayEffect(self.shotEffectRUID, self.Entity.CurrentMap, 
			Vector3(self.Entity:GetChildByName("readyEffect").TransformComponent.WorldPosition.x, self.Entity:GetChildByName("readyEffect").TransformComponent.WorldPosition.y, 0), 0, Vector3(0.3,0.3,0), false)
			
			local arrow = _SpawnService:SpawnByModelId(self.bulletId, "arrow", Vector3(self.Entity.TransformComponent.WorldPosition.x, self.Entity.TransformComponent.WorldPosition.y, 0), self.Entity.CurrentMap)
			arrow.SpriteRendererComponent.SortingLayer = "Foreground"
			arrow.Trap.damage = self.damage
			
			if self.Entity.SpriteRendererComponent.FlipX then
				dir = Vector2(-1, 0)
				arrow.SpriteRendererComponent.FlipX = false
			else
				dir = Vector2(1, 0)
				arrow.SpriteRendererComponent.FlipX = true
			end
			
			arrow.Trap_Arrow.dir = dir
		
			local destroy = function()
				if isvalid(arrow) then
					arrow:Destroy()
				end
			end
			_TimerService:SetTimerOnce(destroy, self.arrowLifeTime)
		end
		
		_TimerService:SetTimerOnce(shot, self.shotReadyTime)
	end

end