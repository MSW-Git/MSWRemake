@Component
script RotateDegree180 extends Component

	property boolean isClockwise = false

	property number rotationSpeed = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 180도 회전 범위 내에서 시계방향/반시계방향으로 연속 회전
		-- 270 > 0 , 0 < 90
		
		if math.floor(self.Entity.TransformComponent.WorldZRotation) == 90 and self._T.rotationChange == true then
			self._T.rotationChange = false
			self.isClockwise = true
		elseif math.floor(self.Entity.TransformComponent.WorldZRotation) == 270 and self._T.rotationChange == true then
			self._T.rotationChange = false
			self.isClockwise = false
		elseif  math.floor(self.Entity.TransformComponent.WorldZRotation) == 0 then
			self._T.rotationChange = true
		end
		
		if self.isClockwise == true then
			self.Entity.TransformComponent.WorldZRotation = self.Entity.TransformComponent.WorldZRotation - delta * self.rotationSpeed
		else
			self.Entity.TransformComponent.WorldZRotation = self.Entity.TransformComponent.WorldZRotation + delta * self.rotationSpeed
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 회전 상태 초기화 및 스프라이트 투명도 설정
		self._T.rotationChange = true
		self.Entity.SpriteRendererComponent.Color.a = 0 
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어 접촉 시 회전 방향에 따라 밀어내는 힘을 가하고 상태 변경
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) then
			local dir = 0
			if self.isClockwise then
				dir = -1
			else
				dir = 1
			end
			
			if TriggerBodyEntity.StateComponent.CurrentStateName == "LADDER" or TriggerBodyEntity.StateComponent.CurrentStateName == "ROPE" then
				TriggerBodyEntity.StateComponent:ChangeState("FALL")
			end
			TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(dir * 2.5, 1))
			
		end
	end

end