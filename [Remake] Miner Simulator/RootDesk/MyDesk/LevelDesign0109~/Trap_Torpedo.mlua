@Component
script Trap_Torpedo extends Component

	property string ExploisionRUID = "b77e2f5d95a843a2af8ce6283a801bbe"

	property boolean isExplosion = false

	property number KnockbackPower = 0

	property number damage = 0

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void Explosion(Entity target)
		-- 플레이어가 어뢰에 닿았을 때 폭발 효과 실행 및 넉백 적용
		if _UserService.LocalPlayer.PlayerComponent.UserId ~= target.PlayerComponent.UserId then
			return
		end
		
		self.Entity.SpriteRendererComponent.SpriteRUID = self.ExploisionRUID
		local StandardVector = Vector2(0, 1)
		if target.PlayerControllerComponent.LookDirectionX > 0 then -- 오른쪽 볼 때,
			StandardVector.x = - StandardVector.x
		end
		
		target.RigidbodyComponent:SetForce(StandardVector * self.KnockbackPower) -- 밀쳐내기
		_EffectService:PlayEffect("94d5246047cd41708117b398bbef14ec", self.Entity, self.Entity.TransformComponent.WorldPosition, 0, Vector3.one, false)
		
		-- 타격 사운드
		_SoundService:PlaySound("5156e84e6ba74b76b1a87fdecde69df0", 0.75)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 어뢰 트랩 초기화 시 넉백 파워 설정
		self.KnockbackPower = 10
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 트리거에 진입 시 폭발 상태로 변경하고 폭발 실행
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and not self.isExplosion and TriggerBodyEntity == _UserService.LocalPlayer then
			self.isExplosion = true
			self:Explosion(TriggerBodyEntity)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerChangeFrameEvent(SpriteAnimPlayerChangeFrameEvent event)
		-- 폭발 애니메이션이 끝나면 엔터티 비활성화
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if (self.Entity.SpriteRendererComponent.SpriteRUID == self.ExploisionRUID) and (FrameIndex == TotalFrameCount) then
			self.Entity.Enable = false
		end
	end

end