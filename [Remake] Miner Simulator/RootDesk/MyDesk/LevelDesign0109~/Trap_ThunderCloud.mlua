@Component
script Trap_ThunderCloud extends Component

	property string CloudLightningRUID = ""

	property number Cooltime = 0

	property boolean OnAttack = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 천둑 구름 초기화 및 주기적 번개 공격 타이머 설정
		local playLightning = function()
			self:Lightning()
		end
		
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		
		_TimerService:SetTimerRepeat(playLightning, self.Cooltime, 1.5)
	end

	@ExecSpace("Client")
	method void Lightning()
		-- 천둥 구름 스프라이트 깜빡임 후 랜덤 위치에 번개 공격 생성
		local count = 0
		
		local ChangeRUID = function()
			count = count + 1
			if self.Entity.SpriteRendererComponent.SpriteRUID == self._T.originRUID then
				self.Entity.SpriteRendererComponent.SpriteRUID = self.CloudLightningRUID
			else
				self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			end
			
		
			if count == 20 then	
				self.OnAttack = true
				local lightningNum = _UtilLogic:RandomIntegerRange(1, #self.Entity.Children) -- 최대 생성될 번개 개수 
				local tableIndex = {}
				local lightningIndex = {}
			
				for i = 1, #self.Entity.Children do
					table.insert(tableIndex, i) -- tableIndex = {1,2,3,4,5} 
				end
		
				for i = 1, lightningNum do
					local idx = _UtilLogic:RandomIntegerRange(1, #tableIndex)
					table.insert(lightningIndex, tableIndex[idx]) -- lightningIndex = {0, 0}
					table.remove(tableIndex, idx) -- tableIndex = {0, 0, 0}
				end
				-- lightninIndex에 중복되지 않는 tableIndex의 두 값이 들어옴	
			
				for i = 1 , #lightningIndex	do
					self.Entity:GetChildByName("Lightning_"..math.floor(lightningIndex[i])).BasicParticleComponent:Play()
					self:SpawnBullet(self.Entity:GetChildByName("Lightning_"..math.floor(lightningIndex[i])))
					self.Entity:GetChildByName("Lightning_"..math.floor(lightningIndex[i])).CloudLightningTriggerCheck.selected = true
				end
				
				
				local OffAttack = function()
					self.OnAttack = false
					for i = 1 , #self.Entity.Children do
						self.Entity.Children[i].CloudLightningTriggerCheck.selected = false
					end
					-- log("감전 이펙트 종료") 번개 끝나자마자 판정 없애야 하는데 살짝 타이밍 애매할 수도?
				end
				_TimerService:SetTimerOnce(OffAttack, 0.5)
			end
		end
		
		for i = 1 , 20 do	
			_TimerService:SetTimerOnce(ChangeRUID, 0.25 * i)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SpawnBullet(Entity parents)
		-- 번개 좌우 확산용 전기 발사체 생성
		local rBullet = _SpawnService:SpawnByModelId("model://0ee32f39-219c-4603-97ff-c929a4867d86", "Bullets", Vector3(0, 0, 1), parents)
		local lBullet = _SpawnService:SpawnByModelId("model://0ee32f39-219c-4603-97ff-c929a4867d86", "Bullets", Vector3(0, 0, 1), parents)
		rBullet.Trap_ThunderMonsterBullet.onRight = 1
	end

end