@Component
script Trap_SpawnSnow extends Component

	property number minSnow = 0

	property number maxSnow = 0

	property number minPosX = 0

	property number maxPosX = 0

	property number coolTime = 0

	property number minSpd = 0

	property number maxSpd = 0

	property number lifeTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 눈 생성기 초기화 및 주기적 눈 생성 타이머 설정
		local SpawnSnow = function()
			self:SpawnSnow()
		end
		_TimerService:SetTimerRepeat(SpawnSnow, self.coolTime, 0)
	end

	@ExecSpace("Client")
	method void SpawnSnow()
		-- 지정된 범위 내에서 랜덤 개수의 눈 엔티티를 랜덤 위치에 생성
		local spawnNum = _UtilLogic:RandomIntegerRange(self.minSnow, self.maxSnow)
		
		for i = 1 , spawnNum do
			local posX = _UtilLogic:RandomIntegerRange(self.minPosX, self.maxPosX) + _UtilLogic:RandomDouble()
			local ranSpd = _UtilLogic:RandomIntegerRange(self.minSpd, self.maxSpd)
			local snow = _SpawnService:SpawnByModelId("model://762ba13a-df47-4cac-87d7-b63d8927658d", "snow", Vector3(posX, self.Entity.TransformComponent.WorldPosition.y, 0), self.Entity.CurrentMap)
			--snow.Trap_Snow.speed = ranSpd
		
			local destroy = function()
				snow:Destroy()
			end
			_TimerService:SetTimerOnce(destroy, self.lifeTime)
		end
	end

end