@Component
script Trap_SnowShooter extends Component

	property string ThrowingRUID = ""

	property string BulletModelId = "model://f97c6612-0b2d-4ca6-afc1-59d0f4dcad50"

	property number Cooltime = 10

	property boolean OnAttack = false

	property number damage = 0

	property number speed = 0

	property number lifetime = 0

	property Entity projectile = nil

	property number templeDamageRate = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 눈덩이 발사기 초기화 및 주기적 공격 타이머 설정
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		local excuteThrowing = function()
			self:Throwing()
		end
		_TimerService:SetTimerRepeat(excuteThrowing, self.Cooltime, 1.5)
	end

	@ExecSpace("Client")
	method void Throwing()
		-- 눈덩이 발사 애니메이션 시작 및 공격 상태 활성화
		self.Entity.SpriteRendererComponent.SpriteRUID = self.ThrowingRUID
		self.OnAttack = true
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEmbededSpriteAnimPlayerChangeFrameEvent(EmbededSpriteAnimPlayerChangeFrameEvent event)
		-- 공격 애니메이션 프레임에 따라 눈덩이 발사체 생성 및 스프라이트 전환
		-- Parameters/ui/IngameGroup/Blind
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.Entity.SpriteRendererComponent.SpriteRUID == self.ThrowingRUID then
		if self.OnAttack and FrameIndex == TotalFrameCount then
			self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			self.OnAttack = false
		elseif self.OnAttack and FrameIndex == 2 then
			if self.Entity.SpriteRendererComponent.FlipX then
			
				local bullet = _SpawnService:SpawnByModelId(self.BulletModelId, "Projectile", Vector3(0.85, 0.5, 0), self.Entity)
				self.projectile = bullet
				self.projectile.TrapBullet.speed = self.speed 
				self.projectile.SpriteRendererComponent.FlipX = true
			else
				
				local bullet = _SpawnService:SpawnByModelId(self.BulletModelId, "Projectile", Vector3(-0.85, 0.5, 0), self.Entity)
				self.projectile = bullet
				self.projectile.TrapBullet.speed = self.speed * -1
			
			end
			self.projectile.SpriteRendererComponent.SortingLayer = "Foreground"
			self.projectile.TrapBullet.damage = self.damage
			self.projectile.TrapBullet.surviveTime = self.lifetime	
		end
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerEndFrameEvent(SpriteAnimPlayerEndFrameEvent event)
		-- 애니메이션 종료 시 처리 (현재 비활성화)
		-- Parameters
		--[[
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.OnAttack then
			self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			self.OnAttack = false
		     -- elseif self.OnAttack and FrameIndex == 5 then
			local projectile = _SpawnService:SpawnByModelId(self.BulletModelId, "Projectile", Vector3(0, 0.5, 0), self.Entity)
			projectile.SpriteRendererComponent.SortingLayer = "Foreground"
			projectile.TrapBullet.damage = self.damage
			
			if self.Entity.SpriteRendererComponent.FlipX then
				projectile.TrapBullet.speed = self.speed 
				projectile.SpriteRendererComponent.FlipX = true
			else
				projectile.TrapBullet.speed = self.speed * -1
			end
		
			projectile.TrapBullet.surviveTime = self.lifetime
		end
		]]--
	end

end