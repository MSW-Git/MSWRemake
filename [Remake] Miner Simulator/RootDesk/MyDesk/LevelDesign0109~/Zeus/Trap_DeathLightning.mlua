@Component
script Trap_DeathLightning extends Component

	property number damage = 0

	property number templeDamageRate = 0

	property boolean init = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 초기화 시 벢개를 투명하게 설정하고 2.5초 후 발동 가능으로 설정
		self.Entity.SpriteRendererComponent.Color.a = 0
		local init = function()
			self:Init()
		end
		_TimerService:SetTimerOnce(init, 2.5)
		
	end

	@ExecSpace("Client")
	method void Init()
		-- 초기화 딱지 해제로 전기 데미지 발동 가능 상태로 전환
		self.init = true
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 플레이어가 발둥 범위에 머문 때 전기 데미지를 가하고 벢개를 완전히 만듬
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerStateAtStage) and self.init and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:ElectricDamage(self.damage, TriggerBodyEntity)
			if self.Entity.SpriteRendererComponent.Color.a ~= 1 then
				self.Entity.SpriteRendererComponent.Color.a = 1
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 발둥 범위를 벗어날 때 벢개를 다시 투명하게 설정
		--------------- Native Event Sender Info ----------------
		-- Sender: TriggerComponent
		-- Space: Server, Client
		---------------------------------------------------------
		
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		---------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerStateAtStage) and self.init and TriggerBodyEntity == _UserService.LocalPlayer then
			self.Entity.SpriteRendererComponent.Color.a = 0
		end
	end

end