@Component
script ElectricWarpSwitchInteraction extends InteractionComponent

	property Entity electricLine = nil

	property Entity electricWarp = nil

	property boolean switchOn = false

	property string onRUID = "901143c86b514a2390727f7807d51e51"

	@Sync
	property Entity guideImage = nil

	@ExecSpace("Client")
	method void Switch(boolean switch)
		-- 전기 워프 스위치를 오프에서 온으로 전환하여 워프 라인을 활성화함
		if switch then
			_EffectService:PlayEffectAttached("1fc628fe0f0d40c9bce10b1a3b434b89", self.Entity, Vector3(0,0.5,0), 0, Vector3(2,2,2))
			_SoundService:PlaySound("64dcf877864e42d7a1001597f7b69626", 2.5)
		
			self.switchOn = true
			self.Entity.SpriteRendererComponent.SpriteRUID = self.onRUID
			self.electricLine.Enable= true
			
			-- self.matchingRobot.SpriteRendererComponent.SpriteRUID = self.onRUID	
			--self.matchingRobot.ElectricWarpSwitchInteraction.switchOn = true
			--self.matchingRobot.ElectricWarpSwitchInteraction.electricWarp.ElectricWarpInteraction.usable = true
			--self.matchingRobot.ElectricWarpSwitchInteraction.electricLine.Enable = true
		
			self:destoryGuideKey()
		end
	end

	@ExecSpace("ClientOnly")
	method void destoryGuideKey()
		-- 사용 가이드 UI를 비활성화하고 숨김
		self.guideImage.Enable = false
		self.Entity:GetChildByName("Guide_Key").Enable = false
	end

	method void OnBeginPlay()
		-- 서버에서 가이드 이미지 레퍼런스를 설정
		if self:IsServer() then
			local guideImage = self.Entity:GetChildByName("GuideImage")
			self.guideImage = guideImage
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 스위치와 상호작용 시 스위치를 온으로 전환하여 워프를 활성화함
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		if self.switchOn == false then
			self:Switch(true)
			_UIToast:ShowMessage(_LocalizationService:GetText("Message_WarpSwitchOn"))
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 스위치 근처에 들어올 때 가이드 UI를 표시하고 사용법을 알림
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		
		if not self.switchOn then
			local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
			if guideKeyWorldUI == nil then
				local spawnPos = Vector3(0, 1.2, 0)
				local guideUI = _SpawnService:SpawnByModelId("model://85ad2718-739a-4bf9-aee4-f439cda53303", "Guide_Key", spawnPos, self.Entity)
				guideUI:GetChildByName("UIText").TextComponent.Text = _LocalizationService:GetText("Use")
				guideUI:GetChildByName("icon_key_E").UITransformComponent.WorldPosition.x = guideUI:GetChildByName("icon_key_E").UITransformComponent.WorldPosition.x + 0.2
				guideUI:GetChildByName("UIText").UITransformComponent.RectSize = Vector2(420, 100)
		
				if InteractionEntity ~= _UserService.LocalPlayer then
					guideUI.Enable = false
				else 
					guideUI.Enable = true
				end
			else
				guideKeyWorldUI.Enable = true
			end
		
			self.guideImage.Enable = false
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-- 스위치에서 벗어날 때 가이드 UI를 숨기고 기본 이미지를 표시
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			log("가이드 키가 없습니다.")
			return
		end
		
		if not self.switchOn then
			guideKeyWorldUI.Enable = false
			self.guideImage.Enable = true
		end
	end

end