@Component
script Trap_PillarOfFire extends Component

	property string AttackRUID = "7b72fb44b4314cbe816d4ab4ab1979da"

	property boolean OnHit = false

	property number Damage = 0

	@ExecSpace("ClientOnly")
	method void Attack()
		-- 화염 기둥 공격 애니메이션 시작
		self.Entity.SpriteRendererComponent.SpriteRUID = self.AttackRUID
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 화염 기둥 초기화 및 원본 스프라이트 저장
		self._T.originRUID = self.Entity.SpriteRendererComponent.SpriteRUID
		self._T.curFrame = 0
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 화염 기둥 연소 영역에 진입 시 화상 데미지 처리
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) 
			and self.Entity.SpriteRendererComponent.SpriteRUID == self.AttackRUID and not self.OnHit and TriggerBodyEntity == _UserService.LocalPlayer then 
			if self._T.curFrame > 2 then
				self.OnHit = true
				TriggerBodyEntity.PlayerStateAtStage:GetBurnStack(1, TriggerBodyEntity)
		 	end
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 플레이어가 화염 기둥 연소 영역에 머물 때 화상 데미지 처리
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and self.Entity.SpriteRendererComponent.SpriteRUID == self.AttackRUID 
			and not self.OnHit and TriggerBodyEntity == _UserService.LocalPlayer then
			if self._T.curFrame > 2 then
				self.OnHit = true
				TriggerBodyEntity.PlayerStateAtStage:GetBurnStack(1, TriggerBodyEntity)
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerEndFrameEvent(SpriteAnimPlayerEndFrameEvent event)
		-- 공격 애니메이션 종료 시 원래 스프라이트로 복귀 및 다음 공격 예약
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		-------------------------------------------------------
		
		if self.Entity.SpriteRendererComponent.SpriteRUID == self.AttackRUID then
			self._T.curFrame = 0
			self.Entity.SpriteRendererComponent.SpriteRUID = self._T.originRUID
			self.OnHit = false
			self.Entity.Parent.Trap_PillarManager:PlayAttack()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerChangeFrameEvent(SpriteAnimPlayerChangeFrameEvent event)
		-- 공격 애니메이션 프레임 진행 추적
		-- Parameters
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		--------------------------------------------------------
		if self.Entity.SpriteRendererComponent.SpriteRUID == self.AttackRUID then
			self._T.curFrame = FrameIndex
		end
	end

end