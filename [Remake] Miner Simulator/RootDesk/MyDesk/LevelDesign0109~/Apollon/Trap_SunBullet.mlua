@Component
script Trap_SunBullet extends Component

	property Vector2 dirVec = Vector2(0,0)

	property number lifetime = 0

	property number damage = 0

	property number speed = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 태양 총알의 방향별 이동 및 회전 효과
		self.Entity.TransformComponent:Translate(self.dirVec.x * delta * self.speed, self.dirVec.y * delta * self.speed)
		self.Entity.TransformComponent:Rotate(1)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 태양 총알 생성 시 생명주기 타이머 설정으로 자동 소멸
		local destroy = function()
			if isvalid(self.Entity) then
				_EntityService:Destroy(self.Entity)
			end
		end
		_TimerService:SetTimerOnce(destroy, self.lifetime)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어 충돌 시 화상 스택 적용, 데미지 적용 및 총알 소멸
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if isvalid(TriggerBodyEntity.PlayerControllerComponent) and TriggerBodyEntity == _UserService.LocalPlayer then
			TriggerBodyEntity.PlayerStateAtStage:GetBurnStack(1, TriggerBodyEntity)
			TriggerBodyEntity.PlayerIngameData:Hit(self.damage)
			_EntityService:Destroy(self.Entity)
		end
	end

end