@Logic
script ParsingLogic extends Logic

	method any ParseByType(string value, string typeName)
		-- 문자열 값을 지정된 타입(string, number, boolean)으로 변환하여 반환
		if typeName == "string" then
			return value
		elseif typeName == "number" then
			return tonumber(value)
		elseif typeName == "boolean" then
			return (string.lower(value) == "true")
		end
	end

	method any GetInitValueByType(string typeName)
		-- 지정된 타입의 기본 초기값을 반환 (string:"", number:0, boolean:false)
		if typeName == "string" then
			return ""
		elseif typeName == "number" then
			return 0
		elseif typeName == "boolean" then
			return false
		end
	end

end