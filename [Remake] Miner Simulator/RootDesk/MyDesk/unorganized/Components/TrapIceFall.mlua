@Component
script TrapIceFall extends Component

	property boolean fall = false

	property number fallingTime = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 떨어지는 상태일 때 매 프레임마다 떨어지는 로직 실행
		if self.fall then
			self:Falling(delta)
		end
	end

	@ExecSpace("Client")
	method void Falling(number delta)
		-- 고드름을 아래로 떨어뜨리고 5초 후에 소멸시킴
		self.fallingTime = self.fallingTime + delta
		
		local fallingDist = -0.2 * self.fallingTime
		
		self.Entity.TransformComponent:Translate(0, fallingDist)
		
		if self.fallingTime >= 5 then
			self.Entity:Destroy()
			-- log("시간이 지나서 소멸")
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "player" then
			self.fall = false
			_SoundService:PlaySound("e74dfc928e4d42169990b03e08c68308", 1)
			self.Entity:Destroy()
			local Game = _EntityService:GetEntity("cf7e8298-08f2-4352-b1bc-6a21d7d3992f")
			if Game.MiningGame.onMining == true then return end
			TriggerBodyEntity.PlayerStateAtStage:GetSnownStack(1, TriggerBodyEntity)
		--	log(_UserService.LocalPlayer.PlayerStateAtStage.IcicleCount)
		end
	end

end