@Component
script TrapGuidedMissile extends Component

	property Entity targetEntity = nil

	property number range = 0

	property boolean onTarget = false

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 유도 미사일의 대상을 로컬 플레이어로 설정
		self.targetEntity = _UserService.LocalPlayer
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 타겟과의 거리를 계산하고 사정 내에 있으면 유도 이동 수행
		local Pos = self.Entity.TransformComponent.Position
		local targetPos = self.targetEntity.TransformComponent.Position
		
		if targetPos.x - Pos.x <= self.range then
			if targetPos.y - Pos.y <= self.range then
				self.onTarget = true	
			else
				self.onTarget = false
			end
		else
			self.onTarget = false
		end
		
		if self.onTarget == true then
			self.Entity.TransformComponent.Position = Vector3.Lerp(self.Entity.TransformComponent.Position, self.targetEntity.TransformComponent.Position, 2)
		else return end
	end

end