@Component
script TrapFillWater extends Component

	property SyncTable<number> timerTable

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 물에 들어갔을 때 불 상태를 제거하거나 지역별 특수 효과 적용
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		local PlayerState = _UserService.LocalPlayer.PlayerStateAtStage
		--------------------------------------------------------
		
		if TriggerBodyEntity == _UserService.LocalPlayer then
			_SoundService:PlaySound("10a95382eab94dc88fc54b90df247962", 0.5)
			TriggerBodyEntity.PlayerStateAtStage.IgniteStack = 0
			
			if _EntityService:IsValid(TriggerBodyEntity:GetChildByName("burnEffect")) then
				_UIToast:ShowMessage(_LocalizationService:GetText("Message_RemoveFire")) 
				_UserService.LocalPlayer:GetChildByName("burnEffect"):Destroy() 
			else
				_UIToast:ShowMessage(_LocalizationService:GetText("Message_DiveInWater")) --  // Message_YorAreInWater
				--	log("Message_YouAreInWater = ", _LocalizationService:GetText("Message_YouAreInWater"))
			end
		
			if string.sub(self.Entity.CurrentMapName, -3, -3) == "8" then 
				PlayerState:RemoveThirstyStack(false)
			elseif string.sub(self.Entity.CurrentMapName, -3, -3) == "5" then
				local getWetStack = function()
					_UserService.LocalPlayer.PlayerStateAtStage:GetWetStack(true)
				end
				for i=1, 3 do
					local timer = _TimerService:SetTimerOnce(getWetStack, i)
					table.insert(self.timerTable, timer)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 플레이어가 물에서 나왔을 때 기존 타이머를 정리하고 상태 초기화
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity == _UserService.LocalPlayer then
			
			for i=1, #self.timerTable do
				_TimerService:ClearTimer(self.timerTable[i])
			end
			
			table.clear(self.timerTable)
		end
	end

end