@Component
script TrapGreatRock extends InteractionComponent

	@HideFromInspector
	property boolean IsControlMode = false

	@HideFromInspector
	property number Angle = 0

	property Vector2 StandardVector = Vector2(1,0)

	@HideFromInspector
	property Entity ControlUI = "91838847-e3af-4f04-923d-40b4205addd8"

	@ExecSpace("Client")
	method void ControlAngle(number dir)
		-- 발사각도를 좌우로 조절하고 범위를 제한
		if (dir > 0 and self.Angle < 75) or (dir < 0 and self.Angle > 0)then
			self.Angle = self.Angle + dir
		end
		
		if _UserService.LocalPlayer.ExtendPlayerControllerComponent.LookDirectionX > 0 then
			self.ControlUI:GetChildByName("AngleArrow").UITransformComponent.ZRotation = self.Angle
		else 
			self.ControlUI:GetChildByName("AngleArrow").UITransformComponent.ZRotation = -self.Angle
		end
	end

	@ExecSpace("Client")
	method void Shoot()
		-- 현재 설정된 각도로 바위 투사체를 발사
		local spawnPos = self.Entity.TransformComponent.WorldPosition
		spawnPos.y = spawnPos.y + 0.25
		
		self.IsControlMode = false
		_UserService.LocalPlayer.MovementComponent.Enable = true
		
		local rock = _SpawnService:SpawnByModelId("model://11d126cc-c8f4-4f13-a492-b95d2c1355a4",
			"GreatRock",
			spawnPos,
			self.Entity.Parent)
		
		local radianAngle = math.rad(self.Angle)
		local shootVector = Vector2(math.cos(radianAngle), math.sin(radianAngle))
		if self.StandardVector.x < 0 then
			shootVector.x = -shootVector.x
		end
		
		
		rock.RigidbodyComponent:AddForce(shootVector * 7.5)
		
		self.ControlUI.Enable = false
		
	end

	@ExecSpace("Client")
	method void Shift(number LookAtX)
		-- 플레이어의 바라보는 방향에 따라 UI와 발사 방향을 전환
		if LookAtX < 0 then
			self.StandardVector = Vector2(-1, 0)
			self.ControlUI:GetChildByName("AngleRange").SpriteGUIRendererComponent.FlipX = true
			self.ControlUI:GetChildByName("AngleArrow").SpriteGUIRendererComponent.FlipX = true
			self.ControlUI:GetChildByName("AngleArrow").UITransformComponent.ZRotation = -self.Angle
			
		else 
			self.StandardVector = Vector2(1, 0)
			self.ControlUI:GetChildByName("AngleRange").SpriteGUIRendererComponent.FlipX = false
			self.ControlUI:GetChildByName("AngleArrow").SpriteGUIRendererComponent.FlipX = false
			self.ControlUI:GetChildByName("AngleArrow").UITransformComponent.ZRotation = self.Angle
		end
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력으로 발사각도 조절과 발사를 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if self.IsControlMode == false then
			return
		end
		
		if key == KeyboardKey.UpArrow or key == KeyboardKey.W then
			self:ControlAngle(1)
			
		elseif key == KeyboardKey.DownArrow or key == KeyboardKey.S then
			self:ControlAngle(-1)
		elseif key == KeyboardKey.E then
			self:Shoot()
		end
	end

	@EventSender("Service", "InputService")
	handler HandleKeyHoldEvent(KeyHoldEvent event)
		-- 키를 지속적으로 누르고 있을 때 각도를 연속적으로 조절
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if self.IsControlMode == false then
			return
		end
		
		if key == KeyboardKey.UpArrow or key == KeyboardKey.W then
			self:ControlAngle(1)
		elseif key == KeyboardKey.DownArrow or key == KeyboardKey.S then
			self:ControlAngle(-1)
		
		end
	end

	@EventSender("LocalPlayer")
	handler HandleChangedLookAtEvent(ChangedLookAtEvent event)
		-- 플레이어가 바라보는 방향이 바뀔 때 UI를 동기화
		-- Parameters
		local LookAtX = event.LookAtX
		--------------------------------------------------------
		if self.IsControlMode == true then
			self:Shift(LookAtX)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 대포에 접근했을 때 조종 모드를 활성화
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity ~= _UserService.LocalPlayer then
			return
		end
		
		self.IsControlMode = true
		_UserService.LocalPlayer.MovementComponent.Enable = false
		self.Entity.Enable = false
		
		
		self.ControlUI.Enable = true
		
		if _UserService.LocalPlayer.ExtendPlayerControllerComponent.LookDirectionX < 0 then
			self.ControlUI:GetChildByName("AngleRange").SpriteGUIRendererComponent.FlipX = true
			self.ControlUI:GetChildByName("AngleArrow").SpriteGUIRendererComponent.FlipX = true
		else 
			self.ControlUI:GetChildByName("AngleRange").SpriteGUIRendererComponent.FlipX = false
			self.ControlUI:GetChildByName("AngleArrow").SpriteGUIRendererComponent.FlipX = false
		end
	end

end