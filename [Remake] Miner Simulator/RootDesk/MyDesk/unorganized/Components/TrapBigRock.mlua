@Component
script TrapBigRock extends Component

	property number damage = 10

	property number timer = 0

	property boolean isCool = false

	property string soundId = "020330e6d8014f63a60504beb12fcec4"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 바위를 계속 회전시키며 일정 시간마다 사운드 재생
		self.timer = self.timer - delta
		
		if self.Entity.TransformComponent.ZRotation < 360 then
			self.Entity.TransformComponent.ZRotation = self.Entity.TransformComponent.ZRotation + delta * 360
			if self.timer <= 0 then
				if _UserService.LocalPlayer.CurrentMapName == "Mine1_3" then
					_SoundService:PlaySound("0897760310ef4a60b790ce7ecfc60eb3", 1.5)
					self.isCool = false
					self.timer = 5
				end
			end
		end
		
		if self.Entity.TransformComponent.ZRotation >= 360 then
			self.Entity.TransformComponent.ZRotation = 0
			if self.timer <= 0 then
				if _UserService.LocalPlayer.CurrentMapName == "Mine1_3" then
					_SoundService:PlaySound("0897760310ef4a60b790ce7ecfc60eb3", 1.5)
					self.isCool = false
					self.timer = 5
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 바위 함정 초기화 및 쿨다운 설정
		self.timer = 5
		self.isCool = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 바위에 접촉시 대미지를 가하고 밀백 속도 제공
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if self.isCool == true then return end
		
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "player" then
			self.timer = 5
			TriggerBodyEntity.PlayerIngameData:Hit(self.damage)
			_SoundService:PlaySound(self.soundId, 1)
			if TriggerBodyEntity.PlayerControllerComponent.LookDirectionX > 0 then
				TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(5, 2))
			elseif TriggerBodyEntity.PlayerControllerComponent.LookDirectionX < 0 then
				TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(-5,	2))
			end
			self.isCool = true
		end
	end

end