@Component
script UIHelpGuideNavButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 도움말 가이드 내비게이션 버튼 클릭 시 해당 페이지로 변경
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 17, -1))
		
		_EntityService:GetEntity("8d47c3ba-1a22-47f0-8464-8e95a82503d1").UIHelpGuide:ChangePage(idx)
	end

end