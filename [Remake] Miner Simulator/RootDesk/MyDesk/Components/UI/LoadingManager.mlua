@Component
script LoadingManager extends Component

	@HideFromInspector
	property boolean isLoading = false

	@HideFromInspector
	property number time = 0

	property Entity beginAdventureButton = "94f38c08-7b86-4595-868f-1ffcf5279cef"

	@ExecSpace("Client")
	method void SetLoadingUIOn(boolean activate)
		-- 로딩 UI의 활성화 상태를 설정하고 플레이어 움직임을 제어
		local loadingUI = _EntityService:GetEntity("645244c8-7418-48ef-849c-e659d312c6a0")
		loadingUI:SetEnable(activate)
		
		self.time = 0
		
		self.isLoading = activate
		self:SetPlayerMovement(not activate)
	end

	@ExecSpace("Client")
	method void UpdateTipMessage()
		-- 무작위 팁 메시지를 생성하여 UI에 표시
		local tipMessageTable = _DataService:GetTable("TipMessage")
		local randomRange = tipMessageTable:GetRowCount()
		
		local randIdx = _UtilLogic:RandomIntegerRange(1, randomRange)
		local message = _LocalizationService:GetText(string.format("40%02d", randIdx))
		
		local tipMessageUI = _EntityService:GetEntity("89babea2-8294-44de-b1b7-08569649d9b8")
		tipMessageUI.TextComponent.Text = "[TIP] "..message
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 로딩 중일 때 4초마다 팁 메시지를 업데이트
		if self.isLoading == true then
			
			self.time = self.time + delta
			
			if self.time >= 4 then
				self.time = 0
				self:UpdateTipMessage()
			end
		end
	end

	@ExecSpace("Client")
	method void SetPlayerMovement(boolean activate)
		-- 플레이어의 움직임 컴포넌트 활성화 상태를 설정
		_UserService.LocalPlayer.MovementComponent.Enable = activate
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 로딩 상태를 초기화하고 모험 시작 버튼을 활성화
		self.isLoading = true 
		
		local beginAdventureButton = _EntityService:GetEntity("94f38c08-7b86-4595-868f-1ffcf5279cef")
		beginAdventureButton.Enable = true
		
		--[[
		if _UserService.LocalPlayer.PlayerIngameData.isIngame == false  then
			self:SetLoadingUIOn(true)
		end
		]]--
	end

	@EventSender("Entity", "94f38c08-7b86-4595-868f-1ffcf5279cef")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 모험 시작 버튼 클릭 시 게임 데이터를 초기화하고 맵 진입 UI를 표시
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerIngameData:InitIngamePropertiesOnClient()
		if string.sub(self.Entity.Name, 1, 4) == "Temp" then
			_UserService.LocalPlayer.PlayerIngameData:PopupMapEnteringUI(string.sub(self.Entity.Name, -1, -1), "Map_Temple")
		else
			_UserService.LocalPlayer.PlayerIngameData:PopupMapEnteringUI((string.sub(self.Entity.Name, -3, -1)), "Map_Mine")
		end
		self:SetLoadingUIOn(false)
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- E키 입력으로 모험을 시작할 수 있도록 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		local loadingUI = _EntityService:GetEntity("645244c8-7418-48ef-849c-e659d312c6a0")
		
		if loadingUI.Enable == true and key == KeyboardKey.E and self.beginAdventureButton.Enable == true then
			_UserService.LocalPlayer.PlayerIngameData:InitIngamePropertiesOnClient()
			if string.sub(self.Entity.Name, 1, 4) == "Temp" then
				log("제우스!")
				_UserService.LocalPlayer.PlayerIngameData:PopupMapEnteringUI(string.sub(self.Entity.Name, -1, -1), "Map_Temple")
			else
				_UserService.LocalPlayer.PlayerIngameData:PopupMapEnteringUI((string.sub(self.Entity.Name, -3, -1)), "Map_Mine")
			end
			self:SetLoadingUIOn(false)
		end
	end

end