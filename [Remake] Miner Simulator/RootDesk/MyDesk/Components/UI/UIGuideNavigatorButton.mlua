@Component
script UIGuideNavigatorButton extends Component

	property EntityRef targetPage = nil

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 가이드 내비게이션 버튼 클릭 시 대상 페이지를 활성화하고 나머지는 비활성화
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local guideUI = _EntityService:GetEntity("e66ece79-622c-4b68-9d49-07a85fcad04d")
		for i=1, 6 do
			guideUI:GetChildByName("Page_"..tostring(i)).Enable = false
		end
		
		self.targetPage.Enable = true
	end

end