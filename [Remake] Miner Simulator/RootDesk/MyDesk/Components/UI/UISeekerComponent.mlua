@Component
script UISeekerComponent extends Component

	property Vector2 Velocity = Vector2(0,0)

	property UITransformComponentRef Transform = nil

	property Vector2 target = Vector2(0,0)

	property number Addvel = 50

	property number MaxVel = 36

	property Entity effectEntity = nil

	property string removeSoundRUID = "acf66093cbbe421398da26a335f9616e"

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 타겟으로 이동하는 UI 요소의 위치 및 속도 계산
		if self.target == Vector2.zero then
			return
		end
		
		if self._T.distance == nil then
			self._T.distance = Vector2(0,0)
		end
		
		if self._T.tick == nil then
			self._T.tick = 0
		end
		
		self._T.tick = self._T.tick - delta
		if self._T.tick <= 0 then
			self:Guide(self.target, delta)
		end
		
		self.Transform.anchoredPosition.x = self.Transform.anchoredPosition.x +  self._T.distance.x * self.Velocity.x * self.Addvel
		self.Transform.anchoredPosition.y = self.Transform.anchoredPosition.y +  self._T.distance.y * self.Velocity.y * self.Addvel
		
		if self.Velocity.x <= self.MaxVel then
		self.Velocity.x = self.Velocity.x + delta * self.Addvel
		end
		if self.Velocity.y <= self.MaxVel then
		self.Velocity.y = self.Velocity.y + delta * self.Addvel
		end
		
		
		if Vector2.Distance(self.Transform.anchoredPosition, self.target) <= 36 then
			local clonedEffect = self.effectEntity:Clone()
			clonedEffect:Destroy(1)
			_SoundService:PlaySound(self.removeSoundRUID, 1)
			
			self.Entity:Destroy()
		end
	end

	method void Guide(Vector2 target, number delta)
		-- 타겟 위치를 향한 단위 벡터 계산으로 이동 방향 결정
		local distance = Vector2.Normalize((target - self.Transform.anchoredPosition))
		self._T.distance.x =  distance.x * delta
		self._T.distance.y =  distance.y * delta
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI 트랜스폼 컴포넌트 참조 설정
		self.Transform = self.Entity.UITransformComponent
	end

end