@Component
script ButtonSelect extends Component

	property boolean selected = false

	property boolean selectable = false

	@ExecSpace("Client")
	method void Select(boolean select)
		-- 버튼의 선택 상태를 설정하고 시각적으로 표시
		self.selected = select
		
		if self.selected then
			self.Entity:GetChildByName("Button_Selected"):SetEnable(true)
		else 
			self.Entity:GetChildByName("Button_Selected"):SetEnable(false)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 선택 가능 여부와 선택 상태를 초기화
		self.selectable = false
		self.selected = false
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 선택 가능한 상태일 때 버튼을 선택 상태로 변경
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.selectable then
			self:Select(true)
		end
		
	end

end