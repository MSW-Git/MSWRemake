@Component
script Portal_TownToTownInteraction extends InteractionComponent

	@Sync
	property number TownCategory = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 타운 간 이동 포털 가이드 UI 설정
		local portalGuideUI = self.Entity:GetChildByName("MinePortalGuide")
		
		if portalGuideUI == nil then
			local spawnPos = Vector3(0, 1.7, 0)
			local guideUI = _SpawnService:SpawnByModelId("model://a3e04974-9f26-4033-a3a7-cffe3b0c0cf9", "MinePortalGuide", spawnPos, self.Entity)
			
			-- 맵 이름
			local mapTable = _DataService:GetTable("Map_Town")
			local mapName = _LocalizationService:GetText(string.format("%d",7200+self.TownCategory))
			--local mapName = mapTable:GetCell(self.TownCategory, 2)
			guideUI.TextComponent.Text = mapName
		
		else 
			portalGuideUI.Enable = true
		end
	end

	@ExecSpace("Client")
	method void OnInteractionEventOnClient()
		-- 클라이언트에서 타운 간 텔레포트 실행
		-- log("텔포 시도")
		local currentTownIdx = string.sub(self.Entity.Parent.Name, 5, -1)
		if tonumber(currentTownIdx) == nil then
			currentTownIdx = "1"
		end
		
		local Player = _UserService.LocalPlayer
		
		if self.TownCategory == 1 then
			_TeleportService:TeleportToEntityPath(Player, "/maps/Town/Portal_TownToTown_"..currentTownIdx)
		else
			_TeleportService:TeleportToEntityPath(Player, "/maps/Town"..tostring(math.floor(self.TownCategory)).."/Portal_TownToTown_"..currentTownIdx)
			log("/maps/Town"..tostring(math.floor(self.TownCategory)).."/Portal_TownToTown_"..currentTownIdx)
			-- local dest = _EntityService:GetEntityByPath("/maps/Town"..tostring(math.floor(self.TownCategory)).."/Portal_TownToTown_"..currentTownIdx)
		end
	end

	@ExecSpace("Server")
	method void OnInteractionEvent(Entity player)
		-- 서버에서 타운 진입 권한 확인 후 텔레포트 허가
		if self.TownCategory ~= 1 and player.PlayerData.TownProgress[self.TownCategory] == false then
			if self.TownCategory == 10 then
				_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_CannotEnterTemple", player.OwnerId)
			else
				_CustomLocalizationLogic:SendLocalizedToastMessageFromServer("Message_CannotEnterBecauseOfKey", player.OwnerId)
			log("조건 미달")
			end
			return
		end
		
		--------------------
		self:OnInteractionEventOnClient(player.OwnerId)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 타운 포털 인터랙션 이벤트 핸들러
		self:OnInteractionEvent(_UserService.LocalPlayer)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 인터랙션 영역 진입 시 가이드 키 UI 표시
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			local spawnPos = Vector3(0, 0.75, 0)
			local guideUI = _SpawnService:SpawnByModelId("model://85ad2718-739a-4bf9-aee4-f439cda53303", "Guide_Key", spawnPos, self.Entity)
			guideUI:GetChildByName("UIText").TextComponent.Text = _LocalizationService:GetText("Go")
			
			if InteractionEntity ~= _UserService.LocalPlayer then
				guideUI.Enable = false
			else 
				guideUI.Enable = true
			end
		else
			guideKeyWorldUI.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-- 인터랙션 영역 이탈 시 가이드 키 UI 숨김
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			log("가이드 키가 없습니다.")
			return
		end
		
		guideKeyWorldUI.Enable = false
	end

end