@Component
script PortalToMineInteraction extends InteractionComponent

	property string Tag = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 타운에서 광산으로 가는 포털 가이드 UI 설정
		local portalGuideUI = self.Entity:GetChildByName("TownToMinePortalGuide")
		local mapTable = _DataService:GetTable("Map_Mine")
		
		if portalGuideUI == nil then
			local spawnPos = Vector3(0, 2.15, 0)
			local guideUI = _SpawnService:SpawnByModelId("model://588a8382-990c-4d45-8cfc-6b00b646b02b", "TownToMinePortalGuide", spawnPos, self.Entity)
			
			-- 맵 이름
			local mapName = mapTable:GetCell(tonumber(string.sub(self.Tag, 5, -1))*4 - 3, 2)
			guideUI:GetChildByName("ModelEntrancePanelMine").TextComponent.Text = _LocalizationService:GetText(mapName)
		
			-- 권장 채광력
			local minPower = tonumber(mapTable:GetCell(tonumber(string.sub(self.Tag, 5, 5))*4 - 3, 5))
			local maxPower = tonumber(mapTable:GetCell(tonumber(string.sub(self.Tag, 5, 5))*4 - 3, 6))
			local recommendInfo = ""
			local userPower = _UserService.LocalPlayer.PlayerIngameData.MiningPower
			
			if minPower <= userPower and userPower < maxPower then
				recommendInfo = "[".._LocalizationService:GetText("Recommend").."]"
			elseif minPower > userPower then
				recommendInfo = "[".._LocalizationService:GetText("Hard").."]"
			else
				recommendInfo = "[".._LocalizationService:GetText("Easy").."]"
			end
			
			guideUI:GetChildByName("WarningText").TextComponent.Text = 
				_LocalizationService:GetText("RecommendedPower").."\n".._ThousandsSeparator:ConvertToMetricPrefixString(minPower, nil).."~".._ThousandsSeparator:ConvertToMetricPrefixString(maxPower, nil).."\n"..recommendInfo
			
		else 
			portalGuideUI.Enable = true
			
			-- 권장 채광력
			local minPower = tonumber(mapTable:GetCell(tonumber(string.sub(self.Tag, 5, 5))*4 - 3, 5))
			local maxPower = tonumber(mapTable:GetCell(tonumber(string.sub(self.Tag, 5, 5))*4 - 3, 6))
			local recommendInfo = ""
			local userPower = _UserService.LocalPlayer.PlayerIngameData.MiningPower
			
			if minPower <= userPower and maxPower then
				recommendInfo = "[".._LocalizationService:GetText("Recommend").."]"
			elseif tonumber(minPower) > userPower then
				recommendInfo = "[".._LocalizationService:GetText("Hard").."]"
			else
				recommendInfo = "[".._LocalizationService:GetText("Easy").."]"
			end
			
			portalGuideUI:GetChildByName("WarningText").TextComponent.Text = 
				_LocalizationService:GetText("RecommendedPower").."\n"
				.._ThousandsSeparator:ConvertToMetricPrefixString(minPower, nil).."~".._ThousandsSeparator:ConvertToMetricPrefixString(maxPower, nil).."\n"..recommendInfo
		
		end
	end

	@ExecSpace("Client")
	method void SetLoadingUIOn(boolean activate)
		-- 광산 진입 시 로딩 UI 표시 및 플레이어 이동 비활성화
		local beginAdventureButton = _EntityService:GetEntity("94f38c08-7b86-4595-868f-1ffcf5279cef")
		beginAdventureButton.Enable = false
		
		local loadingUI = _EntityService:GetEntity("645244c8-7418-48ef-849c-e659d312c6a0")
		loadingUI:SetEnable(activate)
		
		_UserService.LocalPlayer.MovementComponent.Enable = not activate
	end

	@ExecSpace("Client")
	method void EnterToMine()
		-- 지정된 광산으로 텔레포트 및 로딩 UI 설정
		local destination = "/maps/"..self.Tag.."_1/SpawnPoint"
		
		_TeleportService:TeleportToEntityPath(_UserService.LocalPlayer, destination)
		
		-- set loading ui
		self:SetLoadingUIOn(true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 광산 진입 인터랙션 이벤트 핸들러
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		self:EnterToMine()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 인터랙션 영역 진입 시 가이드 키 UI 표시
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			local spawnPos = Vector3(0, 0.75, 0)
			local guideUI = _SpawnService:SpawnByModelId("model://85ad2718-739a-4bf9-aee4-f439cda53303", "Guide_Key", spawnPos, self.Entity)
			guideUI:GetChildByName("UIText").TextComponent.Text = _LocalizationService:GetText("Enter")
		
			if InteractionEntity ~= _UserService.LocalPlayer then
				guideUI.Enable = false
			else 
				guideUI.Enable = true
			end
		else
			guideKeyWorldUI.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-- 인터랙션 영역 이탈 시 가이드 키 UI 숨김
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			log("가이드 키가 없습니다.")
			return
		end
		
		guideKeyWorldUI.Enable = false
	end

end