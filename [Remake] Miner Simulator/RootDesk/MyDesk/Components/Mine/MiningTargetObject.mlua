@Component
script MiningTargetObject extends InteractionComponent

	@Sync
	property number level = 0

	property boolean IsKeyBox = false

	property SyncTable<string> Visitor

	method void OnBeginPlay()
		-- 채광 대상 오브젝트 초기화 및 설정
		self:SetPanel()
		if self:IsServer() and self.IsKeyBox == false then
			if string.sub(self.Entity.CurrentMapName, 1, 4) == "Temp" then
				self.level = 27 -- 신전에서는 광맥 레벨 27로 통일
			end
			self:SetSpriteRUID()
		end
		
		if self:IsClient() then
			self.ShowActionInfo = false
			
			
			-- 열쇠박스인 경우 '열쇠박스 이미지' 를 켜둠
			if self.IsKeyBox == true then
				local guideKeyImage = self.Entity:GetChildByName("Guide_KeyImage")
				
				-- 자식 엔티티가 없다면 생성
				if guideKeyImage == nil then
					local spawnPos = Vector3(-0.1, 1, 0)
					local guideUI = _SpawnService:SpawnByModelId("model://0a82aaed-2b96-42ca-858c-71430acfe40c", "Guide_KeyImage", spawnPos, self.Entity)
					guideUI.Enable = true
		
				-- 있다면 활성화
				else
					guideKeyImage.Enable = true
				end
				
			else 
				self.Entity.NameTagComponent.Name = string.format("Lv.%d %s", self.level, _LocalizationService:GetText("OreVein"))
				if self.Entity.CurrentMapName == "Temple_Poseidon_2" then
					self.Entity.NameTagComponent.Enable = false
					local tag = _SpawnService:SpawnByModelId("model://1f562590-e20c-45bb-9777-534ad1c8dd10", "nameTag", Vector3(0,-0.25,0), self.Entity)
					tag.NameTagComponent.NameTagRUID = "0032bdefb94d471a9bbde891fcca2763"
					tag.NameTagComponent.Name = string.format("Lv.%d %s", self.level, _LocalizationService:GetText("OreVein"))
				end
			end
		end
	end

	@ExecSpace("Client")
	method void SetActivateEntity(boolean enable)
		-- 채광 대상 엔티티의 활성화/비활성화 설정
		self.Entity.Enable = enable
	end

	@ExecSpace("Multicast")
	method void SetSpriteRUID()
		-- 채광 대상의 스프라이트와 렌더링 레이어 설정
		if self.level == 0 then
			log("Bonanza Level is 0")
			return 
		end
		------------------------------------------------------
		-- SpriteRUID 변경
		local miningTargetObjectTable = _DataService:GetTable("MiningTarget")
		
		local spriteRUID = miningTargetObjectTable:GetCell(self.level, 3)
		self.Entity.SpriteRendererComponent.SpriteRUID = spriteRUID
		------------------------------------------------------
		-- 레이어 순서 세팅
		self.Entity.SpriteRendererComponent.SortingLayer = "Foreground"
		
		if self.Entity.CurrentMapName == "Temple_Poseidon_2" then
			self.Entity.SpriteRendererComponent.SortingLayer = "Layer2"
		end
	end

	@ExecSpace("Server")
	method void GiveReward(string rewardType, Entity player)
		-- 채광 성공 시 플레이어에게 보상 지급 처리
		-- 현재 맵 인덱스에 따라 보상 인덱스를 결정(검증)
		local currentMine = tonumber(string.sub(self.Entity.CurrentMapName, 5, 5))
		local currentStage = tonumber(string.sub(self.Entity.CurrentMapName, 7, -1))
		local currentTempleFloor = player.PlayerIngameData.TempleFloor_Current
		
		if string.sub(self.Entity.CurrentMapName, 1, 6) == "Temple" then
			currentMine = 27
			currentStage = 6
		end 
		
		if self.IsKeyBox == false then
			if currentMine <=5 then
				self.level = (currentMine - 1)*3 + currentStage
			elseif currentMine <= 8 then
				self.level = 15 + (currentMine - 6)*2 + currentStage
			else
				self.level = 21 + currentStage
			end
		else 
			self.level = currentMine
		end
		---------------------------------------------------------------------------------------------------
		---------------------------------------------------------------------------------------------------
		-- 각 오브젝트에 방문기록을 남겨 중복 수령 방지
		---------------------------------------------------------------------------------------------------
		if self.IsKeyBox == false and not string.sub(self.Entity.CurrentMapName, 1, 6) == "Temple" then
			for i=1, #self.Visitor do
				if self.Visitor[i] == player.OwnerId then
					-- 이미 방문한 기록이 있으므로 중복 수령 방지
					return
				end
			end
			table.insert(self.Visitor, player.OwnerId)
		end
		---------------------------------------------------------------------------------------------------
		---------------------------------------------------------------------------------------------------
		-- 신전인 경우, 현재 층에 대한 기록을 남깁니다.
		if player.PlayerData.TempleRecord_Current < currentTempleFloor then
			player.PlayerData.TempleRecord_Current = currentTempleFloor
		end
		---------------------------------------------------------------------------------------------------
		---------------------------------------------------------------------------------------------------
		local miningTargetTable = _DataService:GetTable("MiningTarget")
		
		
		if rewardType == "normal" or rewardType == "bonus" then
			---------------------------------
			-- 기본 광물
			self:DropItem(player, self.level, player.OwnerId)
			for i=1, 3 do
				local amount = tonumber(miningTargetTable:GetCell(self.level, 2))
				if self.level >= 27 then -- 신전에서는 2층부터 층당 60%씩 증가합니다.
					amount = amount * (1 + 0.6 * (currentTempleFloor - 1))
				end
				local trifectaAmount = math.floor(amount/3)
				
				-- 실제 데이터에 반영합니다.
				local addItem = function()
					player.PlayerBackpack:AddItem(i, trifectaAmount)
				end
				
				_TimerService:SetTimerOnce(addItem, 0.95)
			end
			---------------------------------
			-- 특수재료
			if currentMine == 3 then
				local randomValue = _UtilLogic:RandomDouble()
				if randomValue < 0.25 then
					self:DropMaterial(player, 3)
					local addMaterial = function()
						player.PlayerStateAtStage:GetMaterial(1)
						_UIGetLog:AddLog(Color.FromHexCode("#94FFF9"), "", 1, true, "Icicle", "d660bfd2e6d44b9182f048e730db5b5f", player.OwnerId)
					end
					_TimerService:SetTimerOnce(addMaterial, 0.95)
				end
			elseif currentMine == 6 then
				if player.PlayerIngameData.MPUseRate ~= 0 then
					self:DropMaterial(player, 6)
					local addMaterial = function()
						player.PlayerStateAtStage:GetMaterial(1)
						_UIGetLog:AddLog(Color.FromHexCode("#94FFF9"), "", 1, true, "Stardust","e64e842795614536911e0df826d2c953", player.OwnerId)
					end
					_TimerService:SetTimerOnce(addMaterial, 0.95)
				end
				
			elseif currentMine == 7 then
				self:DropMaterial(player, 7, player.OwnerId)
				local addMaterial = function()
					player.PlayerStateAtStage:GetMaterial(1)
					_UIGetLog:AddLog(Color.FromHexCode("#94FFF9"), "",  1, true, "CloudPiece", "286fbd8ad97645818ef5269b67c144e6", player.OwnerId)
				end
				_TimerService:SetTimerOnce(addMaterial, 0.95)
		
			elseif string.sub(self.Entity.CurrentMapName, 1, 4) == "Temp" then
			 	local randomValue = _UtilLogic:RandomDouble()
				if randomValue <= 0.1 then -- 0.1 then -- 0.1로 수정 (황금 사과)
					self:DropMaterial(player, 0)
					local addMaterial = function()
						player.PlayerStateAtStage:GetMaterial(1)
						_UIGetLog:AddLog(Color.FromHexCode("#94FFF9"), "", 1, true, "GoldApple","301b843fc7b64332bbc2347db41a623d", player.OwnerId) -- 바꿔줘야 
					end
					_TimerService:SetTimerOnce(addMaterial, 0.95)
				end
			end
			
			---------------------------------
			-- 유적에서는 유물
			if self.level >= 22 and self.level <= 26 then
				local roomNum = tonumber(string.sub(self.Entity.CurrentMapName, 7, -1))
				
				-- 드롭 여부 결정
				local dropProbTable = _DataService:GetTable("HistoricSiteMiningTargetBonusRewardProb")
				local randValue = _UtilLogic:RandomDouble()
				local baseProb = tonumber(dropProbTable:GetCell(roomNum, 2))
				local bonusProb = player.PlayerData.BonusProbDroppingRelic
				local prob = baseProb + bonusProb
				
				if randValue < prob then
					-- 드롭하는 경우, 등급 결정
					local grade = 2
					randValue = _UtilLogic:RandomDouble()
					
					local grade1Prob = tonumber(dropProbTable:GetCell(roomNum, 3))
					local grade2Prob = grade1Prob + tonumber(dropProbTable:GetCell(roomNum, 4))
					local grade3Prob = grade2Prob + tonumber(dropProbTable:GetCell(roomNum, 5))
					local grade4Prob = grade3Prob + tonumber(dropProbTable:GetCell(roomNum, 6))
				
					if randValue <= grade1Prob then
						grade = 2
					elseif randValue <= grade2Prob then
						grade = 3
					elseif randValue <= grade3Prob then
						grade = 4
					elseif randValue <= grade4Prob then
						grade = 5
					end
					
					
					-- 드롭할 유물 결정 (중복 제거)
					local relicTable = _DataService:GetTable("Relic")
					local idxTable = {}
					
					for i=1, relicTable:GetRowCount() do
						local targeGrade = tonumber(string.sub(relicTable:GetCell(i, 4), 7, -1))
						if tonumber(grade) == targeGrade then
							if player.PlayerRelic:IsPossibleRegistToBook(i) == true then
								table.insert(idxTable, i)
							end
						end
					end
					
					
					-- 드롭할 유물이 없다면 중복 포함
					if #idxTable == 0 then
						for i=1, relicTable:GetRowCount() do
							local targeGrade = tonumber(string.sub(relicTable:GetCell(i, 4), 7, -1))
							if tonumber(grade) == targeGrade then
								table.insert(idxTable, i)
							end
						end
					end
					
					
					
					local randIdx = _UtilLogic:RandomIntegerRange(1, #idxTable)
					local resultIdx = idxTable[randIdx]
					
					
					-- 데이터 반영 + ui
					local addRelic = function()
						self:SetUI_RelicBoxResult(resultIdx, player.OwnerId)
						player.PlayerRelic:AddRelic(true, resultIdx)
					end
					_TimerService:SetTimerOnce(addRelic, 0.95)
					
					-- 클라에서 보이게 추가
					self:DropRelicBox(player, player.OwnerId)
				end	
			end
			---------------------------------------------------------------------------------------------------
			-- 낮은 확률로 젬 지급 (기본 5%, 행운에 따라 획득 확률 증가)
			local randValue = _UtilLogic:RandomDouble() * 100
			local luck = player.PlayerData.Luck
			local prob = 5 * (1 + luck/100)
			
			if randValue < prob then
				
				local randAmount = _UtilLogic:RandomIntegerRange(10, 15)
				player.PlayerStorage:AddCurrencyItems(2, randAmount, true)
				
				if randValue >= 5 then
					_UIGetLog:PrintLuckAbilityLog(player.OwnerId)
				end
			end
			---------------------------------------------------------------------------------------------------
			-- 신전에서 낮은확률로 엠블렘 지급
			if self.level >= 27 then
				local dropProb = 10*math.log10(currentTempleFloor+1)
				local randomValue = _UtilLogic:RandomDouble()*100
				if randomValue < dropProb then
					local randomEmblemIdx = _UtilLogic:RandomIntegerRange(1, 16)
					player.PlayerEmblem:AddItems(randomEmblemIdx)
					
					-- 이펙트 및 사운드 재생
					_EffectService:PlayEffectAttached("bfd3321a48d647ef84dd5c651a8dcb4a",
							player,
							Vector3.zero, 0, Vector3.one)
					
					_SoundService:PlaySound("731166a346144ab19b2c2a980f9f5084", 1, player.OwnerId)
					
					-- 공허 아이템 16 : 상징 획득 시 낮은 확률로 1개 추가 획득 
					local voidItemLv = player.PlayerVoidItem.haveItems[16]
					local voidItemTable = _DataService:GetTable("VoidItems")
					if voidItemLv > 0 then
						local initAbility = voidItemTable:GetCell(16, "InitAbility")
						local levelAbility = voidItemTable:GetCell(16, "AbilityPerLevel")
						local currentAbility = tonumber(initAbility) + tonumber(levelAbility) * voidItemLv
						
						local bonusRandValue = _UtilLogic:RandomIntegerRange(1, 100)
						if bonusRandValue <= currentAbility then
							player.PlayerEmblem:AddItems(randomEmblemIdx)
							
							_UIGetLog:PrintVoidItemLog(16, player.OwnerId)
						end
						
					end
				end
			end
		end
		---------------------------------------------------------------------------------------------------
		---------------------------------------------------------------------------------------------------	
		if rewardType == "bonus" then
			-- 보너스게임 보상 타입을 결정
			local rewardProbTable = _DataService:GetTable("MiningBonusReward")
			local randomValue = _UtilLogic:RandomDouble()
			
			
			local jewerlyProb = tonumber(rewardProbTable:GetCell(self.level, 3))
			local fossilProb = jewerlyProb + tonumber(rewardProbTable:GetCell(self.level, 4))
			local moneyBoxProb = fossilProb + tonumber(rewardProbTable:GetCell(self.level, 5))
			local relicBoxProb = moneyBoxProb + tonumber(rewardProbTable:GetCell(self.level, 6))
			local chairProb = relicBoxProb + tonumber(rewardProbTable:GetCell(self.level, 7))
			local accessoryProb = chairProb + tonumber(rewardProbTable:GetCell(self.level, 8))
		
			--[[
			local jewerlyProb = 0
			local fossilProb = 0
			local moneyBoxProb = 0
			local relicBoxProb = 0
			local chairProb = 0
			local accessoryProb = 1
			]]--
			
			
			-- 보석인 경우
			if randomValue < jewerlyProb then
				-- 원석 또는 보석 결정
				local randValue = _UtilLogic:RandomDouble()
				local dropIdx = self.level * 2 + 1
				
				
				if self.level == 1 then -- 1레벨, 20레벨, 21레벨 광맥은 원석/보석 구분 없음
					dropIdx = 4
					
				elseif self.level == 20 or self.level == 21 then -- 1레벨, 20레벨, 21레벨 광맥은 원석/보석 구분 없음
					dropIdx = self.level + 21
					
				elseif self.level >=2 and self.level <= 19 then -- 2~19레벨 광맥은 원석 또는 보석 랜덤
					if randValue < 0.9 then
						dropIdx = self.level*2 + 1
					else 
						dropIdx = self.level*2 + 2
					end
					
				elseif self.level == 27 then -- 신전에서는 인덱스 랜덤, 개수 1개 고정
					dropIdx = _UtilLogic:RandomIntegerRange(4, 42)
				end 
				
				-- 클라이언트 상에서 보석이 떨어진 것처럼 보이게 함
				self:DropJewerly(player, dropIdx) 
				
				-- 데이터 처리 (획득 처리)
				local addItem = function()
					player.PlayerBackpack:AddItem(dropIdx, 1)
				end
				_TimerService:SetTimerOnce(addItem, 0.94)
			
				
			-- 화석인 경우
			elseif randomValue < fossilProb then
				local dropIdx = _UtilLogic:RandomIntegerRange(43, 49)
				
				-- 데이터 처리 (획득 처리)
				local addItem = function()
					player.PlayerBackpack:AddItem(dropIdx, 1)
				end
				_TimerService:SetTimerOnce(addItem, 0.94)
				
				-- 떨어뜨린것처럼 보이게
				self:DropFossilBox(player, dropIdx, player.OwnerId)
			
				
			-- 골드상자인 경우		
			elseif randomValue < moneyBoxProb then
				local goldBoxRewardTable = _DataService:GetTable("GoldBoxReward")
				local localLevel = self.level
				if self.level > 21 and self.level < 27 then
					localLevel = 21
				elseif self.level >= 27 then
					localLevel = 22
				end
				
				
				
				-- 최소금액을 기준으로 100% ~ 200% 사이에서 결정한다.
				local minMoneyReward = tonumber(goldBoxRewardTable:GetCell(localLevel, 2))
				local amount = minMoneyReward * (1 + _UtilLogic:RandomDouble())
				
				-- 신전에서는 단계에 비례해 보상이 증가한다. (60%)
				if self.level >= 27 then
					amount = math.floor(amount * (1+0.6*currentTempleFloor))
				end
				
				-- 결과를 플레이어 데이터에 반영 + UI 띄우기
				local addMoney = function()
					player.PlayerData:GetMoney(amount)
					self:SetUI_GoldBoxResult(localLevel, amount, player.OwnerId)
				end		
				_TimerService:SetTimerOnce(addMoney, 0.95)
				
				-- 상자 개체 소환
				self:DropMoneyBox(player, player.OwnerId)
			
				
			-- 유물상자인 경우	
			elseif randomValue < relicBoxProb then
				
				-- 드롭할 유물 결정
				local relicTable = _DataService:GetTable("Relic")
				local idxTable = {}
				
				for i=1, relicTable:GetRowCount() do
					if relicTable:GetCell(i, 4) == "Grade_2" then
						table.insert(idxTable, i)
					end
				end
				
				local randIdx = _UtilLogic:RandomIntegerRange(1, #idxTable)
				local resultIdx = idxTable[randIdx]
				
				
				-- 데이터 반영 + ui
				local addRelic = function()
					self:SetUI_RelicBoxResult(resultIdx, player.OwnerId)
					player.PlayerRelic:AddRelic(true, resultIdx)
				end
				_TimerService:SetTimerOnce(addRelic, 0.95)
				
				
				-- 클라에서 보이게 추가
				self:DropRelicBox(player, player.OwnerId)
				
				
			-- 의자인 경우	
			elseif randomValue < chairProb then
				local chairKindNum = _DataService:GetRowCount("Chair")
				local idx = _UtilLogic:RandomIntegerRange(1, chairKindNum)
				
				player.PlayerChair:AddItem(idx)
				
				self:DropChair(player, idx)
				
			-- 장신구인 경우
			elseif randomValue < accessoryProb then
				local part = _UtilLogic:RandomIntegerRange(1, 3)
				local grade = 1
				local gradeProb = {90.0, 8.0, 1.5, 0.4, 0.1}
				
				-- 공허 아이템 10 : 장신구 획득 시 더 높은 등급을 얻을 확률 증가
				-- 일반~전설등급 드롭률을 올리고, 흔함등급 드롭률을 낮춥니다.
				local voidItemLv = player.PlayerVoidItem.haveItems[10]
				local voidItemTable = _DataService:GetTable("VoidItems")
				if voidItemLv > 0 then
					local initAbility = voidItemTable:GetCell(10, "InitAbility")
					local levelAbility = voidItemTable:GetCell(10, "AbilityPerLevel")
					local currentAbility = tonumber(initAbility) + tonumber(levelAbility) * voidItemLv
					
					local normalProbDelta = 0
					for i=2, 5 do
						local currentGradeProbDelta = gradeProb[i] * currentAbility/100 
						normalProbDelta = normalProbDelta + currentGradeProbDelta
						
						gradeProb[i] = gradeProb[i] + currentGradeProbDelta
					end
					gradeProb[1] = gradeProb[1] - normalProbDelta
				end
				
				--log("등급별 확률 = ", gradeProb[1],  gradeProb[2],  gradeProb[3],  gradeProb[4],  gradeProb[5])
				
				local gradeRandomVal = _UtilLogic:RandomIntegerRange(1, 10000)/100
				--log("랜덤값 = ", gradeRandomVal)
				local currentProb = 0
				for i=1, 5 do
					if gradeRandomVal > currentProb and gradeRandomVal <= currentProb + gradeProb[i] then
						grade = i
					end
					
					currentProb = currentProb + gradeProb[i]
				end
				
				-- 공허 아이템 효과가 적용되었다면 출력
				if grade > 1 then
					_UIGetLog:PrintVoidItemLog(10, player.OwnerId)
				end
				
				
				local set =_UtilLogic:RandomIntegerRange(1, 5) 
				
				local status = _AccessoryLogic:SetStatus(part, grade)
				player.PlayerAccessory:GetItems(part, grade, set, status)
				
				
			-- 잘못된 경우	
			else
				log("random value is wrong... = ", randomValue)
			end
			
		end
		---------------------------------------------------------------------------------------------------
		---------------------------------------------------------------------------------------------------		
		if rewardType == "key" then
			player.PlayerData:ChangeTownProgress(self.level+1)
			
			-- 1레벨 열쇠박스는 업적 목표 (광산 1-3)
			if self.level ==1 then
				player.PlayerAchievementComponent:GetProgress(2, 1)
			end
			
			self:SetUI_KeyboxSuccess(self.level, player.OwnerId)
		end
	end

	@ExecSpace("Client")
	method void DropItem(Entity ownerEntity, number targetLevel)
		-- 채광 시 기본 광물 아이템 드롭 처리
		local dropPos = Vector3(self.Entity.TransformComponent.WorldPosition.x,
			self.Entity.TransformComponent.WorldPosition.y + 0.25,
			self.Entity.TransformComponent.WorldPosition.z)
			
		local miningTargetTable = _DataService:GetTable("MiningTarget")
		local amount = tonumber(miningTargetTable:GetCell(self.level, 2))
		
		local trifectaAmount = math.floor(amount/3)
		local bonusIdx = _UtilLogic:RandomIntegerRange(1,3)
		for i=1, 3 do
			local item = _SpawnService:SpawnByModelId("model://41d3444d-2911-46f5-85a0-daa35d8570ad",
			"item",	dropPos,	self.Entity.Parent)
			
			if _UserService.LocalPlayer ~= ownerEntity then
				item.Enable = false
			end
			
			item.DroppedItem.OwnerEntity = ownerEntity
			
			if i == bonusIdx then
				item.DroppedItem:SetItemProperty(i, amount-trifectaAmount*2)
			else 
				item.DroppedItem:SetItemProperty(i, trifectaAmount)
			end
			
			item.DroppedItem:SetSpriteRUID()
		end
	end

	@ExecSpace("Client")
	method void DropJewerly(Entity ownerEntity, number dropIdx)
		-- 보너스 보상으로 보석류 아이템 드롭 처리
		local dropPos = Vector3(self.Entity.TransformComponent.WorldPosition.x,
			self.Entity.TransformComponent.WorldPosition.y + 0.25,
			self.Entity.TransformComponent.WorldPosition.z)
		
		
		local item = _SpawnService:SpawnByModelId("model://41d3444d-2911-46f5-85a0-daa35d8570ad",
				"item",
				dropPos,
				self.Entity.Parent)
				
		if _UserService.LocalPlayer ~= ownerEntity then
			item.Enable = false
		end
		
		item.DroppedItem.OwnerEntity = ownerEntity
		
		item.DroppedItem:SetItemProperty(dropIdx, 1)
