	@ExecSpace("Client")
	method void DropMaterial(Entity ownerEntity, number stage)
		-- 특수 재료 아이템 드롭 처리
		local dropPos = Vector3(self.Entity.TransformComponent.WorldPosition.x,
			self.Entity.TransformComponent.WorldPosition.y + 0.25,
			self.Entity.TransformComponent.WorldPosition.z)
		
		if stage == 6 and ownerEntity.PlayerIngameData.MPUseRate == 0 then
			return
		end
		
		
		local material = _SpawnService:SpawnByModelId("model://a58189c7-1e26-494b-8b9d-3188a77f6930",
			"Material",
			dropPos,
			self.Entity.Parent.Parent)
		
		
		
		if ownerEntity ~= _UserService.LocalPlayer then
			material.Enable = false
		end
		
		material.DroppedMaterial.OwnerEntity = ownerEntity
		
		if stage == 3 then
			material.SpriteRendererComponent.SpriteRUID = "d660bfd2e6d44b9182f048e730db5b5f"
			material.DroppedMaterial.ItemName = "고드름"
			
		elseif stage == 6 then
			material.SpriteRendererComponent.SpriteRUID = "e64e842795614536911e0df826d2c953"
			material.DroppedMaterial.ItemName = "별 조각"
			
		elseif stage == 7 then
			material.SpriteRendererComponent.SpriteRUID = "286fbd8ad97645818ef5269b67c144e6"
			material.DroppedMaterial.ItemName = "구름 조각"
			
		elseif stage == 0 then 
			material.SpriteRendererComponent.SpriteRUID = "301b843fc7b64332bbc2347db41a623d"
			material.DroppedMaterial.ItemName = "황금 사과"
		end
		
	end

