	@ExecSpace("Client")
	method void SetPanel()
		-- 채광 대상 오브젝트의 인터랙션 패널 UI 설정
		self.Entity.MiningTargetObject.ShowActionInfo = false
		local Panel = _SpawnService:SpawnByModelId("model://85ad2718-739a-4bf9-aee4-f439cda53303", "Panel", Vector3(0,0.5,0), self.Entity)
		Panel:GetChildByName("UIText").TextComponent.Text = "채광하기"
		Panel:SetEnable(false)
	end

	@ExecSpace("Server")
	method void OnInteractionEvent(Entity player, boolean isInGame)
		-- 플레이어가 채광 대상과 상호작용 시 처리
		--------------------------------------------------------
		if isInGame == false then
			return
		end
		--------------------------------------------------------
		-- 보너스게임 등장 여부 설정
		local containBonusGame = false
		local randValue = _UtilLogic:RandomDouble()
		local miningBonusProbTable = _DataService:GetTable("MiningBonusReward")
		local containProbability = tonumber(miningBonusProbTable:GetCell(self.level, 2))
		
		-- 공허 아이템 15번 효과 적용 : 보너스게임 등장 확률 증가
		local voidItemLv = player.PlayerVoidItem.haveItems[15]
		local voidItemTable = _DataService:GetTable("VoidItems")
		if voidItemLv > 0 then
			local initAbility = voidItemTable:GetCell(15, "InitAbility")
			local levelAbility = voidItemTable:GetCell(15, "AbilityPerLevel")
			local currentAbility = tonumber(initAbility) + tonumber(levelAbility) * voidItemLv
			
			local appliedProb = containProbability * (1 + currentAbility/100)
			
			if randValue >= containProbability and randValue < appliedProb then
				_UIGetLog:PrintVoidItemLog(15, player.OwnerId)
			end
			
			containProbability = appliedProb
		end
		
		if randValue < containProbability then
			containBonusGame = true
		end
		--------------------------------------------------------
		-- 맵에 따라 레벨 검증
		-- 현재 맵 인덱스에 따라 레벨 인덱스를 결정(검증)
		local currentMine = tonumber(string.sub(self.Entity.CurrentMapName, 5, 5))
		local currentStage = tonumber(string.sub(self.Entity.CurrentMapName, 7, -1))
		if string.sub(self.Entity.CurrentMapName, 1, 6) == "Temple" then
			currentMine = 1
			currentStage = 1 
		end 
		--------------------------------------------------------
		self:OnInteractionEventOnClient(containBonusGame, currentMine, currentStage, player.OwnerId)
	end

	@ExecSpace("Client")
	method void OnInteractionEventOnClient(boolean containBonusGame, number mine, number stage)
		-- 클라이언트에서 채광 미니게임 시작 처리
		if _UserService.LocalPlayer.MovementComponent.Enable == false then
			--채광 중에도 E키로 초기화되어버리는 버그 수정
			return
		end
		
		--------------------------------------
		if mine <=5 then
			self.level = (mine - 1)*3 + stage
		elseif mine <= 8 then
			self.level = 15 + (mine - 6)*2 + stage
		else
			self.level = 21+stage
		end
		
		--------------------------------------
		
		local miningGameUI = _EntityService:GetEntity("cf7e8298-08f2-4352-b1bc-6a21d7d3992f")
		
		-- 열쇠박스가 아니고, '신난다' 모드라면 바로 채광됨
		if self.IsKeyBox == false and _UserService.LocalPlayer.PlayerStateAtStage.ExitedMode_LeftTime > 0 then
			_EffectService:PlayEffectAttached("cb9cff6c57fd4cb18a05db3d47277031", _UserService.LocalPlayer, Vector3.zero, 0, Vector3.one)
			_SoundService:PlaySound("fde27ff3991f4cf4a8218f61058db1d0", 1)
			self:GiveReward("normal", _UserService.LocalPlayer)
			self.Entity:SetEnable(false)
			return
		end
		
		
		-- 플레이어 움직임 제한
		_UserService.LocalPlayer.MovementComponent.Enable = false
		
		-- 타겟을 이 엔티티로 설정
		miningGameUI.MiningGame.TargetEntity = self.Entity
		
		-- 미니게임 팝업 등장
		if self.IsKeyBox == true then
			miningGameUI.MiningGame:InitMinningGame(mine, self.IsKeyBox, containBonusGame)
		else 
			miningGameUI.MiningGame:InitMinningGame(self.level, self.IsKeyBox, containBonusGame)
		end
		
		miningGameUI.MiningGame.onMining = true
		miningGameUI:SetEnable(true)
		
		if self.IsKeyBox == false then
			self.Enable = false
		end
	end

	@ExecSpace("Server")
	method void RemoveVisitRecord(string playerId)
		-- 플레이어의 채광 대상 방문 기록 제거
		local idx = 0
		for i=1, #self.Visitor do
			if self.Visitor[i] == playerId then
				idx = i
				break
			end
		end
		
		if idx ~= 0 then
			table.remove(self.Visitor, idx)
			--log("테이블에서 지웠습니다")
		end
	end

	@ExecSpace("Client")
	method void SetUI_GoldBoxResult(number level, number amount)
		-- 골드박스 개봉 결과 UI 표시
		local resultUI = _EntityService:GetEntity("54996a97-addd-483d-98bb-1fda7c4b94bc")
		resultUI:SetEnable(true)
		------------------------------
		local titleUI = _EntityService:GetEntity("63f877a5-d9c2-43b0-b5b6-a68075b3a235")
		local amountUI = _EntityService:GetEntity("014751fa-c4ea-415d-85b8-0aa33ed022a4")
		
		--------------------------------
		titleUI.TextComponent.Text = _LocalizationService:GetTextFormat("Message_GoldBoxOpen", string.format("%d", level))
		--string.format(_LocalizationService:GetText("Message_GoldBoxOpen"), level)
		amountUI.TextComponent.Text = string.format("+ %s", _ThousandsSeparator:ConvertToMetricPrefixString(amount, nil))
		--------------------------------
		local DisableUI = function()
			resultUI.Enable = false
		end
		
		_TimerService:SetTimerOnce(DisableUI, 3.5)
	end

	@ExecSpace("Client")
	method void SetUI_RelicBoxResult(number resultIdx)
		-- 유물박스 개봉 결과 UI 표시
		local relicTable = _DataService:GetTable("Relic")
		local gradeTable = _DataService:GetTable("GradeIconback")
		
		-- 결과 팝업 UI 
		local boxResultUI = _EntityService:GetEntity("1d2caece-bf8b-4dbe-b0f1-f5acfa8df0c2")
		local panelUI = boxResultUI:GetChildByName("Panel")
		
		local iconBackUI = panelUI:GetChildByName("iconBack")
		local iconUI = panelUI:GetChildByName("icon")
		local nameUI = panelUI:GetChildByName("Name")
		local titleUI = panelUI:GetChildByName("Title")
		
		local name = relicTable:GetCell(resultIdx, 1)
		local iconRUID = relicTable:GetCell(resultIdx, 2)
		local grade = relicTable:GetCell(resultIdx, 4)
		
		local gradeNum = tonumber(string.sub(grade, 7, -1))
		local iconbackRUID = gradeTable:GetCell(gradeNum, "iconback")
		local gradeColor = gradeTable:GetCell(gradeNum, "color")
		
		nameUI.TextComponent.Text = _LocalizationService:GetText(name)
		iconUI.SpriteGUIRendererComponent.ImageRUID = iconRUID
		titleUI.TextComponent.Text = _LocalizationService:GetTextFormat("Message_GetRelicItem", _LocalizationService:GetText(grade))
		iconBackUI.SpriteGUIRendererComponent.ImageRUID = iconbackRUID
		titleUI.TextComponent.FontColor = Color.FromHexCode(gradeColor)
		
		boxResultUI:SetEnable(true)
		--------------------------------
		-- 끄기 예약
		local DisableUI = function()
			boxResultUI.Enable = false
		end
		
		_TimerService:SetTimerOnce(DisableUI, 3.5)
	end

	method void Init()
		-- 채광 대상 오브젝트 초기화 (인스펙터에서 사용)
		self:SetPanel()
		if self:IsServer() and self.IsKeyBox == false then
			self:SetSpriteRUID()
		end
		
		if self:IsClient() then
			self.ShowActionInfo = false
			
			
			-- 열쇠박스인 경우 '열쇠박스 이미지' 를 켜둠
			if self.IsKeyBox == true then
				local guideKeyImage = self.Entity:GetChildByName("Guide_KeyImage")
				
				-- 자식 엔티티가 없다면 생성
				if guideKeyImage == nil then
					local spawnPos = Vector3(-0.1, 1, 0)
					local guideUI = _SpawnService:SpawnByModelId("model://0a82aaed-2b96-42ca-858c-71430acfe40c", "Guide_KeyImage", spawnPos, self.Entity)
					guideUI.Enable = true
		
				-- 있다면 활성화
				else
					guideKeyImage.Enable = true
				end
				
			else 
				self.Entity.NameTagComponent.Name = string.format("Lv.%d %s", self.level, _LocalizationService:GetText("OreVein"))
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 채광 대상과 상호작용 이벤트 처리
		if _UserService.LocalPlayer.PlayerIngameData.isIngame == false then
			return
		end
		
		self:OnInteractionEvent(_UserService.LocalPlayer, _UserService.LocalPlayer.PlayerIngameData.isIngame)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEnterEvent(InteractionEnterEvent event)
		-- 채광 대상에 근접 시 가이드 UI 표시
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if guideKeyWorldUI == nil then
			local spawnPos = Vector3(0, 1.25, 0)
			local guideUI = _SpawnService:SpawnByModelId("model://85ad2718-739a-4bf9-aee4-f439cda53303", "Guide_Key", spawnPos, self.Entity)
			
			if self.IsKeyBox == true then
				guideUI:GetChildByName("UIText").TextComponent.Text = _LocalizationService:GetText("InteractionGuideText_MiningKeyBox")
		
				
				local guideKeyImage = self.Entity:GetChildByName("Guide_KeyImage")
				guideKeyImage.Enable = false
			else 
				guideUI:GetChildByName("UIText").TextComponent.Text = _LocalizationService:GetText("InteractionGuideText_Mining")
			end
			
		
			if InteractionEntity ~= _UserService.LocalPlayer then
				guideUI.Enable = false
			else 
				guideUI.Enable = true
			end
		else
			guideKeyWorldUI.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionLeaveEvent(InteractionLeaveEvent event)
		-- 채광 대상에서 멀어질 때 가이드 UI 비활성화
		-- Parameters
		local InteractionEntity = event.InteractionEntity
		--------------------------------------------------------
		local guideKeyWorldUI = self.Entity:GetChildByName("Guide_Key")
		
		if self.IsKeyBox == true then
			local guideKeyImage = self.Entity:GetChildByName("Guide_KeyImage")
			guideKeyImage.Enable = true
		end
		
		
		if guideKeyWorldUI == nil then
			log("가이드 키가 없습니다.")
			return
		end
		
		guideKeyWorldUI.Enable = false
	end

end