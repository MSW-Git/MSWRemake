@Component
script DroppedChair extends Component

	property number itemIdx = 0

	property Entity OwnerEntity = nil

	@ExecSpace("Client")
	method void SetSpriteRUID()
		-- 드롭된 의자의 스프라이트 설정
		local chairTable = _DataService:GetTable("Chair")
		
		self.Entity.SpriteRendererComponent.SpriteRUID = chairTable:GetCell(self.itemIdx, 2)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 드롭된 의자가 플레이어를 따라가고 자동 픽업
		local frame = 0
		
		local chasePlayer = function()
			frame = frame + 1
			local playerPos = self.OwnerEntity.TransformComponent.WorldPosition
			local dir = playerPos - self.Entity.TransformComponent.WorldPosition
			dir = dir * (frame/30)
			
			self.Entity.TransformComponent:Translate(dir.x, dir.y)
		end
		
		for i=1, 30 do
			_TimerService:SetTimerOnce(chasePlayer, i/30)
		end
		-----------------------------
		local autoPickup = function()
			--_UserService.LocalPlayer.PlayerChair:AddItem(self.itemIdx)
			
			local chairTable = _DataService:GetTable("Chair")
			local itemName = chairTable:GetCell(self.itemIdx, 1)
			local itemIcon = chairTable:GetCell(self.itemIdx, 2)
			local flavorText = chairTable:GetCell(self.itemIdx, 4)
			
			local effectPos = Vector3(0, 0.25, 0)
			_EffectService:PlayEffectAttached("0017802d10d94bf8919a3bc1a309a752", 
				self.OwnerEntity, effectPos,	 0, Vector3.one)
			
			_EntityService:Destroy(self.Entity)
		end
		
		_TimerService:SetTimerOnce(autoPickup, 0.95)
		-----------------------------
	end

	@ExecSpace("Client")
	method void SetItemProperty(number itemIdx)
		-- 드롭된 의자의 인덱스 설정
		self.itemIdx = itemIdx
	end

end