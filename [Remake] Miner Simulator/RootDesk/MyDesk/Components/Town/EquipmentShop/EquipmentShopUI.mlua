		--------------------------------------------------------
		self:ChangeFilter(4)
	end

	@EventSender("Entity", "ef25004f-25f8-4d49-b4c6-4048d15da3b6")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 장비 상세 정보 팝업에서 구매 버튼 클릭 시 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local LvNTypeTxt = _EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop/DetailInfoPopup/Panel/Level&Type").TextComponent.Text
		local toolStr_S, toolStr_E = string.find(LvNTypeTxt, " ")
		
		local level = tonumber(string.sub(LvNTypeTxt, 4, toolStr_S-1))
		
		-- 증가한 능력치 및 레벨을 데이터 추가 전 미리 계산
		local beforeAbility1 = 0
		local beforeAbility2 = 0
		
		
		-- 구매한 장비 타입에 따라 증가한 능력치가 다르므로 구분해줌
		if self.filterIdx == 1 then
			self.beforeAbility1 = _UserService.LocalPlayer.PlayerIngameData.MiningPower
			_UserService.LocalPlayer.PlayerData:AddEquipment(1, level)
			self.recentBuyType = 1
		elseif self.filterIdx == 2 then
			self.beforeAbility1 = _UserService.LocalPlayer.PlayerIngameData.HPMax
			_UserService.LocalPlayer.PlayerData:AddEquipment(2, level)
			self.recentBuyType = 2
		elseif self.filterIdx == 3 then
			self.beforeAbility1 = _UserService.LocalPlayer.PlayerBackpack.maxStorageNum
			_UserService.LocalPlayer.PlayerData:AddEquipment(3, level)
			self.recentBuyType = 3
		elseif self.filterIdx == 4 then
			self.beforeAbility1 = _UserService.LocalPlayer.MovementComponent.InputSpeed
			self.beforeAbility2 = _UserService.LocalPlayer.PlayerIngameData.MPMax
			_UserService.LocalPlayer.PlayerData:AddEquipment(4, level)
			self.recentBuyType = 4
		end
		
		self.recentBuyIndex = level
		------------------------------------------------------------
		-- 상세 정보 팝업 닫기
		local detailInfoPopup = _EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop/DetailInfoPopup")
		detailInfoPopup.Enable = false
		-------------------------------------------------------------------------
	end

	@EventSender("Entity", "363707fb-de14-4f62-9da8-01c313c305e5")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 번들 구매 버튼 클릭 시 체크 상태 초기화하고 팝업 표시
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		for i=1, 40 do
			self.oneshot_checked[i] = false
		end
		self:RefreshBundlePurchasePopup()
		_EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop/BundlePurchasePopup").Enable = true
	end

	@EventSender("Entity", "fa2281ca-ea10-4c42-991d-2a78cfc5af35")
	handler HandleButtonClickEvent11(ButtonClickEvent event)
		-- 번들 구매 팝업에서 구매 확정 버튼 클릭 시 실제 구매 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local parameterTable = _UtilLogic:TableToString(self.oneshot_checked)
		_UserService.LocalPlayer.PlayerData:PurchaseEquipmentBundle(self.filterIdx,parameterTable)
	end

	@EventSender("Entity", "412c763f-222c-4374-9be3-b63722147f63")
	handler HandleButtonClickEvent12(ButtonClickEvent event)
		-- 구매 결과창에 생성해두었던 슬롯들을 모두 제거
		local purchasedList = _EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop/BundlePurchaseResultPopup/Panel/EquipmentIconList")
		
		for i=#purchasedList.Children, 1, -1 do
			local childName = purchasedList.Children[i].Name
			if childName ~= "Slot" then
				purchasedList.Children[i]:Destroy()
			end
		end
		
		-- 체크 해제
		for i=1, 40 do
			self.oneshot_checked[i] = false
		end
	end

	@EventSender("Entity", "e49e92f8-f380-4cad-89b3-fadcb4efffea")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 상점을 닫으면 묶음구매를 닫습니다.
		for i=1, 40 do
			self.oneshot_checked[i] = false
		end
		local bundlePurchasePopup = _EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop/BundlePurchasePopup")
		bundlePurchasePopup.Enable = false
	end

end