		--------------------------------------------------------
		self:ChangeFilter(2)
	end

	@EventSender("Entity", "18bc30cf-a6b1-4a62-8e0d-20672fbabb1f")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 필터 버튼 3번(액세서리) 클릭 시 해당 장비 종류로 전환
