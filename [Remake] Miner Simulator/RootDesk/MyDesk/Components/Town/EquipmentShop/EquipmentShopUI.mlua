	@EventSender("Entity", "b504628b-1dc7-4e54-a54c-e877e1ec2a2a")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 필터 버튼 4번(스킹) 클릭 시 해당 장비 종류로 전환
