	@EventSender("Entity", "c2e2057a-9ec1-4eaf-89bc-e65a8eb0d0f9")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 재분배 실행 버튼 클릭 시 신석 재분배 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		Entity.Enable = false
		
		-- 조건 검증
		local canRedistribution = false
		for i=1, 8 do
			if self.redistributionChecked[i] == true then
				canRedistribution = true
				break
			end
		end
		
		if canRedistribution == false then
			return
		end
		
		_UserService.LocalPlayer.PlayerMythicEquipment:RedistributionPowerOfGod(self.filterIdx, _UtilLogic:TableToString(self.redistributionChecked))
	end

	@EventSender("Entity", "6388f23d-d9fd-457e-b7c3-d530c259b5f7")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- 언락을 시도합니다.
		--------------------------------------------------------
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerMythicEquipment:UnlockUpgradeLimit()
		Entity.ButtonComponent.Enable = false
		
		local buttonEnable = function()
			Entity.ButtonComponent.Enable = true
		end
		_TimerService:SetTimerOnce(buttonEnable, 3)
	end

	@EventSender("Entity", "172f9718-22cf-46bf-a9bd-38a28c6ce75b")
	handler HandleButtonClickEvent11(ButtonClickEvent event)
