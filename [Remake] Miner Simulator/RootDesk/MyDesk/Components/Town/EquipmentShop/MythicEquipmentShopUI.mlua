	@EventSender("Entity", "b54fb897-7052-44f5-9d1c-d4b4662d4454")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 재분배 버튼 클릭 시 신석 재분배 팝업 표시
