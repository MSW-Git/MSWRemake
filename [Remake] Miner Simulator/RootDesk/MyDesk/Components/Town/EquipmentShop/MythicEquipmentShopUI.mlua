	@EventSender("Entity", "dc919fe2-4b9c-4aa1-a302-2bb270561234")
	handler HandleButtonClickEvent14(ButtonClickEvent event)
		-- 레벨 업 버튼 클릭 시 업그레이드 레벨 1단계 증가
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local currentLevel = _UserService.LocalPlayer.PlayerMythicEquipment.EquipmentLevel[self.filterIdx]
		local targetLevel = currentLevel + self.upgradeLevel + 1
		if targetLevel > _UserService.LocalPlayer.PlayerMythicEquipment.PurchaseUnlockedLevel then
			return
		end
		
		self.upgradeLevel = self.upgradeLevel + 1
		self:SetUpgradeCheckPopup()
	end

	@EventSender("Entity", "bd54b52d-4173-4c5c-b690-6dcdbdd46386")
	handler HandleButtonClickEvent15(ButtonClickEvent event)
		-- 최대 레벨 버튼 클릭 시 사용 가능한 최대 레벨로 업그레이드 설정
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local userMoney = _UserService.LocalPlayer.PlayerData.Money
		local currentLevel = _UserService.LocalPlayer.PlayerMythicEquipment.EquipmentLevel[self.filterIdx]
		
		
		-- 공허 아이템 19 : 신화장비 레벨업 비용 감소
		local purchaseCostRate = 1.0
		local voidItemLv = _UserService.LocalPlayer.PlayerVoidItem.haveItems[19]
		local voidItemTable = _DataService:GetTable("VoidItems")
		if voidItemLv == nil then
			return
		end
		if voidItemLv > 0 then
			local initAbility = voidItemTable:GetCell(19, "InitAbility")
			local levelAbility = voidItemTable:GetCell(19, "AbilityPerLevel")
			local currentAbility = tonumber(initAbility) + tonumber(levelAbility) * voidItemLv
			
			purchaseCostRate = 1 - currentAbility/100
		end
		
		
		
		local cost = 0
		local level = 1
		while true do
			local targetLevel = currentLevel + level
			local currentCost = purchaseCostRate * 150000000000 * (1 + 0.6*(targetLevel-1))
		
			if targetLevel > _UserService.LocalPlayer.PlayerMythicEquipment.PurchaseUnlockedLevel then
				level = level - 1
				break
			end
			
			
			if (cost+currentCost) > userMoney then
				level = level - 1
				break
			else 
				level = level + 1
				cost = cost + currentCost
			end
		end
		
		self.upgradeLevel = level
		self:SetUpgradeCheckPopup()
	end

	@EventSender("Entity", "404b7c7d-bac6-4c98-908d-a77ee28cba0f")
	handler HandleButtonClickEvent16(ButtonClickEvent event)
		-- 레벨 다운 버튼 클릭 시 업그레이드 레벨 1단계 감소
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		if self.upgradeLevel <=1  then
			return
		end
		
		self.upgradeLevel = self.upgradeLevel - 1
		self:SetUpgradeCheckPopup()
	end

	@EventSender("Entity", "a8329a41-c71d-494a-a180-50c93cbd09e4")
	handler HandleButtonClickEvent17(ButtonClickEvent event)
		-- 최소 레벨 버튼 클릭 시 업그레이드 레벨을 1로 리셋
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		self.upgradeLevel = 1
		self:SetUpgradeCheckPopup()
	end

	@EventSender("Entity", "64699a95-c9f4-4df2-b3aa-ba6d2617bea2")
	handler HandleButtonClickEvent18(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 UI 새로고침
		self:RefreshUI()
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 상세 정보 패널 또는 UI 닫기
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape and self.IsPlayingDirection == false then
			
			if self.beadsDetailInfoPanel.Enable == true then
				self.beadsDetailInfoPanel.Enable = false
			else 
				self.Entity.Enable = false
			end
			
		end
	end

end