@Component
script EquipmentShopSlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 장비샵 아이템 슬롯 버튼 클릭 시 상세 정보 팝업 표시
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		-- Get Index
		local underbarS, underbarE = string.find(Entity.Name, "_")
		local idxStr = string.sub(Entity.Name, underbarS+1, -1)
		
		local slotIdx = -1
		if string.sub(idxStr, 1, 1) == "_" then
			slotIdx = tonumber(string.sub(idxStr, -1, -1))
		else 
			slotIdx = tonumber(idxStr)
		end
		
		local equipShopUI = _EntityService:GetEntityByPath("/ui/EquipShopGroup/EquipShop")
		equipShopUI.EquipmentShopUI:ShowDetailPopup(slotIdx)
	end

end