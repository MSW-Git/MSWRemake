@Component
script ChairStorageUI extends Component

	property number showingIdx = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 의자 보관함 UI 초기화 - 의자 슬롯들을 복제하여 리스트 생성
		local chairTable = _DataService:GetTable("Chair")
		local listSlot = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/Panel_right/ListPanel/Slot")
		for i=1, chairTable:GetRowCount() do
			local clonedSlot = listSlot:Clone("Slot_"..tostring(i))
			
			clonedSlot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = chairTable:GetCell(i, 2)
			clonedSlot:GetChildByName("EquipedItem"):SetEnable(false)
			clonedSlot:GetChildByName("outline"):SetEnable(false)
		end
		
	end

	@ExecSpace("Client")
	method void RefreshUI()
		-- 전체 UI 새로고침 - 장착 의자, 보유 리스트, 능력치, 수집 개수 업데이트
		local haveChairs = _UserService.LocalPlayer.PlayerChair.haveItem
		local equipedChair = _UserService.LocalPlayer.PlayerChair.equipedIdx
		local chairTable = _DataService:GetTable("Chair")
		local abilityIconTable = _DataService:GetTable("AbilityIcon")
		
		local abilities = {}
		for i=1, 13 do
			abilities[i] = 0
		end
		
		local holdingQuantity = 0
		------------------------------------------------------
		-- 현재 장착중인 의자 정보 갱신
		local equipedIcon = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/BuffPanel/EquipedSlot/Icon")
		local equipedBuffInfo = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/BuffPanel/ActiveBuffSlot")
		
		
		
		local equipedIdx = _UserService.LocalPlayer.PlayerChair.equipedIdx
		if equipedIdx == nil or equipedIdx == 0 then
			equipedIcon.SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
			
			for i=1, 2 do
				local abilitySlot = equipedBuffInfo:GetChildByName("Slot_"..tostring(i))
				
				abilitySlot:GetChildByName("Name").TextComponent.Text = ""
				abilitySlot:GetChildByName("Num").TextComponent.Text = ""
				abilitySlot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
			end
		else
			equipedIcon.SpriteGUIRendererComponent.ImageRUID = chairTable:GetCell(equipedIdx, "iconRUID")
			
			for i=1,2 do
				local abilitySlot = equipedBuffInfo:GetChildByName("Slot_"..tostring(i))
		
				local abilityType = chairTable:GetCell(equipedIdx, 2*i+16)
				local abilityAmount = chairTable:GetCell(equipedIdx, 2*i+17)
				
				if abilityType ~= nil and abilityType ~= "" then
					abilitySlot:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(abilityType)
					abilitySlot:GetChildByName("Num").TextComponent.Text = string.format("+ %.2f%%", tonumber(abilityAmount))
					abilitySlot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = abilityIconTable:GetCell(tonumber(abilityType) - 8000, 2)
				else
					abilitySlot:GetChildByName("Name").TextComponent.Text = ""
					abilitySlot:GetChildByName("Num").TextComponent.Text = ""
					abilitySlot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
				end
			end 
		end
		------------------------------------------------------
		-- 의자 보유 목록 갱신
		local listPanel = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/Panel_right/ListPanel")
		for i=1, chairTable:GetRowCount() do
			local slot = listPanel:GetChildByName("Slot_"..tostring(i))
			
			if haveChairs[i] == true then
				slot:GetChildByName("Icon").SpriteGUIRendererComponent.Color = Color(1, 1, 1, 1)
				slot.ButtonComponent.Enable = true
				
				for j=1, 2 do
					local abilityType = chairTable:GetCell(i, 2*j+12)
					local abilityAmount = chairTable:GetCell(i, 2*j+13)
					
					if abilityType ~= "" then
						local idx = tonumber(string.sub(abilityType, 3, 4))
						abilities[idx] = abilities[idx] + tonumber(abilityAmount)
					end
				end
				
				holdingQuantity = holdingQuantity + 1
				
			else 
				slot:GetChildByName("Icon").SpriteGUIRendererComponent.Color = Color(0, 0, 0, 0.4)
				slot.ButtonComponent.Enable = false 
			end
			
			local equipedText = slot:GetChildByName("EquipedItem")
			
			if equipedChair == i then
				equipedText.Enable = true
			else 
				equipedText.Enable = false
			end
			
			if self.showingIdx == i then
				slot:GetChildByName("outline").Enable = true
			else
				slot:GetChildByName("outline").Enable = false
			end
			
		end
		
		_EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/DetailInfoPopup").Enable = false
		------------------------------------------------------
		-- 수집한 능력치 패널 갱신
		local abilityListPanel = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/AbilityPanel/List")
		local originalSlot = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/AbilityPanel/List/Slot")
		local keys = table.keys(abilities)
		local data = table.values(abilities) 
		for i=1, #abilities do
			local slot = abilityListPanel:GetChildByName("Slot_"..tostring(i))
			if slot == nil then
				slot = originalSlot:Clone("Slot_"..tostring(i)) 
			end
			
			slot:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(tostring(math.floor(8000+i)))
			slot:GetChildByName("Num").TextComponent.Text = "+"..data[i].."%"
			slot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _DataService:GetCell("AbilityIcon", i, 2)
			
			if data[i] == 0 then
				slot.Enable = false
			else 
				slot.Enable = true
			end
		end
		------------------------------------------------------
		-- 수집 개수 갱신
		_EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/Panel_right/AchievementRate/Achievement").TextComponent.Text = string.format("%d / 30", holdingQuantity)
		_EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/Panel_right/AchievementRate/Fill").UITransformComponent.RectSize.x = 390 * (holdingQuantity/30)
	end

	@ExecSpace("Client")
	method void ShowDetailInfoPopup(number slotIdx)
		-- 의자 상세 정보 팝업 표시 - 이름, 설명, 능력치, 버프들을 표시
		local chairTable = _DataService:GetTable("Chair")
		local abilityIconTable = _DataService:GetTable("AbilityIcon")
		local detailPopup = _EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage/Panel/DetailInfoPopup")
		self.showingIdx = slotIdx
		self:RefreshUI()
		---------------------------------------------------------------------------------------
		for i=1, 2 do
			local abilityEntity = detailPopup:GetChildByName("AbilitySlot_"..tostring(i))
			
			local abilityType = chairTable:GetCell(slotIdx, 2*i+12)
			local abilityAmount = chairTable:GetCell(slotIdx, 2*i+13)
			
			if abilityType ~= nil and abilityType ~= "" then
				abilityEntity:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(abilityType)
				abilityEntity:GetChildByName("Num").TextComponent.Text = string.format("+ %.2f%%", tonumber(abilityAmount))
				abilityEntity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = abilityIconTable:GetCell(tonumber(abilityType) - 8000, 2)
			else
				abilityEntity:GetChildByName("Name").TextComponent.Text = ""
				abilityEntity:GetChildByName("Num").TextComponent.Text = ""
				abilityEntity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
			end
		end
		
		---------------------------------------------------------------------------------------
		for i=1, 2 do
			local abilityEntity = detailPopup:GetChildByName("BuffSlot_"..tostring(i))
			local abilityType = chairTable:GetCell(slotIdx, 2*i+16)
			local abilityAmount = chairTable:GetCell(slotIdx, 2*i+17)
			
			if abilityType ~= nil and abilityType ~= "" then
				abilityEntity:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(abilityType)
				abilityEntity:GetChildByName("Num").TextComponent.Text = string.format("+ %.2f%%", tonumber(abilityAmount))
				abilityEntity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = abilityIconTable:GetCell(tonumber(abilityType) - 8000, 2)
			else
				abilityEntity:GetChildByName("Name").TextComponent.Text = ""
				abilityEntity:GetChildByName("Num").TextComponent.Text = ""
				abilityEntity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = "3e9d52ed52d64794bbd6f72bab8ee3d9"
			end
		end
		
		local i = slotIdx
		---------------------------------------------------------------------------------------
		detailPopup:GetChildByName("IconBack"):GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = chairTable:GetCell(i, 2)
		detailPopup:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(chairTable:GetCell(i, 1))
		detailPopup:GetChildByName("FlavorBG"):GetChildByName("FlavorText").TextComponent.Text = _LocalizationService:GetText(chairTable:GetCell(i, 6))
		
		if slotIdx == _UserService.LocalPlayer.PlayerChair.equipedIdx then
			detailPopup:GetChildByName("Button_Equip").ButtonComponent.Enable = false
		else 
			detailPopup:GetChildByName("Button_Equip").ButtonComponent.Enable = true
		end
		--------------------------------------------------------------------------------
		detailPopup.Enable = true
	end

	@EventSender("Entity", "7526f98d-6326-44f4-b6f9-1e24163546a6")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기/취소 버튼 클릭 - 선택 인덱스 리셋 및 UI 새로고침
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		self.showingIdx = 0
		self:RefreshUI()
	end

	@EventSender("Entity", "039ecd42-c043-49eb-b76a-50789ec126b1")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 장착 버튼 클릭 - 선택된 의자로 장착 대상 변경
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerChair:ChangeEquipedItem(self.showingIdx)
	end

	@EventSender("Entity", "7dd02be3-8e22-4f72-a915-381c6bbe463a")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 아마 상세 팝업 닫기 버튼 - 선택 인덱스 리셋 및 UI 새로고침
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		self.showingIdx = 0
		self:RefreshUI()
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 의자 보관함 UI 닫기
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape then
			self.Entity.Enable = false
		end
	end

end