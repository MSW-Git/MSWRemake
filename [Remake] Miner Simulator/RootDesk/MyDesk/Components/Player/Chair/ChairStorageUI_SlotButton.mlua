@Component
script ChairStorageUI_SlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 의자 슬롯 버튼 클릭 시 해당 의자의 상세 정보 팝업 표시
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local slotIdx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/InventoryGroup/ChairStorage").ChairStorageUI:ShowDetailInfoPopup(slotIdx)
	end

end