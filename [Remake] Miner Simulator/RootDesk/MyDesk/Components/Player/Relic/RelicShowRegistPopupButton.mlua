@Component
script RelicShowRegistPopupButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 유물 등록 팝업 버튼 클릭 시 해당 슬롯과 재료 인덱스를 전달하여 등록 팝업 표시
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local slotIdx = tonumber(string.sub(Entity.Parent.Name, 6, -1))
		local registIdx = tonumber(string.sub(Entity.Name, -1, -1))
		
		_EntityService:GetEntity("71a64caf-bdc5-48a3-95f2-e3b201d90948").RelicBookUI:ShowRegistrationPopup(slotIdx, registIdx)
	end

end