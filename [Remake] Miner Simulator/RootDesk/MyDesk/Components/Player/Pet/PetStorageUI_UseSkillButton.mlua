@Component
script PetStorageUI_UseSkillButton extends Component

	property boolean State = false

	property Entity circle = nil

	@ExecSpace("Client")
	method void PlayUseSkillButtonAnim(boolean afterState)
		-- 펫 스킬 사용 버튼의 ON/OFF 상태에 따른 애니메이션과 시각적 업데이트
		if afterState == nil then
			return
		end
		
		-- 텍스트 관련 값을 적용합니다.
		if afterState == true then
			self.Entity.TextComponent.Text = _LocalizationService:GetText("ON")
			self.Entity.TextComponent.Padding.right = 0
			self.Entity.TextComponent.Padding.left  = 30
			
		else
			self.Entity.TextComponent.Text = _LocalizationService:GetText("OFF") 
			self.Entity.TextComponent.Padding.right = 30
			self.Entity.TextComponent.Padding.left  = 0
		end
		
		--------------------------------------------------------------------------------
		
		--log("before= ", self.State, ", after = ", afterState)
		
		-- 상태가 같다면 애님을 재생하지 않습니다.
		if self.State == afterState then
			return
		end
		
		
		-- (1-1) 프레임별 변동량입니다.
		local circlePosTick = -106/30  
		local colorRTick = (195-142)/255/30
		local colorGTick = (241-142)/255/30
		local colorBTick = (78-142)/255/30
		local textPadTick = 1
		
		-- (1-2) 만약 false to true 라면, 변동량을 정반대로 합니다. 
		if self.State == true and afterState == false then
			circlePosTick = 106/30
			colorRTick = (142-195)/255/30
			colorGTick = (142-241)/255/30
			colorBTick = (142-78)/255/30
		end
		
		-- (2) 색상을 변경하고 원모양 이미지의 위치를 변경합니다.
		local buttonAnimDirection = function()
			self.circle.UITransformComponent.anchoredPosition.x = self.circle.UITransformComponent.anchoredPosition.x + circlePosTick
			self.Entity.SpriteGUIRendererComponent.Color.r = self.Entity.SpriteGUIRendererComponent.Color.r + colorRTick
			self.Entity.SpriteGUIRendererComponent.Color.g = self.Entity.SpriteGUIRendererComponent.Color.g + colorGTick
			self.Entity.SpriteGUIRendererComponent.Color.b = self.Entity.SpriteGUIRendererComponent.Color.b + colorBTick
		end
		for i=1, 30 do
			_TimerService:SetTimerOnce(buttonAnimDirection, i/180)
		end
		
		
		local setSelfState = function()
			self.State = afterState
		end
		_TimerService:SetTimerOnce(setSelfState, 0.2)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 스킬 버튼 초기화 시 원형 이미지 엔티티 참조 설정
		self.circle = self.Entity:GetChildByName("circle")
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 펫 스킬 사용 버튼 클릭 시 스킬 사용 상태 토글 요청
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local slotIdx = tonumber(string.sub(self.Entity.Parent.Parent.Name, 6, -1))
		
		local beforeState = _UserService.LocalPlayer.PlayerPet.useSkill[slotIdx]
		
		if beforeState == true then	
			_UserService.LocalPlayer.PlayerPet:ChangePetSkillUseState(slotIdx, false)
		else 
			_UserService.LocalPlayer.PlayerPet:ChangePetSkillUseState(slotIdx, true)
		end
	end

end