@Component
script PetShopUI extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 펫 상점 UI 초기화 및 로커라이제이션 설정
		self:RefreshUI()
		
		---------------------------------------------------
		-- 로컬라이징
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- UI 새로고침 플래그 상태 확인 및 지연 업데이트 처리
		if self._T.refreshUI then
			self:RefreshUI_Inner()
			self._T.refreshUI = false
		end
	end

	@ExecSpace("Client")
	method void RefreshUI()
		-- UI 새로고침 플래그 활성화
		self._T.refreshUI = true
	end

	@ExecSpace("Client")
	method void RefreshUI_Inner()
		-- 플레이어의 펫 알 보유량을 표시하고 전체 펫 보유 여부에 따른 UI 상태 업데이트
		local player = _UserService.LocalPlayer
		
		local havingEggNumUI = _EntityService:GetEntity("5f83ab94-7f35-48df-9724-963c8269c955")
		havingEggNumUI.TextComponent.Text = string.format("%d", player.PlayerData.PetEgg)
		---------------------------------------------------
		-- 모든 펫을 가지고 있으면 버튼을 가림
		local havePet = player.PlayerPet.havePet
		local haveAllPet = true
		for i=1, #havePet do
			if havePet[i] < 3 then
				local hidePanel = _EntityService:GetEntity("945cdb6a-49c2-4278-8f41-549b4d5965b0")
				hidePanel.Enable = false
				haveAllPet = false
				break
			end
		end
		
		if haveAllPet == true then
			local hidePanel = _EntityService:GetEntity("945cdb6a-49c2-4278-8f41-549b4d5965b0")
			hidePanel.Enable = true
			self:ButtonEnable(false)
		else
			self:ButtonEnable(true)
		end
		
	end

	@ExecSpace("Client")
	method void SetWarningPopup(string message)
		-- 경고 메시지를 표시하는 팝업 활성화
		local popup = _EntityService:GetEntity("8410d2c1-9407-4d5b-a0ed-0e976c4b3e82")
		local messageUI = popup:GetChildByName("Panel"):GetChildByName("Message")
		
		messageUI.TextComponent.Text = message
		
		popup.Enable = true
	end

	@ExecSpace("Client")
	method void ButtonEnable(boolean Enable)
		-- 펫 알 오픈 버튼의 활성화 상태 설정
		local eggOpenBtn = _EntityService:GetEntity("b4051d74-7d03-4c40-8268-c7446befaf62")
		eggOpenBtn.ButtonComponent.Enable = Enable
	end

	@ExecSpace("Client")
	method void SetUIGettingNewPet(number petIdx, number grade)
		-- 새로운 펫 획듵 결과 UI에 펫 이미지, 등급, 설명 표시 및 사운드 재생
		-- entity
		local getNewPetUI = _EntityService:GetEntity("73ac4f32-55b3-4fba-a09f-2ed18f7b383d")
		local panel = getNewPetUI:GetChildByName("Panel")
		local petImageUI = panel:GetChildByName("PetImage")
		local petGradeUI = panel:GetChildByName("PetGrade")
		local descUI = panel:GetChildByName("Desc")
		
		-- data
		local petTable = _DataService:GetTable("Pet")
		local name = petTable:GetCell(petIdx, 1)
		local RUID = petTable:GetCell(petIdx, 2)
		local gradeText = ""
		for i=1, grade do
			gradeText = gradeText.."★"
		end
		
		-- apply to entity
		petImageUI.SpriteGUIRendererComponent.ImageRUID = RUID
		petGradeUI.TextComponent.Text = gradeText
		 descUI.TextComponent.Text = _LocalizationService:GetTextFormat("PetGacha_ResultDesc", _LocalizationService:GetText(name))
		_SoundService:PlaySound("c198d87b06b24707864b1ac73345cca8", 1)
		
		-- entity enable
		getNewPetUI.Enable = true
	end

	@EventSender("Entity", "b4051d74-7d03-4c40-8268-c7446befaf62")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 펫 알 오픈 버튼 클릭 시 조건 검사 후 새 펫 획듵 요청
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		-- 재화(펫 알)가 부족한 경우
		local havingEgg = _UserService.LocalPlayer.PlayerData.PetEgg
		if havingEgg <= 0 then
			self:SetWarningPopup(_LocalizationService:GetText("Message_NoEnoughPetEgg"))
			return
		end
		------------------------------------------
		-- 이미 모든 펫을 보유하고 있는 경우
		local targetTable = {}
		local havePet = _UserService.LocalPlayer.PlayerPet.havePet
		for i=1, #havePet do
			if havePet[i] < 3 then
				table.insert(targetTable, i)
			end
		end
		if #targetTable < 0 then
			self:SetWarningPopup(_LocalizationService:GetText("Message_HaveFullPet"))
			return
		end
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerPet:GetNewPet()
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키를 눌러 펫 상점 UI와 모든 팝업을 닫는 이벤트 처리
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if key==KeyboardKey.Escape and self.Entity.Enable then
			self.Entity.Enable = false
			self.Entity:GetChildByName("WarningPopup").Enable = false
			self.Entity:GetChildByName("GetNewPetPopup").Enable = false
			_UserService.LocalPlayer.MovementComponent.Enable = true
		end
	end

end