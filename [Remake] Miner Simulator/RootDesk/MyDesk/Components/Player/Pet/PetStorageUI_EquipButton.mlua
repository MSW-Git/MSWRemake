@Component
script PetStorageUI_EquipButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 펫 장착 버튼 클릭 시 해당 슬롯 인덱스의 펫을 장착하도록 요청
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local slotIdx = tonumber(string.sub(self.Entity.Parent.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/PetShopGroup/PetStorage").PetStorageUI:ChangeEquipedPet(slotIdx)
	end

end