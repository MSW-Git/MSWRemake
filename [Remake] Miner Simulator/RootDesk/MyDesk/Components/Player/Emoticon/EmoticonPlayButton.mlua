@Component
script EmoticonPlayButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 장착된 이모티콘 재생 버튼 클릭 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_UserService.LocalPlayer.PlayerEmoticon:PlayEmoticon(idx, _UserService.LocalPlayer)
	end

end