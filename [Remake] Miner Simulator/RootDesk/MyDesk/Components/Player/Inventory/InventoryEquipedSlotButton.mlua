@Component
script InventoryEquipedSlotButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 인벤토리 장착 슬롯 버튼 클릭 시 상세 정보 표시 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Name, 6, -1))
		
		_EntityService:GetEntity("48667632-97d3-4ffa-a58a-50f9d188cc1e").InventoryUI:SetDetailInfoUI(idx, true)
	end

end