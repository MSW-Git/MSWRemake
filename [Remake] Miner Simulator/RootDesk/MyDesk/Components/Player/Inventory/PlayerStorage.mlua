@Component
script PlayerStorage extends Component

	@Description("([1]일반유물상자 [2]고급유물상자) [3]김훈수계약서 [4]계약서뭐더라 [5]~[10]뿌리기류 [11]장신구뽑기상자")
	property SyncTable<number> consumableItems

	@Description("([1]골드) [2]젬 ([3]펫알 [4]감정표현토큰) [5]환생코인 [6]황금열쇠 [7]레거시코인")
	property SyncTable<number> currencyItems

	property SyncTable<number> consumableItemStartTime

	property SyncTable<number> consumableItemDuration

	property SyncTable<boolean> consumableItemAvailable

	property Entity buffUI = "090d60e0-cba6-4fe4-8362-ead22d244aba"

	property SyncTable<string> buffIconRUID

	property SyncTable<string> buffName

	property SyncTable<string> buffDesc

	method void OnBeginPlay()
		-- 플레이어 저장소 컴포넌트 초기화 시 테이블 설정과 소모품 지속시간 데이터 준비
		self._T.tableList = { 
			consumableItems = self.consumableItems, 
			currencyItems = self.currencyItems, 
			consumableItemStartTime = self.consumableItemStartTime }
		
		self._T.tableType = { 
			consumableItems = "number", 
			currencyItems = "number", 
			consumableItemStartTime = "number"}
		
		self._T.time = 0
		
		-- 소모품의 지속시간을 기록합니다. (sync 안함)
		local consumableItemTable = _DataService:GetTable("ConsumableItems")
		for i=1, consumableItemTable:GetRowCount() do
			local filterIdx = tonumber(consumableItemTable:GetCell(i, "FilterType"))
			
			if filterIdx == 1 then
				self.consumableItemDuration[i] = 1800
			elseif filterIdx == 2 then
				self.consumableItemDuration[i] = 600
			else
				self.consumableItemDuration[i] = 0
			end 
		end
		
		-- 소모품의 정보를 등록해둡니다.
		if self:IsClient() then
			for i=1, consumableItemTable:GetRowCount() do
				self.buffIconRUID[i] = consumableItemTable:GetCell(i, "IconRUID")
				self.buffName[i] = _LocalizationService:GetText(consumableItemTable:GetCell(i, "Name"))
				self.buffDesc[i] = _LocalizationService:GetText(consumableItemTable:GetCell(i, "Desc"))
			end
		end
	end

	@ExecSpace("Client")
	method void SetTableClient(string tableName, string strValue)
		-- 서버에서 받은 테이블 데이터를 클라이언트에 동기화하고 관련 UI 갱신
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local tableValue = _UtilLogic:StringToTable(strValue)
		
		for index, value in ipairs(tableValue) do
			t[index] = value
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void SetTableElementClient(string tableName, number index, string value)
		-- 테이블의 특정 인덱스 요소를 클라이언트에서 업데이트하고 타입 파싱 후 UI 갱신
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedValue = _ParsingLogic:ParseByType(value, self._T.tableType[tableName])
		t[index] = parsedValue
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ClearTableClient(string tableName, string initValue, number tableCount)
		-- 클라이언트 측에서 테이블 전체를 초기값으로 클리어하고 관련 UI 갱신
		--any type은 슬프게도 아직 다른 공간(Server -> Client / 혹은 반대)의 경우에는 동작하지 않습니다.
		--string type으로 받아 별도의 ParsingLogic과 OnBeginPlay에서 지정된 Type을 통해 값을 지정합니다.
		local t = self._T.tableList[tableName]
		if not t then return end
		
		local parsedInitValue = _ParsingLogic:ParseByType(initValue, self._T.tableType[tableName])
		for index=1, tableCount do
			t[index] = parsedInitValue
		end
		
		self:ChangedTable(tableName)
	end

	@ExecSpace("Client")
	method void ChangedTable(string name)
		-- 테이블 데이터 변경 시 해당하는 모든 관련 UI 컴포넌트들을 새로고침
		if name == "currencyItems" then
			_EntityService:GetEntityByPath("/ui/InventoryGroup/Storage").StorageUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/IngameGroup/Gem/Num").TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(self.currencyItems[2], nil)
			_EntityService:GetEntityByPath("/ui/GemShopGroup/GemShop").GemShopUI:RefreshUI()	
			_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop").ConstructionShopUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/LegacySystemGroup/LegacyCoinToEmblem").LegacycoinToEmblemUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/VoidItemGroup/VoidItemShop").VoidItemShopUI:RefreshUI()
		
		elseif name == "consumableItems" then
			_EntityService:GetEntityByPath("/ui/InventoryGroup/Storage").StorageUI:RefreshUI()
			_EntityService:GetEntityByPath("/ui/GemShopGroup/GemShop").GemShopUI:RefreshUI()
		end
	end

	@ExecSpace("Server")
	method void LoadedUserData(string consumableItemsStr, string currencyItemsStr, string consumableItemStartTimeStr)
		-- 저장된 유저 데이터를 로드하여 소모품, 재화, 시작시간 정보를 복원하고 클라이언트에 동기화
		if isvalid(consumableItemsStr) == false then
			for i=1, _DataService:GetRowCount("ConsumableItems") do
				self.consumableItems[i] = 0
			end
		else 
			local consumableItems = _UtilLogic:StringToTable(consumableItemsStr)
			for i=1, _DataService:GetRowCount("ConsumableItems") do
				if consumableItems[i] ~= nil then
					self.consumableItems[i] = consumableItems[i]
				else 
					self.consumableItems[i] = 0
				end
			end
		end
		----------------------------------------------------------------------------------
		if isvalid(currencyItemsStr) == false then
			for i=1, _DataService:GetRowCount("CurrencyItems") do
				self.currencyItems[i] = 0
			end
		else 
			local currencyItems = _UtilLogic:StringToTable(currencyItemsStr)
			for i=1, _DataService:GetRowCount("CurrencyItems") do
				if currencyItems[i] ~= nil then
					self.currencyItems[i] = currencyItems[i]
				else 
					self.currencyItems[i] = 0
				end
			end
		end
		----------------------------------------------------------------------------------
		if isvalid(consumableItemStartTimeStr) == false then
			for i=1, _DataService:GetRowCount("ConsumableItems") do
				self.consumableItemStartTime[i] = 0
			end
		else 
			local Items = _UtilLogic:StringToTable(consumableItemStartTimeStr)
			for i=1, _DataService:GetRowCount("ConsumableItems") do
				if Items[i] ~= nil then
					self.consumableItemStartTime[i] = tonumber(Items[i])
				else 
					self.consumableItemStartTime[i] = 0
				end
			end
		end
		----------------------------------------------------------------------------------
		----------------------------------------------------------------------------------
		self:SetTableClient("consumableItems", _UtilLogic:TableToString(self.consumableItems), self.Entity.OwnerId)
		self:SetTableClient("currencyItems", _UtilLogic:TableToString(self.currencyItems), self.Entity.OwnerId)
		self:SetTableClient("consumableItemStartTime", _UtilLogic:TableToString(self.consumableItemStartTime), self.Entity.OwnerId)
	end

	@ExecSpace("Server")
	method void AddCurrencyItems(number idx, number amount, boolean playEffect)
		-- 플레이어에게 지정된 재화 아이템을 추가하고 특별 효과 재생 여부 결정
		
		if amount == 0 then
			return
		end
		
		if idx==1 then
			log("money인데 인덱스로 추가했습니다")
			self.Entity.PlayerData.Money = self.Entity.PlayerData.Money + amount
		
		elseif idx == 3 then
			log("pet egg인데 인덱스로 추가했습니다")
			self.Entity.PlayerData:AddPetEgg()
			
		elseif idx == 4 then
			log("emot token인데 인덱스로 추가했습니다")
			self.Entity.PlayerEmoticon.EmotToken = self.Entity.PlayerEmoticon.EmotToken + amount
		else
			--log("idx = ", idx , ", amount = ", amount)
			self.currencyItems[idx] = self.currencyItems[idx] + amount
			--log(string.format("self.currencyItems[%d] = %d", idx, self.currencyItems[idx]))
		end
		
		
		if idx == 2 and playEffect then
			self:PlayGainGemsDirection(amount, self.Entity.OwnerId)
		end
		
		
		self:SetTableElementClient("currencyItems", idx, tostring(self.currencyItems[idx]), self.Entity.OwnerId)
	end

	@ExecSpace("Client")
	method void PlayGainGemsDirection(number amount)
		-- 젬 획득 시 클라이언트에서 시각적 연출 효과를 재생하여 획득량 표시
		local gemIcon = _EntityService:GetEntityByPath("/ui/IngameGroup/direction_gem_icon")
		local gemEffect = _EntityService:GetEntityByPath("/ui/IngameGroup/direction_gem_effect")
		local getText = _EntityService:GetEntityByPath("/ui/IngameGroup/direction_gem_text")
		----------------------------------------------------------------------------------------------------
		local creatIcon = function()
			local clonedIcon = gemIcon:Clone("clonedIcon")
			clonedIcon.UITransformComponent.anchoredPosition = Vector2(_UtilLogic:RandomIntegerRange(-500, 500), _UtilLogic:RandomIntegerRange(-300, 300))
			getText.TextComponent.Text = string.format("+ %d", amount)
		end
		local alpha = 0
		local setTextAlphaUp = function()
			alpha = alpha + 1/30
			getText.TextComponent.FontColor.a = alpha
			getText.TextComponent.OutlineColor.a = alpha 
			getText.TextComponent.Padding.bottom = alpha*5
		end
		
		local setTextAlphaDown = function()
			alpha = alpha - 1/30
			getText.TextComponent.FontColor.a = alpha
			getText.TextComponent.OutlineColor.a = alpha 
			getText.TextComponent.Padding.bottom = 5 + (1-alpha)*5
		end
		
		local setTextPaddingInit = function()
			getText.TextComponent.Padding.bottom = 0
		end
		----------------------------------------------------------------------------------------------------
		local dirAmount = 1
		local dirTime = 0
		
		if amount <= 9 then
			dirAmount = math.ceil(amount/3)
		elseif amount <= 15 then
			dirAmount= 3
		elseif amount <= 200 then
			dirAmount = math.ceil(amount/10)
		else
			dirAmount = string.len(tostring(math.floor(amount))) + 13
		end
		
		dirTime = dirAmount * 0.05
		
		for i=1, dirAmount do
			_TimerService:SetTimerOnce(creatIcon, 0.05*i)
		end
		for i=1, 30 do
			_TimerService:SetTimerOnce(setTextAlphaUp, dirTime + i/60)
			_TimerService:SetTimerOnce(setTextAlphaDown, 1+dirTime + i/60)
			_TimerService:SetTimerOnce(setTextPaddingInit, dirTime + 2)
		end
		----------------------------------------------------------------------------------------------------
	end

	@ExecSpace("Server")
	method void AddConsumableItems(number idx, number amount)
		-- 플레이어에게 소모품 아이템을 추가하고 로그 메시지 출력
		local consumableItemTable = _DataService:GetTable("ConsumableItems")
		
		self.consumableItems[idx] = self.consumableItems[idx] + amount
		
		self:SetTableElementClient("consumableItems", idx, tostring(self.consumableItems[idx]), self.Entity.OwnerId)
		
		_UIGetLog:AddLog(Color.FromHexCode("#7FFF6E"), 
			consumableItemTable:GetCell(idx, "Name"), 
			amount, true, 
			"ItemType_ConsumableItem", 
			consumableItemTable:GetCell(idx, "IconRUID"), 
			self.Entity.OwnerId)
	end

	@ExecSpace("Server")
	method void UseCurrencyItems(number idx, number amount)
		-- 플레이어의 재화 아이템을 소모하고 데이터를 저장 및 클라이언트 동기화
		if idx==1 then
			log("money인데 인덱스로 추가했습니다")
			self.Entity.PlayerData.Money = self.Entity.PlayerData.Money - amount
		
			
		elseif idx == 3 then
			log("pet egg인데 인덱스로 추가했습니다")
			self.Entity.PlayerData:AddPetEgg()
			
		elseif idx == 4 then
			log("emot token인데 인덱스로 추가했습니다")
			self.Entity.PlayerEmoticon.EmotToken = self.Entity.PlayerEmoticon.EmotToken - amount
			
		else
			self.currencyItems[idx] = self.currencyItems[idx] - amount
		
		end
		
		
		------------------------------------
		-- 클라이언트 동기화
		self:SetTableElementClient("currencyItems", idx, tostring(self.currencyItems[idx]), self.Entity.OwnerId)
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	@ExecSpace("Server")
	method void UseConsumableItem(number idx)
		-- 소모품 아이템 사용 처리: 계약서, 뿌리기, 장신구상자 등의 타입별 로직 실행
		-- 검증
		if self.consumableItems[idx] < 1 then
			return
		end
		----------------------------------------------------------------
		local consumableItemTable = _DataService:GetTable("ConsumableItems")
		local itemType = tonumber(consumableItemTable:GetCell(idx, "FilterType"))
		----------------------------------------------------------------
		-- 뿌리기인 경우 마을에서만 사용 가능
		if itemType == 2 then
			if string.sub(self.Entity.CurrentMapName, 1, 4) ~= "Town" then
				return
			end
		end
		----------------------------------------------------------------
		
		-- 아이템 소모 처리
		self.consumableItems[idx] = self.consumableItems[idx] - 1
		
		-- 계약서류 아이템인 경우
		if itemType == 1 then
			self:ApplySprinkleItem(idx, nil)	
			
		-- 뿌리기류 아이템인 경우
		elseif itemType == 2 then
			local sprinkleEntity = _SpawnService:SpawnByModelId("model://21279b19-1077-4248-ac85-7be3d40be867",
				"SprinkleItem",
				self.Entity.TransformComponent.WorldPosition,
				self.Entity.Parent)
			
			sprinkleEntity.SprinkleItem.idx = idx
			sprinkleEntity.SprinkleItem.userNickname = self.Entity.NameTagComponent.Name
			sprinkleEntity.SpriteParticleComponent.SpriteRUID = consumableItemTable:GetCell(idx, "IconRUID")
			
		-- 예외 처리 필요한 항목
		elseif itemType == 3 then
			if idx == 11 then
				self.Entity.PlayerAccessory:OpenAccessoryBox(1)
			end
		end
		----------------------------------------------------------------
		-- 테이블 동기화
		self:SetTableElementClient("consumableItems", idx, tostring(self.consumableItems[idx]), self.Entity.OwnerId)
		
		-- 데이터 저장
		self.Entity.PlayerData:SaveData(1)
	end

	method number GetConvertedTimeFromUTC()
		-- UTC 시간을 초 단위의 누적 시간으로 변환하여 소모품 지속시간 계산에 사용
		local utcnow = 	DateTime.UtcNow
		local year = 		tonumber(utcnow.Year)
		local month = 	tonumber(utcnow.Month)
		local day = 		tonumber(utcnow.Day)
		local hour =		tonumber(utcnow.Hour)
		local minute = 	tonumber(utcnow.Minute)
		local sec = 		tonumber(utcnow.Second)
		
		local dayValue = 0
		
		-- 1. 연도에서부터 더하기
		dayValue = dayValue + (year-1)*365 --기본값
		local leapYearDays = math.floor((year-1)/4) - math.floor((year-1)/100) + math.floor((year-1)/400)
		dayValue = dayValue + leapYearDays
		
		-- 2. 월에서부터 더하기
		local monthDays = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31}
		if (year%4 == 0 and year%100) or year%400 == 0 then
			monthDays[2] = 29
		end
		for i=1, (month-1) do
			dayValue = dayValue + monthDays[i]
		end
		
		-- 3. 날에서부터 더하기
		dayValue = dayValue + day - 1
		
		local convertedTime = sec + minute*60 + hour*3600 + dayValue*86400
		
		
		return convertedTime
	end

	method void OnUpdate(number delta)
		-- 매 프레임마다 소모품의 지속시간을 체크하고 1초마다 상태 갱신
		self._T.time = self._T.time + delta 
		
		if self._T.time > 1 then
			self:RefreshConsumableItemAbility()
			self._T.time = 0
		end
	end

	method void RefreshConsumableItemAbility()
		-- 소모품의 지속시간을 체크하여 버프 상태를 관리하고 UI에 버프 아이콘 표시
		if self:IsClient() and _UserService.LocalPlayer ~= self.Entity then
			return
		end
		
		
		local currentTime = self:GetConvertedTimeFromUTC()
		
		for i=1, #self.consumableItemStartTime do
			local startTime = self.consumableItemStartTime[i]
			local timeGap = currentTime - startTime
			if timeGap <= self.consumableItemDuration[i] then
				if self.consumableItemAvailable[i] == false then
					self.consumableItemAvailable[i] = true
					self.Entity.PlayerData:ApplyPlayerStatus()
				else 
					self.consumableItemAvailable[i] = true
				end
				
				
				
				-- 클라이언트에서 효과 적용 여부에 따라 ui 표시
				if self:IsClient() then
					local remainTime = (self.consumableItemDuration[i] - timeGap)
					
					-- HUD에 버프 아이콘을 표시합니다.
					local bufficon = self.buffUI:GetChildByName("Slot_ConsumableItem_"..tostring(i))
					if bufficon == nil then
						bufficon = _EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/Buff/Slot_ConsumableItem"):Clone("Slot_ConsumableItem_"..tostring(i))
					end
					
					bufficon.SpriteGUIRendererComponent.ImageRUID = self.buffIconRUID[i]
					bufficon.UIMouseHover.Type3_Icon = self.buffIconRUID[i]
					bufficon.UIMouseHover.Type3_Name = self.buffName[i]
					bufficon.Enable = true
					
					-- 남은 시간에 따라 분/초 단위 표기 변경
					if remainTime > 60 then
						bufficon.TextComponent.Text = string.format("%d", remainTime/60)
						bufficon.UIMouseHover.Type3_Desc = 
							self.buffDesc[i].."(".._LocalizationService:GetText("RemainDuration")..": "..string.format("%d ", remainTime/60).._LocalizationService:GetText("Minute")..")"
					else 
						bufficon.TextComponent.Text = string.format("%d", remainTime)
						bufficon.UIMouseHover.Type3_Desc = 
							self.buffDesc[i].."(".._LocalizationService:GetText("RemainDuration")..": "..string.format("%d ", remainTime).._LocalizationService:GetText("Second")..")"
					end
				end
				
			else 
				if self.consumableItemAvailable[i] == true then
					self.consumableItemAvailable[i] = false
					self.Entity.PlayerData:ApplyPlayerStatus()
				else 
					self.consumableItemAvailable[i] = false
				end
				
				
				if self:IsClient() then
					local bufficon = self.buffUI:GetChildByName("Slot_ConsumableItem_"..tostring(i))
					if bufficon == nil then
						bufficon = _EntityService:GetEntityByPath("/ui/IngameGroup/PlayerInfo/Buff/Slot_ConsumableItem"):Clone("Slot_ConsumableItem_"..tostring(i))
					end
					bufficon.Enable = false
				end
				
			end
		end
	end

	@ExecSpace("Multicast")
	method void ApplySprinkleItem(number idx, string userNickname)
		-- 뿌리기 아이템 사용 시 모든 클라이언트에 효과를 적용하고 시작시간 기록
		self.consumableItemStartTime[idx] = self:GetConvertedTimeFromUTC()
		
		if self:IsClient() and userNickname ~= nil and self.Entity == _UserService.LocalPlayer then
			local itemName = _LocalizationService:GetText(_DataService:GetCell("ConsumableItems", idx, "Name"))
			_UIToast:ShowMessage(_LocalizationService:GetTextFormat("PossessiveCase", userNickname).." "..itemName)
		end
	end

end