	@EventSender("Entity", "1bac33ba-5d81-4cdd-b8ab-028087249d89")
	handler HandleButtonClickEvent14(ButtonClickEvent event)
		-- 장신구 숙련도 업그레이드 실행 버튼 클릭 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		----------------------------------------------------------
		-- 승급하기 버튼을 (비)활성화합니다.
		local allRegisted = true
		for i=1, 3 do
			if self.materialIdx[i] == nil or self.materialIdx[i] == 0 then
				allRegisted = false
			end
		end
		
		if allRegisted == true then
			_EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage/Accessory_Gradeup/WarningPopup").Enable = true
		else 
			_UIToast:ShowMessage("모든 재료를 등록해야 합니다.")
			Entity.ButtonComponent.Enable = false
		end
	end

	@EventSender("Entity", "15b271ea-f9a1-4560-ac46-b41069317f2e")
	handler HandleButtonClickEvent15(ButtonClickEvent event)
		-- 장신구 숙련도 업그레이드 확인 버튼 클릭 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local materialIdxs = _UtilLogic:TableToString(self.materialIdx)
		_UserService.LocalPlayer.PlayerAccessory:UpgradeProficiency(materialIdxs)
		
		Entity.ButtonComponent.Enable = false
		local buttonReEnable = function()
			Entity.ButtonComponent.Enable = true
		end
		_TimerService:SetTimerOnce(buttonReEnable, 1)
	end

	@EventSender("Entity", "6e0782b3-837e-4aec-aec7-7e36d34dfead")
	handler HandleButtonClickEvent16(ButtonClickEvent event)
		-- 장신구 숙련도 업그레이드 취소 버튼 클릭 이벤트 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		for i=1, 3 do
			self.materialIdx[i] = 0 
		end
		
		self.currentSelectingMaterialSlotIdx = 0
		 
		
		
		local upgradeBtn = _EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage/Accessory_Gradeup/BasePanel/Button_Upgrade")
		local exitBtn = _EntityService:GetEntityByPath("/ui/EquipmentStorageGroup/EquipmentStorage/Accessory_Gradeup/TitlePanel/ExitButton")
		upgradeBtn.Enable = true
		exitBtn.Enable = true
		
		self:RefreshUI()
		self:RefreshAccessoryGradeupPanel()
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC키 입력 시 장비 보관함 UI를 닫는 이벤트 처리
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape and self.IsPlayingDirection == false then
			self.Entity.Enable = false
		end
	end

end