@Component
script ConstructionShopUI_BuyButton extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 건설/레벨업 버튼 클릭 시 확인 팝업 표시 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		local idx = tonumber(string.sub(self.Entity.Parent.Name, 6, -1))
		
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop").ConstructionShopUI:SetBuyCheckPopup(idx)
	end

end