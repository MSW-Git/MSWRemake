@Component
script ConstructionShopUI extends Component

	property number showingBuyIdx = 0

	@ExecSpace("Client")
	method void RefreshUI()
		-- 건설 상점 UI 전체 갱신 (재화, 리스트, 상태 등)
		local itemTable = _DataService:GetTable("Construction")
		-----------------------------------------------------------------
		-- 재화 정보 갱신
		local rebirthCoin = _UserService.LocalPlayer.PlayerStorage.currencyItems[5]
		local goldKey = _UserService.LocalPlayer.PlayerStorage.currencyItems[6] 
		
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/Bg_Panel_List/RebirthCoin/Amount").TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(rebirthCoin, nil)
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/Bg_Panel_List/GoldKey/Amount").TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(goldKey, nil)
		-----------------------------------------------------------------
		-- 리스트를 갱신
		local listEntity = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/ListPanel")
		for i=1, itemTable:GetRowCount() do
			local slot = listEntity:GetChildByName("Slot_"..tostring(math.floor(i)))
			if slot == nil then
				slot = listEntity:GetChildByName("Slot"):Clone("Slot_"..tostring(i))
				
				slot:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = itemTable:GetCell(i, "IconRUID")
				slot:GetChildByName("Name").TextComponent.Text = _LocalizationService:GetText(itemTable:GetCell(i, "Name"))
				slot:GetChildByName("Desc").TextComponent.Text = _LocalizationService:GetText(itemTable:GetCell(i, "Desc"))
					
				_EntityService:GetEntityByPath(slot.Path.."/LockedPanel/IconBack/Icon").SpriteGUIRendererComponent.ImageRUID = itemTable:GetCell(i, "IconRUID")
				_EntityService:GetEntityByPath(slot.Path.."/LockedPanel/UnlockButton/CostAmount").TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(tonumber(itemTable:GetCell(i, "UnlockCost")),nil)
			
			end
			
			-- 해금 여부 및 맥스레벨 초과 여부에 따라 버튼 활성화
			local level = _UserService.LocalPlayer.PlayerConstruction.haveItems[i] 
			if level == nil then
				return
			end
			
			local maxLevel = tonumber(itemTable:GetCell(i, "MaxLevel"))+1
			-- 데이터 상으로 0=잠김, 1=잠김해제+0레벨, 2=1레벨, ... 이므로 이에 맞게 반영해주어야함
			
			local nameUI = slot:GetChildByName("Name")
			local descUI = slot:GetChildByName("Desc")
			local levelNumUI = _EntityService:GetEntityByPath(slot.Path.."/Level/Fill_frame/RatioNum") 
			local levelSliderUI =  _EntityService:GetEntityByPath(slot.Path.."/Level/Fill_frame/Fill") 
			
			local levelupBtnText = _EntityService:GetEntityByPath(slot.Path.. "/Button_Buy/txt_levelup")
			if level < 2 then
				levelupBtnText.TextComponent.Text = _LocalizationService:GetText("Construct")
			else
				levelupBtnText.TextComponent.Text = _LocalizationService:GetText("LevelUp")
			end
			
			local costUI = _EntityService:GetEntityByPath(slot.Path.."/Button_Buy/CostAmount")
			if maxLevel >= 2147483647 then
				costUI.TextComponent.Text = _ThousandsSeparator:Separate(math.floor(4*level))
			else
				costUI.TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(tonumber(itemTable:GetCell(i, "ConstructionCost")), nil)
			end
			
			
			if level < 1 then -- 잠금 여부 활성화
				slot:GetChildByName("LockedPanel").Enable = true
				local unlockBtn = _EntityService:GetEntityByPath(slot.Path.."/LockedPanel/UnlockButton")
						
				if i > 1 then
					local prevIdxLevel = _UserService.LocalPlayer.PlayerConstruction.haveItems[i - 1]
					if prevIdxLevel < 1 then
						unlockBtn.Enable = false
					else
						unlockBtn.Enable = true
					end
				else 
					unlockBtn.Enable = true
				end
			
			elseif maxLevel >= 2147483647 then -- 최고레벨 제한이 없는 경우	
				slot:GetChildByName("LockedPanel").Enable = false
				slot:GetChildByName("Button_Buy").Enable = true
				slot:GetChildByName("IsMaxLevel").Enable = false	
				levelNumUI.TextComponent.Text = _ThousandsSeparator:ConvertToMetricPrefixString(level-1, nil)
				levelSliderUI.UITransformComponent.RectSize.x = 0
				
				slot:GetChildByName("IsMaxLevel").Enable = false
				slot:GetChildByName("Icon_Info").Enable = true
				nameUI.TextComponent.FontColor = Color.FromHexCode("#ddddf3")
				descUI.TextComponent.FontColor = Color.FromHexCode("#ddddf3")
			
			elseif level < maxLevel then -- 최고레벨 제한이 있고, 최고레벨 미만인 경우 레벨업 가능
				slot:GetChildByName("LockedPanel").Enable = false
				slot:GetChildByName("Button_Buy").Enable = true
				slot:GetChildByName("IsMaxLevel").Enable = false
				levelNumUI.TextComponent.Text = string.format("%d/%d", level-1, maxLevel-1)
				levelSliderUI.UITransformComponent.RectSize.x = 175 * (level-1)/(maxLevel-1)
				
				slot:GetChildByName("IsMaxLevel").Enable = false
				slot:GetChildByName("Icon_Info").Enable = false
				nameUI.TextComponent.FontColor = Color.FromHexCode("#ddddf3")
				descUI.TextComponent.FontColor = Color.FromHexCode("#ddddf3")
				
			
			else  -- 최고레벨인 경우
				slot:GetChildByName("LockedPanel").Enable = false
				slot:GetChildByName("Button_Buy").Enable = false
				slot:GetChildByName("IsMaxLevel").Enable = true
				levelNumUI.TextComponent.Text = string.format("%d/%d", level-1, (maxLevel-1))
				levelSliderUI.UITransformComponent.RectSize.x = 175 * (level-1)/(maxLevel-1)
				
				slot:GetChildByName("IsMaxLevel").Enable = true
				slot:GetChildByName("Icon_Info").Enable = false
				nameUI.TextComponent.FontColor = Color.FromHexCode("#181c28")
				descUI.TextComponent.FontColor = Color.FromHexCode("#181c28")
			end
		end
		-----------------------------------------------------------------
	end

	@ExecSpace("Client")
	method void SetBuyCheckPopup(number idx)
		-- 건설/레벨업 확인 팝업 UI 설정
		local popup = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup")
		local itemTable = _DataService:GetTable("Construction")
		
		self.showingBuyIdx = idx
		------------------------------------------------------------------------------------------------
		local iconUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/IconBack/Icon")
		local nameUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/Name")
		local descUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/Desc")
		local costUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/Button_Yes/Cost")
		local messageUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/Message")
		local buyButton = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/Button_Yes")
		local currentLvUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/txt_currentLv")
		local nextLvUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/txt_UpperLv")
		
		local icon = itemTable:GetCell(idx, "IconRUID")
		local name = _LocalizationService:GetText(itemTable:GetCell(idx, "Name"))
		local desc = _LocalizationService:GetText(itemTable:GetCell(idx, "Desc"))
		local currentLv = _UserService.LocalPlayer.PlayerConstruction.haveItems[idx] - 1
		local cost = itemTable:GetCell(idx, "ConstructionCost")
		local nextLv = currentLv + 1
		if cost == "N" then
			cost = string.format("%d", 4*nextLv)
		end
		
		iconUI.SpriteGUIRendererComponent.ImageRUID = icon
		nameUI.TextComponent.Text = name
		descUI.TextComponent.Text = desc
		costUI.TextComponent.Text = cost
		currentLvUI.TextComponent.Text = "Lv. ".._ThousandsSeparator:ConvertToMetricPrefixString(currentLv, nil)
		nextLvUI.TextComponent.Text = "Lv. ".. _ThousandsSeparator:ConvertToMetricPrefixString(nextLv, nil)
		
		
		-- 레벨에 따라 '건설하기(Construct)' 또는 '레벨업(LevelUp)'으로 다르게 표기
		local buyButtonText = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup/Panel/Button_Yes/txt_construction")
		if currentLv >= 1 then
			buyButtonText.TextComponent.Text = _LocalizationService:GetText("LevelUp")
			messageUI.TextComponent.Text = _LocalizationService:GetText("Construction_LvUpCheckMessage")
		else 
			buyButtonText.TextComponent.Text = _LocalizationService:GetText("Construct")
			messageUI.TextComponent.Text = _LocalizationService:GetText("Construction_ConstructCheckMessage")
		end
		
		-- 재화 보유량에 따라 구매버튼 비활성화
		if tonumber(cost) > _UserService.LocalPlayer.PlayerStorage.currencyItems[5] then
			buyButton.ButtonComponent.Enable = false
		else 
			buyButton.ButtonComponent.Enable = true
		end
		------------------------------------------------------------------------------------------------
		popup.Enable = true
	end

	@ExecSpace("Client")
	method void SetUnlockCheckPopup(number idx)
		-- 건설 시설 잠금 해제 확인 팝업 UI 설정
		local popup = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/UnlockCheckPopup")
		local itemTable = _DataService:GetTable("Construction")
		
		self.showingBuyIdx = idx
		------------------------------------------------------------------------------------------------
		local costUI = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/UnlockCheckPopup/Panel/Button_Yes/Cost")
		local buyButton = _EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/UnlockCheckPopup/Panel/Button_Yes")
		
		local cost = itemTable:GetCell(idx, "UnlockCost")
		
		costUI.TextComponent.Text = cost
		
		if tonumber(cost) > _UserService.LocalPlayer.PlayerStorage.currencyItems[6] then
			buyButton.ButtonComponent.Enable = false
		else 
			buyButton.ButtonComponent.Enable = true
		end
		------------------------------------------------------------------------------------------------
		popup.Enable = true
	end

	@ExecSpace("Client")
	method void PlayUnlockDirection(number idx)
		-- 건설 시설 잠금 해제 성공 연출 및 토스트 메시지 표시
		-- 잠금 해제할 때 실행하는 연출
		
		local itemTable = _DataService:GetTable("Construction")
		
		local itemName = _LocalizationService:GetText(itemTable:GetCell(idx, "Name"))
		
		_UIToast:ShowMessage(_LocalizationService:GetTextFormat("Message_ConstructionUnlocked", _LocalizationService:GetText(itemName)))
		
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/UnlockCheckPopup").Enable = false
	end

	@ExecSpace("Client")
	method void PlayPurchaseDireciton(number idx, number afterLevel)
		-- 건설/레벨업 성공 연출 및 토스트 메시지 표시
		-- 건설할 때 실행하는 연출
		
		local itemTable = _DataService:GetTable("Construction")
		
		local itemName = itemTable:GetCell(idx, "Name")
		
		if afterLevel > 2 then
			_UIToast:ShowMessage(_LocalizationService:GetTextFormat("Message_ConstructionLevelUp", _LocalizationService:GetText(itemName)))
		else 
			_UIToast:ShowMessage(_LocalizationService:GetTextFormat("Message_Construction", _LocalizationService:GetText(itemName)))
		end
		
		
		
		_EntityService:GetEntityByPath("/ui/ConstructionGroup/ConstructionShop/BuyCheckPopup").Enable = false
	end

	@EventSender("Entity", "5949b8fe-3237-4379-befc-0b926cf6d5c0")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 건설/레벨업 확인 버튼 클릭 시 실제 구매 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerConstruction:BuyConstruction(self.showingBuyIdx)
	end

	@EventSender("Entity", "d84d8135-f8b9-448a-a19d-5277e2aa100a")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 잠금 해제 확인 버튼 클릭 시 실제 해제 처리
		-- Parameters
		local Entity = event.Entity
		--------------------------------------------------------
		_UserService.LocalPlayer.PlayerConstruction:UnlockConstruction(self.showingBuyIdx)
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 상점 UI 닫기 처리
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Escape then
			self.Entity.Enable = false
			_UserService.LocalPlayer.MovementComponent.Enable = true
		end
	end

end