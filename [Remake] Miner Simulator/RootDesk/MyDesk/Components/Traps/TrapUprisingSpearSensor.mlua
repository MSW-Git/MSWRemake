@Component
script TrapUprisingSpearSensor extends Component

	property number sensingCooldown = 0

	@ExecSpace("Client")
	method void SpawnUprisingSpearTrap()
		-- 솟아오르는 창 트랩을 생성하고 0.5초 후에 제거
		local trap = _SpawnService:SpawnByModelId("model://9de71163-f263-46ee-96da-9175e8e92870", "UprisingSpear", Vector3(0, 0, 0), self.Entity)
		
		local destroy = function()
			_EntityService:Destroy(trap)
		end
		
		_TimerService:SetTimerOnce(destroy, 0.5)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 감지 쿨다운 시간을 업데이트
		if self.sensingCooldown <= 0 then
			return
		end
		
		self.sensingCooldown = self.sensingCooldown - delta
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 감지 쿨다운을 초기화
		self.sensingCooldown = 1.5
	end

	@EventSender("Self")
	handler HandleTriggerStayEvent(TriggerStayEvent event)
		-- 플레이어 감지 시 사운드 재생 후 창 트랩을 1초 뒤에 소환
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and
			TriggerBodyEntity.TagComponent.Tags[1] == "player" and
			self:IsClient() and
			self.sensingCooldown <= 0  then
			
			_SoundService:PlaySound("0144c64bc55940b4a32fe0e151afac5e", 1)
			
			local spawn = function()
				self:SpawnUprisingSpearTrap()
			end
			
			_TimerService:SetTimerOnce(spawn, 1)
			
			self.sensingCooldown = 1.5
		end
	end

end