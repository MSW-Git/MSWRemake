@Component
script TrapJump extends Component

	property number power = 0

	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 점프대에 충돌할 때 위로 점프력 부여
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if self:IsServer() then
			return
		end
		--------------------------------------------------------
		if TriggerBodyEntity.TagComponent and TriggerBodyEntity.TagComponent.Tags[1] == "player" then
		
			if string.sub(self.Entity.Name, 1,7) == "Octopus" then
				_SoundService:PlaySound("08747c4cbe1445558b2f19c6cf695fa7", 1)
			end
			local forceX = TriggerBodyEntity.RigidbodyComponent.RealMoveVelocity.x
			TriggerBodyEntity.RigidbodyComponent:SetForce(Vector2(forceX, self.power))
			
		end
	end

end