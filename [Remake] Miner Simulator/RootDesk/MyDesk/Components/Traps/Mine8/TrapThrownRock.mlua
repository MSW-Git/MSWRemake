@Component
script TrapThrownRock extends Component

	@HideFromInspector
	property number SpawnedTime = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 3초 후에 돌 오브젝트를 제거
		self.SpawnedTime = self.SpawnedTime + delta
		
		if self.SpawnedTime > 3 then 
			self.Entity:Destroy()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 몬스터와 충돌 시 기절 효과를 적용하고 이펙트를 재생
		-- Parameters
		local TriggerBodyEntity = event.TriggerBodyEntity
		--------------------------------------------------------
		if TriggerBodyEntity.TrapMonster ~= nil and TriggerBodyEntity.TrapMonster.Enable == true then
			TriggerBodyEntity.TrapMonster:Sturn(true)
			_EffectService:PlayEffect("04e3be2cd7704ba6839c849bc5642724", self.Entity, TriggerBodyEntity.TransformComponent.WorldPosition, 0, Vector3.one)
			_SoundService:PlaySoundAtPos("1b54e03352ae4430ae39be54d2ee88f4", TriggerBodyEntity.TransformComponent.WorldPosition, _UserService.LocalPlayer, 0.75)
			if TriggerBodyEntity.RigidbodyComponent:PredictFootholdEnd(0.1, true) == false and TriggerBodyEntity.RigidbodyComponent:PredictFootholdEnd(0.1, false) == false then
				TriggerBodyEntity.RigidbodyComponent:AddForce(Vector2(0, 0.5))
			end
		end
	end

end