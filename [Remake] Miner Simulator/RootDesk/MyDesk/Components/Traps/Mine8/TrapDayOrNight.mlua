@Component
script TrapDayOrNight extends Component

	@Sync
	@HideFromInspector
	property number Time = 0

	@Sync
	@HideFromInspector
	property boolean IsNight = false

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		-- 30초마다 낮과 밤 배경을 전환
		self.Time = self.Time + delta
		
		if self.Time >= 30 then
			self.Time = 0
			
			if self.IsNight == true then
				-- 낮으로 전환
				self.IsNight = false
				self.Entity:GetChildByName("Background").BackgroundComponent:ChangeBackgroundByTemplateRUID("2fffe90856164417b5544216f988b1ac")
				
			else 
				-- 밤으로 전환 
				self.IsNight = true
				self.Entity:GetChildByName("Background").BackgroundComponent:ChangeBackgroundByTemplateRUID("c41343177137437187e3a10f2f80525e")
			end
			
			
		end
	end

end