		playerData.RebornCount = 0
		-------------------------------
		-- 7
		playerData.PetEgg = 0
		-------------------------------
		-- 8
		playerData.HistoricSiteRecord = 0
		-------------------------------
		-- 9 : Collection
		playerData.Entity.PlayerCollection:LoadedUserData("")
		-------------------------------
		-- 10, 11 : Title Equiped, Have Bool
		playerData.Entity.PlayerTitle:LoadedUserData(nil, nil)
		-------------------------------
		-- 12~14 : 이모티콘 보유여부, 장착인덱스, 토큰보유량
		playerData.Entity.PlayerEmoticon:LoadedUserData(nil, nil, nil)
		-------------------------------
		-- 15~16 : 의자 보유, 장착
		playerData.Entity.PlayerChair:LoadedUserData(nil, nil)
		-------------------------------
		-- 17~18 : 펫 보유, 장착
		playerData.Entity.PlayerPet:LoadedUserData(nil, nil, nil)
		-------------------------------
		-- 19~20 : 업적 진행도, 클리어여부
		playerData.Entity.PlayerAchievementComponent:LoadedUserData(nil, nil)
		-------------------------------
		-- 21~24 : 유물(정화) 보유 여부, 등록 여부, 보유 유물상자 개수, 유물상자 구매회수
		playerData.Entity.PlayerRelic:LoadedUserData(nil, nil, nil)
		-------------------------------
		-- 25~26 : 출석보상 진행도, 최근 보상수령일
		playerData.Entity.PlayerDailyRewardComponent:LoadedUserData(nil, nil, nil)
		-------------------------------
		-- 27~29 : 소모품, 재화템
		playerData.Entity.PlayerStorage:LoadedUserData(nil, nil, nil)
		-------------------------------
		-- 30~35 : 신화 장비
		playerData.Entity.PlayerMythicEquipment:LoadedData(nil, nil, nil, 
			nil, nil, nil)
		-------------------------------
		-- 엠블렘
		playerData.Entity.PlayerEmblem:LoadedData(nil)
		-------------------------------
		-- 건설소
		playerData.Entity.PlayerConstruction:LoadedData(nil)
		-------------------------------
		-- 장신구
		playerData.Entity.PlayerAccessory:LoadedData(nil, nil, nil)
		-------------------------------
		-- 공허
		playerData.Entity.PlayerVoidItem:LoadedData(nil,nil)
		playerData.VoidItemPurchaseCount = 0
		if playerData.VoidItemPurchaseCount == nil then playerData.VoidItemPurchaseCount = 0 end
		-------------------------------
		-- 환생
		playerData.TempleRecord_Current = 0
		if playerData.TempleRecord_Current == nil then playerData.TempleRecord_Current = 0 end
		playerData.GoldKeyRewardedStage = 0
		if playerData.GoldKeyRewardedStage == nil then playerData.GoldKeyRewardedStage = 0 end
		-------------------------------
		playerData:LoadedUserData()
		
		
		
		
		
		
		----------------------------------------
		local dataStroage = _DataStorageService:GetGlobalDataStorage(player.OwnerId.."_tutorial")
		
		local errorCode = dataStroage:SetAndWait("IsPlayedTable", _UtilLogic:TableToString({}))
		local errorCode2 = dataStroage:SetAndWait("Condition", _UtilLogic:TableToString({}))
		
		----------------------------------------
		----------------------------------------
		_TutorialGuide:LoadData(player.OwnerId)
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력 처리로 스페이스키와 숫자키 조합으로 치트 활성화
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if key == KeyboardKey.Space then
			self.ctrInputted = true
		end
		---------------------
		if key == KeyboardKey.Alpha0 and self.ctrInputted == true then
			self:SetCheatUIEnableOnServer(_UserService.LocalPlayer.OwnerId)
		end
		
		--[[
		
		-- space + 숫자로 치트 사용
		if key == KeyboardKey.Alpha1 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "allequipment")
			
		elseif key == KeyboardKey.Alpha2 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "money2")
			
		elseif key == KeyboardKey.Alpha3 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "money3")
			
		elseif key == KeyboardKey.Alpha4 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "money4")
			
		elseif key == KeyboardKey.Alpha5 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "townProgress")
			
		elseif key == KeyboardKey.Alpha6 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "addPetEgg")
			
		elseif key == KeyboardKey.Alpha7 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "addRelic")
			
		elseif key == KeyboardKey.Alpha8 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "addChair")
			
		elseif key == KeyboardKey.Alpha9 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "addRelicBox_normal")
			
		elseif key == KeyboardKey.Alpha0 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "addRelicBox_special")
			
		elseif key == KeyboardKey.Q and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "emotion")
			
		elseif key == KeyboardKey.F6 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "dropRelic1")
			
		elseif key == KeyboardKey.F7 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "dropRelic2")
			
		elseif key == KeyboardKey.F8 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "dropRelic3")
			
		elseif key == KeyboardKey.F9 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "dropRelic4")
			
		elseif key == KeyboardKey.F10 and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "dropRelic5")
			
		elseif key == KeyboardKey.T and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "relicBook1" )
			
		elseif key == KeyboardKey.Y and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "relicBook2" )
			
		elseif key == KeyboardKey.U and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "relicBook3" )
			
		elseif key == KeyboardKey.I and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "relicBook4" )
			
		elseif key == KeyboardKey.Insert and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "DailyRewardTest")
			
		elseif key == KeyboardKey.Home and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "NeverDie")
			
		elseif key == KeyboardKey.Comma and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "Jewerly1")
			
		elseif key == KeyboardKey.Period and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "Jewerly1000")
			
		elseif key == KeyboardKey.Z and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "Add10Equipments")
			
		elseif key == KeyboardKey.X and self.ctrInputted == true then
			self:UseCheatOnServer(_UserService.LocalPlayer, "Get10GoldKeys")
		end
		]]--
	end

	@EventSender("Service", "InputService")
	handler HandleKeyUpEvent(KeyUpEvent event)
		-- 키보드 키를 뗄 때 처리하여 치트 입력 상태를 해제
		-- Parameters
		local key = event.key
		--------------------------------------------------------
		if key == KeyboardKey.Space then
			self.ctrInputted = false
		end
	end

	@EventSender("Entity", "a6561098-7c1a-4e51-b728-f661fc37c5db")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 테스트 버튼 클릭 시 모든 아이템과 진행사항을 지급하는 치트 실행
		self:UseCheatForTest0314(_UserService.LocalPlayer)
	end

