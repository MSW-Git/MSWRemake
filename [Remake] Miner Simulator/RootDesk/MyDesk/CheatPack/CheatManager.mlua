@Logic
script CheatManager extends Logic

	property SyncTable<string, string> admin

	property boolean isNotAdmin = false

	property boolean ctrInputted = false

	property number cheatDaily = 0

	property number cheatChair = 0

	@Sync
	property number TemplePortalCheatIdx = 0

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 관리자 계정 목록을 초기화
		self:InitPPSN()
	end

	@ExecSpace("Server")
	method void UseCheatOnServer(Entity player, string cheatType)
		-- 관리자 권한을 확인하고 다양한 치트 명령을 실행
		log("UseCheatOnServer")
		
		if isvalid(player) == false then
			return
		end
		local targetPPSN = player.PlayerComponent.UserId
		
		
		if self:IsAdmin(targetPPSN) == false then
			return
		end
		---------------------------------------------------------
		if cheatType == "money1M" then
			player.PlayerData:GetMoney(1000000)
			_UIToast:ShowMessage("100만골드 획득!", player.OwnerId)
			
		elseif cheatType == "money100M" then
			player.PlayerData:GetMoney(100000000)
			_UIToast:ShowMessage("1억골드 획득!", player.OwnerId) 
			
		elseif cheatType == "money1B" then
			player.PlayerData:GetMoney(10000000000)
			_UIToast:ShowMessage("100억골드 획득!", player.OwnerId) 
			
		elseif cheatType == "money100B" then
			player.PlayerData:GetMoney(1000000000000)
			_UIToast:ShowMessage("1조골드 획득!", player.OwnerId)
			
		elseif cheatType == "money1T" then
			player.PlayerData:GetMoney(100000000000000)
			_UIToast:ShowMessage("100조골드 획득!", player.OwnerId)
		---------------------------------------------------------	
		elseif cheatType == "gem1" then
			local amount = 1
			player.PlayerStorage:AddCurrencyItems(2, amount, false)
			_UIToast:ShowMessage(string.format("젬 %d개 획득!", amount), player.OwnerId)
			
		elseif cheatType == "gem100" then
			local amount = 100
			player.PlayerStorage:AddCurrencyItems(2, amount, false)
			_UIToast:ShowMessage(string.format("젬 %d개 획득!", amount), player.OwnerId)
			
		elseif cheatType == "gem10000" then
			local amount = 10000
			player.PlayerStorage:AddCurrencyItems(2, amount, false)
			_UIToast:ShowMessage(string.format("젬 %d개 획득!", amount), player.OwnerId)
			
		---------------------------------------------------------	
		elseif cheatType == "townProgress" then
			for i=1, 10 do
				player.PlayerData:ChangeTownProgress(i)
				player.PlayerData.TownAdmission[i] = true
			end
			player.PlayerData:SetTableClient("TownAdmission", _UtilLogic:TableToString(player.PlayerData.TownAdmission), player.OwnerId)
			_UIToast:ShowMessage("모든 마을 입장 해금!", player.OwnerId)  
		---------------------------------------------------------
		elseif cheatType == "mineralOre" then
			local idx = _UtilLogic:RandomIntegerRange(1, 3) 
			player.PlayerBackpack:AddItem(idx, 1)
			_UIToast:ShowMessage("광석1개 치트 사용 : 인덱스는 "..idx, player.OwnerId)
			
		elseif cheatType == "mineralJewelry" then
			local idx = _UtilLogic:RandomIntegerRange(4, 42) 
			player.PlayerBackpack:AddItem(idx, 1)
			_UIToast:ShowMessage("보석1개 치트 사용 : 인덱스는 "..idx, player.OwnerId)
			
		elseif cheatType == "mineralFossil" then
			local idx = _UtilLogic:RandomIntegerRange(43, 49) 
			player.PlayerBackpack:AddItem(idx, 1)
			_UIToast:ShowMessage("화석1개 치트 사용 : 인덱스는 "..idx, player.OwnerId)
		---------------------------------------------------------
		elseif cheatType == "addRelicPurified" then
			local randIdx = _UtilLogic:RandomIntegerRange(1, 90)
			player.PlayerRelic:AddRelic(false, randIdx)
			_UIToast:ShowMessage(string.format("정화된 유물(idx = %d) 획득", randIdx), player.OwnerId)
			
		elseif cheatType == "addRelicUnpurified" then
			local randIdx = _UtilLogic:RandomIntegerRange(1, 90)
			player.PlayerRelic:AddRelic(true, randIdx)
			_UIToast:ShowMessage(string.format("정화되지 않은 유물(idx = %d) 획득", randIdx), player.OwnerId)
			
		elseif cheatType == "addRelicBox_normal" then
			player.PlayerRelic.havingRelicBoxNum[1] = player.PlayerRelic.havingRelicBoxNum[1] + 1
			_UIToast:ShowMessage("일반 유물상자 1개 획득", player.OwnerId)
			player.PlayerRelic:SetTableElementClient("havingRelicBoxNum", 1, tostring(player.PlayerRelic.havingRelicBoxNum[1]), player.OwnerId)
			
		elseif cheatType == "addRelicBox_special" then
			player.PlayerRelic.havingRelicBoxNum[2] = player.PlayerRelic.havingRelicBoxNum[2] + 1
			_UIToast:ShowMessage("고급 유물상자 1개 획득", player.OwnerId)
			player.PlayerRelic:SetTableElementClient("havingRelicBoxNum", 2, tostring(player.PlayerRelic.havingRelicBoxNum[2]), player.OwnerId)
		---------------------------------------------------------		
		elseif string.sub(cheatType, 1, 15) == "miningRelicSite" then
			local level = tonumber(string.sub(cheatType, -1, -1)) + 21
			self:GiveReward(player, level)
		---------------------------------------------------------
		elseif string.sub(cheatType, 1, 9) == "relicBook" then
			local level = tonumber(string.sub(cheatType, -1, -1))
			
			if level == 1 then
				for i=1, 129 do
					for j=1, 4 do
						player.PlayerRelic.RegistrationInfo[(i-1)*4 + j] = true
					end
				end
				
				_UIToast:ShowMessage("일반유물 도감 채우기", player.OwnerId)
				
			elseif level == 2 then
				for i=130, 186 do
					for j=1, 4 do
						player.PlayerRelic.RegistrationInfo[(i-1)*4 + j] = true
					end
				end
				_UIToast:ShowMessage("고급유물 도감 채우기", player.OwnerId)
				
			elseif level == 3 then
				for i=187, 243 do
					for j=1, 4 do
						player.PlayerRelic.RegistrationInfo[(i-1)*4 + j] = true
					end
				end
				_UIToast:ShowMessage("희귀유물 도감 채우기", player.OwnerId)
				
			elseif level == 4 then
				for i=244, 345 do
					for j=1, 4 do
						player.PlayerRelic.RegistrationInfo[(i-1)*4 + j] = true
					end
				end
				_UIToast:ShowMessage("전설유물 도감 채우기", player.OwnerId)
					
			end
			
			player.PlayerRelic:SetTableClient("RegistrationInfo", _UtilLogic:TableToString(player.PlayerRelic.RegistrationInfo), player.OwnerId)
					
		---------------------------------------------------------
		elseif string.sub(cheatType, 1, 11) == "rebirthcoin" then
			local amount = tonumber(string.sub(cheatType, 13, -1))
			player.PlayerStorage:AddCurrencyItems(5, amount, false)
			_UIToast:ShowMessage(string.format("리버스코인 %d개 획득", amount), player.OwnerId)
			
		elseif string.sub(cheatType, 1, 7) == "goldkey" then
			local amount = tonumber(string.sub(cheatType, 9, -1))
			player.PlayerStorage:AddCurrencyItems(6, amount, false)
			_UIToast:ShowMessage(string.format("황금열쇠 %d개 획득", amount), player.OwnerId)
			
		elseif string.sub(cheatType, 1, 8) == "currency" then
			local idx = tonumber(string.sub(cheatType, 10, -1))
			player.PlayerStorage:AddCurrencyItems(idx, 1, false)
			_UIToast:ShowMessage(string.format("%d번 재화 획득", idx), player.OwnerId)
		---------------------------------------------------------
		elseif cheatType == "addChair" then
			self.cheatChair = self.cheatChair + 1
			player.PlayerChair:AddItem(self.cheatChair)
			_UIToast:ShowMessage("No."..tostring(self.cheatChair).." 의자 획득", player.OwnerId)
			
		elseif cheatType == "Accessory" then
			for i=1, 3 do
				for j=1, 5 do
					for k=1, 5 do
						local part = i
						local grade = j
						local set = k
						local status = 0
						local randomVal1 = _UtilLogic:RandomIntegerRange(0, 100)/100
						local randomVal2 = _UtilLogic:RandomIntegerRange(0, 100)/100
						local statusRate = (randomVal1 + randomVal2)/2
						
						if part == 1 then
							status = 10000000 * 2^(grade-1)
						elseif part == 2 then
							status = 2000000 * 2^(grade-1)
						elseif part == 3 then
							status = 2000000000 * 2^(grade-1)
						end
						status = math.floor( 0.8 * status + 0.4 * status * statusRate )  
						player.PlayerAccessory:GetItems(part, grade, set, status)
						
						
						_UIToast:ShowMessage("장신구 획득!", player.OwnerId)
					end
				end
			end
			--[[
			local part = _UtilLogic:RandomIntegerRange(1, 3)
			local grade = _UtilLogic:RandomIntegerRange(1, 5)
			local set =_UtilLogic:RandomIntegerRange(1, 5) 
			local status = 0
			local randomVal1 = _UtilLogic:RandomIntegerRange(0, 100)/100
			local randomVal2 = _UtilLogic:RandomIntegerRange(0, 100)/100
			local statusRate = (randomVal1 + randomVal2)/2
			
			if part == 1 then
				status = 10000000 * 2^(grade-1)
			elseif part == 2 then
				status = 2000000 * 2^(grade-1)
			elseif part == 3 then
				status = 2000000000 * 2^(grade-1)
			end
			status = math.floor( 0.8 * status + 0.4 * status * statusRate )  
			player.PlayerAccessory:GetItems(part, grade, set, status)
			
			
			_UIToast:ShowMessage("장신구 획득!", player.OwnerId)
			]]--
		elseif cheatType == "randomEmblem" then
			local randIdx =_UtilLogic:RandomIntegerRange(1, 16) 
			player.PlayerEmblem:AddItems(randIdx)
			_UIToast:ShowMessage(string.format("%d번 엠블렘 획득!", randIdx), player.OwnerId)
		---------------------------------------------------------
		elseif string.sub(cheatType, 1, 10) == "consumable" then
			local typeIdx = tonumber(string.sub(cheatType, 12, -1))
			local itemIdx = 1
			
			if typeIdx == 1 then
				itemIdx = _UtilLogic:RandomIntegerRange(3, 4)
			elseif typeIdx == 2 then
				itemIdx = _UtilLogic:RandomIntegerRange(5, 10)
			end
			player.PlayerStorage:AddConsumableItems(itemIdx, 1)
		---------------------------------------------------------			
		elseif string.sub(cheatType, 1, 19)  == "templePortalCheatOn" then
			local idx = tonumber(string.sub(cheatType, 21, -1))
			self.TemplePortalCheatIdx = idx	
				
		elseif cheatType == "templePortalCheatOff" then
			self.TemplePortalCheatIdx = 0
				
		---------------------------------------------------------
		elseif cheatType == "addPetEgg" then
			player.PlayerData.PetEgg = player.PlayerData.PetEgg + 1
			_UIToast:ShowMessage("펫 알 획득", player.OwnerId)
			
		elseif cheatType == "addRelic" then
			local randIdx = _UtilLogic:RandomIntegerRange(1, 50)
			player.PlayerRelic:AddRelic(true, randIdx)
			_UIToast:ShowMessage("정화되지 않은 유물 획득", player.OwnerId)
			
		elseif cheatType == "VoidItem" then
			local randIdx = _UtilLogic:RandomIntegerRange(1, 20)
			player.PlayerVoidItem:GetItem(randIdx)
			_UIToast:ShowMessage("공허 아이템 획득 : "..tostring(math.floor(randIdx)), player.OwnerId)
		---------------------------------------------------------	
		elseif cheatType == "title" then
			local gotIdx = 0
			for i=1, #player.PlayerTitle.haveItem do
				if player.PlayerTitle.haveItem[i] == false then
					player.PlayerTitle:GetNewItem(i)
					gotIdx = i
					break
				end
			end
			
			_UIToast:ShowMessage(tostring(gotIdx).."번 칭호 획득!", player.OwnerId)
			
		---------------------------------------------------------
		elseif cheatType == "allequipment" then
			for i=1, 160 do
				player.PlayerData.haveEquipment[i] = true
			end
			player.PlayerData:ChangedTable("haveEquipment", player.OwnerId)
			
			_UIToast:ShowMessage("모든 장비 획득", player.OwnerId)
			
		elseif cheatType == "emotion" then
			for i=1, #player.PlayerEmoticon.haveEmoticon do
				player.PlayerEmoticon.EmotToken = player.PlayerEmoticon.EmotToken + 1
				player.PlayerEmoticon:GetNewEmot()
			end
			
		elseif string.sub(cheatType, 1, 9) == "dropRelic" then
			local floor = tonumber(string.sub(cheatType, -1, -1))
			local level = floor +21
			self:GiveReward(player, level)
		
			
		elseif cheatType == "DailyRewardTest" then
			self.cheatDaily = self.cheatDaily + 1
			player.PlayerDailyRewardComponent:RefreshDailyRewardTimeOnCheat(self.cheatDaily)
			
		elseif cheatType == "NeverDie" then
			player.PlayerIngameData.HPUseAmountPerSec = 0
			_UIToast:ShowMessage("무적치트 사용", player.OwnerId)
			
		elseif cheatType == "Jewerly1" then
			local idx = _UtilLogic:RandomIntegerRange(4, 42) 
			player.PlayerBackpack:AddItem(idx, 1)
			_UIToast:ShowMessage("보석1개 치트 사용 : 인덱스는 "..idx, player.OwnerId)
			
		elseif cheatType == "Jewerly1000" then
			local idx = _UtilLogic:RandomIntegerRange(4, 42) 
			player.PlayerBackpack:AddItem(idx, 1000)
			_UIToast:ShowMessage("보석1000개 치트 사용 : 인덱스는 "..idx, player.OwnerId)
		elseif cheatType == "Add10Equipments" then
			local range = 10
			while true do
				if player.PlayerData.haveEquipment[range] == true and range < 41 then
					range = range + 10
				else
					break
				end
			end
			
			if range == 50 then
				_UIToast:ShowMessage("다가지셨어요!", player.OwnerId)
				return
			end
			
			for i=1, range do
				player.PlayerData.haveEquipment[i] = true
				player.PlayerData.haveEquipment[i+40] = true
				player.PlayerData.haveEquipment[i+80] = true
				player.PlayerData.haveEquipment[i+120] = true
			end
			
			player.PlayerData:ChangedTable("haveEquipment", player.OwnerId)
			
			_UIToast:ShowMessage(tostring(math.floor(range)).."레벨까지의 장비 획득", player.OwnerId)
			
		elseif cheatType == "Get10GoldKeys" then
			player.PlayerStorage:AddCurrencyItems(6, 10, false)
			_UIToast:ShowMessage("황금열쇠 10개 치트 사용", player.OwnerId)
			
		elseif cheatType == "dataReset" then
			_UIToast:ShowMessage("데이터 리셋", player.OwnerId)
			self:ResetDB(player)
		end
	end

	@ExecSpace("ServerOnly")
	method boolean IsAdmin(string ppsn)
		-- 주어진 PPSN이 관리자 권한을 가지고 있는지 확인
		
		if self.admin[ppsn] == nil then	
			return false
		end
		if self.admin[ppsn] ~= "admin" then	
			return false
		end
		
		return true
	end

	@ExecSpace("ServerOnly")
	method void InitPPSN()
		-- 관리자 권한을 가진 계정들의 PPSN 목록을 초기화
		local ppsn = {
			"12345678901234567", -- 여기에 계정 코드를 넣어주세요
		}
		
		
		for i=1, #ppsn do
			self.admin[ppsn[i]] = "admin"
		end
	end

	@ExecSpace("Server")
	method void GiveReward(Entity player, number level)
		-- 유적지 채굴 치트에서 유물 드롭 여부를 결정하고 보상을 지급
		if level >= 22 and level <= 26 then
			local roomNum = level-21
			
			
			-- 드롭 여부 결정
			local dropProbTable = _DataService:GetTable("HistoricSiteMiningTargetBonusRewardProb")
			local randValue = _UtilLogic:RandomDouble()
			local baseProb = tonumber(dropProbTable:GetCell(roomNum, 2))
			local bonusProb = player.PlayerData.BonusProbDroppingRelic
			local prob = baseProb + bonusProb
			
			if randValue < prob then
				_UIToast:ShowMessage("유적 "..tostring(math.floor(roomNum)).."층 치트 결과, 유물 드롭됨")
				-- 드롭하는 경우, 등급 결정
				local grade = 1
				randValue = _UtilLogic:RandomDouble()
				
				local grade1Prob = tonumber(dropProbTable:GetCell(roomNum, 3))
				local grade2Prob = grade1Prob + tonumber(dropProbTable:GetCell(roomNum, 4))
				local grade3Prob = grade2Prob + tonumber(dropProbTable:GetCell(roomNum, 5))
				local grade4Prob = grade3Prob + tonumber(dropProbTable:GetCell(roomNum, 6))
				
				if randValue <= grade1Prob then
					grade = 1
				elseif randValue <= grade2Prob then
					grade = 2
				elseif randValue <= grade3Prob then
					grade = 3
				elseif randValue <= grade4Prob then
					grade = 4
				end
				
				-- 드롭할 유물 결정
				local relicTable = _DataService:GetTable("Relic")
				local idxTable = {}
				
				for i=1, relicTable:GetRowCount() do
					if (grade == 1 and relicTable:GetCell(i, 4) == "일반") or 
						(grade == 2 and relicTable:GetCell(i, 4) == "고급") or 
						(grade == 3 and relicTable:GetCell(i, 4) == "희귀") or 
						(grade == 4 and relicTable:GetCell(i, 4) == "전설") then
						table.insert(idxTable, i)
					end
				end
				
				local randIdx = _UtilLogic:RandomIntegerRange(1, #idxTable)
				local resultIdx = idxTable[randIdx]
				
				-- 데이터 반영 + ui
				local addRelic = function()
					self:SetUI_RelicBoxResult(resultIdx, player.OwnerId)
					player.PlayerRelic:AddRelic(true, resultIdx)
				end
				_TimerService:SetTimerOnce(addRelic, 0.95)
				
				-- 클라에서 보이게 추가
				--self:DropRelicBox(player, player.OwnerId)
			else
				_UIToast:ShowMessage("유적 "..tostring(math.floor(roomNum)).."층 치트 결과, 유물 드롭 안됨")
			end	
		
		
		end
	end

	@ExecSpace("Client")
	method void SetUI_RelicBoxResult(number resultIdx)
		-- 유물상자 개봉 결과를 UI로 표시
		local relicTable = _DataService:GetTable("Relic")
		
		-- 결과 팝업 UI 
		local boxResultUI = _EntityService:GetEntity("1d2caece-bf8b-4dbe-b0f1-f5acfa8df0c2")
		
		local iconUI = boxResultUI:GetChildByName("Panel"):GetChildByName("icon")
		local nameUI = boxResultUI:GetChildByName("Panel"):GetChildByName("Name")
		local titleUI = boxResultUI:GetChildByName("Panel"):GetChildByName("Title")
		
		local name = relicTable:GetCell(resultIdx, 1)
		local iconRUID = relicTable:GetCell(resultIdx, 2)
		local grade = relicTable:GetCell(resultIdx, 4)
		
		nameUI.TextComponent.Text = name
		iconUI.SpriteGUIRendererComponent.ImageRUID = iconRUID
		titleUI.TextComponent.Text = grade.." 등급 유물을 획득했습니다."
		
		boxResultUI:SetEnable(true)
		--------------------------------
		-- 끄기 예약
		local DisableUI = function()
			boxResultUI.Enable = false
		end
		
		_TimerService:SetTimerOnce(DisableUI, 3.5)
	end

	@ExecSpace("Server")
	method void SetCheatUIEnableOnServer(string ppsn)
		-- 관리자인지 확인 후 치트 UI를 활성화
		
		if self:IsAdmin(ppsn) == true then
			self:SetCheatUIEnableOnClient(ppsn)
		else
			return
		end
		
	end

	@ExecSpace("Client")
	method void SetCheatUIEnableOnClient()
		-- 클라이언트에서 치트 UI 그룹을 활성화
		_EntityService:GetEntityByPath("/ui/CheatGroup").Enable = true
	end

	@ExecSpace("Server")
	method void UseCheatForTest0314(Entity player)
		-- 테스트용 치트로 모든 아이템과 진행사항을 플레이어에게 지급
		-- 장비
		for i=1, 160 do
			player.PlayerData.haveEquipment[i] = true
		end
		player.PlayerData:SetTableClient("haveEquipment", _UtilLogic:TableToString(player.PlayerData.haveEquipment), player.OwnerId)
		
		
		-- 펫
		for i=1, 8 do
			player.PlayerPet.havePet[i] = 3
		end
		player.PlayerPet:SetTableClient("havePet", _UtilLogic:TableToString(player.PlayerPet.havePet), player.OwnerId)
		
		
		-- 칭호
		for i=1, 17 do
			player.PlayerTitle.haveItem[i] = true
		end
		player.PlayerTitle:SetTableClient("haveItem", _UtilLogic:TableToString(player.PlayerTitle.haveItem), player.OwnerId)
		
		
		-- 마을이동
		for i=1, 10 do
			player.PlayerData.TownProgress[i] = true
			player.PlayerData.TownAdmission[i] = true
		end
		player.PlayerData:SetTableClient("TownProgress", _UtilLogic:TableToString(player.PlayerData.TownProgress), player.OwnerId)
		player.PlayerData:SetTableClient("TownAdmission", _UtilLogic:TableToString(player.PlayerData.TownAdmission), player.OwnerId)
		
		
		-- 유물도감 
		for i=1, 345 do
			for j=1, 4 do
				player.PlayerRelic.RegistrationInfo[(i-1)*4 + j] = true
			end
		end
		player.PlayerRelic:SetTableClient("RegistrationInfo", _UtilLogic:TableToString(player.PlayerRelic.RegistrationInfo), player.OwnerId)
		
		
		-- 마을이동
		_TeleportService:TeleportToEntityPath(player, "/maps/Town10/SpawnLocation")
	end

	@ExecSpace("Server")
	method void ResetDB(Entity player)
		-- 플레이어의 모든 데이터를 초기 상태로 리셋
		--[[
		----------------------------------------
		local saveKey = playerId.."_PlayerData"
		local playerDB = _DataStorageService:GetGlobalDataStorage(saveKey)
		----------------------------------------
		local storageSet = {}
		storageSet["money"] = tostring(0)
		storageSet["haveEquipment"] = {}
		storageSet["TownAdmission"] = {}
		storageSet["TownProgress"] = {}
		storageSet["equiped"] = {}
		
		storageSet["RebornCount"] = tostring(0)
		storageSet["PetEgg"] = tostring(0)
		storageSet["HistoricSiteRecord"] = tostring(0)
		storageSet["collection"] =  {}
		storageSet["haveTitle"] = {}
		
		storageSet["equipedTitle"] = "0"
		storageSet["haveEmoticon"] = {}
		storageSet["equipedEmoticon"] =  {}
		storageSet["emotToken"] = "0"
