		-- 2
		for i=1, 160 do
			playerData.haveEquipment[i] = false
		end
		-------------------------------
		-- 3
		
		playerData.TownAdmission[1] = true 
		for i=2, playerData.maxTown do
			playerData.TownAdmission[i] = false
		end
		-------------------------------
		-- 4 
		playerData.TownProgress[1] = true
		for i=1, playerData.maxTown do
			playerData.TownProgress[i] = false
		end
