@Component
script UIIngreBunCollectionDetailBun extends Component

	property Entity RecipePreview = nil

	property SpriteGUIRendererComponent IngreGrade = nil

	property SpriteGUIRendererComponent IngreIcon = nil

	property TextComponent TasteScoreText = nil

	property TextComponent CostText = nil

	property SpriteGUIRendererComponent BonusTypeIcon = nil

	property TextComponent BonusTypeText = nil

	property TextComponent NameText = nil

	method void Init()
		-- 번 상세 정보 UI 컴포넌트들을 초기화하는 함수
		self.NameText = self.Entity:GetChildByName("Name").TextComponent
		
		self.RecipePreview = self.Entity:GetChildByName("RecipePreview"):GetChildByName("Img")
		local ingreSlot = self.Entity:GetChildByName("IngreSlot")
		self.IngreGrade = ingreSlot:GetChildByName("Grade").SpriteGUIRendererComponent
		self.IngreIcon = ingreSlot:GetChildByName("Icon").SpriteGUIRendererComponent
		
		local list = self.Entity:GetChildByName("List")
		local tasteScore = list:GetChildByName("TasteScore")
		tasteScore:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("TasteScore")
		self.TasteScoreText = tasteScore:GetChildByName("Value").TextComponent
		
		local cost = list:GetChildByName("Cost")
		cost:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("Price")
		cost:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData("G0001").IconRUID
		self.CostText = cost:GetChildByName("Value").TextComponent
		
		local type = list:GetChildByName("BonusType")
		type:GetChildByName("Title").TextComponent.Text = _GetLocalizationTextLogic:GetText("BunTagBonus")
		self.BonusTypeText = type:GetChildByName("Value").TextComponent
		self.BonusTypeIcon = self.BonusTypeText.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
	end

	method void Refresh(integer bunId)
		-- 지정된 번 ID의 상세 정보를 화면에 표시하는 함수
		if self.RecipePreview == nil then
			self:Init()
		end
		
		local bunData = _IngredientDataSetLogic:GetBunData(bunId)
		if isvalid(bunData) == false then
			return
		end
		
		for i, child in pairs(self.RecipePreview.Children) do
			child.Enable = false
		end
		
		local rectSizeX = self.RecipePreview.UITransformComponent.RectSize.x
		
		local bottomDraw = RecipeIngreDrawData()
		bottomDraw:Init(bunId, _RecipeIngreDrawEnum.Bun, "Bottom", false, nil)
		local bottom = _DrawBurgerUIService:ReturnIngreData(bottomDraw, rectSizeX, nil)
		local bottomDrawData = _DrawBurgerUIService:DrawIngredientUI(bottom, 1, 1, self.RecipePreview)
		
		local topDraw = RecipeIngreDrawData()
		topDraw:Init(bunId, _RecipeIngreDrawEnum.Bun, "Top", false, nil)
		local top = _DrawBurgerUIService:ReturnIngreData(topDraw, rectSizeX, bottomDrawData)
		local topDrawData = _DrawBurgerUIService:DrawIngredientUI(top, 2, 2, self.RecipePreview)
		
		local topData = _IngredientDataSetLogic:GetBunDetailData(bunId, "Top")
		self.IngreGrade.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(bunData.Grade)
		self.IngreIcon.ImageRUID = topData.IconRUID
		self.NameText.Text = _GetLocalizationTextLogic:GetText(topData.NameKey)
		
		local player = _UserService.LocalPlayer
		local collected = player.PlayerCollection.BunCollection[bunId]
		if collected == nil then collected = false end
		
		local materialId = collected and _IconRuidEnum.EmptyMaterial or _IconRuidEnum.GrayScaleMaterial
		self.IngreIcon:ChangeMaterial(materialId)
		bottomDrawData[8].SpriteGUIRendererComponent:ChangeMaterial(materialId)
		topDrawData[8].SpriteGUIRendererComponent:ChangeMaterial(materialId)
		
		self.TasteScoreText.Text = tostring(topData.TastePoint)
		self.CostText.Text = tostring(topData.BaseCost)
		
		if _UtilLogic:IsNilorEmptyString(bunData.Tag) then
			self.BonusTypeIcon.Entity.Enable = false
			self.BonusTypeText.Text = _GetLocalizationTextLogic:GetText("None")
		else
			local tagData = _RecipeTagDataSetLogic:GetRecipeTagData(bunData.Tag)
			self.BonusTypeIcon.Entity.Enable = true
			self.BonusTypeIcon.ImageRUID = tagData.IconRUID
			self.BonusTypeText.Text = _GetLocalizationTextLogic:GetText(tagData.TagNameKey)
		end
	end

end