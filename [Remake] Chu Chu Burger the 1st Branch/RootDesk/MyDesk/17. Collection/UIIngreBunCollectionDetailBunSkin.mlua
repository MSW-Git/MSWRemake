@Component
script UIIngreBunCollectionDetailBunSkin extends Component

	property Entity RecipePreview = nil

	property SpriteGUIRendererComponent IngreGrade = nil

	property SpriteGUIRendererComponent IngreIcon = nil

	property TextComponent UseEffectText = nil

	property TextComponent CollectEffectText = nil

	property Entity BuyButton = nil

	property Entity BtnBuyInfo = nil

	property TextComponent BuyCostText = nil

	property Entity UnlockInfo = nil

	property TextComponent UnlockInfoText = nil

	property Entity AlreadyGet = nil

	property TextComponent NameText = nil

	property Entity BtnUnlockInfo = nil

	property Entity BtnTooltip = nil

	property TextComponent BuyInfoTitle = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 번 스킨 상세 정보 UI 컴포넌트들을 초기화하는 함수
		self.NameText = self.Entity:GetChildByName("Name").TextComponent
		
		self.RecipePreview = self.Entity:GetChildByName("RecipePreview"):GetChildByName("Img")
		local ingreSlot = self.Entity:GetChildByName("IngreSlot")
		ingreSlot:GetChildByName("BG").SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.BunSkinSlotBG
		self.IngreIcon = ingreSlot:GetChildByName("Icon").SpriteGUIRendererComponent
		
		local list = self.Entity:GetChildByName("List")
		local useEffect = list:GetChildByName("UseEffect")
		self.UseEffectText = useEffect:GetChildByName("Value").TextComponent
		
		local collectEffect = list:GetChildByName("CollectEffect")
		self.CollectEffectText = collectEffect:GetChildByName("Value").TextComponent
		
		self.BuyButton = self.Entity:GetChildByName("BuyButton")
		self.BtnBuyInfo = self.BuyButton:GetChildByName("BuyInfo")
		self.BuyInfoTitle = self.BtnBuyInfo:GetChildByName("UIText").TextComponent
		self.BuyCostText = self.BtnBuyInfo:GetChildByName("CostText").TextComponent
		self.BuyCostText.Entity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData("G1001").IconRUID
		
		self.BtnUnlockInfo = self.BuyButton:GetChildByName("ButtonUnlockInfo")
		self.BtnTooltip = self.BuyButton:GetChildByName("Tooltip")
		
		self.UnlockInfo = self.Entity:GetChildByName("UnlockInfo")
		self.UnlockInfoText = self.UnlockInfo:GetChildByName("Text").TextComponent
		
		self.AlreadyGet = self.Entity:GetChildByName("AlreadyGet")
		
		self.BuyButton:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			local bunData = _IngredientDataSetLogic:GetBunSkinData(self._T.bunSkinId)
			if isvalid(bunData) == false then
				return
			end
			
			if bunData.GetCondition ~= "Buy" then
				if bunData.GetCondition == "StagePass" then
					local openKey = string.sub(bunData.ConditionValue, 1, 1)
					_BMDropDownLogic.UIStagePass:Open(openKey)
								
				elseif bunData.GetCondition == "PiggyBank" then
		            _BMDropDownLogic.UIPiggyBank:Open()
					
				end
				
				return
			end
			
			local onOk = function()
				local player = _UserService.LocalPlayer
			local cost = tonumber(bunData.ConditionValue)
				if player.PlayerOutgameManager:GetDiamondCount() < cost then
					_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("NoDiaToastMsg"))
					_UIGroupManager.DiaInfoGroup.UIDiaInfo:OpenUI()
					return
				end
				
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				player.PlayerCollection:RequestAddBunSkinCollection(self._T.bunSkinId)
			end
			
			local onCancel = function() end
			
			local costText = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(tonumber(bunData.ConditionValue)))
			_UIPurchasePopupLogic:OpenNoRefunablePurchasePopup(costText, onOk, false)
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		end)
	end

	method void Refresh(integer bunSkinId)
		-- 지정된 번 스킨 ID의 상세 정보를 화면에 표시하는 함수
		if self.RecipePreview == nil then
			self:Init()
		end
		
		self._T.bunSkinId = bunSkinId
		
		local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(bunSkinId)
		if bunSkinData == nil then
			return
		end
		
		local rectSizeX = self.RecipePreview.UITransformComponent.RectSize.x
		local bottomDraw = RecipeIngreDrawData()
		bottomDraw:Init(1, _RecipeIngreDrawEnum.Bun, "Bottom", true, bunSkinId)
		local bottom = _DrawBurgerUIService:ReturnIngreData(bottomDraw, rectSizeX, nil)
		local bottomDrawData = _DrawBurgerUIService:DrawIngredientUI(bottom, 1, 1, self.RecipePreview)
		
		local topDraw = RecipeIngreDrawData()
		topDraw:Init(1, _RecipeIngreDrawEnum.Bun, "Top", true, bunSkinId)
		local top = _DrawBurgerUIService:ReturnIngreData(topDraw, rectSizeX, bottomDrawData)
		_DrawBurgerUIService:DrawIngredientUI(top, 2, 2, self.RecipePreview)
		
		local bunDetailData = _IngredientDataSetLogic:GetBunSkinDetailData(bunSkinId, "Top")
		self.IngreIcon.ImageRUID = bunDetailData.IconRUID
		self.NameText.Text = _GetLocalizationTextLogic:GetText(bunDetailData.NameKey)
		
		local useEffectPercent = math.floor(_GetConfigDataLogic:GetConfigNumDataByKey("BunSkinUseBonusAmount")*100)
		self.UseEffectText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("IngreBunCollectionBunSkinUseEffectText", useEffectPercent)
		
		local collectEffectPercent = math.floor(_GetConfigDataLogic:GetConfigNumDataByKey("BunSkinCollectBonusAmountPerCount")*100)
		self.CollectEffectText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("IngreBunCollectionBunSkinBonusText", collectEffectPercent)
		
		local player = _UserService.LocalPlayer
		local isOpened = player.PlayerCollection.BunSkinCollection[bunSkinId]
		if isOpened == nil then isOpened = false end
		
		self.AlreadyGet.Enable = isOpened
		if isOpened == true then
			self.BuyButton.Enable = false
			self.UnlockInfo.Enable = false
			return
		end
		
		if bunSkinData.GetCondition == "Buy" then
			self.BuyButton.Enable = true
			self.UnlockInfo.Enable = false
			self.BtnBuyInfo.Enable = true
			self.BtnUnlockInfo.Enable = false
			self.BtnTooltip.Enable = false
			
			local cost = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(tonumber(bunSkinData.ConditionValue)))
			self.BuyCostText.Text = cost
			self.BuyCostText.FontColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#fa5246") or _ColorCodeEnum:GetColor("#ffffff")
			self.BuyCostText.OutlineColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#FFFFFF") or _ColorCodeEnum:GetColor("#af7016")
			self.BuyInfoTitle.FontColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#fa5246") or _ColorCodeEnum:GetColor("#ffffff")
			self.BuyInfoTitle.OutlineColor = player.PlayerOutgameManager:GetDiamondCount() < tonumber(bunSkinData.ConditionValue) and _ColorCodeEnum:GetColor("#FFFFFF") or _ColorCodeEnum:GetColor("#af7016")
		
		elseif bunSkinData.GetCondition == "StageClear" then
			self.BuyButton.Enable = false
			self.UnlockInfo.Enable = true
			
			local stageData = _StageDataSetLogic:GetStageData(tonumber(bunSkinData.ConditionValue))
			self.UnlockInfoText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("BunSkinGetConditionStageClear", _GetLocalizationTextLogic:GetText(stageData.NameKey))
			
		elseif bunSkinData.GetCondition == "StagePass" then
			self.BuyButton.Enable = true
			self.UnlockInfo.Enable = false
			self.BtnBuyInfo.Enable = false
			self.BtnUnlockInfo.Enable = true
			self.BtnTooltip.Enable = true
			
			self.BtnUnlockInfo.TextComponent.Text = _GetLocalizationTextLogic:GetText("BunSkinGetButtonStagePass")
			local productData = _StagePassDataLogic:GetStagePassProductData(bunSkinData.ConditionValue)
			self.BtnTooltip.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("BunSkinGetConditionStagePass", _GetLocalizationTextLogic:GetText(productData.PassNameKey))
			
		elseif bunSkinData.GetCondition == "PiggyBank" then
			self.BuyButton.Enable = true
			self.UnlockInfo.Enable = false
			self.BtnBuyInfo.Enable = false
			self.BtnUnlockInfo.Enable = true
			self.BtnTooltip.Enable = true
			
			self.BtnUnlockInfo.TextComponent.Text = _GetLocalizationTextLogic:GetText("BunSkinGetButtonPiggyBank")
			self.BtnTooltip.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("BunSkinGetConditionPiggyBank", bunSkinData.ConditionValue)	
			
		end
	end

end