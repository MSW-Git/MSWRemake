@Component
script UIIngreBunCollectionSlot extends Component

	property Entity Grade = nil

	property Entity Icon = nil

	property Entity RewardDot = nil

	property Entity Selected = nil

	property integer id = 0

	property Entity Locked = nil

	property Entity Deco = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI 요소들을 참조하는 함수
		self.Grade = self.Entity:GetChildByName("Grade")
		self.Icon = self.Entity:GetChildByName("Icon")
		self.RewardDot = self.Entity:GetChildByName("RewardDot")
		self.Selected = self.Entity:GetChildByName("Selected")
		self.Locked = self.Entity:GetChildByName("Locked")
		self.Deco = self.Entity:GetChildByName("Deco")
	end

	method void RefreshIngre(integer ingreId)
		-- 재료 컴렉션 슬롯의 데이터를 갱신하는 함수
		local ingredientData = _IngredientDataSetLogic:GetIngredientData(ingreId)
		
		if isvalid(ingredientData) == false then
			self.Entity.Enable = false
			return
		end
		
		self.id = ingreId
		self.Deco.Enable = false
		
		self.Grade.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(ingredientData.Grade)
		self.Icon.SpriteGUIRendererComponent.ImageRUID = ingredientData.IconRUID
		
		self.Locked.Enable = false
		
		local player = _UserService.LocalPlayer
		local collected = player.PlayerCollection.IngredientCollection[ingreId]
		if collected == nil then collected = false end
		
		local materialId = collected and _IconRuidEnum.EmptyMaterial or _IconRuidEnum.GrayScaleMaterial
		self.Icon.SpriteGUIRendererComponent:ChangeMaterial(materialId)
		
		local isRedDotEnable = function()	
			local getReward = player.PlayerCollection.IngredientCollectionGetReward[ingreId]
			if getReward == nil then getReward = false end
			
			return collected and not getReward	
		end
		self.RewardDot.Enable =  isRedDotEnable()
	end

	method void RefreshBun(integer bunId)
		-- 번 컴렉션 슬롯의 데이터를 갱신하는 함수
		local bunData = _IngredientDataSetLogic:GetBunData(bunId)
		
		if isvalid(bunData) == false then
			self.Entity.Enable = false
			return
		end
		
		self.id = bunId
		self.Deco.Enable = false
		
		self.Grade.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(bunData.Grade)
		self.Icon.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:GetBunDetailData(bunId, "Top").IconRUID
		
		self.Locked.Enable = false
		
		local player = _UserService.LocalPlayer
		local collected = player.PlayerCollection.BunCollection[bunId]
		if collected == nil then collected = false end
		
		local materialId = collected and _IconRuidEnum.EmptyMaterial or _IconRuidEnum.GrayScaleMaterial
		self.Icon.SpriteGUIRendererComponent:ChangeMaterial(materialId)
		
		local isRedDotEnable = function()
			local getReward = player.PlayerCollection.BunCollectionGetReward[bunId]
			if getReward == nil then getReward = false end
				
			return collected and not getReward
		end
		self.RewardDot.Enable =  isRedDotEnable()
	end

	method void RefreshBunSkin(integer bunSkinId)
		-- 번 스킨 컴렉션 슬롯의 데이터를 갱신하는 함수
		local bunSkinData = _IngredientDataSetLogic:GetBunSkinData(bunSkinId)
		if isvalid(bunSkinData) == false then
			self.Entity.Enable = false
			return
		end
		
		self.id = bunSkinId
		self.Deco.Enable = true
		
		self.Grade.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.BunSkinSlotBG
		self.Icon.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:GetBunSkinDetailData(bunSkinId, "Top").IconRUID
		
		local player = _UserService.LocalPlayer
		local collected = player.PlayerCollection.BunSkinCollection[bunSkinId]
		if collected == nil then collected = false end
		
		self.Icon.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		self.Locked.Enable = not collected
		
		self.RewardDot.Enable = false
		
		self.id = bunSkinId
	end

	method void EnableSelected(boolean isSelected)
		-- 슬롯의 선택 상태를 설정하는 함수
		self.Selected.Enable = isSelected
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 슬롯 클릭 이벤트 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_UICollectionLogic.uiIngreBunCollection:OnClickSlot(self.id)
	end

end