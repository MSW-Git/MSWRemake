@Component
script UIBadgeSlot extends Component

	property SpriteGUIRendererComponent Icon = nil

	property Entity Grade = nil

	property TextComponent Name = nil

	property TextComponent Desc = nil

	property SliderComponent ProgressSlider = nil

	property TextComponent ProgressText = nil

	method void Init()
		-- UI 컴포넌트 참조를 초기화하는 함수
		self.Icon = self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		self.Grade = self.Entity:GetChildByName("Grade")
		self.Name = self.Entity:GetChildByName("Name").TextComponent
		self.Desc = self.Entity:GetChildByName("Desc").TextComponent
		self.ProgressSlider = self.Entity:GetChildByName("ProgressSlider").SliderComponent
		self.ProgressText = self.ProgressSlider.Entity:GetChildByName("ProgressText").TextComponent
	end

	method void Refresh(string badgeId)
		-- 배지 슬롯 UI를 배지 데이터로 업데이트하는 함수
		if self.Icon == nil then
			self:Init()
		end
		
		local badgeData = _BadgeDataSetLogic:GetBadgeData(badgeId)
		local player = _UserService.LocalPlayer
		local isAchieved = player.PlayerBadge.BadgeAchieved[badgeId]
		if isAchieved == nil then
			isAchieved = false
		end
		
		self.Icon.ImageRUID = badgeData.IconRUID
		local materialId = isAchieved and _IconRuidEnum.EmptyMaterial or _IconRuidEnum.GrayScaleMaterial
		self.Icon:ChangeMaterial(materialId)
		
		self.Name.Text = badgeData.Name
		self.Desc.Text = badgeData.Desc
		
		local gradeColor = function(g)
			if g == 0 then
				return _ColorCodeEnum:GetColor("#161615")
			elseif g == 1 then
				return _ColorCodeEnum:GetColor("#F78029")
			elseif g == 2 then
				return _ColorCodeEnum:GetColor("#5F48D9")
			end
		end
		
		
		self.Grade.SpriteGUIRendererComponent.Color = gradeColor(badgeData.Grade)
		self.Grade.TextComponent.Text = _GetLocalizationTextLogic:GetText("UIBadgeFilter"..badgeData.Grade)
		
		
		self.ProgressSlider.Entity.Enable = badgeData.IsProgressVisible
		if badgeData.IsProgressVisible == true then
			local userProgress = player.PlayerBadge.BadgeProgress[badgeData.TypeId]
			if userProgress == nil then
				userProgress = 0
			end
			local typeValue = badgeData.TypeValue
			
			self.ProgressSlider.Value = userProgress/typeValue
			if self.ProgressSlider.Value > 0 and self.ProgressSlider.Value < 0.05 then
				self.ProgressSlider.Value = 0.05
			end
			
			local userProgressText = _StringUtilLogic:ReturnThousandsSeparatedString(userProgress)
			local typeValueText = _StringUtilLogic:ReturnThousandsSeparatedString(typeValue)
			self.ProgressText.Text = string.format("%s/%s", userProgressText, typeValueText)	
		end
	end

end