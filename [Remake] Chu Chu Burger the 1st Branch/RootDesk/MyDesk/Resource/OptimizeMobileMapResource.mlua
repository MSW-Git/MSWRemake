@Component
script OptimizeMobileMapResource extends Component

	property string originRUID = ""

	property number multiplication = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 모바일 최적화된 맵 리소스로 스프라이트 설정 및 크기 조정
		self.Entity.SpriteRendererComponent.SpriteRUID = _ResourceLoadLogic:OptimizeMobileResource(self.originRUID)
		self.Entity.TransformComponent.Scale.x = self.Entity.TransformComponent.Scale.x * _ResourceLoadLogic:OptimizeMobileSize(self.multiplication)
		self.Entity.TransformComponent.Scale.y = self.Entity.TransformComponent.Scale.y * _ResourceLoadLogic:OptimizeMobileSize(self.multiplication)
	end

end