@Component
script OptimizeMobileResource extends Component

	property string originRUID = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 모바일 최적화된 이미지 리소스로 스프라이트 GUI 렌더러 설정
		self.Entity.SpriteGUIRendererComponent.ImageRUID = _ResourceLoadLogic:OptimizeMobileResource(self.originRUID)
	end

end