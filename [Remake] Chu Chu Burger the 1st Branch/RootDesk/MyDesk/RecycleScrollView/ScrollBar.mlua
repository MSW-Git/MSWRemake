@Component
script ScrollBar extends Component

	property Entity Handle = nil

	property boolean IsDrag = false

	property Vector2 CurrentNormalizedPosition = Vector2(0,0)

	property Vector2 PrevTouchedPosition = Vector2(0,0)

	property integer Type = 0

	property number MaxContentSize = 0

	property RecycleScrollView ScrollView = nil

	property number PrePosition = 0

	@ExecSpace("ClientOnly")
	method void SetScrollNormalizedPosition(Vector2 position)
		-- 스크롤바의 정규화된 위치를 설정하고 스크롤뷰에 반영
		if self.Type ~= self.ScrollView.ScrollingType then
			return
		end
		
		local nextPosition = self.Handle.UITransformComponent.anchoredPosition + position
		if self.Type == _ScrollingType.Horizontal then
			local minX = (self.Handle.UITransformComponent.Pivot.x) * self.Handle.UITransformComponent.RectSize.x
			local maxX = self.Entity.UITransformComponent.RectSize.x -(1 - self.Handle.UITransformComponent.Pivot.x) * self.Handle.UITransformComponent.RectSize.x
			
			if nextPosition.x >= maxX then
				self.Handle.UITransformComponent.anchoredPosition.x = maxX
			elseif nextPosition.x <= minX then
				self.Handle.UITransformComponent.anchoredPosition.x = minX
			else
				self.Handle.UITransformComponent.anchoredPosition.x = nextPosition.x
			end
		elseif self.Type == _ScrollingType.Vertical then
			local maxY = -(1 - self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y
			local minY = -self.Entity.UITransformComponent.RectSize.y + (self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y
			
			if nextPosition.y >= maxY then
				self.Handle.UITransformComponent.anchoredPosition.y = maxY
			elseif nextPosition.y <= minY then
				self.Handle.UITransformComponent.anchoredPosition.y = minY
			else
				self.Handle.UITransformComponent.anchoredPosition.y = nextPosition.y
			end
		end
		
		local normalizedPosition = self:CalcNormalizedPosition()
		local currentPosition = (normalizedPosition) * self.MaxContentSize
		
		local move = self.PrePosition - currentPosition
		if self.Type == _ScrollingType.Horizontal then
			self.ScrollView:OnScroll(Vector2(move, 0))
		elseif self.Type == _ScrollingType.Vertical then
			self.ScrollView:OnScroll(Vector2(0, move))
		end
		
		self.PrePosition = currentPosition
	end

	@ExecSpace("ClientOnly")
	method number CalcNormalizedPosition()
		-- 현재 스크롤바 핸들 위치를 기반으로 정규화된 위치값 계산
		if self.Type == _ScrollingType.Horizontal then
			return ((self.Handle.UITransformComponent.anchoredPosition.x - self.Handle.UITransformComponent.Pivot.x * self.Handle.UITransformComponent.RectSize.x) / (self.Entity.UITransformComponent.RectSize.x - self.Handle.UITransformComponent.RectSize.x))
		elseif self.Type == _ScrollingType.Vertical then
			return ((self.Handle.UITransformComponent.anchoredPosition.y + (1 - self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y) / (self.Entity.UITransformComponent.RectSize.y - self.Handle.UITransformComponent.RectSize.y))
		end
	end

	@ExecSpace("ClientOnly")
	method void SetScrollBar(Entity scrollView)
		-- 스크롤뷰와 연결하여 스크롤바 크기와 위치 설정
		if self.Handle == nil then
			self.Handle = self.Entity:GetChildByName("Handle")	
		end
		
		self.ScrollView = scrollView.RecycleScrollView
		
		local startPoint = 0
		local totalBarSize = 0
		
		if self.Type == _ScrollingType.Horizontal then
			self.MaxContentSize = (scrollView.RecycleScrollView.ContentBoundsMax.x - scrollView.RecycleScrollView.ContentBoundsMin.x) - (scrollView.RecycleScrollView.BoundingMax.x - scrollView.RecycleScrollView.BoundingMin.x)
			startPoint = -scrollView.RecycleScrollView.ContentBoundsMin.x
			totalBarSize = (self.Entity.UITransformComponent.RectSize.x - ((1 - self.Handle.UITransformComponent.Pivot.x) * self.Handle.UITransformComponent.RectSize.x))
			
			local barSizeRatio = (scrollView.RecycleScrollView.BoundingMax.x - scrollView.RecycleScrollView.BoundingMin.x) / (scrollView.RecycleScrollView.ContentBoundsMax.x - scrollView.RecycleScrollView.ContentBoundsMin.x)
			barSizeRatio = math.max(0, barSizeRatio)
			barSizeRatio = math.min(barSizeRatio, 1)
			local barSize = self.Entity.UITransformComponent.RectSize.x * barSizeRatio
			self.Handle.UITransformComponent.RectSize.x = barSize
		elseif self.Type == _ScrollingType.Vertical then
			self.MaxContentSize = (scrollView.RecycleScrollView.ContentBoundsMin.y - scrollView.RecycleScrollView.ContentBoundsMax.y) - (scrollView.RecycleScrollView.BoundingMin.y - scrollView.RecycleScrollView.BoundingMax.y)
			startPoint = -scrollView.RecycleScrollView.ContentBoundsMin.y
			totalBarSize = (self.Entity.UITransformComponent.RectSize.y -(self.Handle.UITransformComponent.Pivot.y * self.Handle.UITransformComponent.RectSize.y))
			
			local barSizeRatio =  (scrollView.RecycleScrollView.BoundingMin.y - scrollView.RecycleScrollView.BoundingMax.y) / (scrollView.RecycleScrollView.ContentBoundsMin.y - scrollView.RecycleScrollView.ContentBoundsMax.y)
			barSizeRatio = math.max(0, barSizeRatio)
			barSizeRatio = math.min(barSizeRatio, 1)
			local barSize = self.Entity.UITransformComponent.RectSize.y * barSizeRatio
			self.Handle.UITransformComponent.RectSize.y = barSize
		end
		
		local barPos = 0
		if self.ScrollView.ScrollingType == self.Type then
			local contentRatio = startPoint / self.MaxContentSize
			barPos = contentRatio * totalBarSize
		end
		
		if self.Type == _ScrollingType.Horizontal then
			self.Handle.UITransformComponent.anchoredPosition.x = barPos + (self.Handle.UITransformComponent.Pivot.x * self.Handle.UITransformComponent.RectSize.x)
		elseif self.Type == _ScrollingType.Vertical then
			self.Handle.UITransformComponent.anchoredPosition.y = barPos - ((1 - self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y)
		end
		
		self.PrePosition = startPoint
	end

	@ExecSpace("ClientOnly")
	method void SetScrollPosition(number dir)
		-- 스크롤 방향에 따라 스크롤바 핸들 위치 업데이트
		local totalBarSize = 0
		if self.Type == _ScrollingType.Horizontal then
			totalBarSize = (self.Entity.UITransformComponent.RectSize.x - ((1 - self.Handle.UITransformComponent.Pivot.x) * self.Handle.UITransformComponent.RectSize.x))
		elseif self.Type == _ScrollingType.Vertical then
			totalBarSize = (self.Entity.UITransformComponent.RectSize.y -(self.Handle.UITransformComponent.Pivot.y * self.Handle.UITransformComponent.RectSize.y))
		end
		
		self.PrePosition = self.PrePosition - dir
		local normalize = self.PrePosition / self.MaxContentSize
		local barPos = normalize * totalBarSize
		
		if self.Type == _ScrollingType.Horizontal then
			local minX = (self.Handle.UITransformComponent.Pivot.x) * self.Handle.UITransformComponent.RectSize.x
			local maxX = self.Entity.UITransformComponent.RectSize.x -(1 - self.Handle.UITransformComponent.Pivot.x) * self.Handle.UITransformComponent.RectSize.x
			
			local nextPosition = barPos + (self.Handle.UITransformComponent.Pivot.x * self.Handle.UITransformComponent.RectSize.x)
			if nextPosition >= maxX then
				self.Handle.UITransformComponent.anchoredPosition.x = maxX
			elseif nextPosition <= minX then
				self.Handle.UITransformComponent.anchoredPosition.x = minX
			else
				self.Handle.UITransformComponent.anchoredPosition.x = nextPosition
			end
			
		elseif self.Type == _ScrollingType.Vertical then
			local maxY = -(1 - self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y
			local minY = -self.Entity.UITransformComponent.RectSize.y + (self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y
			
			local nextPosition = barPos - ((1 - self.Handle.UITransformComponent.Pivot.y) * self.Handle.UITransformComponent.RectSize.y)
			if nextPosition >= maxY then
				self.Handle.UITransformComponent.anchoredPosition.y = maxY
			elseif nextPosition <= minY then
				self.Handle.UITransformComponent.anchoredPosition.y = minY
			else
				self.Handle.UITransformComponent.anchoredPosition.y = nextPosition
			end	
		end
	end

	@ExecSpace("ClientOnly")
	method void Clear()
		-- 스크롤바 상태 초기화
		self.IsDrag = false
		self.PrePosition = 0
	end

	@ExecSpace("ClientOnly")
	method void OnMapLeave(Entity leftMap)
		-- 맵 떠날 때 스크롤바 상태 정리
		self:Clear()
	end

	@EventSender("Self")
	handler HandleUITouchBeginDragEvent(UITouchBeginDragEvent event)
		-- 스크롤바 드래그 시작 시 초기 터치 위치 저장
		
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.IsDrag == true then
			return
		end
		
		if Environment:IsMobilePlatform() == false then
			if TouchId ~= -1 then
				return
			end
		end
		
		
		TouchPoint = _ScrollMathLogic:GetTouchPoint(TouchPoint)
		self.PrevTouchedPosition = TouchPoint
		self.IsDrag = true
	end

	@EventSender("Self")
	handler HandleUITouchDragEvent(UITouchDragEvent event)
		-- 스크롤바 드래그 중 위치 업데이트 처리
		
		local Entity = event.Entity
		local TouchDelta = event.TouchDelta
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.IsDrag == false then
			return
		end
		
		if Environment:IsMobilePlatform() == false then
			if TouchId ~= -1 then
				return
			end
		end
		
		TouchPoint = _ScrollMathLogic:GetTouchPoint(TouchPoint)
		self:SetScrollNormalizedPosition(TouchPoint - self.PrevTouchedPosition)
		self.PrevTouchedPosition = TouchPoint
	end

	@EventSender("Self")
	handler HandleUITouchEndDragEvent(UITouchEndDragEvent event)
		-- 스크롤바 드래그 종료 시 드래그 상태 해제
		
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.IsDrag == false then
			return
		end
		
		if Environment:IsMobilePlatform() == false then
			if TouchId ~= -1 then
				return
			end
		end
		
		self.PrevTouchedPosition = Vector2.zero
		self.IsDrag = false
	end

end