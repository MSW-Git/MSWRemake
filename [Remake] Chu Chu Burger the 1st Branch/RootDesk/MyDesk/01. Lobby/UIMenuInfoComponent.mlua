@Component
script UIMenuInfoComponent extends Component

	property Entity BurgerImage = nil

	property Entity TypeIcon = nil

	property Entity Price = nil

	property Entity SalesCount = nil

	property Entity TrialBuff = nil

	property Entity Slot = nil

	property Entity Empty = nil

	property Entity TypeColor = nil

	property Entity TasteGradeIcon = nil

	property Entity Locked = nil

	property Entity Plus = nil

	property Entity EmptySalesCount = nil

	property Entity DebugMonitor = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 컴포넌트들을 초기화하는 함수
		self.Slot = self.Entity:GetChildByName("Slot")
		self.TypeColor = self.Slot:GetChildByName("TypeColor")
		self.BurgerImage = self.Slot:GetChildByName("BurgerMask"):GetChildByName("BurgerImage")
		self.TypeIcon = self.Slot:GetChildByName("TypeIcon")
		self.Price = self.Slot:GetChildByName("PriceInfo"):GetChildByName("Price")
		self.SalesCount = self.Slot:GetChildByName("SalesCount")
		self.TrialBuff = self.Slot:GetChildByName("TrialBuff")
		self.TasteGradeIcon = self.Slot:GetChildByName("TasteGradeIcon")
		
		self.Empty = self.Entity:GetChildByName("Empty")
		self.Locked = self.Empty:GetChildByName("Locked")
		self.Plus = self.Empty:GetChildByName("Plus")
		self.EmptySalesCount = self.Empty:GetChildByName("SalesCount")
		
		self.DebugMonitor = self.Slot:GetChildByName("DebugMonitor")
		self.DebugMonitor:SetEnable(false)
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer recipeId, integer slotIndex)
		-- 메뉴 정보를 새로고침하는 함수
		---@type RecipeData
		local recipeData = _UserService.LocalPlayer.PlayerRecipe.Recipes[recipeId]
		if recipeData == nil then
			self.Slot.Enable = false
			self.Empty.Enable = true
			
			local locked = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer, _UpgradeTypeEnum.DisplayCount) < slotIndex
			self.Empty.SpriteGUIRendererComponent.Color = locked and _ColorCodeEnum:GetColor("#C2C0B9") or _ColorCodeEnum:GetColor("#E9E1D6")
			self.EmptySalesCount.SpriteGUIRendererComponent.Color = locked and _ColorCodeEnum:GetColor("#C2C0B9") or _ColorCodeEnum:GetColor("#E9E1D6")
			self.Locked.Enable = locked
			self.Plus.Enable = not locked
			return
		end
		
		self.Slot.Enable = true
		self.Empty.Enable = false
		
		_DrawBurgerUIService:DrawBurgerUI(self.BurgerImage, recipeData.IngreList, self.BurgerImage.UITransformComponent.RectSize.x)
		
		local tagData = _RecipeTagDataSetLogic:GetRecipeTagData(recipeData.Tag)
		self.TypeIcon.SpriteGUIRendererComponent.ImageRUID = tagData.IconRUID
		self.TypeColor.SpriteGUIRendererComponent.Color = tagData.SlotColor
		
		local isTrend = _RecipeDataSetLogic:IsRecipeTrend(_UserService.LocalPlayer, recipeId)
		if _UtilLogic:IsNilorEmptyString(isTrend) == false then
			if isTrend == "Positive" then
				self.TypeIcon.SpriteGUIRendererComponent:ChangeMaterial(_RecipeDataSetLogic.PositiveMaterial)
			elseif isTrend == "Negative" then
				self.TypeIcon.SpriteGUIRendererComponent:ChangeMaterial(_RecipeDataSetLogic.NegativeMaterial)
			end
		else
			self.TypeIcon.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		end
		
		local tasteGradeData = _TasteGradeDataSetLogic:ReturnGradeDataByScore(recipeData.TasteScore)
		self.TasteGradeIcon.SpriteGUIRendererComponent.ImageRUID = tasteGradeData.RUID
		
		local isRecipeCombo = _RecipeTagDataSetLogic:IsRecipeComboActiveForTag(_UserService.LocalPlayer, recipeData.Tag)
		self.Price.TextComponent.FontColor = isRecipeCombo and _ColorCodeEnum:GetColor("#FFE84E") or _ColorCodeEnum:GetColor("#FFFFFF")
		self.Price.TextComponent.OutlineColor = isRecipeCombo and _ColorCodeEnum:GetColor("#814514") or _ColorCodeEnum:GetColor("#585043")
		
		local price = _RecipeDataSetLogic:GetRecipeCost(recipeData, _UserService.LocalPlayer, true, true)
		self.Price.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(price))
		
		local salesCount = _UserService.LocalPlayer.MenuManager:ReturnSalesBurgerByRecipeID(recipeId)
		local salesCountStr = tostring(math.floor(salesCount))
		self.SalesCount.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Things_Format", salesCountStr) 
		
		self.TrialBuff.Enable = recipeData.IsTrialBuff
	end

	@ExecSpace("ClientOnly")
	method void UpdateDebugMonitorUIRecipe(integer recipeId, integer slotIndex)
		-- 디버그 모니터 UI 레시피를 업데이트하는 함수
		local uniqueIdText = "UniqueId : ".. tostring(_UserService.LocalPlayer.MenuManager:ReturnRecipeUniqueID(recipeId))
		
		---@type RecipeData
		local recipeData = _UserService.LocalPlayer.PlayerRecipe.Recipes[recipeId]
		if isvalid(recipeData) == false then
			return
		end
		
		local tasteGradeData = _TasteGradeDataSetLogic:ReturnGradeDataByScore(recipeData.TasteScore)
		
		local attractiveScoreText = "AttScore : ".. tostring(_UserService.LocalPlayer.CustomerManager:CalcRecipeAttractive(recipeId))
		
		self.DebugMonitor.TextComponent.Text = uniqueIdText .." \n"..attractiveScoreText
	end

end