@Logic
script UILobbyManager extends Logic

	property Entity MainMenuButton = "374d1cb8-196f-48d6-9a39-852e9e197aab"

	property Entity MainMenuPanel = "cb87ca9f-44ce-49fe-90d7-66abc8306694"

	property Entity StoreInfoArea = "2e17da92-1f49-4b68-be33-ea03d9e93a9f"

	property boolean StoreInfoEnable = false

	property number longDuration = 0.2

	property number shortDuration = 0.1

	property Entity MenuLayout = "247ee886-631e-4416-a816-be654e8b0652"

	property Entity MainMenuEmpManageBtn = "159887a0-6abe-4d33-bebe-018ef295ee07"

	property Entity UIShopPurchaePopup = "f559d238-6ce3-4076-bd00-2a53657e0433"

	property Entity TutorialGuideButton = "e85c7eff-23c1-4758-ba20-69306b4036f9"

	property Entity StoreInfoRecordPage = "a9bc7490-43a1-44ec-8cee-ca498e8e9517"

	property Entity UISpecialShopPurchasePopup = "76b85d9e-dd8d-405b-94bb-accad3a66d4f"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI를 초기화하는 함수
		self.MainMenuPanel:SetEnable(false)
		
		
		self.MainMenuEmpManageBtn:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIEmployeeManageService:UIOpen() 
		end )
		
		self.StoreInfoArea:SetVisible(false)
		self.StoreInfoArea.UITransformComponent.anchoredPosition.x = -630
		self.StoreInfoArea.UITweenPosition.to.x = 770
		self.StoreInfoArea.UITweenPosition.duration = self.longDuration
	end

	@ExecSpace("ClientOnly")
	method void HideStoreInfoArea()
		-- 상점 정보 영역을 숨기는 함수
		self.StoreInfoEnable = false
		self.StoreInfoArea.UIStoreInfoPageManager:TabOffAll()
		
		self.StoreInfoArea.UITransformComponent.anchoredPosition.x = 140
		self.StoreInfoArea.UITweenPosition.to.x = -770
		
		self.StoreInfoArea.UITweenPosition:Play()
		
		local setStartPos = function()
			self.StoreInfoArea:SetVisible(false)
		end
		_TimerService:SetTimerOnce(setStartPos , self.longDuration/2 )
		
	end

	@ExecSpace("ClientOnly")
	method void ShowStoreInfoArea()
		-- 상점 정보 영역을 보여주는 함수
		self.StoreInfoArea.UITransformComponent.anchoredPosition.x = -630
		self.StoreInfoArea.UITweenPosition.to.x = 820
		
		self.StoreInfoArea.UITweenPosition:Play()
		
		local setEndPos1 = function()
			self.StoreInfoArea:SetVisible(true)
		end
		_TimerService:SetTimerOnce(setEndPos1 , self.longDuration/2)
		
		local setEndPos2 = function()
			self.StoreInfoEnable = true
		end
		_TimerService:SetTimerOnce(setEndPos2 , self.longDuration)
		
	end

	@ExecSpace("ClientOnly")
	method void RequestUpdateSettlementRecordUI(Entity player)
		-- 정산 기록 UI 업데이트를 요청하는 함수
		player.PlayerSettlement:RequestSyncSettlementDataFromServer()
	end

	@ExecSpace("ClientOnly")
	method void RefreshMenuInfo()
		-- 메뉴 정보를 새로고침하는 함수
		for i, entity in pairs(self.MenuLayout.Children) do
			entity.Enable = false
		end
		local menuSlotMaxCount = _RecipeDataSetLogic.MaxRecipeSetSlot
		for i = 1, menuSlotMaxCount do
			local slot = _UIEntityService:GetOrCreateEntityOfModel("Model_MenuInfoOrigin", i, self.MenuLayout)
			local setRecipe = _UserService.LocalPlayer.PlayerRecipe.SetRecipes[i]
			
			slot.UIMenuInfoComponent:Refresh(setRecipe, i)
			
			if _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
				if setRecipe ~= nil then
					slot.UIMenuInfoComponent:UpdateDebugMonitorUIRecipe(setRecipe,i)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OpenMainMenu()
		-- 메인 메뉴를 여는 함수
		_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		self.MainMenuPanel:SetEnable(true)
		_UIGroupManager:EnableMoneyBarGroup(false)
	end

	@ExecSpace("ClientOnly")
	method void CloseMainMenu()
		-- 메인 메뉴를 닫는 함수
		_UIGroupManager:EnableMoneyBarGroup(true)
		self.MainMenuPanel:SetEnable(false)
		
		_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "374d1cb8-196f-48d6-9a39-852e9e197aab")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 메인 메뉴 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_MainMenu"], 1)
		self:OpenMainMenu()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a275c08b-dc63-4252-a1ce-ce89a5c37e72")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 메인 메뉴 닫기 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseMainMenu()
	end

	@EventSender("Entity", "a058e3e4-c28c-4f29-9a2d-2e834d368143")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 메인 메뉴 닫기 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseMainMenu()
	end

end