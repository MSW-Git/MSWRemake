@Component
script UIStoreManageBtn extends Component

	property Entity SlideParent = "3dc6e8fc-4a58-4de5-b386-5cad10239ab2"

	property Entity Slide = "8c4f8198-cfe3-49fd-8506-92891d4234be"

	property number duration = 0.5

	property Entity SupplymentCoolTimeUI = "afa88508-8bc0-4e9c-ad8e-a6c6bf85d2b0"

	property Entity PromotionCoolTimeUI = "ed947d5f-ec08-423a-8f1f-2e62356fea8c"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 상점 관리 UI의 슬라이드 애니메이션을 위한 초기 설정을 하는 함수
		self._T.slideRectSizeX = self.SlideParent.UITransformComponent.RectSize.x
		self._T.isTween = false
		self.SlideParent.Enable = false
	end

	method void SetEnable(boolean isOpen)
		-- 상점 관리 UI를 슬라이드 애니메이션으로 열고 닫는 함수
		self._T.isTween = true
		
		local startPos = isOpen and Vector2(self._T.slideRectSizeX, 0) or Vector2(0, 0)
		local targetPos = isOpen and Vector2(0, 0) or Vector2(self._T.slideRectSizeX, 0)
		
		self.Slide.UITransformComponent.anchoredPosition = Vector2(startPos.x, startPos.y)
		
		if isOpen == true then
			self.SlideParent.Enable = true
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		end
		
		_TweenLogic:PlayTween(startPos, targetPos, self.duration, EaseType.CubicEaseOut, function(t)
			self.Slide.UITransformComponent.anchoredPosition = t
		end)
		
		_TimerService:SetTimerOnce(function()
			self._T.isTween = false
			if isOpen == false then
				self.SlideParent.Enable = false
				_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
			end
		end, self.duration)
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 상점 관리 버튼 클릭 시 UI의 열기/닫기를 처리하는 핸들러
		
		
		if self._T.isTween == true then
			return
		end
		
		self:SetEnable(not self.SlideParent.Enable)
	end

end