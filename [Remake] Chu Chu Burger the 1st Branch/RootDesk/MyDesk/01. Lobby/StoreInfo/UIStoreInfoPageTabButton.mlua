@Component
script UIStoreInfoPageTabButton extends Component

	property Entity TabOnIcon = nil

	property UITransformComponent Transform = nil

	property UITweenPosition TweenPosition = nil

	property number tweenduration = 0

	property boolean IsPositionSelected = false

	property Entity OnDeco = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 엘리먼트들을 초기화하는 함수
		self.TabOnIcon = self.Entity:GetChildByName("TabOn")
		self.OnDeco = self.Entity:GetChildByName("OnDeco")
		self.Transform = self.Entity.UITransformComponent
		self.TweenPosition = self.Entity.UITweenPosition
		self.IsPositionSelected = false
		self.tweenduration = self.TweenPosition.duration*(1.1)
		
		self:IsButtonSelected(false)
	end

	@ExecSpace("ClientOnly")
	method void IsButtonSelected(boolean enable)
		-- 버튼 선택 상태에 따라 UI 애니메이션을 설정하는 함수
		
		self.TabOnIcon:SetEnable(enable)
		self.OnDeco:SetEnable(enable)
		
		if enable then
			
			if self.IsPositionSelected == true then 
				return
			else	
				self.IsPositionSelected = true
				self.TweenPosition.to.x = 30
				self.Transform.anchoredPosition.x = 0
			end 
			
			self.TweenPosition:Play()
			if isvalid(self.TabOnIcon.UITweenPosition) then
				self.TabOnIcon.UITweenPosition:Play()
			end
			
			
		else	
			
			if self.IsPositionSelected == false then 
				return 
			else	
				self.IsPositionSelected = false	
				self.TweenPosition.to.x = -30
				self.Transform.anchoredPosition.x = 30
			end 
		
			self.TweenPosition:Play()
			if isvalid(self.TabOnIcon.UITweenPosition) then
				self.TabOnIcon.UITweenPosition:Stop()
			end
		
		end
	end

end