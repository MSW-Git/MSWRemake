@Component
script UIEmployeeReviewSortButton extends Component

	property string SortKey = ""

	property Entity UIEmployeeReview = nil

	property integer SortValue = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 정렬 키와 UI 엘리먼트를 초기화하는 함수
		self.SortKey = self.Entity.Parent.Parent.Name
		
		self.UIEmployeeReview = _EntityService:GetEntityByPath("/ui/StoreInfoGroup/UIStoreInfo/InfoArea/UIEmployeeReview")
	end

	@ExecSpace("ClientOnly")
	method void SetSortValue(integer value)
		-- 일반 정렬 버튼의 정렬 값을 설정하는 함수
		
		if self.SortKey == "Skill" then
			self:SetSortValueSkill(value)
			return
		end
		
		if isvalid(value) then
			self.SortValue = value
			
		else
			self.SortValue = self.SortValue + 1
			if self.SortValue > 2 then
				self.SortValue = 0
			end
		end
		
		self.Entity.SpriteGUIRendererComponent.Color = Color.white
		if self.SortValue == 0 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "a96bb8ee92d84827a218b3974bff0e13"
		elseif self.SortValue == 1 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "3b0e4b51f17b43bd9ee4f8b334ce4e19"
		elseif self.SortValue == 2 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "cf6b81a8d08f4da682cf744d077adfdc"
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSortValueSkill(integer value)
		-- 스킬 정렬 버튼의 정렬 값을 설정하는 함수
		
		if isvalid(value) then
			self.SortValue = value
			
		else
			self.SortValue = self.SortValue + 1
			if self.SortValue > 4 then
				self.SortValue = 0
			end
		end
		
		self.Entity.UITransformComponent.ZRotation = 0
		if self.SortValue == 0 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "a96bb8ee92d84827a218b3974bff0e13"
			self.Entity.SpriteGUIRendererComponent.Color = Color.white
		elseif self.SortValue == 1 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "a3f17829c6c045549fb50a1480273103"
			self.Entity.SpriteGUIRendererComponent.Color = Color.white
		elseif self.SortValue == 2 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "e50833f6f8864f518f65022eff2ba0ca"
			self.Entity.SpriteGUIRendererComponent.Color = Color.white
		elseif self.SortValue == 3 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "2ec7cd3dedc545a6b35b1050d164ed57"
			self.Entity.SpriteGUIRendererComponent.Color = Color.white
		elseif self.SortValue == 4 then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "54117f06afd24b8e95dce3aa17fe2e11"
			self.Entity.SpriteGUIRendererComponent.Color = Color.white
		end
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 정렬 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:SetSortValue(nil)
		self.UIEmployeeReview.UIEmployeeReview:SetSortCriteria(self.SortKey, self.SortValue)
	end

end