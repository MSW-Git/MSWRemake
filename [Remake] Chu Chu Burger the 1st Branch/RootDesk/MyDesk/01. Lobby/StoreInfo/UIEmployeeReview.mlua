@Component
script UIEmployeeReview extends Component

	property SyncTable<string, Entity> SortButtons

	property table SortCriteria = {}

	property SyncTable<string, string> EmployeeStatus

	property SyncTable<string> AlertEntities

	property RecycleScrollView EmployeeReviewScroll = "63bc1447-515b-455c-b5b7-bed951024212"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 엘리먼트와 이벤트를 초기화하는 함수
		self:SetTitleBar()
		
		self.EmployeeReviewScroll.onUpdateCell = function(i, e)
			local empDetail = self._T.userDetailTable[i]
			e.UIEmployeeReviewSlotRenderer:Refresh(empDetail)
		end
	end

	@ExecSpace("ClientOnly")
	method void Open(string param)
		-- 직원 리뷰 UI를 열고 데이터를 설정하는 함수
		if self.Entity.Enable == true then
			return
		end
		
		self._T.scrollIdx = 0
		
		self:SetUserDetailTable(param)
		
		self:SetStatusData()
		self:SetSortCriteria(nil, nil)
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 직원 리뷰 리스트를 새로고침하는 함수
		local employeeDetails = self:ReturnSortedEmployeeDetailTable()
		
		local totalCount = #table.keys(self._T.userDetailTable)
		self.EmployeeReviewScroll:SetTotalCount(totalCount)
		
		if self._T.scrollIdx ~= 0 then
			self.EmployeeReviewScroll:ScrollToIndex_Horizontal(self._T.scrollIdx)
			self._T.scrollIdx = 0
		end
	end

	@ExecSpace("ClientOnly")
	method void SetStatusData()
		-- 모든 직원의 상태 데이터를 설정하는 함수
		table.clear(self.EmployeeStatus)
		
		for i, employee in pairs(_UserService.LocalPlayer.EmployeeManager.EmployeeDetailTable) do
			local statusKey = _EmployeeReveiwStatusEnum:ReturnEmployeeStatus(_UserService.LocalPlayer, employee.Id)
			local statusComment = _EmployeeReveiwStatusEnum:ReturnRandomStatusComment(statusKey)
			
			self.EmployeeStatus[employee.Id] = statusKey.."/"..statusComment
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetTitleBar()
		-- 타이틀 바 UI와 정렬 버튼들을 설정하는 함수
		local titleBar = self.Entity:GetChildByName("TitleBar")
		
		for i = 1, #titleBar.Children do
			local child = titleBar.Children[i]
			local key = child.Name
			
			local titleText = child:GetChildByName("TitleText")
			titleText.TextComponent.Text = _GetLocalizationTextLogic:GetText("EmployeeReviewTitle"..key)
			self.SortButtons[key] = titleText:GetChildByName("SortBtn")
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSortCriteria(string key, integer sortType)
		-- 정렬 기준을 설정하고 UI를 새로고침하는 함수
		
		table.clear(self.SortCriteria)
		self.SortCriteria = {key, sortType}
		
		for i, entity in pairs(self.SortButtons) do
			local sortBtn = entity.UIEmployeeReviewSortButton
			if sortBtn.SortKey ~= key then
				sortBtn:SetSortValue(0)
				
			end
		end
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method table ReturnSortedEmployeeDetailTable()
		-- 직원 데이터를 정렬 기준에 따라 정렬하여 반환하는 함수
		local player = _UserService.LocalPlayer
		
		local sortKey = self.SortCriteria[1]
		local sortValue = self.SortCriteria[2]
		if sortKey == "Name" then
			if sortValue == 1 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aValue = _GetLocalizationTextLogic:GetText(_EmployeeService:GetData(a.Id).NameKey)
					local bValue = _GetLocalizationTextLogic:GetText(_EmployeeService:GetData(b.Id).NameKey)
					
					return aValue > bValue
				end)
			elseif sortValue == 2 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aValue = _GetLocalizationTextLogic:GetText(_EmployeeService:GetData(a.Id).NameKey)
					local bValue = _GetLocalizationTextLogic:GetText(_EmployeeService:GetData(b.Id).NameKey)
					
					return aValue < bValue
				end)
			end
				
		elseif sortKey == "Status" then
			if sortValue == 1 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aKey = _UtilLogic:Split(self.EmployeeStatus[a.Id], "/")[1]
					local bKey = _UtilLogic:Split(self.EmployeeStatus[b.Id], "/")[1]
					
					local aValue = _EmployeeReveiwStatusEnum.Status[aKey]
					local bValue = _EmployeeReveiwStatusEnum.Status[bKey]
					
					return aValue > bValue
				end)
			elseif sortValue == 2 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aKey = _UtilLogic:Split(self.EmployeeStatus[a.Id], "/")[1]
					local bKey = _UtilLogic:Split(self.EmployeeStatus[b.Id], "/")[1]
					
					local aValue = _EmployeeReveiwStatusEnum.Status[aKey]
					local bValue = _EmployeeReveiwStatusEnum.Status[bKey]
					
					return aValue < bValue
				end)
			end
			
		elseif sortKey == "Level" then
			if sortValue == 1 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aValue = a:ReturnTypeLevel()
					local bValue = b:ReturnTypeLevel()
					
					return aValue > bValue
				end)
			elseif sortValue == 2 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aValue = a:ReturnTypeLevel()
					local bValue = b:ReturnTypeLevel()
					
					return aValue < bValue
				end)
			end
			
		elseif sortKey == "Skill" then
			local getScore = function(sortV, detail)
				local score = 0
				
				local employeeData = _EmployeeService:GetData(detail.Id)
				local outgameData = player.EmployeeManager:GetEmployeeOutgameDetail(detail.Id)
				
				local skill1Type = employeeData.Skill1Type
				local skill1Grade = outgameData.Skill1Grade
				local skill2Type = employeeData.Skill2Type
				local skill2Grade = outgameData.Skill2Grade
				
				local skill1Category = tonumber(string.sub(skill1Type,1,1))
				local skill2Category = tonumber(string.sub(skill2Type,1,1))
				
				if sortV == skill1Category then
					score += 100 + (50 * skill1Grade) + (10 * skill2Grade)
					
				elseif sortV == skill2Category then
					score += 100 + (50 * skill2Grade) + (10 * skill2Grade)
				end
				
				score += (skill1Grade + skill2Grade) * 1
				
				return score
			end
			
			if sortValue ~= 0 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aScore = getScore(sortValue, a)	
					local bScore = getScore(sortValue, b)
					return aScore > bScore
				end)
			end	
				
		elseif sortKey == "Location" then
			if sortValue == 1 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aValue = _GetLocalizationTextLogic:GetText("EmployeeLocation"..player.EmployeeManager:GetEmployeeLocation(a.Id).Location)
					local bValue = _GetLocalizationTextLogic:GetText("EmployeeLocation"..player.EmployeeManager:GetEmployeeLocation(b.Id).Location)
					
					return aValue > bValue
				end)
			elseif sortValue == 2 then
				table.sort(self._T.userDetailTable, function(a, b)
					local aValue = _GetLocalizationTextLogic:GetText("EmployeeLocation"..player.EmployeeManager:GetEmployeeLocation(a.Id).Location)
					local bValue = _GetLocalizationTextLogic:GetText("EmployeeLocation"..player.EmployeeManager:GetEmployeeLocation(b.Id).Location)
					
					return aValue < bValue
				end)
			end
		end
		
		return self._T.userDetailTable
	end

	@ExecSpace("ClientOnly")
	method void SetUserDetailTable(string param)
		-- 직원 상세 테이블을 설정하는 함수
		self._T.userDetailTable = {}
		local player = _UserService.LocalPlayer
		for i, employeeDetail in pairs(player.EmployeeManager.EmployeeDetailTable) do	
			self._T.userDetailTable[i] = employeeDetail
			
			if param ~= nil then
				if employeeDetail.Id == param then
					self._T.scrollIdx = i-1
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "7baafba6-e2f2-44d5-abf7-f407fdd6ffcb")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 직원 관리 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_UIEmployeeManageService:UIOpen()
	end

end