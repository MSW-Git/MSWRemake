@Struct
script StoreInfoReportData

	property integer Id = 0

	property string CategoryTextKey = ""

	property string ReportTextKey = ""

	property integer ParamCount = 0

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 상점 정보 리포트 데이터를 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = tonumber(row:GetItem("Id"))
		self.CategoryTextKey = row:GetItem("CategoryTextKey")
		self.ParamCount = tonumber(row:GetItem("ParamCount"))
		self.ReportTextKey = row:GetItem("ReportTextKey")
	end

end