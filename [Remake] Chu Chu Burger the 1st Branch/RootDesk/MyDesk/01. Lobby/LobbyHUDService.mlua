	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 메뉴 버튼 아이콘 애니메이션을 설정하는 함수
		local book = self.MenuBtnIconParent:GetChildByName("Book")
		local burger = self.MenuBtnIconParent:GetChildByName("Burger")
		local interval = 4
		self._T.menuBtnTimer = _TimerService:SetTimerRepeat(function()
			book.UITweenScale:Play()
			book.UITweenRotate:Play()
		    _TimerService:SetTimerOnce(function()
		        book.UITweenScale:Stop()
		        book.UITweenRotate:Stop()
		    end, book.UITweenScale.duration*2)
			_TimerService:SetTimerOnce(function()
				burger.UITweenScale:Play()
				burger.UITweenRotate:Play()
		        _TimerService:SetTimerOnce(function()
		            burger.UITweenScale:Stop()
		            burger.UITweenRotate:Stop()
		        end, burger.UITweenScale.duration*2)
			end, book.UITweenScale.duration)
		end, interval, 0)
		
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		-- 게임 종료 시 타이머를 정리하는 함수
		_TimerService:ClearTimer(self._T.menuBtnTimer)
	end

	@ExecSpace("Client")
	method void OpenHUD(Entity player)
		-- 로비 HUD를 열고 초기화하는 함수
		
		_UIGroupManager:EnableLobbyHUDGroup(true)
		_UIGroupManager:EnableMoneyBarGroup(true)
		
		_EventUIManager.ExLobbyHUDEnable = true
		
		self.DropDown_BM.UIHUDDropDown:SetDropdownSize(1)
		self.DropDown_Event.UIHUDDropDown:SetDropdownSize(1)
		
		_UIMoneyBarLogic.CloverUI:GetChildByName("Tooltip").Enable = false
		_UIMoneyBarLogic.MoneyUI:GetChildByName("Tooltip").Enable = false
		_UIMoneyBarLogic.HeartUI:GetChildByName("Tooltip").Enable = false
		
		_UIMoneyBarLogic:UpdateCloverUI(player.PlayerInventory.ArcaneSymbol)
		_UIMoneyBarLogic:UpdateHeartUI(player.PlayerInventory.Heart)
		_UIMoneyBarLogic:UpdateMoneyUI(player.PlayerInventory.Money)
		_UIMoneyBarLogic:UpdateDiamondUI(player.PlayerOutgameManager:GetDiamondCount())
		
		local ingreBoxCount = 0
		for itemId, data in pairs(_ItemDataSetLogic.ItemData) do
			if string.sub(itemId, 1, 1) ~= "B" then
				continue
			end
			
			ingreBoxCount += player.PlayerInventory:GetItemCount(itemId)
		end
		
		_UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting:SetIngreGachaRedDot(ingreBoxCount > 0)
		_MainMenuRedDotManager:EnableIngreGachaRedDot(ingreBoxCount > 0)
		
		self:UpdateTrainingTokenUI(player.PlayerInventory.LunchBox)
		
		self.ManagementUI.UIHUDManagement:Refresh()
		
		self.ReputationUI.UIReputation:Refresh()
		
		self:UpdateTipUI(_UserService.LocalPlayer.PlayerInventory.Tip) 
		self:UpdateTipMaxText()
		self:EnableTipUI(true)
		
		self:UpdateStoreNameUI()
		self:UpdateMoveNextStageBtn()
		
		self:RefreshSubscriptionBoxButton()
	end

	@ExecSpace("ClientOnly")
	method void UpdateTrainingTokenUI(integer tokenCount)
		-- 훈련 토큰 UI를 업데이트하는 함수
		local maxCount = _UserService.LocalPlayer.PlayerInventory.MaxLunchBoxNum
		self.TrainingTokenGauge.SliderComponent.MaxValue = maxCount
		self.TrainingTokenGauge.SliderComponent.Value = tokenCount
		
		local trainingGauge = _EntityService:GetEntityByPath("/ui/TrainingSettingGroup/Panel/TrainingGauge/GaugeBg/Gauge")
		local trainingGaugeText = _EntityService:GetEntityByPath("/ui/TrainingSettingGroup/Panel/TrainingGauge/GaugeBg/GaugeText")
		local autoTrainingGauge = _EntityService:GetEntityByPath("/ui/AutoTrainingGroup/Panel/TrainingGauge/GaugeBg/Gauge")
		local autoTrainingGaugeText = _EntityService:GetEntityByPath("/ui/AutoTrainingGroup/Panel/TrainingGauge/GaugeBg/GaugeText")
		local parkingAreaTrainingGauge = _EntityService:GetEntityByPath(_LobbyRenovationService:GetParkingAreaEntity().Path.."/Info_Truck/TrainingGauge/GaugeBg/Gauge")
		local parkingAreaTrainingGaugeText = parkingAreaTrainingGauge.Parent:GetChildByName("GaugeText")
		
		trainingGauge.SliderComponent.MaxValue = maxCount
		trainingGauge.SliderComponent.Value = tokenCount
		autoTrainingGauge.SliderComponent.MaxValue = maxCount
		autoTrainingGauge.SliderComponent.Value = tokenCount
		
		local text = string.format("%s / %d", tostring(tokenCount), maxCount)
		self.TrainingTokenGaugeText.TextComponent.Text = text
		trainingGaugeText.TextComponent.Text = text
		autoTrainingGaugeText.TextComponent.Text = text
		
		if isvalid(parkingAreaTrainingGauge) then
			parkingAreaTrainingGaugeText.TextComponent.Text = text
			parkingAreaTrainingGauge.SliderComponent.MaxValue = maxCount
			parkingAreaTrainingGauge.SliderComponent.Value = tokenCount
		end
		
		_UIGroupManager.TrainingSettingGroup.UITrainingSetting:UpdateStartButtonDim()
		_UserService.LocalPlayer.PlayerAutoTrainingManager:UpdateLunchBoxTruckSlotOkButtons()
	end

	@ExecSpace("ClientOnly")
	method void UpdateStoreInfoReportUI(string message, integer reportId)
		-- 상점 정보 리포트 UI를 업데이트하는 함수
		local reportCount = #self.ReportEntities
		
		
		if reportCount > 0 then
				
			for i =1 , 5 do
		
				if self.ReportIds[i] == reportId and reportId > 3000 and reportId < 3999 then 
					self.ReportEntities[i].TextComponent.Text = message	
					return
					
				elseif self.ReportIds[i] == reportId and reportId == 2005 then 
					local beforeText = self.ReportEntities[i].TextComponent.Text
					if beforeText == message then
						self.ReportEntities[i].TextComponent.Text = message
						return	
					end
		
				elseif self.ReportIds[i] == reportId and reportId == 2006 then 
					local beforeText = self.ReportEntities[i].TextComponent.Text
					if beforeText == message then
						self.ReportEntities[i].TextComponent.Text = message
						return	
					end
				end
			end
			
		end
		
		if reportCount == 0 then
			self._T.reportIndex = 0
		end
		self._T.reportIndex = self._T.reportIndex + 1
		
		if reportCount >= 5 then		
			local oldestEntity = table.remove(self.ReportEntities,1)
			local oldestId = table.remove(self.ReportIds,1) 
			oldestEntity:Destroy()
		end
		
		local clone = _SpawnService:SpawnByEntity( self.ReportOrigin , "Report"..tostring(self._T.reportIndex) , Vector3.zero , self.StoreInfoReportLayout )
		
		clone.TextComponent.Text = message
		table.insert(self.ReportEntities,clone)
		table.insert(self.ReportIds,reportId)
	end

	@ExecSpace("ClientOnly")
	method void UpdateStoreInfoTrendUI()
		-- 상점 정보 트렌드 UI를 업데이트하는 함수
		self.HUDTrendInfo.UITrendInfoBar:Refresh(false)
	end

	@ExecSpace("Client")
	method void RefreshRemainText(boolean isOn)
		-- 남은 시간 텍스트를 새로고침하는 함수
		
		local playerInven = _UserService.LocalPlayer.PlayerInventory
		local remainDay = playerInven.LunchBoxRemainDay
		
		local remainString = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("LeftDay_Format", tostring(remainDay))
		self.TokenTimerText.TextComponent.Text = remainString
		self.TokenTimerEntity.Enable = isOn
		
	end

	@ExecSpace("Client")
	method void EnableTipUI(boolean enable)
		-- 팁 UI를 활성화/비활성화하는 함수
		local level = _UserService.LocalPlayer.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(_UpgradeTypeEnum.TipStorageLevel)
		if level >= 1 then 
			self.TipStorageBtn.Enable = enable
		
		else
			self.TipStorageBtn.Enable = false 
		end
	end

	@ExecSpace("Client")
	method void UpdateTipUI(integer value)
		-- 팁 UI를 업데이트하는 함수
		self.TipStorageBtn:GetChildByName("CountText").TextComponent.Text = _StringUtilLogic:FormatNumber(value)
		if value > 0 then 
			self.TipStorageBtn:GetChildByName("Icon").SpriteGUIRendererComponent:ChangeMaterial("material://0ad54005-5ff2-4098-9751-49dd754aefb3")
			self.TipStorageBtn:GetChildByName("Icon2").SpriteGUIRendererComponent:ChangeMaterial("material://0ad54005-5ff2-4098-9751-49dd754aefb3")
		else
			self.TipStorageBtn:GetChildByName("Icon").SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
			self.TipStorageBtn:GetChildByName("Icon2").SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		end
	end

	@ExecSpace("Client")
	method void GainTip()
		-- 팁을 획득하는 함수
		_UserService.LocalPlayer.PlayerInventory:RequestUseTip()
	end

	@ExecSpace("Client")
	method void UpdateTipMaxText()
		-- 팁 최대치 텍스트를 업데이트하는 함수
		local tip = _UserService.LocalPlayer.PlayerInventory.Tip
		local maxTip = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.TipStorageLevel)
		if maxTip <= tip then 
			
			self.TipStorageBtn:GetChildByName("MaxText").Enable = true 
		
		else
			
			self.TipStorageBtn:GetChildByName("MaxText").Enable = false 	
			
		end
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshSubscriptionBoxButton()
		-- 구독 박스 버튼을 새로고침하는 함수
		local player = _UserService.LocalPlayer
		
		local isShopOpened = _UIButtonUnlockLogic:IsButtonUnlocked(_ButtonUnlockEnum.MainMenuShop, player)
		
		local isSubsEmpty = #table.keys(player.PlayerIngredient.IngreSubscriptionBox) == 0
		if isShopOpened == false then
			self.IngreSubsCount.Entity.Enable = false
			self.GetIngreSubsBtnIcon:ChangeMaterial(_IconRuidEnum.GrayScaleMaterial)
		else
			self.IngreSubsCount.Entity.Enable = true
			self.GetIngreSubsBtnIcon:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
			if isSubsEmpty == true then
				self.IngreSubsCount.Text = "0"
			else
				local totalCount = 0
				for itemId, itemCount in pairs(player.PlayerIngredient.IngreSubscriptionBox) do
					totalCount = totalCount + itemCount
				end
				
				self.IngreSubsCount.Text = _StringUtilLogic:ReturnThousandsSeparatedString(totalCount)
			end
			
		end
	end

	@ExecSpace("Client")
	method void UpdateBestEarningRecord(integer record, integer changeAmount)
		-- 최고 수익 기록을 업데이트하는 함수
		
		if record == self._T.bestRecipeEarnings then
			return
		end
		
		local isSkipAnim = false
		if self._T.bestRecipeEarnings == nil then
			isSkipAnim = true
		end
		
		
		self.BestEarningRecordText.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(record)
		
		if isvalid(self._T.monthlyRecordTimer) then
			_TimerService:ClearTimer(self._T.monthlyRecordTimer)
		end
		
		local bestEntity = self.BestEarningRecordText.Parent:GetChildByName("Best")
		
		if isSkipAnim == false then
			bestEntity.Enable = true
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_MonthlyBest"], 1)
			
			local material = _EntryService:GetMaterialIdByName("MonthlyRecord_Fx")
			self.BestEarningRecordText.Parent.SpriteGUIRendererComponent:ChangeMaterial(material)
			
			self._T.monthlyRecordTimer = _TimerService:SetTimerOnce(function()
				bestEntity.Enable = false
				self.BestEarningRecordText.Parent.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
			end, 1.4)
		end
		
		self._T.bestRecipeEarnings = record
	end

	@ExecSpace("ClientOnly")
	method void UpdateStoreNameUI()
		-- 상점 이름 UI를 업데이트하는 함수
		self.StoreNameUI.TextComponent.Text = _UserService.LocalPlayer.PlayerOutgameManager.StoreName
	end

	@ExecSpace("Client")
	method void UpdateVIPOrderBtn(Entity player)
		-- VIP 주문 버튼을 업데이트하는 함수
		local isOpen = true
		if _UtilLogic:IsNilorEmptyString(player.PlayerVIPOrder.NowSeasonMainTag) == true then
			isOpen = false
		else
			local vipOrderMaxCnt = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.VIPOrderCount)
			if player.PlayerVIPOrder.SeasonCompleteCount >= vipOrderMaxCnt then
				isOpen = false
			end
		end
		
		local eventThreadVIPOrder = self.DropDown_Event.UIHUDDropDown.ItemListEntity:GetChildByName(_HUDDropDownEnum.VIPOrderBtn)
		local eventThreadEnable = self.DropDown_Event.UIHUDDropDown.ItemDraw[_HUDDropDownEnum.VIPOrderBtn]
		if eventThreadEnable ~= isOpen then
			self.DropDown_Event.UIHUDDropDown:SetDrawOfName(_HUDDropDownEnum.VIPOrderBtn, isOpen)
		end
		
		_MainMenuRedDotManager:EnableVIPOrderRedDot(false)
		
		if isOpen == true and player.PlayerVIPOrder.IsFirstEnterUI == false then
			_MainMenuRedDotManager:EnableVIPOrderRedDot(true)
			self.DropDown_Event.UIHUDDropDown:SetItemRedDot(_HUDDropDownEnum.VIPOrderBtn, true)
		end
		
		local isCloseEndSeason = player.PlayerVIPOrder.IsCloseEnterUI == false and player.PlayerVIPOrder.IsCloseToEndSeason == true and isOpen == true
		if isCloseEndSeason == true then
			_MainMenuRedDotManager:EnableVIPOrderRedDot(true)
			self.DropDown_Event.UIHUDDropDown:SetItemRedDot(_HUDDropDownEnum.VIPOrderBtn, true)
		end
		
		_MainMenuRedDotManager.Menu_VIPOrderBtn:GetChildByName("CloseToEndText").Enable = isCloseEndSeason
	end

	@ExecSpace("Client")
	method void ClearLobbyHUD()
		-- 로비 HUD를 정리하는 함수
		_UILobbyManager:HideStoreInfoArea()
		_InteractionUIService.UIEmployeeInfo.Enable = false
		_InteractionUIService.UIKitchenAppInfo.Enable = false
		_InteractionUIService.UIKitchenAppNone.Enable = false
		_SettlementUIService.UISettlement.Enable = false
		_SettlementUIService:ForceCloseUISettlement()
		self.CustomChatUI:ToggleCustomChat(false)
	end

	@ExecSpace("Client")
	method void PlayGainTipEffectOnTipButton()
		-- 팁 버튼에 팁 획득 효과를 재생하는 함수
		_UIEntityService:PlayUISpriteAnim(self.TipButtonEffect, "8954464adb284257b3371f908e9f6c5b", 0.35)
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_GainHeart_v2"], 1)
	end

	@ExecSpace("Server")
	method void RequestChangeStoreName(Entity player, string text)
		-- 상점 이름 변경을 요청하는 함수
		local cost = math.floor(_GetConfigDataLogic:GetConfigNumDataByKey("StoreNameChangeDiamondCost"))
		if player.PlayerOutgameManager:GetDiamondCount() < cost then
			return
		end
		
		local result1 = player.PlayerOutgameManager:RequestSetStoreName(text, true, "1")
		if result1 == false then
			_GetLocalizationTextLogic:CallToastByLocalizationKey("UserInputErrorMessage", nil, false, player.PlayerComponent.UserId)
			return
		end
		
		player.PlayerOutgameManager:ModifyDiamond(-cost, false, "Change StoreName", "Change StoreName Popup")
	end

	@ExecSpace("Client")
	method void ClearStoreInfoReportUI()
		-- 상점 정보 리포트 UI를 정리하는 함수
		for i, entity in pairs(self.ReportEntities) do
			entity:Destroy()
		end
		
		table.clear(self.ReportEntities)
		table.clear(self.ReportIds)
	end

	@ExecSpace("ClientOnly")
	method void UpdateMoveNextStageBtn()
		-- 다음 스테이지 이동 버튼을 업데이트하는 함수
		local player = _UserService.LocalPlayer
		
		local maxStage = 0
		for id, progress in pairs(player.PlayerStage.StageProgress) do
			if progress >= _StageDataSetLogic:GetStageClearProgress(id) then
				local nextStage = id == _StageDataSetLogic.LastStageNum and id or id+1
				maxStage = math.max(nextStage, maxStage)
			end
		end
		
		local isOn = false
		if maxStage > player.PlayerStage.NowStage then
			local maxStageData = _StageDataSetLogic:GetStageData(maxStage)
			isOn = true
			
			if maxStageData.HideSlot == true or maxStageData.ComingSoon == true then
				isOn = false 
			end
		end
		
		local isTutorialEventOccured = player.PlayerEvent:IsEventOccured(_TutorialEventEnum.Stage1ClearedEventId)
		if isTutorialEventOccured == false then
			isOn = false
		end
		
		self.MoveNextStageBtn.Enable = isOn
	end

	@ExecSpace("Client")
	method void OpenStartStageToast(integer stageId)
		-- 스테이지 시작 토스트를 여는 함수
		self.StartStageToast.UIStartStageToast:Open(stageId)
	end

	@ExecSpace("Client")
	method void OpenStartDayToast()
		-- 하루 시작 토스트를 여는 함수
		local player = _UserService.LocalPlayer
		if #table.keys(player.TimeManager.FirstEnterUtc) == 0 then
			_TimerService:SetTimerOnce(function()
				self:OpenStartDayToast()
			end, 0.5)
			return
		end
		
		local year = player.TimeManager.FirstEnterUtc["Year"]
		local month = player.TimeManager.FirstEnterUtc["Month"]
		local day = player.TimeManager.FirstEnterUtc["Day"]
		self.UIStartDayToast:Open(year, month, day)
	end

	@ExecSpace("Client")
	method void SetDropdownTestTimer()
		-- 드롭다운 테스트 타이머를 설정하는 함수
		self.DropDown_BM.UIHUDDropDown:SetTestTimer()
		self.DropDown_Event.UIHUDDropDown:SetTestTimer()
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerManagementChangedEvent(PlayerManagementChangedEvent event)
		-- 플레이어 관리 상태 변경 이벤트를 처리하는 핸들러
		self.ManagementUI.UIHUDManagement:Refresh()
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerTrainingTokenChangedEvent(PlayerTrainingTokenChangedEvent event)
		-- 플레이어 훈련 토큰 변경 이벤트를 처리하는 핸들러
		local current = event.Current
		local max = event.Max
		if _UtilLogic:Contains(_UserService.LocalPlayer.CurrentMapName, "Lobby") == false then
			return
		end
		
		self:UpdateTrainingTokenUI(current)
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerTipChangedEvent(PlayerTipChangedEvent event)
		-- 플레이어 팁 변경 이벤트를 처리하는 핸들러
		local value = event.Value
		local maxTip = event.MaxTip
		self:UpdateTipUI(value)
		self:UpdateTipMaxText()
	end

	@EventSender("Entity", "2831acc0-8908-4045-bc0f-35df25458fc3")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 팁 저장소 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:GainTip()
	end

	@EventSender("Entity", "5814137b-22c0-42f7-9ab5-d06f28080ad7")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 재료 구독 박스 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerIngredient.IsServerProcessing then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		local isShopOpened = _UIButtonUnlockLogic:IsButtonUnlocked(_ButtonUnlockEnum.MainMenuShop, player)
		if isShopOpened == false then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("HUDShopToast1")) 
			return
		end
		
		if isShopOpened == true and _SubscriptionService.SubsInfoSlotHolder.Enable == false then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("HUDShopToast2")) 
			return	
		end
		
		player.PlayerIngredient:ChangeConnectingStatus(true)
		player.PlayerIngredient:RequestGetIngreSubscriptionBox()
	end

	@EventSender("LocalPlayer")
	handler HandleBestEarningRecordChangedEvent(BestEarningRecordChangedEvent event)
		-- 최고 수익 기록 변경 이벤트를 처리하는 핸들러
		local Record = event.Record
		local ChangeAmount = event.ChangeAmount
		self:UpdateBestEarningRecord(Record, ChangeAmount)
	end

	@EventSender("Entity", "27c4c404-7f45-4afb-bf9e-567a988532a9")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 상점 정보 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_StoreInfoDataSetLogic.UIStoreInfo:Open(2, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "12f2efe1-10eb-4c6b-9747-133fa54a2047")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 상점 이름 변경 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local onOk = function()
			_UserService.LocalPlayer.PlayerEvent:RequestCallEvent("E0001")
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		local contents = _GetLocalizationTextLogic:GetText("ChangeStoreNamePopupText")
		_UIPopup:Open(contents, onOk, function() end, _GetLocalizationTextLogic:GetText("ChangeStoreNamePopupTitle"))
	end

	@EventSender("Entity", "60d166e9-f1d6-4e55-9ddf-95a2b7aba02f")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 다음 스테이지 이동 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_StageDataSetLogic.UIStageSelect:Open(nil)
	end

end