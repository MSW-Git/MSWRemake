@Component
script UIDiaInfoSlotMoveBtn extends Component

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 다이아 획득 방법 슬롯의 이동 버튼 클릭 시 해당 UI로 이동하는 이벤트 핸들러
		
		local type = self.Entity.Parent.UIDiaInfoSlot.type
		local diaInfo = _EntityService:GetEntityByPath("/ui/DiaInfoGroup")
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		diaInfo.UIDiaInfo:MoveUI(type)
	end

end