@Component
script SubscriptionPostBox extends Component

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 구독 상자의 상태를 새로고침하고 알림 표시를 업데이트하는 함수
		local player = _UserService.LocalPlayer
		
		local postBalloon = self.Entity:GetChildByName("PostBalloon")
		if #table.keys(player.PlayerIngredient.IngreSubscriptionBox) == 0 then
			postBalloon.Enable = false
			self.Entity.Enable = false
		else
			self.Entity.Enable = true
			postBalloon.Enable = true
			local countText = postBalloon:GetChildByName("CountText")
			_SoundService:PlaySound(_ResourceManager.SFXTable["ArrivalSubscription"], 1)
			
			local totalCount = 0
			for itemId, itemCount in pairs(player.PlayerIngredient.IngreSubscriptionBox) do
				totalCount = totalCount + itemCount
			end
			countText.TextComponent.Text = tostring(totalCount)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 구독 상자 초기화 및 터치 이벤트 설정을 하는 함수
		
		local postBalloon = self.Entity:GetChildByName("PostBalloon")
		local bulb = postBalloon:GetChildByName("Bulb")
		
		self.Entity.SpriteRendererComponent.SortingLayer = "Npc"
		postBalloon.SpriteRendererComponent.SortingLayer = "Npc" 
		bulb.SpriteRendererComponent.SortingLayer = "Npc" 
		
		postBalloon.Enable = false
		postBalloon:ConnectEvent(TouchEvent, function()
			self:OnTouch()
		end)
		
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnTouch()
		-- 구독 상자 터치 시 UI 오버레이 체크 후 아이템 수령을 요청하는 함수
		if _InputService:IsPointerOverUI() then 
			return
		end
		
		if _UIGroupManager:IsOnUI() then 
			return
		end
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerIngredient.IsServerProcessing then
			return
		end
		
		player.PlayerIngredient:ChangeConnectingStatus(true)
		player.PlayerIngredient:RequestGetIngreSubscriptionBox()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		-- 터치 이벤트를 처리하여 구독 상자 터치 상호작용을 실행하는 핸들러
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		self:OnTouch()
	end

end