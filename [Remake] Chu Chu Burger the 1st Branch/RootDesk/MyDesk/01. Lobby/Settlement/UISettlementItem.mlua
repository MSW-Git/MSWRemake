@Component
script UISettlementItem extends Component

	property Entity Title = nil

	property Entity Sign = nil

	property Entity Value = nil

	property string localizationKey = "Settlement_"

	@ExecSpace("ClientOnly")
	method void Init()
		-- 정산 아이템 UI 컴포넌트를 초기화하는 함수
		self.Title = self.Entity:GetChildByName("Title")
		self.Value = self.Entity:GetChildByName("Value")
		self.Sign = self.Value:GetChildByName("Sign")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(SettlementData settlementData, string enum, boolean isMinus)
		-- 정산 데이터에 따라 UI를 새로고침하는 함수
		if self.Title == nil then
			self:Init()
		end
		
		if isMinus then
			self.Sign.TextComponent.Text = "-"
		else
			self.Sign.TextComponent.Text = "+"
		end
		
		self.Sign.TextComponent.FontColor = isMinus and _ColorCodeEnum:GetColor("#FA5246") or _ColorCodeEnum:GetColor("#D6FF30")
		self.Sign.TextComponent.OutlineColor = isMinus and _ColorCodeEnum:GetColor("#FFFAEB") or _ColorCodeEnum:GetColor("#6B741E")
		self.Value.TextComponent.FontColor = isMinus and _ColorCodeEnum:GetColor("#FA5246") or _ColorCodeEnum:GetColor("#D6FF30")
		self.Value.TextComponent.OutlineColor = isMinus and _ColorCodeEnum:GetColor("#FFFAEB") or _ColorCodeEnum:GetColor("#6B741E")
		
		
		local data = self:ReturnTitleValueTableOfEnum(settlementData, enum)
		self.Title.TextComponent.Text = data[1]
		self.Value.TextComponent.Text = data[2]
	end

	@ExecSpace("ClientOnly")
	method table ReturnTitleValueTableOfEnum(SettlementData settlementData, string enum)
		-- 열거형에 따른 제목과 값을 테이블로 반환하는 함수
		local titleText
		local value
		
		local localizationKey = self.localizationKey..enum
		
		titleText = _GetLocalizationTextLogic:GetText(localizationKey)
		value = settlementData[enum]
		
		local valueString = _StringUtilLogic:ReturnThousandsSeparatedString(value)
		
		return {titleText, valueString}
	end

end