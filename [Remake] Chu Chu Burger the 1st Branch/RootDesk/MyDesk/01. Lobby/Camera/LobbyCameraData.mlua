@Struct
script LobbyCameraData

	property integer Level = 0

	property table CameraTypeData = {}

	method void Load(any dataTable, integer level)
		-- 데이터 테이블에서 레벨별 카메라 데이터를 로드하는 함수
		self.Level = level
		
		local rowCount = dataTable:GetRowCount()
		local typeDatas = {}
		for i = 1, rowCount do
			---@type UserDataRow
			local row = dataTable:GetRow(i)
			if tonumber(row:GetItem("ExpansionLevel")) == self.Level then
				local cameraType = row:GetItem("CameraType")
				local cameraTypeData = LobbyCameraTypeData()
		
				cameraTypeData:Load(row)
				typeDatas[cameraType] = cameraTypeData
			end
		end
		
		self.CameraTypeData = typeDatas
	end

	method LobbyCameraTypeData GetCameraTypeDataByKey(string key)
		-- 키에 해당하는 카메라 타입 데이터를 반환하는 함수
		return self.CameraTypeData[key]
	end

end