@Struct
script LobbyCameraTypeData

	property string CameraType = ""

	property Vector2 CustomBoundLB = Vector2(0,0)

	property Vector2 CustomBoundRT = Vector2(0,0)

	property number PosX = 0

	property number PosY = 0

	property number ZoomRatio = 0

	method void Load(any rowData)
		-- 행 데이터에서 카메라 타입 데이터를 로드하는 함수
		self.CameraType = rowData:GetItem("CameraType")
		
		if _UtilLogic:IsNilorEmptyString(rowData:GetItem("CustomBoundLB")) == false then
			local customBoundLbData = _UtilLogic:Split(rowData:GetItem("CustomBoundLB"), ",")
			self.CustomBoundLB = Vector2(tonumber(customBoundLbData[1]), tonumber(customBoundLbData[2]))
		end
		
		if _UtilLogic:IsNilorEmptyString(rowData:GetItem("CustomBoundRT")) == false then
			local customBoundRtData = _UtilLogic:Split(rowData:GetItem("CustomBoundRT"), ",")
			self.CustomBoundRT = Vector2(tonumber(customBoundRtData[1]), tonumber(customBoundRtData[2]))
		end
		
		self.PosX = tonumber(rowData:GetItem("PosX"))
		self.PosY = tonumber(rowData:GetItem("PosY"))
		self.ZoomRatio = tonumber(rowData:GetItem("ZoomRatio"))
	end

end