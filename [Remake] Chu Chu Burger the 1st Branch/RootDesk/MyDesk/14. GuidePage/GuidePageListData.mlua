@Struct
script GuidePageListData

	property string Id = ""

	property string GuidePageTitleKey = ""

	property integer GuideContentCount = 0

	property string GuidePageLayoutType = ""

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 가이드 페이지 정보를 로드하여 속성에 저장하는 함수
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		self.Id = rowData:GetItem("Id")
		self.GuidePageTitleKey = rowData:GetItem("GuidePageTitleKey")
		self.GuideContentCount = tonumber(rowData:GetItem("GuideContentCount"))
		self.GuidePageLayoutType = rowData:GetItem("GuidePageLayoutType")
	end

end