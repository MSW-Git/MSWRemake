@Struct
script EmployeeMoveStatLevelExpData

	property integer Level = 0

	property number Exp = 0

	property number ExpSum = 0

	method void Load(string level)
		-- 레벨에 따른 직원 이동 능력 경험치 데이터를 로드하는 함수
		local rowData = _DataService:GetTable("EmployeeMoveStatLevelExpDataSet"):FindRow("Level",level)
		
		self.Level = tonumber(rowData:GetItem("Level"))
		
		self.Exp = tonumber(rowData:GetItem("Exp"))
		
		self.ExpSum = tonumber(rowData:GetItem("ExpSum"))
	end

end