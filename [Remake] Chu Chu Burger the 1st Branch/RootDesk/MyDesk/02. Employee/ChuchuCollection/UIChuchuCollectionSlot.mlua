@Component
script UIChuchuCollectionSlot extends Component

	property Entity ChuchuSlots = nil

	property Entity GroupNameEntity = nil

	property Entity GroupPanel = nil

	property Entity ChuchuSlot = nil

	property Entity RedDot = nil

	property integer GroupId = 0

	property integer Index = 0

	property Entity SetBtn = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 초기화를 처리하는 함수
		
		self.GroupPanel = self.Entity:GetChildByName("GroupPanel")
		self.GroupNameEntity = self.GroupPanel:GetChildByName("GroupName")
		self.ChuchuSlots = self.Entity:GetChildByName("ChuchuSlots")
		self.ChuchuSlot = self.ChuchuSlots:GetChildByName("1")
		self.RedDot = self.Entity:GetChildByName("RedDot")
		self.SetBtn = self.GroupPanel:GetChildByName("SetBtn")
		
		self.SetBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_UIGroupManager.ChuchuCollectionGroup.UIChuchuCollection:OnClickGroupSlot(self.GroupId)
		end)
		
	end

	@ExecSpace("ClientOnly")
	method void Init(integer groupId, integer index)
		-- 츄츄 컬렉션 슬롯을 초기화하는 함수
		self.GroupId = groupId
		self.Index = index
		local groupData = _ChuchuGroupLogic:GetChuchuGroupData(groupId)
		local groupName = _LocalizationService:GetText(groupData.GroupNameKey)
		self:UpdateGroupLevel(groupId) 
		
		self.GroupNameEntity.TextComponent.Text = groupName
		self.GroupPanel.Enable = true
		self.Entity.Enable = true
		
		local chuchuIds = groupData.GroupChuchuList
		table.sort(chuchuIds)
		local groupRedDot = false
		for j = 1, 5 do
			local chuchuId = chuchuIds[j]
			local slotEntity = _UIEntityService:GetOrCreateClonedEntityByName(self.ChuchuSlots, tostring(j), self.ChuchuSlot)
			
			if isvalid(chuchuId) then
				slotEntity.Enable = true
				if self:UpdateChuchuSlot(chuchuId, slotEntity) then
					groupRedDot = true
				end
			else
				slotEntity.Enable = false
			end
		end
		
		local setRedDot = false
		local groupLevel =  _UserService.LocalPlayer.ChuchuCollectionDB:CalcGroupLevel(groupId)
		for i = 1, groupLevel do
			local isReward = _UserService.LocalPlayer.ChuchuCollectionDB:CheckIsRewardGroupLevelReward(groupId, i)
			if isReward == false then
				setRedDot = true 
				break 
			end
		end
		
		if setRedDot then
			self.SetBtn.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.UI_AdvantageMaterial)
		else
			self.SetBtn.SpriteGUIRendererComponent:ChangeMaterial(nil)
		end
		
		local redDot = false
		if groupRedDot or setRedDot then
			redDot = true
		end
		self.RedDot.Enable = redDot 
	end

	@ExecSpace("ClientOnly")
	method void UpdateGroupLevelUI(integer level)
		-- 그룹 레벨 UI를 업데이트하는 함수
		
		for i = 1, 6 do
			local entity = self.GroupPanel:GetChildByName("GroupLevel".._StringUtilLogic:NumToString(i))
			local icon = entity:GetChildByName("Check")
			if not isvalid(icon) then
				icon = entity
			end
			if not isvalid(entity) then
				return
			end
			if i <= level then
				icon.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.ChuchuGroupLevel_Fill
			else
				icon.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.ChuchuGroupLevel_Empty
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method boolean UpdateChuchuSlot(string chuchuId, Entity slotEntity)
		-- 츄츄 슬롯을 업데이트하고 빨간점 상태를 반환하는 함수
		if isvalid(chuchuId) then
			
			slotEntity.UIEmployeeManageListRenderer:Set(chuchuId) 
			
			local collected = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollection[chuchuId]
			local portrait = slotEntity:GetChildByName("Mask"):GetChildByName("Portrait")
			if isvalid(collected) and collected == true then
				portrait.SpriteGUIRendererComponent:ChangeMaterial(nil)
			else
				portrait.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.BlackoutMaterial)
			end
			
			local chuchuRedDot = false
			local getReward =  _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollectionGetReward[chuchuId]
			if not isvalid(getReward) then
				getReward = false
			end
			if collected == true and getReward == false then
				slotEntity:GetChildByName("RedDot").Enable = true
				chuchuRedDot = true
			else
				slotEntity:GetChildByName("RedDot").Enable = false
			end 
			
			slotEntity.Enable = true
			
			return chuchuRedDot
		end
		
	end

	@ExecSpace("ClientOnly")
	method void UpdateGroupLevel(integer groupId)
		-- 그룹 레벨을 업데이트하는 함수
		local groupLevel = _UserService.LocalPlayer.ChuchuCollectionDB:CalcGroupLevel(groupId)
		self:UpdateGroupLevelUI(groupLevel)
		
	end

end