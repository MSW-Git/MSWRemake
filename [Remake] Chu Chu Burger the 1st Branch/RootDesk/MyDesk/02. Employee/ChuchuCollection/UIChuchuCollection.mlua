@Component
script UIChuchuCollection extends Component

	property Entity StageScroll = "26eddd5b-04b4-4c2c-81a8-1cb63271dd8c"

	property Entity StagePanel = "c3da5f30-db88-4e33-ac49-9e392f680f0a"

	property SyncTable<integer, Entity> StageBtnEntities

	property Entity StgBtn_Origin = "26822737-75fa-4206-ae89-f019841daa8c"

	property Entity ChuchuGroupSlot_Origin = "09ccda5f-e436-4c22-ad0c-008a79ef894e"

	property Entity ChuchuInfoPanel = "d989b804-c5ad-4d52-8608-f946b8179163"

	property Entity BuyEquipPopupDim = "0c2e8782-4e4b-4e90-9300-d99d050a33be"

	property Entity BuyEquipPopup = "3c872061-b7b7-4934-bfe0-5c4f378e94a1"

	property string SelectedChuchuId = ""

	property integer SelectedStgId = -1

	property integer SelectedGroupId = 0

	property Entity GroupInfoPanel = "7850239f-9cee-41ab-b621-1e5951c09264"

	property Entity UpgradeEquipPopup = "8caafedd-f7a0-4486-a6b5-b161a25f9f91"

	property Entity EquipBuy_EquipPanel = "44688d44-1b1c-47a2-9832-7a7ea48f3171"

	property TextComponent EquipBuy_CostText = "bb079495-9b06-4cda-9f0e-cb0d203cd431"

	property Entity EquipUpgrade_PopupPanel = "5e8be80b-769d-40c3-94c1-e07fd9e4f1e1"

	property Entity EquipUpgrade_EquipInfoPanel_After = "07118294-578b-4106-b2ff-055e8565aa92"

	property TextComponent EquipUpgrade_ProbText = "16c2a59a-37a9-4fb0-88ce-e1b2c1c93402"

	property TextComponent EquipUpgrade_CostText = "769ed9ca-61ca-4f8b-98de-19414ea398ab"

	property SpriteGUIRendererComponent EquipUpgrade_CostIcon = "44b485f6-a4c3-4b64-9cd4-1b27157b0322"

	property Entity EquipUpgrade_EquipInfoPanel_Before = "c3cde1d1-31a1-4058-8144-3f35f491fb33"

	property Entity EquipInfoPanel = "a83edbb5-b4a3-48fa-9a6b-49349e848de7"

	property TextComponent EquipInfoLvText = "0d877e69-00ba-46b1-8d7d-92ffa2322466"

	property TextComponent EquipInfoDescText = "91dc605b-dfe6-468c-ac47-046174ab966f"

	property SyncTable<integer, boolean> GroupRedDot

	property Entity ChuchuInfoPanel_Portrait = "e804c3c4-bba3-4df6-bf92-8841d829320f"

	property any BuyEquipPopup_EventHandler = nil

	property any UpgradeEquipPopup_EventHandler = nil

	property Entity CollectionPercent = "e976de10-0abf-4178-b80e-71802d0b01bf"

	property Entity CollectionEffectText = "02bdbe30-34d4-4ce2-af32-5ef1e7cd5387"

	property Entity StageCollectGauge = "aadb71de-8ac3-454b-8c6e-9b026aa3e729"

	property Entity ChuchuSlot_Origin = "3cf99a60-e478-46d4-8d2c-2bff09c80072"

	property Entity RewardEffectParent = "0e724d33-7bb7-4fa1-801e-976405b84664"

	property Entity SelectedChuchuSlotEntity = nil

	property Entity SkillUpPopup = "30f4b772-a71c-4ca3-89ab-8a4b71bf7df6"

	property SyncTable<integer, boolean> StageRedDot

	property boolean CollectionRedDot = false

	property Entity ChuchuGroupList = "39ff3ad8-2ca3-4b10-ae9b-c99dcafa87ac"

	property integer RecycleScrollContentsCount = 5

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 초기화를 처리하는 함수
		self:SetStgIcons()
		
		local player = _UserService.LocalPlayer
		local diaCountString1 = _StringUtilLogic:ReturnThousandsSeparatedString(player.ChuchuCollectionDB.CollectionLv1RewardDiaCount)
		local diaCountString2 = _StringUtilLogic:ReturnThousandsSeparatedString(player.ChuchuCollectionDB.CollectionLv2RewardDiaCount)
		self.StagePanel:GetChildByName("RewardIcon1"):GetChildByName("Count").TextComponent.Text = diaCountString1
		self.StagePanel:GetChildByName("RewardIcon2"):GetChildByName("Count").TextComponent.Text = diaCountString2
		
		local tooltip = function(btn, tooltipEntity)
			if isvalid(btn) then 
				btn:ConnectEvent(ButtonClickEvent, function()
					if _UIGroupManager:IsEnableOpenPopUp() == false then
						return
					end
					_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
					_TooltipService:OpenTooltip(tooltipEntity, nil)
				end)
			end
		end
		
		local skill1Btn = self.ChuchuInfoPanel:GetChildByName("Skill1")
		local skill1InfoBtn = skill1Btn:GetChildByName("UIButton")
		local skill1ToolTip = skill1InfoBtn:GetChildByName("ToolTip")
		skill1ToolTip:SetEnable(false)
		
		local skill2Btn = self.ChuchuInfoPanel:GetChildByName("Skill2")
		local skill2InfoBtn = skill2Btn:GetChildByName("UIButton")
		
		local skill2ToolTip = skill2InfoBtn:GetChildByName("ToolTip")
		skill2ToolTip:SetEnable(false)
		
		tooltip(skill1Btn, skill1ToolTip)
		tooltip(skill1InfoBtn, skill1ToolTip)
		tooltip(skill2Btn, skill2ToolTip)
		tooltip(skill2InfoBtn, skill2ToolTip)
		
		local groupEffectHelpButton = self.GroupInfoPanel:GetChildByName("GroupEffectPanel"):GetChildByName("HelpBtn")
		local groupEffectHelpTooltip = groupEffectHelpButton:GetChildByName("Tooltip")
		groupEffectHelpTooltip.Enable = false
		
		tooltip(groupEffectHelpButton, groupEffectHelpTooltip)
		
	end

	@ExecSpace("ClientOnly")
	method void OpenUI(string chuchuId)
		-- 츄츄 컬렉션 UI를 여는 함수
		_UIGroupManager:EnableChuchuCollectionGroup(true)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Open_Collection"], 1)
		if not isvalid(chuchuId) then
		
			self:OnClickStgIcon(0)
			self:CloseBuyEquipPopup()
			self:CloseUpgradeEquipPopup()
			self.ChuchuInfoPanel.Enable = false
			 
		else
			local data = _EmployeeService:GetData(chuchuId)
			self:ScrollToGroup(data.GroupId) 
			self:OnClickChuchuSlot(chuchuId, nil)
			self:CloseBuyEquipPopup()
			self:CloseUpgradeEquipPopup()
			self.ChuchuInfoPanel.Enable = true
		end
		self.GroupInfoPanel.Enable = false
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.EnterEmployeeCollection)
		
	end

	@ExecSpace("ClientOnly")
	method void CloseUI()
		-- 츄츄 컬렉션 UI를 닫는 함수
		_UIGroupManager:EnableChuchuCollectionGroup(false)
	end

	@ExecSpace("ClientOnly")
	method void SetStgIcons()
		-- 스테이지 아이콘들을 설정하는 함수
		
		for i = 1, _StageDataSetLogic.LastStageNum do
			if i == 1 then i = 0 end
			local stgData = _StageDataSetLogic:GetStageData(i)
			local btnName = "StgBtn_".._StringUtilLogic:NumToString(i)
			local btnEntity = self.StageScroll:GetChildByName(btnName)
			if not isvalid(btnEntity) then
				btnEntity = _SpawnService:SpawnByEntity(self.StgBtn_Origin, btnName, Vector3.zero, self.StageScroll)
			end
			self.StageBtnEntities[i] = btnEntity
			
			if stgData.HideSlot == true then
				btnEntity.Enable = false
				continue
			end
			if stgData.ComingSoon == true then
				btnEntity:GetChildByName("LockText").Enable = true
				btnEntity:GetChildByName("Icon").Enable = false
				btnEntity:GetChildByName("RedDot").Enable = false
				continue
			end
			
			local stgIcon = stgData.BadgeIconRUID
			local stgName = _GetLocalizationTextLogic:GetText(stgData.NameKey)
		
			btnEntity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = stgIcon
			btnEntity:GetChildByName("RedDot").Enable = false
			btnEntity:GetChildByName("LockText").Enable = false
			
			btnEntity:ConnectEvent(ButtonClickEvent, function() 
				if _UIGroupManager:IsEnableOpenPopUp() == false then
					return
				end
				
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				self:OnClickStgIcon(i)
			end)
		end
		
		self.StgBtn_Origin.Enable = false
		
		for i, entity in pairs(self.StageBtnEntities) do
			if i == 0 or i == 1 then
				entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.CategoryTabBg_Selected
				entity:GetChildByName("Icon").SpriteGUIRendererComponent.Color.a = 1
			else
				entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.CategoryTabBg_UnSelected
				entity:GetChildByName("Icon").SpriteGUIRendererComponent.Color.a = 0.5
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetScrollView(integer stageId)
		-- 스테이지에 따른 스크롤 뷰를 설정하는 함수
		
		if stageId == 1 then stageId = 0 end
		local stgData = _StageDataSetLogic:GetStageData(stageId)
		if stgData.HideSlot == true or stgData.ComingSoon == true then
			return
		end
		self:RegisterRecycleScrollLayoutCallback()
		
		self.ChuchuGroupSlot_Origin.Enable = false
		
		local chuchuGroupData = _ChuchuGroupLogic:RetrunGroupIdsFromStageId(stageId)
		local itemCount = #chuchuGroupData 
		self.ChuchuGroupList.RecycleScrollView:SetTotalCount(itemCount)
		self.ChuchuGroupList.RecycleScrollView:Refresh(true)
		table.sort(chuchuGroupData)
		
		for i = 1, self.RecycleScrollContentsCount do
			local groupId = chuchuGroupData[i]
			local entityName = "Item".._StringUtilLogic:NumToString(i)
			local groupEntity = _UIEntityService:GetOrCreateClonedEntityByName(self.ChuchuGroupList, entityName, self.ChuchuGroupSlot_Origin)
			local groupData = _ChuchuGroupLogic:GetChuchuGroupData(groupId)
			if not isvalid(groupData) then
				groupEntity.Enable = false
				continue
			end
			groupEntity.Enable = true
			local chuchuIds = groupData.GroupChuchuList
			table.sort(chuchuIds)
			if isvalid(chuchuIds) then
				local chuchuSlots = groupEntity:GetChildByName("ChuchuSlots")
				for j = 1, 5 do
					local chuchuId = chuchuIds[j]
					local slotEntity = _UIEntityService:GetOrCreateClonedEntityByName(chuchuSlots, tostring(j), self.ChuchuSlot_Origin)
					
					slotEntity.Enable = isvalid(chuchuId)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateChuchuGroupSlot(integer groupId)
		-- 츄츄 그룹 슬롯을 업데이트하는 함수
		local entity = self:ReturnEntityByGroupId(groupId) 
		if isvalid(entity) then
			entity.UIChuchuCollectionSlot:UpdateGroupLevel(groupId) 
			self:RecycleScrollOnUpdateByGroupId(groupId, entity)
		end
		self:CheckGroupRedDot(groupId)
	end

	@ExecSpace("ClientOnly")
	method void OnClickStgIcon(integer stgId)
		-- 스테이지 아이콘 클릭 시 처리하는 함수
		if not isvalid(stgId) then
			stgId = 0
		end
		
		local stgData = _StageDataSetLogic:GetStageData(stgId)
		if stgData.HideSlot or stgData.ComingSoon then
			_UIToast:ShowMessage(_LocalizationService:GetText("Comming Soon"))
			return
		end
		
		if self.SelectedStgId ~= stgId then
			self.ChuchuInfoPanel.Enable = false
			self.GroupInfoPanel.Enable = false
		end
		
		local stgIcon = stgData.BadgeIconRUID
		local stgName = _GetLocalizationTextLogic:GetText(stgData.NameKey)
		self.SelectedStgId = stgId
		
		self.StagePanel:GetChildByName("StgName").TextComponent.Text = _LocalizationService:GetText(stgName)
		self.StagePanel:GetChildByName("StgIcon").SpriteGUIRendererComponent.ImageRUID = stgIcon
		
		for i, entity in pairs(self.StageBtnEntities) do
			if i == stgId then
				entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.CategoryTabBg_Selected
				entity:GetChildByName("Icon").SpriteGUIRendererComponent.Color.a = 1
			else
				entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.CategoryTabBg_UnSelected
				entity:GetChildByName("Icon").SpriteGUIRendererComponent.Color.a = 0.5
			end
		end
		
		self:UpdateStageCollectionGauge(stgId)
		
		self:SetScrollView(stgId)
		
	end

	@ExecSpace("ClientOnly")
	method void UpdateChuchuSlot(string chuchuId)
		-- 츄츄 슬롯을 업데이트하는 함수
		local groupId = _EmployeeService:GetData(chuchuId).GroupId
		local groupEntity = self:ReturnEntityByGroupId(groupId)
		local chuchuSlotEntity = self:ReturnEntityByEmpId(chuchuId)
		groupEntity.UIChuchuCollectionSlot:UpdateChuchuSlot(chuchuId, chuchuSlotEntity)
		
	end

	@ExecSpace("ClientOnly")
	method void OnClickChuchuSlot(string chuchuId, Entity slotEntity)
		-- 츄츄 슬롯 클릭 시 상세 정보를 표시하는 함수
		local data = _EmployeeService:GetData(chuchuId)
		if not isvalid(data) then return end 
		
		local collected = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollection[chuchuId]
		if not isvalid(collected) then
			collected = false
		end
		
		self.ChuchuInfoPanel.Enable = true
		self.GroupInfoPanel.Enable = false
		
		self.SelectedChuchuId = chuchuId
		local ui = self.ChuchuInfoPanel
		
		local portraitImage = ui:GetChildByName("Portrait"):GetChildByName("UISpriteCardBg")
		portraitImage.SpriteGUIRendererComponent.ImageRUID = data.StandRUID
		
		local portraitMaterial = _IconRuidEnum.BlackoutMaterial
		local equip = portraitImage:GetChildByName("equip")
		local equipRuid = _IconRuidEnum.Empty
		local nameString = "???"
		local chuchuChat = "..."
		
		if collected then
			---@type EmployeeOutgameDetailData
			local outgameData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeOutgameDetail(chuchuId)
			if isvalid(outgameData) and outgameData.EquipLevel >= 0 then
				equipRuid = data.EquipStandRUID 
			end
			portraitMaterial = nil
			nameString = _GetLocalizationTextLogic:GetText(data.NameKey)
			chuchuChat = _GetLocalizationTextLogic:GetText("ChuchuChatBalloonText")
		end
		portraitImage.SpriteGUIRendererComponent:ChangeMaterial(portraitMaterial)
		equip.SpriteGUIRendererComponent.ImageRUID = equipRuid 
		
		ui:GetChildByName("Portrait"):GetChildByName("Name").TextComponent.Text = nameString
		
		ui:GetChildByName("ChuchuChatBalloon"):GetChildByName("Text").TextComponent.Text = chuchuChat
		
		local stageId =  _ChuchuGroupLogic:ReturnStageIdFromGroupId(data.GroupId)
		if self.SelectedStgId ~= stageId then
			self:OnClickStgIcon(stageId)
		end
		
		ui:GetChildByName("TypeName").TextComponent.Text =  _GetLocalizationTextLogic:GetText(data.Type)
		ui:GetChildByName("TypeIcon").SpriteGUIRendererComponent.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(data.Type) 
		
		_EmployeeSkillService:DisplaySkillSlot(chuchuId, ui, true)
		
		local empManager =  _UserService.LocalPlayer.EmployeeManager
		local detailData = empManager:GetEmployeeDetail(chuchuId)
		local outgameDetailData = empManager:GetEmployeeOutgameDetail(chuchuId)
		
		local equipLevel = outgameDetailData.EquipLevel 
		local equipPanel = ui:GetChildByName("EquipPanel")
		local lockedEquipIcon = equipPanel:GetChildByName("LockedIcon")
		local equipIcon =  equipPanel:GetChildByName("Icon") 
		local equipName =  _LocalizationService:GetText("LockedEquipIconName")
		local equipDesc =  _LocalizationService:GetText("EquipLevelDescNone") 
		
		equipPanel:GetChildByName("Complete").Enable = false
		if equipLevel >= 0 then
			equipIcon.Enable = true
			equipIcon.SpriteGUIRendererComponent.ImageRUID = data.EquipIcon
			lockedEquipIcon.Enable = false
			equipName = _LocalizationService:GetText(data.EquipNameKey)
			equipPanel:GetChildByName("BuyEquipBtn").Enable = false
			equipPanel:GetChildByName("UpgradeEquipBtn").Enable = true
			equipPanel:GetChildByName("Stars").Enable = true
			if equipLevel >= 8 then
				equipPanel:GetChildByName("Complete").Enable = true
				equipPanel:GetChildByName("UpgradeEquipBtn").Enable = false
			end
			
		else
			equipIcon.Enable = false
			lockedEquipIcon.Enable = true
			equipPanel:GetChildByName("BuyEquipBtn").Enable = true
			equipPanel:GetChildByName("UpgradeEquipBtn").Enable = false
			equipPanel:GetChildByName("Stars").Enable = false
		end
		self:ResetEquipStarsUI(equipPanel, equipLevel)
		equipPanel:GetChildByName("Name").TextComponent.Text = equipName
		
		self:ResetEquipDesc(equipLevel, self.EquipInfoLvText, self.EquipInfoDescText)
		
		local getReward =  _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollectionGetReward[chuchuId]
		if not isvalid(getReward) then
			getReward = false
		end
		if collected == true and getReward == false then
			self:ChuchuCollectionReward(chuchuId)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickGroupSlot(integer groupId)
		-- 그룹 슬롯 클릭 시 그룹 정보를 표시하는 함수
		self.GroupInfoPanel.Enable = true
		self.ChuchuInfoPanel.Enable = false
		self.SelectedGroupId = groupId
		
		local groupData = _ChuchuGroupLogic:GetChuchuGroupData(groupId)
		local name = _LocalizationService:GetText(groupData.GroupNameKey)
		local level = _UserService.LocalPlayer.ChuchuCollectionDB:CalcGroupLevel(groupId)
		local speedBonus = level * _GetConfigDataLogic:GetConfigNumDataByKey("MoveSpeedAddedByGroupBonus")
		local descText = _LocalizationService:GetTextFormat("GroupEffectTitle", tostring(speedBonus)) 
		local desc2Text =  _LocalizationService:GetText("GroupEffectDesc")
		
		if level == 0 then
			descText = _LocalizationService:GetText("GroupEffectTitle_None") 
			desc2Text =  _LocalizationService:GetText("GroupEffectDesc_None")
		end
		self.GroupInfoPanel:GetChildByName("GroupName"):GetChildByName("Text").TextComponent.Text = name
		self.GroupInfoPanel:GetChildByName("GroupEffectPanel"):GetChildByName("Desc").TextComponent.Text = descText
		self.GroupInfoPanel:GetChildByName("GroupEffectPanel"):GetChildByName("Desc2").TextComponent.Text = desc2Text
		self:UpdateGroupLevelUI(self.GroupInfoPanel, level)
		
		local chuchuIds = groupData.GroupChuchuList
		table.sort(chuchuIds)
		
		if isvalid(chuchuIds) then
			local chuchuSlots = self.GroupInfoPanel:GetChildByName("GroupImg")
			
			for j = 1, 5 do
				local img = chuchuSlots:GetChildByName(_StringUtilLogic:NumToString(j))
				local chuchuId = chuchuIds[j]
				if isvalid(chuchuId) then
					---@type EmployeeData
					local data = _EmployeeService:GetData(chuchuId)
					_EmployeeUIService:DrawPortraitWithEquip(img, img, data)	
					local collected = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollection[chuchuId]
					if isvalid(collected) and collected == true then
						img.SpriteGUIRendererComponent:ChangeMaterial(nil)
					else
						img.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.BlackoutMaterial)
					end
					img.Enable = true
				else
					img.Enable = false
				end
			end
		end
		
		self:UpdateGroupLevelRewardList(groupId)
	end

	@ExecSpace("ClientOnly")
	method void OnClickChuchuInfoGroupBtn()
		-- 츄츄 정보에서 그룹 버튼 클릭 시 처리하는 함수
		local chuchuId = self.SelectedChuchuId
		local data = _EmployeeService:GetData(chuchuId)
		self:OnClickGroupSlot(data.GroupId)
	end

	@ExecSpace("ClientOnly")
	method void OpenBuyEquipPopup()
		-- 장비 구매 팝업을 여는 함수
		local collected = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollection[self.SelectedChuchuId]
		if not isvalid(collected) or collected == false then
			_UIToast:ShowMessage(_LocalizationService:GetText("CantBuyEquipMsg_NotCollected"))
			return 
		end
		
		self.BuyEquipPopupDim.Enable = true
		
		self:ResetEmployeeEquipBuyPopup()
		
		self:HandleEventToPopup(true, self.BuyEquipPopup_EventHandler, self.ResetEmployeeEquipBuyPopup)
	end

	@ExecSpace("ClientOnly")
	method void CloseBuyEquipPopup()
		-- 장비 구매 팝업을 닫는 함수
		self.BuyEquipPopupDim.Enable = false
		
		self:HandleEventToPopup(false, self.BuyEquipPopup_EventHandler, nil)
	end

	@ExecSpace("ClientOnly")
	method void OpenUpgradeEquipPopup()
		-- 장비 업그레이드 팝업을 여는 함수
		---@type EmployeeOutgameDetailData
		local myData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeOutgameDetail(self.SelectedChuchuId)
		local equipLevel = myData.EquipLevel
		
		if equipLevel >= _EmployeeEquipUpgradeDataLogic.MaxUpgradeLevel then
			return
		end
		self.UpgradeEquipPopup.Enable = true
		
		self:ResetEmployeeEquipUpgradePopup()
		
		self:HandleEventToPopup(true, self.UpgradeEquipPopup_EventHandler, self.ResetEmployeeEquipUpgradePopup)
	end

	@ExecSpace("ClientOnly")
	method void CloseUpgradeEquipPopup()
		-- 장비 업그레이드 팝업을 닫는 함수
		self.UpgradeEquipPopup.Enable = false
		
		self:HandleEventToPopup(false, self.UpgradeEquipPopup_EventHandler, nil)
	end

	@ExecSpace("ClientOnly")
	method void OnPurchaseEquipCompleted()
		-- 장비 구매 완료 후 UI를 업데이트하는 함수
		local employeeId = self.SelectedChuchuId
		
		---@type EmployeeData
		local data = _EmployeeService:GetData(employeeId)
		
		---@type EmployeeOutgameDetailData
		local myData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeOutgameDetail(employeeId) 
		
		local equip = self.ChuchuInfoPanel_Portrait:GetChildByName("equip")
		if isvalid(myData) and myData.EquipLevel >= 0 then 
			equip.SpriteGUIRendererComponent.ImageRUID = data.EquipStandRUID
		else
			equip.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.Empty
		end
		
		local equipLevel = myData.EquipLevel
		local equipIcon = self.EquipBuy_EquipPanel:GetChildByName("Icon") 
		local equipName = self.EquipBuy_EquipPanel:GetChildByName("Name")
		local equipStars = self.EquipBuy_EquipPanel:GetChildByName("Stars")
		local lockedEquipIcon = self.EquipBuy_EquipPanel:GetChildByName("LockedIcon")
		
		equipIcon.SpriteGUIRendererComponent.ImageRUID = data.EquipIcon
		equipName.TextComponent.Text = _LocalizationService:GetText(data.EquipNameKey)
		self:ResetEquipStarsUI(self.EquipBuy_EquipPanel, equipLevel)
		self:ResetEquipDesc(equipLevel, self.EquipInfoLvText, self.EquipInfoDescText)
		
		equipIcon.Enable = true
		equipName.Enable = true
		equipStars.Enable = true
		lockedEquipIcon.Enable = false
		self.EquipBuy_EquipPanel:GetChildByName("BuyEquipBtn").Enable = false
		self.EquipBuy_EquipPanel:GetChildByName("UpgradeEquipBtn").Enable = true
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_PetEquipPurchase"], 1)
		
		
		self:UpdateChuchuGroupSlot(data.GroupId)
		
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.BuyEmployeeEquip)
	end

	@ExecSpace("ClientOnly")
	method void ResetEquipStarsUI(Entity panel, integer equipLevel)
		-- 장비 별 UI를 리셋하는 함수
		local uiStars = panel:GetChildByName("Stars")
		
		for i, entity in pairs(uiStars.Children) do
			if i > equipLevel then
		
				entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.ChuchuEquipStar_Empty
				continue
			end
			
			entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.ChuchuEquipStar
		end
	end

	@ExecSpace("ClientOnly")
	method void ResetEmployeeEquipUpgradePopup()
		-- 직원 장비 업그레이드 팝업을 리셋하는 함수
		
		local panel = self.EquipUpgrade_PopupPanel
		
		local employeeId = self.SelectedChuchuId
		
		---@type EmployeeOutgameDetailData
		local myData = _UserService.LocalPlayer.EmployeeManager:GetEmployeeOutgameDetail(employeeId)
		local equipLevel = myData.EquipLevel
		
		if equipLevel >= _EmployeeEquipUpgradeDataLogic.MaxUpgradeLevel then
			return
		end
		
		---@type EmployeeData
		local employeeData = _EmployeeService:GetData(employeeId)
		
		self:ResetEquipStarsUI(panel, equipLevel)
		
		local icon = panel:GetChildByName("Icon")
		icon.SpriteGUIRendererComponent.ImageRUID = employeeData.EquipIcon
		
		local name = panel:GetChildByName("Name")
		name.TextComponent.Text = _LocalizationService:GetText(employeeData.EquipNameKey)
		
		local equipInfoBeforeLvText = self.EquipUpgrade_EquipInfoPanel_Before:GetChildByName("LvText")
		local equipInfoBeforeDescText = equipInfoBeforeLvText:GetChildByName("Desc")
		self:ResetEquipDesc(equipLevel, equipInfoBeforeLvText.TextComponent, equipInfoBeforeDescText.TextComponent)
		
		local nextEquipLevel = equipLevel + 1
		local equipInfoAfterLvText = self.EquipUpgrade_EquipInfoPanel_After:GetChildByName("LvText")
		local equipInfoAfterDescText = equipInfoAfterLvText:GetChildByName("Desc")
		local upgradeData = self:ResetEquipDesc(nextEquipLevel, equipInfoAfterLvText.TextComponent, equipInfoAfterDescText.TextComponent)
		
		self.EquipUpgrade_ProbText.Text = tostring(upgradeData.UpgradeProb)..'%'
		
		local employeeType = employeeData.Type
		local requiredItemId
		if employeeType == _EmployeeTypeEnum.Cook then
			requiredItemId = _ItemDataEnum.CookEmployeeEquipUpgradeItemId
		else
			requiredItemId = _ItemDataEnum.ServingEmployeeEquipUpgradeItemId
		end
		local ownItemCount = _UserService.LocalPlayer.PlayerInventory:GetItemCount(requiredItemId)
		
		
		if ownItemCount < upgradeData.UpgradeCost then
			self.EquipUpgrade_CostText.Text = string.format("<color=#fa5246>%s</color>/%d", _StringUtilLogic:ReturnThousandsSeparatedString(ownItemCount), upgradeData.UpgradeCost)
		else
			self.EquipUpgrade_CostText.Text = string.format("%s/%d", _StringUtilLogic:ReturnThousandsSeparatedString(ownItemCount), upgradeData.UpgradeCost)
		end
		
		self.EquipUpgrade_CostIcon.ImageRUID = _ItemDataSetLogic:GetItemData(requiredItemId).IconRUID
	end

	@ExecSpace("ClientOnly")
	method void OnUpgradeEquipCompleted(string itemId, integer count, integer equipLevel, boolean isSuccess)
		-- 장비 업그레이드 완료 후 UI를 업데이트하는 함수
		
		local panel = self.EquipBuy_EquipPanel
		
		self:ResetEquipStarsUI(panel, equipLevel)
		
		if equipLevel >= _EmployeeEquipUpgradeDataLogic.MaxUpgradeLevel then
			panel:GetChildByName("Complete").Enable = true
			panel:GetChildByName("UpgradeEquipBtn").Enable = false
		
		elseif equipLevel >= 0 then 
			panel:GetChildByName("Complete").Enable = false
			panel:GetChildByName("UpgradeEquipBtn").Enable = true
		else
			panel:GetChildByName("Complete").Enable = false
			panel:GetChildByName("UpgradeEquipBtn").Enable = false
		end
		
		local lvText = self.EquipInfoPanel:GetChildByName("LvText")
		local descText = lvText:GetChildByName("Desc")
		self:ResetEquipDesc(equipLevel, lvText.TextComponent, descText.TextComponent)
		_EmployeeSkillService:DisplaySkillSlot(self.SelectedChuchuId, self.ChuchuInfoPanel, true)
		
		local refreshUpgradePanel = function()
			panel = self.EquipUpgrade_PopupPanel
			
			if equipLevel >= _EmployeeEquipUpgradeDataLogic.MaxUpgradeLevel then
				self:CloseUpgradeEquipPopup()
				return
			end
			
			self:ResetEquipStarsUI(panel, equipLevel)
			
			local equipInfoBeforeLvText = self.EquipUpgrade_EquipInfoPanel_Before:GetChildByName("LvText")
			local equipInfoBeforeDescText = equipInfoBeforeLvText:GetChildByName("Desc")
			self:ResetEquipDesc(equipLevel, equipInfoBeforeLvText.TextComponent, equipInfoBeforeDescText.TextComponent)
			
			local nextEquipLevel = equipLevel + 1
			local equipInfoAfterLvText = self.EquipUpgrade_EquipInfoPanel_After:GetChildByName("LvText")
			local equipInfoAfterDescText = equipInfoAfterLvText:GetChildByName("Desc")
			local upgradeData = self:ResetEquipDesc(nextEquipLevel, equipInfoAfterLvText.TextComponent, equipInfoAfterDescText.TextComponent)
			
			self.EquipUpgrade_ProbText.Text = tostring(upgradeData.UpgradeProb)..'%'
			
			self.EquipUpgrade_CostText.Text = string.format("%s/%d", _StringUtilLogic:ReturnThousandsSeparatedString(count), upgradeData.UpgradeCost)
			
		end
		
		if isSuccess then
			
			local data = _EmployeeService:GetData(self.SelectedChuchuId)
			self:UpdateChuchuGroupSlot(data.GroupId)
			
				local skillId = data.Skill1Type
				if _EmployeeSkillService:ReturnUpgradeSkillNumByEquipLevel(equipLevel) == 2 then
					skillId = data.Skill2Type
				end
				self:SkillUpgradePopup(self.SelectedChuchuId, skillId)
				_TimerService:SetTimerOnce(function()
					refreshUpgradePanel()
				end, 1)
				
			
		end
	end

	@ExecSpace("ClientOnly")
	method EmployeeEquipUpgradeData ResetEquipDesc(integer equipLevel, TextComponent lvText, TextComponent descText)
		-- 장비 레벨에 따른 설명 텍스트를 리셋하는 함수
		local equipLevelLocaleKey = _EmployeeEquipUpgradeDataLogic.EquipLevelTextLocaleKey
		
		if equipLevel == -1 then
			lvText.Text = _LocalizationService:GetText("None") 
			descText.Text = _LocalizationService:GetText(_EmployeeEquipUpgradeDataLogic.EquipNoneTextLocaleKey) 
			return
		end
		
		---@type EmployeeEquipUpgradeData
		local employeeEquipUpgradeData = _EmployeeEquipUpgradeDataLogic:GetEmployeeEquipUpgrageData(equipLevel)
		local equipLevelDesc = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(equipLevelLocaleKey, equipLevel)
		local equipInfoDesc = _LocalizationService:GetText(employeeEquipUpgradeData.EquipLevelDescKey)
		if equipLevel == 0 then
			equipInfoDesc = _LocalizationService:SmartFormat(equipInfoDesc, _GetConfigDataLogic:GetConfigNumDataByKey("MoveSpeedAddedByGetEquip"))
		end
		lvText.Text = equipLevelDesc
		descText.Text = equipInfoDesc
		
		return employeeEquipUpgradeData
	end

	@ExecSpace("ClientOnly")
	method void HandleEventToPopup(boolean connect, any eventHandlerBase, any func)
		-- 팝업 이벤트 핸들링을 처리하는 함수
		local player = _UserService.LocalPlayer
		
		if connect then
			if eventHandlerBase ~= nil then
				return
			else
				player:ConnectEvent(PlayerInventoryItemChangedEvent, func)
			end
		else
			player:DisconnectEvent(PlayerInventoryItemChangedEvent, eventHandlerBase)
		end
	end

	@ExecSpace("ClientOnly")
	method void ResetEmployeeEquipBuyPopup()
		-- 직원 장비 구매 팝업을 리셋하는 함수
		
		local chuchuId = self.SelectedChuchuId
		local data = _EmployeeService:GetData(chuchuId)
		if not isvalid(data) then return end 
		
		local equipIcon = data.EquipIcon
		local equipName = _LocalizationService:GetText(data.EquipNameKey)
		local equipDesc =  _LocalizationService:GetText("EquipLevelDescNone")
		self.BuyEquipPopup:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = equipIcon
		self.BuyEquipPopup:GetChildByName("Name").TextComponent.Text = equipName
		self.BuyEquipPopup:GetChildByName("EquipInfoPanel"):GetChildByName("Desc").TextComponent.Text = equipDesc
		
		local chuchuBeforeEntity = self.BuyEquipPopup:GetChildByName("Chuchu_Before")
		local chuchuAfterEntity = self.BuyEquipPopup:GetChildByName("Chuchu_After")
		local chuchuEquipEntity = chuchuAfterEntity:GetChildByName("Equip")
		
		chuchuBeforeEntity.SpriteGUIRendererComponent.ImageRUID = data.StandRUID
		chuchuAfterEntity.SpriteGUIRendererComponent.ImageRUID = data.StandRUID
		chuchuEquipEntity.SpriteGUIRendererComponent.ImageRUID = data.EquipStandRUID
		
		local myCount = _UserService.LocalPlayer.PlayerInventory:GetItemCount(_ItemDataEnum.EmployeeEquipOpenItemId)
		
		if myCount < 1 then
			self.EquipBuy_CostText.Text = _LocalizationService:SmartFormat("<color=#fa5246>{0}</color>/1", myCount)
		else
			self.EquipBuy_CostText.Text = _LocalizationService:SmartFormat("{0}/1", _StringUtilLogic:ReturnThousandsSeparatedString(myCount))
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateCollectionPercent()
		-- 컬렉션 달성률을 업데이트하는 함수
		local player = _UserService.LocalPlayer
		local percent = player.ChuchuCollectionDB.CollectionPercent 
		self.CollectionPercent.TextComponent.Text = string.format("%.2f", percent).."%"
		
		local cloverBonus = player.ChuchuCollectionDB.ChuchuCollectionCloverBonus * 100 
		local cloverBonusString = string.format("%.1f", cloverBonus)
		self.CollectionEffectText.TextComponent.Text = _LocalizationService:GetTextFormat("ChuchuCollectionCloverBonus", cloverBonusString)
		
	end

	@ExecSpace("ClientOnly")
	method void UpdateStageCollectionGauge(integer stageId)
		-- 스테이지 컬렉션 게이지를 업데이트하는 함수
		if self.SelectedStgId ~= stageId then
			return
		end
		local counts = _UserService.LocalPlayer.ChuchuCollectionDB.StageCollectionProgress[stageId]
		local count = counts[1]
		local maxCount = counts[2]
		self.StageCollectGauge.SliderComponent.MaxValue = maxCount
		self.StageCollectGauge.SliderComponent.Value = count
		self.StageCollectGauge:GetChildByName("EffectText").TextComponent.Text = string.format("%d/%d", tostring(count), tostring(maxCount))
		
		local diaIcon1 = self.StagePanel:GetChildByName("RewardIcon1")
		local diaIcon2 = self.StagePanel:GetChildByName("RewardIcon2")
		local percent = counts[3] * 100
		local level = 0
		if percent >= _UserService.LocalPlayer.ChuchuCollectionDB.CollectionLv2Percent then
			level = 2
		elseif percent >= _UserService.LocalPlayer.ChuchuCollectionDB.CollectionLv1Percent then
			level = 1
		end
		
		for i = 1, 2 do
			---@type Entity
			local icon
			if i == 1 then
				icon = diaIcon1
			else
				icon = diaIcon2
			end
			
			if i <= level then
				
				local getReward
				local getRewardLevel =	_UserService.LocalPlayer.ChuchuCollectionDB.StageCollectionReward[stageId] 
				if isvalid(getRewardLevel) then
					if i == 1 and getRewardLevel == 1 then
						getReward = true
					elseif i == 2 and getRewardLevel == 2 then
						getReward = true
					elseif getRewardLevel == 3 then
						getReward = true
					else
						getReward = false
					end
				else
					getReward = false
				end
				
				if getReward == false then
					icon.Enable = true
					icon.ButtonComponent.Enable = true
					icon.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.BounceMaterial)
				else
					icon.Enable = false
				end
		
			else
				icon.Enable = true
				icon.SpriteGUIRendererComponent:ChangeMaterial(nil)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateGroupLevelUI(Entity panel, integer level)
		-- 그룹 레벨 UI를 업데이트하는 함수
		for i = 1, 6 do
			local entity = panel:GetChildByName("GroupLevel".._StringUtilLogic:NumToString(i))
			local icon = entity:GetChildByName("Check")
			if not isvalid(icon) then
				icon = entity
			end
			if not isvalid(entity) then
				return
			end
			if i <= level then
				icon.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.ChuchuGroupLevel_Fill
			else
				icon.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.ChuchuGroupLevel_Empty
			end
			
		end
	end

	@ExecSpace("Client")
	method void OnClickGroupLevelRewardIcon(integer groupLevel)
		-- 그룹 레벨 보상 아이콘 클릭 시 처리하는 함수
		_UserService.LocalPlayer.ChuchuCollectionDB:GroupLevelReward(self.SelectedGroupId, groupLevel)
	end

	@ExecSpace("ClientOnly")
	method void AfterRewardGroupLevel(integer groupLevel, integer count)
		-- 그룹 레벨 보상 지급 후 이팩트를 처리하는 함수
		local entity = self.GroupInfoPanel:GetChildByName("GroupLevel"..tostring(groupLevel))
		local rewardButton = entity:GetChildByName("RewardButton")
		_UICollectionLogic:DropDiamondAndMoveToMoneyBar_ChuchuCollection(count, rewardButton.SpriteGUIRendererComponent.ImageRUID.DataId, self.RewardEffectParent, rewardButton.UITransformComponent.WorldPosition)
	end

	@ExecSpace("ClientOnly")
	method void UpdateGroupLevelRewardList(integer groupId)
		-- 그룹 레벨 보상 목록을 업데이트하는 함수
		local groupData = _ChuchuGroupLogic:GetChuchuGroupData(groupId)
		local stageId = groupData.StageId
		local level = _UserService.LocalPlayer.ChuchuCollectionDB:CalcGroupLevel(groupId)
		local redDot = false
		
		for i = 1, 6 do
			local entity = self.GroupInfoPanel:GetChildByName("GroupLevel"..tostring(i))
			local rewardButton = entity:GetChildByName("RewardButton")
			local check = rewardButton:GetChildByName("Complete")
			local lock =  rewardButton:GetChildByName("Lock")
			local shine = entity:GetChildByName("Shine")
			local count =  rewardButton:GetChildByName("Count")
			
			---@type GroupCollectionRewardData
			local rewardData = _GroupCollectionRewardDataSetLogic.GroupCollectionRewardData[i]
			local rewardId = rewardData:ReturnRewardIdFromType(groupData.GroupRewardType)
			rewardButton.SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:ReturnItemRuidFromId(rewardId)
			count.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(rewardData.RewardItemCount)
			
			rewardButton:ConnectEvent(ButtonClickEvent, function()
				self:OnClickGroupLevelRewardIcon(i)
			end)
			
			if i <= level then
				lock.Enable = false
				
				local getReward  = _UserService.LocalPlayer.ChuchuCollectionDB:CheckIsRewardGroupLevelReward(groupId, i)
				
				if getReward == false then
					check.Enable = false
					rewardButton.ButtonComponent.Enable = true
					rewardButton.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.BounceMaterial)
					shine.Enable = true
				else
					check.Enable = true
					rewardButton.ButtonComponent.Enable = false
					rewardButton.SpriteGUIRendererComponent:ChangeMaterial(nil)
					shine.Enable = false
				end
		
		
			else
				lock.Enable = true
				check.Enable = false
				rewardButton.ButtonComponent.Enable = false
				rewardButton.SpriteGUIRendererComponent:ChangeMaterial(nil)
				shine.Enable = false
			end
		end
		
	end

	@ExecSpace("Client")
	method void UpdateStageCollectionReward(integer stageId, integer iconNum)
		-- 스테이지 컬렉션 보상을 업데이트하는 함수
		if self.SelectedStgId ~= stageId then
			return
		end
		local dia = _UserService.LocalPlayer.ChuchuCollectionDB.CollectionLv1RewardDiaCount
		local diaIcon1 = self.StagePanel:GetChildByName("RewardIcon1")
		local diaIcon2 = self.StagePanel:GetChildByName("RewardIcon2")
		
		local icon = diaIcon1
		if iconNum == 2 then
			dia = _UserService.LocalPlayer.ChuchuCollectionDB.CollectionLv2RewardDiaCount
			icon = diaIcon2
		end
		
		local iconPos = icon.UITransformComponent.WorldPosition
		icon.Enable = false 
		_UICollectionLogic:DropDiamondAndMoveToMoneyBar_ChuchuCollection(dia, nil, self.RewardEffectParent, iconPos)
		
		self:UpdateStageCollectionGauge(stageId)
	end

	@ExecSpace("Client")
	method void OnClickStageGaugeDiaIcon(integer iconNum)
		-- 스테이지 게이지 다이아 아이콘 클릭 시 처리하는 함수
		_UserService.LocalPlayer.ChuchuCollectionDB:StageReward(self.SelectedStgId, iconNum)
	end

	@ExecSpace("Client")
	method void ChuchuCollectionReward(string chuchuId)
		-- 츄츄 컬렉션 보상을 요청하는 함수
		_UserService.LocalPlayer.ChuchuCollectionDB:GiveChuchuCollectionReward(chuchuId)
	end

	@ExecSpace("Client")
	method void AfterChuchuCollectionReward(string chuchuId)
		-- 츄츄 컬렉션 보상 지급 후 이팩트를 처리하는 함수
		local groupId = _EmployeeService:GetData(chuchuId).GroupId
		self:UpdateChuchuGroupSlot(groupId) 
		
		local slotEntity = self:ReturnEntityByEmpId(chuchuId)
		if isvalid(slotEntity) then
			slotEntity:GetChildByName("RedDot").Enable = false
			local diaCount = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollectionRewardDiaCount
			_UICollectionLogic:DropDiamondAndMoveToMoneyBar_ChuchuCollection(diaCount, nil, self.RewardEffectParent, slotEntity.UITransformComponent.WorldPosition)
		else
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SkillUpgradePopup(string empId, string skillId)
		-- 스킬 업그레이드 팝업을 표시하는 함수
		self.SkillUpPopup.UISkillOpenPopup:Open(empId, skillId, false)
	end

	@ExecSpace("ClientOnly")
	method void CheckCollectionRedDot()
		-- 컬렉션 빨간점 표시 상태를 확인하는 함수
		local collectionRedDot = false
		for i = 1, _StageDataSetLogic.LastStageNum do
			if i == 1 then i = 0 end
			if isvalid(self.StageRedDot[i]) and self.StageRedDot[i] == true then
				collectionRedDot = true
			end
		end
		
		self.CollectionRedDot = collectionRedDot
		_MainMenuRedDotManager:EnableChuchuCollectionRedDot(self.CollectionRedDot)
	end

	@ExecSpace("ClientOnly")
	method void CheckStageIconRedDot(integer stageId)
		-- 스테이지 아이콘 빨간점 표시 상태를 확인하는 함수
		local btnName = "StgBtn_".._StringUtilLogic:NumToString(stageId)
		local btnEntity = self.StageScroll:GetChildByName(btnName)
		local stageRedDot = false
		local groupIds = _ChuchuGroupLogic:RetrunGroupIdsFromStageId(stageId)
		for _, groupId in pairs(groupIds) do
			if isvalid(self.GroupRedDot[groupId]) and self.GroupRedDot[groupId] == true then
				stageRedDot = true
			end
		end
		
		self.StageRedDot[stageId] = stageRedDot
		btnEntity:GetChildByName("RedDot").Enable = stageRedDot
		
		self:CheckCollectionRedDot()
	end

	@ExecSpace("ClientOnly")
	method void CheckGroupRedDot(integer groupId)
		-- 그룹 빨간점 표시 상태를 확인하는 함수
		
		local setRedDot = false
		local groupLevel =  _UserService.LocalPlayer.ChuchuCollectionDB:CalcGroupLevel(groupId)
		for i = 1, groupLevel do
			local isReward = _UserService.LocalPlayer.ChuchuCollectionDB:CheckIsRewardGroupLevelReward(groupId, i)
			if isReward == false then
				setRedDot = true 
				break 
			end
		end
		
		local groupRedDot = false
		local groupData = _ChuchuGroupLogic:GetChuchuGroupData(groupId)
		
		local chuchuIds = groupData.GroupChuchuList
		table.sort(chuchuIds)
		for _, chuchuId in pairs(chuchuIds) do
			local collected = _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollection[chuchuId]
			local getReward =  _UserService.LocalPlayer.ChuchuCollectionDB.ChuchuCollectionGetReward[chuchuId]
			if not isvalid(getReward) then
				getReward = false
			end
			if collected == true and getReward == false then
				groupRedDot = true
			end 
		end
		
		local redDot = false
		if setRedDot or groupRedDot then
			redDot = true
		end
		self.GroupRedDot[groupId] = redDot
		
		
		local stageId = _ChuchuGroupLogic:GetChuchuGroupData(groupId).StageId
		self:CheckStageIconRedDot(stageId)
	end

	@ExecSpace("ClientOnly")
	method void RegisterRecycleScrollLayoutCallback()
		-- 리사이클 스크롤 레이아웃 콜백을 등록하는 함수
		if self.ChuchuGroupList.RecycleScrollView.onUpdateCell ~= nil then
			return
		end
		
		local recycleFunc = function(index, entity)
			self:RecycleScrollOnUpdateByIndex(index, entity)
		end
		self.ChuchuGroupList.RecycleScrollView.onUpdateCell = recycleFunc
		
	end

	@ExecSpace("ClientOnly")
	method integer CalcIndexFromGroupId(integer groupId)
		-- 그룹 ID로 인덱스를 계산하는 함수
		local index
		local stageId = self.SelectedStgId
		
		if stageId == 0 then
			index = groupId
			
		else
			local stageCap =  #table.keys(_ChuchuGroupLogic:RetrunGroupIdsFromStageId(0))
			if stageId > 2 then
				for i = 2, stageId - 1 do
					stageCap += #table.keys(_ChuchuGroupLogic:RetrunGroupIdsFromStageId(i))
				end
			end
			index = groupId - stageCap
		end
		return index
	end

	@ExecSpace("ClientOnly")
	method integer CalcGroupIdFromIndex(integer index)
		-- 인덱스로 그룹 ID를 계산하는 함수
		local groupId 
		local stageId = self.SelectedStgId
		
		if stageId == 0 then
			groupId = index
			
		else
			local stageCap =  #table.keys(_ChuchuGroupLogic:RetrunGroupIdsFromStageId(0))
			if stageId > 2 then
				for i = 2, stageId - 1 do
					stageCap += #table.keys(_ChuchuGroupLogic:RetrunGroupIdsFromStageId(i))
				end
			end
			groupId = index + stageCap
		end
		return groupId
	end

	@ExecSpace("ClientOnly")
	method Entity ReturnEntityByGroupId(integer groupId)
		-- 그룹 ID로 엔티티를 반환하는 함수
		local groupEntity = nil
		for i = 1, self.RecycleScrollContentsCount do
			local entity = self.ChuchuGroupList:GetChildByName("Item"..tostring(i))
			if entity.UIChuchuCollectionSlot.GroupId == groupId then
				groupEntity = entity
				break
			end
		end
		
		return groupEntity
	end

	@ExecSpace("ClientOnly")
	method void RecycleScrollOnUpdateByIndex(integer index, Entity entity)
		-- 리사이클 스크롤의 인덱스 업데이트를 처리하는 함수
		local groupId = self:CalcGroupIdFromIndex(index)
		
		entity.UIChuchuCollectionSlot:Init(groupId, index) 
		self:CheckGroupRedDot(groupId)
	end

	@ExecSpace("ClientOnly")
	method void RecycleScrollOnUpdateByGroupId(integer groupId, Entity entity)
		-- 리사이클 스크롤의 그룹 ID 업데이트를 처리하는 함수
		local index = self:CalcIndexFromGroupId(groupId)
		
		entity.UIChuchuCollectionSlot:Init(groupId, index) 
	end

	@ExecSpace("ClientOnly")
	method Entity ReturnEntityByEmpId(string empId)
		-- 직원 ID로 엔티티를 반환하는 함수
		local empEntity = nil
		local groupId = _EmployeeService:GetData(empId).GroupId
		local groupEntity = self:ReturnEntityByGroupId(groupId)
		
		if isvalid(groupEntity) then
			for i = 1, 5 do
				local entity = groupEntity:GetChildByName("ChuchuSlots"):GetChildByName(tostring(i))
				if entity.UIEmployeeManageListRenderer.EmployeeId == empId then
					empEntity = entity
					break
				end
			end
		end
		return empEntity
	end

	@ExecSpace("ClientOnly")
	method void ScrollToGroup(integer groupId)
		-- 특정 그룹으로 스크롤하는 함수
		
		local stageId = _ChuchuGroupLogic:GetChuchuGroupData(groupId).StageId
		self:OnClickStgIcon(stageId)
		
		local index = self:CalcIndexFromGroupId(groupId) - 1
		self.ChuchuGroupList.RecycleScrollView:ScrollToIndex_Horizontal(index)
	end

	@ExecSpace("ClientOnly")
	method void SetRedDotOnBegin()
		-- 초기 빨간점 표시 상태를 설정하는 함수
		
		for i = 1, _StageDataSetLogic.LastStageNum do
			if i == 1 then i = 0 end
			local stageData = _StageDataSetLogic:GetStageData(i)
			if stageData.HideSlot or stageData.ComingSoon then
				continue
			end
			
			local groupIds = _ChuchuGroupLogic:RetrunGroupIdsFromStageId(i)
			for _, groupId in pairs(groupIds) do
				self:CheckGroupRedDot(groupId)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "74207717-c424-4857-9d3b-e29a80c0a948")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 컴렉션 UI 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OpenUI(nil) 
	end

