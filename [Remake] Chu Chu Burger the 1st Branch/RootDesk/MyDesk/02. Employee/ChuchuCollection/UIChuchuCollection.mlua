	@ExecSpace("ClientOnly")
	@EventSender("Entity", "18ce6a67-2e48-4c63-a412-a095811515c5")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 직원 컴렉션 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if _TutorialManager.target == _UIEmployeeManageService.DeployBtn then
		    return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		local empId = Entity.Parent.UIEmployeeManageDetailRenderer.EmployeeId
		
		self:OpenUI(empId) 
	end

