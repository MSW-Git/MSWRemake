@Logic
script GroupCollectionRewardDataSetLogic extends Logic

	property table GroupCollectionRewardData = {}

	method void OnBeginPlay()
		-- 게임 시작 시 데이터셋을 로드하는 함수
		self:LoadDataSet()
	end

	method void LoadDataSet()
		-- 그룹 컬렉션 보상 데이터셋을 로드하는 함수
		table.clear(self.GroupCollectionRewardData)
		local dataSet = _DataService:GetTable("GroupCollectionRewradDataSet")
		for i = 1, dataSet:GetRowCount() do
			local data = GroupCollectionRewardData()
			data:Load(dataSet, i)
			
			if self.GroupCollectionRewardData[data.GroupCollectionLevel] ~= nil then
				break
			end
			
			self.GroupCollectionRewardData[data.GroupCollectionLevel] = data
		end
	end

	method GroupCollectionRewardData GetGroupCollectionRewardData(integer level)
		-- 레벨에 따른 그룹 컬렉션 보상 데이터를 반환하는 함수
		return self.GroupCollectionRewardData[level]
	end

end