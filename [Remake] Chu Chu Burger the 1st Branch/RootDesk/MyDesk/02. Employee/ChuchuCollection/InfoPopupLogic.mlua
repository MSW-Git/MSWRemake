@Logic
script InfoPopupLogic extends Logic

	property Entity InfoPopupGroup = "56ea1c2f-fefb-466a-a4b9-29b3955780e3"

	property Entity EquipLevelDesc0 = "db5cac35-c0cb-499a-a696-f1933ec8a66e"

	@ExecSpace("ClientOnly")
	method void CloseUI()
		-- 정보 팝업 UI를 닫는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self.InfoPopupGroup.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OpenUI()
		-- 정보 팝업 UI를 여는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self.InfoPopupGroup.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Set()
		-- 정보 팝업 내용을 설정하는 함수
		local level0Desc = _EntityService:GetEntityByPath("/ui/InfoPopupGroup/PopupDim/Popup/Scroll/Slot_0/Desc")
		local equipInfoDesc = _LocalizationService:GetText("EquipLevelDesc0")
		level0Desc.TextComponent.Text = _LocalizationService:SmartFormat(equipInfoDesc, _GetConfigDataLogic:GetConfigNumDataByKey("MoveSpeedAddedByGetEquip"))
		local scroll = _EntityService:GetEntityByPath("/ui/InfoPopupGroup/PopupDim/Popup/Scroll")
		for _, slot in pairs(scroll.Children) do
			local slotNum = _UtilLogic:Trim(slot.Name, "Slot_")
			if tonumber(slotNum) > 0 then
				slot:GetChildByName("Title").TextComponent.Text = _LocalizationService:GetTextFormat("EquipLevelText", slotNum) 
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 초기화를 처리하는 함수
		self:Set()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "835de567-73e1-46b0-82d2-59846f13e8a4")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 정보 팝업 닫기 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:CloseUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "7a6ec3ad-5cda-46d4-812d-d45e1cd9c93e")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 정보 팝업 닫기 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:CloseUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5f3c5a23-43b4-4883-906e-64e4fa97bb9d")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 정보 팝업 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:OpenUI()
	end

	@EventSender("Entity", "0dbcd8af-fdcc-47c2-b237-a6ec7aae97dc")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 정보 팝업 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:OpenUI()
	end

	@EventSender("Entity", "64bf415c-8994-4a40-8238-5941efc5603d")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 정보 팝업 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:OpenUI()
	end

	@EventSender("Entity", "a89bde40-bf91-4cc8-aaa0-0509bdf89ef7")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 정보 팝업 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		self:OpenUI()
	end

end