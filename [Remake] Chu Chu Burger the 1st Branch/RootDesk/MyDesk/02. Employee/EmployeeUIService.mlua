@Logic
script EmployeeUIService extends Logic

	@ExecSpace("ClientOnly")
	method Entity ProgressUICreate(Entity owner)
		-- 직원 작업 진행 UI를 생성하는 함수
		local modelId =  _EntryService:GetModelIdByName("Model_WorkProgressCircle") 
		local ui = _SpawnService:SpawnByModelId(modelId,"WorkProgress!!",owner.TransformComponent.Position,owner)
		ui.UITransformComponent.WorldPosition = owner.TransformComponent.WorldPosition +Vector3(0.35,0.5,0)
		ui.Enable = false
		 
		return ui
	end

	@ExecSpace("ClientOnly")
	method void ProgressUIInit(boolean isStatLow, Entity uiEntity)
		-- 직원 작업 진행 UI를 초기화하는 함수
		local progressBackRUID = ""
		local progressRUID = ""
		
		if isStatLow == true then 
			progressBackRUID = "02ec47b5bfc6436ea6473f4aaaf1794c"
			progressRUID = "16f246a7ea1d4d6abfd16108415d1fec"
		else
			progressBackRUID = "f4ab411ded7f45d2a5e4d0f5a3002777"
			progressRUID = "9ea42eec0b4c4a1b8ac8fe8d74ddefa0" 
		 	
		end
		
		uiEntity.SpriteGUIRendererComponent.ImageRUID = progressBackRUID
		uiEntity:GetChildByName("Progress").SpriteGUIRendererComponent.ImageRUID = progressRUID
	end

	@ExecSpace("ClientOnly")
	method void ProgressUIOn(Entity uiEntity)
		-- 직원 작업 진행 UI를 활성화하는 함수
		uiEntity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void PreogressUIOff(Entity uiEntity)
		-- 직원 작업 진행 UI를 비활성화하는 함수
		uiEntity:GetChildByName("Progress").SpriteGUIRendererComponent.FillAmount = 0
		uiEntity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void ProgressUIUpdate(Entity uiEntity, number value, number maxValue)
		-- 직원 작업 진행 UI를 업데이트하는 함수
		if maxValue <= 0 then
			return
		end
		uiEntity:GetChildByName("Progress").SpriteGUIRendererComponent.FillAmount = value / maxValue
	end

	@ExecSpace("ClientOnly")
	method Entity PeedbackUICreate(Entity employee)
		-- 직원 피드백 UI를 생성하는 함수
		local modelId = _EntryService:GetModelIdByName("Model_PeedbackUI") 
		
		
		local peedbackUI = _SpawnService:SpawnByModelId(modelId,"PeedbackUI",employee.TransformComponent.Position,employee)
		peedbackUI.UITransformComponent.WorldPosition = employee.TransformComponent.WorldPosition + Vector3(-0.3,0.35,0)
		
		peedbackUI:GetChildByName("Tag").SpriteGUIRendererComponent.ImageRUID = _PeedbackRUID.NeedEmployeeUpgrade 
		peedbackUI:GetChildByName("Tag").UITransformComponent.WorldPosition = employee.TransformComponent.WorldPosition + Vector3(-0.15,0.5,0)
		 
		peedbackUI.Enable = false 
		
		return peedbackUI
	end

	@ExecSpace("ClientOnly")
	method void PeedbackUIClose(Entity employee)
		-- 직원 피드백 UI를 닫는 함수
		employee.EmployeeInfoScript.PeedbackUI.Enable = false
		employee.EmployeeInfoScript.PeedbackKey = ""
	end

	@ExecSpace("Client")
	method void PeedbackUIUpdate(string type, string tag, Entity employee)
		-- 직원 피드백 UI를 업데이트하는 함수
		local employeeInfo = employee.EmployeeInfoScript 
		local peedbackUI = employee.EmployeeInfoScript.PeedbackUI
		
		if employeeInfo.PeedbackTimer ~= 0 then 
			_TimerService:ClearTimer(employeeInfo.PeedbackTimer)
			employeeInfo.PeedbackTimer = 0
		end
		
		employee.EmployeeInfoScript.PeedbackKey = type
		
		
		local data = _EmployeeService:GetData(employeeInfo.Id):ConvertToTable()
		local name = _GetLocalizationTextLogic:GetText(data["NameKey"]) 
		local ruid = _PeedbackRUID.NeedEmployeeUpgrade 
		
		local spritreOffset = Vector3(0.1,0.2,0)
		local spritreSize = Vector2(120,120)
		if type == "LackDisplay" then 
		
			ruid = _PeedbackRUID.LackDisplay
			spritreOffset = Vector3(0.29,0.4,1)
			spritreSize = Vector2(150,150)
			
		elseif type == "NoBurger" then 
			ruid = _PeedbackRUID.NoBurger[tag]
		
			spritreOffset = Vector3(0.29,0.4,1)
			spritreSize = Vector2(150,150)
		elseif type == "ResignWarning" then
		
			ruid = _PeedbackRUID.ResignWarning
			spritreSize = Vector2(150,150)
			spritreOffset = Vector3(0.26,-0.4,1)
				
		elseif type == "EmployeeUpgrade" then 
			
			spritreOffset = Vector3(0.3,0.35,1)
		
			if employeeInfo.CheckReportTimeStat then 
				
				employeeInfo.CheckReportTimeStat = false 
				_TimerService:SetTimerOnce(function() employeeInfo.CheckReportTimeStat = true end, employeeInfo.CoolDownForRepeatedReportMsg)
				_ReportMessageMaker:RequestAddToReportQueue(2005,"","","") 
		
			end
			
		end
		
		peedbackUI:GetChildByName("Tag").SpriteGUIRendererComponent.ImageRUID = ruid 
		peedbackUI:GetChildByName("Tag").UITransformComponent.RectSize  = spritreSize
		peedbackUI:GetChildByName("Tag").UITransformComponent.Position  = spritreOffset
		
		peedbackUI.Enable = true
		
		if type == "EmployeeUpgrade" then
			_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.EmployeeLackOfStat)
		end
	end

	@ExecSpace("ClientOnly")
	method void DrawPortraitWithEquip(Entity portraitEntity, Entity equipEntityParent, EmployeeData data)
		-- 직원 초상화와 장비를 그리는 함수
		local player = _UserService.LocalPlayer
		if not isvalid(portraitEntity.SpriteGUIRendererComponent) then
			return
		end
		
		portraitEntity.SpriteGUIRendererComponent.ImageRUID = data.StandRUID
		portraitEntity.SpriteGUIRendererComponent.PlayRate = 0
		
		portraitEntity.SpriteGUIRendererComponent.PreserveSprite = PreserveSpriteType.NativeSize
		portraitEntity.SpriteGUIRendererComponent.LocalScale = Vector2(1.8, 1.8)
		portraitEntity.SpriteGUIRendererComponent.LocalPosition.y = -50
		
		local equipEntity = _UIEntityService:GetOrCreateClonedEntityByName(equipEntityParent, "equip", portraitEntity)
		local blurEntity = portraitEntity.Parent:GetChildByName("Blur") 
		if not isvalid(blurEntity) then
			blurEntity =  portraitEntity.Parent.Parent:GetChildByName("Blur") 
		end
		
		
		---@type EmployeeOutgameDetailData
		local outgameData = player.EmployeeManager:GetEmployeeOutgameDetail(data.Id)
		
		local hasEquip = false
		if isvalid(outgameData) and outgameData.EquipLevel >= 0 then
			equipEntity.SpriteGUIRendererComponent.ImageRUID = data.EquipStandRUID
			hasEquip = true
		else
			equipEntity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.Empty
		end
		equipEntity.SpriteGUIRendererComponent.PlayRate = 0
		equipEntity.SpriteGUIRendererComponent.Outline = false 
		
		portraitEntity.Enable = true
		equipEntity.Enable = true
		
		
		if isvalid(blurEntity) then
			if hasEquip then
				blurEntity.Enable = true
			else
				blurEntity.Enable = false
			end
		end
	end

end