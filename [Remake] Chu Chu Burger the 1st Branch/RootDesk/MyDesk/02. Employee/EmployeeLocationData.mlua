@Struct
script EmployeeLocationData

	property string Id = ""

	property string Location = ""

	property integer SlotIdx = 0

	method table ConvertToDBTable()
		-- 직원 위치 데이터를 DB 저장용 테이블로 변환하는 함수
		if self.Location == nil then
			self.Location = ""
		end
		
		if self.SlotIdx == nil then
			self.SlotIdx = 0
		end
		
		local result = {self.Id, self.Location, self.SlotIdx}
		
		
		return result
	end

	method void SetFromTable(table data)
		-- 테이블 데이터로부터 직원 위치 정보를 설정하는 함수
		self.Id =  data["Id"]
		self.Location = data["Location"]
		self.SlotIdx = data["SlotIdx"]
	end

	method void SetFromTable_Ver2(table data)
		-- 버전 2 테이블 데이터로부터 직원 위치 정보를 설정하는 함수
		self.Id =  data[1]
		self.Location = data[2]
		self.SlotIdx = tonumber(data[3])
	end

end