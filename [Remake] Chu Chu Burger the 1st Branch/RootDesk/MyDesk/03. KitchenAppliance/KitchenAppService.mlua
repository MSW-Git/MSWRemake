@Logic
script KitchenAppService extends Logic

	property table KAppData = {}

	property table KAppsOffset = {}

	property table KAppsNoneOffset = {}

	property table ChuChuUseKitAppOffset = {}

	property Vector3 ChuChuCookDisplayOffset = Vector3(0,0.3,0)

	property Vector3 ChuChuServingDisplayOffset = Vector3(0,-0.8,0)

	property Vector3 KAppsScale = Vector3(0.785,0.785,0)

	method void OnBeginPlay()
		-- 게임 시작 시 주방기기 데이터를 로드하고 초기화하는 함수
		self:LoadData()
		
		self.ChuChuUseKitAppOffset[_KitchenAppEnumType.Grill] = Vector3(0,-0.6,0) 
		self.ChuChuUseKitAppOffset[_KitchenAppEnumType.Counter] = Vector3(0,0.18,0)
		
		self.KAppsNoneOffset[_KitchenAppEnumType.Grill] = {0.05,-0.17}
		self.KAppsNoneOffset[_KitchenAppEnumType.Display] = {0.0,-0.05}
		self.KAppsNoneOffset[_KitchenAppEnumType.Counter] = {0.0,0.25}
		
		self.KAppsOffset[_KitchenAppEnumType.Grill] = { {0,0}, {0.0,0},{0.0,0} }
		self.KAppsOffset[_KitchenAppEnumType.Display] = { {0,-0.3}, {0.0,-0.3},{0.0,-0.3} }
		self.KAppsOffset[_KitchenAppEnumType.Counter] = { {-0.02,0}, {0,0},{0,0} }
	end

	method void InsertKitAppOffsetDataSet()
		-- 주방기기 위치 데이터를 데이터셋에 삽입하는 에디터용 함수
		local count = 1; 
		for i=1, 6 do
			local dataSetName = "KitchenAppPosDataSet"
			local currentMap = _UserService.LocalPlayer.CurrentMap
			local parent = _EntityService:GetEntityByPath(currentMap.Path.."/KitchenApp_Level"..i)
		
			local nodes = parent.Children 
			for row,entity in pairs(nodes) do
				local Stage =  i
				local Type 
				
				if	string.find(entity.Name,_KitchenAppEnumType.Display) then 
					Type = _KitchenAppEnumType.Display
				elseif string.find(entity.Name,_KitchenAppEnumType.Counter) then 
					Type = _KitchenAppEnumType.Counter	
				else
					Type = _KitchenAppEnumType.Grill
				end
					
				local Index = string.sub(entity.Name,string.len("Deco")+string.len(Type)+1,string.len(entity.Name))
				local PosX = entity.TransformComponent.WorldPosition.x
				local PosY = entity.TransformComponent.WorldPosition.y
				local Name = tostring(Stage).."_"..entity.Name
				
				_EditorService:DataSetInsertRow(dataSetName)
				_EditorService:DataSetSetCell(dataSetName, count, "Stage", tostring(Stage))
				_EditorService:DataSetSetCell(dataSetName, count, "Type", tostring(Type))
				_EditorService:DataSetSetCell(dataSetName, count, "Index", tostring(Index))
				_EditorService:DataSetSetCell(dataSetName, count, "PosX", tostring(PosX))		
				_EditorService:DataSetSetCell(dataSetName, count, "PosY", tostring(PosY))
				_EditorService:DataSetSetCell(dataSetName, count, "StageName", tostring(Name))
			count = count + 1
			end
			
			
		end
	end

	method void LoadData()
		-- 주방기기 데이터셋에서 데이터를 로드하여 내부 테이블에 저장하는 함수
		
		local dataSet = _DataService:GetTable("KitchenAppDataSet")
		
		for _,row in pairs(dataSet:GetAllRow()) do
		
		
			local data = KitchenAppData()
			data:Load(row:GetItem("Id"))
			
			self.KAppData[data.Id] = data
			
			
		end
	end

	method KitchenAppData GetData(string id)
		-- ID로 주방기기 데이터를 조회하여 반환하는 함수
		if self.KAppData == nil then
			return nil
		end
		
		return self.KAppData[id]
		
	end

	method integer ReturnDisplayNum(Entity player)
		-- 플레이어가 사용 가능한 디스플레이 개수를 계산하여 반환하는 함수
		local displayResearch = player.PlayerUpgrade:ReturnPlayerUpgradeLevelOfType(_UpgradeTypeEnum.DisplayResearch)
		local displayUpgradeCount = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.DisplayCount)
		local displayCount = 0 
		
		if displayResearch > 0 then 
			displayCount = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(_UpgradeTypeEnum.DisplayResearch,displayResearch, player)
		else
			displayCount = displayUpgradeCount
		end
		
		return displayCount
	end

	@ExecSpace("ClientOnly")
	method string ReturnDisplayRUID(string tag, integer themeLv, integer burgerNum)
		-- 디스플레이에 표시할 버거 스프라이트 RUID를 반환하는 함수
		
		if burgerNum ~= 0 then
			local displayLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.DisplaystandLevel)
			local displayMaxCount = _KitchenAppService:GetData(_KitchenAppEnumType.Display..displayLv).EffectValue
			local ratio = burgerNum / displayMaxCount  * 100
			
			if 0 == ratio then
				burgerNum = 0
			elseif 0 < ratio and ratio < 50 then
				burgerNum = 1
			elseif 50 <= ratio and ratio < 75 then
				burgerNum = 2
			elseif 75 <= ratio and ratio < 95 then
				burgerNum = 3
			elseif 95 <= ratio and ratio <= 100 then
				burgerNum = 4
			end
		end
		
		return _DataService:GetTable("DisplaySpritreDataSet"):FindRow("Id",tag..tostring(themeLv)):GetItem("BurgerNum"..tostring(burgerNum))
	end

	@ExecSpace("ClientOnly")
	method string ReturnKitchenAppRUID(string type, boolean isUsed, integer interior)
		-- 주방기기의 사용 상태에 따른 스프라이트 RUID를 반환하는 함수
		
		local themeLv 
		
		if not isvalid(interior) then 
			themeLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.InteriorLevel)
		else
			themeLv = interior 
		end
		
		local grillOnRuid = {_KitchenAppAnimRUID.OnAnimGrill1,_KitchenAppAnimRUID.OnAnimGrill2,_KitchenAppAnimRUID.OnAnimGrill3}
		local grillOffRuid = {_KitchenAppAnimRUID.OffAnimGrill1,_KitchenAppAnimRUID.OffAnimGrill2,_KitchenAppAnimRUID.OffAnimGrill3}
		
		local counterOnRuid = {_KitchenAppAnimRUID.OnCounter1,_KitchenAppAnimRUID.OnCounter2,_KitchenAppAnimRUID.OnCounter3}
		local counterOffRuid = {_KitchenAppAnimRUID.OffCounter1,_KitchenAppAnimRUID.OffCounter2,_KitchenAppAnimRUID.OffCounter3}
		
		
		if type == _KitchenAppEnumType.Grill then 
			if isUsed then 
				return grillOnRuid[themeLv]	
			else
				return grillOffRuid[themeLv]	
			end
		elseif type == _KitchenAppEnumType.Counter then 
			if isUsed then 
				return counterOnRuid[themeLv]	
			else
				return counterOffRuid[themeLv]	
			end
		
		end
	end

	@ExecSpace("Client")
	method void UpdateDisplaySpriteByID(integer targetDisplaySlotID, string tag, integer burgerNum, Entity player, integer expansionLv)
		-- 특정 디스플레이 슬롯의 스프라이트를 업데이트하는 함수
		local themeLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.InteriorLevel) 
			
		local currentMap = _UserService.LocalPlayer.CurrentMap
		local decoGroup = _EntityService:GetEntityByPath(currentMap.Path.."/KitchenApp_Level"..expansionLv)
		if isvalid(decoGroup) then
			local displayEntity = decoGroup:GetChildByName("Deco".._KitchenAppEnumType.Display..targetDisplaySlotID)
			
			displayEntity.SpriteRendererComponent.SpriteRUID = self:ReturnDisplayRUID(tag,themeLv,burgerNum)
		else
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateAllDisplaySprite(Entity player, integer expansionLv, integer themeLv, integer displayCount)
		-- 모든 디스플레이의 스프라이트를 업데이트하는 함수
		local currentMap = _UserService.LocalPlayer.CurrentMap
		local decoGroup = _EntityService:GetEntityByPath(currentMap.Path.."/KitchenApp_Level"..expansionLv)
		
		local recipes = player.PlayerRecipe.Recipes
		local setRecipes = player.PlayerRecipe.SetRecipes
		local menuManger = player.MenuManager
		
		
		local returnSlotAmount = function(slotIdx)
			
			for uniqueID,slotAmountData in pairs(menuManger.DisplayBurger) do
				
				if slotAmountData[slotIdx] > 0 then 
				
					return {uniqueID,slotAmountData[slotIdx]} 
					
				end			
			end
			
			return {nil,0} 
		end
		
		
		
		local burgerNum = 0
		local tag = "None"
		
		for slotIdx = 1, 15 do 
			
			if slotIdx > displayCount then 
				break
			end 
			
			local displayInfo = returnSlotAmount(slotIdx)
			
			if not isvalid(displayInfo[1]) then 
				
				tag = "None"
				burgerNum = 0 
				
			else 
				
				tag = menuManger:ReturnRecipeDataByUniqueID(displayInfo[1]).Tag
				burgerNum = displayInfo[2]
			end
			
			local targetDisplay = decoGroup:GetChildByName("Deco".._KitchenAppEnumType.Display..slotIdx)
			if isvalid(targetDisplay) then
				targetDisplay.SpriteRendererComponent.SpriteRUID = self:ReturnDisplayRUID(tag,themeLv,burgerNum)
			else
			end
		end
	end

	@ExecSpace("Client")
	method void UpdateKitchenAppSpriteByID(integer themeLv, integer expansionLv, string appType, integer appIdx, Entity player)
		-- 특정 주방기기의 스프라이트를 ID로 업데이트하는 함수
		
		local currentMap = _UserService.LocalPlayer.CurrentMap
		local apps = _EntityService:GetEntityByPath(currentMap.Path.."/KitchenApp_Level"..expansionLv)
		local target = apps:GetChildByName("Deco"..appType..appIdx)
		
		local ruid = _KitchenAppService:ReturnKitchenAppRUID(appType,false,themeLv) 
		target.SpriteRendererComponent.SpriteRUID = ruid 
		
		
		self:UpdateKitchenAppPosByID(expansionLv,themeLv,appType,appIdx)
	end

	@ExecSpace("ClientOnly")
	method void UpdateAllKitchenAppSprite(Entity player)
		-- 모든 주방기기의 스프라이트를 업데이트하는 함수
		local grillCount =  _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.GrillCount)
		local counterCount =  _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.CounterCount)
		
		local themeLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.InteriorLevel)
		local expansionLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player,_UpgradeTypeEnum.ExpansionStep)
		local currentMap = player.CurrentMap
		if currentMap == nil then
		end
		
		if currentMap == nil then
		end
		
		
		local appParent = _EntityService:GetEntityByPath(currentMap.Path.."/KitchenApp_Level"..expansionLv)
		if isvalid(appParent) == false then
		end
		local apps = appParent.Children
		
		local grillNum = 0 
		local counterNum = 0
		
		for k,v in pairs(apps) do
			local appType = v.TagComponent.Tags[1]
			local appIdx = tonumber(v.TagComponent.Tags[2])
			
			if  appType == _KitchenAppEnumType.Display then 
		
				continue
		
			elseif appType == _KitchenAppEnumType.Grill then 
		
				if grillCount > grillNum then 
					grillNum = grillNum + 1 
				else 
					continue
				end
		
			elseif appType == _KitchenAppEnumType.Counter then 
		
				if counterCount > counterNum then 
					counterNum = counterNum + 1
				else 
					continue
				end
		
			end
		
			v.SpriteRendererComponent.SpriteRUID = self:ReturnKitchenAppRUID(appType,false,themeLv) 
		
			self:UpdateKitchenAppPosByID(expansionLv,themeLv,appType,appIdx)
		end
	end

	@ExecSpace("Client")
	method void UpdateKitchenAppPosByID(integer expansionLv, integer themeLv, string appType, integer appIdx)
		-- 특정 주방기기의 위치를 ID로 업데이트하는 함수
		local currentMap = _UserService.LocalPlayer.CurrentMap
		local apps = _EntityService:GetEntityByPath(currentMap.Path.."/KitchenApp_Level"..expansionLv)
		local decoKApp = apps:GetChildByName("Deco"..appType..appIdx)
		
		local data = _DataService:GetTable("KitchenAppPosDataSet"):FindRow("StageName",expansionLv.."_"..decoKApp.Name)
		
		decoKApp.TransformComponent.WorldPosition.x = tonumber(data:GetItem("PosX")) + _KitchenAppService.KAppsOffset[appType][themeLv][1]
		decoKApp.TransformComponent.WorldPosition.y = tonumber(data:GetItem("PosY")) + _KitchenAppService.KAppsOffset[appType][themeLv][2]
		decoKApp.TransformComponent.Scale = self.KAppsScale
		
		self:UpdateEmployeeUseKitchenAppPos(decoKApp.TransformComponent.WorldPosition, appType, appIdx)
	end

	@ExecSpace("ClientOnly")
	method void UpdateAllEmployeeUseKitchenAppPos(integer expansionLv)
		-- 모든 직원이 사용할 주방기기 위치를 업데이트하는 함수
		local entityName ="KitchenApp_Level"..expansionLv
		local decoGroup = _UserService.LocalPlayer.CurrentMap:GetChildByName(entityName)
		
		
		for type, dic in pairs(_LobbySpawnPositionLogic.EmployeeUseKitchenAppPosGroup) do
			---@type string
			local appType = type
			for index, pos in pairs(dic) do
				---@type integer
				local appIdx = index
				---@type FastVector3
				local appPos = pos
				
				local decoKApp = decoGroup:GetChildByName("Deco"..appType..appIdx)
				
				if not isvalid(decoKApp) then 
					continue
				end
				
				if appType == _KitchenAppEnumType.Display then
					_LobbySpawnPositionLogic:ResetDisplayOffset(_EmployeeTypeEnum.Cook, appIdx, decoKApp.TransformComponent.WorldPosition + _KitchenAppService.ChuChuCookDisplayOffset)
					_LobbySpawnPositionLogic:ResetDisplayOffset(_EmployeeTypeEnum.Serving, appIdx, decoKApp.TransformComponent.WorldPosition + _KitchenAppService.ChuChuServingDisplayOffset)
				else		
					self:UpdateEmployeeUseKitchenAppPos(decoKApp.TransformComponent.WorldPosition, appType, appIdx)
				end
			end
		end
	end

	@ExecSpace("Client")
	method void VisibleKitAppsEntity(integer expansionLv, integer interiorLv, integer grillCount, integer displayCount, integer counterCount)
		-- 주방기기 엔티티들을 확장 단계에 맞게 생성하고 설정하는 함수
		
		 local lobby = _UserService.LocalPlayer.CurrentMap
		
		for _, entity in pairs(lobby.Children) do
			if _UtilLogic:Contains(entity.Name, "KitchenApp") then
				entity:Destroy()
			end
		end
		
		local entityName = "KitchenApp_Level"..expansionLv
		local modelId = _EntryService:GetModelIdByName(entityName)
		
		local group = lobby:GetChildByName(entityName)
		
		if not isvalid(group) then
			group = _SpawnService:SpawnByModelId(modelId, entityName, Vector3.zero, lobby)
			_LobbyEntityLogic:SetModelAfterSpawn(expansionLv)
			group.Enable = true
		end
		
		
		local hasAppNum = {}
		hasAppNum[_KitchenAppEnumType.Grill] = grillCount
		hasAppNum[_KitchenAppEnumType.Display] = displayCount
		hasAppNum[_KitchenAppEnumType.Counter] = counterCount
			
		local order = {}
		order[_KitchenAppEnumType.Grill] = _SortLayerEnumType.Grill
		order[_KitchenAppEnumType.Display] = _SortLayerEnumType.Display
		order[_KitchenAppEnumType.Counter] = _SortLayerEnumType.Counter
		
		local dataSet = _DataService:GetTable("KitchenAppPosDataSet")
		local themeLv = _UpgradeDataSetLogic:ReturnValueOfTypeLevel(_UpgradeTypeEnum.InteriorLevel, interiorLv, _UserService.LocalPlayer) 
		
		for K,decoKApp in pairs(group.Children) do 
			
			local appType = decoKApp.TagComponent.Tags[1]
			local kitAppIdx = tonumber(decoKApp.TagComponent.Tags[2])
		
			decoKApp.SpriteRendererComponent.OrderInLayer = order[appType] 
			
		
			local data = dataSet:FindRow("StageName",expansionLv.."_"..decoKApp.Name)
		
			if hasAppNum[appType] < kitAppIdx then
				decoKApp.SpriteRendererComponent.SpriteRUID = _IconRuidEnum.KitchenNoneRUID
						
				decoKApp.TransformComponent.WorldPosition.x = tonumber(data:GetItem("PosX")) + self.KAppsNoneOffset[appType][1] 
				decoKApp.TransformComponent.WorldPosition.y = tonumber(data:GetItem("PosY")) + self.KAppsNoneOffset[appType][2] 
		
				continue
			end
		
			decoKApp.SpriteRendererComponent.SpriteRUID = self:ReturnKitchenAppRUID(appType,false,themeLv)
			
			decoKApp.TransformComponent.WorldPosition.x = tonumber(data:GetItem("PosX")) + self.KAppsOffset[appType][themeLv][1]
			decoKApp.TransformComponent.WorldPosition.y = tonumber(data:GetItem("PosY")) + self.KAppsOffset[appType][themeLv][2]
			decoKApp.TransformComponent.Scale = self.KAppsScale
			decoKApp.Enable = true 	
		
		end
		
		self:UpdateAllEmployeeUseKitchenAppPos(expansionLv) 
		self:UpdateAllDisplaySprite(_UserService.LocalPlayer,expansionLv,themeLv,displayCount)
		
			_LobbyRenovationService:UpdateAllInnerWall(expansionLv,interiorLv,displayCount,counterCount, _UserService.LocalPlayer) 
	end

	@ExecSpace("ClientOnly")
	method void KitchenAppProductionByID(integer appIdx, boolean onoff, string appType)
		-- 특정 주방기기의 작동 상태를 변경하는 함수
		local themeLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.InteriorLevel)
		local expansionLv = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(_UserService.LocalPlayer,_UpgradeTypeEnum.ExpansionStep)
		
		local currentMap = _UserService.LocalPlayer.CurrentMap
		local entityPathName1 = currentMap.Path.."/KitchenApp_Level"..expansionLv 
		local entityPathName2 = "Deco"..appType..appIdx 
		local targetEntity = _EntityService:GetEntityByPath(entityPathName1):GetChildByName(entityPathName2)
		if targetEntity == nil then
		end
		
		local ruid = _KitchenAppService:ReturnKitchenAppRUID(appType,onoff,themeLv)
		targetEntity.SpriteRendererComponent.SpriteRUID = ruid 
	end

	@ExecSpace("ClientOnly")
	method void UpdateEmployeeUseKitchenAppPos(Vector3 decoKAppPosition, string appType, integer appIdx)
		-- 직원이 사용할 주방기기 위치를 업데이트하는 함수
		_LobbySpawnPositionLogic:ResetEmployeeUseKitchenAppPosGroup(appType, appIdx, decoKAppPosition + _KitchenAppService.ChuChuUseKitAppOffset[appType])
	end

	@EventSender("Entity", "e148f2ac-5b8e-422c-a7ed-fa738f7fb6fd")
	handler HandleButtonClickEditorEvent(ButtonClickEditorEvent event)
		-- 에디터에서 버튼 클릭 이벤트를 처리하여 데이터셋을 삽입하는 함수
		
		local Entity = event.Entity
		self:InsertKitAppOffsetDataSet()
	end

end