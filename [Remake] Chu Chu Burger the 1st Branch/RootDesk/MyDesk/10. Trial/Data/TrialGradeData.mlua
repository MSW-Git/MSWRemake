@Struct
script TrialGradeData

	property string TrialId = ""

	property integer Grade = 0

	property integer MissionCount = 0

	property table DifficultyData = {}

	method void Load(string trialId, integer grade, table difficultyRows)
		-- Trial 등급 데이터를 로드하고 해당 등급의 모든 난이도 데이터를 초기화하는 함수
		self.TrialId = trialId
		self.Grade = math.floor(grade)
		
		local trialType = _DataService:GetTable("TrialDataSet"):FindRow("Id", self.TrialId):GetItem("Type")
		self.MissionCount = tonumber(_DataService:GetTable("TrialMissionData"):FindRow("Grade", tostring(self.Grade)):GetItem(trialType))
		
		for i = 1, #difficultyRows do
			---@type UserDataRow
			local row = difficultyRows[i]
			
			local difficultyData = TrialDifficultyData()
			difficultyData:Load(self.TrialId, self.Grade, row)
			
			if self.DifficultyData[difficultyData.Difficulty] ~= nil then
				break		
			end
			
			self.DifficultyData[difficultyData.Difficulty] = difficultyData
		end
	end

	method string ReturnGradeBGRUID(integer grade)
		-- 등급에 따른 배경 이미지 RUID를 반환하는 함수
		if grade == 0 then
			return "c32e6b69c62d4e51b0ba6ea7a48eea66"
		elseif grade == 1 then
			return "b02d992e118b41d6a9bce359015eba2e"
		elseif grade == 2 then
			return "53de4f9f6e424163b211a32c0ebbcf93"
		elseif grade == 3 then
			return "767ba5f8bccd46799529577b12ab4d3b"
		end
	end

	method TrialDifficultyData GetDifficultyData(integer difficulty)
		-- 지정된 난이도에 해당하는 TrialDifficultyData 객체를 반환하는 함수
		return self.DifficultyData[difficulty]
	end

	method integer ReturnMaxDifficulty()
		-- 현재 등급에서 사용 가능한 최대 난이도 값을 반환하는 함수
		local maxDifficulty = 0
		for i, _ in pairs(self.DifficultyData) do
			maxDifficulty = math.max(maxDifficulty, i)
		end
		
		return maxDifficulty
	end

end