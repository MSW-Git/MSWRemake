@Struct
script TrialData

	property string Id = ""

	property string IconRUID = ""

	property string Target = ""

	property string TargetStat = ""

	property string Name = ""

	property integer Type = 0

	property integer Layout = 0

	property string Desc = ""

	property string TargetType = ""

	property string WinFeedback = ""

	property string LoseFeedback = ""

	property string IngameDesc = ""

	property table GradeData = {}

	property string ImageRUID = ""

	method void Load(any dataTable, integer index)
		-- CSV 데이터에서 Trial 정보를 로드하여 객체의 속성들을 초기화하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		self.IconRUID = row:GetItem("IconRUID")
		self.Target = row:GetItem("Target")
		self.TargetStat = row:GetItem("TargetStat")
		self.TargetType = row:GetItem("TargetType")
		self.Name = row:GetItem("Name")
		self.Desc = row:GetItem("Desc")
		self.IngameDesc = row:GetItem("IngameDesc")
		
		self.Type = tonumber(row:GetItem("Type"))
		self.Layout = tonumber(row:GetItem("Layout"))
		
		self.WinFeedback = row:GetItem("WinFeedback")
		self.LoseFeedback = row:GetItem("LoseFeedback")
		
		self.ImageRUID = row:GetItem("ImageRUID")
		
		local trialDifficultyData = _DataService:GetTable("TrialDifficultyData")
		local rows = {}
		for i = 1, trialDifficultyData:GetRowCount() do
			local rewardRow = trialDifficultyData:GetRow(i)
			if rewardRow:GetItem("Id") ~= self.Id then
				continue
			end
			
			local grade = tonumber(rewardRow:GetItem("Grade"))
				
			if rows[grade] == nil then
				rows[grade] = {}
			end
			table.insert(rows[grade], rewardRow)
		end
		
		for grade, rowTable in pairs(rows) do
			local gradeData = TrialGradeData()
			gradeData:Load(self.Id, grade, rowTable)
			
			if self.GradeData[grade] ~= nil then
				break
			end
			
			self.GradeData[grade] = gradeData
		end
	end

	method TrialGradeData GetGradeData(integer grade)
		-- 지정된 등급에 해당하는 TrialGradeData 객체를 반환하는 함수
		return self.GradeData[grade]
	end

	method TrialDifficultyData GetMaxDifficultyData()
		-- 최고 등급의 최고 난이도 데이터를 반환하는 함수
		local maxGradeData = self:GetGradeData(#self.GradeData)
		return maxGradeData:GetDifficultyData(#maxGradeData.DifficultyData)
	end

end