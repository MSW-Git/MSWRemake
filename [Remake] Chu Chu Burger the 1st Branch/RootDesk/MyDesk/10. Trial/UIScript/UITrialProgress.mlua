@Component
script UITrialProgress extends Component

	property Entity Grade = nil

	property Entity Difficulty = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- Trial 진행도 UI의 등급과 난이도 엔티티를 초기화하는 클라이언트 전용 함수
		self.Grade = self.Entity:GetChildByName("Grade")
		self.Difficulty = self.Entity:GetChildByName("Difficulty")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer grade, integer difficulty, string trialId)
		-- Trial 진행도 UI를 주어진 등급과 난이도로 새로고침하는 클라이언트 전용 함수
		if self.Grade == nil then
			self:Init()
		end
		
		for i, child in pairs(self.Difficulty.Children) do
			child.Enable = false
		end
		
		local ruid = function(g)
			if g == 0 then
				return "390d2a78f2e740c78203f46391c638dd"
			elseif g == 1 then
				return "3f939fad18d04f5db9a1c54d1221e107"
			elseif g == 2 then
				return "10dafcf41c3c48a69a45c670c0601a9d"
			elseif g == 3 then
				return "7b5153b36e8b4d2795fe6cde0cebcef2"
			end
		end
		self.Grade.SpriteGUIRendererComponent.ImageRUID = ruid(grade)
		
		local outline = function(g)
			if g == 0 then
				return _ColorCodeEnum:GetColor("#545454")
			elseif g == 1 then
				return _ColorCodeEnum:GetColor("#466021")
			elseif g == 2 then
				return _ColorCodeEnum:GetColor("#2B5980")
			elseif g == 3 then
				return _ColorCodeEnum:GetColor("#5A2D69")
			end
		end
		self.Grade.TextComponent.OutlineColor = outline(grade)
		self.Grade.TextComponent.Text = _GetLocalizationTextLogic:GetText("TrialGrade"..grade)
		
		local difficultyRUID = function(g)
			if g == 0 then
				return "001e95c605234f7faea527a597c3d020"
			elseif g == 1 then
				return "30b2ee173d344715a7cc9f0c339c6cbc"
			elseif g == 2 then
				return "f940db3854e141d0924fde1b1b25d31a"
			elseif g == 3 then
				return "48f71b41dd7d4fc38a4fbda4de261603"
			end
		end
		
		local maxDifficulty = _TrialDataSetLogic:GetTrialData(trialId):GetGradeData(grade):ReturnMaxDifficulty()
		for i = 1, maxDifficulty do
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_UITrialDifficulty", i, self.Difficulty)
			entity.SpriteGUIRendererComponent.ImageRUID = "fcfe94dd5e5e49489f1df78219ec6e09"
			local on = entity:GetChildByName("On")
			on.SpriteGUIRendererComponent.ImageRUID = difficultyRUID(grade)
			on.Enable = i <= difficulty	
		end
	end

end