@Component
script UITrialEmployeeDetail extends Component

	property TextComponent Name = nil

	property UIImageAlign Portrait = nil

	property TextComponent LevelText = nil

	property SpriteGUIRendererComponent TypeIcon = nil

	property TextComponent TypeText = nil

	property SpriteGUIRendererComponent ResultImg = nil

	property TextComponent ResultText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI 요소들을 찾아 연결하는 클라이언트 전용 함수
		local portrait = self.Entity:GetChildByName("Portrait")
		self.Portrait = portrait:GetChildByName("UISpriteCardBg").UIImageAlign
		self.Name = portrait:GetChildByName("Name").TextComponent
		
		self.LevelText = self.Entity:GetChildByName("LvText").TextComponent
		self.TypeIcon = self.Entity:GetChildByName("TypeIcon").SpriteGUIRendererComponent
		self.TypeText = self.Entity:GetChildByName("TypeName").TextComponent
		
		local resultGuess = self.Entity:GetChildByName("ResultGuess")
		self.ResultImg = resultGuess:GetChildByName("ResultImg").SpriteGUIRendererComponent
		self.ResultText = resultGuess:GetChildByName("ResultText").TextComponent
	end

	@ExecSpace("ClientOnly")
	method void Refresh(string employeeId, string trialId)
		-- 직원 정보와 Trial 결과 예측을 표시하도록 UI를 새로고침하는 클라이언트 전용 함수
		local player = _UserService.LocalPlayer
		local employeeDetail = player.EmployeeManager:GetEmployeeDetail(employeeId)
		local employeeData = _EmployeeService:GetData(employeeId)
		
		local trialData = _TrialDataSetLogic:GetTrialData(trialId)
		local challengingData = _TrialLogic:GetChallengingTrialData(trialId, _UserService.LocalPlayer, _TrialUILogic.UITrialSelect.UITrialSelect.SelectTab)
		
		local empLevel = _EmployeeService:ReturnChuchuLevel(employeeId, player)
		
		self.Name.Text = _GetLocalizationTextLogic:GetText(employeeData.NameKey)
		
		_EmployeeUIService:DrawPortraitWithEquip(self.Portrait.Entity, self.Portrait.Entity, employeeData)
		self.LevelText.Text = tostring(empLevel)
		
		self.TypeIcon.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(employeeData.Type)
		self.TypeText.Text = _GetLocalizationTextLogic:GetText(employeeData.Type)
		
		if empLevel/challengingData.Requirement < 0.8 then
			self.ResultImg.ImageRUID = "9f0a8fb9c57c4a12bafbe6e8f6493f0a"
			self.ResultText.Text = _GetLocalizationTextLogic:GetText("TrialResultGuessBad")
			self.ResultText.FontColor = _ColorCodeEnum:GetColor("#DE2616")
		elseif empLevel/challengingData.Requirement >= 0.8 and empLevel/challengingData.Requirement < 1 then
			self.ResultImg.ImageRUID = "688d48ca342e45888d52f279679b76ba"
			self.ResultText.Text = _GetLocalizationTextLogic:GetText("TrialResultGuessNormal")
			self.ResultText.FontColor = _ColorCodeEnum:GetColor("#474747")
		else
			self.ResultImg.ImageRUID = "ed2a90c3349a49bb9f83ad13d902175d"
			self.ResultText.Text = _GetLocalizationTextLogic:GetText("TrialResultGuessGood")
			self.ResultText.FontColor = _ColorCodeEnum:GetColor("#355700")
		end
	end

end