@Component
script UITrialCustomer extends Component

	property number duration = 0.8

	property Vector2 defaultPos = Vector2(0,0)

	property Vector2 spawnPos = Vector2(0,-100)

	property Vector2 outPos = Vector2(100,0)

	property integer timer = 0

	property string nextState = ""

	property string currentState = ""

	property Entity Item = nil

	@ExecSpace("ClientOnly")
	method void ChangeAvatarActionState(string stateKey)
		-- Trial 고객 아바타의 액션 상태를 변경하는 클라이언트 전용 함수
		local body = self.Entity.AvatarGUIRendererComponent:GetBodyEntity()
		
		local event = ActionStateChangedEvent(stateKey, stateKey,1, SpriteAnimClipPlayType.Loop)
		body:SendEvent(event)
	end

	@ExecSpace("ClientOnly")
	method void SpawnAndGetIn(Vector2 startPos, Vector2 targetPos)
		-- Trial 고객을 생성하고 지정된 위치로 이동시키는 클라이언트 전용 함수
		if targetPos == nil then
			targetPos = self.defaultPos
		end
		
		if startPos == nil then
			startPos = self.spawnPos
		end
		
		self.Entity.UITransformComponent.anchoredPosition = Vector2(startPos.x, startPos.y)
		self.Entity.CanvasGroupComponent.GroupAlpha = 0
		self.Item.Enable = false
		_TweenLogic:PlayTween(startPos, targetPos, self.duration, EaseType.CubicEaseOut, function(t)
			self.Entity.UITransformComponent.anchoredPosition = Vector2(t.x, t.y)
		end)
		_TweenLogic:PlayTween(0, 1, self.duration, EaseType.QuadEaseOut, function(t)
			self.Entity.CanvasGroupComponent.GroupAlpha = t
		end)
		
		self:ChangeAvatarActionState("walk1")
		self.Entity.Enable = true
		
		self.currentState = "entrance"
		self.nextState = ""
		
		self.timer = _TimerService:SetTimerOnce(function()
			self.currentState = "stand"
			self:ChangeAvatarActionState("stand1")
			
			self.timer = 0
			
			if self.nextState == "buy" then
				self:BuyAndGoOut(_TrialSimpleRenderLogic.PhaseIndex == 2)
			end
		end, self.duration)
	end

	@ExecSpace("ClientOnly")
	method void BuyAndGoOut(boolean isBuy)
		-- Trial 고객이 구매 후 퇴장하는 애니메이션을 처리하는 클라이언트 전용 함수
		if self.currentState ~= "stand" then
			return
		end
		
		self.currentState = "buy"
		if isBuy then
			self.Item.Enable = true
		end
		
		self:ChangeAvatarActionState("walk1")
		_TweenLogic:PlayTween(self.Entity.UITransformComponent.anchoredPosition, self.outPos, self.duration, EaseType.CubicEaseOut, function(t)
			self.Entity.UITransformComponent.anchoredPosition = Vector2(t.x, t.y)
		end)
		_TweenLogic:PlayTween(1, 0, self.duration, EaseType.QuadEaseOut, function(t)
			self.Entity.CanvasGroupComponent.GroupAlpha = t
		end)
		
		self.timer = _TimerService:SetTimerOnce(function()
			self.Entity.Enable = false
			self:ChangeAvatarActionState("stand1")
			
			self.timer = 0
		end, self.duration)
	end

	@ExecSpace("ClientOnly")
	method void RequestBuyState()
		-- Trial 고객에게 구매 상태를 요청하는 클라이언트 전용 함수
		self.nextState = "buy"
		self:BuyAndGoOut(_TrialSimpleRenderLogic.PhaseIndex == 2)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 아이템 엔티티를 찾아 저장하는 클라이언트 전용 함수
		self.Item = self.Entity:GetChildByName("Item")
	end

	@ExecSpace("ClientOnly")
	method void SetItem(string targetTag)
		-- Trial 고객이 들고 있을 아이템을 태그에 따라 설정하는 클라이언트 전용 함수
		if _UtilLogic:IsNilorEmptyString(targetTag) then
			targetTag = _RecipeTagEnum.None
		end
		
		---@type RecipeTagData
		local tagData = _RecipeTagDataSetLogic.RecipeTagData[targetTag]
		local ruid = tagData.PackRUID
		
		self.Item.SpriteGUIRendererComponent.ImageRUID = ruid
	end

end