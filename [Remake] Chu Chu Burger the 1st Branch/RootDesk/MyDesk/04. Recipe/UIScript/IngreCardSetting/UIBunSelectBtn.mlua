@Component
script UIBunSelectBtn extends Component

	property integer Index = 0

	property Entity Outline = nil

	property Entity Icon = nil

	property Entity CountText = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 번 선택 버튼 UI 요소들을 초기화하는 함수
		self.Outline = self.Entity:GetChildByName("Outline")
		self.Icon = self.Entity:GetChildByName("BunIcon")
		self.CountText = self.Entity:GetChildByName("Count")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer index, boolean isSelected)
		-- 번 선택 버튼의 상태와 정보를 새로고침하는 함수
		if self.Outline == nil then
			self:Init()
		end
		
		self.Index = index
		
		---@type BunData
		local bunData = _IngredientDataSetLogic.BunData[index]
		
		self.Entity.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(bunData.Grade)
		
		if isSelected then
			self.Outline.Enable = true
		else
			self.Outline.Enable = false
		end
		
		---@type BunDetailData
		local topBunData = bunData.Top
		self.Icon.SpriteGUIRendererComponent.ImageRUID = topBunData.IconRUID
		
		if bunData.isInfinite then
			self.CountText.TextComponent.Text = "∞"
			self.CountText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#635743")
		else
			local count = _UserService.LocalPlayer.PlayerIngredient.Buns[index]
			if count == nil then
				count = 0
			end
			self.CountText.TextComponent.Text = tostring(count)
			
			if count == 0 then
				self.CountText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#fa5246")
			else
				self.CountText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#635743")
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnSelectFunction()
		-- 번 선택 시 호출되는 함수
		local uiBunList = _UIEntityLogic_RecipeGroup.UIBunListDim.UIBunList
		uiBunList:RefreshDetail(self.Index)
		uiBunList:RefreshList()
		
		_UserService.LocalPlayer.PlayerRecipe:ChangeConnectingStatus(false)
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 번 선택 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerRecipe.IsServerProcessing then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		player.PlayerRecipe:ChangeConnectingStatus(true)
		self:OnSelectFunction()
	end

end