@Component
script UIIngreAutoSetSelectBtn extends Component

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 재료 자동 설정 버튼을 초기화하고 클릭 이벤트를 연결하는 함수
		local tag = self.Entity.Name
		self.Entity.TextComponent.Text = _GetLocalizationTextLogic:GetText("Tag"..tag)
		---@type RecipeTagData
		local tagData = _RecipeTagDataSetLogic.RecipeTagData[tag]
		self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = tagData.IconRUID
		
		self.Entity:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			local player = _UserService.LocalPlayer
			if player.PlayerRecipe.IsServerProcessing then
			    return
			end
			
			local uiIngreCardSetting = _UIEntityLogic_RecipeGroup.UIIngreCardSetting.UIIngreCardSetting
			if uiIngreCardSetting.isAutoCoolTime == true then
				return
			end
				
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			player.PlayerRecipe:ChangeConnectingStatus(true)
			uiIngreCardSetting:AutoSetIngreCard(tag)
			uiIngreCardSetting.AutoSetSelectArea.UIIngreAutoSetSelectArea:Close() 
		end)
	end

end