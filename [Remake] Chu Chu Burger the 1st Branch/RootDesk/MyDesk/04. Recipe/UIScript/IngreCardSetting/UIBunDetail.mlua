@Component
script UIBunDetail extends Component

	property Entity BunIcon = nil

	property Entity Name = nil

	property Entity TasteScoreText = nil

	property Entity PriceText = nil

	property Entity TagIcon = nil

	property Entity TagText = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 번 상세정보 UI 요소들을 초기화하는 함수
		self.BunIcon = self.Entity:GetChildByName("BunIconHolder"):GetChildByName("BunIcon")
		self.Name = self.Entity:GetChildByName("Name")
		
		local infoBar = self.Entity:GetChildByName("InfoBar")
		local BG = infoBar:GetChildByName("BG")
		self.TasteScoreText = BG:GetChildByName("TasteScoreText")
		self.PriceText = BG:GetChildByName("PriceText")
		
		self.TagText = BG:GetChildByName("TypeText")
		self.TagIcon = self.TagText:GetChildByName("TypeIcon")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(integer index)
		-- 번 데이터를 기반으로 상세정보를 새로고침하는 함수
		if self.BunIcon == nil then
			self:Init()
		end
		
		---@type BunData
		local bunData = _IngredientDataSetLogic.BunData[index]
		---@type BunDetailData
		local topBunData = bunData.Top
		
		self.BunIcon.SpriteGUIRendererComponent.ImageRUID = topBunData.IconRUID
		self.BunIcon.Parent.SpriteGUIRendererComponent.ImageRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(bunData.Grade)
		
		self.Name.TextComponent.Text = _GetLocalizationTextLogic:GetText(topBunData.NameKey)
		
		self.TasteScoreText.TextComponent.Text = tostring(topBunData.TastePoint)
		self.PriceText.TextComponent.Text = tostring(topBunData.BaseCost)
		
		if not _UtilLogic:IsNilorEmptyString(bunData.Tag) then
			---@type RecipeTagData
			local tagData = _RecipeTagDataSetLogic.RecipeTagData[bunData.Tag]
			self.TagIcon.SpriteGUIRendererComponent.ImageRUID = tagData.IconRUID
			self.TagText.TextComponent.Text = _GetLocalizationTextLogic:GetText(tagData.TagNameKey)
			self.TagIcon.Enable = true
		else
			self.TagText.TextComponent.Text = "-"
			self.TagIcon.Enable = false
		end
	end

end