@Component
script UIRecipeMaking extends Component

	property table ChoicePairs = {}

	property integer ChoiceIndex = 1

	property Entity ChoiceLBtn = "80fc3864-eed7-4fdb-bb61-b576eafa407b"

	property Entity ChoiceRBtn = "ffa33cde-63f6-4464-8113-47223160ec47"

	property table SelectedIngres = {}

	property Entity BurgerParent = "bb035107-cf57-48ce-aa7d-6eeaa4b1a36b"

	property table lastIngreData = {}

	property number xSize = 300

	property number standardXSize = 300

	property Entity CountText = "8e946987-d0ea-4b5c-9ed9-615a802b380c"

	property number BalancePoint = 0

	property number SpicyPoint = 0

	property Entity BalancePointer = "b8a14e41-0d95-4ea7-8e01-6e71ed1caf25"

	property Entity SpicinessBar = "b5be64de-0a8d-424e-8bef-8fce2a023bef"

	property Entity BalanceZone = "c0ca0367-88c2-46d0-8dc6-8bea69298119"

	property integer balanceCombo = 0

	property Entity ScoreText = "068afad4-12ab-46c5-b0cf-edbf3e1653ed"

	property Entity ScoreGrade = "58aac736-2507-40ed-b546-57f6d96e8b70"

	property number TasteScore = 0

	property Entity ChoiceEntities = "914f4034-d770-4095-a88b-32a6a9dc62a5"

	property Entity ResultEntities = "80cd9c15-db67-4eac-ae65-74fd73c46d1a"

	property boolean isMakingBurger = false

	property Entity EndMakingButton = "a84c9982-868b-4358-ad05-996ba9f4cd94"

	property Entity RerollButton = "85d1bf93-ea3d-45ca-82d8-d16ac0765fee"

	property table Cards = {}

	property integer RerollCount = 0

	property integer starIndex = 1

	property Entity BurgerEntity = "768ed44a-5b87-4f1b-abfb-56630f5526ab"

	property integer MaxCombo = 0

	property string Tag = ""

	property integer rerollCost = 1000

	property number TrialSkillBonus = 0

	property string rerollCostItemType = "G0004"

	property Entity ComboTextImg = "61617944-3ec6-493e-b205-03d67a57d0c0"

	property Entity BurgerRenderParent = "bbaee59c-6f05-4248-9941-01417116b1b6"

	property Entity CompleteEffect = "a3743374-8da2-46cb-862c-bde4e5a38260"

	property Entity HelpBtn = "b0771c20-ea08-4438-8087-accb7ed1b401"

	property UIVIPOrderPreview UIVIPOrderPreview = "b686f23d-5099-463c-b7f0-f049e4d03d12"

	property Entity SideMenuInfo = "94bf0afa-31c0-4332-b37e-f00fe21591af"

	property Entity SideMenuInfoTooltip = "02d6e8ee-205c-4ef8-b7ad-003a75b5069c"

	@ExecSpace("ClientOnly")
	method void Open()
		-- 레시피 만들기 UI를 여는 함수
		if self.Entity.Enable == true then
			return
		end
		
		self.Entity.Enable = true
		
		self.ChoiceEntities.Enable = true
		self.HelpBtn.Enable = true
		self.ResultEntities.Enable = false
		
		self:SetBalanceZone()
		self:RefreshSideMenuInfo()
		
		_UIGroupManager:EnableBackToLobbyBtn(false)
		_UIGroupManager:EnableMoneyBarGroup(false)
		
		self._T.comboIndex = 0
		self._T.isBalanced = false
		
		_UserService.LocalPlayer.PlayerDebugMonitor:UpdateDebugMonitorRecipeMaking("Making")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 레시피 만들기 UI를 닫는 함수
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void RequestEndRecipeMaking()
		-- 레시피 만들기 종료를 요청하는 함수
		local recipeResult = self.ResultEntities.UIRecipeResult
		
		local name = recipeResult.BurgerNameInput.TextComponent.Text	
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Sleep"], 1)
		
		local ingreList = _RecipeIngreDrawEnum:EncodeIngreList(self.SelectedIngres)	
		local tasteScore = recipeResult.FinalTasteScore 				
		local balancePoint = self.BalancePoint 							
		local spicyPoint = self.SpicyPoint 								
		local cost = recipeResult.FinalPrice 							
		local tag = self.Tag											
		local trialSkillBonus = self.TrialSkillBonus					
		local usedSkillList = _UtilLogic:TableToString(recipeResult.UsedSkillList) 
		local employeeId = recipeResult.SelectedEmployeeId 				
		
		local burgerData = {name, ingreList, tasteScore, balancePoint, spicyPoint, cost, tag, trialSkillBonus, usedSkillList, employeeId}
		
		_UserService.LocalPlayer.PlayerRecipe:RequestEndRecipeMaking(self.SelectedIngres, burgerData)
		
		if isvalid(_UserService.LocalPlayer.PlayerDebugMonitor.RecipeInfoMonitor) then
			_UserService.LocalPlayer.PlayerDebugMonitor.RecipeInfoMonitor.Enable = false
		end
		self._T.maxChoiceCount = 0
	end

	@ExecSpace("ClientOnly")
	method void SetChoicePairs(table cards, integer startIndex)
		-- 선택 가능한 재료 쌍들을 설정하는 함수
		
		local player = _UserService.LocalPlayer
		local isTutorial = player.PlayerStage.NowStage == 1 and player.PlayerAchievement:ReturnAchievementProgress(_TutorialAchievementTypeEnum.RecipeMakeCount) < 1
		if isTutorial then
			self.ChoicePairs[1] = {43, 34}
			self.ChoicePairs[2] = {7, 7}
			self.ChoicePairs[3] = {34, 43}	
			return
		end
		
		
		
		local priorityTable = {}
		
		for _, id in pairs(cards) do
			local isContained = false
			
			for _, v in pairs(self.SelectedIngres) do
				---@type RecipeIngreDrawData
				local drawData = v
				
				if drawData.DrawType == _RecipeIngreDrawEnum.Ingredient then
					if drawData.Id == id then
						isContained = true
						break
					end
				end
			end
			
			if isContained == false then
				local dup = false
				for _, p in pairs(priorityTable) do
					if p == id then
						dup = true
						break
					end
				end
				
				if dup == false then 
					table.insert(priorityTable, id)
				end
			end
		end
		
		local nowPair = self.ChoicePairs[startIndex]
		if nowPair ~= nil then 
			local contained = false
			for _, id in pairs(nowPair) do
				for i, pId in pairs(priorityTable) do
					if id == pId then
						contained = true
						break
					end
				end
				
				if contained == false then
					table.insert(priorityTable, id)
				end
			end	
		end
		
		
		
		local finalIndex = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.BurgerStack)
		local leftPairCount = finalIndex - (startIndex-1)
		local leftCardCount = leftPairCount * 2
		
		local isChecked = {}
		local leftCards = {}
		for i, id in pairs(cards) do
			local check = isChecked[id]
			if check == nil then
				check = false
			end
			
			local canInsert = true
			for j, pId in pairs(priorityTable) do
				if id == pId and check == false then
					isChecked[id] = true
					canInsert = false
					break
				end
			end
			
			if canInsert then
				table.insert(leftCards, id)
			end
		end
		
		
		
		local pool = {}
		local priorityCount = #priorityTable
		if priorityCount > leftCardCount then
			priorityCount = leftCardCount
		end
		
		table.sort(priorityTable, function(a, b)
			local aGrade = _IngredientDataSetLogic:GetIngredientData(a).Grade
			local bGrade = _IngredientDataSetLogic:GetIngredientData(b).Grade
			return aGrade > bGrade
		end)
		for i = 1, priorityCount do 
			table.insert(pool, priorityTable[i])
		end
		leftCardCount -= priorityCount
		
		for i = leftCardCount, 1, -1 do 
			local randId = table.remove(leftCards, _UtilLogic:RandomIntegerRange(1, #leftCards))
			table.insert(pool, randId)
		end
		
		
		
		local choiceIndex = 0
		local choicePair = {}
		local choicePairs = {}
		for i = #pool, 1, -1 do
			local randId = table.remove(pool, _UtilLogic:RandomIntegerRange(1, #pool))
			
			table.insert(choicePair, randId)
			choiceIndex += 1
			if choiceIndex >= 2 then
				table.insert(choicePairs, {choicePair[1], choicePair[2]})
				
				choiceIndex = 0
				table.clear(choicePair)
			end
		end
		
		if nowPair ~= nil then
			local isSame = nowPair[1] == choicePairs[1][1] and nowPair[2] == choicePairs[1][2]
			if isSame then
				self:SetChoicePairs(cards, startIndex)
				return
			end
		end
		
		for i = 1, #choicePairs do
			local idx = startIndex + i - 1
			self.ChoicePairs[idx] = choicePairs[i]
		end
	end

	@ExecSpace("ClientOnly")
	method void SetChoiceButtons(integer index)
		-- 선택 버튼들을 설정하는 함수
		local currentPair = self.ChoicePairs[index]
		
		local player = _UserService.LocalPlayer
		local burgerStackLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.BurgerStack)
		
		local maxChoiceCount = math.min(burgerStackLimit, self._T.maxChoiceCount)
		
		if index > maxChoiceCount then
			self:CompleteMakingFunction()
			return
		end
		
		self.ChoiceLBtn.UIRecipeChoiceBtn:Refresh(currentPair[1])
		self.ChoiceRBtn.UIRecipeChoiceBtn:Refresh(currentPair[2])
		
		_UserService.LocalPlayer.PlayerRecipe:ChangeConnectingStatus(false)
	end

	@ExecSpace("ClientOnly")
	method void ChoiceFunction(integer ingreId)
		-- 재료를 선택하는 함수
		local player = _UserService.LocalPlayer
		local burgerStackLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.BurgerStack)
		
		local maxChoiceCount = math.min(burgerStackLimit, self._T.maxChoiceCount)
		if self.ChoiceIndex > maxChoiceCount then
			player.PlayerRecipe:ChangeConnectingStatus(false)
			return
		end
		
		self:SpawnIngredient(ingreId, _RecipeIngreDrawEnum.Ingredient, "")
		_SoundService:PlaySound(_ResourceManager.SFXTable["ThrowWind"], 1)
		
		self.UIVIPOrderPreview:RefreshNowRequirements()
		
		self.ChoiceIndex = self.ChoiceIndex + 1
		self:RefreshCountText()
		self:SetChoiceButtons(self.ChoiceIndex)
		
		_TutorialManager:CheckForceTo()
	end

	@ExecSpace("ClientOnly")
	method void CompleteMakingFunction()
		-- 레시피 만들기를 완료하는 함수
		self.ChoiceLBtn.Enable = false
		self.ChoiceRBtn.Enable = false
		self.EndMakingButton.Enable = false
		self.RerollButton.Enable = false
		self.HelpBtn.Enable = false
		self.SideMenuInfo.Enable = false
		
		self.UIVIPOrderPreview.Entity:SetEnable(false)
		
		_TimerService:SetTimerOnce(function()
			local bunIndex = _UserService.LocalPlayer.PlayerRecipe.SetBun
			self:SpawnIngredient(bunIndex, _RecipeIngreDrawEnum.Bun, "Top")
		end, 0.3)
		
		_TimerService:SetTimerOnce(function()
			self.ResultEntities.UIRecipeResult:Open()
		end, 1)
	end

	@ExecSpace("ClientOnly")
	method void SpawnIngredient(integer ingreId, string drawType, string detailType)
		-- 재료를 생성하고 버거에 추가하는 함수
		local balancePoint = 0
		local spicyPoint = 0
		local tastePoint = 0
		
		if drawType == _RecipeIngreDrawEnum.Ingredient then
			local ingreData = _IngredientDataSetLogic:GetIngredientData(ingreId)
				
			balancePoint = ingreData.BalancePoint
			spicyPoint = ingreData.SpicyPoint
			tastePoint = ingreData:GetTasteScore(_UserService.LocalPlayer.PlayerStage.NowStage, _UserService.LocalPlayer)
			
		else
			local ingreData = _IngredientDataSetLogic:GetBunDetailData(ingreId, detailType)
			
			balancePoint = nil
			spicyPoint = nil
			tastePoint = ingreData.TastePoint
			
		end
		
		local drawData = RecipeIngreDrawData()
		drawData:Init(ingreId, drawType, detailType, false, nil)
		local ingreData = _DrawBurgerUIService:ReturnIngreData(drawData, self.xSize, self.lastIngreData)
		self.lastIngreData = _DrawBurgerUIService:TweenIngredientUI(ingreData, #self.SelectedIngres+1, self.ChoiceIndex, self.BurgerParent)
		
		if isvalid(balancePoint) then
			self.BalancePoint = self.BalancePoint + balancePoint
			self:RefreshBalanceBar()
		end
		
		if isvalid(spicyPoint) then
			self.SpicyPoint = self.SpicyPoint + spicyPoint
			self:RefreshSpicinessBar()
		end
		
		if drawType == _RecipeIngreDrawEnum.Ingredient then
			self:CheckBalanceCombo()
		end
		
		
		self.starIndex = _UIEntityService:MakeStarIconForTasteScore(self.starIndex, tastePoint, self.BurgerParent, self.BurgerRenderParent, _IconRuidEnum.EmptyMaterial)
		if tastePoint > 0 then
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_RecipeIcon"], 1)
		end
		self.TasteScore = self.TasteScore + tastePoint
		
		self:RefreshScoreBar()
		
		table.insert(self.SelectedIngres, drawData)
		
		_UserService.LocalPlayer.PlayerDebugMonitor:UpdateDebugMonitorRecipeMaking("Making")
	end

	@ExecSpace("ClientOnly")
	method void RefreshCountText()
		-- 남은 선택 횟수 텍스트를 새로고침하는 함수
		local player = _UserService.LocalPlayer
		local burgerStackLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.BurgerStack)
		
		local limit = math.min(burgerStackLimit, self._T.maxChoiceCount)
		
		local leftCount = limit - self.ChoiceIndex + 1
		
		self.CountText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Things_Format", leftCount)
	end

	@ExecSpace("ClientOnly")
	method void RefreshBalanceBar()
		-- 밸런스 바를 새로고침하는 함수
		local balanceBarLength = self.BalancePointer.Parent.UITransformComponent.RectSize.x
		local balanceBarMax = 50
		
		local lastPos = self.BalancePointer.UITransformComponent.anchoredPosition
		local newPosX = balanceBarLength/2 * self.BalancePoint / balanceBarMax
		if newPosX >= balanceBarLength/2 then
			newPosX = balanceBarLength/2
		end
		if newPosX <= -balanceBarLength/2 then
			newPosX = -balanceBarLength/2
		end
		local tween = _TweenLogic:PlayTween(lastPos, Vector2(newPosX, lastPos.y), 0.3, EaseType.CubicEaseOut, function(t)
			self.BalancePointer.UITransformComponent.anchoredPosition = t
		end)
		
		_TimerService:SetTimerOnce(function()	
			if self.BalancePoint >= -_IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer) and self.BalancePoint <= _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer) then
				self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "3a178133919e4171a09ce815f6a58a6a"
			else
				self.BalancePointer.SpriteGUIRendererComponent.ImageRUID = "e7d7ef61793f426097204ceec35045b1"
			end
		end, 0.1)
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshSpicinessBar()
		-- 매운맛 바를 새로고침하는 함수
		local spicyIcon = self.SpicinessBar:GetChildByName("SpicyIcon")
		spicyIcon.Enable = true
		local fillImage = self.SpicinessBar:GetChildByName("FillImage")
		if self.SpicyPoint >= _IngredientDataSetLogic:GetSpicyThreshold(_UserService.LocalPlayer) then
			self.SpicyPoint = _IngredientDataSetLogic:GetSpicyThreshold(_UserService.LocalPlayer)
			spicyIcon.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
			spicyIcon.TextComponent.FontColor = Color.white
			spicyIcon.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#8c0101")
			
		else
			spicyIcon.SpriteGUIRendererComponent:ChangeMaterial(_StringUtilLogic.GrayScaleMaterial)
			spicyIcon.TextComponent.FontColor = _ColorCodeEnum:GetColor("#dfdfdf")
			spicyIcon.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#424242")
			
		end
		
		local lastValue = fillImage.SpriteGUIRendererComponent.FillAmount
		local newValue = self.SpicyPoint / _IngredientDataSetLogic:GetSpicyThreshold(_UserService.LocalPlayer)
		local tween = _TweenLogic:PlayTween(lastValue, newValue, 0.3, EaseType.CubicEaseOut, function(t)
			fillImage.SpriteGUIRendererComponent.FillAmount = t
		end)
		
	end

	@ExecSpace("ClientOnly")
	method boolean CheckBalanceCombo()
		-- 밸런스 콤보를 확인하고 처리하는 함수
		
		if math.abs(self.BalancePoint) <= _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer) then
			if isvalid(self._T.balanceTimer) then
				_TimerService:ClearTimer(self._T.balanceTimer)
			end
			
			self.balanceCombo = self.balanceCombo + 1
			self.ComboTextImg.Enable = true
			self.ComboTextImg.UITweenScale:Play()
				
			local combo10 = math.floor(self.balanceCombo/10)
			local combo1 = self.balanceCombo%10
			
			local combo10Entity = self.ComboTextImg:GetChildByName("10")
			if combo10 < 1 then
				combo10Entity.Enable = false
			else
				combo10Entity.Enable = true
				combo10Entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum:GetComboCountRUID(combo10)		
				combo10Entity.UITweenScale:Play()
			end
			
			local combo1Entity = self.ComboTextImg:GetChildByName("1")
			combo1Entity.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum:GetComboCountRUID(combo1)
			combo1Entity.UITweenScale:Play()
			
			self._T.balanceTimer = _TimerService:SetTimerOnce(function()
				self.ComboTextImg.UITweenScale:Stop()
				combo10Entity.UITweenScale:Stop()
				combo1Entity.UITweenScale:Stop()
			end, self.ComboTextImg.UITweenScale.duration*2)
			
			
			
			self.MaxCombo = math.max(self.balanceCombo, self.MaxCombo)
			
			return true
		else
			self.balanceCombo = 0
			self.ComboTextImg.Enable = false
			
			return false
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshScoreBar()
		-- 점수 바를 새로고침하는 함수
		self.ScoreText.TextComponent.Text = tostring(math.floor(self.TasteScore))
		
		local gradeData = _TasteGradeDataSetLogic:ReturnGradeDataByScore(self.TasteScore)
		self.ScoreGrade.SpriteGUIRendererComponent.ImageRUID = gradeData.RUID
	end

	@ExecSpace("ClientOnly")
	method void RerollChoicePairs()
		-- 선택지 쌍들을 다시 뒤섭는 함수
		local player = _UserService.LocalPlayer
		local rerollLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.RecipeRerollCount)
		
		if rerollLimit == 0 then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("RecipeMakingRerollErrorMessage2"))
			player.PlayerRecipe:ChangeConnectingStatus(false)
			return
		end
		
		local rerollMax = _UpgradeDataSetLogic:GetData(_UpgradeTypeEnum.RecipeRerollCount):GetMaxLevel(player)
		if self.RerollCount >= rerollLimit then
			
			if rerollLimit == rerollMax then
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("RecipeMakingRerollErrorMessage3"))
			else
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("RecipeMakingRerollErrorMessage4"))
			end
			
			player.PlayerRecipe:ChangeConnectingStatus(false)
			return
		end
		
		local cost = _RecipeDataSetLogic:ReturnRerollCost(self.RerollCount)
		
		if player.PlayerInventory.ArcaneSymbol < cost then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("NoArcaneSymbolToastMsg"))
			player.PlayerRecipe:ChangeConnectingStatus(false)
			return
		end
		
		if cost > 0 then
			player.PlayerInventory:ModifyArcaneSymbol(-cost,"Reroll in make recipe play","Make recipe popup")
			local costText = _StringUtilLogic:ReturnThousandsSeparatedString(cost)
			_UIToast:ShowMessage(_LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("UseArcaneSymbolToast", costText))
		end
		
		local choicedIngres = {} 
		for k, v in pairs(self.SelectedIngres) do
			---@type RecipeIngreDrawData
			local drawData = v
			
			if drawData.DrawType == _RecipeIngreDrawEnum.Ingredient then
				if isvalid(choicedIngres[drawData.Id]) == false then
					choicedIngres[drawData.Id] = 0			
				end
				
				choicedIngres[drawData.Id] += 1
			end
		end
		
		local leftCards = {}
		for i = 1, #self.Cards do
			local ingreId = self.Cards[i]
			local isContained = false
			
			for k, v in pairs(choicedIngres) do
				if k == ingreId then
					choicedIngres[k] -= 1
					if choicedIngres[k] == 0 then
						choicedIngres[k] = nil
		
					end
					isContained = true
					break
				end		
			end
			
			if isContained == false then
				table.insert(leftCards, ingreId)
			end
			
		end
		
		self.RerollCount = self.RerollCount + 1
		self:RefreshRerollButton()
		_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_Reroll"], 1)
		
		self:SetChoicePairs(leftCards, self.ChoiceIndex)
		self:SetChoiceButtons(self.ChoiceIndex)
	end

	@ExecSpace("ClientOnly")
	method void StartRecipeMaking(table cards)
		-- 레시피 만들기를 시작하는 함수
		table.clear(self.Cards)
		table.clear(self.ChoicePairs)
		
		self.Cards = cards
		
		self._T.maxChoiceCount = math.floor(#cards / 2)
		
		self:SetChoicePairs(cards, 1)
		
		self.ChoiceIndex = 1
		self:RefreshCountText()
		self.lastIngreData = {0, "", 0, 0, 0, 0, 0, 0}
		
		self.BalancePoint = _StrategyEnum:GetSideMenuEffect(_UserService.LocalPlayer.PlayerIngameManager.StageSideMenu, _StrategyEnum.SideMenu_StartBalance, nil)
		self.SpicyPoint = 0
		self:RefreshBalanceBar()
		self:RefreshSpicinessBar()
		self.TasteScore = 0
		self.starIndex = 1
		
		self.balanceCombo = 0
		self.MaxCombo = 0
		self.ComboTextImg.Enable = false
		table.clear(self.SelectedIngres)
		
		self.RerollCount = 0
		self:RefreshRerollButton()
		
		self.TrialSkillBonus = 0
		
		
		local bunIndex = _UserService.LocalPlayer.PlayerRecipe.SetBun
		self:SpawnIngredient(bunIndex, _RecipeIngreDrawEnum.Bun, "Bottom")
		self:SetChoiceButtons(self.ChoiceIndex)
		self.EndMakingButton.Enable = true
		self.RerollButton.Enable = true
		
		if _VIPOrderDataSetLogic.UIVIPOrderPreviewNowSlot == nil or _VIPOrderDataSetLogic.UIVIPOrderPreviewNowSlot == 0 then
			self.UIVIPOrderPreview.Entity:SetEnable(false)
		else
			self.UIVIPOrderPreview:Refresh(nil)
		end
		
		_BGMService:ApplyBGM(_BGMService.RecipeMakingBGM)
		_FadeService:HideFade()
		
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.StartRecipeMaking)
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshRerollButton()
		-- 리롤 버튼을 새로고침하는 함수
		local player = _UserService.LocalPlayer
		local rerollLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.RecipeRerollCount)
		
		local leftCountText = self.RerollButton:GetChildByName("LeftCountText")
		local text = leftCountText:GetChildByName("Text")
		local costIcon = text:GetChildByName("Icon")
		
		local dim = self.RerollButton:GetChildByName("Dim")
		local lockIcon = dim:GetChildByName("LockIcon")
		
		if rerollLimit == 0 then
			dim.Enable = true
			lockIcon.Enable = true
			leftCountText.Enable = false
		
		else
			if self.RerollCount >= rerollLimit then
				dim.Enable = true
				leftCountText.Enable = false
				lockIcon.Enable = false
				return
			end
			
			dim.Enable = false
			leftCountText.Enable = true
			
			if self.RerollCount < 1 then
				text.TextComponent.FontColor = _ColorCodeEnum:GetColor("#72634b")
				text.TextComponent.Text = _GetLocalizationTextLogic:GetText("RecipeMakingRerollFreeText")
				text.UITransformComponent.anchoredPosition = Vector2(0, text.UITransformComponent.anchoredPosition.y)
				costIcon.Enable = false
			else
				local cost = _RecipeDataSetLogic:ReturnRerollCost(self.RerollCount)
				
				text.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Things_Format", _StringUtilLogic:ReturnThousandsSeparatedString(cost))
				text.UITransformComponent.anchoredPosition = Vector2(costIcon.UITransformComponent.RectSize.x/2, text.UITransformComponent.anchoredPosition.y)
				costIcon.Enable = true
				costIcon.SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData(self.rerollCostItemType).IconRUID
				
				if player.PlayerInventory.ArcaneSymbol < cost then
					text.TextComponent.FontColor = _ColorCodeEnum:GetColor(_ColorCodeEnum.RedFont)
				else
					text.TextComponent.FontColor = _ColorCodeEnum:GetColor("#72634b")
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetBalanceZone()
		-- 밸런스 영역을 설정하는 함수
		local rectSizeX = self.BalanceZone.Parent.UITransformComponent.RectSize.x * _IngredientDataSetLogic:GetBalanceThreshold(_UserService.LocalPlayer) / 50
		self.BalanceZone.UITransformComponent.RectSize.x = rectSizeX
		
		local leftEntity = self.BalanceZone.Parent:GetChildByName("Left")
		local leftLastPos = leftEntity.UITransformComponent.anchoredPosition
		leftEntity.UITransformComponent.anchoredPosition = Vector2(-rectSizeX/2, leftLastPos.y)
		
		local rightEntity = self.BalanceZone.Parent:GetChildByName("Right")
		local rightLastPos = rightEntity.UITransformComponent.anchoredPosition
		rightEntity.UITransformComponent.anchoredPosition = Vector2(rectSizeX/2, rightLastPos.y)
	end

	method void RefreshSideMenuInfo()
		-- 사이드 메뉴 정보를 새로고침하는 함수
		self.SideMenuInfoTooltip.Enable = false
		
		local sideMenuData = _StrategyDataSetLogic:GetSideMenuData(_UserService.LocalPlayer.PlayerIngameManager.StageSideMenu)
		if sideMenuData == nil then
			self.SideMenuInfo.Enable = false
			return
		end
		
		self.SideMenuInfo.Enable = true
		local iconEntity = self.SideMenuInfo:GetChildByName("Dish"):GetChildByName("Icon")
		iconEntity.SpriteGUIRendererComponent.ImageRUID = sideMenuData.IconRUID
		_StrategyDataSetLogic:SetSideMenuIconPos(iconEntity, sideMenuData.Id)
		self.SideMenuInfoTooltip.TextComponent.Text = _StrategyDataSetLogic:GetSideMenuDescText(sideMenuData.Id)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a84c9982-868b-4358-ad05-996ba9f4cd94")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 레시피 만들기 종료 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerRecipe.IsServerProcessing then
			return
		end
		
		local isTutorial = player.PlayerAchievement:ReturnAchievementProgress(_TutorialAchievementTypeEnum.RecipeMakeCount) <= 0
		if isTutorial then
			return
		end
		
		local onOk = function()
			player.PlayerRecipe:ChangeConnectingStatus(true)
			self:CompleteMakingFunction()
		end
		
		local choiceIndex = self.ChoiceIndex-1
		local burgerStackLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.BurgerStack)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_RecipeComplete"], 1)
		_UIPopup:Open(_LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RecipeMakingForceEndPopupMessage", choiceIndex, burgerStackLimit), 
			onOk, function() end, _GetLocalizationTextLogic:GetText("RecipeMakingForceEndPopupTitle"))
	end

	@EventSender("Entity", "199258c1-32ec-43c4-ac0e-5ca78abd42b6")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 레시피 만들기 완료 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerRecipe.IsServerProcessing then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_RecipeComplete"], 1)
		player.PlayerRecipe:ChangeConnectingStatus(true)
		self:RequestEndRecipeMaking()
	end

	@EventSender("Entity", "85d1bf93-ea3d-45ca-82d8-d16ac0765fee")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 리롤 버튼 클릭 이벤트를 처리하는 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		local player = _UserService.LocalPlayer
		if player.PlayerRecipe.IsServerProcessing then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		player.PlayerRecipe:ChangeConnectingStatus(true)
		self:RerollChoicePairs()
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerArcaneSymbolChangedEvent(PlayerArcaneSymbolChangedEvent event)
		-- 플레이어의 아카네 심볼 변경 이벤트를 처리하는 핸들러
		local Current = event.Current
		local Amount = event.Amount
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:RefreshRerollButton()
	end

	@EventSender("Entity", "94bf0afa-31c0-4332-b37e-f00fe21591af")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 사이드 메뉴 정보 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_TooltipService:OpenTooltip(self.SideMenuInfoTooltip, nil)
	end

end