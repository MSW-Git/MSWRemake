@Component
script UITrendInfoBar extends Component

	@ExecSpace("ClientOnly")
	method void Refresh(boolean isRecipeList)
		-- 트렌드 정보 바를 새로고침하는 함수
		local player = _UserService.LocalPlayer
		
		local positiveInfo = self.Entity.Children[1]
		local negativeInfo = self.Entity.Children[2]
		
		local positiveId = nil
		local negativeId = nil
		for k, v in pairs(player.PlayerRecipe.NowTrend) do
			---@type TrendData
			local trendData = _RecipeDataSetLogic.TrendData[k]
			if trendData == nil then
				continue
			end
			
			if trendData.Type == "Positive" then
				positiveId = k
			elseif trendData.Type == "Negative" then
				negativeId = k
			end
		end
		
		if isRecipeList then
			positiveInfo.UITrendInfo:RefreshForRecipeList(positiveId)
			negativeInfo.UITrendInfo:RefreshForRecipeList(negativeId)
		else
			positiveInfo.UITrendInfo:Refresh(positiveId)
			negativeInfo.UITrendInfo:Refresh(negativeId)
		end
	end

end