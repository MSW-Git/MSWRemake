@Component
script UIIngreDishIcon extends Component

	property SpriteGUIRendererComponentRef IconSprite = nil

	property Entity Desc = nil

	property boolean isShowDesc = false

	property Entity Check = nil

	@ExecSpace("ClientOnly")
	method void SetItem(table ingreTable, boolean isEmphasized)
		-- 재료 아이템 정보를 설정하는 함수
		local ingreId = ingreTable[1]
		local isBun = ingreTable[2]
		local bunType = ingreTable[3]
		
		local dishRUID
		local iconRUID
		local desc
		if isBun then
			---@type BunData
			local ingreData = _IngredientDataSetLogic.BunData[ingreId]
			if ingreData == nil then
				return
			end
			
			---@type BunDetailData
			local bunDetailData = ingreData[bunType]
			
			dishRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(ingreData.Grade)
			iconRUID = bunDetailData.IconRUID
			desc = _GetLocalizationTextLogic:GetText(bunDetailData.NameKey)
		else
			local ingreData = _IngredientDataSetLogic:GetIngredientData(ingreId)
			if ingreData == nil then
				return
			end
			
			dishRUID = _IngredientDataSetLogic:ReturnDishRUIDByGrade(ingreData.Grade)
			iconRUID = ingreData.IconRUID
			desc = _GetLocalizationTextLogic:GetText(ingreData.NameKey)
		end
		
		if self.IconSprite ~= nil then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = dishRUID
			self.IconSprite.ImageRUID = iconRUID
		end
		
		if isEmphasized then
			self.Check.Enable = true
		else
		    self.Check.Enable = false
		end
		
		self.Desc.TextComponent.Text = desc
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 요소들을 초기화하는 함수
		local iconSpriteEntity = self.Entity:GetChildByName("Icon")
		if iconSpriteEntity ~= nil then
			self.IconSprite = iconSpriteEntity.SpriteGUIRendererComponent
		end
		
		self.Desc = self.Entity:GetChildByName("UISpriteDesc")
		self.Desc.Enable = false
		
		self.Check = self.Entity:GetChildByName("Check")
		
		self.Entity:ConnectEvent(ButtonClickEvent, self.OnClickItem)
	end

	method void OnClickItem()
		-- 아이템 클릭 시 호출되는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if self.isShowDesc == false then
			return
		end
		
		_TooltipService:OpenTooltip(self.Desc, nil)
	end

end