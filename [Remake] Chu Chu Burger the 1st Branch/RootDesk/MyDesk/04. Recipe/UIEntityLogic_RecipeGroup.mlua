@Logic
script UIEntityLogic_RecipeGroup extends Logic

	property Entity UIRecipeBook = "518cd46f-6396-490b-a0d6-fa20daa1be5f"

	property Entity UIRecipeMaking = "927e3468-be6d-48fc-9366-8e578c5f2d1f"

	property Entity UIIngreCardSetting = "216bf70c-1f5f-481d-97a2-47af6c67065e"

	property Entity UIBunListDim = "ac978724-2c27-459c-ab38-551142325a26"

	property Entity UIIngreGachaDim = "af8d6377-b8f0-46a1-958f-c22cf7e1c31d"

	property string BonusMaterial = "material://f5d55bbb-e340-45a7-b72e-8e4032520566"

	property Entity UIRecipeComboInfoDim = "52481073-b15e-4e6e-a0f9-e720e777a024"

	property Entity UIRecipeList = "46fd51f4-3765-4616-9775-60742e651c85"

	property string NowPlayFlow = ""

	@ExecSpace("ClientOnly")
	method void InitializeRecipeUI()
		-- 레시피 UI를 초기화하고 레시피북을 열어주는 함수
		
		self.UIRecipeBook.UIRecipeBook:Close(false, true)
		self.UIRecipeBook.UIRecipeBook:Open() 
		self.UIRecipeMaking.UIRecipeMaking:Close()
		self.UIRecipeComboInfoDim.UIRecipeComboInfo:Close()
		self.UIIngreCardSetting.UIIngreCardSetting:Close(false)
		self.UIBunListDim.UIBunList:Close()
		self.UIIngreGachaDim.UIIngreGacha:Close()
		
		self.NowPlayFlow = "RecipeBook"
	end

end