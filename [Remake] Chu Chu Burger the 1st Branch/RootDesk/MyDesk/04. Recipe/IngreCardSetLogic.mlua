@Logic
script IngreCardSetLogic extends Logic

	property SyncTable<integer, integer> SelectedIngreCards

	property table SelectedIngreList = {}

	@ExecSpace("Client")
	method void SetIngreCard(integer ingreId, boolean refreshBalance)
		-- 재료 카드를 선택 목록에 추가하는 함수
		if _IngredientDataSetLogic:GetIngredientData(ingreId) == nil then
			return
		end
		
		local player = _UserService.LocalPlayer
		local burgerStackLimit = _UpgradeDataSetLogic:ReturnCurrentPlayerValue(player, _UpgradeTypeEnum.BurgerStack)
		local maxCount = burgerStackLimit*2
		local currentCount = self:GetCurrentSelectedTotalCount()
		if currentCount >= maxCount then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("IngreCardSetErrorMessage1"))
			return
		end
		
		local userIngreCount = player.PlayerIngredient.IngredientCards[ingreId]
		local nowCount = self.SelectedIngreCards[ingreId]
		if nowCount == nil then
			nowCount = 0
		end
		local nextCount = nowCount + 1
		if userIngreCount < nextCount then
			return
		end
		
		self.SelectedIngreCards[ingreId] = nextCount
		table.insert(self.SelectedIngreList, ingreId)
		
		local e = ChangedSelectedIngreCardsEvent()
		e:Init(ingreId, refreshBalance)
		player:SendEvent(e)
	end

	@ExecSpace("Client")
	method void UnsetIngreCard(integer ingreId, boolean refreshBalance)
		-- 재료 카드를 선택 목록에서 제거하는 함수
		if _IngredientDataSetLogic:GetIngredientData(ingreId) == nil then
			return
		end
		
		if self.SelectedIngreCards[ingreId] == nil then
			return
		end
		
		if self.SelectedIngreCards[ingreId] == 0 then
			return
		end
		
		self.SelectedIngreCards[ingreId] = self.SelectedIngreCards[ingreId] - 1
		if self.SelectedIngreCards[ingreId] == 0 then
			self.SelectedIngreCards[ingreId] = nil
		end
		
		table.remove(self.SelectedIngreList, self:GetIndexById(self.SelectedIngreList, ingreId))
		
		local player = _UserService.LocalPlayer
		local e = ChangedSelectedIngreCardsEvent()
		e:Init(ingreId, refreshBalance)
		player:SendEvent(e)
	end

	@ExecSpace("Client")
	method integer GetCurrentSelectedTotalCount()
		-- 현재 선택된 재료 카드의 총 개수를 반환하는 함수
		local count = 0
		for id, cnt in pairs(self.SelectedIngreCards) do
			count += cnt
		end
		
		return count
	end

	@ExecSpace("Client")
	method void UnsetIngreCardAll(boolean refreshBalance)
		-- 선택된 모든 재료 카드를 초기화하는 함수
		table.clear(self.SelectedIngreCards)
		table.clear(self.SelectedIngreList)
		
		local player = _UserService.LocalPlayer
		local e = ChangedSelectedIngreCardsEvent()
		e:Init(-1, refreshBalance)
		player:SendEvent(e)
	end

	method integer GetIndexById(table tb, integer id)
		-- 테이블에서 특정 ID의 인덱스를 찾는 함수
		for i, k in pairs(tb) do
			if k == id then
				return i
			end
		end
		
		return nil
	end

end