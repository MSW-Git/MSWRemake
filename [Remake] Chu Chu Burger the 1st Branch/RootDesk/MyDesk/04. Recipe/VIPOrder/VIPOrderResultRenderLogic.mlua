@Logic
script VIPOrderResultRenderLogic extends Logic

	property Entity ScoreEntityParent = "d52f49d3-678a-4bbf-94c6-f74d3b96708f"

	@ExecSpace("Client")
	method void DropSeasonScores(Entity startEntity, integer score)
		-- 시즌 점수를 시각적으로 드롭하는 애니메이션을 실행
		local player = _UserService.LocalPlayer
		
		if startEntity == nil or score == nil or score == 0 then
			return
		end
		
		
		local scorePerCount = 10 
		local entityCount = math.floor(score/scorePerCount)
		
		local slotWorldPos = startEntity.UITransformComponent.WorldPosition
		local moveTargetWorldPos = _VIPOrderDataSetLogic.UIVIPOrderPanel.SeasonInfo.ScoreIcon.UITransformComponent.WorldPosition
		
		local dropDuration = 0.55
		local moveDelay = 0.15
		local moveDuration = 0.55
		for i = 1, entityCount do
			self._T.entityId = self._T.entityId + 1
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_VIPOrderSeasonScore", self._T.entityId, self.ScoreEntityParent)
			table.insert(self._T.scoreEntities, entity)
			
			entity.UITransformComponent.WorldPosition = Vector3(slotWorldPos.x, slotWorldPos.y+50, slotWorldPos.z)
			
			local targetPosX = entity.UITransformComponent.WorldPosition.x + _UtilLogic:RandomIntegerRange(-70, 70)
			local targetPosY = entity.UITransformComponent.WorldPosition.y - 100 + _UtilLogic:RandomIntegerRange(-200, 200)/10
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_VipOrderPointDrop"], 1)
			entity.UITweenPop:StartPop(Vector3(targetPosX, targetPosY, slotWorldPos.z), dropDuration, true, moveDelay, moveTargetWorldPos, moveDuration)
		end
		
		self._T.timer = _TimerService:SetTimerOnce(function()
			_VIPOrderDataSetLogic.UIVIPOrderPanel.SeasonInfo:TweenRewardSlider()
		end, (dropDuration+moveDelay+moveDuration)*0.8)
	end

	@ExecSpace("ClientOnly")
	method void ClearScoreEntities()
		-- 생성된 모든 점수 엔티티들을 제거하고 카운터 초기화
		for i, entity in pairs(self._T.scoreEntities) do
			_EntityService:Destroy(entity)
		end
		
		self._T.entityId = 0
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 점수 렌더링 로직 초기화
		self._T.scoreEntities = {}
		self._T.timer = {}
		self._T.entityId = 0
	end

	@ExecSpace("Client")
	method void RequestStartPopAfterWaiting(integer slotIndex, integer score)
		-- 대기 후 점수 팝업을 시작하도록 요청
		_VIPOrderDataSetLogic.UIVIPOrderPanel.SeasonInfo:SetNotToRefreshSlider(true)
		_VIPOrderDataSetLogic.UIVIPOrderPanel.VIPOrderSlot[slotIndex].UIVIPOrderSlot:PopAfterWait(score)
	end

	@ExecSpace("Client")
	method void RequestStartExtraRewardAfterWaiting(integer gap)
		-- 대기 후 추가 보상을 시작하도록 요청
		self._T.extraRewardGap = gap
	end

	@ExecSpace("Client")
	method void RequestOpenExtraReward()
		-- 저장된 추가 보상이 있으면 팝업을 열어서 표시
		if self._T.extraRewardGap == nil then
			return
		end
		
		if self._T.extraRewardGap == 0 then
			return
		end
		
		_VIPOrderDataSetLogic.UIVIPOrderScoreExtraReward:Open(self._T.extraRewardGap)
		self._T.extraRewardGap = 0
	end

end