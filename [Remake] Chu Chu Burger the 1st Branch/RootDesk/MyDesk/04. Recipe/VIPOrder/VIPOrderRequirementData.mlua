@Struct
script VIPOrderRequirementData

	property integer ManagementLevel = 0

	property integer BurgerStack = 0

	property table RecipeTasteGrade = {}

	property table RecipeTag = {}

	property table RecipeSameTagIngreGrade = {}

	property table RecipeDiffTagIngreGrade = {}

	property integer DiffTagIngreCount = 0

	property table IngreGrade1Count = {}

	property table IngreGrade2Count = {}

	property table IngreGrade3Count = {}

	method void Load(any dataTable, integer index)
		-- CSV 데이터에서 VIP 주문 요구사항 정보를 로드하고 파싱
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.ManagementLevel = tonumber(row:GetItem("ManagementLevel"))
		self.BurgerStack = tonumber(row:GetItem("BurgerStack"))
		self.DiffTagIngreCount = tonumber(row:GetItem("DiffTagIngreCount"))
		
		local recipeTasteGrade = _UtilLogic:Split(row:GetItem("RecipeTasteGrade"), ",")
		for _, tasteGrade in pairs(recipeTasteGrade) do
			table.insert(self.RecipeTasteGrade, tonumber(tasteGrade))
		end
		
		local recipeTag = _UtilLogic:Split(row:GetItem("RecipeTag"), ",")
		for _, tag in pairs(recipeTag) do
			table.insert(self.RecipeTag, tag)
		end
		
		local recipeSameTagIngre = _UtilLogic:Split(row:GetItem("RecipeSameTagIngreGrade"), ",")
		for _, grade in pairs(recipeSameTagIngre) do
			table.insert(self.RecipeSameTagIngreGrade, tonumber(grade))
		end
		
		local recipeDiffTagIngre = _UtilLogic:Split(row:GetItem("RecipeDiffTagIngreGrade"), ",")
		for _, grade in pairs(recipeDiffTagIngre) do
			table.insert(self.RecipeDiffTagIngreGrade, tonumber(grade))
		end
		
		local ingreGrade1MinMax = row:GetItem("IngreGrade1MinMax")
		if _UtilLogic:IsNilorEmptyString(ingreGrade1MinMax) == false then
			local minmaxTable = _UtilLogic:Split(ingreGrade1MinMax, ",")
			local min = tonumber(minmaxTable[1])
			local max = tonumber(minmaxTable[2])
			for i = min, max do
				table.insert(self.IngreGrade1Count, i)
			end
		end
		
		local ingreGrade2MinMax = row:GetItem("IngreGrade2MinMax")
		if _UtilLogic:IsNilorEmptyString(ingreGrade2MinMax) == false then
			local minmaxTable = _UtilLogic:Split(ingreGrade2MinMax, ",")
			local min = tonumber(minmaxTable[1])
			local max = tonumber(minmaxTable[2])
			for i = min, max do
				table.insert(self.IngreGrade2Count, i)
			end
		end
		
		local ingreGrade3MinMax = row:GetItem("IngreGrade3MinMax")
		if _UtilLogic:IsNilorEmptyString(ingreGrade3MinMax) == false then
			local minmaxTable = _UtilLogic:Split(ingreGrade3MinMax, ",")
			local min = tonumber(minmaxTable[1])
			local max = tonumber(minmaxTable[2])
			for i = min, max do
				table.insert(self.IngreGrade3Count, i)
			end
		end
	end

	method integer ReturnRandomIngreGrade()
		-- 사용 가능한 재료 등급 중에서 랜덤하게 하나를 선택하여 반환
		
		local gradePool = {}
		if #self.IngreGrade1Count > 0 then
			table.insert(gradePool, 1)
		end
		
		if #self.IngreGrade2Count > 0 then
			table.insert(gradePool, 2)
		end
		
		if #self.IngreGrade3Count > 0 then
			table.insert(gradePool, 3)
		end
		
		return gradePool[_UtilLogic:RandomIntegerRange(1, #gradePool)]
	end

end