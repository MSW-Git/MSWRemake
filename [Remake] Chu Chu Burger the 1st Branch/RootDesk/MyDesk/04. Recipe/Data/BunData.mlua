@Struct
script BunData

	property integer Index = 0

	property any Bottom = nil

	property any Top = nil

	property string Tag = ""

	property boolean isInfinite = false

	property integer Grade = 0

	method void Load(any dataTable, integer index)
		-- 번 데이터를 로드하고 상단/하단 부분을 초기화하는 함수
		self.Index = index
		
		local bottomData = BunDetailData()
		bottomData:Load(dataTable["Bottom"], index)
		self.Bottom = bottomData
		
		local topData = BunDetailData()
		topData:Load(dataTable["Top"], index)
		self.Top = topData
		
		if self.Index == 1 then
			self.isInfinite = true
		else
			self.isInfinite = false
		end
		
		self.Tag = dataTable["Tag"]
		self.Grade = tonumber(dataTable["Grade"])
	end

end