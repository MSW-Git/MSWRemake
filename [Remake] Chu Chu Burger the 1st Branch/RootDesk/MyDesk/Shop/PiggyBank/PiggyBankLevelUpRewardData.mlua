@Struct
script PiggyBankLevelUpRewardData

	property integer RewardSlotIndex = 0

	property integer RequiredLevel = 0

	property string ItemId = ""

	property integer ItemCount = 0

	method void LoadFrom(any userdataRow)
		-- CSV 데이터 행에서 저금통 레벨업 보상 데이터의 모든 속성을 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.RewardSlotIndex = tonumber(rowData:GetItem("RewardSlotIndex"))
		self.RequiredLevel = tonumber(rowData:GetItem("RequiredLevel"))
		self.ItemId = rowData:GetItem("ItemId")
		self.ItemCount = tonumber(rowData:GetItem("ItemCount"))
	end

end