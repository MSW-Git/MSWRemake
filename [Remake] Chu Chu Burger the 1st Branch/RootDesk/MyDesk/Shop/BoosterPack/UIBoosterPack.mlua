@Component
script UIBoosterPack extends Component

	property table BoosterPackRUID = {"c6e544f618124c60a027a0c2e3386dce", "e2e06b9a239a4bb09f2bbd62302a16f0"}

	property Entity BoosterPackList = "c4282791-0bc4-4c19-8a67-16b83b0831b0"

	property TextComponent DescText1 = "10186ed7-9c15-4513-b311-9de9cbcd4696"

	property Entity BoosterPackButton_HUD = "4527051f-7d0f-4ca7-8819-086a1a5d3641"

	property Entity BoosterPackButton_Shop = "1739a434-d2b6-4c8b-98d6-a6e87b4a6164"

	property Entity ItemDescTooltip = "0721d6b7-378e-4a9c-8499-8ddb907a343d"

	property EntityRef TitleBg = "afdec41f-6691-4fe7-bf72-150879c74775"

	property EntityRef TitleText = "10978005-1e79-4cc7-ae6f-4cd8ba2932d5"

	property any tweener1 = nil

	property any tweener2 = nil

	property any closeCallback = nil

	@ExecSpace("ClientOnly")
	method void Open()
		-- 부스터 팩 UI를 열고 초기화
		_SoundService:PlaySound(_ResourceManager.SFXTable["System_BlastFurnace_NormalOpen_01"], 1)
		
		local myStageId = _UserService.LocalPlayer.PlayerStage.NowStage
		
		if myStageId < 2 then
		    _UIToast:ShowMessage("제 2 지역 츄츄 타운부터 진입 가능")
		    return
		end
		_UIGroupManager:EnableBoosterPackGroup(true)
		
		self.DescText1.Text = _LocalizationService:SmartFormat(_LocalizationService:GetText("BoosterPackDescText1"), myStageId)
		
		self.BoosterPackList.Children[1].UIBoosterPackRenderer:Init(1)
		self.BoosterPackList.Children[2].UIBoosterPackRenderer:Init(2)
		
		self:TitleAnimation()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 부스터 팩 UI를 닫고 콜백 실행
		_UIGroupManager:EnableBoosterPackGroup(false)
		
		if self.closeCallback ~= nil then
			self.closeCallback()
			self.closeCallback = nil
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdateBoosterPackButtonExpose()
		-- 부스터 팩 버튼 노출 상태 업데이트
		
		local player = _UserService.LocalPlayer
		local myStageId = player.PlayerStage.NowStage
		
		local boosterPackBtnOn = false
		local boosterPackRedDotOn = false
		
		if myStageId >= 2 then
			local myManagementLevel = player.PlayerManagement.ManagementLevel
			local boosterPack1Purchased = player.PlayerOutgameManager.BoosterPack1PurchaseTable[myStageId]
			
			local premiumBoosterPackItemId = _BoosterPackDataLogic:GetBoosterPackData(myStageId).BoosterPackItemIdPricePair[2][1]
			local boosterPack2Purchased = player.PlayerOutgameManager:GetPurchaseCount(premiumBoosterPackItemId)
			
			if myManagementLevel <= tonumber(_GetConfigDataLogic.ConfigValues["BoosterPackAvailableManagementLevel"]) then
				boosterPackBtnOn = true
				if boosterPack1Purchased ~= true then
					boosterPackRedDotOn = true
				end
			end
		end
		
		
		
		self.BoosterPackButton_HUD.Enable = boosterPackBtnOn
		self.BoosterPackButton_Shop.Enable = boosterPackBtnOn
		
		self.BoosterPackButton_Shop:GetChildByName("RedDot").Enable = boosterPackRedDotOn
		
		_LobbyHUDService.DropDown_BM.UIHUDDropDown:SetDrawOfName(_HUDDropDownEnum.BoosterPackButton, boosterPackBtnOn)
		_LobbyHUDService.DropDown_BM.UIHUDDropDown:SetItemRedDot(_HUDDropDownEnum.BoosterPackButton, boosterPackRedDotOn)
		
	end

	@ExecSpace("ClientOnly")
	method void TitleAnimation()
		-- 제목 애니메이션 실행
		if self.tweener1 ~= nil then
			self.tweener1:Destroy()
		end
		
		if self.tweener2 ~= nil then
			self.tweener2:Destroy()
		end
		
		local endScaleBg = self.TitleBg.UITransformComponent.Scale
		local endScaleText = self.TitleText.UITransformComponent.Scale
		self.TitleBg.UITransformComponent.Scale = endScaleBg * 2.5
		self.TitleText.UITransformComponent.Scale = endScaleText * 2.5
		self.tweener1 = _TweenLogic:ScaleTo(self.TitleBg, endScaleBg:ToVector2(), 0.3, EaseType.BackEaseIn)
		self.tweener2 = _TweenLogic:ScaleTo(self.TitleText, endScaleText:ToVector2(), 0.3, EaseType.BackEaseIn)
	end

	@ExecSpace("ClientOnly")
	method void OpenAndRegisterPiggyBankOpenCallback()
		-- 부스터 팩을 열고 닫을 때 피기뱅크를 열도록 콜백 등록
		self.closeCallback = function() _PiggyBankDataLogic.UIPiggyBank:Open() end
		self:Open()
	end

	@EventSender("Entity", "1739a434-d2b6-4c8b-98d6-a6e87b4a6164")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 샵에서 부스터 팩 버튼 클릭 이벤트 처리
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		
		self:Open()
	end

	@EventSender("Entity", "b1471a1f-9a51-4574-91c2-34fca81135c1")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 부스터 팩 닫기 버튼 클릭 이벤트 처리
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerManagementChangedEvent(PlayerManagementChangedEvent event)
		-- 플레이어 경영 상태 변경 시 부스터 팩 버튼 업데이트
		self:OnUpdateBoosterPackButtonExpose()
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerBoosterPackPurchaseChangedEvent(PlayerBoosterPackPurchaseChangedEvent event)
		-- 플레이어 부스터 팩 구매 상태 변경 시 버튼 업데이트
		self:OnUpdateBoosterPackButtonExpose()
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerPurchaseCountChangedEvent(PlayerPurchaseCountChangedEvent event)
		-- 플레이어 구매 카운트 변경 시 버튼 업데이트
		self:OnUpdateBoosterPackButtonExpose()
	end

end