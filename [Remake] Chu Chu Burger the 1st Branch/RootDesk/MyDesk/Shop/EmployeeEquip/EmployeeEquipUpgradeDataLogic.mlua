@Logic
script EmployeeEquipUpgradeDataLogic extends Logic

	property table EmployeeEquipUpgradeData = {}

	property number MaxUpgradeLevel = 8

	property string EquipLevelTextLocaleKey = "EquipLevelText"

	property string EquipNoneTextLocaleKey = "EquipLevelDescNone"

	method void OnBeginPlay()
		-- 게임 시작 시 직원 장비 업그레이드 데이터 로드
		self:LoadEmployeeEquipUpgradeDataSet()
	end

	method void LoadEmployeeEquipUpgradeDataSet()
		-- 직원 장비 업그레이드 데이터셋을 로드하여 테이블에 저장
		table.clear(self.EmployeeEquipUpgradeData)
		
		local dataSet = _DataService:GetTable("ChuchuEquipUpgradeDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = EmployeeEquipUpgradeData()
			data:LoadFrom(dataSet:GetRow(i))
			self.EmployeeEquipUpgradeData[data.EquipLevel] = data
			if data.EquipLevel == 0 then
				self.EmployeeEquipUpgradeData[-1] = data 
			end
		end
		
	end

	method EmployeeEquipUpgradeData GetEmployeeEquipUpgrageData(integer equipLevel)
		-- 장비 레벨에 따른 업그레이드 데이터 조회
		return self.EmployeeEquipUpgradeData[equipLevel]
	end

end