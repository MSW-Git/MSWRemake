@Logic
script StagePassDataLogic extends Logic

	property Entity UIStagePassEntity = "f96cb0f0-b032-46a5-b189-a42ab5963b45"

	property table StagePassGroupData = {}

	property table StagePassProductData = {}

	property table StagePassLevelData = {}

	property table StagePassLevelId_Sorted = {}

	property integer StagePassProductCount = 3

	property table StagePassRewardData = {}

	property table StagePassRewardIdByGroupId = {}

	property table StagePassRewardIdBySlotId = {}

	property table StagePassRewardIdByProductId = {}

	property table StagePassGroupId_Sorted = {}

	property string LimitedItemId = "G0008"

	property integer SpecialRewardProgress = 6

	property string Name = "StagePass"

	method void OnBeginPlay()
		-- 게임 시작 시 모든 스테이지 패스 데이터셋을 로드하는 함수
		self:LoadStagePassGroupDataSet()
		self:LoadStagePassProductDataSet()
		self:LoadStagePassLevelDataSet()
		self:LoadStagePassRewardDataSet()
		
	end

	method void LoadStagePassGroupDataSet()
		-- 스테이지 패스 그룹 데이터를 CSV에서 로드하여 초기화하는 함수
		table.clear(self.StagePassGroupData)
		
		local dataSet = _DataService:GetTable("StagePassGroupDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = StagePassGroupData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.StagePassGroupData[data.GroupId] ~= nil then
				break
			end
			self.StagePassGroupData[data.GroupId] = data
			table.insert(self.StagePassGroupId_Sorted, data.GroupId)
		end
	end

	method void LoadStagePassProductDataSet()
		-- 스테이지 패스 상품 데이터를 CSV에서 로드하여 초기화하는 함수
		table.clear(self.StagePassProductData)
		
		local dataSet = _DataService:GetTable("StagePassProductDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = StagePassProductData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.StagePassProductData[data.Id] ~= nil then
				break
			end
			self.StagePassProductData[data.Id] = data
		end
	end

	method void LoadStagePassLevelDataSet()
		-- 스테이지 패스 레벨 데이터를 CSV에서 로드하여 초기화하는 함수
		table.clear(self.StagePassLevelData)
		
		local dataSet = _DataService:GetTable("StagePassLevelDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = StagePassLevelData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.StagePassLevelData[data.Id] ~= nil then
				break
			end
			self.StagePassLevelData[data.Id] = data
			table.insert(self.StagePassLevelId_Sorted, data.Id)
		end
	end

	method void LoadStagePassRewardDataSet()
		-- 스테이지 패스 보상 데이터를 CSV에서 로드하여 초기화하는 함수
		table.clear(self.StagePassRewardData)
		table.clear(self.StagePassRewardIdByGroupId)
		table.clear(self.StagePassRewardIdBySlotId)
		
		local dataSet = _DataService:GetTable("StagePassRewardDataSet")
		
		for i = 1, dataSet:GetRowCount() do
			local data = StagePassRewardData()
			data:LoadFrom(dataSet:GetRow(i))
			if self.StagePassRewardData[data.Id] ~= nil then
				break
			end
			
			self.StagePassRewardData[data.Id] = data
			
			local groupId = string.sub(data.Id, 1, 1)
			local slotId = string.sub(data.Id, 3, 4)
			local productId = string.sub(data.Id, 1, 2)
			
			if self.StagePassRewardIdByGroupId[groupId] == nil then
				self.StagePassRewardIdByGroupId[groupId] = {}
			end
			
			if self.StagePassRewardIdBySlotId[slotId] == nil then
				self.StagePassRewardIdBySlotId[slotId] = {}
			end
			
			if self.StagePassRewardIdByProductId[productId] == nil then
				self.StagePassRewardIdByProductId[productId] = {}
			end
			
		
			table.insert(self.StagePassRewardIdByGroupId[groupId], data.Id)
			table.insert(self.StagePassRewardIdBySlotId[slotId], data.Id)
			table.insert(self.StagePassRewardIdByProductId[productId], data.Id)
		end
	end

	method boolean IsWorldCoinProduct(string productId)
		-- 해당 상품이 월드 코인 상품인지 확인하는 함수
		for i, d in pairs(self.StagePassProductData) do
			---@type StagePassProductData
			local data = d
			if data.ProductId == productId then
				return true
			end
		end
		
		return false
	end

	method boolean IsPassProductPurchased(string productId, string userId)
		-- 사용자가 해당 패스 상품을 구매했는지 확인하는 함수
		
		---@type StagePassProductData
		local productData = _StagePassDataLogic.StagePassProductData[productId]
		
		if productData.Id == productData.ProductId then
			return true
		end
		
		return _UserService:GetUserEntityByUserId(userId).PlayerOutgameManager:GetPurchaseCount(productData.ProductId) > 0
	end

	method boolean CanReceiveReward(string rewardSlotId, string userId)
		-- 사용자가 해당 보상을 받을 수 있는지 확인하는 함수
		local player =_UserService:GetUserEntityByUserId(userId)
		
		local groupId = string.sub(rewardSlotId, 1,1)
		local passLevelId = groupId..string.sub(rewardSlotId, 3, 4)
		local productId = string.sub(rewardSlotId, 1, 2)
		
		---@type StagePassLevelData
		local levelData = self.StagePassLevelData[passLevelId]
		
		local myProgress = player.PlayerStage.StageProgress[levelData.StageId]
		local isAchieve = myProgress ~= nil and myProgress >= levelData.StageProgress
		
		local isPassRewardReceived = player.PlayerOutgameManager:GetStagePassRewardReceived(rewardSlotId)
		
		---@type StagePassProductData
		local isPassProductPurchased = self:IsPassProductPurchased(productId, userId)
		
		return isPassProductPurchased and isAchieve and not isPassRewardReceived
	end

	method StagePassProductData GetStagePassProductData(string productId)
		-- 상품 ID로 스테이지 패스 상품 데이터를 반환하는 함수
		return self.StagePassProductData[productId]
	end

end