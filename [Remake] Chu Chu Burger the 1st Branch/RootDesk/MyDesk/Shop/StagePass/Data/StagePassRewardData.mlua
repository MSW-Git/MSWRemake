@Struct
script StagePassRewardData

	property string Id = ""

	property string RewardItemId = ""

	property integer RewardItemCount = 0

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 스테이지 패스 보상 데이터를 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.Id = rowData:GetItem("RewardSlotId")
		self.RewardItemId = rowData:GetItem("RewardItemId")
		self.RewardItemCount = tonumber(rowData:GetItem("RewardItemCount"))
	end

end