@Component
script UIStagePassPurchaseReward extends Component

	property Entity RewardEnable = nil

	property Entity ItemIcon = nil

	property Entity PurchaseRewardText = nil

	property Entity IconLock = nil

	property Entity PurchaseRewardDim = nil

	property string ProductId = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 UI 컴포넌트를 초기화하는 함수
		self.RewardEnable = self.Entity:GetChildByName("RewardEnable")
		self.ItemIcon = self.Entity:GetChildByName("ItemIcon")
		self.PurchaseRewardText = self.Entity:GetChildByName("PurchaseRewardText")
		self.IconLock = self.Entity:GetChildByName("IconLock")
		self.PurchaseRewardDim = self.Entity:GetChildByName("PurchaseRewardDim")
	end

	@ExecSpace("ClientOnly")
	method void Init(string productId)
		-- 상품 ID로 구매 보상을 초기화하는 함수
		---@type StagePassProductData
		local productData = _StagePassDataLogic.StagePassProductData[productId]
		if productData.PurchaseRewardItemId == nil then
			self.Entity.Enable = false
			return
		end
		
		self.ProductId = productId
		
		self.ItemIcon.SpriteGUIRendererComponent.ImageRUID = _ItemDataSetLogic:GetItemData(productData.PurchaseRewardItemId).IconRUID
		
		local player = _UserService.LocalPlayer
		local isPassProductPurchased = _StagePassDataLogic:IsPassProductPurchased(self.ProductId, player.PlayerComponent.UserId)
		
		self.RewardEnable.Enable = false
		self.IconLock.Enable = false
		self.PurchaseRewardDim.Enable = false
		
		if isPassProductPurchased == false then
			self.IconLock.Enable = true 
			self.PurchaseRewardText.TextComponent.Text = _LocalizationService:GetText("PurchaseRewardText")
		else
			local isReceived = player.PlayerOutgameManager:GetStagePassPurchaseRewardReceived(productId)
			if isReceived then
				self.PurchaseRewardDim.Enable = true
				self.PurchaseRewardText.TextComponent.Text = _LocalizationService:GetText("RewardTitleText")
			else
				self.Entity.ButtonComponent.Enable = true
				self.RewardEnable.Enable = true
				self.PurchaseRewardText.TextComponent.Text = _LocalizationService:GetText("GetRewardText")
			end
		end
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트를 처리하는 핸들러
		if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		---@type StagePassProductData
		local productData = _StagePassDataLogic.StagePassProductData[self.ProductId]
		if productData.PurchaseRewardItemId == nil then
			self.Entity.Enable = false
			return
		end
		
		local player = _UserService.LocalPlayer
		local isPassProductPurchased = _StagePassDataLogic:IsPassProductPurchased(self.ProductId, player.PlayerComponent.UserId)
		local isReceived = player.PlayerOutgameManager:GetStagePassPurchaseRewardReceived(self.ProductId)
		
		if not isReceived and isPassProductPurchased then
			_PaidLogic:RequestGetPurchaseReward_StagePass(self.ProductId, _UserService.LocalPlayer.PlayerComponent.UserId)
		else
			---@type ItemData
			local itemData = _ItemDataSetLogic:GetItemData(productData.PurchaseRewardItemId)
			_TooltipService:OpenTooltipWithPadding(_StagePassDataLogic.UIStagePassEntity.UIStagePass.ItemDescTooltip, itemData.DescriptionKey, itemData.NameKey, self.Entity.UITransformComponent.WorldPosition)
		end
		
	end

	@EventSender("LocalPlayer")
	handler HandlePlayerStagePassPurchaseRewardReceivedChangedEvent(PlayerStagePassPurchaseRewardReceivedChangedEvent event)
		-- 플레이어 스테이지 패스 구매 보상 수령 변경 이벤트를 처리하는 핸들러
		if _UtilLogic:IsNilorEmptyString(self.ProductId) then
			_SpecialShopDataLogic:CommonLog('ID 배정 전에 구매 보상 갱신 요청')
			return
		end
		self:Init(self.ProductId)
	end

end