@Component
script UIRewardInfo extends Component

	property TextComponent TitleText = nil

	property Entity CloseButton = nil

	property Entity RewardListLayoutEntity = nil

	property Entity PassPurchaseButton = nil

	property TextComponent PriceText = nil

	property EntityRef PurchaseCompleteTextEntity = nil

	property table RewardItemIds = {}

	property table RewardList = {}

	property integer PurchaseRewardIndex = 0

	property any TargetProduct = nil

	@ExecSpace("ClientOnly")
	method void ConnectEntities()
		-- UI 엔티티들을 연결하고 참조 설정
		local panel = self.Entity:GetChildByName("Panel")
		self.TitleText = panel:GetChildByName("Title").TextComponent
		self.CloseButton = panel:GetChildByName("CloseBtn")
		
		local rewardListBg = panel:GetChildByName("RewardListBg")
		self.RewardListLayoutEntity = rewardListBg:GetChildByName("RewardList")
		
		local bottom = rewardListBg:GetChildByName("Bottom")
		self.PassPurchaseButton = bottom:GetChildByName("ProductPassButton")
		self.PriceText = self.PassPurchaseButton:GetChildByName("PriceText").TextComponent
		self.PurchaseCompleteTextEntity = self.PassPurchaseButton:GetChildByName("PurchaseCompleteText")
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 초기화 및 이벤트 연결 설정
		self:ConnectEntities()
		
		self.CloseButton:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
		    return
		end
			self:OnClickCloseButton() end)
		self.PassPurchaseButton:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
		    	return
			end
			self:OnClickPurchaseButton() 
		end)
		
		self.RewardListLayoutEntity.RecycleScrollView.onUpdateCell = function(index, entity) 
			local itemId = self.RewardItemIds[index]
		
			if itemId ~= nil and self.RewardList[itemId] ~= nil then
				---@type Entity
				local slotEntity = entity
				
				slotEntity.UIRewardSumSlot:Init(itemId, self.RewardList[itemId], index == self.PurchaseRewardIndex)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickCloseButton()
		-- 보상 정보 팝업 닫기 버튼 처리
		self.TargetProduct = nil
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnClickPurchaseButton()
		-- 보상 정보에서 구매 버튼 클릭 처리
		if self.TargetProduct == nil then
			_SpecialShopDataLogic:AbnormalLog()
			return
		end
		
		if self.PriceText.Entity.Enable == true then
			self.TargetProduct:OnClickPurchaseButton()
		end
		
		self:OnClickCloseButton()
	end

end