@Component
script Extend_UIRewardInfoSpecialShop extends UIRewardInfo

	property TextComponent PolicyText = "ea9c7660-b332-49d0-9c41-addca434d0bf"

	@ExecSpace("ClientOnly")
	method void Init(UISpecialShopProductRef targetProduct)
		-- 특별 상점 상품의 보상 정보 UI를 초기화
		if self.TargetProduct ~= nil and self.TargetProduct.ProductId ~= targetProduct.ProductId then
			return
		end
		self.TargetProduct = targetProduct
		
		local productId = targetProduct.ProductId
		
		---@type SpecialShopProductData
		local productData = _SpecialShopDataLogic.SpecialShopProductData[productId]
		
		---@type ItemData
		local itemData = _ItemDataSetLogic.ItemData[productData.ItemId]
		self.TitleText.Text = _LocalizationService:SmartFormat(_LocalizationService:GetText("PassRewardSumTitleText"), _LocalizationService:GetText(itemData.NameKey))
		
		table.clear(self.RewardList)
		table.clear(self.RewardItemIds)
		
		
		local useItemsResult = itemData:GetUseItems_ItemId_Pair()
		if useItemsResult ~= nil then
			self.RewardList = useItemsResult.rewardList
			self.RewardItemIds = useItemsResult.rewardItemIds
		else
			self.RewardList = {}
			self.RewardItemIds = {}
		end
		self.RewardListLayoutEntity.RecycleScrollView:SetTotalCount(#self.RewardItemIds)
		self.RewardListLayoutEntity.RecycleScrollView:Refresh(true)
		self.PriceText.Text = _StringUtilLogic:ReturnThousandsSeparatedString(productData.Price)
		
		self:SetPolicyText(productData)
		
		self.Entity.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void SetPolicyText(SpecialShopProductData productData)
		-- 상품 타입에 따라 정책 안내 텍스트를 설정
		
		local resulText = nil
		
		if productData.LinkedShopId == _SpecialShopDataLogic.StarterPackShopId then
			resulText = _LocalizationService:GetText("PolicyExplanationForValueText2")
		elseif productData.LinkedShopId == _SpecialShopDataLogic.ItemPackageShopId then
			if productData.ItemCount == -1 then
				resulText = _LocalizationService:GetTextFormat("PolicyExplanationForValueText3", productData.PackageBenefitValue)
			elseif productData.ItemCount == 1 then
				resulText = _LocalizationService:GetText("PolicyExplanationForDiscountText1")
			end
		end
		
		if resulText == nil then
			self.PolicyText.Enable = false
		else
			self.PolicyText.Enable = true
			self.PolicyText.Text = resulText
		end
	end

end