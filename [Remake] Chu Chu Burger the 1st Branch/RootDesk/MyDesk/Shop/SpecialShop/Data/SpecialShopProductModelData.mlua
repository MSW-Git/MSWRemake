@Struct
script SpecialShopProductModelData

	property string UISlotModel = ""

	property boolean Amount = false

	property boolean AmountDiscount = false

	property boolean AmountSaleCloud = false

	property boolean PriceSaleCloud = false

	property boolean PriceDiscount = false

	property boolean FirstBenefit = false

	method void LoadFrom(any userdataRow)
		-- 데이터셋에서 특별 상점 상품 모델 UI 표시 정보를 로드
		---@type UserDataRow
		local rowData = userdataRow
		
		self.UISlotModel = rowData:GetItem("UISlotModel")
		self.Amount = tonumber(rowData:GetItem("Amount")) == 1 
		self.AmountDiscount = tonumber(rowData:GetItem("AmountBonus")) == 1 
		self.AmountSaleCloud = tonumber(rowData:GetItem("AmountSaleCloud")) == 1 
		self.PriceSaleCloud = tonumber(rowData:GetItem("PriceSaleCloud")) == 1 
		self.PriceDiscount = tonumber(rowData:GetItem("PriceDiscount")) == 1 
		self.FirstBenefit = tonumber(rowData:GetItem("FirstBenefit")) == 1 
	end

end