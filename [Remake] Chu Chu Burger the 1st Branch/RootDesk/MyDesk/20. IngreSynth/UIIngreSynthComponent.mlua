@Component
script UIIngreSynthComponent extends Component

	property Entity IngreListEntity = "3e0906fb-0514-4e1e-8034-9ee6b8097ea7"

	property Entity SynthFilterList = "445885b6-2713-43d8-98c2-7864bb2163ba"

	property Entity SelectedFilterPanel = "7a813322-08a3-4930-9a68-29f0f0341556"

	property Entity FilterListTitle = "aa81875b-0b24-459a-8b54-13ab0ea29773"

	property Entity ClearBtn = "4df7ec86-0426-47ca-960b-4ffbbe6990ed"

	property Entity AutoSetBtn = "6cbec977-2004-4ab3-827d-be4c285a03e8"

	property Entity StartSynthBtn = "753478ac-dabd-4938-ae94-7b9e2b9f5fde"

	property Entity NoticePanel = "e9e37e2d-2241-4627-8c4b-8a3ebe06249e"

	property Entity TagBtnPanel = "8ae5a022-2278-4c50-a156-a8e98cb1ce48"

	property Entity EffectPanel = "2ad1f576-f6f7-4072-bcbe-7bf38e20df60"

	property integer EffectDuration = 2

	property Entity ResultIngreIcon = "3ffae1ef-1f78-4b2e-bbba-9759510d6ef2"

	property Entity BaseIngreIcon = "a525e7de-f6d3-44d9-b2a3-06b52875b88f"

	property Entity Smile = "72ea6df4-4248-4d31-9d4a-de59e14147c7"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 버튼 이벤트 등록을 수행하는 함수
		local filterBtnList = {}
		for i, btn in pairs(self.SynthFilterList.Children) do
			table.insert(filterBtnList, btn)
			self:SetSynthRecipeIcon(btn:GetChildByName("BaseIngreIcon"), btn:GetChildByName("ResultIngreIcon"), i) 
			
			btn:ConnectEvent(ButtonClickEvent, function()
				_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
				self:SelectFilterType(i)
			end)
		end
		
		self._T.tagBtnList = {}
		for i, btn in pairs(self.TagBtnPanel.Children) do
			table.insert(self._T.tagBtnList, btn)
			btn:ConnectEvent(ButtonClickEvent, function()
				_SoundService:PlaySound(_ResourceManager.SFXTable["BtnClick_Cute"], 1) 
				self:SelectTagBtn(i)
			end)
		end
		
		local effect = self.EffectPanel:GetChildByName("Effect_In")
		effect.UIBasicParticleComponent.PlaySpeed = 8
		effect.UIBasicParticleComponent.ParticleLifeTime = 2
		
	end

	@ExecSpace("ClientOnly")
	method void OpenUI()
		-- 재료 합성 UI를 열고 게임 시간을 정지하는 함수
		self.Entity.Enable = true
		_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(true)
		self:InitUIFirstPage()
	end

	@ExecSpace("ClientOnly")
	method void CloseUI()
		-- 재료 합성 UI를 닫고 게임 시간을 재개하는 함수
		self.Entity.Enable = false
		_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		_UIGroupManager:EnableBackToLobbyBtn(false)
		_UIGroupManager:EnableMoneyBarGroup(nil)
	end

	@ExecSpace("ClientOnly")
	method void EnableNoticePanel(boolean enable, boolean isFull)
		-- 알림 패널을 활성화하고 상황에 따른 텍스트를 설정하는 함수
		self.NoticePanel.Enable = enable
		self.IngreListEntity.Enable = not enable 
		
		if enable then
			local textEntity = self.NoticePanel:GetChildByName("Text")
			if isFull then
				textEntity.TextComponent.Text = _LocalizationService:GetText("IngreSynthNoticePanelText1") 
			else
				textEntity.TextComponent.Text = _LocalizationService:GetText("IngreSynthNoticePanelText2") 
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableFilterList(boolean enable)
		-- 필터 목록을 활성화하고 첫 페이지 애니메이션을 재생하는 함수
		if enable then
			self:FirstPageAnim() 
		end
		
		self.SynthFilterList.Enable = enable
		self.FilterListTitle.Enable = enable
	end

	@ExecSpace("ClientOnly")
	method void EnableIngreList(boolean enable, integer filterType)
		-- 재료 목록을 활성화하고 선택된 필터에 따라 내용을 갱신하는 함수
		self.IngreListEntity.Parent.Enable = enable
		self.IngreListEntity.Enable = enable
		self.SelectedFilterPanel.Enable = enable
		self.AutoSetBtn.Enable = enable
		self.ClearBtn.Enable = enable
		self:SetStateSynthBtn(enable, true)
		
		_IngreSynthLogic:ResetAllSelectedIngreSlot() 
		
		if enable then
			self:SetSynthRecipeIcon(self.BaseIngreIcon, self.ResultIngreIcon, filterType) 
			_IngreSynthLogic:DrawIngreList()  
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SelectFilterType(integer filterType)
		-- 필터 타입을 선택하고 해당 화면으로 전환하는 함수
		_IngreSynthLogic:SetFilterType(filterType)
		self:EnableFilterList(false)
		self:EnableIngreList(true, filterType)
	end

	@ExecSpace("ClientOnly")
	method void OnClickFilterBackBtn()
		-- 필터 뒤로가기 버튼 클릭 시 초기 화면으로 돌아가는 함수
		self:InitUIFirstPage()
		
	end

	@ExecSpace("ClientOnly")
	method void InitUIFirstPage()
		-- UI를 초기 상태로 리셋하고 필터 선택 화면을 표시하는 함수
		_IngreSynthLogic:SetFilterType(0) 
		self:EnableFilterList(true)
		self:EnableIngreList(false, nil)
		self:SelectTagBtn(nil) 
		self.EffectPanel.Enable = false
		self._T.effectPlaying = false
	end

	@ExecSpace("ClientOnly")
	method void OnClickClearBtn()
		-- 클리어 버튼 클릭 시 선택된 모든 재료를 초기화하는 함수
		_IngreSynthLogic:ResetAllSelectedIngreSlot()
	end

	@ExecSpace("ClientOnly")
	method void OnClickAutoSetBtn()
		-- 자동 설정 버튼 클릭 시 재료를 자동으로 선택하는 함수
		_IngreSynthLogic:AutoSet()
	end

	@ExecSpace("ClientOnly")
	method void SelectTagBtn(integer tagNum)
		-- 태그 버튼을 선택하고 체크 상태를 업데이트하는 함수
		_IngreSynthLogic:SetTagType(tagNum)
		
		for i, entity in pairs(self._T.tagBtnList) do
			if i == tagNum then
				entity:GetChildByName("Check").Enable = false
			else
				entity:GetChildByName("Check").Enable = true
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickSynthBtn()
		-- 합성 버튼 클릭 시 로직에 합성 요청을 전달하는 함수
		_IngreSynthLogic:OnClickSynthBtn()
	end

	@ExecSpace("ClientOnly")
	method void PlayEffect(boolean isGreatSuccess)
		-- 합성 효과를 재생하고 대성공 여부에 따라 다른 연출을 하는 함수
		_SoundService:PlaySound("ab876c2a33ab4f228dd842e894e5d2b3", 1) 
		self._T.effectPlaying = true 
		self:EnableBtnOnEffectPlaying(false)
		
		self.EffectPanel.Enable = true
		self.Smile.Enable = true
		local greatEffect = self.EffectPanel:GetChildByName("Effect_Out")
		greatEffect.Enable = false
		
		local colorcode = ""
		if _IngreSynthLogic.TagType == _RecipeTagEnum.Meat then
			colorcode = "#83453c"
		elseif _IngreSynthLogic.TagType == _RecipeTagEnum.Chicken then
			colorcode = "#ecb782"
		elseif _IngreSynthLogic.TagType == _RecipeTagEnum.Seafood then
			colorcode = "#82e8ec"
		elseif _IngreSynthLogic.TagType == _RecipeTagEnum.Veggie then
			colorcode = "#97b15c"
		elseif _IngreSynthLogic.TagType == _RecipeTagEnum.Spicy then
			colorcode = "#cd6b81"
		end
		
		self.Smile.CanvasGroupComponent.GroupAlpha = 0
		_TweenLogic:PlayTween(0, 1, 0.1, EaseType.Linear, function(t)
			self.Smile.CanvasGroupComponent.GroupAlpha = t
		end)
		
		if isGreatSuccess then
			_TimerService:SetTimerOnce(function()
				_SoundService:PlaySound("cf1c83ba08034cf28f49f7a262661ce2", 1)
			end, 0.5)
			
			_TimerService:SetTimerOnce(function()
				_SoundService:PlaySound("cac34f61865b43abb6808a9293d855c4", 1)
			end, 0.8)
			
			_TimerService:SetTimerOnce(function() 
				greatEffect.UIBasicParticleComponent.Color = _ColorCodeEnum:GetColor(colorcode)
				greatEffect.Enable = true
				greatEffect.UIBasicParticleComponent:Play()
			end, self.EffectDuration - 0.6)
		end
		
		_TimerService:SetTimerOnce(function() 
			self.EffectPanel.Enable = false
			greatEffect.Enable = false
			self.Smile.Enable = false
			self._T.effectPlaying = false 
			self:EnableBtnOnEffectPlaying(true)
		end, self.EffectDuration)
	end

	@ExecSpace("ClientOnly")
	method void SetStateSynthBtn(boolean enable, boolean dimEnable)
		-- 합성 버튼의 활성화 상태와 디밍 상태를 설정하는 함수
		self.StartSynthBtn.Enable = enable
		self.StartSynthBtn:GetChildByName("Dim").Enable = dimEnable
	end

	@ExecSpace("ClientOnly")
	method void FirstPageAnim()
		-- 초기 페이지 진입 시 필터 버튼들의 애니메이션을 재생하는 함수
		_SoundService:PlaySound(_ResourceManager.SFXTable["Eff_VipOrderSlot"], 1)
		
		local duration = 0.2 
		local btn1 = self.SynthFilterList:GetChildByName("FilterBtn1")
		local btn2 = self.SynthFilterList:GetChildByName("FilterBtn2")
		local btn3 = self.SynthFilterList:GetChildByName("FilterBtn3")
		btn1.CanvasGroupComponent.GroupAlpha = 0
		btn2.CanvasGroupComponent.GroupAlpha = 0
		btn3.CanvasGroupComponent.GroupAlpha = 0
		self.SynthFilterList.CanvasGroupComponent.GroupAlpha = 0
		self.IngreListEntity.Parent.Enable = false
		
		local originPosX = self.FilterListTitle.UITransformComponent.anchoredPosition.x
		_TweenLogic:PlayTween(originPosX + 200, originPosX, duration, EaseType.CubicEaseOut, function(t)
			self.FilterListTitle.UITransformComponent.anchoredPosition.x = t
		end)
		
		_TweenLogic:PlayTween(0, 1, duration, EaseType.Linear, function(t)
			self.FilterListTitle.CanvasGroupComponent.GroupAlpha = t
		end)
		
		_TimerService:SetTimerOnce(function()
			_TweenLogic:PlayTween(originPosX + 200, originPosX, duration, EaseType.CubicEaseOut, function(t)
				self.SynthFilterList.UITransformComponent.anchoredPosition.x = t
			end)
			_TweenLogic:PlayTween(0, 1, duration, EaseType.Linear, function(t)
				self.SynthFilterList.CanvasGroupComponent.GroupAlpha = t
				btn1.CanvasGroupComponent.GroupAlpha = t
				btn2.CanvasGroupComponent.GroupAlpha = t
				btn3.CanvasGroupComponent.GroupAlpha = t
			end)
		end, 0.1)
		
	end

	@ExecSpace("ClientOnly")
	method void SetSynthRecipeIcon(Entity baseIngreIcon, Entity resultIngreIcon, integer filterType)
		-- 필터 타입에 따라 합성 레시피 아이콘을 설정하는 함수
		
		local resultDishRuid = ""
		local baseDishRuid = ""
		local baseCount = 10
		local resultCount = 1
		 
		if filterType == 1 then
			baseDishRuid = _IngredientDataSetLogic:ReturnDishRUIDByGrade(1)
			resultDishRuid = _IngredientDataSetLogic:ReturnDishRUIDByGrade(2)
			
		elseif filterType == 2 then
			baseDishRuid = _IngredientDataSetLogic:ReturnDishRUIDByGrade(2)
			resultDishRuid = _IngredientDataSetLogic:ReturnDishRUIDByGrade(3)
			
		elseif filterType == 3 then
			baseDishRuid = _IngredientDataSetLogic:ReturnDishRUIDByGrade(3)
			resultDishRuid = _IngredientDataSetLogic:ReturnDishRUIDByGrade(3)
			baseCount = 3 
		end
		
		baseIngreIcon.SpriteGUIRendererComponent.ImageRUID = baseDishRuid
		baseIngreIcon:GetChildByName("Count").TextComponent.Text = "x".. _StringUtilLogic:NumToString(baseCount)
		resultIngreIcon.SpriteGUIRendererComponent.ImageRUID = resultDishRuid 
		resultIngreIcon:GetChildByName("Count").TextComponent.Text = "x".. _StringUtilLogic:NumToString(resultCount)
	end

	@ExecSpace("ClientOnly")
	method void EnableBtnOnEffectPlaying(boolean enable)
		-- 효과 재생 중에 버튼들의 활성화 상태를 제어하는 함수
		
		_UIGroupManager:EnableBackToLobbyBtn(enable)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6f332940-91a0-4bae-ba46-858918869de7")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		if self._T.effectPlaying == true then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "cfefc833-4210-45df-a084-bb3254f0c7d4")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 필터 뒤로가기 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		if self._T.effectPlaying == true then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:OnClickFilterBackBtn()
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "4df7ec86-0426-47ca-960b-4ffbbe6990ed")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 클리어 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		if self._T.effectPlaying == true then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickClearBtn()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6cbec977-2004-4ab3-827d-be4c285a03e8")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 자동 설정 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		if self._T.effectPlaying == true then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickAutoSetBtn()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "753478ac-dabd-4938-ae94-7b9e2b9f5fde")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 합성 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		if self._T.effectPlaying == true then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["ItemHintDrop"], 1) 
		self:OnClickSynthBtn()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "08226cca-cc61-4850-b098-21acd3879876")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- UI 열기 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OpenUI()
	end

end