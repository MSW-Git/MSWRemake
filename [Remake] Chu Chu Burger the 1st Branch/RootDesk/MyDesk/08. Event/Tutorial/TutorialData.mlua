@Struct
script TutorialData

	property string Id = ""

	property boolean Highlight = false

	property boolean Mask = false

	property boolean ClickEntity = false

	property string TargetPath = ""

	property string TargetPathFix = ""

	property string GuideTextKey = ""

	property boolean TextVisible = false

	property boolean AutoNext = false

	property string Alignment = ""

	property Vector2 Offset = Vector2(0,0)

	property string funcExecute = ""

	property table executeParams = {}

	property boolean TouchAnywhere = false

	property string ForceTo = ""

	property string funcCallback = ""

	property table callbackParams = {}

	property boolean FuncOnTouch = false

	method void Load(any dataTable, integer index)
		-- CSV 데이터에서 튜토리얼 설정을 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		self.Highlight =  _StringUtilLogic:GetBoolByString(row:GetItem("Highlight"), false)
		self.Mask =  _StringUtilLogic:GetBoolByString(row:GetItem("Mask"), false)
		self.ClickEntity =  _StringUtilLogic:GetBoolByString(row:GetItem("ClickEntity"), false)
		
		self.TargetPath = row:GetItem("TargetPath")
		self.TargetPathFix = row:GetItem("TargetPathFix")
		self.GuideTextKey = row:GetItem("GuideTextKey")
		
		self.TextVisible =  _StringUtilLogic:GetBoolByString(row:GetItem("TextVisible"), true)
		self.AutoNext =  _StringUtilLogic:GetBoolByString(row:GetItem("AutoNext"), false)
		self.TouchAnywhere = _StringUtilLogic:GetBoolByString(row:GetItem("TouchAnywhere"), false)
		self.FuncOnTouch = _StringUtilLogic:GetBoolByString(row:GetItem("FuncOnTouch"), true)
		
		self.Alignment = row:GetItem("Alignment")
		local offsetX = _UtilLogic:IsNilorEmptyString(row:GetItem("OffsetX")) and 0 or tonumber(row:GetItem("OffsetX"))
		local offsetY = _UtilLogic:IsNilorEmptyString(row:GetItem("OffsetY")) and 0 or tonumber(row:GetItem("OffsetY"))
		self.Offset = Vector2(offsetX, offsetY)
		
		self.ForceTo = row:GetItem("ForceTo")
		
		self.funcExecute = row:GetItem("funcExecute")
		for i = 1, 2 do
			local param = row:GetItem("executeParam"..i)
			self.executeParams[i] = param
		end
		
		self.funcCallback = row:GetItem("funcCallback")
		for i = 1, 2 do
			local param = row:GetItem("callbackParam"..i)
			self.callbackParams[i] = param
		end
	end

end