@Component
script UIEventOpenFunction extends Component

	property Entity EventTitle = nil

	property Entity Image = nil

	property Entity DialogText = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 기능 열기 이벤트 UI 요소들을 초기화하는 함수
		self.EventTitle = self.Entity:GetChildByName("EventTitle")
		self.Image = self.Entity:GetChildByName("ImageHolder"):GetChildByName("Image")
		self.DialogText = self.Entity:GetChildByName("DialogText")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(EventDialogData dialogData)
		-- 기능 열기 이벤트 UI를 새로고침하고 아이콘을 표시하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventTitleOpenFunction")
		
		self.Image.SpriteGUIRendererComponent.ImageRUID = _EventDataSetLogic.OpenFunctionRUIDs[dialogData.TitleInfo[1]]
		self.DialogText.TextComponent.Text = _GetLocalizationTextLogic:GetText(dialogData.DialogInfoKey)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Bell"], 1)
	end

	@ExecSpace("ClientOnly")
	method void Reset()
		-- 기능 열기 이벤트 UI를 초기 상태로 리셋하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.Image.SpriteGUIRendererComponent.ImageRUID = _StringUtilLogic.EmptyRUID
	end

end