@Component
script UIEventInfoDialog extends Component

	property Entity EventTitle = nil

	property Entity TitleText = nil

	property Entity DialogText = nil

	property Entity Img = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 정보 다이얼로그 UI 요소들을 초기화하는 함수
		self.EventTitle = self.Entity:GetChildByName("EventTitle")
		local contents = self.Entity:GetChildByName("Contents")
		self.TitleText = contents:GetChildByName("TitleText")
		self.DialogText = contents:GetChildByName("DialogText")
		self.Img = contents:GetChildByName("Img")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(EventDialogData dialogData)
		-- 정보 다이얼로그 UI를 새로고침하고 내용을 표시하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("HOT ISSCHU")
		
		local referKeyText = _GetLocalizationTextLogic:GetReferKeyText("PlayerShopName")
		if _UtilLogic:IsNilorEmptyString(referKeyText) then
			referKeyText = "PlayerShopName"
		end
		
		local titleText = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.TitleInfo[1], referKeyText)
		self.TitleText.TextComponent.Text = titleText
		self.Img.SpriteGUIRendererComponent.ImageRUID = _ResourceLoadLogic:OptimizeMobileResource(dialogData.TitleInfo[2]) 
		
		local arguments = dialogData.Arguments
		self.DialogText.TextComponent.Text = _EventDataSetLogic:ReturnDialogText(dialogData)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["ShowHintPaper"], 1)
	end

end