@Component
script UIEventStoreName extends Component

	property Entity InputText = nil

	property TextComponent CostText = nil

	property TextComponent DescText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 상점명 변경 UI를 초기화하고 이벤트를 연결하는 함수
		if _UtilLogic:Contains(self.Entity.Name, "Change") then
			local panel = self.Entity:GetChildByName("Panel")
			self.InputText = panel:GetChildByName("InputText")
			self.DescText = panel:GetChildByName("Desc").TextComponent
			local confirmBtn = panel:GetChildByName("PopupBtnOK")
			confirmBtn:ConnectEvent(ButtonClickEvent, self.OnClickConfirmBtn)
			
			if isvalid(confirmBtn:GetChildByName("CostText")) then
				self.CostText = panel:GetChildByName("PopupBtnOK"):GetChildByName("CostText").TextComponent
			end
			
			local closeBtn = self.Entity:GetChildByName("CloseBtn")
			if isvalid(closeBtn) == true then
				closeBtn:ConnectEvent(ButtonClickEvent, function()
					if _UIGroupManager:IsEnableOpenPopUp() == false then
						return
					end
					
					_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
					
					_EventManager:SetCanMoveNext(true)
					_EventManager:MoveNextDialog()
				end)
			end
		else
			self.InputText = self.Entity:GetChildByName("InputText")
			self.DescText = self.Entity:GetChildByName("Desc").TextComponent
			local confirmBtn = self.Entity:GetChildByName("PopupBtnOK")
			confirmBtn:ConnectEvent(ButtonClickEvent, self.OnClickConfirmBtn)
			
			if isvalid(confirmBtn:GetChildByName("CostText")) then
				self.CostText = self.Entity:GetChildByName("PopupBtnOK"):GetChildByName("CostText").TextComponent
			end
			
			local closeBtn = self.Entity:GetChildByName("CloseBtn")
			if isvalid(closeBtn) == true then
				closeBtn:ConnectEvent(ButtonClickEvent, function()
					if _UIGroupManager:IsEnableOpenPopUp() == false then
						return
					end
					
					_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
					
					_EventManager:SetCanMoveNext(true)
					_EventManager:MoveNextDialog()
				end)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 상점명 입력 필드와 비용 정보를 업데이트하는 함수
		local player = _UserService.LocalPlayer
		local userName = player.PlayerOutgameManager.StoreName
		
		local text = _GetLocalizationTextLogic:GetText("DefaultStoreName")
		local defaultText, count = string.gsub(text, " ", "")
		if _UtilLogic:IsNilorEmptyString(userName) == false then
			defaultText = userName
		else
			player.PlayerOutgameManager:RequestSetStoreName(defaultText, false, _UtilLogic:Contains(self.Entity.Name, "Change") and "1" or "0")
		end
		self.InputText.TextComponent.Text = defaultText
		self.InputText.TextInputComponent.PlaceHolder = defaultText
		
		self.DescText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("EventInfoStoreName", self.InputText.TextInputComponent.CharacterLimit)
		
		if isvalid(self.CostText) == true then
			local cost = math.floor(_GetConfigDataLogic:GetConfigNumDataByKey("StoreNameChangeDiamondCost"))
			self.CostText.Text = _StringUtilLogic:ReturnThousandsSeparatedString(cost)
			if player.PlayerOutgameManager:GetDiamondCount() < cost then
				self.CostText.FontColor = _ColorCodeEnum:GetColor("#FA5246")
				self.CostText.OutlineColor = _ColorCodeEnum:GetColor("#ffffff")
			else
				self.CostText.FontColor = _ColorCodeEnum:GetColor("#ffffff")
				self.CostText.OutlineColor = _ColorCodeEnum:GetColor("#b95b0c")
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickConfirmBtn()
		-- 상점명 설정/변경 확인 버튼 클릭 이벤트를 처리하는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		local player = _UserService.LocalPlayer
		local text = self.InputText.TextComponent.Text
		
		if _UtilLogic:IsNilorEmptyString(text) then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("EventStoreNameToast1"))
			return
		end
		
		
		if _UtilLogic:Contains(self.Entity.Name, "Change") == true then
			local cost = math.floor(_GetConfigDataLogic:GetConfigNumDataByKey("StoreNameChangeDiamondCost"))
			if player.PlayerOutgameManager:GetDiamondCount() < cost then
				_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("NoDiaToastMsg"))
				return
			end
			
			local onOk = function()
				_LobbyHUDService:RequestChangeStoreName(player, text)
			end
			
			local content = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("EventStoreNameChangePopupContents", text, _StringUtilLogic:ReturnThousandsSeparatedString(cost))
			_UIPopup:Open(content, onOk, function() end, _GetLocalizationTextLogic:GetText("EventStoreNamePopupTitle"))
			
		else
			local onOk = function()
				player.PlayerOutgameManager:RequestSetStoreName(text, true, "0")
			end
				
			local content = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("EventStoreNamePopupContents", text)
			_UIPopup:Open(content, onOk, function() end, _GetLocalizationTextLogic:GetText("EventStoreNamePopupTitle"))
		end
	end

end