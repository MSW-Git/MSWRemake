@Component
script UIEventStartTrend extends Component

	property Entity EventTitle = nil

	property Entity Frame = nil

	property Entity TagIcon = nil

	property Entity DialogText = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- 트렌드 시작 이벤트 UI 요소들을 초기화하는 함수
		self.EventTitle = self.Entity:GetChildByName("EventTitle")
		self.Frame = self.Entity:GetChildByName("Frame")
		self.TagIcon = self.Frame:GetChildByName("TagHolder"):GetChildByName("TagIcon")
		self.DialogText = self.Entity:GetChildByName("DialogText")
	end

	@ExecSpace("ClientOnly")
	method void Refresh(EventDialogData dialogData, boolean isPositive)
		-- 트렌드 시작 이벤트 UI를 새로고침하고 긍정/부정 트렌드를 표시하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		local tag = _UserService.LocalPlayer.PlayerEvent.EventReferKey[dialogData.EventGroupId]
		---@type RecipeTagData
		local tagData = _RecipeTagDataSetLogic.RecipeTagData[tag]
		
		if isPositive then
			self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventTitlePositiveTrendStart")
			_SoundService:PlaySound(_ResourceManager.SFXTable["Popup_TrendStart"], 1)
			_ReportMessageMaker:RequestAddToReportQueue(5001, _GetLocalizationTextLogic:GetText(tagData.TagNameKey), "", "")
		else
			self.EventTitle.TextComponent.Text = _GetLocalizationTextLogic:GetText("EventTitleNegativeTrendStart")
			_SoundService:PlaySound(_ResourceManager.SFXTable["Popup_FailEvent_v2"], 1)
			_ReportMessageMaker:RequestAddToReportQueue(5002, _GetLocalizationTextLogic:GetText(tagData.TagNameKey), "", "")
		end
		
		
		if isvalid(tagData) then
			self.TagIcon.SpriteGUIRendererComponent.ImageRUID = tagData.IconRUID
		end
		
		self.DialogText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.DialogInfoKey, _GetLocalizationTextLogic:GetText(tagData.TagNameKey))
	end

	@ExecSpace("ClientOnly")
	method void Reset()
		-- 트렌드 시작 이벤트 UI를 초기 상태로 리셋하는 함수
		if self.EventTitle == nil then
			self:Init()
		end
		
		self.TagIcon.SpriteGUIRendererComponent.ImageRUID = _StringUtilLogic.EmptyRUID
	end

end