@Logic
script EventDataSetLogic extends Logic

	property table EventGroupData = {}

	property table NPCData = {}

	property SyncTable<string, string> OpenFunctionRUIDs

	method void OnBeginPlay()
		-- 게임 시작 시 이벤트 관련 데이터를 초기화하는 함수
		self:LoadDataSet()
		
		if self:IsClient() then
			self:SetOpenFunctionRUIDs()
		end
	end

	method void LoadDataSet()
		-- CSV에서 이벤트 그룹 데이터와 NPC 데이터를 로드하는 함수
		table.clear(self.EventGroupData)
		local eGroupDataSet = _DataService:GetTable("EventGroupData")
		for i = 1, eGroupDataSet:GetRowCount() do
			local eGroupData = EventGroupData()
			eGroupData:Load(eGroupDataSet, i)
			
			if self.EventGroupData[eGroupData.Id] ~= nil then
				break
			end
		
			self.EventGroupData[eGroupData.Id] = eGroupData
		end
		
		table.clear(self.NPCData)
		local npcDataSet = _DataService:GetTable("NPCData")
		for i = 1, npcDataSet:GetRowCount() do
			local npcData = NPCData()
			npcData:Load(npcDataSet, i)
			
			if self.NPCData[npcData.Id] ~= nil then
				break
			end
		
			self.NPCData[npcData.Id] = npcData
		end
	end

	@ExecSpace("ClientOnly")
	method void SetOpenFunctionRUIDs()
		-- 기능 열기 이벤트에 사용할 아이콘 RUID들을 설정하는 함수
		self.OpenFunctionRUIDs["Upgrade"] = "e7d72d5dec0740f5a002a01639a9f6a0"
		self.OpenFunctionRUIDs["Employment"] = "571e50b921974a0c9fcd7d004f67b6f2"
		self.OpenFunctionRUIDs["Recipe"] = "5c6a284c715e454686aca1f927c98f3b"
		self.OpenFunctionRUIDs["EmployeeUpgrade"] = "53e4db2ca91c4b788c41544c4ce6913a"
		self.OpenFunctionRUIDs["Management"] = "a06f3afae3a84725b8e752edbb43fab9"
		self.OpenFunctionRUIDs["VIPOrder"] = "6512629e3fbc41088846de3f41089cf7"
		self.OpenFunctionRUIDs["AutoTraining"] = "c2338e5dc79c4da59924e9a1421c4b35"
		self.OpenFunctionRUIDs["Interior"] = "5aa6d728449d460b978ae6403eb0fe93"
		self.OpenFunctionRUIDs["Expansion"] = "c376a1f72ed6495f99f1b559591084a4"
		self.OpenFunctionRUIDs["Subscription"] = "de34bc8137594ad393dd8c74f64f3472"
		self.OpenFunctionRUIDs["Shop"] = "ed136e5692364d31b2af2c65c2d941cf"
		self.OpenFunctionRUIDs["Training"] = "0d32289149c744c0b09c875fa9afa07f"
		self.OpenFunctionRUIDs["Trial"] = "c2148eb14f844cae83c6d772ea5abe57"
		self.OpenFunctionRUIDs["Deco"] = "39f143f9f5934554bbd96d0657409e97"
		self.OpenFunctionRUIDs["PlaceExp"] = "9ec648b1732a491e8c90971c86e0b697"
		self.OpenFunctionRUIDs["Ranking"] = "0746afe7dfac4208a7c9564447d1ca1f"
		self.OpenFunctionRUIDs["Exchange"] = "83bdb483cf7247c9a41d666d951b58f4"
		self.OpenFunctionRUIDs["IngreSynth"] = "7148b011f07d4466b39996a972de8da4"
	end

	method NPCData GetNPCData(string npcId)
		-- NPC ID로 NPC 데이터를 반환하는 함수
		return self.NPCData[npcId]
	end

	@ExecSpace("ClientOnly")
	method string ReturnDialogText(EventDialogData dialogData)
		-- 이벤트 다이얼로그의 텍스트를 참조키와 인수로 포맷팅하여 반환하는 함수
		local dialogInfo = _GetLocalizationTextLogic:GetText(dialogData.DialogInfoKey)
		
		if dialogData.IsReferKey == true then
			local referKey = _UserService.LocalPlayer.PlayerEvent.EventReferKey[dialogData.EventGroupId]
			if _UtilLogic:IsNilorEmptyString(referKey) == false then
				dialogInfo = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.DialogInfoKey, referKey)
			end
			
		else
			if #dialogData.Arguments > 0 then
				local arguments = {}
				for i, argument in pairs(dialogData.Arguments) do
					local referKeyText
					if argument == "RankingIndex" then
						referKeyText = _UserService.LocalPlayer.PlayerEvent.EventReferKey[dialogData.EventGroupId]
					elseif argument == "RivalStoreName" then
						local stageData = _StageDataSetLogic:GetStageData(_UserService.LocalPlayer.PlayerStage.NowStage)
						referKeyText = _GetLocalizationTextLogic:GetText(stageData.RivalStoreNameKey)
					else
						referKeyText = _GetLocalizationTextLogic:GetReferKeyText(argument)
					end
					
					if _UtilLogic:IsNilorEmptyString(referKeyText) == false then
						table.insert(arguments, referKeyText)
						continue
					end
				end
				
				if #arguments == 1 then
					dialogInfo = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.DialogInfoKey, arguments[1])
				elseif #arguments == 2 then
					dialogInfo = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.DialogInfoKey, arguments[1], arguments[2])
				elseif #arguments == 3 then
					dialogInfo = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat(dialogData.DialogInfoKey, arguments[1], arguments[2], arguments[3])
				end
				
			end
		end
		
		return dialogInfo
	end

	method EventGroupData GetEventGroupData(string eventGroupId)
		-- 이벤트 그룹 ID로 이벤트 그룹 데이터를 반환하는 함수
		return self.EventGroupData[eventGroupId]
	end

end