@Struct
script ButtonUnlockData

	property string Id = ""

	property string RelatedEvent = ""

	property string EntityPath = ""

	property string ConditionType = ""

	property string EventCondition = ""

	property integer AchievementCondition = 0

	property string UpgradeCondition = ""

	property boolean IsFull = false

	method void Load(any dataTable, integer index)
		-- CSV 데이터에서 버튼 잠금 해제 정보를 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		self.RelatedEvent = row:GetItem("RelatedEvent")
		self.EntityPath = row:GetItem("EntityPath")
		self.ConditionType = row:GetItem("ConditionType")
		self.EventCondition = row:GetItem("EventCondition")
		self.AchievementCondition = isvalid(row:GetItem("AchievementCondition")) and tonumber(row:GetItem("AchievementCondition")) or nil
		self.UpgradeCondition = row:GetItem("UpgradeCondition")
		self.IsFull = _StringUtilLogic:GetBoolByString(row:GetItem("IsFull"), false)
	end

end