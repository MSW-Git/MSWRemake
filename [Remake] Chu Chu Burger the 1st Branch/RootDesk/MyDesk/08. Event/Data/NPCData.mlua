@Struct
script NPCData

	property string Id = ""

	property string NameKey = ""

	property string PortraitRUID = ""

	property string TalkRUID = ""

	property string SmileRUID = ""

	property string CryRUID = ""

	property integer OffsetY = 0

	property string SoundSFX = ""

	property integer OffsetX = 0

	method void Load(any dataTable, integer index)
		-- CSV 데이터에서 NPC 정보를 로드하고 기본값을 설정하는 함수
		---@type UserDataRow
		local rowData = dataTable:GetRow(index)
		
		self.Id = rowData:GetItem("Id")
		self.NameKey = rowData:GetItem("NameKey")
		self.PortraitRUID = rowData:GetItem("PortraitRUID")
		self.TalkRUID = rowData:GetItem("TalkRUID")
		if _UtilLogic:IsNilorEmptyString(self.TalkRUID) then
			self.TalkRUID = self.PortraitRUID
		end
		self.SmileRUID = rowData:GetItem("SmileRUID")
		if _UtilLogic:IsNilorEmptyString(self.SmileRUID) then
			self.SmileRUID = self.PortraitRUID
		end
		self.CryRUID = rowData:GetItem("CryRUID")
		if _UtilLogic:IsNilorEmptyString(self.CryRUID) then
			self.CryRUID = self.PortraitRUID
		end
		self.OffsetY = tonumber(rowData:GetItem("OffsetY"))
		self.OffsetX = tonumber(rowData:GetItem("OffsetX"))
		self.SoundSFX = rowData:GetItem("SoundSFX")
		
	end

end