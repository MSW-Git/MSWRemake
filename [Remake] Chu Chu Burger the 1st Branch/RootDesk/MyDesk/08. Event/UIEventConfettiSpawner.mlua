@Component
script UIEventConfettiSpawner extends Component

	property integer ConfettiTimer = 0

	property number spawnDelay = 0.2

	property integer spawnCount = 2

	property Entity ConfettiParent = nil

	property integer entityMaxCount = 60

	property number fallDuration = 4.3

	property table ConfettiPool = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 콘페티 스포너를 초기화하는 함수
		self.ConfettiParent = self.Entity:GetChildByName("Confetties")
	end

	@ExecSpace("ClientOnly")
	method void SpawnRandomConfetti()
		-- 랜덤 콘페티를 생성하고 애니메이션을 시작하는 함수
		local confetti = table.remove(self.ConfettiPool, 1)
		
		if isvalid(confetti) == false then
			return
		end
		
		local randomRUID = self:ReturnRandomConfettiRUID()
		confetti.SpriteGUIRendererComponent.ImageRUID = randomRUID
		
		local rectSizeX = self.Entity.UITransformComponent.RectSize.x
		local rectSizeY = self.Entity.UITransformComponent.RectSize.y
		
		local randomPosX = _UtilLogic:RandomIntegerRange(-rectSizeX/2, rectSizeX/2)
		confetti.UITransformComponent.anchoredPosition = Vector2(randomPosX, 0)
		
		local randomDelay = _UtilLogic:RandomIntegerRange(1, 250)/1000
		confetti.UITweenConfetti.delay = randomDelay
		confetti.UITweenConfetti.duration = self.fallDuration
		confetti.UITweenConfetti.fromY = 0
		confetti.UITweenConfetti.toY = -(rectSizeY+500)
		confetti.UITweenConfetti.toXGap = _UtilLogic:RandomIntegerRange(200, 500)/10
		confetti.UITweenConfetti.pingpongDuration = _UtilLogic:RandomIntegerRange(20, 40)/100
		confetti.UITweenConfetti.fromX = randomPosX
		
		confetti.UITweenConfetti:Play()
	end

	@ExecSpace("ClientOnly")
	method void StartSpawnConfetties()
		-- 콘페티 스폰 애니메이션을 시작하는 함수
		table.clear(self.ConfettiPool)
		
		for i = 1, self.entityMaxCount do
			local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_Confetti", i, self.ConfettiParent)
			table.insert(self.ConfettiPool, entity)
			entity.Enable = false
		end
		
		
		self.Entity.Enable = true
		
		self.ConfettiTimer = _TimerService:SetTimerRepeat(function()
			for i = 1, self.spawnCount do
				self:SpawnRandomConfetti()
			end
		end, self.spawnDelay)
	end

	@ExecSpace("ClientOnly")
	method void EndSpawnConfetties()
		-- 콘페티 스폰을 종료하고 정리하는 함수
		if #self.ConfettiParent.Children > 0 then
			for i = #self.ConfettiParent.Children, 1, -1 do
				local entity = self.ConfettiParent.Children[i]
				_EntityService:Destroy(entity)
			end
		end
		
		
		_TimerService:ClearTimer(self.ConfettiTimer)
		self.ConfettiTimer = 0
		
		self.Entity.Enable = false
	end

	method string ReturnRandomConfettiRUID()
		-- 랜덤 콘페티 RUID를 반환하는 함수
		local ruids = {"ab1a9770a5d847c58debac6112434f7e", "970eb272c13c4f6fae7be9a722d32e81", "95671594552447479b690b5f5eae51b4", "71c39c5ff1bc42c191808870b759c7ba",
			"85a150de470342dcb5b6873c0fd311ae", "94a35e8cbb2b47ff9a53aea2985fac4b", "4a0aceeb6d0b44648bbffc20a5677f26", "5e1d8dbba0f54376bf5e5e03be3acaef", "60328d6f3f6a4ce3a5795315d8c9abf9",
			"62f65d65db4c4c72aadeb815b9576735", "1aee5aef524c41269a0f3ed904f04a16"}
		
		local randomIndex = _UtilLogic:RandomIntegerRange(1, #ruids)
		return ruids[randomIndex]
	end

end