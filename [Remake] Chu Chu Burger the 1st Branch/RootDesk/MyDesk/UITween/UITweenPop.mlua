@Component
script UITweenPop extends Component

	property number posX = 0

	property number posY = 0

	property integer moveUpY = 1000

	@ExecSpace("ClientOnly")
	method void StartPop(Vector3 targetPos, number duration, boolean isMove, number moveDelay, Vector3 moveTargetPos, number moveDuration)
		-- 팝업 효과와 함께 등장하는 트윈 시작
		self.Entity.Enable = false
		self.Entity.SpriteGUIRendererComponent.RaycastTarget = false
		local delay = _UtilLogic:RandomIntegerRange(0, 1000)/10000
		
		self.posX = self.Entity.UITransformComponent.WorldPosition.x
		self.posY = self.Entity.UITransformComponent.WorldPosition.y
		
		self.Entity.CanvasGroupComponent.GroupAlpha = 1
		
		local firstTime = duration*0.2 + delay
		local lastTime = duration - firstTime
		
		local firstTargetPosY = self.posY + _UtilLogic:RandomIntegerRange(0, self.moveUpY)/10
		local lastTargetPosY = targetPos.y
		
		local fadePointY = firstTargetPosY - (firstTargetPosY - lastTargetPosY)*0.8
		
		_TimerService:SetTimerOnce(function()
			_SoundService:PlaySound(_ResourceManager.SFXTable["IconDrop"], 0.1)
			
			self.Entity.Enable = true
			
			local xTween = _TweenLogic:PlayTween(self.posX, targetPos.x, duration, EaseType.CubicEaseOut, function(t)
				self.posX = t
			end)
			
			local yTweenFirst = _TweenLogic:PlayTween(self.posY, firstTargetPosY, firstTime, EaseType.SineEaseOut, function(t)
				self.posY = t
			end)
			
			_TimerService:SetTimerOnce(function()
				local yTween = _TweenLogic:PlayTween(firstTargetPosY, targetPos.y, lastTime, EaseType.SineEaseIn, function(t)
					self.posY = t
				end)
				
				_TimerService:SetTimerOnce(function()
					if isMove then
						_TimerService:SetTimerOnce(function()
							self:StartMoveToTarget(moveTargetPos, moveDuration)
						end, moveDelay)
					end
				end, lastTime)
			end, firstTime)
			
		end, delay)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임 월드 위치 업데이트
		self.Entity.UITransformComponent.WorldPosition = Vector3(self.posX, self.posY, 0)
	end

	@ExecSpace("ClientOnly")
	method void StartMoveToTarget(Vector3 targetPos, number duration)
		-- 타겟 위치로 이동 후 페이드 아웃 처리
		local xTween = _TweenLogic:PlayTween(Vector3(self.posX, self.posY, targetPos.z), targetPos, duration, EaseType.CubicEaseOut, function(t)
			self.posX = t.x
			self.posY = t.y
		end)
		
		local fadeDuration = 0.1
		_TimerService:SetTimerOnce(function()
			_TweenLogic:PlayTween(1, 0, fadeDuration, EaseType.CubicEaseOut, function(t)
				self.Entity.CanvasGroupComponent.GroupAlpha = t
			end)
			
			_TimerService:SetTimerOnce(function()
				self.Entity:Destroy()
			end, fadeDuration)
		end, duration)
	end

end