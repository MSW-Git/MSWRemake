@Component
script PlayerAccount extends Component

	property integer Date_Create = 0

	property integer Date_Login = 0

	@Sync
	property integer Date_Logout = 0

	property string DBKey = "PlayerAccount"

	@ExecSpace("ServerOnly")
	method void SaveToDB(table saveData)
		-- 플레이어 계정 정보를 데이터베이스에 저장하는 함수
		local dbTable = {}
		
		local playerComponent = self.Entity.PlayerComponent
		dbTable["Nickname"] = playerComponent.Nickname
		dbTable["ProfileCode"] = playerComponent.ProfileCode
		dbTable["Date_Create"] = self.Date_Create 
		dbTable["Date_Last_Login"] = self.Date_Login
		dbTable["Date_Last_Logout"] = self.Date_Logout
		
		saveData[self.DBKey] = dbTable
	end

	@ExecSpace("ServerOnly")
	method void OnLoadedDataFromDB(table loadedData)
		-- 데이터베이스에서 로드된 계정 데이터를 처리하는 함수
		local dbTable = loadedData[self.DBKey]
		if dbTable == nil then
			dbTable = {}
		end
		
		if #table.keys(dbTable) > 0 then
			self.Date_Create = dbTable["Date_Create"]
			self.Date_Login = dbTable["Date_Last_Login"]
			self.Date_Logout = dbTable["Date_Last_Logout"]
		else
			self:OnCreated()
		end
	end

	@ExecSpace("ServerOnly")
	method void OnCreated()
		-- 계정 생성 시 생성일시를 설정하는 함수
		self.Date_Create = os.time(os.date("!*t"))
	end

	@ExecSpace("ServerOnly")
	method void OnLogin()
		-- 플레이어 로그인 시 로그인 시간을 기록하는 함수
		self.Date_Login = os.time(os.date("!*t"))
	end

	@ExecSpace("ServerOnly")
	method void OnLogout()
		-- 플레이어 로그아웃 시 로그아웃 시간을 기록하는 함수
		self.Date_Logout = os.time(os.date("!*t"))
	end

end