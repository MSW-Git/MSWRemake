@Struct
script ManagementGoalData

	property integer Level = 0

	property table IndexData = {}

	method void Load(integer level, table rows)
		-- 특정 레벨의 관리 목표 데이터를 CSV 행들로부터 로드하는 함수
		self.Level = level
		
		local indexDatas = {}
		for i = 1, #rows do
			---@type UserDataRow
			local row = rows[i]
			
			if tonumber(row:GetItem("Level")) == self.Level then
				local index = tonumber(row:GetItem("Index"))
				local indexData = ManagementGoalIndexData()
				indexData:Load(row)
				indexDatas[index] = indexData
			end
		end
		
		self.IndexData = indexDatas
	end

end