@Struct
script ManagementGoalIndexData

	property integer AchievementType = 0

	property integer TypeValue = 0

	method void Load(any rowData)
		-- CSV 데이터에서 업적 타입과 목표값을 로드하는 함수
		self.AchievementType = tonumber(rowData:GetItem("AchievementType"))
		self.TypeValue = tonumber(rowData:GetItem("TypeValue"))
	end

end