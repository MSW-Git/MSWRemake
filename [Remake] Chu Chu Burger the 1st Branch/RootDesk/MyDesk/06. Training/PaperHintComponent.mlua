@Component
script PaperHintComponent extends Component

	property string type = ""

	method void SetPaperHint(string type)
		-- 종이 힌트의 타입을 설정하는 함수
		self.type = type
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 시 종이 힌트 아이콘을 여는 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Btn_OpenPaperHint"], 1)
		_UserService.LocalPlayer.PlayerTrainingManager:OnClickPaperHintIcon(self.Entity)
	end

end