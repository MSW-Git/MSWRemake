@Component
script UITrainingSetting extends Component

	property Entity EmployeeScroll = "fdd74a3a-2fbc-4472-9fe5-4ca387a2f875"

	property Entity SelectedEmployeeScroll = "9e1a40c9-bd1f-4394-9594-3f35c0bc214f"

	property SyncTable<integer, string> SelectedEmpList

	property SyncTable<string, Entity> ListSlotEntities

	property table SlotHandlers = {}

	property string SelectedEmployeeId = ""

	property Entity EmployeeDetail = "0a461ae5-77b9-4a1c-a65d-db333c58cb5c"

	property Entity SelectedSlot1 = "cadb01f1-5bb3-4c69-8acc-cd87e6f47297"

	property Entity SelectedSlot2 = "77717bfb-5e49-4def-9f8b-26f6b0d7db95"

	property Entity SelectedSlot3 = "d122e260-c0d2-4a2a-8379-06c200f739eb"

	property Entity EnterCountEntity = "ce5dc5ac-1730-4d1e-964e-524a9455d0eb"

	property Entity OkButton = "e83b743d-4909-4295-b44a-fdef2ede53e4"

	property integer CheckHalfYear = 1

	property Entity UpgradePanel = "792dae8e-b1e5-4eed-9271-415fe85f7c8b"

	property table UpgradeIdList = {30003, 30004, 30005}

	property SyncTable<integer, string> ChuchuIndexTable

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 훈련 설정 UI를 초기화하는 함수
		self.SelectedSlot1:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
			    return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
			self:OnClickSelectedSlot(1) 
		end)
		
		self.SelectedSlot2:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
			    return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
			self:OnClickSelectedSlot(2) 
		end)
		
		self.SelectedSlot3:ConnectEvent(ButtonClickEvent, function() 
			if _UIGroupManager:IsEnableOpenPopUp() == false then
			    return
			end
			_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
			self:OnClickSelectedSlot(3) 
		end)
		
		self._T.UpgradeBtnEntities = {}
		for i = 1, 3 do
			local entity = self.UpgradePanel:GetChildByName("UpgradeBtn".._StringUtilLogic:NumToString(i))
			table.insert(self._T.UpgradeBtnEntities, entity)
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OpenTrainingSettingUI()
		-- 훈련 설정 UI를 여는 함수
		self.Entity.Enable = true
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(true)
		
		_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		
		self:DisplayEmployeeScroll()
		self:UpdateStartButtonDim()
		self:UpdateSelectedScroll(self.SelectedEmpList)
		self:UpdateUpgradeInfo()
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.TrainingSettingEnter)
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.TrainingSettingEnter2)
	end

	@ExecSpace("ClientOnly")
	method void OnClickStartButton()
		-- 시작 버튼 클릭 시 처리하는 함수
		_UserService.LocalPlayer.PlayerTrainingManager:OnClickTrainingButton()
	end

	@ExecSpace("ClientOnly")
	method void CloseTrainingSettingUI()
		-- 훈련 설정 UI를 닫는 함수
		self.Entity.Enable = false
		_UserService.LocalPlayer.PlayerTrainingManager:SetSelectedChuchuIdList(self.SelectedEmpList) 
		_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		_UIGroupManager:EnableMoneyBarGroup(nil)
		_UIGroupManager:EnableBackToLobbyBtn(false)
	end

	@ExecSpace("ClientOnly")
	method void RefreshDetail(string employeeId)
		-- 직원 상세 정보를 새로고침하는 함수
		self.SelectedEmployeeId = employeeId
		
		for i, entity in pairs(self.EmployeeScroll.Children) do
			if _UtilLogic:Contains(entity.Name, "Item") then
				local empId = entity.UIEmployeeManageListRenderer.EmployeeId
				if empId == employeeId then
					entity.UIEmployeeManageListRenderer:EnableOutline()
				else
					entity.UIEmployeeManageListRenderer:DisableOutline()
				end
			end
		end
		
		self.EmployeeDetail.UIRecipeEmployeeDetail:Refresh(employeeId)
	end

	@ExecSpace("ClientOnly")
	method void DisplayEmployeeScroll()
		-- 직원 스크롤을 표시하는 함수
		
		
		local player = _UserService.LocalPlayer
		local myEmployees = player.EmployeeManager.EmployeeDetailTable
		
		local drawList = {}
		local drawFirst = {}
		local drawLast = {}
		for i, employee in pairs(myEmployees) do
			local hasTrainingSkill = _EmployeeSkillService:HasSkillOfType(employee.Id, "Training", player)
			if hasTrainingSkill then
				table.insert(drawFirst, employee.Id)
			else
				table.insert(drawLast, employee.Id)
			end
		end
		
		for i = 1, #drawFirst do
			table.insert(drawList, drawFirst[i])
		end
		for i = 1, #drawLast do
			table.insert(drawList, drawLast[i])
		end
		
		for i = 1, #drawList do
			self.ChuchuIndexTable[i] = drawList[i]
		end
		
		self:RegisterRecycleScrollLayoutCallback()
		
		local count = #table.keys(drawList)
		self.EmployeeScroll.RecycleScrollView:SetTotalCount(count)
		self.EmployeeScroll.RecycleScrollView:Refresh(true)
		
		for i, entity in pairs(self.EmployeeScroll.Children) do
			if _UtilLogic:Contains(entity.Name, "Item") then
				local index = entity.UIEmployeeManageListRenderer.Index
				if index == 1 then
					local empId = entity.UIEmployeeManageListRenderer.EmployeeId
					self:RefreshDetail(empId)
				end
				if index < 1 or  index > count then
					entity.Enable = false
				else
					entity.Enable = true
				end
				entity:GetChildByName("Select").Enable = false
			end
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void AddSelectedScroll(string employeeId)
		-- 선택된 직원을 스크롤에 추가하는 함수
		if _UtilLogic:IsNilorEmptyString(employeeId) then
			return
		end
		
		local autoSlotNum = 0
		for i = 1, 3 do
			---@type AutoTrainingSlotData
			local slotData = _UserService.LocalPlayer.PlayerAutoTrainingManager.AutoTrainingSlotInfoTable[i]
			if isvalid(slotData.ChuchuId) and slotData.ChuchuId == employeeId then
				autoSlotNum = i
				break
			end
		end
		if autoSlotNum > 0 then
			local slotData = _UserService.LocalPlayer.PlayerAutoTrainingManager.AutoTrainingSlotInfoTable[autoSlotNum] 
			if slotData.State == _AutoTrainingUIStateEnum.OnProgress then
				_UIToast:ShowMessage(_LocalizationService:GetText("CantSelectAutoTrainingChuchu"))
				return
			end
		end
		
		---@type Entity
		local slot
		for i = 1, 3 do
			if isvalid(self.SelectedEmpList[i]) == false then
				self.SelectedEmpList[i] = employeeId
				slot = self.SelectedEmployeeScroll:GetChildByName("EmployeeListSlot_IconVer"..tostring(math.tointeger(i)))
				break
			end
		end
		
		if isvalid(slot) then
			self:SetSelectedSlot(slot, employeeId)
			self:RecycleScrollOnUpdateByEmpId(employeeId)
		else
			_UIToast:ShowMessage(_LocalizationService:GetText("TrainingSettingSlotIsFull"))
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickSelectButton()
		-- 선택 버튼 클릭 시 처리하는 함수
		
		if self.SelectedEmployeeId then
			local slotEntity = self:ReturnEntityByEmpId(self.SelectedEmployeeId)
			if slotEntity:GetChildByName("Disable").Enable then
				if slotEntity:GetChildByName("Disable"):GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID.DataId == _IconRuidEnum.CheckSign then
					_UIToast:ShowMessage(_LocalizationService:GetText("TrainingSettingAlreadySelect"))
				else
					_UIToast:ShowMessage(_LocalizationService:GetText("CantSelectAutoTrainingChuchu"))
				end
				return
			end
			self:AddSelectedScroll(self.SelectedEmployeeId)
		else
			_UIToast:ShowMessage(_LocalizationService:GetText("TrainingSettingSelectChuchu"))
		end
		
	end

	@ExecSpace("ClientOnly")
	method void OnClickSelectedSlot(integer slotNum)
		-- 선택된 슬롯 클릭 시 처리하는 함수
		
		local empId = self.SelectedEmpList[slotNum] 
		local entity = self:ReturnEntityByEmpId(empId)
		self:EmptySelectedSlot(slotNum)
		
		if isvalid(entity) then
			self:RecycleScrollOnUpdateByEmpId(empId)
		end
	end

	@ExecSpace("ClientOnly")
	method void EmptySelectedSlot(integer slotNum)
		-- 선택된 슬롯을 비우는 함수
		local slot = self.SelectedEmployeeScroll:GetChildByName("EmployeeListSlot_IconVer"..tostring(math.tointeger(slotNum)))
		
		slot:GetChildByName("Portrait").Enable = false
		slot:GetChildByName("SkillIcon").Enable = false
		slot.SpriteGUIRendererComponent.ImageRUID = ""
		slot.SpriteGUIRendererComponent.Color.a = 0 
		slot.ButtonComponent.Enable = false
		slot:GetChildByName("Btn_UnEquiped").Enable = false
		
		self.SelectedEmpList[slotNum] = nil
	end

	@ExecSpace("Client")
	method integer GetSelectedChuchuNum()
		-- 선택된 캐릭터 수를 반환하는 함수
		local count = 0
		for i = 1, 3 do
			if isvalid(self.SelectedEmpList[i]) then
				count += 1
			end
		end
		
		return count
	end

	method table GetSelectedChuchuList()
		-- 선택된 캐릭터 목록을 반환하는 함수
		return self.SelectedEmpList
	end

	@ExecSpace("Client")
	method void UpdateSelectedScroll(table chuchuIds)
		-- 선택된 스크롤을 업데이트하는 함수
		for i = 1, 3 do
			if _UtilLogic:IsNilorEmptyString(chuchuIds[i]) == false and _UserService.LocalPlayer.EmployeeManager:CheckEmployeeAlreadyHave(chuchuIds[i]) == true then
				local employeeId = chuchuIds[i]
				local slot = self.SelectedEmployeeScroll:GetChildByName("EmployeeListSlot_IconVer"..tostring(math.tointeger(i)))
		
				if isvalid(slot) then
					self:SetSelectedSlot(slot, employeeId) 
					self:RecycleScrollOnUpdateByEmpId(employeeId)
				end
			else
				self:EmptySelectedSlot(i)
			end
		end
		
	end

	@ExecSpace("Client")
	method void UpdateSelectedList(table chuchuIds)
		-- 선택된 목록을 업데이트하는 함수
		for i = 1, 3 do
			self.SelectedEmpList[i] = chuchuIds[i]
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateStartButtonDim()
		-- 시작 버튼의 딩 상태를 업데이트하는 함수
		local playerInven = _UserService.LocalPlayer.PlayerInventory
		local lunchBox = playerInven.LunchBox
		local ticket = playerInven.TrainingTicket
		local dimEnable = false
		if ticket < 1 then
			dimEnable = true
		elseif lunchBox < _UserService.LocalPlayer.PlayerTrainingManager.RequireTokenNum then
			dimEnable = true
		end
		
		local okButton = _EntityService:GetEntityByPath("/ui/TrainingSettingGroup/Panel/OkButton")
		okButton:GetChildByName("Dim").Enable = dimEnable
		okButton:GetChildByName("Icon"):GetChildByName("IconDim").Enable = dimEnable
		
		if dimEnable then
			okButton:GetChildByName("Text").TextComponent.FontColor = _ColorCodeEnum:GetColor("#8C8C8C")
			okButton:GetChildByName("Text").TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#06252d")
		else
			okButton:GetChildByName("Text").TextComponent.FontColor = _ColorCodeEnum:GetColor("#ffffff")
			okButton:GetChildByName("Text").TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#04637b")
		end
		
		self:UpdateTrainingTicketUI()
	end

	@ExecSpace("ClientOnly")
	method void UpdateTrainingTicketUI()
		-- 훈련 티켓 UI를 업데이트하는 함수
		local playerInven = _UserService.LocalPlayer.PlayerInventory
		local ticket = playerInven.TrainingTicket 
		local countText = self.EnterCountEntity:GetChildByName("CountText")
		local nameText = self.EnterCountEntity:GetChildByName("NameText")
		
		if self.CheckHalfYear == 2 then
			nameText.TextComponent.Text = _LocalizationService:GetText("SecondHalf")
		else
			nameText.TextComponent.Text = _LocalizationService:GetText("FirstHalf")
		end
		
		if ticket < 1 then 
			countText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			countText.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#415E92")
			nameText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			nameText.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#415E92")
		else
			countText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#ffffff")
			countText.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#415E92")
			nameText.TextComponent.FontColor = _ColorCodeEnum:GetColor("#ffffff")
			nameText.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#415E92")
		end
		countText.TextComponent.Text = _LocalizationService:SmartFormat("{0}/2", ticket)
		
		self:UpdateParkingAreaInfo()
	end

	@ExecSpace("ClientOnly")
	method void SetSelectedSlot(Entity slot, string employeeId)
		-- 선택된 슬롯을 설정하는 함수
		---@type EmployeeData
		local data = _EmployeeService:GetData(employeeId)
		local portraitEntity = slot:GetChildByName("Portrait")
		_EmployeeUIService:DrawPortraitWithEquip(portraitEntity, portraitEntity, data)
		
		
		local hasTrainingSkill = _EmployeeSkillService:HasSkillOfType(data.Id, "Training", _UserService.LocalPlayer)
		if hasTrainingSkill == true then
			slot:GetChildByName("SkillIcon").SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum:GetSkillTypeIcon("Training")
			slot:GetChildByName("SkillIcon").Enable = true
		else
			slot:GetChildByName("SkillIcon").Enable = false
		end
		
		slot.SpriteGUIRendererComponent.ImageRUID = ""
		slot.SpriteGUIRendererComponent.Color.a = 0 
		slot.ButtonComponent.Enable = true
		slot:GetChildByName("Btn_UnEquiped").Enable = true
		
		
	end

	@ExecSpace("ClientOnly")
	method void OnClickUpgradeBtn(integer btnNum)
		-- 업그레이드 버튼 클릭 시 처리하는 함수
		local upgradeId = 30003
		if isvalid(self.UpgradeIdList[btnNum]) then
			upgradeId = self.UpgradeIdList[btnNum]
		end
		
		_UpgradeDataSetLogic.UIUpgradePanel.UIUpgradePanel:Open(upgradeId)
	end

	@ExecSpace("Client")
	method void UpdateUpgradeInfo()
		-- 업그레이드 정보를 업데이트하는 함수
		local player = _UserService.LocalPlayer
		
		for btnNum, upgradeId in pairs(self.UpgradeIdList) do
			local data = _UpgradeDataSetLogic:GetData(upgradeId)
			---@type Entity
			local entity = self._T.UpgradeBtnEntities[btnNum]
			entity:GetChildByName("Name").TextComponent.Text = _GetLocalizationTextLogic:GetText(data.NameKey)
			entity:GetChildByName("Level").TextComponent.Text = "Lv."..tostring(_UpgradeDataSetLogic:ReturnCurrentPlayerLevel(player, upgradeId))
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateParkingAreaInfo()
		-- 주차장 영역 정보를 업데이트하는 함수
		local parkingArea = _LobbyRenovationService:GetParkingAreaEntity()
		if not isvalid(parkingArea) then
			return
		end
		
		local check = false
		local info = parkingArea:GetChildByName("Info_Truck")
		local goMark = info:GetChildByName("UISprite")
		
		local playerInven = _UserService.LocalPlayer.PlayerInventory
		local ticket = playerInven.TrainingTicket 
		info.TextComponent.Text = _LocalizationService:SmartFormat("{0}/2", ticket)
		info.Enable = true
		
		if ticket < 1 then 
			info.TextComponent.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			info.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#415E92")
			goMark.Enable = false
		else
			info.TextComponent.FontColor = _ColorCodeEnum:GetColor("#ffffff")
			info.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#415E92")
			goMark.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickTruckArea()
		-- 트럭 영역 클릭 시 처리하는 함수
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OpenTrainingSettingUI()
	end

	@ExecSpace("ClientOnly")
	method void RegisterRecycleScrollLayoutCallback()
		-- 리사이클 스크롤 콜백을 등록하는 함수
		if self.EmployeeScroll.RecycleScrollView.onUpdateCell ~= nil then
			return
		end
		
		local recycleFunc = function(index, entity)
			self:RecycleScrollOnUpdateByIndex(index, entity)
		end
		self.EmployeeScroll.RecycleScrollView.onUpdateCell = recycleFunc
	end

	@ExecSpace("ClientOnly")
	method void RecycleScrollOnUpdateByIndex(integer index, Entity entity)
		-- 인덱스로 리사이클 스크롤을 업데이트하는 함수
		local empId = self:CalcEmpIdFromIndex(index)
		entity.UIEmployeeManageListRenderer:Init_Training(index, empId, false)
	end

	@ExecSpace("ClientOnly")
	method string CalcEmpIdFromIndex(integer index)
		-- 인덱스로부터 직원 ID를 계산하는 함수
		local empId = self.ChuchuIndexTable[index]
		
		return empId
	end

	@ExecSpace("ClientOnly")
	method Entity ReturnEntityByEmpId(string empId)
		-- 직원 ID로부터 엔티티를 반환하는 함수
		local target
		for i, entity in pairs(self.EmployeeScroll.Children) do
			if _UtilLogic:Contains(entity.Name, "Item") then
				if entity.UIEmployeeManageListRenderer.EmployeeId == empId then
					target = entity
					break
				end
			end
		end
		
		return target
	end

	@ExecSpace("ClientOnly")
	method void RecycleScrollOnUpdateByEmpId(string empId)
		-- 직원 ID로 리사이클 스크롤을 업데이트하는 함수
		local entity = self:ReturnEntityByEmpId(empId)
		if isvalid(entity) then
			local index = entity.UIEmployeeManageListRenderer.Index
			entity.UIEmployeeManageListRenderer:Init_Training(index, empId, false)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "910a41c2-a270-464a-b888-25aea19d78bb")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 훈련 설정 UI 열기 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OpenTrainingSettingUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "e83b743d-4909-4295-b44a-fdef2ede53e4")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- OK 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickStartButton()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "2dd851b5-788e-4cdc-8c78-eae0555d0479")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseTrainingSettingUI()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "6ecd084a-eb93-40d2-930e-5231cda5b21a")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 선택 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickSelectButton()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "37f28832-83d3-49ce-950c-2049ab7b3f88")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 직원 업그레이드 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		if isvalid(self.SelectedEmployeeId) then
			local category = _EmployeeService:GetData(self.SelectedEmployeeId).Type
			_EmployeeUpgradeUIServcie:UIOpen(self.SelectedEmployeeId)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5955ba7b-c7b0-42e1-a9ac-ff75a3a2a33b")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 상점 열기 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		local uiShop = _UIGroupManager.ShopGroup:GetChildByName("UIShop")
		uiShop.UIShop:Open("GeneralShop", "5") 
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "85e36de7-ca81-48f6-9dc7-fd94f48cde3e")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 1번 업그레이드 버튼 클릭 이벤트 핸들러
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickUpgradeBtn(1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "cfcc9e92-2625-437b-9925-1c665f8190e9")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 2번 업그레이드 버튼 클릭 이벤트 핸들러
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickUpgradeBtn(2)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "150c7950-dcb6-4be3-b6a6-d0fa387bdbeb")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 3번 업그레이드 버튼 클릭 이벤트 핸들러
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickUpgradeBtn(3)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "37f60e0d-94fd-43a0-bf54-a03d4ba8793e")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- 상점 열기 버튼 클릭 이벤트 핸들러 2
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		local uiShop = _UIGroupManager.ShopGroup:GetChildByName("UIShop")
		uiShop.UIShop:Open("GeneralShop", "5") 
	end

	@EventSender("LocalPlayer")
	handler HandleEmployeeDetailChangeEvent(EmployeeDetailChangeEvent event)
		-- 직원 상세 정보 변경 이벤트를 처리하는 핸들러
		if self.Entity.Enable == true then
			if _UtilLogic:IsNilorEmptyString(self.SelectedEmployeeId) then
				return
			end
			self:RefreshDetail(self.SelectedEmployeeId)
		end
	end

end