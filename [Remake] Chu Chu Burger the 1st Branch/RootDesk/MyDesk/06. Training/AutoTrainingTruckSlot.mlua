@Component
script AutoTrainingTruckSlot extends Component

	property boolean isLocked = true

	property string ChuChuId = ""

	@ExecSpace("ClientOnly")
	method void SetLock()
		-- 슬롯을 잠금 상태로 설정하는 함수
		self.isLocked = true
		self:SwitchLockPanel(true)
	end

	@ExecSpace("ClientOnly")
	method void SetUnlock()
		-- 슬롯을 잠금 해제 상태로 설정하는 함수
		self.isLocked = false
		self:SwitchLockPanel(false)
	end

	@ExecSpace("ClientOnly")
	method void SwitchLockPanel(boolean isLocked)
		-- 잠금 상태에 따라 UI 패널을 전환하는 함수
		self:ChangeUIOnState(_AutoTrainingUIStateEnum.Default)
		local truckImg = self.Entity:GetChildByName("TruckImg")
		local coverSprite = truckImg:GetChildByName("Cover")
		local chuchuSlot = truckImg:GetChildByName("Model_EmployeeListSlot")
		local okButton = self.Entity:GetChildByName("OkButton")
		local btnDim = okButton:GetChildByName("Dim")
		local dimText = btnDim:GetChildByName("UIText")
		local lockIcon = okButton:GetChildByName("LockIcon")
		
		local panel = self.Entity:GetChildByName("InfoPanel")
		local stateText = panel:GetChildByName("StateText")
		local timerPanel = panel:GetChildByName("TimerPanel")
		
		if isLocked then
			lockIcon.Enable = true
			btnDim.Enable = true
			dimText.Enable = false
			timerPanel.Enable = false
			stateText.Enable = true
			coverSprite.Enable = true
			chuchuSlot.Enable = false
			chuchuSlot.ButtonComponent.Enable = false
			stateText.TextComponent.Text = _LocalizationService:GetText("AutoTrainingScooterOpenCondition")
			
		else
			lockIcon.Enable = false
			btnDim.Enable = false
			timerPanel.Enable = true
			stateText.Enable = false
			coverSprite.Enable = false
			chuchuSlot.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void ChangeUIOnState(string state)
		-- 상태에 따라 UI를 변경하는 함수
		local panel = self.Entity:GetChildByName("InfoPanel")
		local stateText = panel:GetChildByName("StateText") 
		local timerPanel = panel:GetChildByName("TimerPanel")
		local timeUIText = timerPanel:GetChildByName("UIText")
		local timeText = timerPanel:GetChildByName("Time")
		local truckImg = self.Entity:GetChildByName("TruckImg")
		local chuchuSlot = truckImg:GetChildByName("Model_EmployeeListSlot")
		local noParkingSign = self.Entity:GetChildByName("NoParkingSign")
		local coverSprite = truckImg:GetChildByName("Cover")
		
		local okButton = self.Entity:GetChildByName("OkButton")
		local buttonText = okButton:GetChildByName("ButtonText")
		local lunchBox = okButton:GetChildByName("LunchBox")
		local btnDim = okButton:GetChildByName("Dim")
		local lockIcon = okButton:GetChildByName("LockIcon")
		local dimText = btnDim:GetChildByName("UIText")
		local balloon = self.Entity:GetChildByName("Balloon")
		
		
		
		if state == _AutoTrainingUIStateEnum.OnProgress then
			
			btnDim.Enable = true
			dimText.Enable = true
			timerPanel.Enable = true
			stateText.Enable = false
			timeUIText.TextComponent.Text = _LocalizationService:GetText("AutoTrainingRemainTimeText")
			noParkingSign.Enable = true
			truckImg.Enable = false
			chuchuSlot.Enable = false
			chuchuSlot.ButtonComponent.Enable = false
			buttonText.TextComponent.Alignment = TextAlignmentType.MiddleRight
			buttonText.TextComponent.Text =  _LocalizationService:GetText("Depart")
			lunchBox.Enable = true
			
			
		elseif state == _AutoTrainingUIStateEnum.WaitingReward then
			
			btnDim.Enable = false
			timerPanel.Enable = false
			stateText.Enable = true
			stateText.TextComponent.Text = _LocalizationService:GetText("Arrive")
			balloon.Enable = true
			noParkingSign.Enable = false
			truckImg.Enable = true
			chuchuSlot.Enable = true
			chuchuSlot.ButtonComponent.Enable = false
			
			buttonText.TextComponent.Alignment = TextAlignmentType.MiddleCenter
			buttonText.TextComponent.Text =  _LocalizationService:GetText("AutoTrainingRewardBtn")
			okButton.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.BlinkMaterial)
			lunchBox.Enable = false
			
			
		else 
			
			btnDim.Enable = false
			dimText.Enable = false
			timerPanel.Enable = true
			stateText.Enable = false
			timeUIText.TextComponent.Text = _LocalizationService:GetText("AutoTrainingTimeText")
			timeText.TextComponent.Text = _LocalizationService:GetTextFormat("Day_Format", _UserService.LocalPlayer.PlayerAutoTrainingManager.TrainingTime)
			balloon.Enable = false
			noParkingSign.Enable = false
			truckImg.Enable = true
			chuchuSlot.Enable = true
			chuchuSlot.ButtonComponent.Enable = true
			
			buttonText.TextComponent.Alignment = TextAlignmentType.MiddleRight
			buttonText.TextComponent.Text =  _LocalizationService:GetText("Depart")
			okButton.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
			lunchBox.Enable = true
			
		end
		
		if self.isLocked then
			btnDim.Enable = true
			dimText.Enable = false
			chuchuSlot.Enable = false
			chuchuSlot.ButtonComponent.Enable = false
			timerPanel.Enable = false
			coverSprite.Enable = true
			lockIcon.Enable = true
			stateText.Enable = true
			stateText.TextComponent.Text = _LocalizationService:GetText("AutoTrainingScooterOpenCondition")
			balloon.Enable = false
		end
		
		self:ChangeUIOnState_ParkingArea(state)
		
	end

	@ExecSpace("Client")
	method void UpdateTimeText(integer time)
		-- 시간 텍스트를 업데이트하는 함수
		local panel = self.Entity:GetChildByName("InfoPanel")
		local timerPanel = panel:GetChildByName("TimerPanel")
		local timeText = timerPanel:GetChildByName("Time")
		if not isvalid(time) then
			time = _UserService.LocalPlayer.PlayerAutoTrainingManager.TrainingTime
		end
		timeText.TextComponent.Text = _LocalizationService:GetTextFormat("Day_Format", time)
		self:UpdateTimeText_ParkingArea(time)
	end

	@ExecSpace("ClientOnly")
	method void EnableOkButtonDim(boolean enable)
		-- OK 버튼의 딤 상태를 설정하는 함수
		local okButton = self.Entity:GetChildByName("OkButton")
		local dim = okButton:GetChildByName("Dim")
		dim.Enable = enable
	end

	@ExecSpace("ClientOnly")
	method void SetOkBtnLunchBoxNum(integer count)
		-- OK 버튼에 도시락 개수를 설정하는 함수
		local okButton = self.Entity:GetChildByName("OkButton")
		local entity = okButton:GetChildByName("LunchBox"):GetChildByName("Count")
		entity.TextComponent.Text = _StringUtilLogic:NumToString(count)
	end

	@ExecSpace("ClientOnly")
	method void UpdateTimeText_ParkingArea(integer time)
		-- 주차장 영역의 시간 텍스트를 업데이트하는 함수
		local parkingArea = _LobbyRenovationService:GetParkingAreaEntity()
		if not isvalid(parkingArea) then
			return
		end
		local num = _UtilLogic:Trim(self.Entity.Name, "TruckSlot_")
		local info = parkingArea:GetChildByName("Info_"..num) 
		info.TextComponent.Text = _LocalizationService:GetTextFormat("Day_Format", time)
		if time < 1 then
			info.TextComponent.Text = _LocalizationService:GetText("Arrive")
		end
	end

	@ExecSpace("ClientOnly")
	method void ChangeUIOnState_ParkingArea(string state)
		-- 주차장 영역의 UI 상태를 변경하는 함수
		local parkingArea = _LobbyRenovationService:GetParkingAreaEntity()
		if not isvalid(parkingArea) then
			return
		end
		local num = _UtilLogic:Trim(self.Entity.Name, "TruckSlot_")
		local scooter = parkingArea:GetChildByName("Scooter_"..num)
		local noParkingSign =  parkingArea:GetChildByName("NoParkingSign_"..num)
		local info = parkingArea:GetChildByName("Info_"..num)
		local cover = scooter:GetChildByName("Cover")
		
		
		if state == _AutoTrainingUIStateEnum.OnProgress then
			
			scooter.Enable = false
			noParkingSign.Enable = true
			info.Enable = true
			
		elseif state == _AutoTrainingUIStateEnum.WaitingReward then
			
			scooter.Enable = true
			noParkingSign.Enable = false
			info.Enable = true
			info.TextComponent.Text =  _LocalizationService:GetText("Arrive")
			
		elseif state == _AutoTrainingUIStateEnum.Locked then
			
			scooter.Enable = true
			cover.Enable = true
			noParkingSign.Enable = false
			info.Enable = false
			
		else 
			
			scooter.Enable = true
			noParkingSign.Enable = false
			info.Enable = false
			
		end
	end

end