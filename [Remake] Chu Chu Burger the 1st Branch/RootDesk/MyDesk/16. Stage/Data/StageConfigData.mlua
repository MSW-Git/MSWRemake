@Struct
script StageConfigData

	property integer StageId = 0

	property number UpgradeCostRate = 0

	property number MaintainCostRate = 0

	property number SalaryCostRate = 0

	property number EmploymentCostRate = 0

	property number OverLimitCostRate = 0

	property number TipDropValueRate = 0

	property number BurgerPriceRate = 0

	property number TrainingMoneyRate = 0

	property number AchievementMoneyRate = 0

	property number ServingWorkProgressAdd = 0

	property number CookWorkProgressAdd = 0

	property integer GrillUpgradeMaxLevel = 0

	property integer CounterUpgradeMaxLevel = 0

	property number TrialCostRate = 0

	property integer StrategyStartWithGoldEarningLevel = 0

	property number OfflineRewardBonusPercent = 0

	property number ExchangeBaseMoneyRate = 0

	property integer FixedPositiveTrendId = 0

	property integer TrainingReputationRewardRate = 0

	method void Load(any dataTable, integer index)
		-- CSV 데이터를 읽어서 스테이지 설정 데이터를 로드하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.StageId = tonumber(row:GetItem("StageId"))
		self.UpgradeCostRate = tonumber(row:GetItem("UpgradeCostRate"))
		self.MaintainCostRate = tonumber(row:GetItem("MaintainCostRate"))
		self.SalaryCostRate = tonumber(row:GetItem("SalaryCostRate"))
		self.EmploymentCostRate = tonumber(row:GetItem("EmploymentCostRate"))
		self.TipDropValueRate = tonumber(row:GetItem("TipDropValueRate"))
		self.BurgerPriceRate = tonumber(row:GetItem("BurgerPriceRate"))
		self.TrainingMoneyRate = tonumber(row:GetItem("TrainingMoneyRate"))
		self.AchievementMoneyRate = tonumber(row:GetItem("AchievementMoneyRate"))
		self.ServingWorkProgressAdd = tonumber(row:GetItem("ServingWorkProgressAdd"))
		self.CookWorkProgressAdd = tonumber(row:GetItem("CookWorkProgressAdd"))
		self.GrillUpgradeMaxLevel = tonumber(row:GetItem("GrillUpgradeMaxLevel"))
		self.CounterUpgradeMaxLevel = tonumber(row:GetItem("CounterUpgradeMaxLevel"))
		self.TrialCostRate = tonumber(row:GetItem("TrialCostRate"))
		self.OverLimitCostRate = tonumber(row:GetItem("OverLimitCostRate"))
		self.StrategyStartWithGoldEarningLevel = tonumber(row:GetItem("StrategyStartWithGoldEarningLevel"))
		self.OfflineRewardBonusPercent = tonumber(row:GetItem("OfflineRewardBonusPercent"))
		self.ExchangeBaseMoneyRate = tonumber(row:GetItem("ExchangeBaseMoneyRate"))
		self.FixedPositiveTrendId = tonumber(row:GetItem("FixedPositiveTrendId"))
		self.TrainingReputationRewardRate = tonumber(row:GetItem("TrainingReputationRewardRate"))
	end

end