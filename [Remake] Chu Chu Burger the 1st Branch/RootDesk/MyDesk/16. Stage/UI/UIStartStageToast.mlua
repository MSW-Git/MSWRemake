@Component
script UIStartStageToast extends Component

	property Entity BG = nil

	property Entity IconHolder = nil

	property SpriteGUIRendererComponent IconSprite = nil

	property TextComponent NameText = nil

	property Entity Particle = nil

	property SpriteGUIRendererComponent Blur = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 UI를 비활성화하는 함수
		self.Entity.Enable = false
	end

	method void Init()
		-- UI 컴포넌트들을 초기화하는 함수
		self.BG = self.Entity:GetChildByName("BG")
		self._T.bgOriginHeight = self.BG.UITransformComponent.RectSize.y
		
		self.IconHolder = self.Entity:GetChildByName("IconHolder")
		self.IconSprite = self.IconHolder:GetChildByName("Icon").SpriteGUIRendererComponent
		self.NameText = self.Entity:GetChildByName("Name").TextComponent
		
		self.Blur = self.Entity:GetChildByName("Blur").SpriteGUIRendererComponent
		
		self.Particle = self.Entity:GetChildByName("Particle")
	end

	@ExecSpace("ClientOnly")
	method void Open(integer stageId)
		-- 스테이지 시작 토스트 UI를 여는 함수
		if self.BG == nil then
			self:Init()
		end
		
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		if stageData == nil then
			return
		end
		
		self.BG.UITransformComponent.RectSize = Vector2(self.BG.UITransformComponent.RectSize.x, 0)
		self.IconHolder.CanvasGroupComponent.GroupAlpha = 0
		self.NameText.FontColor.a = 0
		self.NameText.OutlineColor.a = 0
		self.NameText.DropShadow = false
		self.Entity.CanvasGroupComponent.GroupAlpha = 1
		self.Blur.Color.a = 0
		self.Particle.Enable = false
		
		self.Entity.Enable = true
		
		self.IconSprite.ImageRUID = stageData.IconRUID
		self.NameText.Text = _GetLocalizationTextLogic:GetText(stageData.NameKey)
		
		self:StartRender()
	end

	method void StartRender()
		-- 토스트 애니메이션을 시작하는 함수
		local shortDuration = 0.6
		local duration = 1
		
		_TweenLogic:PlayTween(0, self._T.bgOriginHeight, shortDuration, EaseType.SineEaseOut, function(t)
			self.BG.UITransformComponent.RectSize = Vector2(self.BG.UITransformComponent.RectSize.x, t)
		end)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Open_Reputation"], 0.6)
		
		self._T.timer = _TimerService:SetTimerOnce(function()
			self.Particle.Enable = true
			_SoundService:PlaySound(_ResourceManager.SFXTable["Bell"], 1)
			
			_TweenLogic:PlayTween(0, 1, duration, EaseType.Linear, function(t)
				self.IconHolder.CanvasGroupComponent.GroupAlpha = t
				self.NameText.FontColor.a = t
				self.NameText.OutlineColor.a = t
				self.Blur.Color.a = t		
			end)
			
			self._T.timer = _TimerService:SetTimerOnce(function()
				self.NameText.DropShadow = true
				
				self._T.timer = _TimerService:SetTimerOnce(function()
					_TweenLogic:PlayTween(1, 0, duration, EaseType.Linear, function(t)
						self.Entity.CanvasGroupComponent.GroupAlpha = t
					end)
					
					self._T.timer = _TimerService:SetTimerOnce(function()
						self.Entity.Enable = false
					end, duration)
					
				end, duration)		
				
			end, duration*2)
			
		end, shortDuration * 0.7)
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		-- 컴포넌트 종료 시 타이머를 정리하는 함수
		if isvalid(self._T.timer) == true then
			_TimerService:ClearTimer(self._T.timer)
		end
	end

	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키 입력 이벤트를 처리하는 핸들러
		
		 local key = event.key
		
	end

end