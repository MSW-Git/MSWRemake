@Component
script UIStageInfoEmployee extends Component

	property ScrollLayoutGroupComponent StartingEmpList = nil

	property Entity StartingEmpEmpty = nil

	property TextComponent StageEmpTitle = nil

	property ScrollLayoutGroupComponent StageEmpList = nil

	property Entity EmpSlotSample = nil

	method void Init()
		-- UI 컴포넌트들을 초기화하는 함수
		local info = self.Entity:GetChildByName("Info"):GetChildByName("Text")
		local moveSpeedBonus = _GetConfigDataLogic:GetConfigNumDataByKey("MoveSpeedAddedByStage")
		info.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("StageInfoEmployeeInfoText", moveSpeedBonus)
		
		self.StartingEmpList = self.Entity:GetChildByName("StartingEmpList").ScrollLayoutGroupComponent
		self.StartingEmpEmpty = self.Entity:GetChildByName("StartingEmpEmpty")
		self.StageEmpTitle = self.Entity:GetChildByName("StageEmpTitle").TextComponent
		self.StageEmpList = self.Entity:GetChildByName("StageEmpList").ScrollLayoutGroupComponent
		
		self.EmpSlotSample = self.Entity:GetChildByName("EmpSlotSample")
		self.EmpSlotSample.Enable = false
	end

	method void Refresh(integer stageId, boolean isStageSetting)
		-- 직원 정보를 새로고침하는 함수
		if self.EmpSlotSample == nil then
			self:Init()
		end
		
		for i, child in pairs(self.StartingEmpList.Entity.Children) do
			child.Enable = false
		end
		for i, child in pairs(self.StageEmpList.Entity.Children) do
			child.Enable = false
		end
		
		local player = _UserService.LocalPlayer
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		local startingEmp = {}
		if stageId == player.PlayerStage.NowStage then
			startingEmp = player.PlayerIngameManager.StageStartingEmployee	
		else
			if _UtilLogic:IsNilorEmptyString(player.PlayerStage.StageSettingData[stageId]) == false then
				local stageSettingData = _HttpService:JSONDecode(player.PlayerStage.StageSettingData[stageId])
				if _UtilLogic:IsNilorEmptyString(stageSettingData[_StageSettingEnum.Employee]) == false then
					startingEmp = _UtilLogic:StringToTable(stageSettingData[_StageSettingEnum.Employee])
				end
			end
			
		end
		
		if isStageSetting == true then 
			local uiStageSetting = _StageDataSetLogic.UIStageSetting
			local settingPage = uiStageSetting.EnumPages[_StageSettingEnum:GetIndexByKey(_StageSettingEnum.Employee)]
			startingEmp = table.values(settingPage.UIStageSettingEmployee.SelectedEmployee)
		end
		local stageEmp = _EmployeeService:ReturnStageEmpIdList(stageId)
		
		local isStageOpened = player.PlayerStage:IsStageOpened(stageId)
		local isListOff = isStageSetting == false and (isStageOpened == false or #startingEmp <= 0)
		
		
		if isListOff == false then
			for i, empId in pairs(startingEmp) do
				local slot = _UIEntityService:GetOrCreateClonedEntityByName(self.StartingEmpList.Entity, "EmpSlot"..i, self.EmpSlotSample)
				
				local empData = _EmployeeService:GetData(empId)
				
				local portrait = slot:GetChildByName("Mask"):GetChildByName("Portrait")
				local typeIcon = slot:GetChildByName("TypeIcon")
				local check = slot:GetChildByName("Check")
				
				_EmployeeUIService:DrawPortraitWithEquip(portrait, portrait, empData)
				typeIcon.SpriteGUIRendererComponent.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(empData.Type)
		        typeIcon.Enable = false
				
				check.Enable = false
			end
		end
		
		self.StartingEmpList.Entity.Enable = not isListOff
		self.StartingEmpEmpty.Enable = isListOff
		self.StartingEmpEmpty.TextComponent.Text = _GetLocalizationTextLogic:GetText("StageInfoListEmptyText1") 
		
		local haveEmpCount = 0
		for i, empId in pairs(stageEmp) do
			local slot = _UIEntityService:GetOrCreateClonedEntityByName(self.StageEmpList.Entity, "EmpSlot"..i, self.EmpSlotSample)	
			local empData = _EmployeeService:GetData(empId)
		    local haveEmp = player.ChuchuCollectionDB.ChuchuCollection[empId]
			if haveEmp == nil then
				haveEmp = false
			end
			
			local portrait = slot:GetChildByName("Mask"):GetChildByName("Portrait")
			local typeIcon = slot:GetChildByName("TypeIcon")
			local check = slot:GetChildByName("Check")
			
			_EmployeeUIService:DrawPortraitWithEquip(portrait, portrait, empData)
			typeIcon.SpriteGUIRendererComponent.ImageRUID = _EmployeeRUID:ReturnIconRUIDByStatType(empData.Type)
		    typeIcon.Enable = false
			
			check.Enable = haveEmp
			local materialId = haveEmp and _IconRuidEnum.EmptyMaterial or _IconRuidEnum.GrayScaleMaterial
			portrait.SpriteGUIRendererComponent:ChangeMaterial(materialId)
			
			if haveEmp == true then
				haveEmpCount += 1
			end
		end
		self.StageEmpTitle.Text = string.format("%s ( %d / %d )", _GetLocalizationTextLogic:GetText("StageEmployee"), haveEmpCount, #stageEmp)
		
	end

end