@Component
script UIStageSelectSlot extends Component

	property TextComponent Name = nil

	property Entity Ing = nil

	property Entity Complete = nil

	property SliderComponent CollectionProgressSlider = nil

	property TextComponent CollectionProgressText = nil

	property Entity LockedDim = nil

	property Entity Selected = nil

	property Entity CollectionProgress = nil

	property SpriteGUIRendererComponent IconBig = nil

	property Entity ComingSoon = nil

	property SpriteGUIRendererComponent DecoTop = nil

	property SpriteGUIRendererComponent DecoBottom = nil

	property SpriteGUIRendererComponent IconSmall = nil

	property Entity OverLockedDim = nil

	property Entity IconBigDim = nil

	method void Init()
		-- UI 컴포넌트들을 초기화하는 함수
		self.Name = self.Entity:GetChildByName("Name").TextComponent
		self.Ing = self.Entity:GetChildByName("Ing")
		self.Complete = self.Entity:GetChildByName("Complete")
		self.CollectionProgress = self.Entity:GetChildByName("CollectionProgress")
		self.CollectionProgressSlider = self.CollectionProgress:GetChildByName("Slider").SliderComponent
		self.CollectionProgressText = self.CollectionProgressSlider.Entity:GetChildByName("Text").TextComponent
		
		self.Selected = self.Entity:GetChildByName("Selected")
		self.IconBig = self.Entity:GetChildByName("Icon").SpriteGUIRendererComponent
		self.IconBigDim = self.IconBig.Entity:GetChildByName("Dim")
		
		local deco = self.Entity:GetChildByName("Deco")
		self.DecoTop = deco:GetChildByName("Top").SpriteGUIRendererComponent
		self.DecoBottom = deco:GetChildByName("Bottom").SpriteGUIRendererComponent
		
		self.IconSmall = self.Entity:GetChildByName("Icon_mini").SpriteGUIRendererComponent
		
		self.LockedDim = self.Entity:GetChildByName("LockedDim")
		self.OverLockedDim = self.Entity:GetChildByName("OverLockedDim")
		self.ComingSoon = self.OverLockedDim:GetChildByName("ComingSoon")
	end

	method void Refresh(integer stageId)
		-- 스테이지 슬롯을 새로고침하는 함수
		if self.Name == nil then
			self:Init()
		end
		
		if isvalid(self._T.buttonHandler) then
			self.Entity:DisconnectEvent(ButtonClickEvent, self._T.buttonHandler)
		end
		
		local stageData = _StageDataSetLogic:GetStageData(stageId)
		local player = _UserService.LocalPlayer
		local isLocked = self:IsLocked(stageId)
		
		self.Selected.Enable = stageId == _StageDataSetLogic.UIStageSelect.NowSelected
		self._T.buttonHandler = self.Entity:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			_StageDataSetLogic.UIStageSelect:OnSelectSlot(stageId)	
		end)
		
		
		
		self.ComingSoon.Enable = false
		self.IconBig:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		
		self.Name.Text = string.format("%d %s", stageId, _GetLocalizationTextLogic:GetText(stageData.NameKey))
		self.IconBig.ImageRUID = stageData.IconRUID
		self.IconSmall.ImageRUID = stageData.BadgeIconRUID
		
		self.Ing.Enable = stageId == player.PlayerStage.NowStage
		self.Complete.Enable = self:IsComplete(stageId)
		
		self.LockedDim.Enable = isLocked
		self.IconBigDim.Enable = isLocked
		self.IconBigDim.SpriteGUIRendererComponent.ImageRUID = stageData.IconRUID
		self.OverLockedDim.Enable = isLocked
		
		if stageData.DecoType == "Color" then
			self.DecoTop.ImageRUID = "40e7bf1ed4254e3ab36a29b653132f95"
			self.DecoBottom.ImageRUID = "9d458de346a54377be6e110aa8411447"
			self.DecoTop.Color = _ColorCodeEnum:GetColor(stageData.DecoTopSmall)
			self.DecoBottom.Color = _ColorCodeEnum:GetColor(stageData.DecoBottomSmall)
				
		elseif stageData.DecoType == "Sprite" then
			self.DecoTop.ImageRUID = stageData.DecoTopSmall
			self.DecoBottom.ImageRUID = stageData.DecoBottomSmall
			self.DecoTop.Color = Color.white
			self.DecoBottom.Color = Color.white
		end
		
		if stageData.ComingSoon then
			self:SetStageComingSoon(stageData)
			return
		end
		
		self.CollectionProgress.Enable = stageId > 1
		if stageId <= 1 then
			return
		end
		
		local collectionRate = _StageDataSetLogic:GetStageCollectionRate(nil, stageId, player)
		self.CollectionProgressSlider.Value = collectionRate
		self.CollectionProgressText.Text = math.floor(collectionRate*100).."%"
	end

	method boolean IsComplete(integer stageId)
		-- 스테이지가 완료되었는지 확인하는 함수
		local player = _UserService.LocalPlayer
		if player.PlayerStage.StageProgress[stageId] == nil then
			return false
		end
		
		return player.PlayerStage.StageProgress[stageId] >= _StageDataSetLogic:GetStageClearProgress(stageId)
	end

	method boolean IsLocked(integer stageId)
		-- 스테이지가 잠겨있는지 확인하는 함수
		local player = _UserService.LocalPlayer
		if player.PlayerStage:IsStageOpened(stageId) == false then
			return true
		end
		
		return false
	end

	method void SetStageComingSoon(StageData stageData)
		-- 스테이지 출시 예정 상태를 설정하는 함수
		if stageData.ComingSoon == false then
			return
		end
		
		self.Name.Text = string.format("%d %s", stageData.StageId, "???")
		self.IconBig:ChangeMaterial(_IconRuidEnum.GrayScaleMaterial)
		self.IconSmall:ChangeMaterial(_IconRuidEnum.GrayScaleMaterial)
		self.CollectionProgress.Enable = false
		self.LockedDim.Enable = true
		self.ComingSoon.Enable = true
		self.Complete.Enable = false
		self.Ing.Enable = false
	end

end