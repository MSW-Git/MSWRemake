@Component
script UIStageSettingEmployee extends Component

	property SyncTable<string, string> SelectedEmployee

	property Entity CookSlot = nil

	property Entity CookSlotContents = nil

	property Entity CookSlotEmpty = nil

	property Entity CookSlotPortrait = nil

	property Entity CookSlotName = nil

	property Entity ServingSlot = nil

	property Entity ServingSlotContents = nil

	property Entity ServingSlotEmpty = nil

	property Entity ServingSlotPortrait = nil

	property Entity ServingSlotName = nil

	property string NowSlotType = ""

	method void Init()
		-- UI 컴포넌트들을 초기화하고 이벤트를 연결하는 함수
		self.CookSlot = self.Entity:GetChildByName("CookSlot")
		self.CookSlotContents = self.CookSlot:GetChildByName("Contents")
		self.CookSlotPortrait = self.CookSlotContents:GetChildByName("Slot"):GetChildByName("Portrait")
		self.CookSlotName = self.CookSlotContents:GetChildByName("Name")
		self.CookSlotEmpty = self.CookSlot:GetChildByName("Empty")
		self.CookSlot:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			self.NowSlotType = _EmployeeTypeEnum.Cook
			_UIGroupManager.SelectChuchuInCollection.UISelectChuchuInCollection:OpenUI(_EmployeeTypeEnum.Cook)
		end)
		
		self.ServingSlot = self.Entity:GetChildByName("ServingSlot")
		self.ServingSlotContents = self.ServingSlot:GetChildByName("Contents")
		self.ServingSlotPortrait = self.ServingSlotContents:GetChildByName("Slot"):GetChildByName("Portrait")
		self.ServingSlotName = self.ServingSlotContents:GetChildByName("Name")
		self.ServingSlotEmpty = self.ServingSlot:GetChildByName("Empty")
		self.ServingSlot:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
			self.NowSlotType = _EmployeeTypeEnum.Serving
			_UIGroupManager.SelectChuchuInCollection.UISelectChuchuInCollection:OpenUI(_EmployeeTypeEnum.Serving)
		end)
	end

	method void Refresh()
		-- 직원 선택 UI를 새로고침하는 함수
		if self.CookSlot == nil then
			self:Init()
		end
		
		self.NowSlotType = nil
		
		self:RefreshCookSlot()
		self:RefreshServingSlot()
	end

	method void RefreshCookSlot()
		-- 요리사 슬롯을 새로고침하는 함수
		local employeeId = self.SelectedEmployee[_EmployeeStatEnumType.Cook]
		local empData = _EmployeeService:GetData(employeeId)
		
		self.CookSlotContents.Enable = isvalid(empData)
		self.CookSlotEmpty.Enable = not isvalid(empData)
		if isvalid(empData) == false then
			return
		end
		
		self.CookSlotName.TextComponent.Text = _GetLocalizationTextLogic:GetText(empData.NameKey)
		_EmployeeUIService:DrawPortraitWithEquip(self.CookSlotPortrait, self.CookSlotPortrait, empData)
	end

	method void RefreshServingSlot()
		-- 서빙 직원 슬롯을 새로고침하는 함수
		local employeeId = self.SelectedEmployee[_EmployeeStatEnumType.Serving]
		local empData = _EmployeeService:GetData(employeeId)
		
		self.ServingSlotContents.Enable = isvalid(empData)
		self.ServingSlotEmpty.Enable = not isvalid(empData)
		if isvalid(empData) == false then
			return
		end
		
		self.ServingSlotName.TextComponent.Text = _GetLocalizationTextLogic:GetText(empData.NameKey)
		_EmployeeUIService:DrawPortraitWithEquip(self.ServingSlotPortrait, self.ServingSlotPortrait, empData)
	end

	@ExecSpace("Client")
	method void SetSlot(string statType, string employeeId)
		-- 직원 슬롯을 설정하는 함수
		self.SelectedEmployee[statType] = employeeId
		if statType == _EmployeeStatEnumType.Cook then
			self:RefreshCookSlot()
		else
			self:RefreshServingSlot()
		end
	end

end