@Component
script UISideMenuReward extends Component

	property SpriteGUIRendererComponent RewardIcon = "9b1a5b47-f249-4c33-95cf-a8844f8b59ca"

	property TextComponent RewardName = "6009ed5c-8012-4efd-baa6-4eda61d387e4"

	property TextComponent RewardEffect = "4bd2f0ba-7d24-48cf-8b0a-6c9adb3a4ec1"

	property TextComponent TitleText = "213a0713-58b3-44e1-a991-4c4503e2013d"

	@ExecSpace("Client")
	method void Open(integer rewardId, integer stageId)
		-- 사이드메뉴 보상 UI를 여는 함수
		_UIGroupManager:EnableStageClearRewardGroup(true)
		
		self._T.currentIndex = 0
		self._T.stageId = stageId
		self._T.canBuyId = nil
		
		for id, data in pairs(_StrategyDataSetLogic.SideMenuData) do
			local smData = _StrategyDataSetLogic:GetSideMenuData(id)
			if _UtilLogic:IsNilorEmptyString(smData.OpenCondition) == false then
				if smData.OpenCondition == "StageClear" then
					if tonumber(smData.OpenConditionValue) == stageId then
						self._T.canBuyId = id
						break
					end
				end
			end
		end
		
		self:Refresh(rewardId, stageId, false)
	end

	method void MoveNext()
		-- 다음 보상 단계로 이동하는 함수
		if self._T.currentIndex == 1 then
			if self._T.canBuyId ~= nil then
				self:Refresh(self._T.canBuyId, self._T.stageId, true)
			else
				self:Close()
			end
			
		else
			self:Close()
		end
	end

	method void Close()
		-- 사이드메뉴 보상 UI를 닫는 함수
		_UIGroupManager:EnableStageClearRewardGroup(false)
		_UIItemRewardService:RequestSetQueueToUI("SideMenu Reward Popup")
	end

	method void Refresh(integer rewardId, integer stageId, boolean isCanBuy)
		-- 보상 UI를 새로고침하는 함수
		local rewardData = _StrategyDataSetLogic:GetSideMenuData(rewardId)
		if rewardData == nil then
			self:Close()
			return
		end
		
		
		if isCanBuy == false then
			self.TitleText.Text = _GetLocalizationTextLogic:GetText("StageRewardTitle3")
		else
			self.TitleText.Text = _GetLocalizationTextLogic:GetText("StageRewardTitle4")
		end
		
		self.RewardIcon.ImageRUID = rewardData.IconRUID
		self.RewardName.Text = _GetLocalizationTextLogic:GetText(rewardData.NameKey)
		self.RewardEffect.Text = _StrategyDataSetLogic:GetSideMenuDescText(rewardId)
	end

	@EventSender("Entity", "56ce6220-7ce2-498d-a877-eed6bc709a09")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 보상 구매 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self._T.currentIndex += 1
		self:MoveNext()
	end

end