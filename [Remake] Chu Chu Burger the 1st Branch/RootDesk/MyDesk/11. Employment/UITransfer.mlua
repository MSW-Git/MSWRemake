@Component
script UITransfer extends Component

	property string EmployeeId = ""

	property Entity DetailEntity = "abfd2461-7f7a-4164-931b-e830f088b1de"

	property Entity TransferHeartText = "f6d6fc97-dbb7-4267-8502-bf66fa074f01"

	property Entity TransferJemText = "12756a94-f373-4761-be08-6c389e970873"

	@ExecSpace("ClientOnly")
	method void CloseUI()
		-- 이적 UI를 닫는 함수
		self.Entity.Enable = false
		self.EmployeeId = nil
		_UIGroupManager:EnableBackToLobbyBtn(nil)
	end

	@ExecSpace("ClientOnly")
	method void OnClickOkButton()
		-- 이적 확인 버튼 클릭 시 처리하는 함수
		if not isvalid(self.EmployeeId) then
			return
		end
		
		local function onOk ()
			self:TransferChuChu()
		end
		
		local function onCancel()
			
		end
		
		---@type EmployeeData
		local data = _EmployeeService.EmployeeData[self.EmployeeId]
		local chuchuName = _LocalizationService:GetText(data.NameKey)
		
		_UIPopup:Open(_LocalizationService:GetTextFormat("TransferPopupMsg", chuchuName), onOk, onCancel, _GetLocalizationTextLogic:GetText("TransferPopupTitle"))
		
	end

	@ExecSpace("ClientOnly")
	method void TransferChuChu()
		-- 츄츄 이적을 실행하는 함수
		local player = _UserService.LocalPlayer
		player.EmployeeManager:RequestTransferEmployee(self.EmployeeId, true,"Tranasfer")
		self:CloseUI()
	end

	@ExecSpace("ClientOnly")
	method void OpenTransferUI(string employeeId)
		-- 이적 UI를 열고 직원 정보를 설정하는 함수
		self.EmployeeId = employeeId
		self:SetInfo()
		self.Entity.Enable = true
		_UIGroupManager:EnableBackToLobbyBtn(true)
		
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.EnterTransfer)
	end

	@ExecSpace("ClientOnly")
	method void SetInfo()
		-- 이적 시 환급받을 하트와 젬 정보를 설정하는 함수
		local refundHeart = _EmployeeService:ReturnTransferHeart(self.EmployeeId, _UserService.LocalPlayer)
		local refundJemTable = _UserService.LocalPlayer.EmployeeManager:ReturnTransferRefundJemCost(self.EmployeeId)
		local jemId = refundJemTable[1]
		local jemCount =  refundJemTable[2]
		---@type ItemData
		local itemData = _ItemDataSetLogic:GetItemData(jemId)
		local iconRUID = itemData.IconRUID
		
		local refundHeartText =  _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(refundHeart))
		local refundJemText =  _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(jemCount))
		self.TransferHeartText.TextComponent.Text = refundHeartText
		self.TransferJemText.TextComponent.Text = refundJemText
		self.TransferJemText:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = iconRUID 
		
		self.DetailEntity.UIEmployeeManageDetailRenderer:Set(self.EmployeeId)
	end

	@ExecSpace("ClientOnly")
	method void NotifyFinishTransfer(string employeeId)
		-- 이적 완료 알림을 처리하는 함수
		local empData = _EmployeeService:GetData(employeeId)
		local name = _LocalizationService:GetText(empData.NameKey)
		
		_ReportMessageMaker:RequestAddToReportQueue(2002, name, "", "")
	end

	@EventSender("Entity", "a2a12d4f-4f96-406d-a3a7-9abd7aa37cf9")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseUI()
	end

	@EventSender("Entity", "f473042d-e3b9-49be-8e54-5be51dfd0f40")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 확인 버튼 클릭 이벤트를 처리하는 함수
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickOkButton()
	end

end