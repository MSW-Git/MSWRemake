@Logic
script CustomerAvatarService extends Logic

	property table CustomerAvatars = {}

	property integer AvatarNumsInStage = 30

	property integer AvatarNumsInStage_Mobile = 10

	property table PreLoadedRUIDs = {}

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 서비스 시작 시 고객 아바타 데이터셋을 로드하는 함수
		self:LoadDataSet()
	end

	@ExecSpace("ClientOnly")
	method void LoadDataSet()
		-- CSV에서 고객 아바타 데이터를 로드하여 메모리에 저장하는 함수
		table.clear(self.CustomerAvatars)
		local dataSet = _DataService:GetTable("CustomerAvatarDataSet")
		
		local ruids = {}
		for i = 1, dataSet:GetRowCount() do
			local data = CustomerAvatarData()
			data:Load(dataSet, i, ruids)
			
			if self.CustomerAvatars[i] ~= nil then
				break
			end
			
			self.CustomerAvatars[i] = data
		end
	end

	method void SetRandomCostume(CostumeManagerComponent costumeMgr)
		-- 현재 스테이지에 맞는 랜덤 고객 의상을 설정하는 함수
		
		local Indexs = self:GetIndex(_UserService.LocalPlayer.PlayerStage.NowStage)
		local randomIndex = _UtilLogic:RandomIntegerRange(Indexs[1], Indexs[2])
		local randomData = self:GetCostumerAvatarData(randomIndex)
		
		costumeMgr.CustomBodyEquip = randomData.Body
		costumeMgr.CustomFaceEquip = randomData.Face
		costumeMgr.CustomHairEquip = randomData.Hair
		costumeMgr.CustomLongcoatEquip = randomData.Longcoat
		costumeMgr.CustomShoesEquip = randomData.Shoes
		costumeMgr.CustomCapEquip = randomData.Cap
	end

	method CustomerAvatarData GetCostumerAvatarData(integer index)
		-- 인덱스에 해당하는 고객 아바타 데이터를 반환하는 함수
		return self.CustomerAvatars[index]
	end

	method void SetRandomEmotion(AvatarGUIRendererComponent guiRenderer)
		-- 고객에게 랜덤한 감정 표현을 설정하는 함수
		local emotionList = {
			"Smile",
			"Cheers",
			"Glitter",
			"Chu",
		
			"Love",
			"Shine"
		}
		
		local randNum = _UtilLogic:RandomIntegerRange(1, #emotionList)
		guiRenderer:PlayEmotion(emotionList[randNum], 30)
	end

	@ExecSpace("Client")
	method void ResetCustomerAvatarResources(integer nowStage)
		-- 현재 스테이지에 맞는 고객 아바타 리소스를 미리 로드하는 함수
		
		if #self.PreLoadedRUIDs > 0 then
			_ResourceService:RemoveCaches(self.PreLoadedRUIDs)
			_ResourceService:UnloadUnusedResources(0)
			table.clear(self.PreLoadedRUIDs)
		end
		
		local Indexs = self:GetIndex(nowStage)
		for i=Indexs[1], Indexs[2] do
			local randomData = self:GetCostumerAvatarData(i)
			if randomData ~= nil then
				self:InsertRUIDToPreloadData(randomData.Body)
				self:InsertRUIDToPreloadData(randomData.Face)
				self:InsertRUIDToPreloadData(randomData.Hair)
				self:InsertRUIDToPreloadData(randomData.Longcoat)
				self:InsertRUIDToPreloadData(randomData.Shoes)
				self:InsertRUIDToPreloadData(randomData.Cap)
			end
		end
		
		if #self.PreLoadedRUIDs > 0 then
			_ResourceService:PreloadAsync(self.PreLoadedRUIDs, function()
			end)
		end
	end

	@ExecSpace("ClientOnly")
	method table GetIndex(integer nowStage)
		-- 현재 스테이지에 해당하는 아바타 인덱스 범위를 계산하는 함수
		
		local gap = (self.AvatarNumsInStage * (nowStage - 1))
		local minIndex = 1 + gap
		local maxIndex = self.AvatarNumsInStage + gap
		if Environment:IsPCPlatform() == false then
			maxIndex -= self.AvatarNumsInStage - self.AvatarNumsInStage_Mobile
		end
		
		return {minIndex, maxIndex}
	end

	@ExecSpace("ClientOnly")
	method void InsertRUIDToPreloadData(string ruid)
		-- 유효한 리소스 ID를 프리로드 목록에 추가하는 함수
		if not _UtilLogic:IsNilorEmptyString(ruid) then
			table.insert(self.PreLoadedRUIDs, ruid)
		end
	end

end