@Component
script UIExchangeSetting extends Component

	property Entity HeartBtn = "174c93a8-8c68-48fa-9685-0e12a2c5cf9a"

	property Entity CloverBtn = "f3352b07-b66b-482f-99f7-af51cad325df"

	property integer ExchangeType = 0

	property integer IngredientsCount = 1

	property Entity BucketPanel = "31d65c9f-3148-41fc-bb30-96dfc89dd928"

	property table Ingredients = {}

	property Entity RewardImg = "4d5d9efe-2c86-4c46-ac86-2c8fb7d2dbb0"

	property Entity RewardCost = "f9547d64-616d-4f13-b0d0-bf6a841c30f6"

	property Entity IngredientsCost = "b1b28aa0-7b6e-4c9a-aeb3-b9efb27320c1"

	property number DefaultGoldConst = 0

	property number ExchangeMoneyToHeartRate = 0

	property number ExchangeMoneyToCloverRate = 0

	property integer ManagementLevel = 0

	property integer CurrentStage = 0

	property number ExchangeBaseMoneyRate = 0

	property Entity IngredientCountEntity = "3c4cdc86-919c-4c89-acf4-8c2d83d46841"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 교환 설정 UI 초기화 시 재료 오브젝트를 로드하고 설정값을 설정하는 함수
		
		for i=1, 10 do
			local name = "Ingredients" .. i
			local ingredient = self.BucketPanel:GetChildByName(name)
			table.insert(self.Ingredients, ingredient)
		end
		
		self.ExchangeMoneyToHeartRate = tonumber(_DataService:GetTable("GameConfigData"):FindRow("ConfigType","ExchangeMoneyToHeartRate"):GetItem("ConfigValue"))
		self.ExchangeMoneyToCloverRate = tonumber(_DataService:GetTable("GameConfigData"):FindRow("ConfigType","ExchangeMoneyToCloverRate"):GetItem("ConfigValue"))
	end

	@ExecSpace("ClientOnly")
	method void OnClickHeartBtn()
		-- 하트 보상 타입을 선택하고 UI를 업데이트하는 함수
		self:SetExchangeType(1)
		
		local selected_heart = self.HeartBtn:GetChildByName("Selected")
		local notSelected_heart = self.HeartBtn:GetChildByName("NotSelected")
		
		selected_heart.Enable = true
		notSelected_heart.Enable = false
		
		local selected_clover = self.CloverBtn:GetChildByName("Selected")
		local notSelected_clover = self.CloverBtn:GetChildByName("NotSelected")
		
		selected_clover.Enable = false
		notSelected_clover.Enable = true
		
		self.RewardImg.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.Heart
		self.RewardImg.SpriteGUIRendererComponent.Color.a = 1
		
		self:SetIngredientCost()
		self:SetReward()
	end

	@ExecSpace("ClientOnly")
	method void OnClickCloverBtn()
		-- 클로버 보상 타입을 선택하고 UI를 업데이트하는 함수
		self:SetExchangeType(2)
		
		local selected_clover = self.CloverBtn:GetChildByName("Selected")
		local notSelected_clover = self.CloverBtn:GetChildByName("NotSelected")
		
		selected_clover.Enable = true
		notSelected_clover.Enable = false
		
		local selected_heart = self.HeartBtn:GetChildByName("Selected")
		local notSelected_heart = self.HeartBtn:GetChildByName("NotSelected")
		
		selected_heart.Enable = false
		notSelected_heart.Enable = true
		
		self.RewardImg.SpriteGUIRendererComponent.ImageRUID = _IconRuidEnum.AcaneSimbol
		self.RewardImg.SpriteGUIRendererComponent.Color.a = 1
		
		self:SetIngredientCost()
		self:SetReward()
	end

	@ExecSpace("ClientOnly")
	method void OnClickResetBtn()
		-- 재료 개수를 1로 초기화하는 함수
		self:SetIngredients(-10)
		self:SetIngredientCost()
		self:SetReward()
	end

	@ExecSpace("ClientOnly")
	method void OnClickMinusBtn()
		-- 재료 개수를 1 감소시키는 함수
		self:SetIngredients(-1)
		self:SetIngredientCost()
		self:SetReward()
	end

	@ExecSpace("ClientOnly")
	method void OnClickAddBtn()
		-- 재료 개수를 1 증가시키는 함수
		self:SetIngredients(1)
		self:SetIngredientCost()
		self:SetReward()
	end

	@ExecSpace("ClientOnly")
	method void OnClickMaxBtn()
		-- 재료 개수를 최대값인 10으로 설정하는 함수
		self:SetIngredients(10)
		self:SetIngredientCost()
		self:SetReward()
	end

	@ExecSpace("ClientOnly")
	method void SetExchangeType(integer type)
		-- 교환 타입을 설정하는 함수
		
		self.ExchangeType = type
	end

	@ExecSpace("ClientOnly")
	method void SetIngredients(integer count)
		-- 재료 개수를 설정하고 UI를 업데이트하는 함수
		self.IngredientsCount += count
		
		if self.IngredientsCount < 1 then
			self.IngredientsCount = 1
		elseif self.IngredientsCount > 10 then
			self.IngredientsCount = 10
		end
		
		local text = self.IngredientCountEntity
		text.TextComponent.Text = self.IngredientsCount .. " / 10"
		
		for i=1, 10 do
			---@type Entity
			local ingredient = self.Ingredients[i]
			
			if i <= self.IngredientsCount then
				ingredient.SpriteGUIRendererComponent.Color.a = 1
			else
				ingredient.SpriteGUIRendererComponent.Color.a = 0
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetReward()
		-- 카드 보너스를 고려하여 보상 범위를 계산하고 UI에 표시하는 함수
		local reward = self:CalculateReward()
		local card1Bonus = _DataService:GetTable("GameConfigData"):FindRow("ConfigType","ExchangeCard1BonusRate"):GetItem("ConfigValue")
		local card2Bonus = _DataService:GetTable("GameConfigData"):FindRow("ConfigType","ExchangeCard2BonusRate"):GetItem("ConfigValue")
		local card3Bonus = _DataService:GetTable("GameConfigData"):FindRow("ConfigType","ExchangeCard3BonusRate"):GetItem("ConfigValue")
		
		local minReward = reward * (1 + card1Bonus * 3)
		local maxReward = reward * (1 + card1Bonus * 2 + card2Bonus * 2 + card3Bonus )
		
		if self.ExchangeType == 0 then
			self.RewardCost.Parent:GetChildByName("Cost").Enable = false
			self.RewardCost.Parent:GetChildByName("DefaultText").Enable = true
		else
			self.RewardCost.Parent:GetChildByName("Cost").Enable = true
			self.RewardCost.Parent:GetChildByName("DefaultText").Enable = false
			local min = tonumber(string.format("%0.f", minReward))
			local max = tonumber(string.format("%0.f", maxReward))
			self.RewardCost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(min) .. " ~ " .. _StringUtilLogic:ReturnThousandsSeparatedString(max)
			if self.ExchangeType == 1 then
				self.RewardCost.TextComponent.FontColor = _ColorCodeEnum:GetColor("#ff94b2")
				self.RewardCost.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#700028")
			elseif self.ExchangeType == 2 then
				self.RewardCost.TextComponent.FontColor = _ColorCodeEnum:GetColor("#d6ff1f")
				self.RewardCost.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#3e501b")
			end
			self.RewardCost.UITransformComponent.Pivot.x = 1
			self.RewardCost.UITransformComponent.anchoredPosition.x = -17
			self.RewardCost.Parent:GetChildByName("DefaultReward").Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void SetIngredientCost()
		-- 재료 비용을 계산하고 UI에 표시하는 함수
		
		self.IngredientsCost.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.tointeger(self:CalculateGold()))
		
		local player = _UserService.LocalPlayer
		if self:CalculateGold() > player.PlayerInventory:GetItemCount("G0001") then
			self.IngredientsCost.TextComponent.FontColor = _ColorCodeEnum:GetColor("#FA5246")
			self.IngredientsCost.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#863205")
		else
			self.IngredientsCost.TextComponent.FontColor = _ColorCodeEnum:GetColor("#FFFFFF")
			self.IngredientsCost.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#8c7352")
		end
	end

	@ExecSpace("ClientOnly")
	method number CalculateGold()
		-- 재료 개수와 기본 금액을 기반으로 필요한 금액을 계산하는 함수
		
		local gold = 0
		
		
		gold = self:GetDefaultGold() * (1 + self.ExchangeBaseMoneyRate) * self.IngredientsCount
		
		return gold
		
	end

	@ExecSpace("ClientOnly")
	method void CloseExchangeSettingUI()
		-- 교환 설정 UI를 닫고 초기화하는 함수
		_UIGroupManager:EnableExchangeSettingGroup(false)
		
		self.RewardImg.SpriteGUIRendererComponent.Color.a = 0
		
		self.ExchangeType = 0
		self:OnClickResetBtn()
	end

	@ExecSpace("ClientOnly")
	method void OpenExchangeSettingUI()
		-- 교환 설정 UI를 열고 초기 설정을 수행하는 함수
		local player = _UserService.LocalPlayer
		self.ManagementLevel = player.PlayerManagement.ManagementLevel
		self.CurrentStage = player.PlayerStage.NowStage
		
		
		
		
		local selected_heart = self.HeartBtn:GetChildByName("Selected")
		local notSelected_heart = self.HeartBtn:GetChildByName("NotSelected")
		
		selected_heart.Enable = false
		notSelected_heart.Enable = true
		
		local selected_clover = self.CloverBtn:GetChildByName("Selected")
		local notSelected_clover = self.CloverBtn:GetChildByName("NotSelected")
		
		selected_clover.Enable = false
		notSelected_clover.Enable = true
		
		_UIGroupManager:EnableExchangeSettingGroup(true)
		
		self.ExchangeType = 0
		self.IngredientsCount = 1
		
		for i=1, 10 do
			---@type Entity
			local ingredient = self.Ingredients[i]
			ingredient.SpriteGUIRendererComponent.ImageRUID = _ExchangeDataSetLogic:GetExchangeIngredientData(self.ManagementLevel, i).ruid
		end
		
		self.ExchangeBaseMoneyRate = _BalanceDataSetLogic:GetStageConfigData(self.CurrentStage).ExchangeBaseMoneyRate
		
		
		self:SetIngredientCost()
		self:SetReward()
		self:GetDefaultGold()
		_UIGroupManager:EnableBackToLobbyBtn(nil)
		_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.ExchangeSettingEnter)
	end

	@ExecSpace("ClientOnly")
	method void OnClickStartBtn()
		-- 교환 시작 버튼 클릭 시 유효성 검사 후 교환 UI를 여는 함수
		local player = _UserService.LocalPlayer
		
		if self.ExchangeType == 0 then
			_UIToast:ShowMessage(_LocalizationService:GetText("ExchangeSelectRewardText"))
			return
		end
		
		if self:CalculateGold() > player.PlayerInventory:GetItemCount("G0001") then
			_UIToast:ShowMessage(_LocalizationService:GetText("ExchangeToastLackCost"))
			return
		end
		
		local uiExchange = _EntityService:GetEntityByPath("/ui/ExchangeGroup")
		local gold = self:CalculateGold()
		local reward = self:CalculateReward()
		local exchangeType = self.ExchangeType
		
		_FadeService:ShowFade("ExchangeStart")
		
		_TimerService:SetTimerOnce(function() 
			uiExchange.UIExchange:OpenExchangeUI(gold, reward, exchangeType, self.IngredientsCount)
		end, 1)
		
		self:CloseExchangeSettingUI()
	end

	@ExecSpace("ClientOnly")
	method number GetDefaultGold()
		-- 현재 스테이지와 경영 레벨에 따라 기본 금액을 가져오는 함수
		
		local manageLv = "ManageLv" .. self.ManagementLevel
		if self.ManagementLevel == 0 then
			manageLv = "ManageLv1"
		end
		
		local gold = _DataService:GetTable("ExchangeBaseMoneyDataSet"):FindRow("StageId",tostring(self.CurrentStage)):GetItem(manageLv)
		
		return tonumber(gold)
	end

	@ExecSpace("ClientOnly")
	method integer CalculateReward()
		-- 교환 타입과 재료 개수에 따라 보상을 계산하는 함수
		local reward = 0
		
		if self.ExchangeType == 1 then
			reward = self:GetDefaultGold() / self.ExchangeMoneyToHeartRate * self.IngredientsCount
		elseif self.ExchangeType == 2 then
			reward = self:GetDefaultGold() / self.ExchangeMoneyToCloverRate * self.IngredientsCount
		end
		
		return math.tointeger(reward)
	end

	@EventSender("Entity", "174c93a8-8c68-48fa-9685-0e12a2c5cf9a")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 첫 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickHeartBtn()
	end

	@EventSender("Entity", "f3352b07-b66b-482f-99f7-af51cad325df")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 두 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickCloverBtn()
	end

	@EventSender("Entity", "7e5642d1-d57f-4c2c-9655-f70d47c2604d")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 세 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickResetBtn()
	end

	@EventSender("Entity", "47351bbf-5dc3-418f-b8fb-5c7b89ee45ca")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 네 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickMinusBtn()
	end

	@EventSender("Entity", "d52e88fe-284b-4e01-8d29-05e4e8c97814")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 다섯 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickAddBtn()
	end

	@EventSender("Entity", "5a11891a-cef1-40aa-9c9b-584187793b06")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 여섯 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OnClickMaxBtn()
	end

	@EventSender("Entity", "e4c07165-9f09-47fe-a6cb-5f4265953b72")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 일곱 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:CloseExchangeSettingUI()
	end

	@EventSender("Entity", "c2b48a20-65c5-468f-ae6e-02e7183017d1")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 여덟 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		
		self:OnClickStartBtn()
	end

	@EventSender("Entity", "a9e5beaa-2333-4dd5-80a7-3b95743b63df")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 아홉 번째 버튼 클릭 이벤트를 처리하는 핸들러
		
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:OpenExchangeSettingUI()
	end

end