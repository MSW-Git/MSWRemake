@Logic
script DialogDataLogic extends Logic

	property table TableData = {}

	property table FirstLineId = {}

	property table LineTableData = {}

	property string HighligtColor = "e77e18"

	property boolean IsLoaded = false

	property table CustomAvatarData = {}

	method boolean Load()
		-- 다이얼로그 데이터와 커스텀 아바타 데이터를 CSV에서 로드하여 테이블에 저장하는 함수
		local tableData = self.TableData
		local lineTableData = self.LineTableData
		
		local tbl = _DataService:GetTable("DialogDataSet")
		for i, row in ipairs(tbl:GetAllRow()) do	
			local data = DialogLineData()
			data:Init(row)
			local dialogId = row:GetItem("DialogId")
			local dialogTable = tableData[dialogId]
			if not dialogTable then
				dialogTable = {}
				tableData[dialogId] = dialogTable
				self.FirstLineId[dialogId] = data.Id
			end
			dialogTable[data.Id] = data
			lineTableData[data.Id] = data
		end
		
		table.clear(self.CustomAvatarData)
		local dataSet = _DataService:GetTable("CustomAvatarDataSet")
		
		local ruids = {}
		for i = 1, dataSet:GetRowCount() do
			local data = CustomAvatarData()
			data:Load(dataSet, i, ruids)
				
			if self.CustomAvatarData[data.Id] ~= nil then
				break
			end
			self.CustomAvatarData[data.Id] = data
		end
		
		return true
	end

	@ExecSpace("Client")
	method table GetDialogTable(string dialogId)
		-- 다이얼로그 ID에 해당하는 다이얼로그 테이블을 반환하는 함수
		
		if self.IsLoaded then
			return self.TableData[dialogId]	
		else
			
			_ResourceLoadLogic:AvatarResourcesLoad("CustomAvatarDataSet", function()  end)
			
			
			self:Load()
			
			local reLoadTimer = 0
			
			local reLoad = function()
				self:Load()
			end
			
			if self.IsLoaded then 
		
				_TimerService:ClearTimer(reLoadTimer)
				reLoadTimer = 0
				
				return self.TableData[dialogId]	
			end
			reLoadTimer = _TimerService:SetTimerRepeat( reLoad , 0.2 , 0 )
		end
		
	end

	method string GetFirstLineId(string dialogId)
		-- 다이얼로그 ID의 첫 번째 라인 ID를 반환하는 함수
		if _UtilLogic:IsNilorEmptyString(self.FirstLineId[dialogId]) then
			return
		end
		return self.FirstLineId[dialogId]
	end

	@ExecSpace("ClientOnly")
	method table ChangeDefinitionWord(string message)
		-- 메시지 텍스트에서 특수 키워드를 실제 값으로 치환하고 하이라이트 정보를 추출하는 함수
		local result = message
		local highlight = {}
		
		
		local _
		local nick = _UserService.LocalPlayer.PlayerComponent.Nickname
		result,_ = string.gsub(result,"@Nick",nick)
		
		local _2
		local storeName = _UserService.LocalPlayer.PlayerOutgameManager.StoreName
		result,_2 = string.gsub(result,"@Store",storeName)
		
		local _3
		local empty = " \n"
		result,_3 = string.gsub(result , "@enter" ,empty)
		
		
		local highStr = "*"
		while string.find(result,highStr) do
			local a,_  = string.find(result,highStr)
			highlight[#highlight+1] = a
			result,_ = string.gsub(result,highStr,"",1)
		end
		
		
		return {targetText = result, richTextTable = highlight}
	end

	@ExecSpace("ClientOnly")
	method string SetHighlight(string target, table highlightTable)
		-- 텍스트에 하이라이트 색상 태그를 적용하는 함수
		if #highlightTable == 0 then
			return target
		end
		
		local result = string.sub(target,0,highlightTable[1]-1)
		local first = "<color=#"..self.HighligtColor..">" 
		local last = "</color>" 
		
		for i=1, #highlightTable do
			local nextidx = highlightTable[i+1]
			if not nextidx then
				nextidx = -1
			end
			if i%2 == 1 then
				result = result..first..string.sub(target,highlightTable[i],nextidx-1)
			elseif i == #highlightTable then
				result = result..last..string.sub(target,highlightTable[i],nextidx)
			else
				result = result..last..string.sub(target,highlightTable[i],nextidx-1)
			end
		end
		
		return result
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 게임 시작 시 다이얼로그 데이터를 로드하는 함수
		self.IsLoaded = self:Load()
	end

end