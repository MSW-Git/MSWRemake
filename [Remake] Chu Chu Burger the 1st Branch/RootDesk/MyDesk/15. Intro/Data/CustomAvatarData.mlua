@Struct
script CustomAvatarData

	property string Id = ""

	property string Body = ""

	property string Face = ""

	property string Hair = ""

	property string Longcoat = ""

	property string Shoes = ""

	property string Cap = ""

	property string Cape = ""

	property string Ear = ""

	property string EarAcc = ""

	property string EyeAcc = ""

	property string FaceAcc = ""

	property string OnehandedWeapon = ""

	property string SubWeapon = ""

	property string TwoHandedWeapon = ""

	property string Glove = ""

	property string Coat = ""

	property string Pants = ""

	method void Load(any dataTable, integer index, table ruids)
		-- 데이터 테이블에서 커스텀 아바타 정보를 로드하여 속성들을 설정하는 함수
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		
		self.Body = row:GetItem("Body")
		self.Face = row:GetItem("Face")
		self.Hair = row:GetItem("Hair")
		self.Longcoat = row:GetItem("Longcoat")
		self.Shoes = row:GetItem("Shoes")
		self.Cap = row:GetItem("Cap")
		
		self.Cape = row:GetItem("Cape")
		self.Ear = row:GetItem("Ear")
		self.EarAcc = row:GetItem("EarAcc")
		self.EyeAcc = row:GetItem("EyeAcc")
		self.FaceAcc = row:GetItem("FaceAcc")
		self.OnehandedWeapon = row:GetItem("OnehandedWeapon")
		self.SubWeapon = row:GetItem("SubWeapon")
		self.TwoHandedWeapon = row:GetItem("TwoHandedWeapon")
		self.Glove = row:GetItem("Glove")
		self.Coat = row:GetItem("Coat")
		self.Pants = row:GetItem("Pants")
		
		ruids["Body"] = self.Body
		ruids["Face"] = self.Face
		ruids["Hair"] = self.Hair
		ruids["Longcoat"] = self.Longcoat
		ruids["Shoes"] = self.Shoes
		ruids["Cap"] = self.Cap
		ruids["Cape"] = self.Cape
		ruids["Ear"] = self.Ear
		ruids["EarAcc"] = self.EarAcc
		ruids["EyeAcc"] = self.EyeAcc
		ruids["FaceAcc"] = self.FaceAcc
		ruids["OnehandedWeapon"] = self.OnehandedWeapon
		ruids["SubWeapon"] = self.SubWeapon
		ruids["TwoHandedWeapon"] = self.TwoHandedWeapon
		ruids["Glove"] = self.Glove
		ruids["Coat"] = self.Coat
		ruids["Pants"] = self.Pants
		
	end

	method void SetAvatarCostume(CostumeManagerComponent costume)
		-- 커스텀 아바타의 코스튬 정보를 CostumeManagerComponent에 적용하는 함수
		costume.UseCustomEquipOnly = true
		
		costume.CustomBodyEquip = self.Body
		costume.CustomFaceEquip = self.Face
		costume.CustomHairEquip = self.Hair
		costume.CustomLongcoatEquip = self.Longcoat
		costume.CustomShoesEquip = self.Shoes
		costume.CustomCapEquip = self.Cap
		costume.CustomCapeEquip = self.Cape
		costume.CustomEarEquip = self.Ear
		costume.CustomEarAccessoryEquip = self.EarAcc
		costume.CustomEyeAccessoryEquip = self.EyeAcc
		costume.CustomFaceAccessoryEquip = self.FaceAcc
		costume.CustomOneHandedWeaponEquip = self.OnehandedWeapon
		costume.CustomSubWeaponEquip = self.SubWeapon
		costume.CustomTwoHandedWeaponEquip = self.TwoHandedWeapon
		costume.CustomGloveEquip = self.Glove
		costume.CustomCoatEquip = self.Coat
		costume.CustomPantsEquip = self.Pants
	end

end