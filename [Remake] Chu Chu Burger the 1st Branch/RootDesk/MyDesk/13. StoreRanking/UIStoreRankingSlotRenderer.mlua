@Component
script UIStoreRankingSlotRenderer extends Component

	property Entity Ranking = nil

	property Entity StoreName = nil

	property Entity Score = nil

	property Entity Outline = nil

	@ExecSpace("ClientOnly")
	method void Init()
		-- UI 엘리먼트들을 초기화하는 함수
		self.Ranking = self.Entity:GetChildByName("Ranking")
		self.StoreName = self.Entity:GetChildByName("StoreName")
		self.Score = self.Entity:GetChildByName("Score")
		self.Outline = self.Entity:GetChildByName("Outline")
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshInfo(integer ranking, boolean isPlayer, boolean hideInfo, boolean isLastData, boolean hideRanking, boolean isEventResult)
		-- 랭킹 슬롯의 정보를 갱신하고 스타일을 적용하는 함수
		if self.Ranking == nil then
			self:Init()
		end
		
		if isEventResult then
			self.Outline.Enable = false
		end
		
		if hideInfo then
			self.StoreName.Enable = false
			self.Score.Enable = false
			
			if hideRanking then
				self.Ranking.TextComponent.Text = "-"
			else
				self.Ranking.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(ranking)
			end
				
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "2cfd6b32f6db4127ad81543ae96e355f"
			return
		end
		
		self.StoreName.Enable = true
		self.Score.Enable = true
		
		self.Ranking.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(ranking)
		local srData = _UserService.LocalPlayer.PlayerManagement.Surroundings[ranking]
		if isLastData then
			srData = _UserService.LocalPlayer.PlayerManagement.LastSurroundings[ranking]
		end
		
		if srData ~= nil then
			local srDatas = _UtilLogic:Split(srData, ",")
			local storeName = srDatas[1]
			if storeName == "RivalStoreName" then
				local storeNameKey = _StageDataSetLogic:GetStageData(_UserService.LocalPlayer.PlayerStage.NowStage).RivalStoreNameKey
				storeName = _GetLocalizationTextLogic:GetText(storeNameKey)
			else
				if isPlayer then
					storeName = _UserService.LocalPlayer.PlayerOutgameManager.StoreName
				else
					storeName = _GetLocalizationTextLogic:GetText(storeName)
				end
			end
			
			self.StoreName.TextComponent.Text = storeName
			self.Score.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(tonumber(srDatas[2])))
		end
		
		if isPlayer then
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "810dc9dbf80d41e39c4c7c23211631c7"
			self.Score.TextComponent.FontColor = _ColorCodeEnum:GetColor("#635743")
			self.Score.TextComponent.UseOutLine = true
			self.Score.TextComponent.OutlineColor = Color.white
			
			self.StoreName.TextComponent.FontColor = _ColorCodeEnum:GetColor("#ab5d17")
			self.StoreName.TextComponent.UseOutLine = true
			self.StoreName.TextComponent.OutlineColor = _ColorCodeEnum:GetColor("#fffacc")
			
			if isEventResult then
				self.Outline.Enable = false
			else
				self.Outline.Enable = true
			end	
			
		else
			self.Outline.Enable = false
			
			self.Entity.SpriteGUIRendererComponent.ImageRUID = "2cfd6b32f6db4127ad81543ae96e355f"
			
			self.Score.TextComponent.FontColor = _ColorCodeEnum:GetColor("#e58f3b")
			self.Score.TextComponent.UseOutLine = false
			
			self.StoreName.TextComponent.FontColor = _ColorCodeEnum:GetColor("#72634b")
			self.StoreName.TextComponent.UseOutLine = false
		end
	end

end