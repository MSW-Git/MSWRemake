@Component
script UIStoreRanking extends Component

	property Entity RecordText = "3a01812f-6b05-446b-89f9-663bcda808bd"

	property Entity RankingList = "c47974e8-7c2f-41ec-94f6-1d0d09ce6ec8"

	property Entity NoDataText = "4e1b60ed-3899-43cd-914f-d3bc0495c5d9"

	property Entity Rank1NPCPortrait = "da0a32cd-1ec0-4548-b4e5-b44d363d4694"

	property Entity Rank1PlayerAvatar = "f32e3654-3e4f-4d62-8dda-5bd715d219f4"

	property Entity Rank1StoreName = "ab92e3ec-3257-4b9b-8040-a14ce25280df"

	property Entity Rank1OwnerName = "189ab604-eeb7-4d8b-8968-ba85822603ce"

	property Entity FeedbackText = "788f05d9-0557-4e0a-b13f-d4f895800d6a"

	property Entity InputIcon = "bada0778-ed9d-4466-9382-41e340ebc8c5"

	property TextComponent Rank1RecordText = "d7378454-36d3-4708-a5ef-14b5240506cd"

	property Entity ReexamCostTooltip = "40e6918e-d3ae-4f6f-a67a-3fe28a281609"

	property Entity ReexamBtnDim = "95e96e0a-6830-485e-9bcc-b5b77d132b45"

	property Entity ReexamBtn = "4c90b6a8-5087-4f9d-885a-5d8ba244ca43"

	@ExecSpace("ClientOnly")
	method void Open()
		-- 상점 랭킹 UI를 열고 모든 관련 데이터를 갱신하는 함수
		if self.Entity.Parent.Enable == true then
			return
		end
		
		_UIGroupManager:EnableStoreRankingGroup(true)
		
		
		self:RefreshRankingStatus()
		self:RefreshRank1Data()
		self:RefreshReexamButton()
		
		_StoreRankingDataSetLogic:RefreshRankingRedDot()
		
		local player = _UserService.LocalPlayer
		if player.PlayerManagement.StoreRanking ~= 1 then
			_TutorialManager:SendTutorialTriggerEvent(_TutorialEventEnum.EnterRankingUI)
		end
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 상점 랭킹 UI를 닫는 함수
		_UIGroupManager:EnableStoreRankingGroup(false)
	end

	@ExecSpace("ClientOnly")
	method void RefreshRankingStatus()
		-- 플레이어의 랭킹 상태를 갱신하고 랭킹 리스트를 표시하는 함수
		local playerRanking = _UserService.LocalPlayer.PlayerManagement.StoreRanking
		
		for i = 1, #self.RankingList.Children do
			self.RankingList.Children[i].Enable = false
		end
		
		if playerRanking == 0 or playerRanking == nil then
			self.NoDataText.Enable = true
			self.RankingList.Enable = false
			
			self.RecordText.TextComponent.Text = _GetLocalizationTextLogic:GetText("RankingEmptyInfoText")
		else
			self.NoDataText.Enable = false
			self.RankingList.Enable = true
			
			local rankingText = _StringUtilLogic:ReturnThousandsSeparatedString(playerRanking)
			self.RecordText.TextComponent.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Ranking_Format", rankingText)
			
			local idxData = _StoreRankingDataSetLogic:ReturnIndexsByRanking(playerRanking)
			local startIdx = idxData[1]
			local endIdx = idxData[2]
			
		    local modelIdx = 1
			for i = startIdx, endIdx do
				local entity = _UIEntityService:GetOrCreateEntityOfModel("Model_StoreRankingSlot", modelIdx, self.RankingList)
				entity.UIStoreRankingSlotRenderer:RefreshInfo(i, i == playerRanking, false, false, false, false)
				
				modelIdx = modelIdx + 1
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshRank1Data()
		-- 1위 랭커의 정보를 갱신하여 표시하는 함수 (플레이어가 1위인지 라이벌인지에 따라 다르게 표시)
		local playerRanking = _UserService.LocalPlayer.PlayerManagement.StoreRanking
		
		if playerRanking == 1 then
			self.Rank1PlayerAvatar.Enable = true
			self:ClearAvatarCostume(self.Rank1PlayerAvatar.CostumeManagerComponent)
			
			self.Rank1NPCPortrait.Enable = false
			
			self.Rank1StoreName.TextComponent.Text = _UserService.LocalPlayer.PlayerOutgameManager.StoreName
			self.Rank1OwnerName.TextComponent.Text = _UserService.LocalPlayer.PlayerComponent.Nickname
			
			self.FeedbackText.TextInputComponent.Enable = true
			self.InputIcon.Enable = true
			self.FeedbackText.TextComponent.Text = _UserService.LocalPlayer.PlayerManagement.RankingSpeech
			self.FeedbackText.TextInputComponent.Text = _UserService.LocalPlayer.PlayerManagement.RankingSpeech
			self.FeedbackText.TextInputComponent.CharacterLimit = 70
			self.FeedbackText.LocalizedTextInputComponent:SetCharacterLimit()
			
			local recordScore = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(_UserService.LocalPlayer.PlayerSettlement.BestRecipeEarnings))
			self.Rank1RecordText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Meso_Format", recordScore)
			
		else
			local nowStage = _UserService.LocalPlayer.PlayerStage.NowStage
			local stageData = _StageDataSetLogic:GetStageData(nowStage)
			self.Rank1PlayerAvatar.Enable = stageData.RivalType == "Avatar"
			self.Rank1NPCPortrait.Enable = stageData.RivalType == "Npc"
			
			if stageData.RivalType == "Npc" then
				self.Rank1NPCPortrait.SpriteGUIRendererComponent.ImageRUID = stageData.RivalTypeValue
				self.Rank1NPCPortrait.SpriteGUIRendererComponent.LocalPosition.y = stageData.RivalPosY
			elseif stageData.RivalType == "Avatar" then
				---@type CustomAvatarData
				local rivalAvatar = _DialogDataLogic.CustomAvatarData[stageData.RivalTypeValue]
				rivalAvatar:SetAvatarCostume(self.Rank1PlayerAvatar.CostumeManagerComponent)		
			end
				
			self.Rank1StoreName.TextComponent.Text = _GetLocalizationTextLogic:GetText(stageData.RivalStoreNameKey)
			self.Rank1OwnerName.TextComponent.Text = _GetLocalizationTextLogic:GetText(stageData.RivalCharNameKey)
			
			self.FeedbackText.TextInputComponent.Enable = false
			self.InputIcon.Enable = false
			self.FeedbackText.TextInputComponent.CharacterLimit = 999
			
			local feedbackPool = {}
			table.insert(feedbackPool, _GetLocalizationTextLogic:GetText(string.format("RivalComment%d_%d", nowStage, 1)))
			table.insert(feedbackPool, _GetLocalizationTextLogic:GetText(string.format("RivalComment%d_%d", nowStage, 2)))
			table.insert(feedbackPool, _GetLocalizationTextLogic:GetText(string.format("RivalComment%d_%d", nowStage, 3)))
			
			if not (playerRanking == nil or playerRanking == 0) then
				if playerRanking < 1000 then
					table.insert(feedbackPool, _GetLocalizationTextLogic:GetText(string.format("RivalComment%d_%d", nowStage, 4)))
				else
					table.insert(feedbackPool, _GetLocalizationTextLogic:GetText(string.format("RivalComment%d_%d", nowStage, 5)))
				end
			end
			
			
			local randomIndex = _UtilLogic:RandomIntegerRange(1, #feedbackPool)
			local feedbackText = feedbackPool[randomIndex]
			
			self.FeedbackText.TextComponent.Text = feedbackText
			self.FeedbackText.TextInputComponent.Text = feedbackText
			
			local rank1Score = stageData:GetStageRankingData(1).Score
			local rank1ScoreStr = _StringUtilLogic:ReturnThousandsSeparatedString(math.floor(rank1Score))
			self.Rank1RecordText.Text = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("Meso_Format", rank1ScoreStr)
		end
	end

	method void ClearAvatarCostume(CostumeManagerComponent costume)
		-- 아바타의 모든 커스텀 코스튬을 초기화하는 함수
		costume.UseCustomEquipOnly = false
		
		costume.CustomBodyEquip = ""
		costume.CustomFaceEquip = ""
		costume.CustomHairEquip = ""
		costume.CustomLongcoatEquip = ""
		costume.CustomCapEquip = ""
		
		costume.CustomCapeEquip = ""
		costume.CustomEarEquip = ""
		costume.CustomEarAccessoryEquip = ""
		costume.CustomEyeAccessoryEquip = ""
		costume.CustomFaceAccessoryEquip = ""
		costume.CustomTwoHandedWeaponEquip = ""
		costume.CustomGloveEquip = ""
	end

	@ExecSpace("ClientOnly")
	method void RefreshReexamButton()
		-- 재심사 버튼의 상태와 비용 정보를 갱신하는 함수
		local player = _UserService.LocalPlayer
		local playerRanking = player.PlayerManagement.StoreRanking
		
		self.ReexamBtn.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.EmptyMaterial)
		
		
		if playerRanking == 0 or playerRanking == nil then 
			self.ReexamBtnDim.Enable = true
			self.ReexamBtnDim:GetChildByName("Lock").Enable = true
			self.ReexamCostTooltip.Enable = false
		else
			if playerRanking == 1 then 
				self.ReexamBtnDim.Enable = true
				self.ReexamBtnDim:GetChildByName("Lock").Enable = false
				self.ReexamCostTooltip.Enable = false
			else 
				self.ReexamBtnDim.Enable = false
				self.ReexamCostTooltip.Enable = true
				
				self.ReexamCostTooltip.TextComponent.Text = _StringUtilLogic:ReturnThousandsSeparatedString(_StoreRankingDataSetLogic:GetRankingReexamCost(player))
				self.ReexamCostTooltip.TextComponent.FontColor = player.PlayerInventory.Money < _StoreRankingDataSetLogic:GetRankingReexamCost(player) and _ColorCodeEnum:GetColor("#FA5246") or _ColorCodeEnum:GetColor("#000000")
				
				local stageRank1Score = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage):GetStageRankingData(1).Score
				if player.PlayerSettlement.BestRecipeEarnings >= stageRank1Score then 
					self.ReexamBtn.SpriteGUIRendererComponent:ChangeMaterial(_IconRuidEnum.UI_AdvantageMaterial)
				end
			end
		end
	end

	@EventSender("Entity", "cd6ac1b9-3672-45e2-92fa-df29dcee6247")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 랭킹 UI 열기 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		self:Open()
	end

	@EventSender("Entity", "3794f8e9-a568-4efa-8b3e-248cc55e780c")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 랭킹 UI 닫기 버튼 클릭 이벤트 핸들러
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
		self:Close()
	end

	@EventSender("Entity", "788f05d9-0557-4e0a-b13f-d4f895800d6a")
	handler HandleTextInputEndEditEvent(TextInputEndEditEvent event)
		-- 랭킹 코멘트 텍스트 입력 완료 이벤트 핸들러
		
		local Text = event.text
		local player = _UserService.LocalPlayer
		local lastText = player.PlayerManagement.RankingSpeech
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		player.PlayerManagement:RequestSetRankingSpeech(Text)
	end

	@EventSender("Entity", "4c90b6a8-5087-4f9d-885a-5d8ba244ca43")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 랭킹 재심사 버튼 클릭 이벤트 핸들러
		
		local player = _UserService.LocalPlayer
		if _UIGroupManager:IsEnableOpenPopUp() == false then
			return
		end
		
		if player.PlayerManagement.StoreRanking == 0 or player.PlayerManagement.StoreRanking == nil then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("RankingReexamErrorToast1")) 
			return
		end
		
		local srData = player.PlayerManagement.Surroundings[player.PlayerManagement.StoreRanking]
		local srDatas = _UtilLogic:Split(srData, ",")
		local exStoreRanking = math.floor(tonumber(srDatas[2]))
		
		if player.PlayerManagement.StoreRanking == 1 then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("RankingReexamErrorToast2")) 
			return
		end
		
		if player.PlayerInventory.Money < _StoreRankingDataSetLogic:GetRankingReexamCost(player) then
			_UIToast:ShowMessage(_GetLocalizationTextLogic:GetText("NoMoneyToastMsg")) 
			return
		end
		
		local onOk = function()
			player.PlayerManagement:RequestReexamRanking()
		end
		
		local contents = _LocalizationService:GetTranslatorForLocale(_LocalizationService.CurrentLocaleId):GetTextFormat("RankingReexamPopupContents"
				,_StringUtilLogic:ReturnThousandsSeparatedString(exStoreRanking)
				,_StringUtilLogic:ReturnThousandsSeparatedString(player.PlayerManagement.StoreRanking)
				,_StringUtilLogic:ReturnThousandsSeparatedString(player.PlayerSettlement.BestRecipeEarnings)
			)
		
		_SoundService:PlaySound(_ResourceManager.SFXTable["Click"], 1)
		_UIPopup:Open(contents, onOk, function() end, _GetLocalizationTextLogic:GetText("RankingReexamPopupTitle"))
	end

end