@Component
script DebugMonitorUIStore extends Component

	property integer InfoTextUiLength = 430

	property SyncTable<string, Entity> InfoEntityList

	property SyncTable<string, string> ManagementCategoryInfos

	property SyncTable<string, string> AttractiveCategoryInfos

	property SyncTable<string, string> ReputationCategoryInfos

	property string CategoryManagement = "Management"

	property string CategoryAttractive = "Attractive"

	property string CategoryReputation = "Reputation"

	property number MonthlyDownByReview = 0

	property number MonthlyUpByReview = 0

	property number MonthlyUpByContents = 0

	property SyncTable<string, string> PiggyBankCategoryInfos

	property string CategoryPiggyBank = "PiggyBank"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 디버그 모니터 상점 정보 UI를 초기화하고 데이터 설정
		local dataSet = _DataService:GetTable("DebugMonitorStoreInfo")
		local player = _UserService.LocalPlayer
		table.clear(self.InfoEntityList)
		
		for i = 1 , dataSet:GetRowCount() do
			
			local inforKey = dataSet:GetCell( i , 1)
				
			local entity = _SpawnService:SpawnByModelId(player.PlayerDebugMonitor.MonitorInfoText , inforKey , Vector3.zero, self.Entity)
			entity.UITransformComponent.RectSize.x = self.InfoTextUiLength
			self.InfoEntityList[inforKey] = entity
		
			local category = dataSet:GetCell( i , 2)
			local valueText = "text"
				
			if category == self.CategoryManagement then
				self.ManagementCategoryInfos[inforKey] = valueText
				
			elseif category == self.CategoryAttractive then
				self.AttractiveCategoryInfos[inforKey] = valueText
			
			elseif category == self.CategoryReputation then
				self.ReputationCategoryInfos[inforKey] = valueText
			
			elseif category == self.CategoryPiggyBank then
				self.PiggyBankCategoryInfos[inforKey] = valueText
				
			end
			
			entity.TextComponent.Text = inforKey.." : "..valueText
		end
		
	end

	@ExecSpace("Client")
	method void SetUiManagementInfo()
		-- 경영 정보를 UI에 설정 (경영 레벨, 수익 레벨, 매력도 요구사항 등)
		local player = _UserService.LocalPlayer
		local managementLevel = player.PlayerManagement.ManagementLevel 
		
		local stageEarningLevelData = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage):GetStageEarningLevelData(player.PlayerSettlement.EarningLevel)
		if stageEarningLevelData == nil then
			return
		end
		local storeAttractiveLevelData = _BalanceDataSetLogic:GetStoreAttractiveLevelData(stageEarningLevelData.StoreAttractiveLevel)
		if storeAttractiveLevelData == nil then
			return
		end
		
		for key , v in pairs(self.ManagementCategoryInfos) do
			if key == "ManagementLevel" and isvalid(managementLevel) then
				self.ManagementCategoryInfos[key] = tostring (managementLevel )
				
				local levelNameText = _GetLocalizationTextLogic:GetText("NameManagementLevel"..tostring(managementLevel))
						
				self.InfoEntityList[key].TextComponent.Text = key.. " : "..self.ManagementCategoryInfos[key].." ("..tostring(levelNameText)..")"
				
			elseif key == "EarningLevel" and isvalid(stageEarningLevelData) then
				
				self.ManagementCategoryInfos[key] = tostring( stageEarningLevelData.EarningLevel )
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : "..self.ManagementCategoryInfos[key]
				
				
			elseif key == "RequiredCustomerAttractive" and isvalid(storeAttractiveLevelData) then
				self.ManagementCategoryInfos[key] = "( 손님 요구 매력도 : min=" ..tostring(storeAttractiveLevelData.RequiredAttractiveGroup[1]).."/max="..tostring(storeAttractiveLevelData.RequiredAttractiveGroup[9]).." )"
				self.InfoEntityList[key].TextComponent.Text = "- "..self.ManagementCategoryInfos[key]
				
			elseif key == "NextRequiredEarning" and isvalid(stageEarningLevelData) then
				self.ManagementCategoryInfos[key] = tostring( stageEarningLevelData.BestRecipeEarnings )
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : "..self.ManagementCategoryInfos[key]
				
		
			elseif key == "MaxScore" and isvalid(storeAttractiveLevelData) then	
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(storeAttractiveLevelData.MaxReputation)
						
			end	
			
		end
		
	end

	@ExecSpace("Client")
	method void SetAttractiveInfo()
		-- 상점 매력도 정보를 UI에 설정 (확장, 인테리어, 데코, 레시피)
		
		local player = _UserService.LocalPlayer
		
		for key , v in pairs(self.AttractiveCategoryInfos) do
			
			if key == "AttractiveScore" then
				self.InfoEntityList[key].TextComponent.Text = key.. " : ".. tostring(player.CustomerManager.MyAttractiveScore)
				
			elseif key == "Expension" then	
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(player.CustomerManager:CalcAttractiveExpension())
				
			elseif key == "Interior" then
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(player.CustomerManager:CalcAttractiveInterior())
				
			elseif key == "Deco" then
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(player.CustomerManager:CalacAttractiveDeco())
				
			elseif key == "Recipe" then
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(player.CustomerManager:CalcAttractiveRecipe())
			end 
			
		end
		
	end

	@ExecSpace("Client")
	method void SetReputationInfo()
		-- 평판 정보를 UI에 설정 (평판 점수, 스폰 지연 시간)
		
		local player = _UserService.LocalPlayer
		local managementLevel = player.PlayerManagement.ManagementLevel
		
		local stageData = _StageDataSetLogic:GetStageData(player.PlayerStage.NowStage)
		local repMgData = stageData:GetReputationManagementData(managementLevel)
		
		
		for key , v in pairs(self.ReputationCategoryInfos) do
			
			if key == "ReputationScore" then
				self.InfoEntityList[key].TextComponent.Text = key.. " : ".. tostring(player.PlayerInventory.Reputation)
				
		
			elseif key == "SpawnDelay" and isvalid(managementLevel) then	
				local spawnDelay = _ReputationDataSetLogic:ReturnSpawnDelay(player)
				local minSpawnDelay = repMgData.MinSpawnDelay
				local maxSpawnDelay = repMgData.MaxSpawnDelay + minSpawnDelay
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(math.floor(spawnDelay*1000)/1000).." (min=" ..tostring(minSpawnDelay).."/max="..tostring(maxSpawnDelay).." )"
				
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetReputationChangeByReview(number reputationChange)
		-- 리뷰에 의한 평판 변화량을 월간 누적치로 설정
		
		if reputationChange < 0 then
		
			local key = "MonthlyDownByReview" 
			self.MonthlyDownByReview = self.MonthlyDownByReview + reputationChange 
			self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(self.MonthlyDownByReview )
			
		elseif reputationChange > 0 then
		
			local key = "MonthlyUpByReview"
			self.MonthlyUpByReview = self.MonthlyUpByReview + reputationChange 
			self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(self.MonthlyUpByReview )
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetReputationChangeByContents(number reputationChange)
		-- 콘텐츠에 의한 평판 변화량을 월간 누적치로 설정
		
		self.MonthlyUpByContents = self.MonthlyUpByContents + reputationChange
			
		local key = "MonthlyUpByContents"
		self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(self.MonthlyUpByContents )
		
	end

	@ExecSpace("ClientOnly")
	method void ResetReputationChangeByReview()
		-- 월간 평판 변화량 누적치를 모두 리셋
		
		self.MonthlyUpByReview = 0
		self.MonthlyDownByReview = 0
		self.MonthlyUpByContents = 0
		local key = "MonthlyDownByReview" 
		self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(self.MonthlyDownByReview )
		key = "MonthlyUpByReview"
		self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(self.MonthlyUpByReview )
		key = "MonthlyUpByContents"
		self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(self.MonthlyUpByContents )
	end

	@ExecSpace("ClientOnly")
	method void SetPiggyBankInfo(integer requiredEarnings, integer piggyBankEarnings)
		-- 저금통 정보를 UI에 설정 (다음 레벨까지 수익, 추가 포인트)
		local player = _UserService.LocalPlayer
		
		for key , v in pairs(self.PiggyBankCategoryInfos) do
			
			if key == "IncomeToNextPiggyLevel" then
				self.InfoEntityList[key].TextComponent.Text = key.. " : ".. tostring(piggyBankEarnings) .."/".. tostring(requiredEarnings)
				
			elseif key == "NextAddPiggyPoint" then	
				self.InfoEntityList[key].TextComponent.Text = "- "..key.. " : ".. tostring(_GetConfigDataLogic:GetConfigNumDataByKey(_PiggyBankDataLogic.AddPointPerEarningRateKey))
		
			end 
			
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandlePlayerManagementChangedEvent(PlayerManagementChangedEvent event)
		-- 플레이어 경영 레벨 변경 이벤트 처리
		
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		if isvalid( _UserService.LocalPlayer.PlayerDebugMonitor.StoreInfoMonitor) then
			self:SetUiManagementInfo()
		end
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEarningLevelChangedEvent(EarningLevelChangedEvent event)
		-- 수익 레벨 변경 이벤트 처리
		local EarningLevel = event.EarningLevel
		
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		if isvalid( _UserService.LocalPlayer.PlayerDebugMonitor.StoreInfoMonitor) then
			self:SetUiManagementInfo()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandlePlayerReputationChangedEvent(PlayerReputationChangedEvent event)
		-- 플레이어 평판 변경 이벤트 처리
		local Current = event.Current
		local Amount = event.Amount
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		
		if isvalid( _UserService.LocalPlayer.PlayerDebugMonitor.StoreInfoMonitor) then
			self:SetReputationInfo()
		end
	end

end