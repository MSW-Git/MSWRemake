@Logic
script CheatButtonMacroLogic extends Logic

	property Entity lastClickButton = nil

	property boolean macroEnable = false

	@ExecSpace("ClientOnly")
	method void AutoClick()
		-- 매크로가 활성화되었을 때 자동으로 버튼을 여러 번 클릭
		if self.macroEnable == false then
			return
		end
		self.macroEnable = false
		local random = _UtilLogic:RandomIntegerRange(3,10)
		_ScreenMessageLogic:PrivateMsg(string.format("멀티클릭 %d번 실행(후 자동 비활성화)",random))
		if isvalid(self.lastClickButton) then
			for i = 1, random do
				self.lastClickButton:SendEvent(ButtonClickEvent(self.lastClickButton))
				wait(0.01)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Model", "uibutton")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- UI 버튼 클릭 이벤트를 처리하고 자동 클릭 실행
		
		local Entity = event.Entity
		
		self.lastClickButton = Entity
		self:AutoClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Model", "uitext")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- UI 텍스트 클릭 이벤트를 처리하고 자동 클릭 실행
		
		local Entity = event.Entity
		self.lastClickButton = Entity
		self:AutoClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Model", "uisprite")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- UI 스프라이트 클릭 이벤트를 처리하고 마지막 클릭 버튼 저장
		
		local Entity = event.Entity
		self.lastClickButton = Entity
	end

	@ExecSpace("ClientOnly")
	@EventSender("Model", "uiempty")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- UI 빈 요소 클릭 이벤트를 처리하고 자동 클릭 실행
		
		local Entity = event.Entity
		self.lastClickButton = Entity
		self:AutoClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- F10 키를 눌러 매크로 기능을 토글하는 키보드 이벤트 처리
		
		local key = event.key
		if isvalid(_UserService.LocalPlayer) == false then
			return
		end
		
		if not _UserService.LocalPlayer.PlayerCheatComponent:HasAuthority() then
			return
		end
		
		if key == KeyboardKey.F10 then
			self.macroEnable = not self.macroEnable
			if self.macroEnable then
				_ScreenMessageLogic:PrivateMsg("멀티클릭 활성화")
			else
				_ScreenMessageLogic:PrivateMsg("멀티클릭 비활성화")
			end
			
		end
	end

end