@Component
script PlayerAdmin extends Component

	@TargetUserSync
	property boolean IsAdmin = false

	property boolean EnableMonitorButtonSetPanel = false

	property Entity MobileOnlyCheatButton = nil

	property Entity MobileOnlyMonitorButton = nil

	property Entity MobileOnlyMonitorButtonSetPanel = nil

	property string PublishWorldId = "21ad8c8b33f34d5aa8be5827a7b07246"

	property string AdminUserId = ""

	property Entity VersionText = nil

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 플레이어가 게임에 입장할 때 관리자 권한을 확인하고 설정
		
		if Environment.WorldId == self.PublishWorldId then
			if self.Entity.PlayerComponent.UserId ~= self.AdminUserId then
				self.IsAdmin = false
				return
			end
		end
		
		self:VersionTextInit()
		
		local adminUserData = _DataService:GetTable("AdminUserId")
		local rowCount = adminUserData:GetRowCount()
		
		for i = 1 , rowCount do
			local id = adminUserData:GetCell(i,"id")
		
			if string.sub(self.Entity.PlayerComponent.UserId ,5, -1) == string.sub(id, 5, -1) then
				self.IsAdmin = true		
				self.Entity.PlayerDebugMonitor:SpawnUIMonitorEntity(self.Entity.PlayerComponent.UserId)
				self:RequestAdminCheatBtnEnable(self.IsAdmin , self.Entity.PlayerComponent.UserId )
				if Environment:IsMobilePlatform() then
					self:RequestMobileCheatBtnEnable(self.IsAdmin, self.Entity.PlayerComponent.UserId)
				end
				return 
			end
		end
		
		self.IsAdmin = false
	end

	@ExecSpace("Client")
	method void RequestMobileCheatBtnEnable(boolean isAdmin)
		-- 모바일 플랫폼에서 치트 버튼들의 활성화 상태를 설정
		
		self.MobileOnlyCheatButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_CheatButton")
		self.MobileOnlyCheatButton:SetEnable(isAdmin)
		
		
		self.MobileOnlyMonitorButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButton")
		self.MobileOnlyMonitorButton:SetEnable(isAdmin)
		
		
		self.MobileOnlyMonitorButtonSetPanel = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButtonSetPanel")
		
		self.MobileOnlyMonitorButtonSetPanel:SetEnable(false)
		self.EnableMonitorButtonSetPanel = false
		local storeMonitorCheatButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButtonSetPanel/MobileOnly_StoreMonitorButton")
		local customerMonitorCheatButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButtonSetPanel/MobileOnly_CustomerMonitorButton")
		local employeeMonitorCheatButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButtonSetPanel/MobileOnly_EmployeeMonitorButton")
		storeMonitorCheatButton:SetEnable(isAdmin)
		customerMonitorCheatButton:SetEnable(isAdmin)
		employeeMonitorCheatButton:SetEnable(isAdmin)
		
	end

	@ExecSpace("Client")
	method void RequestAdminCheatBtnEnable(boolean enable)
		-- 관리자 권한에 따라 디버그 UI 그룹과 치트 버튼들을 활성화
		local debugUIGroup = _EntityService:GetEntityByPath("/ui/UIDebugGroup")
		if enable then
			debugUIGroup.UIGroupComponent.DefaultShow = enable
			debugUIGroup:SetEnable(enable)
		end
		
		
		local introMapPassButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/IntroMapPassButton")
		introMapPassButton:SetEnable(enable)
	end

	@ExecSpace("Client")
	method void VersionTextInit()
		-- 버전 텍스트를 초기화하고 현재 버전 정보를 표시
		self.VersionText = _EntityService:GetEntityByPath("/ui/UIDebugGroup/VersionText")
		self.VersionText.TextComponent.Text = _Version.version
	end

	@EventSender("Entity", "f2f45490-7b9d-4a43-9ae4-35ffcf058c94")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 인트로 맵 패스 버튼 클릭 시 월드 입장 준비 완료 처리
		
		
		_UserService.LocalPlayer.TitleManager:ReadyForEnterToWorld(true)
		event.Entity:SetEnable(false)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "9327af0f-9b81-494f-beeb-a697d6a39ab0")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 모바일 모니터 버튼 클릭 시 모니터 버튼 세트 패널 토글
		
		
		if self.MobileOnlyMonitorButtonSetPanel == nil then
		self.MobileOnlyMonitorButtonSetPanel = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButtonSetPanel")
		end
		
		if self.MobileOnlyMonitorButton == nil then
			self.MobileOnlyMonitorButton = _EntityService:GetEntityByPath("/ui/UIDebugGroup/MobileOnly_MonitorButton") 
		end
		
		
		if self.EnableMonitorButtonSetPanel == false then
			self.EnableMonitorButtonSetPanel = true
			self.MobileOnlyMonitorButtonSetPanel:SetEnable(true)
			self.MobileOnlyMonitorButton.SpriteGUIRendererComponent.ImageRUID = "f1dcd3fece0b40fe9b51ef84003de667"
			
		elseif self.EnableMonitorButtonSetPanel == true then
			self.EnableMonitorButtonSetPanel = false
			self.MobileOnlyMonitorButtonSetPanel:SetEnable(false)
			self.MobileOnlyMonitorButton.SpriteGUIRendererComponent.ImageRUID = "8e66330dfab24da194b036720ba9449e"
		end
		
		
		
	end

end