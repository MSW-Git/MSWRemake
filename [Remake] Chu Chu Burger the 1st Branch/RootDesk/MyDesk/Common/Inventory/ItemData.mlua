@Struct
script ItemData

	property string Id = ""

	property integer ItemCategory = 0

	property string IconRUID = ""

	property string funcUseItemName = ""

	property table funcUseItemParam = {}

	property integer MaxStackCount = 0

	property string NameKey = ""

	property string DescriptionKey = ""

	property boolean SaveToOutgameDB = false

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 아이템 정보를 로드하는 메서드
		local loadTable = dataTable
		local rowData = loadTable:GetRow(index)
		
		local ItemString = 'Item'
		self.Id = rowData:GetItem("Id")
		self.ItemCategory = tonumber(rowData:GetItem("ItemCategory"))
		self.NameKey = rowData:GetItem("NameKey")
		self.DescriptionKey = rowData:GetItem("DescriptionKey")
		self.IconRUID = rowData:GetItem("IconRUID")
		self.MaxStackCount = tonumber(rowData:GetItem("MaxStackCount"))
		local funcUseItem = rowData:GetItem("funcUseItem")
		if _UtilLogic:IsNilorEmptyString(funcUseItem) == false then
			local deleteSpaceStr, num = string.gsub(funcUseItem, '%s', '')
			local tokenizedStringTable = _UtilLogic:Split(deleteSpaceStr, ',', false)
			local paramTable = {}
			table.move(tokenizedStringTable, 2, #tokenizedStringTable, 1, paramTable)
			
			self.funcUseItemName = tokenizedStringTable[1]
			self.funcUseItemParam = paramTable
		end
		
		self.SaveToOutgameDB = _StringUtilLogic:GetBoolByString(rowData:GetItem("SaveToOutgameDB"), false)
	end

	method table GetUseItems_List()
		-- 사용 아이템 정보를 리스트 형태로 반환하는 메서드
		local items = {}
		local pair = {}
		for index, e in pairs(self.funcUseItemParam) do
			if index % 2 == 1 then
				pair[1] = e
			else
				pair[2] = math.tointeger(e)
				table.insert(items, {pair[1], pair[2]})
			end
		end
		return items
	end

	method table GetUseItems_Dictinary()
		-- 사용 아이템 정보를 딕셔너리 형태로 반환하는 메서드
		
		if #self.funcUseItemParam == 0 then
			return nil
		end
		
		local result = {}
		local itemId
		
		for index, e in pairs(self.funcUseItemParam) do
			if index % 2 == 1 then
				itemId = e
			else
				result[itemId] = math.tointeger(e)
			end
		end
		
		return result
	end

	method table GetUseItems_ItemId_Pair()
		-- 사용 아이템 정보를 아이템 ID와 함께 쌍으로 반환하는 메서드
		if #self.funcUseItemParam == 0 then
			return {rewardList = {}, rewardItemIds = {}}
		end
		
		local result = {}
		local ids = {}
		local itemId
		
		for index, e in pairs(self.funcUseItemParam) do
			if index % 2 == 1 then
				itemId = e
			else
				result[itemId] = math.tointeger(e)
				table.insert(ids, itemId)
			end
		end
		
		return {rewardList = result, rewardItemIds = ids}
	end

end