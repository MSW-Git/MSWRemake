	method string GetSkillTypeIcon(string type)
		-- 스킬 타입에 따른 아이콘 RUID를 반환
		local ruid 
		if type == _EmployeeTypeEnum.Cook then 
			ruid = self.SkillIcon_Cook
			
		elseif type == _EmployeeTypeEnum.Serving then 
			ruid = self.SkillIcon_Serving
		
		elseif type == "Recipe" then 
			ruid = self.SkillIcon_Recipe
		
		elseif type == "Training" then 
			ruid = self.SkillIcon_Training
		
		end
		
		return ruid
	end

	method string GetComboCountRUID(integer int)
		-- 콤보 카운트에 해당하는 숫자 아이콘 RUID를 반환
		if int == 0 then
			return "373983bbc9854f7980e634cbc03ccfde"
		elseif int == 1 then
			return "57254cf420c649c38610f76f71755cc8"
		elseif int == 2 then
			return "5f536843a80c4bb899901bd1baf38ced"
		elseif int == 3 then
			return "f9afbe8328e6491683b2f102f754a456"
		elseif int == 4 then
			return "e62beb4a286642cb8f0fee7e48b16e7d"
		elseif int == 5 then
			return "df3c9bf1de524fbea88a7e399bc42633"
		elseif int == 6 then
			return "1cb6ac616b0143c4825e0c47d546dd79"
		elseif int == 7 then
			return "2352ce09ac754950a0f5588ee1db7a13"
		elseif int == 8 then
			return "8f1fa0d9d8d5461d9612de193e9c1b6b"
		elseif int == 9 then
			return "6b69c89ea9364ad8af6b4c59b62204f0"
		end
	end

	method string GetEffectRUIDByGrade(integer grade)
		-- 등급에 따른 이펙트 RUID를 반환
		if grade >= 3 then
			return "3d77a6d8208045c59c5fc55c3e8cc092"
		elseif grade == 2 then
			return "6e899a6478b84758b6c1ba2f89da835c"
		else
			return nil
		end
	end

	method string GetOverLimitJemIcon(string type)
		-- 직원 타입에 따른 오버리밋 젬 아이콘 RUID를 반환
		local ruid 
		if type == _EmployeeTypeEnum.Cook then 
			ruid = self.OverlimitJemIcon_Cook
			
		elseif type == _EmployeeTypeEnum.Serving then 
			ruid = self.OverlimitJemIcon_Serving
		end
		return ruid
	end

	method string GetAutoTrainingIcon(integer index)
		-- 인덱스에 따른 자동 훈련 아이콘 RUID를 반환
		if index == 1 then
			return self.AutoTrainingIcon_1
		elseif index == 2 then
			return self.AutoTrainingIcon_2
		elseif index == 3 then
			return self.AutoTrainingIcon_3
		end
	end

	method string GetMaterialEntryId(string materialId)
		-- 머터리얼 ID에 해당하는 엔트리 ID를 반환
		if materialId == "GrayScaleMaterial" then
			return self.GrayScaleMaterial
			
		elseif materialId == "UI_AdvantageMaterial" then
			return self.UI_AdvantageMaterial
			
		elseif materialId == "ChuChuMovementMaterial" then
			return self.ChuChuMovementMaterial
		
		elseif materialId == "BounceMaterial" then
			return self.BounceMaterial
		
		elseif materialId == "BlackoutMaterial" then
			return self.BlackoutMaterial
		
		elseif materialId == "RainbowMaterial" then
			return self.RainbowMaterial
		
		elseif materialId == "ChuChuMovementMaterial" then
			return self.ChuChuMovementMaterial
			
		elseif materialId == "ToastDialogItemMaterial" then
			return self.ToastDialogItemMaterial
		
		elseif materialId == "ScorePreviewMaterial" then
			return self.ScorePreviewMaterial
			
		elseif materialId == "EmptyMaterial" then
			return self.EmptyMaterial
		else
			return ""
			
		end
	end

end