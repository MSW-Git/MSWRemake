@Struct
script MainMenuBtnData

	property string Id = ""

	property integer Category = 0

	property string IconRUID = ""

	property string NameKey = ""

	property string EntityPath = ""

	method void Load(any dataTable, integer index)
		-- 데이터 테이블에서 메뉴 버튼 정보를 로드하여 프로퍼티에 설정
		---@type UserDataRow
		local row = dataTable:GetRow(index)
		
		self.Id = row:GetItem("Id")
		self.Category = tonumber(row:GetItem("Category"))
		self.IconRUID = row:GetItem("IconRUID")
		self.NameKey = row:GetItem("NameKey")
		self.EntityPath = row:GetItem("EntityPath")
	end

	method string ReturnCategoryRUID()
		-- 카테고리 번호에 따라 해당하는 카테고리 아이콘 RUID를 반환
		if self.Category == 1 then
			return "4bb584fcade34125a388f136a98459d3"
		elseif self.Category == 2 then
			return "3002f830425f4a08a49d5f90b287eaac"
		elseif self.Category == 3 then
			return "d4f8d8d2e3d047729b769cbbd8616077"
		elseif self.Category == 4 then
			return "f76b7e3c740b46c7b681da302a6fa54b"
		end
	end

end