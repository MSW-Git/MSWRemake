@Component
script LocalizedTextComponent extends Component

	property number OriginFontSize = 0

	property number FontSize_es = 0

	property boolean IsAutoSet = true

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 시작 시 자동 설정이 활성화되어 있으면 폰트 크기를 설정
		if self.IsAutoSet == true then
			self:SetFontSize()
		end
	end

	@ExecSpace("ClientOnly")
	method void SetFontSize()
		-- 현재 로케일에 따라 텍스트 컴포넌트의 폰트 크기를 조정
		local textComp = self.Entity.TextComponent
		if textComp == nil then
			return
		end
		
		if self.OriginFontSize == 0 then
			self.OriginFontSize = textComp.FontSize
		end
		
		if _LocalizationService.CurrentLocaleId == "es" then
			textComp.FontSize = self.FontSize_es
		end
	end

end