	property Entity IngreSynthGroup = "fe38a2eb-4ba0-4d52-a401-745ea9925c82"

	@ExecSpace("ClientOnly")
	method boolean IsOnUI()
		-- 어떤 UI 그룹이라도 활성화되어 있는지 확인하여 반환
		local isUIOn = 
			self.TrialGroup.Enable
			or self.EmploymentGroup.Enable
			or self.RecipeGroup.Enable
			or self.AchievementGroup.Enable
			or self.ManagementGroup.Enable
			or self.TrainingGroup.Enable
			or self.EmployeeManageGroup.Enable
			or self.VIPOrderGroup.Enable
			or self.EmployeeUpgradeGroup.Enable 
			or self.TransferGroup.Enable
			or self.UpgradeGroup.Enable
			or self.EventGroup.Enable
			or self.RecipeSetGroup.Enable
			or self.RewardGroup.Enable
			or self.StoreRankingGroup.Enable
			or self.FadeGroup.Enable
			or self.PopupGroup.Enable
			or self.TrainingSettingGroup.Enable
			or self.TrainingAutoGroup.Enable
			or _UILobbyManager.MainMenuPanel.Enable 
			or self.StoreInfoGroup.Enable
			or self.ShopGroup.Enable
			or self.GuideGroup.Enable
			or self.TutorialGroup.Enable
			or self.ReputationRewardGroup.Enable
			or self.StageInfoGroup.Enable
			or self.IngreBunCollectionGroup.Enable
			or self.ChuchuCollectionGroup.Enable
			or self.StageClearRewardGroup.Enable
			or self.SpecialShopGroup.Enable
			or self.StagePassGroup.Enable
			or self.SelectChuchuInCollection.Enable
			or self.BadgeGroup.Enable
			or _OfflineRewardLogic:IsOfflinePopupOpened()
			or self.IngreSynthGroup.Enable
		
		return isUIOn
	end

	@ExecSpace("ClientOnly")
	method boolean IsOnLobby(boolean checkEvent)
		-- 로비 상태인지 확인 (이벤트 체크 옵션 포함)
		local isUIOn = 
			self.RecipeGroup.Enable or self.AchievementGroup.Enable or self.ManagementGroup.Enable or self.UpgradeGroup.Enable
			or self.TrialGroup.Enable or self.RecipeSetGroup.Enable or self.TrainingGroup.Enable or self.EmploymentGroup.Enable or self.EmployeeManageGroup.Enable
			or self.VIPOrderGroup.Enable or self.StoreRankingGroup.Enable or _UILobbyManager.MainMenuPanel.Enable or self.StoreInfoGroup.Enable or self.RewardGroup.Enable 
			or self.ShopGroup.Enable or self.GuideGroup.Enable  or self.EmployeeUpgradeGroup.Enable or self.FadeGroup.Enable or self.ReputationRewardGroup.Enable
			or self.StageInfoGroup.Enable or self.IngreBunCollectionGroup.Enable or self.ChuchuCollectionGroup.Enable or self.StageClearRewardGroup.Enable or self.SelectChuchuInCollection.Enable
			or self.StagePassGroup.Enable or self.BadgeGroup.Enable or self.SpecialShopGroup.Enable or self.StagePassGroup.Enable or self.PiggyBankGroup.Enable or self.BoosterPackGroup.Enable
			or self.DialogGroup.Enable or _OfflineRewardLogic:IsOfflinePopupOpened() or self.IngreSynthGroup.Enable or self.TrainingAutoGroup.Enable
		
		if checkEvent == true then
			isUIOn = isUIOn or self.TutorialGroup.Enable or self.EventGroup.Enable
		end
		
		return not isUIOn
	end

	@ExecSpace("Client")
	method boolean ClearAllUI()
		-- 열려있는 모든 UI를 순차적으로 닫고 정리
		local uiStoreInfo = _EntityService:GetEntityByPath("/ui/StoreInfoGroup/UIStoreInfo")
		local uiVIPOrder = _EntityService:GetEntityByPath("/ui/VIPOrderGroup/VIPOrderPanel")
		local uiManagement = _EntityService:GetEntityByPath("/ui/ManagementGroup/UIManagement")
		local uiStoreRanking = _EntityService:GetEntityByPath("/ui/StoreRankingGroup/StoreRanking")
		local uiAchievement = _EntityService:GetEntityByPath("/ui/AchievementGroup/Model_UIAchievement")
		local uiUpgrade = _EntityService:GetEntityByPath("/ui/UpgradeGroup/UpgradePanel")
		local uiRecipeBook = _UIEntityLogic_RecipeGroup.UIRecipeBook
		local uiIngreGacha = _UIEntityLogic_RecipeGroup.UIIngreGachaDim
		local uiShop = _EntityService:GetEntityByPath("/ui/UIShopGroup/UIShop")
		local uiGuidePage = _EntityService:GetEntityByPath("/ui/GuideUIGroup/GuidePageSample")
		local uiTrialSelect = _TrialUILogic.UITrialSelect
		local uiTrialSetEmployee = _TrialUILogic.UITrialSetEmployee
		local uiSetRecipe = _UIEntityLogic_RecipeGroup.UIRecipeList
		local uiEmployment = self.EmploymentGroup
		local uiStageSelect = _StageDataSetLogic.UIStageSelect.Entity
		local uiStageInfo = _StageDataSetLogic.UIStageInfo.Entity
		local uiStageSetting = _StageDataSetLogic.UIStageSetting.Entity
		local uiSpecialShop = _SpecialShopDataLogic.UISpecialShop
		local uiStagePass = _StagePassDataLogic.UIStagePassEntity
		local uiBoosterPack = _BoosterPackDataLogic.UIBoosterPack
		local uiPiggyBank = _PiggyBankDataLogic.UIPiggyBank
		
		if uiRecipeBook.Enable then
			local close = uiRecipeBook.UIRecipeBook:Close(true, false)
			if close == false then
				return false
			end
		end
		
		if uiIngreGacha.Enable then
			uiIngreGacha.UIIngreGacha:Close()
		end
		
		if self.RecipeGroup.Enable then
			self:EnableRecipeGroup(false)
		end
		
		if uiStoreInfo.Enable then
			uiStoreInfo.UIStoreInfo:Close()
		end
		
		if uiVIPOrder.Enable then
			uiVIPOrder.UIVIPOrderPanel:Close(true)
		end
		
		if uiManagement.Parent.Enable then
			uiManagement.UIManagement:Close()
		end
		
		if uiStoreRanking.Parent.Enable then
			uiStoreRanking.UIStoreRanking:Close()
		end
		
		if uiAchievement.Parent.Enable then
			uiAchievement.UIAchievement:Close()
		end
		
		if uiUpgrade.Enable then
			uiUpgrade.UIUpgradePanel:Close()
		end
		
		if uiShop.Parent.Enable then
			uiShop.UIShop:Close()
		end
		
		if self.GuideGroup.Enable then
			for i, entity in pairs(_GuidePageManager.MadeGuidePageEntites) do
				if entity.Enable then
					entity.GuidePageController:Close()
				end
			end
		end
		
		if uiTrialSelect.Enable then
			uiTrialSelect.UITrialSelect:Close()
		end
		
		if uiTrialSetEmployee.Enable then
			uiTrialSetEmployee.UITrialSetEmployee:Close()
			if self.TrialGroup.Enable then
				self:EnableTrialGroup(false)
			end
		end
		
		if uiSetRecipe.Enable then
			uiSetRecipe.UIRecipeListHolder:Close()
		end
		
		if uiEmployment.Enable then
			uiEmployment.UIEmployment:CloseUI()
		end
		
		if self.EmployeeUpgradeGroup.Enable then
			_EmployeeUpgradeUIServcie:UIClose()
		end
		
		if self.TrainingAutoGroup.Enable then
			self.TrainingAutoGroup.UITrainingAuto:CloseUI()
		end
		
		if self.TrainingSettingGroup.Enable then
			self.TrainingSettingGroup.UITrainingSetting:CloseTrainingSettingUI()
		end
		
		if self.TransferGroup.Enable then
			self.TransferGroup.UITransfer:CloseUI()
		end
		
		if self.EmployeeManageGroup.Enable then
			_UIEmployeeManageService:UIClose()
		end
		
		if uiStageSetting.Enable then
			uiStageSetting.UIStageSetting:Close()
		end
		
		if uiStageInfo.Enable then
			uiStageInfo.UIStageInfo:Close()
		end
		
		if uiStageSelect.Enable then
			uiStageSelect.UIStageSelect:Close()
		end
		
		if self.IngreBunCollectionGroup.Enable then
			self:EnableIngreBunCollectionGroup(false)
		end
		
		if self.StageClearRewardGroup.Enable then
			self:EnableStageClearRewardGroup(false)
		end
		
		if self.SpecialShopGroup.Enable then
			uiSpecialShop.UISpecialShop:Close()
		end
		
		if self.StagePassGroup.Enable then
			uiStagePass.UIStagePass:Close()
		end
		
		if self.PiggyBankGroup.Enable then
			uiPiggyBank:Close()
		end
		
		if self.BoosterPackGroup.Enable then
			uiBoosterPack:Close()
		end
		
		if self.BadgeGroup.Enable then
			self.BadgeGroup.UIBadgeList:Close()
		end
		
		if self.ChuchuCollectionGroup.Enable then
			self:EnableChuchuCollectionGroup(false)
		end
		
		if self.SelectChuchuInCollection.Enable then
			self:EnableSelectChuchuInCollection(false)
		end
		
		if self.IngreSynthGroup.Enable then
			self.IngreSynthGroup.UIIngreSynthComponent:CloseUI()
		end
		
		if self.ExchangeSettingGroup.Enable then
			self.ExchangeSettingGroup.UIExchangeSetting:CloseExchangeSettingUI()
		end
		
		return true
	end

	@ExecSpace("ClientOnly")
	method void EnableMoneyBarGroup(boolean isEnable)
		-- 머니 바 그룹의 활성화 상태를 설정하는 함수
		local isOnUI = function()
			local isUIOn = 
				not (self.StageInfoGroup.Enable and not _StageDataSetLogic.UIStageInfo.Entity.Enable) and
				not self.TrainingGroup.Enable and not self.GuideGroup.Enable and
				not (self.RecipeGroup.Enable and _UIEntityLogic_RecipeGroup.UIRecipeMaking.Enable) and
				(
						self.TrialGroup.Enable
						or self.EmploymentGroup.Enable
						or self.RecipeGroup.Enable
						or self.AchievementGroup.Enable
						or self.ManagementGroup.Enable
						or self.EmployeeManageGroup.Enable
						or self.VIPOrderGroup.Enable
						or self.EmployeeUpgradeGroup.Enable
						or self.TransferGroup.Enable
						or self.UpgradeGroup.Enable
						or self.RecipeSetGroup.Enable
						or self.RewardGroup.Enable
						or self.StoreRankingGroup.Enable
						or self.TrainingSettingGroup.Enable
						or self.TrainingAutoGroup.Enable
						or self.StoreInfoGroup.Enable
						or self.ShopGroup.Enable
						or self.GuideGroup.Enable
						or self.ReputationRewardGroup.Enable
						or self.IngreBunCollectionGroup.Enable
						or self.ChuchuCollectionGroup.Enable
						or self.SelectChuchuInCollection.Enable
						or self.StagePassGroup.Enable
						or self.SpecialShopGroup.Enable
						or self.PiggyBankGroup.Enable
						or self.BoosterPackGroup.Enable
						or self.ExchangeSettingGroup.Enable
						or self.ExchangeGroup.Enable
						or _OfflineRewardLogic:IsOfflinePopupOpened()
						or (self.StageInfoGroup.Enable and _StageDataSetLogic.UIStageInfo.Entity.Enable)
						or self.IngreSynthGroup.Enable
				)
			
			return isUIOn
		end
		
		 
		if isEnable == nil then
			local checkEvent = true
			if self.TutorialGroup.Enable == true or self.EventGroup.Enable == true then
				checkEvent = false
			end
			isEnable = isOnUI() or self:IsOnLobby(checkEvent)
		end
		
		self.MoneyBarGroup.Enable = isEnable
		self.MoneyBarGroup.UIGroupComponent.DefaultShow = isEnable
		
		local enableDiamondInfo = self.ShopGroup.Enable
			or self.SpecialShopGroup.Enable
			or self.StagePassGroup.Enable
			or self.PiggyBankGroup.Enable
			or self.BoosterPackGroup.Enable
		
		if self.DiaInfoGroup.Enable then 
			enableDiamondInfo = false
		end
		
		if isEnable and enableDiamondInfo then
			_UIMoneyBarLogic:EnableDiamondInfoButton(true)
		else
			_UIMoneyBarLogic:EnableDiamondInfoButton(false)
		end
		
		local onlyEnableDiamondUI = self.SpecialShopGroup.Enable
			or self.StagePassGroup.Enable
			or self.ChuchuCollectionGroup.Enable
			or self.IngreBunCollectionGroup.Enable
			or self.DiaInfoGroup.Enable
			or self.StageInfoGroup.Enable
		_UIMoneyBarLogic:EnableOnlyDiamondUI(onlyEnableDiamondUI)
	end

	@ExecSpace("Client")
	method void EnableBackToLobbyBtn(boolean isEnable)
		-- 로비로 돌아가기 버튼의 활성화 상태를 설정하는 함수
		local isOnUI = function()
			local isUIOn = 
				not self.RecipeSetGroup.Enable and 
				not self.DiaInfoGroup.Enable and
				(
				self.TrialGroup.Enable
				or self.EmploymentGroup.Enable
				or (_UIGroupManager.RecipeGroup.Enable and _UIEntityLogic_RecipeGroup.UIRecipeBook.Enable)
				or (_UIGroupManager.RecipeGroup.Enable and _UIEntityLogic_RecipeGroup.UIIngreCardSetting.Enable and not _UIEntityLogic_RecipeGroup.UIIngreGachaDim.Enable)
				or (_UIGroupManager.RecipeGroup.Enable and _UIEntityLogic_RecipeGroup.UIIngreGachaDim.Enable and not _UIEntityLogic_RecipeGroup.UIIngreCardSetting.Enable)
				or self.AchievementGroup.Enable
				or self.ManagementGroup.Enable
				or self.EmployeeManageGroup.Enable
				or self.VIPOrderGroup.Enable
				or self.EmployeeUpgradeGroup.Enable
				or self.TransferGroup.Enable
				or self.UpgradeGroup.Enable
				or self.StoreRankingGroup.Enable
				or self.TrainingSettingGroup.Enable
				or self.TrainingAutoGroup.Enable
				or self.StoreInfoGroup.Enable
				or self.ShopGroup.Enable
				or self.StageInfoGroup.Enable
				or self.IngreBunCollectionGroup.Enable
				or self.ChuchuCollectionGroup.Enable
				or self.BadgeGroup.Enable
				or self.SpecialShopGroup.Enable
				or self.PiggyBankGroup.Enable 
				or self.BoosterPackGroup.Enable
				or self.StagePassGroup.Enable
				or self.ExchangeSettingGroup.Enable
				or self.IngreSynthGroup.Enable
				
				)
			return isUIOn
		end
		
		
		if isEnable == nil then
			isEnable = isOnUI()
		end
		
		
		self.BackToLobbyBtn.Enable = isEnable
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 그룹 매니저 초기화 시 실행되는 함수
		self.BackToLobbyBtn:ConnectEvent(ButtonClickEvent, function()
			if _UIGroupManager:IsEnableOpenPopUp() == false then
				return
			end
			
			if _TutorialManager.target ~= nil then
				if _TutorialManager.target ~= self.BackToLobbyBtn then
					return
				end
			end
			
			if _UtilLogic:IsNilorEmptyString(_EventManager.CurrentEventGroupId) == false and not (_TutorialManager.target == self.BackToLobbyBtn) then
				return
			end
			
			local result = self:ClearAllUI()
			if result == false then return end
			
			_TutorialManager:CheckForceTo() 
			
			_UILobbyManager.MainMenuPanel:SetEnable(false)
			_SoundService:PlaySound(_ResourceManager.SFXTable["Close"], 1)
			self:EnableMoneyBarGroup(true)
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
			
		end)
		
		self:EnableBackToLobbyBtn(false)
	end

	@ExecSpace("ClientOnly")
	method boolean IsEnableOpenPopUp()
		-- 팝업을 열 수 있는 상태인지 확인하는 함수
		local diff = _UtilLogic.ElapsedSeconds - self.lastShowTime
		
		if diff < 0.2 then
			return false
		end
		self.lastShowTime = _UtilLogic.ElapsedSeconds
		
		return true
	end

	@ExecSpace("ClientOnly")
	method void EnableRecipeGroup(boolean enable)
		-- 레시피 그룹의 활성화 상태를 설정하는 함수
		self.RecipeGroup:SetEnable(enable)
		self.RecipeGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		self:EnableBackToLobbyBtn(enable)
		
		if enable then
			_UIEntityLogic_RecipeGroup:InitializeRecipeUI()
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
			
		else
		
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()	
			
		 
			
		end
		
		
	end

	@ExecSpace("ClientOnly")
	method void EnableRewardGroup(boolean enable)
		-- 보상 그룹의 활성화 상태를 설정하는 함수
		self.RewardGroup:SetEnable(enable)
		self.RewardGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		
		if enable then
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		else
			
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableAchievementGroup(boolean enable)
		-- 업적 그룹의 활성화 상태를 설정하는 함수
		self.AchievementGroup:SetEnable(enable)
		self.AchievementGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		self:EnableBackToLobbyBtn(enable)
		
		if enable then
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(false)
		else
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableEventGroup(boolean enable)
		-- 이벤트 그룹의 활성화 상태를 설정하는 함수
		self.EventGroup:SetEnable(enable)
		self.EventGroup.UIGroupComponent.DefaultShow = enable
	end

	@ExecSpace("ClientOnly")
	method void EnableManagementGroup(boolean enable)
		-- 경영 그룹의 활성화 상태를 설정하는 함수
		self.ManagementGroup:SetEnable(enable)
		self.ManagementGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		self:EnableBackToLobbyBtn(enable)
		
		if enable then
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(not enable)
		else
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableTrialGroup(boolean enable)
		-- 트라이얼 그룹의 활성화 상태를 설정하는 함수
		self.TrialGroup.Enable = enable
		self.TrialGroup.UIGroupComponent.DefaultShow = enable
		_UIGroupManager:EnableMoneyBarGroup(nil)
		self:EnableBackToLobbyBtn(enable)
		if enable == false then
			_TrialUILogic.UITrialSelect.Enable = false
			_TrialUILogic.UITrialFrame.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableRecipeSetGroup(boolean enable)
		-- 레시피 세트 그룹의 활성화 상태를 설정하는 함수
		self.RecipeSetGroup.Enable = enable
		self.RecipeSetGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
	end

	@ExecSpace("ClientOnly")
	method void EnableUpgradeGroup(boolean enable)
		-- 업그레이드 그룹의 활성화 상태를 설정하는 함수
		self.UpgradeGroup.Enable = enable
		self.UpgradeGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		
		if enable then
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(not enable)
			self:EnableBackToLobbyBtn(true)
			
		else
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
			self:EnableBackToLobbyBtn(nil)
			
		end
	end

	@ExecSpace("ClientOnly")
	method void EnableVIPOrderGroup(boolean enable)
		-- VIP 주문 그룹의 활성화 상태를 설정하는 함수
		self.VIPOrderGroup.Enable = enable
		self.VIPOrderGroup.UIGroupComponent.DefaultShow = enable
		
		_UIGroupManager:EnableMoneyBarGroup(nil)
		self:EnableBackToLobbyBtn(enable)
		
		if enable then
			
			local playerRecipe = _UserService.LocalPlayer.PlayerRecipe
			table.clear(playerRecipe.LastSetRecipesClientOnly)
			for i, recipeId in pairs(playerRecipe.SetRecipes) do
				---@type RecipeData
				local recipeData = playerRecipe.Recipes[recipeId]
				playerRecipe.LastSetRecipesClientOnly[i] = recipeData.UniqueId 
			end
				
		
			_UserService.LocalPlayer.TimeManager:TimeFlowsChange(not enable)
		else
			_UserService.LocalPlayer.TimeManager:RequestTimeFlowClient()
			_VIPOrderResultRenderLogic:ClearScoreEntities()
		end
	end

