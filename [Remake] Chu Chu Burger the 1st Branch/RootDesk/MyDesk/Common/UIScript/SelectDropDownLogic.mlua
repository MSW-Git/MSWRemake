@Logic
script SelectDropDownLogic extends Logic

	@ExecSpace("ClientOnly")
	method void SetSelected(Entity entity, boolean selected)
		-- 드롭다운 아이템의 선택 상태에 따른 비주얼 스타일을 설정
		if isvalid(entity:GetChildByName("BG")) then
			local bg = entity:GetChildByName("BG")
			bg.Enable = selected
		end
		
		if isvalid(entity:GetChildByName("Text")) then
			local text = entity:GetChildByName("Text")
			local fontColor = selected and _ColorCodeEnum:GetColor("#FFFFFF") or _ColorCodeEnum:GetColor("#72634B") 
			local outlineColor = _ColorCodeEnum:GetColor("#D79D03") 
			
			text.TextComponent.UseOutLine = selected
			text.TextComponent.OutlineColor = outlineColor
			text.TextComponent.FontColor = fontColor
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetIconInfo(Entity entity, string ruid)
		-- 드롭다운 아이템의 아이콘 이미지를 설정
		if isvalid(entity:GetChildByName("Icon")) then
			entity:GetChildByName("Icon").SpriteGUIRendererComponent.ImageRUID = ruid
		end
	end

	@ExecSpace("ClientOnly")
	method void SetTextInfo(Entity entity, string text)
		-- 드롭다운 아이템의 텍스트를 설정
		if isvalid(entity:GetChildByName("Text")) then
			entity:GetChildByName("Text").TextComponent.Text = text
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshSelected(SyncTable<string, Entity> entities, string key)
		-- 드롭다운 아이템들 중 지정된 키에 해당하는 아이템만 선택 상태로 설정
		for k, entity in pairs(entities) do
			self:SetSelected(entity, k == key)
		end
	end

end