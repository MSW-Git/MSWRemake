@Logic
script EditorLogic extends Logic

	property Entity uiGroup = "1597b6c1-99c0-435f-8490-61eb96a382c0"

	@EventSender("Entity", "afb9fbde-f620-46ac-8e39-365868c011d0")
	handler HandleButtonClickEditorEvent(ButtonClickEditorEvent event)
		-- 에디터 버튼 클릭 시 UI 그룹의 모든 텍스트 폰트를 기본값으로 설정
		
		local Entity = event.Entity
		
		for k, v in pairs(self.uiGroup.Parent:GetChildComponentsByTypeName("TextComponent",true)) do
			---@type TextComponent
			local text = v
			text.Font = FontType.Default
		end
	end

	@EventSender("Entity", "ec5dceb3-d500-47dd-a61e-c1ffff5b220f")
	handler HandleButtonClickEditorEvent2(ButtonClickEditorEvent event)
		-- 두 번째 에디터 버튼 클릭 시 특정 엔티티를 제거
		
		local Entity = event.Entity
		local entity = _EntityService:GetEntity("e4758104-4a96-4ea9-b299-03f08a1b7536")
		entity:Destroy()
	end

end