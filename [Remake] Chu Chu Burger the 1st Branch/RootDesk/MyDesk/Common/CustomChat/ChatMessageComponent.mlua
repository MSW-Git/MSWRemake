@Component
script ChatMessageComponent extends Component

	property integer Index = 0

	@ExecSpace("Client")
	method void SetIndex(integer index)
		-- 채팅 메시지의 인덱스를 설정
		
		self.Index = index
		
	end

	method void InitChatInfo(integer index, string profileCode)
		-- 채팅 정보를 초기화하고 인덱스를 설정
		self:SetIndex(index)
	end

end