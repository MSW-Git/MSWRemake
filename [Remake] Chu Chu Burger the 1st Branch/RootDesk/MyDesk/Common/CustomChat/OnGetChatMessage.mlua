@Event
script OnGetChatMessage extends EventType

	property string msg = ""

	property integer stageRank = 0

	property string name = ""

	property string ppsn = ""

	property integer type = 0

	property table extra = {}

	property integer index = -1

	property string profileCode = ""

	method void Init(string msg, integer stageRank, string name, string ppsn, integer type, table extra, integer index, string profileCode)
		-- 채팅 메시지 데이터를 초기화하는 함수
		self.msg = msg
		self.stageRank = stageRank
		self.name = name
		self.ppsn = ppsn
		self.type = type
		self.extra = extra
		self.index = index
		self.profileCode = profileCode
	end

end