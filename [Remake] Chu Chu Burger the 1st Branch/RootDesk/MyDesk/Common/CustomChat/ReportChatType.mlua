@Struct
script ReportChatType

	property string UserId = ""

	property string NickName = ""

	property string ProfileCode = ""

	property string Message = ""

	property integer index = -1

	method void Init(string _userId, string _nickname, string _profileCode, string _msg, integer _index)
		-- 신고용 채팅 데이터를 초기화
		self.UserId = _userId
		self.NickName = _nickname
		self.ProfileCode = _profileCode
		self.Message = _msg
		self.index = _index
	end

end