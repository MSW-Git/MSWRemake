@Component
script ShieldWeaponComponent extends Component

	property number cooltime = 0.5

	property boolean available = true

	method void Guard()
		-- 방패 가드 기능 활성화 (쿨타임 동안 비활성화 후 자동 복구)
		self.available = false
		self.Entity.Parent.SpriteRendererComponent:ChangeMaterial("material://9f9a65e6-6c40-4839-a0ec-e8bae4d82161")
		_TimerLogic:SetTimerOnce(function() 
			if isvalid(self) == false then return end
			self:SetAvailableTrue()
		end, self.cooltime, "ShieldWeaponComponent.Guard")
	end

	method void SetAvailableTrue()
		-- 방패 가드 상태를 사용 가능으로 복구 (재질 초기화)
		self.available = true
		self.Entity.Parent.SpriteRendererComponent:ChangeMaterial("")
	end

end