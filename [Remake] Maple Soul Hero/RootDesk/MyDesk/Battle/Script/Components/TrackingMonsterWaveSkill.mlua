@Component
script TrackingMonsterWaveSkill extends MonsterWaveSkill

	property number ac = 0.2

	property number targetTracking = 0

	@Description([[update가 호출되는 간격을 나타냅니다. 낮을수록 부드럽지만 성능이 낮아집니다.
OnBeginPlay 시점에 값이 고정됩니다.]])
	property number updateTime = 0.15

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 추적형 몬스터 웨이브 스킬 초기화
		__base:OnBeginPlay()
		self._T.updateTime = self.updateTime
	end

	method void StartWave(Vector3 spawnPosition, Entity target, number atk, boolean lastWave)
		-- 추적 웨이브 시작 및 가속도 설정
		__base:StartWave(spawnPosition,target,atk,lastWave)
		
		self._T.ac = self._T.diffNormal * self.ac
		
		self._T.ax = self._T.ac.x
		self._T.ay = self._T.ac.y
		
		self._T.hasAcceleration = self.ac ~= 0
		self._T.hasTraking = self.targetTracking ~= 0
		
		self._T.innerDelta = 0
		
		self._T.playerEntity = _UserService.LocalPlayer
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 플레이어 추적 및 가속도 적용
		local _T = self._T
		
		if _TimerLogic.pause or not _T.hasAcceleration then
			return
		end
		
		_T.innerDelta += delta
		
		if _T.innerDelta < _T.updateTime then
			return
		end
		
		if _T.hasAcceleration then
			if _T.hasTraking then
				---@type Vector3
				local playerPos = _T.playerEntity.BattlePlayer:GetPosition()
				local diff = playerPos - _T.transform.Position
				diff.z = 0
				diff = Vector3.Normalize(diff)
				_T.ax = self.ac * diff.x * self.targetTracking
				_T.ay = self.ac * diff.y * self.targetTracking
			end
			
			_T.vx += _T.ax * _T.innerDelta
			_T.vy += _T.ay * _T.innerDelta
		end
		
		---@type KinematicbodyComponent
		local kinematic = self._T.kinematic
		kinematic.MoveVelocity.x = _T.vx
		kinematic.MoveVelocity.y = _T.vy
		
		_T.innerDelta = 0
	end

	method Vector2 CalcStartPos(Vector3 originalSpawnPosition, number velocityX, number velocityY)
		-- 시작 위치 계산 (원본 위치 그대로 사용)
		return originalSpawnPosition:ToVector2()
		
	end

	method number CalcLife(number startPosX, number startPosY, number velocityX, number velocityY)
		-- 생존 시간 계산 (설정된 life 값 사용)
		return self.life
		
	end

end