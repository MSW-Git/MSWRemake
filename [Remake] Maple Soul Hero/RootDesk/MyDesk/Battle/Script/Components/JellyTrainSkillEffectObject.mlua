@Component
script JellyTrainSkillEffectObject extends SkillEffectObject

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		
	end

	method void Init(number damage, boolean isPlayerSkill, string weaponUniqueKey, string skillId)
		-- 젤리 기차 스킬 초기화 및 지그재그 이동 경로 설정
		__base:Init(damage,isPlayerSkill,weaponUniqueKey,skillId)
		
		
		
		
		local leftBottom = self.Entity.CurrentMap.BattleMap.leftBottom
		local rightTop = self.Entity.CurrentMap.BattleMap.rightTop 
		
		
		local tween = nil
		local to = {}
		
		local life = 0
		local width =  rightTop.x - leftBottom.x
		local speed = 0.2
		local offsetX = 0.4
		local offsetY = 0.2
		
		for i = leftBottom.y, rightTop.y do
			
			if (i - leftBottom.y)%2 == 0 then
				table.insert(to, {flipX = true, to = Vector3(rightTop.x + offsetX,i + offsetY,0), duration = speed * width * (0.75 + _UtilLogic:RandomDouble() * 0.25)})
				table.insert(to, {flipX = true, to = Vector3(rightTop.x+ offsetX,i + 1+ offsetY,0), duration = speed * (0.75 + _UtilLogic:RandomDouble() * 0.25)})
			else
				table.insert(to, {flipX = false,to = Vector3(leftBottom.x+ offsetX,i + offsetY,0), duration = speed * width * (0.75 + _UtilLogic:RandomDouble() * 0.25)})
				table.insert(to, {flipX = false,to = Vector3(leftBottom.x+ offsetX,i + 1+ offsetY,0), duration = speed * (0.75 + _UtilLogic:RandomDouble() * 0.25)})
			end
		end
		
		
		local sprite = self.Entity.SpriteRendererComponent
		
		for k,v in pairs(to) do
			life = life + v.duration 	
		end
		
		self.Entity.TransformComponent.Position = leftBottom:ToVector3()
		tween = function(index) 
			local i = index
			if i < #to then	
				sprite.FlipX = to[i].flipX
				_Tweener:MoveTo(self.Entity,to[i].to,to[i].duration,0,EaseType.Linear,function() 
					tween(i + 1)
				end, "JellyTrainSkillEffectObject_Init")
			else
				self:DestroyEffect()
			end
		end
		
		self.life = life
		tween(1)
		
	end

end