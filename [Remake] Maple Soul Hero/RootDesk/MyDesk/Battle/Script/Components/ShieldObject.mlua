@Component
script ShieldObject extends Component

	property Entity child = nil

	property string guardEffect = "03e10a4f94ec4b429f854b268d2733b8"

	property number rotateSpeed = -120

	property number angleOffset = 0

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 방패 회전 및 자식 오브젝트 회전 고정
		if _TimerLogic.pause then
			return
		end
		local angle = _TimerLogic.ElapsedSeconds * self.rotateSpeed + self.angleOffset
		
		self._T.transform.ZRotation = angle
		self._T.childTransform.WorldZRotation = 0
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 방패 오브젝트 초기화 및 페이드 인 효과
		self.child = self.Entity.Children[1]
		self._T.childTransform = self.child.TransformComponent
		self._T.transform = self.Entity.TransformComponent
		
		local sprite = self.child.SpriteRendererComponent
		
		sprite:ChangeMaterial("material://a42cdbe3-5687-4fe0-8b02-e157d7d8521b")
		
		_Tweener:PlayTween(0.05,0,1,0,EaseType.Linear,function(value) 
				
		   			local changeValue = {["Scale"] = value}
				
					_MaterialService:ChangeMaterialProperty("material://a42cdbe3-5687-4fe0-8b02-e157d7d8521b",changeValue)
				end,function() 
					sprite:ChangeMaterial("")
					
				end, "ShieldObject_OnBeginPlay")
		
		
	end

	method void PlayGuardEff()
		-- 방어 성공 시 가드 이펙트 재생
		_EffectService:PlayEffectAttached(self.guardEffect,self.child,Vector3.zero,0,Vector3.one)
	end

end