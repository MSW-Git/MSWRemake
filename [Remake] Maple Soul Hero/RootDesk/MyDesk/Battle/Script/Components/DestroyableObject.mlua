@Component
script DestroyableObject extends Component

	property boolean isDead = false

	property boolean isBoss = false

	property number exp = 3

	property number type = 0

	property integer hp = 0

	method void SetDamage(number damage, Vector2 knockback, boolean isCritical, string weaponUniqueKey)
		-- 파괴 가능한 오브젝트 데미지 처리 (현재 빈 구현)
		if not isvalid(self.Entity) then return end
	end

	method number GetMaxHp()
		-- 최대 체력 반환 (현재 빈 구현)
		return 100
	end

	method void DropGem()
		-- 경험치 젬 드롭 처리 (레벨 제한 및 게임 모드 확인)
		if _UserService.LocalPlayer.BattlePlayer.lv >= 50 then return end
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then return end
		
		
		local exp = _UtilLogic:RandomIntegerRange(1,self.exp)
		
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_BENCHMARK then
			exp = 5
		end
		if _GameUtil.gemImmediatelyGain then
			_UserService.LocalPlayer.BattlePlayer:GainEXP(exp)
			return
		end
		local largeExpCount = math.floor(exp / 3)
		local smallExpCount = exp - largeExpCount * 3
		
		local entity = self.Entity
		local from = entity.TransformComponent.Position:Clone()
		
		if entity.MonsterWaveSkillObject ~= nil then
			from = entity.TransformComponent.WorldPosition:Clone()
		end
		
		local parent = entity.CurrentMap
		local battleMap = parent.BattleMap
		
		
		for i = 1, smallExpCount do
			local spawnFunc = function(gem)
				gem.ExpGem_Improved:Init(1)
				local to = battleMap:ConvertPositionByBound(from + Vector3(_UtilLogic:RandomDouble()-0.5,_UtilLogic:RandomDouble()-0.5,0) * 1.5)
				_Tweener:MoveTo(gem,to,0.5,0,EaseType.SineEaseIn,nil, "DestroyableObject_DropGem_Small")
			end
			_PoolingLogic:SpawnModelAsync("model://afa7a38c-67b8-45f5-87f5-d90af408383f",from,parent,spawnFunc)
		end
		for i = 1, largeExpCount do
			local spawnFunc = function(gem)
				gem.ExpGem_Improved:Init(3)
				local to = battleMap:ConvertPositionByBound(from + Vector3(_UtilLogic:RandomDouble()-0.5,_UtilLogic:RandomDouble()-0.5,0) * 1.5)
				_Tweener:MoveTo(gem,to,0.5,0,EaseType.SineEaseIn,nil, "DestroyableObject_DropGem_Big")
			end
			_PoolingLogic:SpawnModelAsync("model://afa7a38c-67b8-45f5-87f5-d90af408383f",from,parent,spawnFunc)
		end
	end

	method Vector3 GetPosition()
		-- 오브젝트의 월드 좌표 반환
		return self.Entity.TransformComponent.WorldPosition
	end

	@ExecSpace("ClientOnly")
	method void IncreaseDeadIndex()
		-- 몬스터 사망 시 배틀맵의 사망 카운터 증가
		local monsterObject = self.Entity.MonsterObject
		local battleMap = self.Entity.CurrentMap.BattleMap
		
		if isvalid(monsterObject) then
			if monsterObject.isBoss then
				if _UtilLogic:Contains(monsterObject.monsterId, "EliteBoss") then
					battleMap.eliteIndex += 1
				else
					battleMap.bossIndex += 1
				end
			else
				battleMap.monsterIndex += 1
			end
		end
	end

	@ExecSpace("ClientOnly")
	method boolean IsInMapBound()
		-- 오브젝트가 맵 경계 내에 있는지 확인
		local position = self:GetPosition()
		local battleMap = self.Entity.CurrentMap.BattleMap
		
		if not isvalid(battleMap) then
			return
		end
		
		local leftBottom = battleMap.leftBottom
		local rightTop = battleMap.rightTop
		
		if position.x >= leftBottom.x and position.x <= rightTop.x and
			position.y >= leftBottom.y and position.y <= rightTop.y then
			
			return true
		else
			return false
		end
	end

end