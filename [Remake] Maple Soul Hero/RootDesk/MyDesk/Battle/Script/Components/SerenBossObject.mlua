@Component
script SerenBossObject extends BossObject

	property number changeSkillCool = 0

	property string changeRUID = "a824723d2d6748f0b454c324085748af"

	property number changeColliderSize = 2.5

	property number triggerDelay = 0.35

	method void UpdateMove()
		-- 세렌 보스의 텔레포트 스킬 및 이동 처리
		
		if self.isUsingSkill then
			return
		end
		if self.Entity.Enable == false then
			return
		end
		
		
		
		self.changeSkillCool = self.changeSkillCool - 1
		if self.changeSkillCool < 0 then
			local diff = self:GetPositionVec2() - _UserService.LocalPlayer.BattlePlayer:GetPositionVec2()
			if Vector2.Magnitude(diff) > 3 then
				self.changeSkillCool = 2
				self:ApplySpeedFactorByKey("SkillStop", 0)
				self._T.spriteRenderer.SpriteRUID = self.changeRUID
				
				self.isUsingSkill = true
					
				local colliderSize = self._T.originColliderSize 
				local offset = self.Entity.TriggerComponent.ColliderOffset
				
				_TimerLogic:SetTimerOnce(function() 
					if self.isDead then
						return
					end
					self.Entity.Enable = false
					_SoundService:PlaySound("f57bf7d1fd9444f39d369fec8b353d6b",1)
					self.Entity.TriggerComponent.CircleRadius = 0
					_EffectService:PlayEffect("b780f5b7cdcb451abe64c71cd8471e54",self.Entity,self:GetPosition()+offset:ToVector3(),0,Vector3.one)
				end,1, "SerenBossObject.UpdateMove_disappear")
				
				local delay = 1.0 + _UtilLogic:RandomDouble() * 0.5
				_TimerLogic:SetTimerOnce(function()
					if self.isDead then
						return
					end
					self:SetPosition(_UserService.LocalPlayer.BattlePlayer:GetPositionVec2() + Vector2(_UtilLogic:RandomDouble()*0.2 - 0.1,_UtilLogic:RandomDouble()*0.2 - 0.1 ) - offset )
					_EffectService:PlayEffect("b780f5b7cdcb451abe64c71cd8471e54",self.Entity,self:GetPosition() +offset:ToVector3(),0,Vector3.one)
					self.Entity.Enable = true
				end,delay, "SerenBossObject.UpdateMove_moveToPlayer")
				
				_TimerLogic:SetTimerOnce(function()
					if self.isDead then
						return
					end
						self.Entity.TriggerComponent.CircleRadius = colliderSize * self.changeColliderSize
				end,delay + self.triggerDelay, "SerenBossObject.UpdateMove_triggerChange")
				
				
				_TimerLogic:SetTimerOnce(function()
					if self.isDead then
						return
					end
					self.isUsingSkill = false		
					self._T.spriteRenderer.SpriteRUID = self.stand
					self:ApplySpeedFactorByKey("SkillStop", 1)
					self.Entity.TriggerComponent.CircleRadius = colliderSize
			end,delay + self.triggerDelay + 0.1, "SerenBossObject.UpdateMove_skillEnd")
				return
			end
		end
			
		
		__base:UpdateMove()
		
	end

	method void Init(string monsterId, boolean isAfterMonster, boolean respawn, number life)
		-- 세렌 보스 초기화 및 원본 콜라이더 크기 저장
		__base:Init(monsterId,isAfterMonster,respawn,life)
		self._T.originColliderSize = self.Entity.TriggerComponent.CircleRadius
	end

	method void Dead(boolean dropExp)
		-- 세렌 보스 사망 시 죽음 스프라이트로 변경
		__base:Dead(dropExp)
		
		self._T.spriteRenderer.SpriteRUID = self.die
	end

end