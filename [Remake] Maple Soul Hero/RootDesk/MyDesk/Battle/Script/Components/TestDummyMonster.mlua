@Component
script TestDummyMonster extends Component

	property string skill = "32"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 테스트 더미 몬스터 초기화
		self.Entity.MonsterObject.isInited = true
	end

	@EventSender("Self")
	handler HandleTouchEvent(TouchEvent event)
		-- 터치 시 스킬 사용 테스트
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		
		
		self.Entity.MonsterObject:UseSkill(self.skill,self.Entity.TransformComponent.Position,_UserService.LocalPlayer)
	end

end