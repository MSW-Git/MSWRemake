@Logic
script ArmorSpecLogic extends Logic

	property table armorData = {}

	property table armorColor = {Color.clear,Color(80/255,205/255,12/255,255/255),Color(11/255,110/255,204/255,255/255),Color(155/255,61/255,217/255,255/255),Color(253/255,30/255,25/255,255/255),Color(0/255,0/255,0/255,255/255)}

	property table armorLevelUpData = {}

	property table armorSellPriceData = {}

	method void OnBeginPlay()
		-- 방어구 데이터 및 레벨업 정보 초기화
		local data = _DataService:GetTable("ArmorSpec")
		
		for i = 1, data:GetRowCount() do
			local armor = {}
			armor.id = data:GetCell(i,"id")	
			armor.name = data:GetCell(i,"name")
			armor.grade = data:GetCell(i, "grade")
			armor.gradeLevel = tonumber(data:GetCell(i, "gradeLevel"))
			armor.type = data:GetCell(i,"type")
			armor.class = data:GetCell(i, "class")
			armor.ruid = data:GetCell(i,"ruid")
			armor.star = tonumber(data:GetCell(i, "stars"))
			armor.sellScrollValue = math.floor(tonumber(data:GetCell(i, "sellScrollValue")))
			local outglow = data:GetCell(i,"outglow")
		
			if _UtilLogic:IsNilorEmptyString(outglow) == false then
				armor.outglow = data:GetCell(i,"outglow")
			else
				armor.outglow = ""
			end
			
			armor.mainStatus = data:GetCell(i, "mainStatus")
			armor.maxHp = data:GetCell(i,"maxHp")
			armor.attack = data:GetCell(i, "attack") / 100 
			armor.speed = data:GetCell(i,"speed") 
			armor.attackSpeed = tonumber(data:GetCell(i,"attackSpeed")) 
			armor.addMaxHpRate = tonumber(data:GetCell(i, "addMaxHpRate")) 
			armor.addAttackRate = tonumber(data:GetCell(i, "addAttackRate")) 
			armor.criticalRate = tonumber(data:GetCell(i, "criticalRate")) 
			armor.criticalDamageRate = tonumber(data:GetCell(i, "criticalDamageRate")) 
			armor.bossDamage = tonumber(data:GetCell(i, "bossDamage")) 
			
			armor.reductDamage = data:GetCell(i, "reductDamage") 
			armor.range = data:GetCell(i, "range") 
			armor.hpRecovery = data:GetCell(i, "hpRecovery") 
			armor.evade = data:GetCell(i, "evade") 
			armor.reductMeleeDamage = data:GetCell(i, "reductMeleeDamage")
			armor.reductProjectileDamage = data:GetCell(i, "reductProjectileDamage")
			self.armorData[armor.id] = armor
		end
		
		
		data = _DataService:GetTable("ArmorLevelUpData")
		
		for i = 1, data:GetRowCount() do
			local item = {}
			
			item.level = tonumber(data:GetCell(i, "level"))
			item.needGold = tonumber(data:GetCell(i, "needGold"))
			item.needScroll = tonumber(data:GetCell(i, "needScroll"))
		
			item.helmet_hp = tonumber(data:GetCell(i, "helmet_hp"))
			item.suit_hp = tonumber(data:GetCell(i, "suit_hp"))
			item.glove_attack = tonumber(data:GetCell(i, "glove_attack"))
			item.shoes_hp = tonumber(data:GetCell(i, "shoes_hp"))
			
			self.armorLevelUpData[item.level] = item
		end
		
		data = _DataService:GetTable("ArmorSellingPrice")
		
		for i = 1 , data:GetRowCount() do
			local table = {}
			table.grade = data:GetCell(i , "grade")
			table.meso = tonumber(data:GetCell(i, "meso"))
			table.scroll = tonumber(data:GetCell(i, "scroll"))
			self.armorSellPriceData[table.grade] = table
		end
	end

	method table GetArmorSpec(string id)
		-- 방어구 ID로 방어구 스펙 정보 반환
		return self.armorData[id]
	end

	method Color GetColorByStar(number star)
		-- 별 등급에 따른 방어구 색상 반환
		return self.armorColor[star + 1]
	end

	method table GetArmorLevelUpData(string id)
		-- 방어구 레벨업에 필요한 데이터 반환
		return self.armorLevelUpData[id]
	end

	method number GetMaxHp(table equipArmorTable)
		-- 장착된 방어구들의 총 체력 증가량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].maxHp
			end
		end
			
		return value
	end

	method number GetAttack(table equipArmorTable)
		-- 장착된 방어구들의 총 공격력 증가량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].attack
			end
		end
			
		return value
	end

	method number GetReductDamage(table equipArmorTable)
		-- 장착된 방어구들의 총 데미지 감소량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].reductDamage
			end
		end
			
		return value
	end

	method number GetSpeed(table equipArmorTable)
		-- 장착된 방어구들의 총 이동속도 증가량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].speed
			end
		end
			
		return value
	end

	method number GetAttackSpeed(table equipArmorTable)
		-- 장착된 방어구들의 총 공격속도 증가량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].attackSpeed
			end
		end
			
		return value
	end

	method number GetMaxHpRate(table equipArmorTable)
		-- 장착된 방어구들의 총 체력 비율 증가량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].maxHp
			end
		end
			
		return value
	end

	method number GetAttackRate(table equipArmorTable)
		-- 장착된 방어구들의 총 공격력 비율 증가량 계산
		local value = 0
		
		for i = 1,	#equipArmorTable do
			if isvalid(equipArmorTable[i]) or equipArmorTable[i] ~= nil then
				value = value + self.armorData[equipArmorTable[i]].maxHp
			end
		end
			
		return value
	end

end