@Logic
script MonsterSkillLogic extends Logic

	property table skillData = {}

	property table skillIdTable = {}

	method void OnBeginPlay()
		-- 몬스터 스킬 데이터 테이블 초기화
		local data = _DataService:GetTable("MonsterSkillData")
		
		local count = data:GetRowCount()
		for i = 1, count do
			local skill = {}
			skill.id = data:GetCell(i,"id")
			skill.type = data:GetCell(i,"type")
			skill.effectModelId = data:GetCell(i,"effectModelId")	
			skill.shot = _GameUtil:GetNumberSplitBySlash(data:GetCell(i,"shot"))
			skill.angle = _GameUtil:GetNumberSplitBySlash(data:GetCell(i,"angle"))
			skill.spec = _GameUtil:GetStringTableSplitBySlash(data:GetCell(i,"spec"),true)
			skill.damage = tonumber(data:GetCell(i,"damage"))
			skill.hpRatioDamage = tonumber(data:GetCell(i,"hpRatioDamage"))
			skill.duration = tonumber(data:GetCell(i,"duration"))
			skill.multiShot = tonumber(data:GetCell(i,"multiShot"))
			skill.multiShotDelay = tonumber(data:GetCell(i,"multiShotDelay"))
			skill.offset = Vector2(tonumber(data:GetCell(i,"offsetX")),tonumber(data:GetCell(i,"offsetY")))
			
			local monsterRUID = data:GetCell(i,"monsterRUID")
			skill.monsterRUID = monsterRUID == nil and "" or monsterRUID
		
			local skillDelay = data:GetCell(i,"skillDelay")	
			skill.skillDelay = _UtilLogic:IsNilorEmptyString(skillDelay) and 0 or tonumber(skillDelay)
			
			local sound =data:GetCell(i,"sound")
			skill.sound = nil and 0 or sound
			
			
			local afterSkill = data:GetCell(i,"afterSkill")
			if afterSkill ~= "0" then
				skill.afterSkill = _UtilLogic:Split(afterSkill,"/")
			else
				skill.afterSkill = {} 
			end
			self.skillData[skill.id] = skill
			table.insert(self.skillIdTable,skill.id)
		end
	end

	method table GetSkill(string id)
		-- 스킬 ID로 몬스터 스킬 데이터 반환
		return self.skillData[id]
	end

end