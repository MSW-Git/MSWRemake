@Logic
script BattleUIManager extends Logic

	property SliderComponent expBar = "c735a161-cc83-4059-b914-fd7872a686ac"

	property TextComponent textLevel = "1513d0f7-e4cb-4eb5-a1a1-64337625e8d3"

	property UILevelUpPopup levelUpPopup = "2f9bc163-5c61-4175-b386-71c49bc0094c"

