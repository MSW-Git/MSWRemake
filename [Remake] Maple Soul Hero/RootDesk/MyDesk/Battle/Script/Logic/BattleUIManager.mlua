	property Entity bossHpText = "e17ee560-86db-453b-8b47-1c65c21c528d"

	property Entity bossInfo = "39087cb6-a6ab-4013-a38a-aca133badf4a"

	property TextComponent bossNameText = "2a5a9805-adef-4203-85e0-6c8cfa0a97f8"

	property Entity buffStat = "bb863a68-7473-4aa7-8f5b-0d4d066ec318"

	property Entity background = "6c1bc220-72b6-404d-b938-fa5e25a95f49"

	property Entity pauseButton = "17b5195e-a5f1-4738-9f44-4d79274930e2"

	property Entity interactionButton = "2d5571d4-aceb-49cd-9615-d15d8be2e318"

	property Entity chatUI = "ba7fb1e5-c7e1-4a13-85f8-5cd95e1c2c2f"

	property Entity randomBossInfo = "684168d6-dc1f-4638-8d27-e5fb513446df"

	property Entity randomBossCurrentWave = "4c5b9905-6526-43b4-ac80-2038b532f1e0"

	property Entity stageInfo = "d0795bca-0f82-4d7c-9824-19cb795fb8ca"

	property Entity playerWeaponPanel = "1c5e4588-bf3e-4bef-80cd-917e482c99ff"

	property Entity buffStatByPause = "6c7312a2-0d1d-4b18-93a7-88bba453f485"

	property Entity hpPanel = "5a8dfe9b-2757-4a36-a33e-2b3dc12893d0"

	property number startedMilliSecond = 0

	method void RefreshEXP(number ratio)
		-- 경험치 바의 진행률을 업데이트
		self.expBar.Value = ratio
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 전투 UI 초기화 및 버튼 이벤트 연결 설정
		self.textLevel.Text = string.format(_LocalizeLogic:GetText("etcStr11"), 1)
		self:RefreshEXP(0)
		
		self.dpsButton:ConnectEvent(ButtonClickEvent, function()
				_DPSLogic.dpsUI.Entity.Enable = not _DPSLogic.dpsUI.Entity.Enable
				if _DPSLogic.dpsUI.Entity.Enable then
					self.dpsButton.SpriteGUIRendererComponent.ImageRUID = "dc24bfa182074100a8662d792c15475c"
				else
					self.dpsButton.SpriteGUIRendererComponent.ImageRUID = "63606ce01e07416aaf7186e454a8879c"
				end
			end)
		
		self.statButton:ConnectEvent(ButtonClickEvent, function()
				self:OnStatButtonClick()
			end)
		
		
		self.stageExitButton:ConnectEvent(ButtonClickEvent, function()
				if _UIGroupManager:IsEnableOpenPopup() == false then
					return
				end
		
			
				local player = _UserService.LocalPlayer
				local battlePlayer = player.BattlePlayer
				
				battlePlayer:Dead(true)
				battlePlayer:OnEndBattle(player.CurrentMap.BattleMap.isClear)
				self:OffBattleUI()
				self:Resume()
			end)
		
		self.buffIcon.Enable = false
		
		if Environment:IsPCPlatform() then
			self.dashButton = _EntityService:GetEntityByPath("/ui/BattleGroup/PCOnly/Dash_Sprite")
			self.dashCooltimeCover = self.dashButton:GetChildByName("Dash_Cover")
			self._T.dashCountText = self.dashButton:GetChildByName("Dash_Count")
			
			self.extraSkillIcon = _EntityService:GetEntityByPath("/ui/BattleGroup/PCOnly/Extra_skill")
			self.extraCover = self.extraSkillIcon:GetChildByName("Skill_Cover")
		else
			self.dashButton = _EntityService:GetEntityByPath("/ui/BattleGroup/MobileOnly/Dash_Sprite")
		
			self.dashCooltimeCover = self.dashButton:GetChildByName("Dash_Cover")
			self._T.dashCountText = self.dashButton:GetChildByName("Dash_Count")
			
			self.extraSkillIcon = _EntityService:GetEntityByPath("/ui/BattleGroup/MobileOnly/Extra_skill")
			self.extraCover = self.extraSkillIcon:GetChildByName("Skill_Cover")
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 대시 쿨타임과 일시정지 시간을 업데이트
		local controller = _UserService.LocalPlayer.BattlePlayer
		
		if isvalid(controller) then
			self._T.dashCountText.TextComponent.Text = string.format("%d", controller.stamina / controller.needDashStamina)
			local coverRatio = ((controller.stamina % controller.needDashStamina) / controller.needDashStamina) / 1
			self.dashCooltimeCover.SpriteGUIRendererComponent.FillAmount = coverRatio
		end
		
		if _TimerLogic.pause then
			self.remainSeconds += delta
		end
	end

	@ExecSpace("Client")
	method void OnStatButtonClick()
		-- 스탯 버튼 클릭 시 버프 스탯 UI 토글 처리
		if not _TimerLogic.pause then
			self.buffStat.Enable = not self.buffStat.Enable
			if self.buffStat.Enable then
				self.statButton.SpriteGUIRendererComponent.ImageRUID = "dc24bfa182074100a8662d792c15475c"
			else
				self.statButton.SpriteGUIRendererComponent.ImageRUID = "63606ce01e07416aaf7186e454a8879c"
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OffBattleUI()
		-- 전투 종료 시 모든 전투 관련 UI 비활성화 및 초기화
		self.chatUI:AttachTo(_UIGroupManager.defalutGroup)
		self.battleUIGroup.Enable = false
		_DPSLogic.dpsUI.Entity.Enable = false
		self.levelUpPopup.Entity.Enable = false
		self.bossHpBar.Entity.Parent.Enable = false
		self.timerText.Enable = false
		self.bossInfo.Enable = false
		_HUDManager:SetTownButtonEnable(true)
		
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then
			self._T.randomBossHpBar.Entity.Parent.Enable = false
			self._T.randomBossHpBar.Value = 1
			self._T.randomBossHpText.TextComponent.Text = string.format("100%%")
			self._T.randomBossNameText.Text = ""
			self._T.randomBossNameText.Enable = false
		end
		
		for _, entity in pairs(self.buffIcon.Parent.Children) do
			if entity ~= self.buffIcon then
				entity:Destroy()
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshCurrentWave()
		-- 현재 웨이브 정보를 게임 모드에 따라 업데이트
		local mapCompo = _UserService.LocalPlayer.CurrentMap.BattleMap
		local naviWave = self.currentWaveText:GetChildByName("navi_wave")
		
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then
			naviWave = self.randomBossInfo:GetChildByName("navi_wave")
		end
		
		self.currentWaveText:GetChildByName("TimerText").Enable = false
		naviWave.Enable = true
		
		for _, entity in pairs(naviWave.Children) do
			local child = entity:GetChildByName("wave_on")
			
			child.Enable = false
		end
		
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_LIMITLAND then
			self.currentWaveText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr12"), mapCompo.wave, _LimitLandWaveLogic:GetLastWave(_LimitLandWaveLogic.currentChapter))
			self.currentWaveText.Enable = true
			self.currentWaveText:GetChildByName("TimerText").Enable = true
			naviWave.Enable = false
		elseif _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then
			mapCompo = _UserService.LocalPlayer.CurrentMap.RandomBossMapComponent
			
			if mapCompo.wave == mapCompo.lastWave then
				self.randomBossCurrentWave.TextComponent.Text = _LocalizeLogic:GetText("etcStr16")
			else
				self.randomBossCurrentWave.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr15"), mapCompo.wave, mapCompo.lastWave - 1)
			end
			
			self._T.randomBossNameText.Entity.Enable = true
			self.currentWaveText.Enable = false
		else
			if mapCompo.wave == _WaveLogic:GetLastWave(_WaveLogic.currentChapter) then
				self.currentWaveText.TextComponent.Text = _LocalizeLogic:GetText("etcStr16")
			else
				self.currentWaveText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr15"), mapCompo.wave)
				self.currentWaveText.Enable = true
			end
		end
		
		if _GameSettingLogic.mode ~= _GameConfig:GetConfig().GAMEMODE_LIMITLAND then
			for i = 1, mapCompo.wave do
				local name = string.format("wave%d", i)
				
				if isvalid(naviWave:GetChildByName(name)) then
					naviWave:GetChildByName(name):GetChildByName("wave_on").Enable = true
				else
					naviWave:GetChildByName("boss"):GetChildByName("wave_on").Enable = true
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void AddBuffIcon(string itemName, string weaponId)
		-- 버프 아이콘을 UI에 추가하고 시간 제한 버프는 자동 제거 설정
		
		local buff = _BuffLogic.buffTable[itemName]
		if buff == nil then
			return
		end
		if buff.type == "weapon" or buff.type == "consume" then
			return
		end
		
		local clone = self.buffIcon:Clone("buff")
		local icon = clone.Children[1]
		icon.SpriteGUIRendererComponent.ImageRUID = "thumbnail://"..buff.ruid
		
		if buff.type == "timeout_20" then
			_TimerLogic:SetTimerOnce(function()
					clone:Destroy() 
			end,20, "BattleUIManager.AddBuffIcon_timeout_20")
		
		elseif buff.type == "timeout_40" then
			_TimerLogic:SetTimerOnce(function()
					clone:Destroy() 
			end,40, "BattleUIManager.AddBuffIcon_timeout_40")
		end
	end

	@ExecSpace("ClientOnly")
	method void SetSP(number sp, number maxSp)
		-- 특수 스킬의 SP 게이지를 업데이트하고 충전 완료 시 메시지 표시
		if not _BuffLogic.appliedBuff.chargingSkill then
			self.extraSkillIcon.Enable = false
			self.extraCover.Enable = false
			
			return
		else
			self.extraSkillIcon.Enable = true
		
			self.extraCover.Enable = true
		end
		
			self.extraCover.SpriteGUIRendererComponent.FillAmount = sp / maxSp 
			self.extraSkillIcon:GetChildByName("text").TextComponent.Text = string.format("%d", sp / maxSp)
		
		if sp >= maxSp then
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage41"), "")
		end
	end

	method void PlayUIEff(string modelId, number duration)
		-- UI 효과를 생성하고 캐릭터 일러스트를 설정하여 재생
		local eff = _SpawnService:SpawnByModelId(modelId,"eff",Vector3.zero,self.uiEffectForground)
		local illust = eff:GetChildByName("illust" ,true)
		local currentCharIndex = string.format("%d",_UserService.LocalPlayer.PlayerCharacterData.charIndex)
		local charData = _CharacterLogic.characterTable[currentCharIndex]
		illust.SpriteGUIRendererComponent.ImageRUID = charData.charRUID
		local uiTransform = eff.UITransformComponent
		
		uiTransform.AlignmentOption = AlignmentType.StretchAll
		uiTransform.OffsetMin = Vector2.zero
		uiTransform.OffsetMax = Vector2.zero
		eff:Destroy(duration)
	end

	@ExecSpace("ClientOnly")
	method void SetTimer(integer remainSeconds)
		-- 제한시간 타이머를 설정하고 시간 종료 시 이벤트 처리
		_TimerLogic:ClearTimer(self.timer)
		
		local currentMap = _UserService.LocalPlayer.CurrentMap
		
		self.remainSeconds = remainSeconds 
		self.timerText.Enable = true
		
		local lastElapsed = _UtilLogic.ElapsedSeconds
		local lastRemainTime = TimeSpan(self.remainSeconds * 1000)
		
		local timerFunction = function()
			local remainTime = TimeSpan(self.remainSeconds * 1000)
			local delta = _UtilLogic.ElapsedSeconds - lastElapsed
			
			if lastRemainTime.Seconds ~= remainTime.Seconds then
				self.timerText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr13"), remainTime.Minutes, remainTime.Seconds)
				lastRemainTime = remainTime
			end
			
			self.remainSeconds -= delta
			
			lastElapsed = _UtilLogic.ElapsedSeconds
			
			if self.remainSeconds < 0 then
				_TimerLogic:ClearTimer(self.timer)
				
				if isvalid(currentMap) and _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_LIMITLAND then
					currentMap:SendEvent(LimitLandEndEvent(false))
				end
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(timerFunction, 0.001, 0, "BattleUIManager.SetTimer")
		self.startedMilliSecond = _LocalTimeLogic:GetUTCTotalMilliseconds()
	end

	@ExecSpace("ClientOnly")
	method void InitTimer()
		-- 타이머 초기화 및 정리
		_TimerLogic:ClearTimer(self.timer)
	end

	@ExecSpace("ClientOnly")
	method void Pause()
		-- 게임을 일시정지하고 관련 UI 상태 변경
		if self.levelUpPopup.isShow then
			return
		end
		
		if _UserService.LocalPlayer.CurrentMap.BattleMap.isBossDead then return end
		
		self:RefreshStageInfo()
		
		_TimerLogic:Pause()
		self.background.Enable = true
		self.battleButtonLayout.Enable = false
		self.stageExitButton.Enable = true
		self.resumeButton.Enable = true
		self.playerWeaponPanel.Enable = true
		self.stageInfo.Enable = true
		self.hpPanel.Parent.Enable = true
		self.levelUpPopup.Entity.CanvasGroupComponent.GroupAlpha = 1
		self.buffStatByPause.Enable = true
		self.buffStat.Enable = false
		self.extraSkillIcon.Enable = false
		self.dashButton.Enable = false
		self.pauseButton.SpriteGUIRendererComponent.ImageRUID = "dc24bfa182074100a8662d792c15475c"
		
		_DPSLogic.dpsUI.Entity.Enable = false
		self.dpsButton.SpriteGUIRendererComponent.ImageRUID = "63606ce01e07416aaf7186e454a8879c"
		self.statButton.SpriteGUIRendererComponent.ImageRUID = "63606ce01e07416aaf7186e454a8879c"
		
		self.chatUI:AttachTo(self.battleUIGroup)
	end

	@ExecSpace("ClientOnly")
	method void Resume()
		-- 게임 일시정지를 해제하고 전투 UI 상태 복원
		self.chatUI:AttachTo(_UIGroupManager.defalutGroup)
		self.background.Enable = false
		self.resumeButton.Enable = false
		self.levelUpPopup.Entity.Enable = false
		self.stageExitButton.Enable = false
		self.playerWeaponPanel.Enable = false
		self.stageInfo.Enable = false
		self.buffStatByPause.Enable = false
		self.hpPanel.Parent.Enable = false
		self.battleButtonLayout.Enable = true
		self.levelUpPopup.Entity.CanvasGroupComponent.GroupAlpha = 0
		_TimerLogic:Resume()
		
		self.buffStat.Enable = false
		if _BuffLogic.appliedBuff.chargingSkill then
			self.extraSkillIcon.Enable = true
		end
		self.dashButton.Enable = true
		self.pauseButton.SpriteGUIRendererComponent.ImageRUID = "63606ce01e07416aaf7186e454a8879c"
	end

	@ExecSpace("ClientOnly")
	method void SeBattleUI(integer mode)
		-- 게임 모드에 따라 전투 UI 설정 (일반, 랜덤보스, 리미트랜드)
		self._T.randomBossHpBar = self.randomBossInfo:GetChildByName("HP_bar").SliderComponent
		self._T.randomBossHpText = self.randomBossInfo:GetChildByName("HP_text")
		self._T.randomBossNameText = self.randomBossInfo:GetChildByName("HP_bg"):GetChildByName("Text_name").TextComponent
		self.currentWaveText.Enable = true
		self.expBar.Entity.Enable = true
		self.bossInfo.Enable = false
		
		if mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then
			self.currentWaveText.Enable = false
			self.expBar.Entity.Enable = false
			self.randomBossInfo.Enable = true
		elseif mode == _GameConfig:GetConfig().GAMEMODE_LIMITLAND then
			self.randomBossInfo.Enable = false
		else
			self.randomBossInfo.Enable = false
		end
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshStageInfo()
		-- 현재 스테이지 정보를 UI에 업데이트 (챕터명과 스테이지 번호)
		local stageStep = _UserService.LocalPlayer.CurrentMap.BattleMap.chapter
		local chapter = math.floor(stageStep / 10000)
		local stage = stageStep % 10000
		local chapterStr = ""
		
		if chapter == 1 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup5") 
		elseif chapter == 2 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup6") 
		elseif chapter == 3 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup7") 
		elseif chapter == 4 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup8") 
		elseif chapter == 5 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup9") 
		elseif chapter == 6 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup10") 
		elseif chapter == 7 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup11") 
		elseif chapter == 8 then
			chapterStr = _LocalizeLogic:GetText("confirmPopup12") 
		end
		
		self.stageInfo:GetChildByName("chapterTitle").TextComponent.Text = chapterStr
		self.stageInfo:GetChildByName("stageText").TextComponent.Text = string.format("%d - %d", chapter, stage)
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleBattlePlayerInfoChange(BattlePlayerInfoChange event)
		-- 플레이어 레벨과 경험치 변경 시 UI 업데이트
		local exp = event.exp
		
		local lv = event.lv
		if _OptionLogic.showExp then
			self.textLevel.Text = string.format(_LocalizeLogic:GetText("etcStr14"), lv, exp, _UserService.LocalPlayer.BattlePlayer:GetMaxEXP(lv))
		else
			self.textLevel.Text = string.format(_LocalizeLogic:GetText("etcStr11"),lv)
		end
		if lv == 0 then
			self:RefreshEXP(0)
			return
		end
		local fillAmount = exp / _UserService.LocalPlayer.BattlePlayer:GetMaxEXP(lv)
		self:RefreshEXP(fillAmount)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "MonsterLogic")
	handler HandleBossInfoChange(BossInfoChange event)
		-- 보스 체력 정보 변경 시 HP바와 보스명 UI 업데이트
		
		local hp = event.hp
		local maxHp = event.maxHp
		local show = event.show
		local damage = event.damage
		local bossId = event.bossId
		if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then
			if show == false then
				self._T.randomBossHpBar.Entity.Parent.Enable = false
				return
			end
			
			local value = hp / maxHp
			
			if value == nil or value < 0 then
				self._T.randomBossHpBar.Entity.Parent.Enable = false
				return
			end
			
			self._T.randomBossHpBar.Entity.Parent.Enable = true
			self._T.randomBossHpBar.Value = value
			self._T.randomBossHpText.TextComponent.Text = string.format("%.2f%%", value * 100)
			self._T.randomBossNameText.Text = _LocalizeLogic:GetText(_MonsterLogic.monsterData[bossId].id) 
			self._T.randomBossNameText.Enable = true
		else
			if show == false then
				self.bossHpBar.Entity.Parent.Enable = false
				return
			end
			
			local value = hp / maxHp
			
			if value == nil or value < 0 then
				self.bossHpBar.Entity.Parent.Enable = false
				return
			end
			
			if _GameSettingLogic.mode == _GameConfig:GetConfig().GAMEMODE_BASIC then
				self.bossHpBar.Entity.Parent.Enable = true
			end
			
			
			self.bossHpBar.Value = value
			self.bossHpText.TextComponent.Text = string.format("%.2f%%", value * 100)
			self.bossNameText.Text = _LocalizeLogic:GetText(_MonsterLogic.monsterData[bossId].id) 
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageStartEvent(StageStartEvent event)
		-- 스테이지 시작 시 전투 UI 활성화 및 초기화
		self.bossHpBar.Entity.Parent.Enable = false
		self.battleUIGroup.Enable = true
		_HUDManager:SetTownButtonEnable(false)
		self.playerWeaponPanel.PlayerWeaponStatusUIComponent:Init()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleLevelUpBuff(LevelUpBuff event)
		-- 레벨업 버프 이벤트 처리 (현재 구현 없음)
		local itemName = event.itemName
		local weaponId = event.weaponId
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleBattlePlayerSPChange(BattlePlayerSPChange event)
		-- 플레이어 SP 변경 시 특수 스킬 게이지 업데이트
		local sp = event.sp
		local maxSp = event.maxSp
		local isField = event.isField
		if isField then
			return
		end
		self:SetSP(sp,maxSp)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "17b5195e-a5f1-4738-9f44-4d79274930e2")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 일시정지 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		
		self:Pause()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "396e2925-ae03-4850-92ff-19e156d59b55")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 재개 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		
		self:Resume()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "bf1b31a0-a63e-433f-a538-67184da77483")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 옵션 버튼 클릭 이벤트 처리 (옵션 UI 토글)
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		
		
		if _OptionLogic.optionUI.Entity.Enable then
			_OptionLogic.optionUI:Hide()
		else
			self:Pause()
			_OptionLogic.optionUI:Show()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleBattlePlayerHPChange(BattlePlayerHPChange event)
		-- 플레이어 체력 변경 시 HP 패널 업데이트
		local hp = event.hp
		local maxHp = event.maxHp
		self.hpPanel.SpriteGUIRendererComponent.FillAmount = hp / maxHp
		
	end

	@EventSender("LocalPlayer")
	handler HandleOnMapEnter(OnMapEnter event)
		-- 맵 진입 시 전투 UI 모드 설정
		local currentMap = event.currentMap
		local userEnter = event.userEnter
		local isBattleMap = currentMap.BattleMap ~= nil
		if isBattleMap then
			_BattleUIManager:SeBattleUI(_GameSettingLogic.mode)
		end
	end

end