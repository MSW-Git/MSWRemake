	property Entity dashCooltimeCover = "633b2553-1e2d-4263-b71b-89880adeae55"

	property SliderComponent bossHpBar = "21521785-28ff-42b6-818d-9cc03c8472a7"

	property Entity buttonCharingPC = "87d47ad3-5be2-4105-af34-99e0d5165e8d"

	property LoadingPopup loadingUI = "51cd01b1-e523-4ebf-9941-84af9a16f7ac"

	property Entity battleUIGroup = "27e4cea4-e28f-4ef0-a4dc-c643e0e16f92"

