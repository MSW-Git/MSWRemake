@Component
script KiteFlyPlayerComponent extends Component

	@TargetUserSync
	property number time = 0

	@TargetUserSync
	property boolean inited = false

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 연날리기 플레이어 컴포넌트 초기화 및 DB 설정
		if true then return end
		--[[
		self:InitDB()]]--
	end

	@ExecSpace("ServerOnly")
	method void InitDB()
		-- 데이터베이스에서 마지막 보상 시간을 가져와 초기화
		if true then return end
		--[[
		local info = _KiteFlyEventLogic:GetLastRewardTime(self.Entity.PlayerComponent.UserId)
		if info.error then
			return
		end
		
		self.time = info.time
		self.inited = true]]--
	end

	method boolean IsEnableTryToSendKite()
		-- 연날리기가 가능한 상태인지 쿨타임을 확인
		if true then return end
		--[[
		if self.inited == false then
			return false
			
		end
		
		local diffTime = _LocalTimeLogic:GetElapsed() -  self.time
		if ( _KiteFlyEventLogic.rewardInterval*60-diffTime) > 0 then 	
			return false
		end
		
		return true
		]]--
	end

end