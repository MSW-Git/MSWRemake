@Component
script UINewMergeEggItem extends Component

	property table storageData = {}

	property string originalId = ""

	property string uniqueKey = ""

	property table itemData = {}

	property number count = 0

	property number padding = 20

	property Entity eggIcon = nil

	property string tooltipId = "22"

	property Vector2 offset = Vector2(0,250)

	method void SetEggItem(table storageData)
		-- 알 아이템 데이터로 UI 설정 및 표시
		
		local weaponId= storageData.originalId
		
		self.storageData = storageData
		
		local uniqueKey = storageData.uniqueKey
		
		self.originalId = weaponId
		self.uniqueKey = uniqueKey
		
		local equipmentData = _ItemDataLogic:GetItemData(weaponId)
		self.itemData = equipmentData
		
		self.count = self.storageData.count
		local text = self.Entity:GetChildByName("textCount")
		text.TextComponent.Text = string.format("x%d",self.count)
		local textName = self.Entity:GetChildByName("textEggName")
		local splits = _UtilLogic:Split(_LocalizeLogic:GetItemName(self.originalId), "(")
		_LocalizeLogic:GetItemName(self.originalId)
		textName.TextComponent.Text = string.format("%s\n(%s", splits[1], splits[2])
		local eggIcon = self.Entity:GetChildByName("eggIcon")
		local spriteGUI = eggIcon.SpriteGUIRendererComponent
		spriteGUI.ImageRUID = ""
		spriteGUI.ImageRUID = self.itemData.ruid
		self.Entity.Enable = true
		self.eggIcon = eggIcon
		
		local desc = self.Entity:GetChildByName("text_desc")
		desc.TextComponent.Text = _LocalizeLogic:GetItemDesc(weaponId) 
		local buttonUseAll = self.Entity:GetChildByName("Button_use_all")
		buttonUseAll.Enable = false
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 알 사용 버튼 이벤트 연결
		local button = self.Entity:GetChildByName("Button_use")
		button:ConnectEvent(ButtonClickEvent,function(e)
			
		
			
			_NewMergeLogic:HatchEgg(self.storageData.uniqueKey,self.Entity.TransformComponent.Position,_UserService.LocalPlayer)
		end)
	end

	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 상태 변경 이벤트 처리 (현재 비어있음)
		
		local state = event.state
		
	end

end