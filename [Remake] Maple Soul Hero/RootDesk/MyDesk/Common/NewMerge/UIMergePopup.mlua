	@EventSender("Logic", "NewMergeLogic")
	handler HandleOnHatchSuccess(OnHatchSuccess event)
		-- 알 부화 성공 시 이팩트 및 사운드 재생
		local uniqueKey = event.uniqueKey
		local item = self:GetOrCreateWeaponItem(uniqueKey)
		if isvalid(item) == false then
			return
		end
		item.UINewMergeSlotItem:SetReddotVisible(true)
		_UIEffectLogic:PlayEffect("044f5dcaf5ff4c078b7dc181a1ccbc6a",item.TransformComponent.WorldPosition,Vector3.one)
		
		_SoundService:PlaySound("00b14d430f064a23ba57d7b8e7f2f881",1)
		self.eggEmptyGuide.Enable = _UserService.LocalPlayer.PlayerStorageComponent:GetAllEggCount() == 0
	end

