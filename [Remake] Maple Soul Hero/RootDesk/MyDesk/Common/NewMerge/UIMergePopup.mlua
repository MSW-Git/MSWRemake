	method Entity OnChangePlayerStorageItem(string uniqueKey, table storageData)
		-- 플레이어 인벤토리 아이템 변경 시 머지 UI 업데이트
		self.dragDelta = Vector2.zero
		local weaponItem = nil
		
		if isvalid(storageData) == false then
			weaponItem = self.mergeItems[uniqueKey]
			self.mergeItems[uniqueKey] = nil
			if isvalid(weaponItem) then
				self.weaponCount = self.weaponCount - 1
				if self.requestSyncAll and self._T.autoMergeTo[uniqueKey] ~= nil then
					local transform = weaponItem.TransformComponent
					local from = transform.WorldPosition
					
					local tweener = _TweenLogic:PlayTween(0,1,0.2,EaseType.SineEaseIn,function(value) 
					
							local pos = from * (1-value) + self._T.autoMergeTo[uniqueKey] * value
							transform.WorldPosition = pos
					end)
					
					tweener:SetOnEndCallback(function()
						
						
						_PoolingLogic:DestroyEntity(weaponItem)
					
					end)
					return nil
				end
		
				_PoolingLogic:DestroyEntity(weaponItem)
			
				return weaponItem
			end
			weaponItem = self.eggItems[uniqueKey]
			if isvalid(weaponItem) then
				weaponItem:Destroy()
				self.eggItems[uniqueKey] = nil
				
				return weaponItem
			end
		
			return weaponItem
		end
		local itemData = _ItemDataLogic.equipmentData[storageData.originalId]
		if itemData ~= nil then
			if itemData.category ~= "weapon" then
				return weaponItem
			end
			weaponItem = self:GetOrCreateWeaponItem(uniqueKey)
			weaponItem.UINewMergeSlotItem:SetWeaponID(uniqueKey,storageData)
		
		elseif _ItemDataLogic.itemData[storageData.originalId] ~= nil and _ItemDataLogic.itemData[storageData.originalId].category == "egg" then
			local grade = _ItemDataLogic.itemData[storageData.originalId].grade
			local egg = self:GetOrCreateEgg(uniqueKey)
		
			egg.UINewMergeEggItem:SetEggItem(storageData)
			return nil
		else
		end
		return weaponItem
	end

	method Entity GetOrCreateWeaponItem(string uniqueKey)
		-- 무기 아이템 UI 엔티티를 가져오거나 새로 생성
		local item = self.mergeItems[uniqueKey]
		if isvalid(item) == false then
			item = _PoolingLogic:SpawnModel("model://ffe38ea3-0c25-467e-8c27-5941d240a1bd",Vector3(9999,9999,0),self.parent)
			self.index = self.index + 1
			self.mergeItems[uniqueKey] = item
			item.UINewMergeSlotItem:InitSprite()
			item.Visible = true
			item.Enable = true
			
			self.weaponCount = self.weaponCount + 1
		end
		return item
	end

	method void SetGridPosition(string uniqueKey, number x, number y, boolean apply, boolean setPos)
		-- 아이템을 UI 그리드의 지정된 위치에 배치
		---@type Entity
		local item = self.mergeItems[uniqueKey]
		
		
		if isvalid(item) == false then
			return
		end
		item.Enable = true
		if item.UINewMergeItem.x == x and item.UINewMergeItem.y == y then
			item.UINewMergeItem:SetPosition(x,y)
		
			return
		end
		
		local key = _NewMergeLogic:GetGridKey(x,y)
		if apply == false then
			self.itemGrid[key] = item
			item.UINewMergeItem:SetPosition(x,y)
			return
		end
		
		
		local originPos =  _NewMergeLogic:ConvertSnapPosition(Vector3(item.UINewMergeItem.x,item.UINewMergeItem.y,0))
		local originKey =  _NewMergeLogic:GetGridKey(originPos.x,originPos.y)
		local originItem = self.itemGrid[key]
		self.itemGrid[originKey] = nil
		
		self.itemGrid[key] = item
		
		local pos = Vector3(x,y,0)
		
		self.itemGrid[key].UINewMergeItem:SetPosition(x,y)
		
		_NewMergeLogic:ApplyPosition(_UserService.LocalPlayer,uniqueKey,pos,apply)
	end

	method void Hide()
		-- 머지 팝업 숨기기 및 정리
		if self.slotSelectState then
			self:SetEquipGuidePanel(false)
			return
		end
		__base:Hide()
		self:ClearPopup()
		
	end

	method Entity GetOrCreateEgg(string uniqueKey)
		-- 알 아이템 UI 엔티티를 가져오거나 새로 생성
		local item = self.eggItems[uniqueKey]
		if isvalid(item) == false then
			item =  self.baseEggItem:Clone(uniqueKey)
			item:AttachTo(self.eggParent)
			self.eggItems[uniqueKey] = item
		end
		return item
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화
		__base:OnBeginPlay()
		self.baseEggItem.Enable = false
		self.selectedOutline.Visible = false
		
		for i =1,4 do
			self.textWeaponSpecLocked[i] = self.textWeaponSpec.Entity.Parent:GetChildByName("textWeaponSpec_locked_"..tostring(math.floor(i)))
		end
	end

	method void ShowItemSpec(string uniqueKey, table storage)
		-- 선택된 아이템의 상세 정보를 UI에 표시
		if storage == nil then
			self:ClearWeaponSpecUI()
			return
		end
		local itemData = _ItemDataLogic.equipmentData[storage.originalId]
		if itemData == nil then
			self:ClearWeaponSpecUI()
			return
		end
		self.panelWeaponSpec.Enable = true
		
		self.currentUniqueKey = uniqueKey
		local weaponData = _WeaponSpecLogic:GetWeaponSpec(storage.originalId)
		
		local level = storage.level
		local weaponLevelUpData = _ItemDataLogic:GetWeaponLevelUpData(level)
		
		
		if _UtilLogic:IsNilorEmptyString(itemData.ruid) == true then
			self.thumbItem.ImageRUID = weaponData.ruid
		else
			self.thumbItem.ImageRUID = itemData.ruid
		end
		
		
		self.autoMergeButton.Enable = true
		self.equipButton.Enable = true
		self.unequipButton.Enable = true
		local itemType = weaponData.type
		local grade = itemData.grade
		
		
		self.textItemName.Text = string.format("%s %s",_LocalizationService:GetText(grade),_LocalizationService:GetText(itemType))
		self.textItemName.Entity.SpriteGUIRendererComponent.Color = _WeaponSpecLogic:GetColorBackByGrade(grade)
		
		self.textWeaponLevel.Text = string.format(_LocalizeLogic:GetText("etcStr11"),storage.level)
		
		if _UtilLogic:IsNilorEmptyString(itemData.nextEquipment) == false then
			self.textNextLevel.Text = string.format(_LocalizeLogic:GetText("etcStr46"),itemData.maxLevel + 1)
		else
			self.textNextLevel.Text = ""
		end
		if _GameUtil.UI_DEBUG then
			self.textNextLevel.Text = self.textNextLevel.Text.. string.format("(exp %s/%s)",storage.mergeExp,_ItemDataLogic:GetWeaponMaxExp(storage.level+1))
		end
		
		local atk = _CalcLogic:GetWeaponAttackDamageByKeyWithoutCharBuff(uniqueKey, _UserService.LocalPlayer)
		local charBuffAtk = _CalcLogic:GetWeaponCharBuffAttack(uniqueKey, _UserService.LocalPlayer,atk)
		local currentCharIndex = string.format("%d",_UserService.LocalPlayer.PlayerCharacterData.charIndex)
		local charData = _CharacterLogic.characterTable[currentCharIndex]
		local contain = false
		
		for k,v in pairs(charData.exWeaponId) do
			if itemData.mergeId == v then
				contain = true
			end
		end
		if contain then
			self.atkText.Text = string.format("%d<color=#FFF110> + %d</color>", atk,charBuffAtk)
			self.charMatchWeaponUI.Enable = true
		else
			self.atkText.Text = string.format("%d", atk)
			self.charMatchWeaponUI.Enable = false
		end
		self.selectedWeaponIcon.ImageRUID =_WeaponSpecLogic:GetWeaponCategoryIcon(itemType) 
		self.selectedWeaponSlot.ImageRUID = _WeaponSpecLogic:GetWeaponSlotRUIDByGrade(grade)
		local gradeNum = 1
		if itemData.grade == "normal" then
			gradeNum =1
		elseif itemData.grade == "rare" then
			gradeNum =2
		elseif itemData.grade == "epic" then
			gradeNum =3
		elseif itemData.grade == "unique" then
			gradeNum =4
		elseif itemData.grade == "legendary" then
			gradeNum =5
		end
		
		local optionData = _ItemDataLogic.equipmentOptionData[itemType]
		
		if  weaponData.attribute ==  "physical" then
			self.textWeaponClass.Text = _LocalizeLogic:GetText("etcStr198")
		elseif  weaponData.attribute ==  "magical" then
			self.textWeaponClass.Text = _LocalizeLogic:GetText("etcStr199")
		else
			self.textWeaponClass.Text = weaponData.attribute
		end
		
		
		self.textWeaponSpec.Text = ""
		self.textWeaponSpecLock.Text = ""
		self.gaugeWeaponEXP.FillAmount = _WeaponSpecLogic:GetEXPAmount(storage)
		
		if optionData ~= nil then
			local optionText = ""
			local optionTextLock = ""
			
			for i = 1, 5 do
				local optionKey = string.format("option_%d", i)			
				local optionStr = _LocalizeLogic:GetText(string.format("option%d_Desc_%s",i,itemType)) 
				if _UtilLogic:IsNilorEmptyString(optionStr) == false then
					if i > gradeNum then
						if isvalid(self.textWeaponSpecLocked[i-1]) then
							self.textWeaponSpecLocked[i-1].TextComponent.Text = string.format("%s",optionStr)
							self.textWeaponSpecLocked[i-1].Enable = true
						end
					else
						if _UtilLogic:IsNilorEmptyString(optionText) == false then
							optionText = string.format("%s\n<color=%s>%s</color>",optionText,_WeaponSpecLogic.weaponColor[i],optionStr)
						else
							optionText = string.format("<color=%s>%s</color>",_WeaponSpecLogic.weaponColor[i],optionStr)
						end
						if isvalid(self.textWeaponSpecLocked[i-1]) then
							self.textWeaponSpecLocked[i-1].Enable = false
						end
					end
				end
			end
		
			
			self.textWeaponSpec.Text = optionText
		
			self.textWeaponSpec.Entity.Enable = _UtilLogic:IsNilorEmptyString(optionText) == false
		end
		
		self.equipButton.Enable = storage.equippedSlotNum <= 0
		self.unequipButton.Enable = storage.equippedSlotNum > 0
		self.buttonSellWeapon.Enable = true
		if storage.lock == nil or storage.lock == false then
			self.buttonLockWeapon.Enable = true
			self.buttonUnlockWeapon.Enable = false
			self.iconLock.Enable = false
		else
			self.buttonLockWeapon.Enable = false
			self.buttonUnlockWeapon.Enable = true
			self.iconLock.Enable = true
		end
		
		
		self.buttonSellWeapon.UIButton:SetButtonEnable(true)
		
		self.buttonLockWeapon.UIButton:SetButtonEnable(true)
		self.equipButton.UIButton:SetButtonEnable(true)
		
		
		
		self.autoMergeButton.UIButton:SetButtonEnable(_NewMergeLogic:IsAutoMergeEnable(uniqueKey))
		
		
		local masterValue = _GameConfig:GetConfig().WEAPON_GRAPH_MAX_VALUE
		self.weaponGraph01.FillAmount = weaponData.graph_attack / masterValue
		self.weaponGraph02.FillAmount = weaponData.graph_speed / masterValue
		self.weaponGraph03.FillAmount = weaponData.graph_util / masterValue
		self.weaponGraph04.FillAmount = weaponData.graph_multihit / masterValue
		self.weaponGraph05.FillAmount = weaponData.graph_accuracy / masterValue
	end

	method void SelectItem(Entity entity)
		-- 아이템 선택 및 상세 정보 표시
		if isvalid(self.selectedItem) and self.selectedItem ~= entity then
			self.selectedItem.UINewMergeSlotItem:OnSelected(false)
		end
		
		if isvalid(entity) == false then
			self.selectedItem = nil
			self:ClearWeaponSpecUI()
			_NewMergeLogic:SendEvent(MergeItemDeselectedEvent())
			return
		end
		
		self.selectedItem = entity
		self.selectedItem.UINewMergeSlotItem:SetReddotVisible(false)
		self.selectedItem.UINewMergeSlotItem:OnSelected(true)
		self:ShowItemSpec(entity.UINewMergeItem.uniqueKey,self.selectedItem.UINewMergeItem.storageData)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 캐릭터 정보 업데이트 처리
		if isvalid(self.selectedItem) then
		end
		if self._T.needToRefreshCharacterInfo then
			self._T.needToRefreshCharacterInfo = false
			local currentCharIndex = string.format("%d",_UserService.LocalPlayer.PlayerCharacterData.charIndex)
			local charLevel = _UserService.LocalPlayer.PlayerCharacterData.charLevel
			local charData = _CharacterLogic.characterTable[currentCharIndex]
			self.characterIllust.ImageRUID = charData.thumbnailRUID
			
			self.textCharacterName.Text = _LocalizationService:GetText("soul_name_"..currentCharIndex)
			self.textCharacterLevel.Text = string.format("Lv %d", charLevel)
			self.textCharacterPower.Text = string.format("%d",_MySpecLogic.mySpec.battlePower)
			self.charWeaponIcon.ImageRUID = _CharacterLogic:GetExWeaponCategoryIconRUID(currentCharIndex)
		end
	end

	method void InitWeaponSlots()
		-- 무기 장착 슬롯 UI 초기화
		if self.weaponSlotInited then
			return
		end
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		local canEquipCount = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		local slots = {}
		local maxEquip = _GameConfig:GetConfig().MAX_EQUIPMENT_CNT
		
		self.weaponSlotInited = true
		
		
		for i =1, maxEquip do
			local slot = self.equipSlotParent:GetChildByName(string.format("equipSlot%d",i))
			slot.UINewMergeEquipItem.equipSlot = i
			slot.UINewMergeEquipItem:InitSprite()
			
			table.insert(self.equipSlots,slot)
		end
	end

	method void SetWeaponSlot(number slotNum, string uniqueKey)
		-- 지정된 슬롯에 무기 설정
		if self.weaponSlotInited == false then
			self:InitWeaponSlots()
		end
		---@type Entity
		local equipItem = self.equipSlots[slotNum]
		if isvalid(equipItem)== false then
			return
		end
		equipItem.UINewMergeEquipItem:SetWeaponID(uniqueKey, _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey])
	end

	method void Show()
		-- 머지 팝업 표시 및 데이터 새로고침
		if self.Entity.ContentLockComponent:CheckUIAvailable() then
			self:SelectItem(nil)
			self:ClearPopup()
			__base:Show()
			_UIOpenQuestLogic:CheckQuestInProgress("weapon",self.Entity)
			
			self:SetScaleFactor()
			self.Entity.Enable = true
			
			
			self:Refresh()
			self:RefreshCharacterInfo()
			
			for k,v in pairs(self.equipSlots) do
				---@type Entity
				local entity = v
				entity.UINewMergeEquipItem:RefreshLockIcon()
			end
			
			
			for k,v in pairs(_UserService.LocalPlayer.PlayerStorageComponent.storage) do
				local weapon = _WeaponSpecLogic:GetWeaponSpec(v.originalId)
				if weapon ~= nil then
					if v.equippedSlotNum > 0 then
						self:SetWeaponSlot(v.equippedSlotNum,k)
					end
				end
			end
			
			
		end
	end

	method void SetScaleFactor()
		-- 화면 비율에 따른 UI 스케일 조정
		local ScreenWidth = _GameUtil:GetScreenRectSizeX()
		local ScreenHeight = _GameUtil:GetScreenRectSizeY()
		
		local scaleRatio = (ScreenWidth / ScreenHeight) / (16/9) 
		self.scaleFactor =  math.min(0.95, scaleRatio * scaleRatio)
		
		self.mergePanel.TransformComponent.Scale = Vector3(self.scaleFactor,self.scaleFactor,1) 
		self.buttonPanel.TransformComponent.Scale = Vector3(self.scaleFactor,self.scaleFactor,1) 
	end

	method boolean OnCheckEquipItem(string uniqueKey)
		-- 아이템이 장착 슬롯 영역에 드롭되었는지 확인
		if #self.equipSlots == 0 then
			return false
		end
		
		
		local maxEquip = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		local pos1 = self.canvasTip.anchoredPosition:Clone()
		
		for i =1, maxEquip do
			---@type Entity
			local entity = self.equipSlots[i]
			self.canvasTip.WorldPosition = entity.UITransformComponent.WorldPosition
			local pos2 = self.canvasTip.anchoredPosition:Clone()
			local size2 = entity.UITransformComponent.RectSize 
			
			local topLeft = Vector2(pos2.x - size2.x * 0.5,pos2.y + size2.y * 0.5)
			local bottomRight = Vector2(pos2.x + size2.x * 0.5,pos2.y - size2.y * 0.5)
		
			if topLeft.x < pos1.x and topLeft.y > pos1.y and bottomRight.x > pos1.x and bottomRight.y < pos1.y then
		
				_UserService.LocalPlayer.PlayerStorageComponent:Equip(uniqueKey,i)
				return true
			end
		
		end
		return false
	end

	method void SetEquipGuidePanel(boolean enable)
		-- 장착 가이드 패널 표시/숨김 설정
		local canEquipCount = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		
		if enable then
			for k,v in pairs(self.equipSlots) do
				---@type Entity
				local entity = v
				
				if entity.UINewMergeEquipItem.equipSlot <= canEquipCount then		
					if _UtilLogic:IsNilorEmptyString(entity.UINewMergeEquipItem.uniqueKey) then
						_UserService.LocalPlayer.PlayerStorageComponent:Equip(self.currentUniqueKey,k)
						return
					end	
				end
			end
		end
		self.blockEquipSlot.Enable = enable
		self.textEquipGuide.Enable = enable
		self.slotSelectState = enable
		
		for k,v in pairs(self.equipSlots) do
			---@type Entity
			local entity = v
			local guideEquip = entity:GetChildByName("guideEquip",true)
			if entity.UINewMergeEquipItem.equipSlot <= canEquipCount then		
				guideEquip.Enable = enable
			else
				guideEquip.Enable = false
			end
		end
	end

	method void OnChangeItemData(string uniqueKey, table itemData)
		-- 아이템 데이터 변경 시 UI 업데이트
		
		local item = self:OnChangePlayerStorageItem(uniqueKey,itemData)
		if isvalid(item) == false then
			return
		end
		if itemData ~= nil and item.UINewMergeSlotItem ~=nil then
			self:SetGridPosition(uniqueKey,itemData.posX,itemData.posY,false,true)
		else
		
		end
		
		if self.currentUniqueKey == uniqueKey then
			self:ShowItemSpec(uniqueKey,itemData)
		end
		
	end

	method void Refresh()
		-- 전체 인벤토리 데이터를 기반으로 UI 새로고침
		local storage = {}
		local playerStorage = _UserService.LocalPlayer.PlayerStorageComponent
		
		for k,v in pairs(playerStorage.storage) do
			local eachData = {}
			eachData.originalId = v.originalId
			eachData.uniqueKey = k
			eachData.storage = v
			table.insert(storage,eachData)
		end
		table.sort(storage,function(a,b) return a.originalId > b.originalId end)
		for k,v in pairs(storage) do
			self:OnChangeItemData(v.uniqueKey,v.storage)
		end
		
		self.eggEmptyGuide.Enable = playerStorage:GetAllEggCount() == 0
		self.textWeaponSlotCount.Text = string.format("%d/72",self.weaponCount)
		
		for k,v in pairs(self.eggItems) do		
			if v.UINewMergeEggItem.itemData.grade == "tutorial" then
				v.Enable = false
			end
		end
	end

	method void RefreshCharacterInfo()
		-- 캐릭터 정보 UI 업데이트 플래그 설정
		self._T.needToRefreshCharacterInfo = true
		
		
	end

	method void ClearWeaponSpecUI()
		-- 무기 상세 정보 UI 초기화
		self.panelWeaponSpec.Enable = false
		
		
		self.unequipButton.Enable = false
		self.buttonUnlockWeapon.Enable = false
		
		self.equipButton.Enable = true
		self.buttonLockWeapon.Enable = true
		
		self.buttonSellWeapon.UIButton:SetButtonEnable(false)
		self.autoMergeButton.UIButton:SetButtonEnable(false)
		self.equipButton.UIButton:SetButtonEnable(false)
		self.buttonLockWeapon.UIButton:SetButtonEnable(false)
		
		
		
		self.currentUniqueKey = ""
	end

	method void ClearPopup()
		-- 팝업 내의 모든 아이템 엔티티 정리
		
		for k,v in pairs(self.mergeItems) do
			_PoolingLogic:DestroyEntity(v)
		end
		
		self.weaponCount = 0
		for k,v in pairs(self.eggItems) do
			v:Destroy()
		end
		table.clear(self.mergeItems)
		table.clear(self.eggItems)
		self:ClearWeaponSpecUI()
		
	end

	method void StartTutorial()
		-- 머지 튜토리얼 시작
		if _CheckLogic:IsEnoughWeaponSlot(_UserService.LocalPlayer.PlayerComponent.UserId,2) == false then
			return
		end
		local eggCnt = 0
		for k,v in pairs(self.eggItems) do
			if v.UINewMergeEggItem.itemData.grade == "tutorial" then
				eggCnt = eggCnt + v.UINewMergeEggItem.count
			end
		end
		
		if eggCnt < 2 then
			return
		end
		
		for k,v in pairs(self.eggItems) do
			if v.UINewMergeEggItem.itemData.grade == "tutorial" then
				v.Enable = true
			else
				v.Enable = false
			end
		end
		self.eggEmptyGuide.Enable = false
		_TutorialLogic:StartTutorial("merge_tutorial_1",function() end)
	end

	method void RefreshEquipSlot()
		-- 장착 슬롯 UI 상태 새로고침
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		
		for k,v in pairs(self.equipSlots) do
			---@type Entity
			local entity = v
		
			if 	storage[entity.UINewMergeEquipItem.uniqueKey]  == nil then
				self:SetWeaponSlot(k,"")
			end
			
		end
	end

	method void OnHoverEquipSlot(number slot, boolean hover)
		-- 장착 슬롯 호버 상태 처리
		local entity = self.equipSlots[slot]
		local guideEquip = entity:GetChildByName("guideEquip",true)
		
		if hover == false then
			if slot ~= self._T.hoverSlot then
				return
			end
			self._T.hoverSlot = nil
			self.guideItem.Enable = true
			guideEquip.Enable = false
			return
		end
		
		self._T.hoverSlot = slot
		self.guideItem.Enable = false
		
		
		local canEquipCount = _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount
		
		
		if slot <= canEquipCount then		
			guideEquip.Enable = true
		else
			guideEquip.Enable = false
		end
		
		
	end

	method boolean CheckHoverEquipSlot()
		-- 현재 호버 중인 장착 슬롯에 아이템 장착 시도
		if self._T.hoverSlot == nil then
			self:ResetEquipGuide()
			return false
		end
		if self.mergeItems[self.currentUniqueKey].UINewMergeSlotItem.storageData.equippedSlotNum == self._T.hoverSlot then
			self:ResetEquipGuide()
			self._T.hoverSlot = nil
			return false
		end
		_UserService.LocalPlayer.PlayerStorageComponent:Equip(self.currentUniqueKey,self._T.hoverSlot)
		self.guideItem.Enable = false
		self.dragItem.Enable = false
		self:ResetEquipGuide()
		self._T.hoverSlot = nil
		return true
	end

	method void ResetEquipGuide()
		-- 모든 장착 가이드 UI 비활성화
		for k,v in pairs(self.equipSlots) do
			---@type Entity
			local entity = v
			local guideEquip = entity:GetChildByName("guideEquip",true)
			guideEquip.Enable = false
		end
	end

