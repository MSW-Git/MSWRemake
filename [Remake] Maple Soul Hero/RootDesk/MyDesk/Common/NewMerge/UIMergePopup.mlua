	@EventSender("LocalPlayer")
	handler HandleEquipEvent(EquipEvent event)
		-- 무기 장착/해제 이벤트 처리
		local slotNum = event.slotNum
		local isEquip = event.isEquip
		local uniqueKey = event.uniqueKey
		
		local playerStorage =  _UserService.LocalPlayer.PlayerStorageComponent.storage
		local storage = playerStorage[uniqueKey]
		if storage == nil then
			return
		end
		local originalId = storage.originalId
		
		if not isvalid(_ItemDataLogic.equipmentData[originalId]) then
			
			return
		end
		
		if _ItemDataLogic.equipmentData[originalId].category == "weapon" then
			if isEquip then
				self:SetWeaponSlot(slotNum, uniqueKey)
			else
				for k,v in pairs(self.equipSlots) do
					---@type Entity
					local equipItem = v
					if uniqueKey == equipItem.UINewMergeEquipItem.uniqueKey then
						equipItem.UINewMergeEquipItem.uniqueKey = ""
						equipItem.UINewMergeEquipItem:InitSprite()
						break
					end
				end
			end
		end
		
		
		
	end

	@EventSender("LocalPlayer")
	handler HandleDBLoadedEvent(DBLoadedEvent event)
		-- 데이터베이스 로드 완료 시 UI 초기화
		self:InitWeaponSlots()
		self:Refresh()
		self:RefreshCharacterInfo()
	end

