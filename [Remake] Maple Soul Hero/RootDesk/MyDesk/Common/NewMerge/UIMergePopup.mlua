	@EventSender("Entity", "7f73e90f-f6ad-41ea-91b1-b6c12751e2e2")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 자동 머지 버튼 클릭
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.currentUniqueKey]
		if storage == nil then
			return
		end
		local name = _LocalizationService.LocalTranslator:GetText(_WeaponSpecLogic.weaponData[storage.originalId].type)
		local itemData = _ItemDataLogic:GetItemData(storage.originalId)
		
		
		local weaponName = string.format("<color=%s>%s</color>",_WeaponSpecLogic:GetHexColorByGrade(itemData.grade),name)
		
		_UIPopup:OpenMergeItem(_LocalizeLogic:GetText("popup38"), _LocalizeLogic:GetText("popup39"), _LocalizeLogic:GetText("popup40"),weaponName,self.currentUniqueKey,function()
				local uniqueKey = self.selectedItem.UINewMergeSlotItem.uniqueKey
				if _NewMergeLogic:IsAutoMergeEnable(uniqueKey) == false then
						_UIToast:ShowMessage(_LocalizeLogic:GetText("toast61"))
					return
				end
			
				self.requestSyncAll = true
				if self._T.autoMergeTo == nil then
					self._T.autoMergeTo = {}
				end
				table.clear(self._T.autoMergeTo)	
				local mergeTo = self.selectedItem.TransformComponent.WorldPosition:Clone()
			
				for k,v in pairs(_UserService.LocalPlayer.PlayerStorageComponent:GetAllWeapon()) do
					local eachItemData = _ItemDataLogic:GetItemData(v.originalId)
					if eachItemData.mergeGroup == itemData.mergeGroup then
						self._T.autoMergeTo[v.uniqueKey] = mergeTo
					end
				end
			
			
			
			
				self:SetUIInputEnable(false)
				
				_NewMergeLogic:AutoMerge(self.selectedItem.UINewMergeSlotItem.uniqueKey,mergeTo:ToVector2())
		 end,function() end)
	end

	@EventSender("Logic", "NewMergeLogic")
	handler HandleSuccessAutoMergeEvent(SuccessAutoMergeEvent event)
		-- 자동 머지 성공 이벤트 처리
		local succuess = event.succuess
		local uniqueKey= event.uniqueKey
		self.requestSyncAll = false
		self:SetUIInputEnable(true)
		if succuess == false then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast61"))
		else
			self.currentUniqueKey = uniqueKey
			self:RefreshCharacterInfo()		
			self:SelectItem(self.mergeItems[uniqueKey])
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast60"))
			_SoundService:PlaySound("246bd3394158471d861ddabbe12ba291",1)
			local effect = _WeaponSpecLogic:GetMergeEffect(self.selectedItem.UINewMergeItem.itemData.grade)
			if self._T.autoMergeTo[uniqueKey] ~= nil then
				_UIEffectLogic:PlayEffect(effect,self._T.autoMergeTo[uniqueKey],Vector3.one)
			end
			self.textWeaponSlotCount.Text = string.format("%d/72",self.weaponCount)
			
			self:RefreshEquipSlot()
		end
		
	end

	@EventSender("Entity", "25b64894-46a5-4758-90e2-b48fd7378ad8")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 무기 판매 버튼 클릭
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.currentUniqueKey]
		if storage == nil then
			return
		end
		
		if storage.lock~=nil and storage.lock then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast59"))
			return
		end
		local weaponCnt = _UserService.LocalPlayer.PlayerStorageComponent:GetAllWeaponCnt()
		if weaponCnt == 1 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast58"))
			return
		end
		
		local lv = 	storage.level
		local sellingPrice = _ItemDataLogic.weaponMesoTable[lv].sellingPrice * _GameConfig:GetConfig().WEAPON_SELLING_RATIO
		local name = _LocalizationService.LocalTranslator:GetText(_WeaponSpecLogic.weaponData[storage.originalId].type)
		local itemData = _ItemDataLogic:GetItemData(storage.originalId)
		
		local weaponName = string.format("<color=%s>%s</color>",_WeaponSpecLogic:GetHexColorByGrade(itemData.grade),name)
		_UIPopup:OpenSellPopup(_LocalizeLogic:GetText("popup41"),weaponName,self.currentUniqueKey,sellingPrice,function()
				_UserService.LocalPlayer.PlayerStorageComponent:RequestSellItem(self.currentUniqueKey)
				_SoundService:PlaySound("21600ec9d3a04cfeb69c6fe0c50e197c",1)
				self:SelectItem(nil)
		 end,function() end)
	end

