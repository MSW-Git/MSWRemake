	@EventSender("Entity", "65ed05e5-629f-47ee-b965-2d6f0d44907e")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 전체 자동 머지 버튼 클릭
		
		local Entity = event.Entity
		
		
		_UIPopup:Open(_LocalizeLogic:GetText("popup6"), _LocalizeLogic:GetText("popup7"),function()
			self.requestSyncAll = true
			if self._T.autoMergeTo == nil then
				self._T.autoMergeTo = {}
			end
			table.clear(self._T.autoMergeTo)
		
			local allWeapon = _UserService.LocalPlayer.PlayerStorageComponent:GetAllWeapon()
			local weapon = {}
			
			for k,v in pairs(allWeapon) do
				if v.level < _GameConfig:GetConfig().MAX_ITEM_LEVEL then 
					table.insert(weapon,v)
				end
			end
			
			table.sort(weapon,function(a,b) 
				if a.level == b.level then
					if a.mergeExp == b.mergeExp then
						return a.uniqueKey > b.uniqueKey
					end
					return a.mergeExp > b.mergeExp
				end
				return a.level > b.level
			 end)
			
			local unlockWeapon  = {}
			for k,v in pairs(weapon) do
				if v.lock == false then
					local itemData = _ItemDataLogic:GetItemData(v.originalId)
					if itemData ~= nil then
						if unlockWeapon[itemData.mergeGroup] == nil then
							unlockWeapon[itemData.mergeGroup] = self.mergeItems[v.uniqueKey].TransformComponent.WorldPosition:Clone()
						end
						
					end
				end
			end
			
			for k,v in pairs(weapon) do
				local itemData = _ItemDataLogic:GetItemData(v.originalId)
				if itemData ~= nil then
					if unlockWeapon[itemData.mergeGroup]  ~= nil then
						self._T.autoMergeTo[v.uniqueKey] = unlockWeapon[itemData.mergeGroup]
					end
				end
			end
			
		
		
			_NewMergeLogic:AllAutoMerge()	
			self:SetUIInputEnable(false)
		 end,function() end)
		
	end

end