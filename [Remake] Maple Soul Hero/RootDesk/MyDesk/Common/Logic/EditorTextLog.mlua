@Logic
script EditorTextLog extends Logic

	property Entity parentGroup = nil

	property table textList = {}

	property number count = 0

	property number space = 30

	property Vector2 offset = Vector2(620,-250)

	method void Log(string id, string text)
		-- 에디터 환경에서 디버그 텍스트 로그 출력
		if Environment:IsPublishedPlay() then
			return
		end
		
		if isvalid(self.parentGroup) == false then
			self.parentGroup = _SpawnService:SpawnByModelId("model://uigroup","Editor",Vector3.zero,_EntityService:GetEntityByPath("/ui"))
			self.parentGroup.UITransformComponent.AlignmentOption = AlignmentType.StretchAll
			self.parentGroup.UITransformComponent.OffsetMin = Vector2.zero
			self.parentGroup.UITransformComponent.OffsetMax = Vector2.zero
			self.parentGroup.Enable = true
		end
		
		if self.textList[id] == nil then
			local newText = _SpawnService:SpawnByModelId("model://uitext","text",Vector3.zero,self.parentGroup)
			newText.SpriteGUIRendererComponent.RaycastTarget = false
			newText.UITransformComponent.AlignmentOption = AlignmentType.TopLeft
			newText.UITransformComponent.anchoredPosition = self.offset - Vector2(0,self.space * self.count)
			newText.UITransformComponent.RectSize.x = 1200
			local textComp = newText.TextComponent
			textComp.Alignment = TextAlignmentType.MiddleLeft
			textComp.FontColor = Color.white
			textComp.UseOutLine = true
			textComp.OutlineColor = Color.black
			textComp.Overflow = OverflowType.Overflow
			
			self.count = self.count + 1
			self.textList[id] = textComp
		end
		
		self.textList[id].Text = text
	end

end