@Logic
script ColorLogic extends Logic

	method any GetColorFromRGBAString(string rgba)
		-- RGBA 문자열을 Color 객체로 변환
		local color = Color.white
		local splits = _UtilLogic:Split(rgba, "/")
		
		color = Color(splits[1] / 255, splits[2] / 255, splits[3] / 255, splits[4] / 100)
		
		return color
	end

end