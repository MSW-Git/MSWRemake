@Component
script TestBossRaidPortal extends Component

	property number hp = 1000000

	property number chapter = 99999

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 테스트 보스 레이드 포털 초기화
		
	end

	method void RefreshLeaderboard(table leaderboard)
		-- 리더보드 정보를 채팅 벌룬에 표시
		local message = ""
		for k,v in pairs(leaderboard) do
			message = message .. v.rank .." " .. v.nickname .." " .. v.score .."\n" 
		end
		self.Entity.ChatBalloonComponent.Message = message
	end

	method void RefreshRaidInfo(table raidInfo)
		-- 레이드 정보를 네임태그에 표시
		self.Entity.NameTagComponent.Name = string.format("%d/%d", raidInfo.bossHP,self.hp)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleInteractionEvent(InteractionEvent event)
		-- 플레이어 상호작용 이벤트 처리
		
		local InteractionEntity = event.InteractionEntity
		
		if InteractionEntity == _UserService.LocalPlayer then
			
		end
		
	end

	@EventSender("Logic", "WorldBossRaidLogic")
	handler HandleGetWorldBossRaidInfo(GetWorldBossRaidInfo event)
		-- 월드 보스 레이드 정보 수신
		local raidInfo = event.raidInfo
	end

	@EventSender("Logic", "WorldBossRaidLogic")
	handler HandleGetWorldBossRaidLeaderboard(GetWorldBossRaidLeaderboard event)
		-- 월드 보스 레이드 리더보드 수신
		local leaderboard = event.leaderboard
	end

end