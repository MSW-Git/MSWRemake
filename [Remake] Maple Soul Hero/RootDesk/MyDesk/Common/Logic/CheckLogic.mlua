@Logic
script CheckLogic extends Logic

	method boolean IsEnoughWealth(string userId, string wealthType, integer needAmount)
		-- 플레이어의 자산이 충분한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		local playerCurrency = playerEntity.PlayerCurrencyData
		
		if wealthType == _GameConfig:GetConfig().WEALTHTYPE_MESO then
			if playerCurrency.currencyTable["Gold"].amount < needAmount then
				return false
			end
		elseif wealthType == _GameConfig:GetConfig().WEALTHTYPE_ESSENCE then
			if playerCurrency.currencyTable["Essence"].amount < needAmount then
				return false
			end
		elseif wealthType == _GameConfig:GetConfig().WEALTHTYPE_SCROLL then
			if playerCurrency.currencyTable["WeaponScroll"].amount < needAmount then
				return false
			end
		elseif wealthType == _GameConfig:GetConfig().WEALTHTYPE_DIAMOND then
			if playerCurrency.currencyTable["Diamond"].amount < needAmount then
				return false
			end
		elseif wealthType == _GameConfig:GetConfig().WEALTHTYPE_FIELDGEM then
			if playerCurrency.currencyTable["FieldGem"].amount < needAmount then
				return false
			end
		end
		
		return true
	end

	method boolean IsEnoughStorageSlot(string userId, integer needSlot)
		-- 인벤토리 슬롯이 충분한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		local playerStorage = playerEntity.PlayerStorageComponent
		local storage = playerStorage.storage
		local count = 0 
		
		for key, value in pairs(storage) do
			if not self:IsFieldItem(value.originalId) then
				count = count + 1
			end
		end
		
		
		if count + needSlot <= _GameConfig:GetConfig().LIMIT_STORAGESLOT then
			return true
		else
			return false
		end
	end

	method boolean IsEnoughWeaponSlot(string userId, integer needSlot)
		-- 무기 인벤토리 슬롯이 충분한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		local playerInfo = playerEntity.PlayerInfoComponent.playerInfo
		local playerStorage = playerEntity.PlayerStorageComponent
		local storage = playerStorage.storage
		local count = 0 
		
		for key, value in pairs(storage) do
			local id = value.originalId
			local data = _ItemDataLogic.equipmentData[id]
			
			if isvalid(data) and data.category == "weapon" and not self:IsFieldItem(id) then
				count += 1
			end
		end
		
		if count + needSlot <= _GameConfig:GetConfig().LIMIT_WEAPONSLOT + playerInfo.weaponStorageSlot then
			return true
		else
			return false
		end
	end

