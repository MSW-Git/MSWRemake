	method boolean IsUsableOrEtcItem(string userId, string itemId)
		-- 사용 가능한 아이템 또는 기타 아이템인지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local storage = playerEntity.PlayerStorageComponent.storage
		local item = _ItemDataLogic.itemData
		
		if not isvalid(playerEntity) then
			return false
		end
		
		if not isvalid(item[itemId]) then
			return false
		else
			local category = _ItemDataLogic:GetItemCategory(itemId) 
			
			if category == "consume" or category == "etc" then
				return true
			else
				return false
			end
		end
		
	end

	method string IsAlreadyHaveUsableOrEtcItem(string userId, string itemId)
		-- 이미 보유 중인 사용 가능 아이템 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local storage = playerEntity.PlayerStorageComponent.storage
		
		
		if not isvalid(playerEntity) then
			return ""
		end
		
		for key, value in pairs(storage) do
			if value.originalId == itemId and value.count < playerEntity.PlayerStorageComponent.maxCount then
				return key
			end
		end
		
		return ""
	end

	method boolean IsEnoughConsumeSlot(string userId, integer needSlot)
		-- 소모품 인벤토리 슬롯이 충분한지 확인
