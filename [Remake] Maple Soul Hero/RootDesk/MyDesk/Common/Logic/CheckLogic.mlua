	method boolean IsSoulDust(string id)
		-- 아이템이 소울 더스트인지 확인
		local splits = _UtilLogic:Split(id, "_")
		
		if splits[1] == "9" then
			for i = 1, 15 do
				if tonumber(splits[2]) == i then
					return true
				end
			end
		end
		
		return false
	end

	method boolean IsCanGetLimitLandWaveReward(string userId, integer wave)
		-- 리미트 랜드 웨이브 보상 수령 가능한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) or wave % 5 ~= 0 then
			return false
		end
		
		local playerInfo = playerEntity.PlayerInfoComponent
		local currentSeasonWeek = _LocalTimeLogic:GetCurrentSeasonWeek()
		
		if currentSeasonWeek ~= playerInfo.playerInfo.recordedBestLimitLandWeek then 
			return true
		else
			local rewardedNum = playerInfo.playerInfo.limitLandRewardedNum
			local rewardedWave = rewardedNum * 5
		
			
			if rewardedWave < wave then
				return true
			else
				return false
			end
		end
		
	end

