	method boolean IsEnoughPetSlot(string userId, integer needSlot)
		-- 펫 인벤토리 슬롯이 충분한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		local playerPetStorage = playerEntity.PlayerPetStorageComponent
		local playerInfo = playerEntity.PlayerInfoComponent.playerInfo
		local count = playerPetStorage:GetAllPetCount()
		
		if count + needSlot <= _GameConfig:GetConfig().LIMIT_PETSLOT + playerInfo.petStorageSlot then
			return true
		else
			return false
		end
	end

	method boolean IsCanRemoveItemById(string userId, string itemId, integer count)
		-- 아이템 ID로 제거 가능한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		local playerStorage = playerEntity.PlayerStorageComponent
		local storage = playerStorage.storage
		
		local myCount = 0
		
		for key, value in pairs(storage) do
			if value.originalId == itemId then
				myCount += value.count
			end
		end
		
		if count >= myCount then
			return true
		else
			return false
		end
	end

	method boolean IsCanRemoveItemByUniqueKey(string userId, string uniqueKey)
		-- 고유 키로 아이템 제거 가능한지 확인
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		
		if not isvalid(playerEntity) then
			
			return false
		end
		
		local playerStorage = playerEntity.PlayerStorageComponent
		local storage = playerStorage.storage
		
		
		if isvalid(storage[uniqueKey]) and storage[uniqueKey].count > 0 then
			return true
		else
			return false
		end
	end

	method boolean IsCanRemovePetByUniqueKey(string userId, string uniqueKey)
