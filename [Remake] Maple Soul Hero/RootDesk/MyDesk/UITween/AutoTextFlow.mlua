@Component
script AutoTextFlow extends Component

	property UITransformComponent uiTransform = nil

	property number textFlowSpeed = 50

	property number textFlowWidth = 330

	property TextComponent childText = nil

	property TextComponent text = nil

	property boolean inited = false

	property UITransformComponent parentUITransform = nil

	property number threshold = 75

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시작
		self:Init()
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 텍스트를 좌측으로 이동시켜 흐르는 효과 구현
		self.uiTransform.anchoredPosition.x = self.uiTransform.anchoredPosition.x - delta * self.textFlowSpeed
		if self.uiTransform.anchoredPosition.x < -self.textFlowWidth then
			self.uiTransform.anchoredPosition.x = self.textFlowWidth + self.threshold
		end
	end

	method void Refresh()
		-- 텍스트 길이에 따라 흐름 효과 활성화 여부 결정
		if self.inited == false then
			self:Init()
		end
		local text = self.text.Text
		self.childText.Text = text
		self.textFlowWidth = self.childText:GetPreferredWidth(text)
		
		if (self.parentUITransform.RectSize.x - self.threshold) > self.textFlowWidth then
			self.Enable = false
			self.childText.Enable = false
			self.text.Enable = true
		else
			self.Enable = true
			self.childText.Enable = true
			self.text.Enable = false
		end
	end

	method void Init()
		-- 텍스트 흐름 효과를 위한 자식 텍스트 엔티티 생성 및 설정
		if self.inited then
			return
		end
		self.inited = true
		self.parentUITransform = self.Entity.UITransformComponent
		
		local child = _SpawnService:SpawnByModelId("model://uitext","text_flow",Vector3.zero,self.Entity)
		local childText = child.TextComponent
		self.childText = childText
		
		
		child.SpriteGUIRendererComponent.Enable = false
		
		self.uiTransform = child.UITransformComponent
		
		local text = self.Entity.TextComponent
		self.text = text
		childText.Text = text.Text
		childText.Bold = text.Bold
		childText.FontSize = text.FontSize
		childText.UseOutLine = text.UseOutLine
		childText.OutlineColor = text.OutlineColor
		childText.OutlineWidth = text.OutlineWidth
		childText.DropShadow = text.DropShadow
		childText.DropShadowAngle = text.DropShadowAngle
		childText.DropShadowColor = text.DropShadowColor
		childText.DropShadowDistance = text.DropShadowDistance
		childText.FontColor = text.FontColor
		childText.Alignment = text.Alignment
		childText.SizeFit = true
		text.Enable = false
		
		self:Refresh()
		
	end

end