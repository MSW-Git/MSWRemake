@Logic
script LocalizeLogic extends Logic

	method string GetItemName(string itemId)
		-- 아이템 ID로 현지화된 아이템 이름 반환
		local result = ""
		
		if isvalid(_ItemDataLogic.itemData[itemId]) then
			result = self:GetText(string.format("itemName_%s", itemId))
			
			if _UtilLogic:Contains(result, "itemName_") then
				result = self:GetText("itemName_")..itemId 
			end
		end
		
		return result
	end

	method string GetItemDesc(string itemId)
		-- 아이템 ID로 현지화된 아이템 설명 반환
		local result = ""
		
		if isvalid(_ItemDataLogic.itemData[itemId]) then
			result = self:GetText(string.format("itemDesc_%s", itemId))
			
			if _UtilLogic:Contains(result, "itemDesc_") then
				result = self:GetText("itemDesc_")..itemId 
			end
		end
		
		return result
	end

	method string GetText(string key)
		-- 키로 현지화 텍스트 반환
		local result = ""
		
		if not _UtilLogic:IsNilorEmptyString(_LocalizationService:GetText(key)) then
			result = _LocalizationService:GetText(key)
		end
		
		return result
	end

	method string GetMonsterName(string monsterId)
		-- 몬스터 ID로 현지화된 몬스터 이름 반환
		local result = ""
		
		if isvalid(_MonsterLogic.monsterData[monsterId]) then
			result = self:GetText(monsterId)
		end
		
		return result
	end

	method string GetBuffName(string buffId)
		-- 버프 ID로 현지화된 버프 이름 반환
		local result = ""
		local buffData = _BuffLogic.buffTable[buffId]
		
		if isvalid(buffData) then
			if buffData.level > 1 then
				for key, value in pairs(_BuffLogic.buffTable) do
					if value.name == buffData.name and value.level == 1 then
						result = self:GetText(string.format("Buff_%s_Name", key))
						
						break
					end
				end
			else
				result = self:GetText(string.format("Buff_%s_Name", buffId))
			end
		end
		
		return result
	end

	method string GetBuffDesc(string buffId)
		-- 버프 ID로 현지화된 버프 설명 반환
