	method string GetChapterName(string chapterId)
		-- 챕터 ID로 현지화된 챕터 이름 반환
		if chapterId == "1" then
			return self:GetText("confirmPopup5")
		elseif chapterId == "2" then
			return self:GetText("confirmPopup6")
		elseif chapterId == "3" then
			return self:GetText("confirmPopup7")
		elseif chapterId == "4" then
			return self:GetText("confirmPopup8")
		elseif chapterId == "5" then
			return self:GetText("confirmPopup9")
		elseif chapterId == "6" then
			return self:GetText("confirmPopup10")
		elseif chapterId == "7" then
			return self:GetText("confirmPopup11")
		elseif chapterId == "8" then
			return self:GetText("confirmPopup12")
		end
	end

	method string GetBarricadeName(integer typeId)
		-- 바리케이드 타입 ID로 현지화된 이름 반환
		local result = ""
		
		if isvalid( _MultiMapDataLogic.barricadeData[typeId]) then
			typeId = tostring(math.floor(typeId))
			result = self:GetText(string.format("barricadeData_Name%s", typeId))
		end
		
		return result
	end

	method string GetCharacteristicName(string type, integer level)
		-- 특성 타입과 레벨로 현지화된 특성 이름 반환
		local text = ""
		
		if type == "WeaponType" then
			if level == 1 then
				text = self:GetText("dateSet_CharacteristicData_skillName1")
			elseif level == 2 then
				text = self:GetText("dateSet_CharacteristicData_skillName2")
			elseif level == 3 then
				text = self:GetText("dateSet_CharacteristicData_skillName3")
			end
		elseif type == "LaboratoryType" then
			if level == 1 then
				text = self:GetText("dateSet_CharacteristicData_skillName4")
			elseif level == 2 then
				text = self:GetText("dateSet_CharacteristicData_skillName5")
			elseif level == 3 then
				text = self:GetText("dateSet_CharacteristicData_skillName6")
			end
		elseif type == "PhysicsType"  then
			if level == 1 then
				text = self:GetText("dateSet_CharacteristicData_skillName7")
			elseif level == 2 then
				text = self:GetText("dateSet_CharacteristicData_skillName8")
			elseif level == 3 then
				text = self:GetText("dateSet_CharacteristicData_skillName9")
			elseif level == 4 then
				text = self:GetText("dateSet_CharacteristicData_skillName10")
			end
		elseif type == "RelicType" then
			if level == 1 then
				text = self:GetText("dateSet_CharacteristicData_skillName11")
			elseif level == 2 then
				text = self:GetText("dateSet_CharacteristicData_skillName12")
			elseif level == 3 then
				text = self:GetText("dateSet_CharacteristicData_skillName13")
			end
		elseif type == "PetType" then
			if level == 1 then
				text = self:GetText("dateSet_CharacteristicData_skillName14")
			elseif level == 2 then
				text = self:GetText("dateSet_CharacteristicData_skillName15")
			end
		end
		
		return text
	end

	method string GetCharacteristicDesc(string type, integer level)
		-- 특성 타입과 레벨로 현지화된 특성 설명 반환
		
