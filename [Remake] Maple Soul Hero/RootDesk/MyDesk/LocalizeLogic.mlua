			elseif level == 2 then
				text = self:GetText("dateSet_CharacteristicData_skillDesc_8")
			elseif level == 3 then
				text = self:GetText("dateSet_CharacteristicData_skillDesc_9")
			elseif level == 4 then
				text = self:GetText("dateSet_CharacteristicData_skillDesc_10")
			end
		elseif type == "RelicType" then
			if level == 1 then
