@Component
script DemonSwordSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 5

	property number damageRate = 1.5

	property number timer = 0

	method void BuffOn()
		-- 악마 검 특수 버프 활성화 및 검 폭탄 생성 시작
		__base:BuffOn()
		
		_SpecialBuffLogic.swordTable[#_SpecialBuffLogic.swordTable + 1] = self.Entity.BattleGunObject
		if #_SpecialBuffLogic.swordTable == 1 then
			self:SwordBombSpawn()
		end
		
	end

	method void SwordBombSpawn()
		-- 검 폭탄 반복 생성 및 폭발 효과 처리
		local swordSpawn = function()
			
			if not isvalid(self) then return end
			
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
		
			for i=1,#_SpecialBuffLogic.swordTable do
				if isvalid(_SpecialBuffLogic.swordTable[i]) then
					criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.swordTable[i]:CalculateCriticalDamage())
					criticalRate = math.max(criticalRate,_SpecialBuffLogic.swordTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
					damage += _SpecialBuffLogic.swordTable[i]:CalculateDamage() * self.damageRate
				end
			end
			
			local pos = _UserService.LocalPlayer.TransformComponent.Position+Vector3(-0.25,-0.7,0)
			
			local effect = _PoolingLogic:SpawnModel("model://461f71a8-dfa3-440f-884b-84c94e4b969d",pos,self.Entity.CurrentMap)
			local skillEffect = effect.SkillEffectObject
			
			skillEffect:Init(damage, true,"sword", "")
			skillEffect.criticalRate = criticalRate
			skillEffect.criticalDamage = criticalDamage
			
			_SoundService:PlaySound("8cd6dfacc24f4f0cb6ad14fe547c8668", _SoundLogic.effectRatio)
			
			local explode = function()
				if isvalid(self) == false then return end
				local effect2 = _PoolingLogic:SpawnModel("model://c255a755-31ba-44ef-90b9-3ab09c864986",pos,self.Entity.CurrentMap)
				local skillEffect2 = effect2.SkillEffectObject
		
				skillEffect2:Init(damage, true,"sword", "")
				skillEffect2.criticalRate = criticalRate
				skillEffect2.criticalDamage = criticalDamage
			end
			_TimerLogic:SetTimerOnce(explode,1, "DemonSwordSpecialBuff.SwordBombSpawn_explode")
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(swordSpawn,self.cooltime,_UtilLogic:RandomDouble()*self.cooltime, "DemonSwordSpecialBuff.SwordBombSpawn")
	end

	method void BuffOnForField(number mode)
		-- 필드에서 악마 검 특수 버프 활성화 처리
		__base:BuffOnForField(mode)
		
		
		if mode == 1 then
			_SpecialBuffLogic.swordTable = {}
			
		
		elseif mode == 2 then
			_SpecialBuffLogic.swordTable[#_SpecialBuffLogic.swordTable + 1] = self.Entity.BattleGunObject
			
		
		elseif mode == 3 then
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			local uniqueKey = "["
		
			for i=1,#_SpecialBuffLogic.swordTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.swordTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.swordTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.swordTable[i]:CalculateDamage() * self.damageRate
				if i == #_SpecialBuffLogic.swordTable then
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.swordTable[i].uniqueKey.."\""
				else
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.swordTable[i].uniqueKey.."\","
				end
			end
			uniqueKey = uniqueKey.."]"
			
			local pos = _UserService.LocalPlayer.TransformComponent.Position+Vector3(-0.25,-0.7,0)
			
			local effect = _PoolingLogic:SpawnModel("model://461f71a8-dfa3-440f-884b-84c94e4b969d",pos,self.Entity.CurrentMap)
			local skillEffect = effect.SkillEffectObject
			
			skillEffect:Init(damage, true,uniqueKey, "")
			skillEffect.criticalRate = criticalRate
			skillEffect.criticalDamage = criticalDamage
			
			_SoundService:PlaySound("8cd6dfacc24f4f0cb6ad14fe547c8668", _SoundLogic.effectRatio)
			
			local explode = function()
				if isvalid(self) == false then return end
				local effect2 = _PoolingLogic:SpawnModel("model://c255a755-31ba-44ef-90b9-3ab09c864986",pos,self.Entity.CurrentMap)
				local skillEffect2 = effect2.SkillEffectObject
		
				skillEffect2:Init(damage, true,uniqueKey, "")
				skillEffect2.criticalRate = criticalRate
				skillEffect2.criticalDamage = criticalDamage
			end
			_TimerService:SetTimerOnce(explode,1)
		end
	end

end