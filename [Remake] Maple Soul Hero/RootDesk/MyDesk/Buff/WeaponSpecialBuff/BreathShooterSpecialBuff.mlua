@Component
script BreathShooterSpecialBuff extends WeaponSpecialBuff

	property number cooltime = 6

	property number damageRate = 1.5

	property number timer = 0

	property table posTable = {{Vector3(1.5,0,0)},{Vector3(1.5,1,0),Vector3(1.5,-1,0)},{Vector3(1.5,2,0),Vector3(2,0,0),Vector3(1.5,-2,0)},{Vector3(1.5,1,0),Vector3(1.5,-1,0),Vector3(-1.5,1,0),Vector3(-1.5,-1,0)},{Vector3(1.5,2,0),Vector3(2,0,0),Vector3(1.5,-2,0),Vector3(-1.5,1,0),Vector3(-1.5,-1,0)},{Vector3(1.5,2,0),Vector3(2,0,0),Vector3(1.5,-2,0),Vector3(-1.5,2,0),Vector3(-2,0,0),Vector3(-1.5,-2,0)}}

	method void BuffOn()
		-- 브레스 슈터 특수 버프 활성화 및 드래곤 소환 시작
		__base:BuffOn()
		
		_SpecialBuffLogic.breathShooterTable[#_SpecialBuffLogic.breathShooterTable + 1] = self.Entity.BattleGunObject
		if #_SpecialBuffLogic.breathShooterTable == 1 then
			self:SpawnDragon()
		end
		
	end

	method void SpawnDragon()
		-- 드래곤 소환 및 브레스 공격 실행
		local shoot = function()
			
			if not isvalid(self) then return end
			
			local lookDirMinus = -_UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local currentPosTable = self.posTable[#_SpecialBuffLogic.breathShooterTable]
			
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			for i=1,#_SpecialBuffLogic.breathShooterTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.breathShooterTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.breathShooterTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.breathShooterTable[i]:CalculateDamage() * self.damageRate
			end
			
			for count = 1, #_SpecialBuffLogic.breathShooterTable do
				local pos = _UserService.LocalPlayer.TransformComponent.Position + Vector3(currentPosTable[count].x*lookDirMinus,currentPosTable[count].y,0)
				
				local effect = _PoolingLogic:SpawnModel("model://272f8271-6846-4ded-8185-2de56247c8d0",pos,self.Entity.CurrentMap)
				local skillEffect = effect.SkillEffectObject
				
				local temp = effect.SpriteRendererComponent.SpriteRUID
				effect.SpriteRendererComponent.SpriteRUID = ""
				effect.SpriteRendererComponent.SpriteRUID = temp
				
				skillEffect:Init(damage, true,"breathShooter", "")
				local dir = 1
				if currentPosTable[count].x < 0 then
					dir = -1
				end
				skillEffect:SetAngle(90-dir*lookDirMinus*90,false)
				skillEffect.criticalRate = criticalRate
				skillEffect.criticalDamage = criticalDamage
				if count == 1 then
					_SoundService:PlaySound("0f377670c1a345779d9ef7ed87fffce5", _SoundLogic.effectRatio)
				end
				
				local breathSpawn = function()
					if isvalid(self) == false then return end
				
					local effect2 = _PoolingLogic:SpawnModel("model://3de21d8c-69ab-446f-94f2-ecdc292993bf",pos,self.Entity.CurrentMap)
					local skillEffect2 = effect2.SkillEffectObject
				
					skillEffect2:Init(damage, true,"breathShooter", "")
					skillEffect2:SetAngle(90-dir*lookDirMinus*90,false)
					skillEffect2.criticalRate = criticalRate
					skillEffect2.criticalDamage = criticalDamage
				end
				_TimerLogic:SetTimerOnce(breathSpawn,0.6, "BreathShooterSpecialBuff.SpawnDragon_breathSpawn")
			end
		end
		
		self.timer = _TimerLogic:SetTimerRepeat(shoot,self.cooltime,_UtilLogic:RandomDouble()*self.cooltime, "BreathShooterSpecialBuff.SpawnDragon_shoot")
	end

	method void BuffOnForField(number mode)
		-- 멀티 필드 모드에서 브레스 슈터 특수 버프 처리
		__base:BuffOnForField(mode)
		
		
		if mode == 1 then
			_SpecialBuffLogic.breathShooterTable = {}
			
		
		elseif mode == 2 then
			_SpecialBuffLogic.breathShooterTable[#_SpecialBuffLogic.breathShooterTable + 1] = self.Entity.BattleGunObject
			
		
		elseif mode == 3 then
			local lookDirMinus = -_UserService.LocalPlayer.PlayerControllerComponent.LookDirectionX
			local currentPosTable = self.posTable[#_SpecialBuffLogic.breathShooterTable]
			
			local damage = 0
			local criticalDamage = 0
			local criticalRate = 0
			local uniqueKey = "["
			for i=1,#_SpecialBuffLogic.breathShooterTable do
				criticalDamage = math.max(criticalDamage,_SpecialBuffLogic.breathShooterTable[i]:CalculateCriticalDamage())
				criticalRate = math.max(criticalRate,_SpecialBuffLogic.breathShooterTable[i].weaponSpec.criticalRate + _BuffLogic:GetCriticalPercent())
				damage += _SpecialBuffLogic.breathShooterTable[i]:CalculateDamage() * self.damageRate
				if i == #_SpecialBuffLogic.breathShooterTable then
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.breathShooterTable[i].uniqueKey.."\""
				else
					uniqueKey = uniqueKey.."\"".._SpecialBuffLogic.breathShooterTable[i].uniqueKey.."\","
				end
			end
			uniqueKey = uniqueKey.."]"
			
			for count = 1, #_SpecialBuffLogic.breathShooterTable do
				local pos = _UserService.LocalPlayer.TransformComponent.Position + Vector3(currentPosTable[count].x*lookDirMinus,currentPosTable[count].y,0)
				
				local effect = _PoolingLogic:SpawnModel("model://272f8271-6846-4ded-8185-2de56247c8d0",pos,self.Entity.CurrentMap)
				local skillEffect = effect.SkillEffectObject
				
				local temp = effect.SpriteRendererComponent.SpriteRUID
				effect.SpriteRendererComponent.SpriteRUID = ""
				effect.SpriteRendererComponent.SpriteRUID = temp
				
				skillEffect:Init(damage, true,uniqueKey, "")
				local dir = 1
				if currentPosTable[count].x < 0 then
					dir = -1
				end
				skillEffect:SetAngle(90-dir*lookDirMinus*90,false)
				skillEffect.criticalRate = criticalRate
				skillEffect.criticalDamage = criticalDamage
				if count == 1 then
					_SoundService:PlaySound("0f377670c1a345779d9ef7ed87fffce5", _SoundLogic.effectRatio)
				end
				
				local breathSpawn = function()
					if isvalid(self) == false then return end
				
					local effect2 = _PoolingLogic:SpawnModel("model://3de21d8c-69ab-446f-94f2-ecdc292993bf",pos,self.Entity.CurrentMap)
					local skillEffect2 = effect2.SkillEffectObject
				
					skillEffect2:Init(damage, true,uniqueKey, "")
					skillEffect2:SetAngle(90-dir*lookDirMinus*90,false)
					skillEffect2.criticalRate = criticalRate
					skillEffect2.criticalDamage = criticalDamage
				end
				_TimerService:SetTimerOnce(breathSpawn,0.6)
			end
		end
	end

end