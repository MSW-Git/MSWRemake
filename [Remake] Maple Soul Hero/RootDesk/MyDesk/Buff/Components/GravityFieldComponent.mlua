@Component
script GravityFieldComponent extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 중력장 진입 이벤트 처리 (몰스터 속도 감소)
		
		local monster = event.TriggerBodyEntity.MonsterObject
		
		if not isvalid(monster) or monster.isBoss then return end
		monster:ApplySpeedFactorByKey("PlayerGravityField", 0.333)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 중력장 탈출 이벤트 처리 (몰스터 속도 정상화)
		
		local monster = event.TriggerBodyEntity.MonsterObject
		
		if not isvalid(monster) or monster.isBoss then return end
		monster:ApplySpeedFactorByKey("PlayerGravityField", 1)
	end

end