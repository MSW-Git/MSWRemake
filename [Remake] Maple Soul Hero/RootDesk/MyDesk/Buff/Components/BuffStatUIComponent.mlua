	@ExecSpace("ClientOnly")
	method void SetHealthText()
		-- 체력 버프 수치를 UI에 표시
		local plusSign = self:GetPlusMinusSign(_BuffLogic.appliedBuff.maxHp)
		local plusColor = self:GetPlusMinusColor(plusSign,false)
		self.healthSlot:GetChildByName("StatText").TextComponent.FontColor = plusColor
		self.healthSlot:GetChildByName("StatText").TextComponent.Text = string.format(plusSign.."%.1f%%", _BuffLogic.appliedBuff.maxHp * 100)
	end

	@ExecSpace("ClientOnly")
	method void SetAttackText()
		-- 공격력 버프 수치를 UI에 표시
		local plusSign = self:GetPlusMinusSign(_BuffLogic:GetTotalDamage() * 100 - 100)
		local plusColor = self:GetPlusMinusColor(plusSign,false)
		self.attackSlot:GetChildByName("StatText").TextComponent.FontColor = plusColor
		self.attackSlot:GetChildByName("StatText").TextComponent.Text = string.format("%.1f%%", _BuffLogic:GetTotalDamage() * 100)
		
		
	end

