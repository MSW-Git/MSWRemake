		-- 모든 스탯 UI 텍스트를 초기값으로 설정
		self.healthSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.recoverySlot:GetChildByName("StatText").TextComponent.Text = "0"
		self.absorbSlot:GetChildByName("StatText").TextComponent.Text = "0"
		self.attackSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.meleeAttackSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.rangeAttackSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.criPercentSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.criDamageSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.attackSpeedSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.evadeSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.rangeSlot:GetChildByName("StatText").TextComponent.Text = "0%"
		self.speedSlot:GetChildByName("StatText").TextComponent.Text = "0%"
