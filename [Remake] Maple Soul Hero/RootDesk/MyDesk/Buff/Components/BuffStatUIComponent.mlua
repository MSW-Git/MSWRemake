	@ExecSpace("ClientOnly")
	method void RefreshAllText()
		-- 모든 스탯 UI 텍스트를 갱신
		self:SetHealthText()
		self:SetSpeedText()
		self:SetAttackText()
		self:SetExpText()
		self:SetEvadeText()
		self:SetRangeText()
		self:SetAttackSpeedText()
		self:SetHpRecoveryText()
		self:SetAbsorptionText()
		self:SetPhysicalDamageText()
		self:SetMagicalDamageText()
		self:SetCriticalPercentText()
		self:SetEngineeringText()
		self:SetCriticalDamageText()
		self:SetAttackSpeedText()
		self:SetSpeedText()
		self:SetHitDamageText()
		self:SetBossDamageText()
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 슬롯 엔티티 연결
		local contentPanel = self.Entity:GetChildByName("ContentPanel")
		
		self.healthSlot = contentPanel:GetChildByName("HealthSlot")
		self.recoverySlot = contentPanel:GetChildByName("RecoverySlot")
		self.absorbSlot = contentPanel:GetChildByName("AbsorbSlot")
		self.attackSlot = contentPanel:GetChildByName("AttackSlot")
		self.meleeAttackSlot = contentPanel:GetChildByName("PhysicalAttackSlot")
		self.rangeAttackSlot = contentPanel:GetChildByName("MagicalAttackSlot")
		self.criPercentSlot = contentPanel:GetChildByName("CriPercentSlot")
		self.criDamageSlot = contentPanel:GetChildByName("CriDamageSlot")
		self.attackSpeedSlot = contentPanel:GetChildByName("AttackSpeedSlot")
		self.evadeSlot = contentPanel:GetChildByName("EvadeSlot")
		self.rangeSlot = contentPanel:GetChildByName("RangeSlot")
		self.speedSlot = contentPanel:GetChildByName("SpeedSlot")
		self.engineeringSlot = contentPanel:GetChildByName("EngiineeringSlot")
		self.expSlot = contentPanel:GetChildByName("ExpSlot")
		self.hitDamageSlot = contentPanel:GetChildByName("HitDamageSlot")
		self.bossDamageSlot = contentPanel:GetChildByName("BossDamageSlot")
	end

	@ExecSpace("Client")
	method string GetPlusMinusSign(number target)
		-- 수치에 따른 부호 문자열 반환 (양수면 +, 음수면 빈 문자열)
		if target < 0 then
			return ""
		else
			return "+"
		end
	end

	@ExecSpace("Client")
	method Color GetPlusMinusColor(string sign, boolean reverted)
		-- 부호에 따른 색상 반환 (일반/역전 모드 지원)
		if reverted == false then
			if sign == "+" then
				return Color.FromHexCode("#B5FA4D")
			elseif sign == "" then
				return Color.FromHexCode("#FF6868")
			end
		else
			if sign == "" then
				return Color.FromHexCode("#B5FA4D")
			elseif sign == "+" then
				return Color.FromHexCode("#FF6868")
			end
		end	
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "BuffLogic")
	handler HandleApplyBuffEvent(ApplyBuffEvent event)
		-- 버프 적용 이벤트 처리하여 해당 스탯 UI 갱신
		
		local buffId = event.buffId
		
		local convertedId = tonumber(buffId)
		
		if convertedId >= 100001 and convertedId <= 100003 then 
			self:SetHealthText()
		elseif convertedId >= 100007 and convertedId <= 100009 then 
			self:SetSpeedText()
		elseif convertedId >= 100010 and convertedId <= 100012 then 
			self:SetAttackText()
		elseif convertedId >= 100013 and convertedId <= 100015 then 
			self:SetExpText()
		elseif convertedId >= 100016 and convertedId <= 100018 then 
			self:SetEvadeText()
		elseif convertedId >= 100019 and convertedId <= 100021 then 
			self:SetRangeText()
		elseif convertedId >= 100022 and convertedId <= 100024 then 
			self:SetAttackSpeedText()
		elseif convertedId >= 100025 and convertedId <= 100027 then 
			self:SetHpRecoveryText()
		elseif convertedId >= 100028 and convertedId <= 100030 then 
			self:SetAbsorptionText()
		elseif convertedId >= 100031 and convertedId <= 100033 then 
			self:SetPhysicalDamageText()
		elseif convertedId >= 100034 and convertedId <= 100036 then 
			self:SetMagicalDamageText()
		elseif convertedId >= 100037 and convertedId <= 100039 then 
			self:SetCriticalPercentText()
		elseif convertedId >= 100040 and convertedId <= 100042 then 
			self:SetEngineeringText()
		elseif convertedId >= 100043 and convertedId <= 100045 then 
			self:SetCriticalDamageText()
		elseif convertedId == 100051 then 
			self:SetAttackSpeedText()
			self:SetSpeedText()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleChangeAttackSpeedEvent(ChangeAttackSpeedEvent event)
