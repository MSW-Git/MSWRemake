	property Entity attackSlot = "b83fe449-e89f-4713-a627-0e9544ac16f8"

	property Entity meleeAttackSlot = "abf412e0-5f4b-49c3-9499-a579ef23a4a5"

	property Entity rangeAttackSlot = "f6b60d7f-ba63-430d-bbbf-9074e3ccdf05"

	property Entity criPercentSlot = "06fd4e4c-c37e-417a-8e1c-66de8e674e21"

	property Entity criDamageSlot = "ebf2cec4-5c87-4228-b149-cabd1b9845bd"

	property Entity attackSpeedSlot = "dba85641-813a-4ad5-bc13-7547629354e4"

	property Entity evadeSlot = "3fe973e5-26df-4def-9b0b-4dfa33362347"

