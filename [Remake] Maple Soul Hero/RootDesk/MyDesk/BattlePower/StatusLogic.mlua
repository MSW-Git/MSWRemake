@Logic
script StatusLogic extends Logic

	method number GetGradeToStarCount(string grade)
		-- 등급에 따른 별 개수 반환
		
		if grade == "normal" then
			return 1
		elseif grade == "rare" then
			return 2
		elseif grade == "epic" then
			return 3
		elseif grade == "unique" then
			return 4
		elseif grade == "legendary" then
			return 5
		else
			return 0
		end
	end

end