@Component
script ExtendScrollLayoutGroupComponent extends ScrollLayoutGroupComponent

	property boolean controlSizeWidth = false

	property boolean controlSizeHeight = false

	property boolean forceExpandWidth = false

	property boolean forceExpandHeight = false

	method void Refresh()
		-- 레이아웃 그룹의 자식 요소들을 크기에 맞게 자동 조정
		local rect = self.Entity.UITransformComponent
		if self.controlSizeWidth and self.forceExpandWidth then
		    local childCnt = self.Type == LayoutGroupType.Horizontal and self:GetChildCountOnlyEnable() or 1
		
		    if childCnt > 0 then
		        local totalMinWidth = 0
				local extraChildCnt = 0
				local defaultWidth = rect.RectSize.x / childCnt
		        for k, v in pairs(self.Entity.Children) do
		            if v.EnabledInHierarchy then
		                local layout = v.LayoutElement
		                if layout and layout.usingMinWidth and layout.minWidth > defaultWidth then
		                    totalMinWidth = totalMinWidth + layout.minWidth
							extraChildCnt += 1
		                end
		            end
		        end
		
		        local remainingSpace = rect.RectSize.x - totalMinWidth
		        local width = remainingSpace / (childCnt - extraChildCnt)
		
		        for k, v in pairs(self.Entity.Children) do
		            if v.EnabledInHierarchy then
		                local layout = v.LayoutElement
		                local eachWidth = layout and layout.usingMinWidth and math.max(layout.minWidth, width) or width
		                v.UITransformComponent.RectSize.x = eachWidth
		
		                remainingSpace = remainingSpace - eachWidth
		
		                if remainingSpace > 0 then
		                    v.UITransformComponent.RectSize.x = v.UITransformComponent.RectSize.x + self.Spacing
		                end
		            end
		        end
		    end
		end
		
		if self.controlSizeHeight and self.forceExpandHeight then
		    local childCnt = self.Type == LayoutGroupType.Vertical and self:GetChildCountOnlyEnable() or 1
		
		    if childCnt > 0 then
		        local totalMinHeight = 0
		        local extraChildCnt = 0
				local defaultHeight = rect.RectSize.y / childCnt
		        for k, v in pairs(self.Entity.Children) do
		            if v.EnabledInHierarchy then
		                local layout = v.LayoutElement
		                   if layout and layout.minHeight and layout.minHeight > defaultHeight then
		                    totalMinHeight = totalMinHeight + layout.minHeight
							extraChildCnt += 1
		                end
		            end
		        end
		        local remainingSpace = rect.RectSize.y - totalMinHeight
		        local height = remainingSpace / (childCnt - extraChildCnt)
		        for k, v in pairs(self.Entity.Children) do
		            if v.EnabledInHierarchy then
		                local layout = v.LayoutElement
		                local eachHeight = layout and layout.usingMinHeight and math.max(layout.minHeight, height) or height
		                v.UITransformComponent.RectSize.y = eachHeight
		
		                remainingSpace = remainingSpace - eachHeight
		
		                if remainingSpace > 0 then
		                    v.UITransformComponent.RectSize.y = v.UITransformComponent.RectSize.y + self.Spacing
		                end
		            end
		        end
		    end
		end
		
	end

	method number GetChildCountOnlyEnable()
		-- 활성화된 자식 요소의 개수를 반환
		local count =0 
		for k,v in pairs(self.Entity.Children) do
			if v.EnabledInHierarchy then
				count += 1
			end
		end
		return count
	end

	@EventSender("Service", "EditorService")
	handler HandleScreenTouchEditorEvent(ScreenTouchEditorEvent event)
		-- 에디터에서 화면 터치 시 레이아웃 새로고침
		
		local TouchPoint = event.TouchPoint
		self:Refresh()
	end

end