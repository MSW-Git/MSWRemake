@Component
script PartyInfoSlotComponent extends Component

	property integer slotNum = 0

	property Entity partyInfoUI = nil

	property integer partyId = 0

	property Entity banButton = nil

	property string memberId = ""

	@ExecSpace("ClientOnly")
	method void SetSlot(integer slotNum, integer partyId)
		-- 파티 정보 슬롯에 멤버 데이터 설정 및 표시
		self.slotNum = slotNum
		self.partyId = partyId
		self:Refresh()
		self:Show()
	end

	@ExecSpace("ClientOnly")
	method void Show()
		-- 슬롯을 표시하고 내용 갱신
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void Hide()
		-- 슬롯을 숨기고 파티 ID 초기화
		self.Entity.Enable = false
		self.partyId = 0
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 파티 멤버 정보를 기반으로 슬롯 UI 내용 갱신
		local partyInfo = self.partyInfoUI.PartyInfoUIComponent
		self.banButton.Enable = false
		self.Entity.Enable = true
		
		if partyInfo.partyId ~= 0 then
			local member = _PartyLogic.partyTable[partyInfo.partyId].member[self.slotNum]
			
			local levelText = self.Entity:GetChildByName("LevelText")
			local levelEmpty = self.Entity:GetChildByName("Level_Empty")
			local nickNameText = self.Entity:GetChildByName("NicknameText")
			local roleText = self.Entity:GetChildByName("RoleText")
			local posText = self.Entity:GetChildByName("PosText")
			local leaderIcon = self.Entity:GetChildByName("icon_leader")
			
			self.Entity.ButtonComponent.Enable = false
			self.Entity.SpriteGUIRendererComponent.RaycastTarget = false
			
			nickNameText.TextComponent.FontColor = Color.FromHexCode("#B5FA4D")
			roleText.TextComponent.FontColor = Color.FromHexCode("#B5FA4D")
			posText.TextComponent.FontColor = Color.FromHexCode("#B5FA4D")
			
			levelText.Enable = true
			levelEmpty.Enable = false
			
			if member ~= "" and isvalid(_PartyLogic.levelTable[member]) then
				
				levelText.TextComponent.Text = string.format("%d", _PartyLogic.levelTable[member])
				nickNameText.TextComponent.Text = _PartyLogic.nicknameTable[member]
				if _PartyLogic.partyTable[partyInfo.partyId].leader == member then
					roleText.TextComponent.Text = _LocalizeLogic:GetText("partyStr4")
					leaderIcon.Enable = true
				else
					roleText.TextComponent.Text = _LocalizeLogic:GetText("partyStr5")
					leaderIcon.Enable = false
					
					if _PartyLogic:IsLeader(_UserService.LocalPlayer.PlayerComponent.UserId, partyInfo.partyId) then 
						self.banButton.Enable = true
					end
				end
				posText.TextComponent.Text = _LocalizeLogic:GetText(_PartyLogic.mapTable[member])
				self.memberId = member
				
				if member ~= _UserService.LocalPlayer.PlayerComponent.UserId then
					self.Entity.ButtonComponent.Enable = true
					self.Entity.SpriteGUIRendererComponent.RaycastTarget = true
		
					nickNameText.TextComponent.FontColor = Color.white
					roleText.TextComponent.FontColor = Color.white
					posText.TextComponent.FontColor = Color.white
				end
			else
				levelText.TextComponent.Text = ""
				nickNameText.TextComponent.Text = ""
				roleText.TextComponent.Text = ""
				posText.TextComponent.Text = ""
				self.memberId = ""
				levelText.Enable = false
				levelEmpty.Enable = true
				leaderIcon.Enable = false
			end
		else
			self.Entity.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 초기화 시 부모 UI 참조 설정 및 추방 버튼 이벤트 연결
		self.partyInfoUI = self.Entity.Parent.Parent
		self.banButton = self.Entity:GetChildByName("BanButton")
		
		self.banButton:ConnectEvent(ButtonClickEvent, function()
			self:RequestBan()
		end)
	end

	@ExecSpace("ClientOnly")
	method void RequestBan()
		-- 파티 멤버 추방 요청 및 확인 팝업 표시
		local partyInfo = self.partyInfoUI.PartyInfoUIComponent
		
		if partyInfo.partyId ~= 0 then
			local member = _PartyLogic.partyTable[partyInfo.partyId].member[self.slotNum]
			
			if member ~= "" then
				_UIPopup:Open(_LocalizeLogic:GetText("popup17"), string.format(_LocalizeLogic:GetText("popup18"), _PartyLogic.nicknameTable[member]), 
					function()
						_PartyLogic:RequestBanMember(partyInfo.partyId, member)
					end, nil)
				
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 슬롯 클릭 시 리더 변경 확인 팝업 표시
		
		local Entity = event.Entity
		local userId = _UserService.LocalPlayer.PlayerComponent.UserId
		
		if _PartyLogic:IsLeader(userId, self.partyId) and userId ~= self.memberId then
			_UIPopup:Open(_LocalizeLogic:GetText("popup15"), string.format(_LocalizeLogic:GetText("popup16"), _PartyLogic.nicknameTable[self.memberId]), function() _PartyLogic:RequestChangeLeader(self.partyId, self.memberId) end, nil)
		end
	end

end