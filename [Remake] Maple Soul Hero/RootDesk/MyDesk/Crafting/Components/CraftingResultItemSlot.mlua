@Component
script CraftingResultItemSlot extends Component

	property string recipeId = ""

	property integer index = 0

	method void Init(string id, integer index)
		-- 제작 결과 아이템 슬롯 초기화 및 제작 가능 상태 표시
		self.recipeId = id
		self.index = index
		
		
		local itemInfo = _CraftingLogic.craftingRecipe[id]
		local itemId = itemInfo.itemId
		
		_CraftingLogic:SetCraftingSlot(self.Entity:GetChildByName("Item_Slot", true), itemId)
		
		self.Entity:GetChildByName("Name_ResultItem", true).TextComponent.Text = _LocalizeLogic:GetItemName(itemId) 
		self.Entity:GetChildByName("EnableCrafting_tag", true):SetEnable(false)
		self.Entity:GetChildByName("SelectedOutline", true).Enable = false
		
		if _CraftingLogic:GetEnableCountCraftingByRecipeId(id, _UserService.LocalPlayer.PlayerComponent.UserId) >= 1 then
			self.Entity:GetChildByName("EnableCrafting_tag", true):SetEnable(true)
		else
			self.Entity:GetChildByName("EnableCrafting_tag", true):SetEnable(false)
		end
		
		if _CraftingLogic.resetItemType == true and index == 1 then
			_CraftingLogic.resetItemType = false
			self:Selected(true)
			self:OnClick()
		end
		
		if _CraftingLogic.selectedResultItemSlotIndex == self.index then
			self:Selected(true)
		else
			self:Selected(false)
		end
	end

	method void Selected(boolean isSelected)
		-- 결과 아이템 슬롯 선택 상태 UI 업데이트
		if isSelected then
			self.Entity:GetChildByName("SelectedOutline", true).Enable = true
		else
			self.Entity:GetChildByName("SelectedOutline", true).Enable = false
		end
	end

	method void OnClick()
		-- 결과 아이템 슬롯 클릭 시 제작 탭 변경
		_CraftingLogic.UICrafting:ChangeItemListTab(self.recipeId)
		_CraftingLogic.selectedResultItemSlotIndex = self.index
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 결과 아이템 슬롯 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		
		if _CraftingLogic.craftingRecipe[self.recipeId] == nil then
			return
		end
		
		self:OnClick()
	end

end