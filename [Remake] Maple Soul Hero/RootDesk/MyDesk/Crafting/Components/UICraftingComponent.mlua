@Component
script UICraftingComponent extends UICommonPopup

	property Entity typeListEntity = "2fd8b714-a035-4e23-8d9b-684803d61ea1"

	property Entity typeOriginalSlot = "ec1d38cd-67ef-4279-85e8-c06622eec787"

	property table typeList = {}

	property Entity resultItemListEntity = "2da3cae2-9c1b-4b8a-b1e7-f41521745463"

	property Entity resultItemOriginalSlot = "1ab1b203-cbdd-4201-bd8f-ff043a26da5e"

	property table resultItemList = {}

	property Entity materialListEntity = "190081d2-ddb7-4970-b737-deda9b7fb8bd"

	property Entity materialOriginalSlot = "84fde95f-b7fd-4ef0-a15a-e3713e4280cb"

	property table materialIdList = {}

	property Entity selectedItemPanel = "803852b2-0343-4542-a664-8b5b0ceaf798"

	property Entity craftingCountEntity = "d33d136a-06f7-4f41-ab25-be167ccbdbc0"

	property Entity categoryOriginalSlot = "f293b078-6c7e-4084-b228-fa747076c05c"

	property Entity button_openCrafting = "ad5adee9-7043-48e1-8b2c-6c470e3b6147"

	property table categoryTabList = {}

	property table resultItemEntityTable = {}

	property table typeEntityTable = {}

	property Entity CraftingSuccessPanel = "c11b6b97-a5a9-43a1-aedb-1c1ecd6dbb21"

	property Entity button_doCrafting = "d874b02d-0673-4562-a62f-7c0a26dd59db"

	property Entity button_minus = "58828a55-d841-4574-ad0f-2a3238edce76"

	property Entity button_minimum = "af9db529-5651-447c-8939-86bdbfc9c172"

	property Entity button_plus = "f26995fd-879d-4e2d-8b65-b61625e168ae"

	property Entity button_maximum = "0d6317ac-b507-4bec-872f-f09c47414c52"

	property Entity targetResultSlot = nil

	property Entity gradeEntity = "b1f7887c-1cf4-4011-8ee0-fd9fb19601cc"

	property Entity effectEntity = "49d2bcf6-cb78-49a5-8d14-1ed169902f21"

	property Entity resultPanel_notAcc = "70781afe-9407-47b0-bec0-044cf7576622"

	property Entity resultPanel_Acc = "64359127-6035-449d-97f0-574237026861"

	method void Init()
		-- 제작 UI 컴포넌트 초기화 및 그리드뷰 설정
		self.button_openCrafting:ConnectEvent(ButtonClickEvent, 
		function() 
			self:Show()
		end)
		
		
		local categoryList = {}
		for key, value in pairs(_CraftingLogic.craftingRecipe) do
			table.insert(categoryList, value.category)
		end
		categoryList = _CraftingLogic:DeleteDuplicateInTable(categoryList)
		table.sort(categoryList)
		
		for i = 1 , #categoryList do
			local clone = self.categoryOriginalSlot:Clone("Crafting_CategorySlot")
			clone.CraftingCategoryTabButton:Init(categoryList[i])
			table.insert(self.categoryTabList, clone)
		end
		
		local gridView = self.typeListEntity.GridViewComponent
		gridView.ItemEntity = self.typeOriginalSlot
		gridView.OnRefresh = function(index, entity)
			entity.CraftingTypeTabButton:Init(self.typeList[index + 1], index + 1)
			table.insert(self.typeEntityTable, entity)
		end
		
		local gridView2 = self.resultItemListEntity.GridViewComponent
		gridView2.ItemEntity = self.resultItemOriginalSlot
		gridView2.OnRefresh = function(index, entity)
			entity.CraftingResultItemSlot:Init(self.resultItemList[index + 1], index + 1)
			table.insert(self.resultItemEntityTable, entity)
		end
		
		
		local gridView3 = self.materialListEntity.GridViewComponent
		gridView3.ItemEntity = self.materialOriginalSlot
		
		gridView3.OnRefresh = function(index, entity)
			entity.CraftingMaterialSlot:Init(self.materialIdList[index + 1].id, self.materialIdList[index + 1].count, index + 1)
		end
	end

	method void ChangeItemCategoryTab(string itemCategory)
		-- 제작 아이템 카테고리 탭 변경 및 타입 목록 업데이트
		_CraftingLogic.resetCategoryType = true
		table.clear(self.typeList)
		_CraftingLogic.selectedCategory = itemCategory
		
		for key, value in pairs(_CraftingLogic.craftingRecipe) do
			if itemCategory == value.category then
				table.insert(self.typeList, value.type)
			end
		end
		
		for i = 1 , #self.categoryTabList do
			if self.categoryTabList[i].CraftingCategoryTabButton.category == itemCategory then
				self.categoryTabList[i].CraftingCategoryTabButton:Selected(true)
			else
				self.categoryTabList[i].CraftingCategoryTabButton:Selected(false)
			end
		end
		
		self.typeList = _CraftingLogic:DeleteDuplicateInTable(self.typeList)
		table.sort(self.typeList)
		
		local gridView = self.typeListEntity.GridViewComponent
		gridView.TotalCount = #self.typeList
		gridView:Refresh(true , true)
		
		self:SetSelectedItemPanel("", false) 
	end

	method void ChangeItemTypeTab(string itemType)
		-- 제작 아이템 타입 탭 변경 및 결과 아이템 목록 업데이트
		_CraftingLogic.resetItemType = true
		table.clear(self.resultItemList)
		
		for key, value in pairs(_CraftingLogic.craftingRecipe) do
			if _CraftingLogic.selectedCategory == value.category then
				if itemType == value.type then
					table.insert(self.resultItemList, value.recipeId)
				end
			end
		end
		
		for i = 1 , #self.typeEntityTable do
			if self.typeEntityTable[i].CraftingTypeTabButton.type == itemType then
				self.typeEntityTable[i].CraftingTypeTabButton:Selected(true)
			else
				self.typeEntityTable[i].CraftingTypeTabButton:Selected(false)
			end
		end
		
		table.sort(self.resultItemList, function(a, b) return a < b end)
		
		local gridView2 = self.resultItemListEntity.GridViewComponent
		gridView2.TotalCount = #self.resultItemList
		gridView2:Refresh(true, true)
		
		
		self:SetSelectedItemPanel("", false) 
	end

	method void ChangeItemListTab(string recipeId)
		-- 제작 레시피 선택 및 재료 목록 업데이트
		
		table.clear(self.materialIdList)
		
		
		for key, value in pairs(_CraftingLogic.craftingRecipe[recipeId].ingredients) do
			local temp = {}
			temp.id = key
			temp.count = value
			table.insert(self.materialIdList, temp)
		end
		
		table.sort(self.materialIdList, function(a, b) 
			
			return a.id < b.id 
		
		end)
		
		for i = 1 , #self.resultItemEntityTable do
			if recipeId == self.resultItemEntityTable[i].CraftingResultItemSlot.recipeId then
				self.resultItemEntityTable[i].CraftingResultItemSlot:Selected(true)
			else
				self.resultItemEntityTable[i].CraftingResultItemSlot:Selected(false)
			end
		end
		
		self:SetSelectedItemPanel(recipeId, true)
		
		local gridView3 = self.materialListEntity.GridViewComponent
		gridView3.TotalCount = #self.materialIdList
		gridView3:Refresh(true, true)
		
		_CraftingLogic:ChangeCraftingCount(true, 0)
		
	end

	method void Show()
		-- 제작 UI 표시 및 기본 카테고리 설정
		if self.Entity.ContentLockComponent:CheckUIAvailable() then
			__base:Show()
			
			_CraftingLogic.selectedCategory = "ingredient"
			self:ChangeItemCategoryTab(_CraftingLogic.selectedCategory)
		end
	end

	method void Hide()
		-- 제작 UI 숨김 및 상태 초기화
		__base:Hide()
		self:SetSelectedItemPanel("", false)
		_CraftingLogic.selectedCategory = ""
	end

	method void SetSelectedItemPanel(string recipeId, boolean switchOn)
		-- 선택된 아이템 정보 패널 표시/숨김 및 설정
		if switchOn == false then
			self.selectedItemPanel.Enable = false
			_CraftingLogic.selectedRecipeId = ""
			return
		end
		
		self.selectedItemPanel.Enable = true
		_CraftingLogic.selectedRecipeId = recipeId
		
		
		self.selectedItemPanel:GetChildByName("Item_Name", true).TextComponent.Text = _LocalizeLogic:GetItemName(_CraftingLogic.craftingRecipe[recipeId].itemId)
		self.selectedItemPanel:GetChildByName("Item_Sort", true).TextComponent.Text = 
		_CraftingLogic:GetCraftingCategoryTextByItemId(_CraftingLogic.craftingRecipe[recipeId].itemId) 
		
		_CraftingLogic:SetCraftingSlot(self.selectedItemPanel:GetChildByName("Item_Slot",true),_CraftingLogic.craftingRecipe[recipeId].itemId)
		self.selectedItemPanel:GetChildByName("Item_Desc_Long", true).TextComponent.Text = _LocalizeLogic:GetItemDesc(_CraftingLogic.craftingRecipe[recipeId].itemId)
		
		
		if _CraftingLogic:GetEnableCountCraftingByRecipeId(recipeId, _UserService.LocalPlayer.PlayerComponent.UserId) < 1 then
			self.button_doCrafting.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29" 
			self.button_doCrafting.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.button_doCrafting.TextComponent.OutlineColor = Color.FromHexCode("#616161")
		else
			self.button_doCrafting.SpriteGUIRendererComponent.ImageRUID = "fc7aab99a8e549e58d891d50f594ecd6"
			self.button_doCrafting.TextComponent.FontColor = Color.FromHexCode("#ffffff")
			self.button_doCrafting.TextComponent.OutlineColor = Color.FromHexCode("#589334")
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 제작 UI 컴포넌트 시작 시 초기화
		
		__base:OnBeginPlay()
		self:Init()
		
	end

	@ExecSpace("Client")
	method void ChangeCraftingCountEvent(integer craftingCount)
		-- 제작 수량 변경 이벤트 및 버튼 상태 업데이트
		
		local enableGetCount = _CraftingLogic:GetEnableCountCraftingByRecipeId(_CraftingLogic.selectedRecipeId, _UserService.LocalPlayer.PlayerComponent.UserId)
		local countOverOne = {false, "5e6ddfb6e9314f5c9c4f57fd576c94a2", "#d1d1d1", "#616161"} 
		if craftingCount > 1 then 
			countOverOne = {true, "7dc0a010da0a48539e4a9aa69184afc9", "#ffffff", ""}
		end
		self.button_minus.ButtonComponent.Enable = countOverOne[1]
		self.button_minimum.ButtonComponent.Enable = countOverOne[1]
		
		self.button_minus.SpriteGUIRendererComponent.ImageRUID = countOverOne[2]
		self.button_minimum.SpriteGUIRendererComponent.ImageRUID = countOverOne[2]
		
		self.button_minus:GetChildByName("Icon").SpriteGUIRendererComponent.Color = Color.FromHexCode(countOverOne[3])
		self.button_minimum.TextComponent.FontColor = Color.FromHexCode(countOverOne[3])
		
		
		local enableCrafting = {false, "5e6ddfb6e9314f5c9c4f57fd576c94a2", "#d1d1d1", "#616161"}
		if enableGetCount >= 1 then
			enableCrafting = {true, "7dc0a010da0a48539e4a9aa69184afc9", "#ffffff", ""}
		end
		self.button_plus.ButtonComponent.Enable = enableCrafting[1]
		self.button_maximum.ButtonComponent.Enable = enableCrafting[1]
		
		self.button_plus.SpriteGUIRendererComponent.ImageRUID = enableCrafting[2]
		self.button_maximum.SpriteGUIRendererComponent.ImageRUID = enableCrafting[2]
		
		self.button_plus:GetChildByName("Icon").SpriteGUIRendererComponent.Color = Color.FromHexCode(enableCrafting[3])
		self.button_maximum.TextComponent.FontColor = Color.FromHexCode(enableCrafting[3])
		
		if craftingCount >= enableGetCount then
			self.button_plus.ButtonComponent.Enable = false
			self.button_plus.SpriteGUIRendererComponent.ImageRUID = "5e6ddfb6e9314f5c9c4f57fd576c94a2"
			self.button_plus:GetChildByName("Icon").SpriteGUIRendererComponent.Color = Color.FromHexCode("#d1d1d1")
			
			self.button_maximum.ButtonComponent.Enable = false
			self.button_maximum.SpriteGUIRendererComponent.ImageRUID ="5e6ddfb6e9314f5c9c4f57fd576c94a2"
			self.button_maximum.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
		end
		
		self.craftingCountEntity.TextComponent.Text = string.format("%d", craftingCount)
		
		
		
		local gridView3 = self.materialListEntity
		
		for i = 1 , #gridView3.Children do
			if gridView3.Children[i].CraftingMaterialSlot.index > 0 then
				gridView3.Children[i].CraftingMaterialSlot:ChangeCount()
			end
		end
		
		
	end

	method void ShowCraftingResult(string itemId, integer count, string grade, boolean isAccessory, table resultTable)
		-- 제작 결과 팝업 표시 및 액세서리 등급별 결과 설정
		
		self.resultPanel_Acc.Enable = isAccessory
		self.resultPanel_notAcc.Enable = not isAccessory
		
		if isAccessory == true then
			
			local slotTable = {}
			slotTable["B"] =  self.CraftingSuccessPanel:GetChildByName("Item_Slot_B",true)
			slotTable["A"] =  self.CraftingSuccessPanel:GetChildByName("Item_Slot_A",true)
			slotTable["S"] =  self.CraftingSuccessPanel:GetChildByName("Item_Slot_S",true)
			slotTable["SS"] =  self.CraftingSuccessPanel:GetChildByName("Item_Slot_SS",true)
			slotTable["SSS"] =  self.CraftingSuccessPanel:GetChildByName("Item_Slot_SSS",true)
			
			for k , v in pairs(slotTable) do
				v.Enable = false
			end
			
			if not _UtilLogic:IsNilorEmptyString(grade) then
				for k , v in pairs(resultTable) do
					if v >= 1 then 
						_CraftingLogic:SetCraftingSlot(slotTable[k]:GetChildByName("Item_Slot", true), itemId) 
						_CraftingLogic:SetResultGrade(k, slotTable[k])
						slotTable[k]:GetChildByName("itemName", true).TextComponent.Text = _LocalizeLogic:GetItemName(itemId) 
						slotTable[k]:GetChildByName("itemCount", true).TextComponent.Text = string.format("X %d", v)
					end
				end		
			end	
		
			self.CraftingSuccessPanel.CraftingResultShowPopup:Open(grade)
		
		else
			_CraftingLogic:SetCraftingSlot(self.CraftingSuccessPanel:GetChildByName("Item_Slot", true), itemId) 
			self.CraftingSuccessPanel:GetChildByName("item_Slot_notAcc",true):GetChildByName("itemName",true).TextComponent.Text = _LocalizeLogic:GetItemName(itemId) 
			self.CraftingSuccessPanel:GetChildByName("item_Slot_notAcc",true):GetChildByName("itemCount",true).TextComponent.Text = string.format("X %d", count)
			self.CraftingSuccessPanel.CraftingResultShowPopup:Open(grade)
			self.gradeEntity.Enable = false	
		end
		
	end

	method void RefresuResultItemEntity()
		-- 결과 아이템 엔티티 새로고침 및 선택 패널 업데이트
		for i = 1 , #self.resultItemEntityTable do
			self.resultItemEntityTable[i].CraftingResultItemSlot:Init(self.resultItemEntityTable[i].CraftingResultItemSlot.recipeId, self.resultItemEntityTable[i].CraftingResultItemSlot.index)
		end
		self:SetSelectedItemPanel(_CraftingLogic.selectedRecipeId, true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f87179c0-06e8-4607-acf4-5e92b24c189a")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 제작 UI 닫기 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		self:Hide()
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "d874b02d-0673-4562-a62f-7c0a26dd59db")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 제작 실행 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		if _UtilLogic:IsNilorEmptyString(_CraftingLogic.selectedRecipeId) then
			return
		end
		
		
		_CraftingLogic:RequestCraftInServer(_CraftingLogic.selectedRecipeId, _CraftingLogic.craftingCount)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "af9db529-5651-447c-8939-86bdbfc9c172")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 제작 수량 최소값 버튼 클릭 이벤트 처리
		local Entity = event.Entity
		_CraftingLogic:ChangeCraftingCount(true, 0)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "0d6317ac-b507-4bec-872f-f09c47414c52")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 제작 수량 최대값 버튼 클릭 이벤트 처리
		local Entity = event.Entity 
		local enableMaxCount = _CraftingLogic:GetEnableCountCraftingByRecipeId(_CraftingLogic.selectedRecipeId, _UserService.LocalPlayer.PlayerComponent.UserId)
		
		if enableMaxCount >= _CraftingLogic.craftingMaxCount then 
			enableMaxCount = _CraftingLogic.craftingMaxCount
		end
		
		if _CraftingLogic.craftingCount >= enableMaxCount then
			enableMaxCount = 0
		elseif _CraftingLogic.craftingCount > 0 then
			enableMaxCount = enableMaxCount - _CraftingLogic.craftingCount 
		end
		
		
		_CraftingLogic:ChangeCraftingCount(false, enableMaxCount)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "58828a55-d841-4574-ad0f-2a3238edce76")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 제작 수량 감소 버튼 클릭 이벤트 처리
		local Entity = event.Entity
		_CraftingLogic:ChangeCraftingCount(false, -1)
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f26995fd-879d-4e2d-8b65-b61625e168ae")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 제작 수량 증가 버튼 클릭 이벤트 처리
		local Entity = event.Entity
		_CraftingLogic:ChangeCraftingCount(false, 1)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		-- 화면 터치 시 제작 결과 팝업 닫기 이벤트 처리
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.CraftingSuccessPanel.CraftingResultShowPopup.isOpen then
			self.CraftingSuccessPanel.CraftingResultShowPopup:Hide()
		end
	end

end