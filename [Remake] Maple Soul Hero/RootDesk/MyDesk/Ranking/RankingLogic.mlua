	@ExecSpace("Client")
	method void OnLoadBattlePowerRecord(table rank)
		-- 전투력 랭킹 데이터 로드 완료 후 UI 갱신
		self.battlePowerRecord = rank
		
		if isvalid(self.battlePowerLeaderBoard.Entity) then
			self.battlePowerLeaderBoard:Refresh()
		end
	end

	@ExecSpace("ServerOnly")
	method void SetBattlePowerRecord(string userId)
		-- 플레이어의 전투력 기록을 데이터베이스에 저장
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local nickname = playerEntity.PlayerComponent.Nickname
		local battlePower = math.floor(playerEntity.PlayerInfoComponent.playerInfo.bestBattlePower)
		
		local battlePowerRecordDB = _DataStorageService:GetSortableDataStorage("battlePowerRecord")
		
		battlePowerRecordDB:GetAsync(userId, function(errorCode, key, value)
				local version = "version1"
				local tag = nickname
				
				if isvalid(value) then
					if battlePower > value then
						battlePowerRecordDB:SetByInfoAsync(DataStorageKeyInfo(userId, version, tag), battlePower, nil)
					end
				else
					battlePowerRecordDB:SetByInfoAsync(DataStorageKeyInfo(userId, version, tag), battlePower, nil)
				end
			end)
	end

	@ExecSpace("ServerOnly")
	method table SortLimitLandRecord(table rank)
		-- 리미트랜드 랭킹을 웨이브와 시간에 따라 정렬
		
		local newRank = {} 
		
		for i = 1, #rank do
			local info = {["rank"] = i, ["info"] = rank[i]}
			newRank[i] = info
		end
		
		table.sort(newRank, function(a, b)
				if a.info.value == b.info.value then 
					local splits_a = _UtilLogic:Split(a.info.tag, "/")
					local splits_b = _UtilLogic:Split(b.info.tag, "/")
				
					if isvalid(splits_a[2]) and isvalid(splits_b[2]) then
						local ms_a = self:GetMs(splits_a[2])
						local ms_b = self:GetMs(splits_b[2])
					
						return ms_a < ms_b
					else
						return true
					end
				else
					return a.rank < b.rank 
				end
				
			end)
		
		local returnRank = {}
		
		for i = 1, #newRank do
			returnRank[i] = newRank[i].info
		end
		
		return returnRank
	end

