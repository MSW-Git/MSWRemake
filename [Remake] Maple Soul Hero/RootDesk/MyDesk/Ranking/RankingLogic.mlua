		end
	end

	@ExecSpace("ServerOnly")
	method void SetAccountLevelRecord(string userId)
		-- 플레이어의 계정 레벨 기록을 데이터베이스에 저장
		local playerEntity = _UserService:GetUserEntityByUserId(userId)
		local nickname = playerEntity.PlayerComponent.Nickname
		local level = math.floor(playerEntity.PlayerAccount.accountTable.level)
		
		local accountLevelRecordDB = _DataStorageService:GetSortableDataStorage("accountLevelRecord")
		
		accountLevelRecordDB:GetAsync(userId, function(errorCode, key, value)
				local version = "version1"
				local tag = nickname
				
				if isvalid(value) then
					if level > value then
						accountLevelRecordDB:SetByInfoAsync(DataStorageKeyInfo(userId, version, tag), level, nil)
					end
				else
					accountLevelRecordDB:SetByInfoAsync(DataStorageKeyInfo(userId, version, tag), level, nil)
				end
			end)
	end

	@ExecSpace("ServerOnly")
	method void TempLoadLimitLandRecord(any callbackFunc)
		-- 이전 주차 리미트랜드 기록을 임시로 로드
		local limitLandRecordDBNum = (_LocalTimeLogic:GetCurrentSeasonWeek() + 1) % 2
		local limitLandRecordDBName = string.format("limitLandRecord%d", limitLandRecordDBNum)
		
		local rank = {}
		local limitLandRecordDB = _DataStorageService:GetSortableDataStorage(limitLandRecordDBName)
		
		limitLandRecordDB:GetSortedAsync(SortDirection.Descending, 0, math.maxinteger, function(error, page)
				---@type SortableDataStorageItemPages
				local itemPage = page
				local pageCount = 1
			
				while true do
					for _, data in pairs(itemPage:GetCurrentPageDatas()) do
		
						local key = data.KeyInfo.Key
						local value = data.Value
						local tag = data.KeyInfo.Tag
						
						local info = {["key"] = key, ["value"]= value, ["tag"] = tag}
					
						table.insert(rank, info)
					end
				
					if itemPage.IsLastPage or pageCount >= self.maxPageCount then
						self.previousWeekLimitLandRecord = self:SortLimitLandRecord(rank)
						self:OnLoadWeeklyLimitLandRewardInfo(self.previousWeekLimitLandRecord)
						self.refreshedWeeklyLimitLandDate = _LocalTimeLogic:GetKST()
							
						if isvalid(callbackFunc) then
							callbackFunc()
						end
					
						break
					end
				
					local loadResultCode = itemPage:LoadNextPageAndWait()
				
					if loadResultCode ~= 0 then
						self.previousWeekLimitLandRecord = self:SortLimitLandRecord(rank)
						self:OnLoadWeeklyLimitLandRewardInfo(self.previousWeekLimitLandRecord)
					
						break
					else
						itemPage:MoveToNextPageAndWait()
					end
					
					pageCount += 1
				end
			end)
	end

	method table GetLoggingRank(table rankTable)
		-- 랭킹 데이터를 로깅용 형식으로 변환
		local temp = {}
		local i = 1
		
		for key, value in pairs(rankTable) do
			local newValue = {["key"] = string.format("%s_%d", value.tag, key), ["value"] = value.value}
			temp[i] = newValue
			
			i += 1
		end
		
		return temp
	end

	method number GetMs(string str)
		-- 시간 문자열을 밀리초 단위로 변환
		local splits = _UtilLogic:Split(str, ":")
		
		if #table.keys(splits) > 2 then
			local minutes = tonumber(splits[2]) * 60 * 1000
			
			if _UtilLogic:Contains(splits[3], ".") then
				splits = _UtilLogic:Split(splits[3], ".")
				local seconds = tonumber(splits[1]) * 1000
				local ms = tonumber(splits[2])
				
				return minutes + seconds + ms
			else
				local seconds = tonumber(splits[3]) * 1000
				
				return minutes + seconds
			end
		else
			local minutes = tonumber(splits[1]) * 60 * 1000
			
			if _UtilLogic:Contains(splits[2], ".") then
				splits = _UtilLogic:Split(splits[2], ".")
				local seconds = tonumber(splits[1]) * 1000
				local ms = tonumber(splits[2])
				
				return minutes + seconds + ms
			else
				local seconds = tonumber(splits[2]) * 1000
				
				return minutes + seconds
			end
		end
		
	end

	@ExecSpace("ServerOnly")
	@EventSender("Service", "UserService")
	handler HandleUserEnterEvent(UserEnterEvent event)
		-- 사용자 입장 이벤트 처리 및 랭킹 데이터 전송
		
		local UserId = event.UserId
		_TimerService:SetTimerOnce(function()
				if isvalid(_UserService:GetUserEntityByUserId(UserId)) then
					self:OnLoadLimitLandRecord(self.limitLandRecord, UserId)
					self:OnLoadBattlePowerRecord(self.battlePowerRecord, UserId)
					self:OnLoadAccountLevelRecord(self.accountLevelRecord, UserId)
					self:OnLoadWeeklyLimitLandRewardInfo(self.previousWeekLimitLandRecord, UserId)
				end
			end, 5)
	end

end