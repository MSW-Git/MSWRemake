@Logic
script RankingLogic extends Logic

	property table limitLandRecord = {}

	property LimitLandRankUIComponentRef limitLandLeaderBoard = "8e8dde7d-3ed5-4c7f-8483-8e8177181a78"

	property EntityRef town = "bc376049-67b7-4819-8b18-abc871f66808"

	@HideFromInspector
	property integer limitLandRecordDBNum = 1

	property string limitLandRecordDBName = "limitLandRecord1"

	property table battlePowerRecord = {}

	property BattlePowerRankUIComponentRef battlePowerLeaderBoard = "d51bc266-2920-4d4b-88e0-9079e3777554"

	@HideFromInspector
	property RankingUIComponent rankingUI = "04423e45-d09a-46dc-9d0b-98b02c7f962e"

	property table previousWeekLimitLandRecord = {}

	property any refreshedWeeklyLimitLandDate = nil

	property table accountLevelRecord = {}

	property AccountLevelRankUIComponent accountLevelLeaderBoard = "be25ce5a-d4b4-4bfa-a4ec-1c2023f19dbd"

	property integer maxPageCount = 40

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		-- 랭킹 시스템 초기화 및 주기적 데이터 새로고침 타이머 설정
		local refreshLimitLandStorage = function()
			self:LoadLimitLandRecord()
		end
		
		_TimerService:SetTimerRepeat(refreshLimitLandStorage, 300)
		
		local refreshBattlePowerRank = function()
			self:LoadBattlePowerRecord()
		end
		
		_TimerService:SetTimerRepeat(refreshBattlePowerRank, 601)
		
		local refreshAccountLevelRank = function()
			self:LoadAccountLevelRecord()
		end
		
		
		_TimerService:SetTimerRepeat(refreshAccountLevelRank, 602)
		
		
		local refreshLimitRewardStorage = function()
			self:TempLoadLimitLandRecord(nil)
		end
		
		_TimerService:SetTimerRepeat(refreshLimitRewardStorage, 1139)
		
	end

	@ExecSpace("ServerOnly")
	method void SetLimitLandRecord(integer clearedWave, string senderId, string dateTime)
		-- 리미트랜드 기록을 데이터베이스에 저장
		local recordFunc = function(errorCode, key, value) 
			local limitLandRecordDB = _DataStorageService:GetSortableDataStorage(self.limitLandRecordDBName) 
			local playerEntity = _UserService:GetUserEntityByUserId(senderId)
			
			limitLandRecordDB:GetAsync(senderId, function(errorCode, key, value)
					local version = "version1"
					local tag = string.format("%s/%s", playerEntity.PlayerComponent.Nickname, dateTime) 
					
					if isvalid(value) then
						if clearedWave >= value then
							limitLandRecordDB:SetByInfoAsync(DataStorageKeyInfo(senderId, version, tag), clearedWave, nil)
						end
					else 
						limitLandRecordDB:SetByInfoAsync(DataStorageKeyInfo(senderId, version, tag), clearedWave, nil)
					end
				end)
		end
		
		self:RecordGlobalDBUsedDate(recordFunc) 
	end

	@ExecSpace("ServerOnly")
	method void LoadLimitLandRecord()
		-- 리미트랜드 랭킹 데이터를 로드하여 정렬 및 처리
		self.limitLandRecordDBNum = _LocalTimeLogic:GetCurrentSeasonWeek() % 2
		self.limitLandRecordDBName = string.format("limitLandRecord%d", self.limitLandRecordDBNum)
		
		local rank = {}
		local limitLandRecordDB = _DataStorageService:GetSortableDataStorage(self.limitLandRecordDBName)
		
		limitLandRecordDB:GetSortedAsync(SortDirection.Descending, 0, math.maxinteger, function(error, page)
				---@type SortableDataStorageItemPages
				local itemPage = page
				local pageCount = 1
			
				while true do
					for _, data in pairs(itemPage:GetCurrentPageDatas()) do
		
						local key = data.KeyInfo.Key
						local value = data.Value
						local tag = data.KeyInfo.Tag
					
						local splits = _UtilLogic:Split(tag, "/")
						local nickname = splits[1]
						local time = TimeSpan(splits[2])
						local newTag = string.format("%02d:%02d.%03d", time.Minutes, time.Seconds, time.Milliseconds)
						tag = string.format("%s/%s", nickname, newTag)
		
						local info = {["key"] = key, ["value"]= value, ["tag"] = tag}
						
						table.insert(rank, info)
					end
				
					if itemPage.IsLastPage or pageCount >= self.maxPageCount then
						self.limitLandRecord = self:SortLimitLandRecord(rank)
						_WorldLog:LogRanking(_HttpService:JSONEncode(self:GetLoggingRank(self.limitLandRecord)), "LimitLand")
						self:OnLoadLimitLandRecord(self.limitLandRecord)
						self:RecordGlobalDBUsedDate(nil)
					
						break
					end
				
					local loadResultCode = itemPage:LoadNextPageAndWait()
				
					if loadResultCode ~= 0 then
						self.limitLandRecord = self:SortLimitLandRecord(rank)
						_WorldLog:LogRanking(_HttpService:JSONEncode(self:GetLoggingRank(self.limitLandRecord)), "LimitLand")
						self:OnLoadLimitLandRecord(self.limitLandRecord)
						self:RecordGlobalDBUsedDate(nil)
					
						break
					else
						itemPage:MoveToNextPageAndWait()
					end
					
					pageCount += 1
				end
		
				for userId, entity in pairs(_UserService.UserEntities) do
					if isvalid(entity) then
						entity.PlayerInfoComponent:CheckEnteredDate()
					end
				end
			end)
	end

	@ExecSpace("ServerOnly")
	method void RecordGlobalDBUsedDate(any callbackFunc)
		-- 글로벌 DB 사용 날짜 기록 및 주간 전환 처리
		local currentDate = _LocalTimeLogic:GetKST()
		local globalDB = _DataStorageService:GetGlobalDataStorage("globalDB")
		local dbKey = "lastRecorded"
		local dbValue = string.format("%s,%d", tostring(currentDate), self.limitLandRecordDBNum)
		
		
		globalDB:GetAsync(dbKey, function(errorCode, key, value)
				if isvalid(value) then
					local splits = _UtilLogic:Split(value, ",") 
					local recordedDate = DateTime(splits[1])
					local recordedDBNum = tonumber(splits[2])
		
					local recordedWeek = _LocalTimeLogic:GetSeasonWeek(recordedDate)
					local currentWeek = _LocalTimeLogic:GetCurrentSeasonWeek()
					
					if recordedWeek ~= currentWeek then 
						
						self.limitLandRecordDBNum = _LocalTimeLogic:GetCurrentSeasonWeek() % 2
						self.limitLandRecordDBName = string.format("limitLandRecord%d", self.limitLandRecordDBNum)
						
						local callback = function()
							self:DeleteLimitLandStorage(dbKey, dbValue, globalDB, callbackFunc, currentDate) 
						end
						
						self:RecordWeeklyLimitLandRewardInfo(callback) 
						
					else 
						globalDB:SetAsync(dbKey, dbValue, function(errorCode, key)
							end)
						
						if isvalid(callbackFunc) then
							callbackFunc()
						end
					end
				else 
					globalDB:SetAsync(dbKey, dbValue, function(errorCode, key)
						end)
					
					if isvalid(callbackFunc) then
						callbackFunc()
					end
				end
			end)
	end

	@ExecSpace("ServerOnly")
	method void RecordWeeklyLimitLandRewardInfo(any callback)
		-- 주간 리미트랜드 보상 정보를 기록
		
		
		local dbNum = math.abs(_LocalTimeLogic:GetCurrentSeasonWeek() % 2 - 1)
		local dbName = string.format("limitLandRecord%d", dbNum)
		local rank = {}
		
		_DataStorageService:GetSortableDataStorage(dbName):GetSortedAsync(SortDirection.Descending, 1, math.maxinteger, function(errorCode, page)
				---@type SortableDataStorageItemPages
				local itemPage = page
				local pageCount = 1
				
				while true do
					for _, data in pairs(itemPage:GetCurrentPageDatas()) do
						local key = data.KeyInfo.Key
						local value = data.Value
						local tag = data.KeyInfo.Tag
						local splits = _UtilLogic:Split(tag, "/")
						local name = splits[1]
						local seconds = DateTime(splits[2]).Second + DateTime(splits[2]).Minute * 60
						local newTag = string.format("%s/%d", name, seconds)
						
						local info = {["key"] = key, ["value"]= value, ["tag"] = tag}
						
						table.insert(rank, info)
					end
				
					if itemPage.IsLastPage or pageCount >= self.maxPageCount then
						self.previousWeekLimitLandRecord = self:SortLimitLandRecord(rank)
						self:OnLoadWeeklyLimitLandRewardInfo(self.previousWeekLimitLandRecord)
					
						_DataStorageService:GetGlobalDataStorage("globalDB"):SetAsync("weeklyLimitLandRewardInfo", _HttpService:JSONEncode(self.previousWeekLimitLandRecord), function(errorCode, key)
								if isvalid(callback) then
									callback()
								end
								
							end)
					
						break
					end
				
					local loadResultCode = itemPage:LoadNextPageAndWait()
				
					if loadResultCode ~= 0 then
						self.previousWeekLimitLandRecord = self:SortLimitLandRecord(rank)
						self:OnLoadWeeklyLimitLandRewardInfo(self.previousWeekLimitLandRecord)
					
						_DataStorageService:GetGlobalDataStorage("globalDB"):SetAsync("weeklyLimitLandRewardInfo", _HttpService:JSONEncode(self.previousWeekLimitLandRecord), function(errorCode, key)
								if isvalid(callback) then
									callback()
								end
								
							end)
					
						break
					else
						itemPage:MoveToNextPageAndWait()
					end
				
					pageCount += 1
				end
			end)
		
	end

	@ExecSpace("ServerOnly")
	method void DeleteLimitLandStorage(string dbKey, string dbValue, any globalDB, any callbackFunc, any currentDate)
		-- 이전 주차 리미트랜드 저장소 삭제
		_DataStorageService:DeleteSortableDataStorageAsync(self.limitLandRecordDBName, function(errorCode, dbName) 
				
				globalDB:SetAsync(dbKey, dbValue, function(errorCode, key) 
						self.limitLandRecordDBNum = _LocalTimeLogic:GetCurrentSeasonWeek() % 2
						self.limitLandRecordDBName = string.format("limitLandRecord%d", self.limitLandRecordDBNum)
						
						if isvalid(callbackFunc) then
							callbackFunc()
						end
						
						
						self:LoadLimitLandRecord()
					end)
			end)
	end

	@ExecSpace("Client")
	method void OnLoadLimitLandRecord(table rank)
		-- 리미트랜드 랭킹 데이터 로드 완료 후 UI 갱신
		self.limitLandRecord = rank
		
		if isvalid(self.limitLandLeaderBoard.Entity) then
			self.limitLandLeaderBoard:Refresh()
		end
	end

	@ExecSpace("Server")
	method void LoadWeeklyLimitLandRewardInfo(any callbackFunc)
		-- 주간 리미트랜드 보상 정보를 로드
		local refreshFunc = function()
			_DataStorageService:GetGlobalDataStorage("globalDB"):GetAsync("weeklyLimitLandRewardInfo", function(errorCode, key, value) 
				if isvalid(value) and value ~= "" then
		
					self.previousWeekLimitLandRecord = _HttpService:JSONDecode(value)
					self:OnLoadWeeklyLimitLandRewardInfo(self.previousWeekLimitLandRecord)
					self.refreshedWeeklyLimitLandDate = _LocalTimeLogic:GetKST()
						
					if isvalid(callbackFunc) then
						callbackFunc()
					end
				end
			end)
		end
		
		if isvalid(self.refreshedWeeklyLimitLandDate) then
			local refreshedDate = DateTime(tostring(self.refreshedWeeklyLimitLandDate))
			local currentDate = _LocalTimeLogic:GetKST()
			
			if refreshedDate.Day == currentDate.Day and refreshedDate.Month == currentDate.Month and refreshedDate.Year == currentDate.Year then 
				if isvalid(callbackFunc) then
					callbackFunc()
				end
			else
				refreshFunc()
			end
		else 
			refreshFunc()
		end
	end

	@ExecSpace("Client")
	method void OnLoadWeeklyLimitLandRewardInfo(table infoTable)
		-- 주간 리미트랜드 보상 정보 로드 완료
		self.previousWeekLimitLandRecord = infoTable
	end

