@Component
script LimitLandRankUIComponent extends Component

	property Entity originalItem = nil

	property Entity myRank = nil

	property GridViewComponent gridView = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 리미트랜드 랭킹 UI 컴포넌트 초기화
		self.originalItem = self.Entity:GetChildByName("OriginalItem", true)
		self.myRank = self.Entity:GetChildByName("My_Rank")
		self.gridView = self.Entity:GetChildByName("Layout").GridViewComponent
		
		self.gridView.ItemEntity = self.originalItem
		self.gridView.TotalCount = 1000
		self.gridView.OnRefresh = function(index, entity)
			local slotNum = index + 1
			---@type Entity
			local newEntity = entity
			
			newEntity.LimitLandRankSlotComponent:SetSlot(slotNum)
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshMyInfo()
		-- 내 리미트랜드 랭킹 정보를 갱신
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		local rank = self.myRank:GetChildByName("Text_rank")
		local name = self.myRank:GetChildByName("Text_name")
		local score = self.myRank:GetChildByName("Text_score")
		local recordedTime = self.myRank:GetChildByName("Text_recordedTime")
		local myInfo = {}
		local rankNum = 0
		
		for key, value in pairs(_RankingLogic.limitLandRecord) do
			if value.key == _UserService.LocalPlayer.PlayerComponent.UserId then
				myInfo = value
				rankNum = key
				
				break
			end
		end
		
		if #table.keys(myInfo) > 0 then
			local myRecordedTime = _UtilLogic:Split(myInfo.tag, "/")[2]
			
			rank.TextComponent.Text = string.format("%d", rankNum)
			name.TextComponent.Text = _UserService.LocalPlayer.PlayerComponent.Nickname
			score.TextComponent.Text = string.format("%d", myInfo.value)
			
			if _UtilLogic:Contains(myRecordedTime, ".") then
				recordedTime.TextComponent.Text = string.format("%s", myRecordedTime)
			else
				recordedTime.TextComponent.Text = string.format("%s.000", myRecordedTime)
			end
		else
			rank.TextComponent.Text = _LocalizeLogic:GetText("rankingStr1")
			name.TextComponent.Text = _UserService.LocalPlayer.PlayerComponent.Nickname
			score.TextComponent.Text = "0"
			recordedTime.TextComponent.Text = "-"
			
		end
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 리미트랜드 랭킹 UI 전체를 갱신
		self:RefreshMyInfo()
		self.gridView:Refresh(true, true)
		
		if #table.keys(_RankingLogic.limitLandRecord) < 1 then
			self.gridView.Enable = false
		else
			self.gridView.Enable = true
		end
	end

end