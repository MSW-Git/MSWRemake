@Component
script PotionComponent extends Component

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 포션에 닿았을 때 체력 회복 처리
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		if not isvalid(TriggerBodyEntity.BattlePlayer) then return end
		
		local battlePlayer = TriggerBodyEntity.BattlePlayer
		battlePlayer:SetHP(battlePlayer.hp + battlePlayer.maxHp * 0.1)
		_PoolingLogic:DestroyEntity(self.Entity)
		TriggerBodyEntity:SendEvent(GetPotionEvent())
		battlePlayer.lootedPotionCount += 1
	end

end