	@ExecSpace("ServerOnly")
	method void LogGatchaFlow(string ppsn, string gatchaType, string gatchaId, string source, string sourceId, table gainedIds)
		-- 가챠 사용 결과를 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		
		if account == nil then
			return
		end
		
		local userLevel = self:NumberToString(account.level)
		
		local extras = {
			userLevel = userLevel,
			gatchaId = gatchaId,
		    source = source,
			sourceId = sourceId
		}
		local index = 1
		
		for key, value in pairs(gainedIds) do
			extras[string.format("Result%d", index)] = value
			
			index += 1
		end
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_GatchaFlow, gatchaType, extras)
	end

	@ExecSpace("ServerOnly")
	method void LogPetFlow(string ppsn, string source, string sourceId, string flowType, string uniqueKey, number exp, number beforeExp)
