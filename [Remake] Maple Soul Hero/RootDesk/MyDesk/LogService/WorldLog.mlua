		self:LogQuestFlow(senderUserId, questData, flowType, source)
	end

	@ExecSpace("ServerOnly")
	method void LogConnectFlow(string ppsn, string flowType)
		-- 플레이어 접속/종료를 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if not player.PlayerDBComponent.dbInited then return end
		
		if isvalid(player) == false then
			return
		end
		
		local currency = player.PlayerCurrencyData
		
		if not isvalid(currency) then return end
		
		local character = player.PlayerCharacterData
		
		if not isvalid(character) then return end
		
		local extras = {
			flowType = flowType,
			battlePower = tostring(_BattlePowerLogic:CalcBattlePower(player)),
			stageStep = tostring(player.PlayerInfoComponent.playerInfo.stageStep),
			diamond = tostring(currency.currencyTable["Diamond"].amount),
			meso = tostring(currency.currencyTable["Gold"].amount),
			scroll = tostring(currency.currencyTable["WeaponScroll"].amount),
			essence = tostring(currency.currencyTable["Essence"].amount)
		}
		
		for key, value in pairs(character.charPieceStorage) do
			extras[tostring(key)] = tostring(value.count)
		end
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_ConnectFlow, player.PlayerComponent.Nickname, extras)
		
	end

