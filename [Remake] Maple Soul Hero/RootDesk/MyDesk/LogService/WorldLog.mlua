	@ExecSpace("ServerOnly")
	method void LogExplore(string flowType, string ppsn)
		-- 탐험 보상 수집을 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		local reward = player.PlayerAutoGathering.GatherRewardTable
		
		local time = self:NumberToString(reward["lastAutoGatheringTime"].value)
		local serverTime = self:NumberToString(_LocalTimeLogic:GetElapsed())
		local gold = 0
		local essence = 0
		local scroll = 0
		
		
		for i = 1 , #reward["gold"].reward do
			gold = gold + reward["gold"].reward[i] 
		end
		gold = self:NumberToString(gold)
		
		for i = 1 , #reward["scroll"].reward do
			scroll = scroll + reward["scroll"].reward[i] 
		end
		scroll = self:NumberToString(scroll)
		
		for i = 1 , #reward["essence"].reward do
			essence = essence + reward["essence"].reward[i] 
		end
		essence = self:NumberToString(essence)
		
		
		local extra = {
			flowType = flowType,
			gold = gold,
			scroll = scroll,
			essence = essence,
			time = time,
			serverTime = serverTime
		}
		_LogStorageLogic:LogValue(ppsn, self.LogName_Explore, time, extra)
	end

	@ExecSpace("ServerOnly")
	method void LogMailFlow(string ppsn, string flowType, string source, number mailId, string itemData)
		-- 메일 발송/수신을 로그에 기록
		---@type Entity
		local player = nil
		if _UtilLogic:IsNilorEmptyString(ppsn) == false then
			player = _UserService:GetUserEntityByUserId(ppsn)
		else
			ppsn = "global"
		end
		
		local userLevel = "0"
		
		if isvalid(player) then
			local account = player.PlayerAccount.accountTable
			userLevel = self:NumberToString(account.level)
		end
		local value = self:NumberToString(mailId)
		
		local extras = {
		    flowType = flowType,
		    source = source,
		    userLevel = userLevel,
			itemData = itemData,
		}
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_MailFlow, value, extras)
		
	end

