	@ExecSpace("Server")
	method void LogIngameFlowWaveStart(Entity playerEntity, integer mode, integer waveNum, string dateTime, string deviceType)
		-- 웨이브 시작 시 플레이어 상태를 로그에 기록
		local currentStatus = {}
		
		for key, value in pairs(playerEntity.PlayerStorageComponent.storage) do
			if value.equippedSlotNum > 0 then
				currentStatus["Equip" .. value.equippedSlotNum] = value.originalId
			end
		end
		
		for key, value in pairs(playerEntity.PlayerPetStorageComponent.petInventory) do
			if value.equippedSlotNum > 0 then
				currentStatus["Pet" .. tostring(value.equippedSlotNum)] = value.originalId
			end
		end
		
		for key, value in pairs(playerEntity.PlayerCharacterData.charDeckStorage) do
			if value.equipped then
				currentStatus["Soul"] = tostring(key)
				
				break
			end
		end
		
		_WorldLog:LogIngameFlow(playerEntity.PlayerComponent.UserId, "5", tostring(mode), currentStatus, string.format("LimitLand_%d_%s", waveNum, dateTime), "0", deviceType, true, nil)
	end

end