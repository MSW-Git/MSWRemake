		    petGrade = petGrade,
		    petLevel = petLevel,
		    exp = tostring(exp),
			beforeExp = tostring(beforeExp),
		    uniqueKey = uniqueKey,
		}
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_PetFlow, petId, extras)
	end

