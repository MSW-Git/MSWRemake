	@ExecSpace("ServerOnly")
	method void LogFieldLevelFlow(string flowType, string source, string ppsn, integer beforeLevel, integer changeLevel, integer beforeEXP, integer changeEXP, integer beforeSP, integer changeSP, string monsterId)
		-- 필드 레벨 변화를 로그에 기록
		
		
		local player = _UserService:GetUserEntityByUserId(ppsn)
		local ability = player.PlayerAbilityComponent
		local toStringChangeExp = ""
		
		if changeEXP == nil then
			toStringChangeExp = "0"
		else
			changeEXP = math.abs(changeEXP)
		
			if (changeEXP < 1) and (changeEXP > 0) then
				if changeEXP < 0.00001 then
					toStringChangeExp = "0.000001"
				else
					toStringChangeExp = string.format("%.5f", changeEXP)		
				end
		
			else 
				toStringChangeExp = string.format("%.5f", changeEXP) 
			end
		
		end
		
		
		local extras = {
			flowType = flowType,
			source = source,
			beforeLevel = self:NumberToString(beforeLevel),
			changeLevel = self:NumberToString(changeLevel),
			currentLevel = self:NumberToString(ability.ability["lvData"].lv),
			beforeEXP = self:NumberToString(beforeEXP),
			changeEXP = toStringChangeExp,
			currentExp = self:NumberToString(ability.ability["lvData"].exp),
			beforeSP = self:NumberToString(beforeSP),
			changeSP = self:NumberToString(changeSP),
			currentSP = self:NumberToString(ability.ability["lvData"].cp),
			monsterId = monsterId
			}
			
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_FieldLevelFlow, self:NumberToString(changeEXP), extras)
	end

