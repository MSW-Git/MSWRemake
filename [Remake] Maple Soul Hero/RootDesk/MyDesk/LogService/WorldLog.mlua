	@ExecSpace("ServerOnly")
	method void LogAccountFlow(string flowType, string levelChange, number expChange, string source, string ppsn)
		-- 계정 레벨 및 경험치 변화를 로그에 기록
		
		local player = _UserService:GetUserEntityByUserId(ppsn)
		local account = player.PlayerAccount.accountTable
		local accountToString = _HttpService:JSONEncode(player.PlayerAccount.accountTable)
		
		local extras = {
			flowType = flowType,
			level = self:NumberToString(account.level),
			levelChange = levelChange, 
			levelChangeBef = self:NumberToString(account.level - tonumber(levelChange)), 
			expChange = self:NumberToString(expChange),
			expChangeBef = self:NumberToString(account.exp - expChange),
			source = source,
		}
		
		if _UtilLogic:IsNilorEmptyString(accountToString) then
			accountToString = "none"
		end
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_Account, accountToString, extras)
	end

