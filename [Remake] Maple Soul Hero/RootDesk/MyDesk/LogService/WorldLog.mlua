	@ExecSpace("ServerOnly")
	method void LogAccReinforceFlow(string ppsn, string uniqueKey, string changeBef, string failCountBef, string flowType, string source)
		-- 액세서리 강화를 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		if isvalid(player) == false then
			return
		end
		
		local playerStorage = player.PlayerStorageComponent
		local item = playerStorage.storage[uniqueKey]
		
		if item == nil then
			return
		end
		
		local itemId = item.originalId
		
		local itemData = _ItemDataLogic:GetItemData(itemId)
		local detailCategory = _ItemDataLogic:GetAccessoryDetailCategory(item.originalId)
		local category = "1"
		
		if detailCategory == "necklace" then
			category = "2"
		elseif detailCategory == "earring" then
			category = "3"
		end
		
		local extras = {
			category = category,
			reinforceNum = string.format("%d", item.level),
			changeBef = changeBef,
			flowType = flowType,
			failCount = string.format("%d", item.failCount),
			failCountBef = failCountBef,
			source = source,
			itemId = item.originalId,
			itemGrade = itemData.grade,
			accGrade = item.grade
		}
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_AccessoryReinforceFlow, uniqueKey, extras)
	end

