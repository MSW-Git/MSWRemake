	@ExecSpace("ServerOnly")
	method void LogInventoryFlow(string ppsn, string uniqueKey, string itemId, string source, string flowType, number changeValue, string sourceId)
		-- 인벤토리 아이템 변화를 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		
		if account == nil then
			return
		end
		
		local playerStorage = player.PlayerStorageComponent
		local storage = playerStorage.storage[uniqueKey]
		local value = 0
		local extras = {}
		
		if storage == nil then 
			local itemData = _ItemDataLogic:GetItemData(itemId)
			
			if itemData == nil then
				return
			else
				local category = _UtilLogic:Split(itemId,"_")[1]
				local change = self:NumberToString(math.abs(changeValue))
				local changeBef = self:NumberToString(changeValue * (-1))
				local itemType = itemData.category
				local itemGrade = itemData.grade
				local userLevel = self:NumberToString(account.level)
				local id = uniqueKey
				
				extras = {
					category = category,
				    change = change,
				    changeBef = changeBef,
				    flowType = flowType,
				    source = source,
					sourceId = sourceId,
				    itemType = itemType,
				    itemId = itemId,  
				    itemGrade = itemGrade,
				    itemLevel = "0",
				    itemExp = "0",
				    equipped = "0",
				    userLevel = userLevel,
				    id = id
				}
			end
		else 
			local itemData = _ItemDataLogic:GetItemData(itemId)
			
			if itemData == nil then
				return
			end
			
			value = storage.count
			local category = _UtilLogic:Split(itemId,"_")[1]
			local change = self:NumberToString(math.abs(changeValue)) 
			local changeBef = self:NumberToString(value - changeValue)
			local itemType = itemData.category
			
			local itemGrade = itemData.grade
			local itemLevel = self:NumberToString(storage.level)
			local itemExp = self:NumberToString(storage.mergeExp)
			local equipped = self:NumberToString(storage.equippedSlotNum)
			local userLevel = self:NumberToString(account.level)
			local id = uniqueKey
			
			if itemData.category == "accessory" and source == "CraftingResult" then
				itemGrade = storage.grade
			end
			
			extras = {
				category = category,
			    change = change,
			    changeBef = changeBef,
			    flowType = flowType,
			    source = source,
				sourceId = sourceId,
			    itemType = itemType,
			    itemId = itemId,  
			    itemGrade = itemGrade,
			    itemLevel = itemLevel,
			    itemExp = itemExp,
			    equipped = equipped,
			    userLevel = userLevel,
			    id = id
			}
		end
		
		
		_LogStorageLogic:LogValue(ppsn,self.LogName_InventoryFlow,self:NumberToString(value),extras)
		
	end

	method string NumberToString(number num)
		-- 숫자를 문자열로 변환 (nil 처리 포함)
		if  num == nil then
			return "0"
		end
		return string.format("%d", num)
	end

	@ExecSpace("ServerOnly")
	method void LogAssetFlow(string ppsn, string assetId, string source, string sourceId, string flowType, number changeValue)
		-- 자산(화폐) 변화를 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		if isvalid(player) == false then
			return
		end
		local account = player.PlayerAccount.accountTable
		if account == nil then
			return
		end
		local currencyData = player.PlayerCurrencyData
		if isvalid(currencyData) == nil then
			return
		end
		
		local userLevel = self:NumberToString(account.level)
		local change = self:NumberToString(math.abs(changeValue))
		
		local value = 0
		local category = ""
		
		if assetId == _GameConfig:GetConfig().WEALTHTYPE_MESO then
			category = "0"
			value = currencyData.gold
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_DIAMOND then
			category = "1"
			value = currencyData.diamond
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_SCROLL then
			category = "2"
			value = currencyData.weaponScroll
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_ESSENCE then
			category = "3"
			value = currencyData.essence
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_FIELDGEM then
			category = "5"
			value = currencyData.fieldGem
		elseif assetId == "characteristicCoin" then
			category = "4"
			value = player.PlayerCharacteristicData.characteristicPoint
		else
			category = "-1"
		end
		
		
		local changeBef = self:NumberToString(value - changeValue)
		
		local gameKey = ""
		if source == "StageClear" then
			local myPlayer = player.MyPlayer
			if isvalid(myPlayer) then
				gameKey = myPlayer.gameKey
			end
		end
		local extras = {
			category = category,
		
		    change = change,
		    changeBef = changeBef,
		    flowType = flowType,
		    source = source, 
		    stageId = sourceId,
		    assetId = assetId,
		    userLevel = userLevel,
			id = gameKey,
		}
		
		
		_LogStorageLogic:LogValue(ppsn,self.LogName_AssetFlow,self:NumberToString(value),extras)
	end

	@ExecSpace("ServerOnly")
	method void LogQuestFlow(string ppsn, table questData, string flowType, string source)
		-- 퀘스트 진행 상황을 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		if account == nil then
			return
		end
		local currentObjective = questData.questObjective
		
		if _UtilLogic:IsNilorEmptyString(currentObjective) and isvalid(questData.objectiveId) then
			local objectiveIds = _UtilLogic:Split(questData.objectiveId, "/")
			for i = 1, #objectiveIds do		
				currentObjective = string.format("%s/0", objectiveIds[i])
				if _UtilLogic:IsNilorEmptyString(currentObjective) == false then
					break
				end
			end
		end
		
		local questId = questData.id
		local questType = questData.category
		local userLevel = self:NumberToString(account.level)
		
		local value = currentObjective
		local category = "0"
		if questType == "main" then
			 category = "0"
		elseif questType == "objective" then
			category = "1"
		else
			 category = "-1"
		end
		
		local extras = {
		 	category = category,
		    flowType = flowType,
		    source = source,
		    questId = questId,
		    questType = questType,
		    userLevel = userLevel,
		}
		
		if _UtilLogic:IsNilorEmptyString(value) then
			value = "none"
		end
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_QuestFlow, value, extras)
		
	end

	@ExecSpace("ServerOnly")
	method void LogPlayFlow(string ppsn, string flowType, string reward)
		-- 게임 플레이 흐름을 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		if isvalid(player) == false then
			return
		end
		
		
		local account = player.PlayerAccount.accountTable
		if account == nil then
			return
		end
		local deviceType = ""
		local myPlayer = player.MyPlayer
		if myPlayer ~= nil then
			deviceType = myPlayer.deviceType
		end
		local userLevel = self:NumberToString(account.level)
		local mode = myPlayer.currentGameMode
		local playId = myPlayer.currentStage
		local gameKey = myPlayer.gameKey
		local category = "-1"
		if mode == _GameConfig:GetConfig().GAMEMODE_BASIC then
			category = "0"
		elseif mode == _GameConfig:GetConfig().GAMEMODE_LIMITLAND then
			category = "1"
		elseif mode == _GameConfig:GetConfig().GAMEMODE_RANDOMBOSS then
			category = "2"
		elseif mode == _GameConfig:GetConfig().GAMEMODE_BENCHMARK then
			category = "3"
		elseif mode == _GameConfig:GetConfig().GAMEMODE_FIELD then
			category = "4"
		end
		local value = self:GetPlayerInfoJson(ppsn)
		local extras = {
			category = category,
		    flowType = flowType,
		    playId = playId,
		    reward = reward,
		    deviceType = deviceType,
		    userLevel = userLevel,
		    id = gameKey,	
		
		}
		
		
		if _UtilLogic:IsNilorEmptyString(value) then
			value = "none"
		end
		
		_LogStorageLogic:LogValue(ppsn,self.LogName_PlayFlow,value,extras)
		
	end

	method string GetPlayerInfoJson(string ppsn)
		-- 플레이어 정보를 JSON 형태로 변환
		local player = _UserService:GetUserEntityByUserId(ppsn)
		if isvalid(player) == false then
			return ""
		end
		 
		local weapon = {}
		local armor = {}
		
		for k,v in pairs(player.PlayerStorageComponent:GetAllEquippedWeapon()) do
			table.insert(weapon,{id = v.originalId,level = v.level}	)
		end
		for k,v in pairs(player.PlayerStorageComponent:GetAllEquippedArmor()) do
			table.insert(armor,{id = v.originalId,level = v.level}	)
		end
		local playerCurrenyCata = player.PlayerCurrencyData
		if playerCurrenyCata == nil then
			return ""
		end
		local currencyTable = playerCurrenyCata.currencyTable
		
		
		local currency = _HttpService:JSONEncode({meso = math.tointeger(currencyTable["Gold"].amount),diamond = math.tointeger(currencyTable["Diamond"].amount),essence = math.tointeger(currencyTable["Essence"].amount),scroll = math.tointeger(currencyTable["WeaponScroll"].amount)})
		local soul =  _HttpService:JSONEncode({index = player.PlayerCharacterData.charIndex,lv = player.PlayerCharacterData.charLevel})
		local pet = _HttpService:JSONEncode(player.PlayerPetStorageComponent:GetAllEquipedPets())
		local battle = string.format("%d", player.PlayerInfoComponent.lastBattlePower)
		local account = _HttpService:JSONEncode({ level = player.PlayerAccount.accountTable.level, stage = player.PlayerInfoComponent.playerInfo.stageStep})
		
		local playerInfo = {
			weapon =  _HttpService:JSONEncode(weapon),
			armor =  _HttpService:JSONEncode(armor),
			currency = currency,
			soul = soul,
			pet = pet,
			battle = battle,
			account = account,
		}
		
		 
		return _HttpService:JSONEncode(playerInfo)
	end

	@ExecSpace("ServerOnly")
	method void LogPurchaseFlow(string ppsn, string productId, string source, string assetId, integer price, boolean isSuccess, string failInfo)
		-- 구매 성공/실패를 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		
		if account == nil then
			return
		end
		
		local currencyData = player.PlayerCurrencyData
		
		if isvalid(currencyData) == nil then
			return
		end
		
		local category = ""
		
		if assetId == _GameConfig:GetConfig().WEALTHTYPE_MESO then
			category = "0"
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_DIAMOND then
			category = "1"
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_SCROLL then
			category = "2"
		elseif assetId == _GameConfig:GetConfig().WEALTHTYPE_ESSENCE then
			category = "3"
		elseif assetId == "characteristicCoin" then
			category = "4"
		else
			category = "-1"
		end
		
		
		local userLevel = self:NumberToString(account.level)
		
		local extras = {
			category = category,
			productId = productId,
		    source = source, 
			price = tostring(price),
		    assetId = assetId,
		    userLevel = userLevel
		}
		
		
		
		if isSuccess then
			_LogStorageLogic:LogValue(ppsn, self.LogName_PurchaseSuccess, "PURCHASE SUCCESS", extras)
		else
			_LogStorageLogic:LogValue(ppsn, self.LogName_PurchaseFail, failInfo, extras)
		end
		
	end

	@ExecSpace("ServerOnly")
	method void LogAttendanceFlow(string ppsn, string category, string flowType, integer day)
		-- 출석 관련 흐름을 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if not player.PlayerDBComponent.dbInited then return end
		
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		
		if account == nil then
			return
		
		end
		
		local userLevel = self:NumberToString(account.level)
		
		local extras = {
			category = category,
			flowType = flowType,
		    userLevel = userLevel
		}
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_Attendance, self:NumberToString(day), extras)
	end

	@ExecSpace("ServerOnly")
	method void LogPlayMissionFlow(string ppsn, string category, string flowType, string playMissionId)
		-- 플레이 미션 관련 흐름을 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if not player.PlayerDBComponent.dbInited then 
			_TimerService:SetTimerOnce(function() self:LogPlayMissionFlow(ppsn, category, flowType, playMissionId) end, 1)
			return 
		end
		
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		
		if account == nil then
			_TimerService:SetTimerOnce(function() self:LogPlayMissionFlow(ppsn, category, flowType, playMissionId) end, 1)
			
			return
		end
		
		local userLevel = self:NumberToString(account.level)
		
		local extras = {
			category = category,
			flowType = flowType,
		    userLevel = userLevel,
			playMissionId = playMissionId
		}
		
		if _UtilLogic:IsNilorEmptyString(playMissionId) then
			extras.playMissionId = "null"
			_LogStorageLogic:LogValue(ppsn, self.LogName_PlayMission, "null", extras)
		else
			_LogStorageLogic:LogValue(ppsn, self.LogName_PlayMission, playMissionId, extras)
		end
	end

	@ExecSpace("ServerOnly")
	method void LogBestRecordFlow(string ppsn, string record, string source, string clearId)
		-- 최고 기록 달성을 로그에 기록
		local playerEntity = _UserService:GetUserEntityByUserId(ppsn)
		
		if not playerEntity.PlayerDBComponent.dbInited then return end
		
		if isvalid(playerEntity) == false then
			return
		end
		
		local account = playerEntity.PlayerAccount.accountTable
		
		if account == nil then
			return
		end
		
		local currentStatus = {}
		local willRecord = false
		
		for key, value in pairs(playerEntity.PlayerStorageComponent.storage) do
			if value.equippedSlotNum > 0 then
				currentStatus["Equip" .. value.equippedSlotNum] = value.originalId
			end
		end
		
		for key, value in pairs(playerEntity.PlayerPetStorageComponent.petInventory) do
			if value.equippedSlotNum > 0 then
				currentStatus["Pet" .. tostring(value.equippedSlotNum)] = value.originalId
			end
		end
		
		for key, value in pairs(playerEntity.PlayerCharacterData.charDeckStorage) do
			if value.equipped then
				currentStatus["Soul"] = key
				
				break
			end
		end
		
		currentStatus = _HttpService:JSONEncode(currentStatus)
		
		local userLevel = self:NumberToString(account.level)
		local battlePower = tostring(playerEntity.PlayerInfoComponent.lastBattlePower)
		
		local extras = {
			source = source,
			record = tostring(record),
			clearId = clearId,
			userLevel = userLevel,
			battlePower = battlePower
		}
		
		local rank = 0
		
		if source == "LimitLand" then
			local battlePowerRecordDB = _DataStorageService:GetSortableDataStorage(_RankingLogic.limitLandRecordDBName)
			
			battlePowerRecordDB:GetAsync(ppsn, function(errorCode, key, value)
				if isvalid(value) then 
					extras["value"] = tostring(value)
					_LogStorageLogic:LogValue(ppsn, self.LogName_BestRecord, currentStatus, extras)
				end
			end)
		elseif source == "AccountLevel" then
			local accountLevelRecordDB = _DataStorageService:GetSortableDataStorage("accountLevelRecord")
			
			accountLevelRecordDB:GetAsync(ppsn, function(errorCode, key, value)
				if isvalid(value) then
					extras["value"] = tostring(value)
		
					_LogStorageLogic:LogValue(ppsn, self.LogName_BestRecord, currentStatus, extras)
				end
			end)
		elseif source == "BattlePower" then
			local battlePowerRecordDB = _DataStorageService:GetSortableDataStorage("battlePowerRecord")
			
			battlePowerRecordDB:GetAsync(ppsn, function(errorCode, key, value)
				if isvalid(value) then
					extras["value"] = tostring(value)
					_LogStorageLogic:LogValue(ppsn, self.LogName_BestRecord, currentStatus, extras)
				end
			end)
		end
		
		
	end

	@ExecSpace("ServerOnly")
	method void LogIngameFlow(string ppsn, string flowType, string gameType, table currentStatus, string playId, string playTime, string deviceType, boolean isEnter, table info)
		-- 인게임 플레이 흐름을 로그에 기록
		local player = _UserService:GetUserEntityByUserId(ppsn)
		
		if not player.PlayerDBComponent.dbInited then return end
		
		if isvalid(player) == false then
			return
		end
		
		local account = player.PlayerAccount.accountTable
		
		if account == nil then
			return
		end
		
		local userLevel = self:NumberToString(account.level)
		local myPlayer = player.MyPlayer
		local gameKey = myPlayer.gameKey
		
		local hitCount= info == nil and 0 or info.hit
		local hitCount2=  info == nil and 0 or info.hit2
		local time=  info == nil and 0 or info.time
		local time2=  info == nil and 0 or info.time2
		
		local hit = string.format("%d",hitCount)
		local hit2 = string.format("%d",hitCount2)
		local t = string.format("%d",time)
		local t2 = string.format("%d",time2)
		
		local extras = {
			gameType = gameType,
			flowType = flowType,
			playTime = playTime,
			deviceType = deviceType,
		    id = gameKey,
			playId = playId,
		    userLevel = userLevel,
			hit = hit,
			time = t,
			hit2 = hit2,
			time2 = t2,
		}
		
		
		local newTable = {}
		
		if isEnter then
			for key, value in pairs(currentStatus) do
				if type(value) == "string" and type(key) == "string" then
					newTable[key] = value
				end
			end
		else
			for key, value in pairs(currentStatus) do
				if key == "selectedCard" and not _UtilLogic:IsNilorEmptyString(value) then
					for k, v in pairs(_HttpService:JSONDecode(value)) do
						newTable["card" .. k] = string.format("%s", v)
					end
				elseif key == "status" and not _UtilLogic:IsNilorEmptyString(value) then
					for k, v in pairs(_HttpService:JSONDecode(value)) do
						if type(k) == "string" and isvalid(k) and isvalid(v) then
							newTable["stat_" .. k] = string.format("%.2f", v)
						end
					end
				elseif not _UtilLogic:IsNilorEmptyString(value) then
					for k, v in pairs(_HttpService:JSONDecode(value))do
						newTable["hit" .. k] = string.format("%s/%s/%s/%s", v.type, v.damage, v.attacker, v.skillId)
					end
				end
			end
		end
		
		_LogStorageLogic:LogValue(ppsn, self.LogName_Ingame, _HttpService:JSONEncode(newTable), extras)
	end

	@ExecSpace("Server")
	method void LogIngameFlowExit(string selectedCard, string status, table hitInfo, string deviceType, string stageId, integer mode, Entity playerEntity, string flowType, string playTime, table extraInfo)
		-- 인게임 종료 시 플레이 정보를 로그에 기록
		local currentStatus = {}
		
		currentStatus["selectedCard"] = selectedCard
		currentStatus["status"] = status
		
		
		_WorldLog:LogIngameFlow(playerEntity.PlayerComponent.UserId, flowType, tostring(mode), currentStatus, stageId, playTime, deviceType, false,extraInfo)
	end

	@ExecSpace("ServerOnly")
	method void LogIngameFlowEnter(Entity playerEntity, integer mode, string stageId, string deviceType)
		-- 인게임 진입 시 플레이어 상태를 로그에 기록
		local currentStatus = {}
		
		for key, value in pairs(playerEntity.PlayerStorageComponent.storage) do
			if value.equippedSlotNum > 0 then
				currentStatus["Equip" .. value.equippedSlotNum] = value.originalId
			end
		end
		
		for key, value in pairs(playerEntity.PlayerPetStorageComponent.petInventory) do
			if value.equippedSlotNum > 0 then
				currentStatus["Pet" .. tostring(value.equippedSlotNum)] = value.originalId
			end
		end
		
		for key, value in pairs(playerEntity.PlayerCharacterData.charDeckStorage) do
			if value.equipped then
				currentStatus["Soul"] = tostring(key)
				
				break
			end
		end
		
		_WorldLog:LogIngameFlow(playerEntity.PlayerComponent.UserId, "0", tostring(mode), currentStatus, stageId, "0", deviceType, true,nil)
	end

