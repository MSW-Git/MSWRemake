	@EventSender("Entity", "bbf627d0-8c94-46de-b7a1-9e3606a540ca")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- HP 포션 버튼 클릭 이벤트 (PC)
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		_UserService.LocalPlayer.MultiBattlePlayer:OnUseQuickSlot(1,false,false)
	end

