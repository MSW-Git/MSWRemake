	@ExecSpace("Client")
	method void Init()
		-- 멀티 HUD 매니저 초기화
		self.baseBuffIcon.Enable = false
		self:TurnMinimap(true)
		self.wealthPanel = self.defaultGroup:GetChildByName("WealthPanel")
		self.wealthPanel.Enable= true
		self:RefreshWeaponStatus()
	end

	@ExecSpace("Client")
	method void TurnMinimap(boolean onoff)
		-- 미니맵 활성화/비활성화 처리
		if onoff then
			_TimerService:ClearTimer(self._T.minimapTimer)
			
			self.minimap.Enable = true
			local minimapUI = function()
				self.minimap.MinimapComponent:miniPlayerUI()
			end
			
			self._T.minimapTimer = _TimerService:SetTimerRepeat(minimapUI, 0.1)
		else
			self.minimap.Enable = false
			_TimerService:ClearTimer(self._T.minimapTimer)
		end
	end

	@ExecSpace("Client")
	method void InitWeaponStatus()
		-- 무기 상태 UI 초기화
		self.weaponStatusPanel.MultiPlayerWeaponStatusUIComponent:Init()
		self:RefreshAbility(_UserService.LocalPlayer.PlayerAbilityComponent.ability)
	end

	@ExecSpace("Client")
	method void RefreshWeaponStatus()
		-- 무기 상태 UI 새로고침
		self.weaponStatusPanel.MultiPlayerWeaponStatusUIComponent:Refresh()
		self:RefreshAbility(_UserService.LocalPlayer.PlayerAbilityComponent.ability)
	end

	@ExecSpace("Client")
	method void OffAll()
		-- 모든 HUD 요소 비활성화
		self:SetEnable(false)
		self:TurnMinimap(false)
		self.wealthPanel.Enable= false
		
	end

	method void RefreshGauge()
		-- HP/MP 게이지 새로고침
		local multiPlayer = _UserService.LocalPlayer.MultiBattlePlayer
		if isvalid(multiPlayer) == false then
			return
		end
		
		local hpRatio = multiPlayer.hp /  multiPlayer.maxHp
		local mpRatio = multiPlayer:GetMPRatio()
		self.guageHP.SpriteGUIRendererComponent.FillAmount = hpRatio
		self.guageMP.SpriteGUIRendererComponent.FillAmount = mpRatio
		self.guageHP.TextComponent.Text = string.format("%d/%d",multiPlayer.hp,multiPlayer.maxHp)
		self.guageMP.TextComponent.Text = string.format("%d/%d",multiPlayer.mp,multiPlayer.maxMp)
		
		
	end

	method void RefreshAbility(table ability)
		-- 능력치 UI 새로고침 및 경험치 게이지 업데이트
		local expRatio = 1
		if ability == nil then
			return
		end
		if ability["lvData"] == nil then
			return
		end
		if ability["lvData"].lv < _AbilityLogic.abilityMaxLevel then
			expRatio = ability["lvData"].exp / _AbilityLogic.abilityExpData[ability["lvData"].lv].needToFillExp 
		else
			expRatio = 1
		end
		self.guageEXP.SpriteGUIRendererComponent.FillAmount = expRatio
		self.guageEXP.TextComponent.Text = string.format("%.2f%%",expRatio * 100)
		
		if self.isShowFieldExpByCheat == true then
			self.guageEXP.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr74"),expRatio * 100,ability["lvData"].exp,_AbilityLogic.abilityExpData[ability["lvData"].lv].needToFillExp )
		end
		
		
		local currentCharIndex = string.format("%d",_UserService.LocalPlayer.PlayerCharacterData.charIndex)
		local data = _CharacterLogic.characterTable[currentCharIndex]
		local charName = _LocalizationService:GetText("soul_name_"..currentCharIndex)
		
		self.textLevel.TextComponent.Text = string.format("LV%d %s %s",ability["lvData"].lv,charName,_UserService.LocalPlayer.PlayerComponent.Nickname)
		self:RefreshGauge()
	end

	method void SetEnable(boolean enable)
		-- HUD 그룹 활성화/비활성화 설정
		self.multiHUDGroup.Enable = enable
		
		if enable then
			self:RefreshAbility(_UserService.LocalPlayer.PlayerAbilityComponent.ability)
		end
	end

	method void Refresh()
		-- 다음 프레임에 UI 새로고침 플래그 설정
		self.needToRefresh = true
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- HUD 매니저 초기화 및 UI 요소 참조 설정
		local _T = self._T
		_T.potionHPIcon = self.potionHP:GetChildByName("icon_weapon",true)
		_T.potionMPIcon = self.potionMP:GetChildByName("icon_weapon",true)
		_T.potionHPMobileIcon = self.potionHPMobile:GetChildByName("icon_weapon",true)
		_T.potionMPMobileIcon = self.potionMPMobile:GetChildByName("icon_weapon",true)
		_T.guideIcon = self.Button_Guide
		
		
		_T.potionHPCountText = self.potionHP:GetChildByName("Usable_count",true).TextComponent
		_T.potionMPCountText = self.potionMP:GetChildByName("Usable_count",true).TextComponent
		_T.potionHPMobileCountText = self.potionHPMobile:GetChildByName("Usable_count",true).TextComponent
		_T.potionMPMobileCountText = self.potionMPMobile:GetChildByName("Usable_count",true).TextComponent
		
		_T.emptyPotionHPIcon = self.potionHP:GetChildByName("icon_plus",true)
		_T.emptyPotionMPIcon = self.potionMP:GetChildByName("icon_plus",true)
		
		_T.emptyMobilePotionHPIcon = self.potionHPMobile:GetChildByName("state_empty",true)
		_T.emptyMobilePotionMPIcon = self.potionMPMobile:GetChildByName("state_empty",true)
		
		
		self.baseBuffIcon.Enable = false
		
		if Environment:IsMobilePlatform() then	
			self.panelExpandMenu.UITransformComponent.anchoredPosition.x = -412.5
			self.panelExpandMenu.UITransformComponent.RectSize.x = 775
			return 
		end
		
	end

	method void SetEnableBuffIcon(string type, number endElapsed, string ruid, string tooltip, number duration)
		-- 버프 아이콘 활성화 및 지속 시간 표시
		
		
		---@type Entity
		local icon = self.buffIcons[type]
		
		if isvalid(icon) then
			icon:Destroy()
		end
		if isvalid(icon) == false then
			self.buffIcons[type] = self.baseBuffIcon:Clone("buff"..type)
			icon = self.buffIcons[type]
			icon:ConnectEvent(ButtonClickEvent,function(e) 		
				_TooltipLogic:ShowTooltipByString("",icon,Vector2.zero,tooltip)
				
				local updateToolTipEventId = _TimerService:SetTimerRepeat(function() 
					local remainTime = endElapsed -_LocalTimeLogic:GetElapsedSecond()
					if remainTime > 60 then
						_TooltipLogic:RefreshChangeText(string.format(_LocalizeLogic:GetText("etcStr75"),remainTime/60,remainTime%60))
					elseif remainTime > 0 then
						_TooltipLogic:RefreshChangeText(string.format(_LocalizeLogic:GetText("etcStr76"),remainTime))
					else
						_TooltipLogic:RefreshChangeText(string.format("              ",remainTime))
					end
				end,1,0)
				_TooltipLogic.hideCallback = function() 
					_TimerService:ClearTimer(updateToolTipEventId)
				end
			end)
		end
		
		local iconGUI = icon:GetChildByName("UISprite").SpriteGUIRendererComponent
		local coverGUI = icon:GetChildByName("Buff_Cover").SpriteGUIRendererComponent
		
		iconGUI.ImageRUID = ruid
		
		if self._T.buffTween == nil then
			self._T.buffTween = {}	
		end
		
		if self._T.buffTween[type] ~= nil then
			_TimerService:ClearTimer(self._T.buffTween[type])
			self._T.buffTween[type] = nil	
		end
		icon.Enable = true
		
		self._T.buffTween[type] = _TimerService:SetTimerRepeat(function()
			local remainTime = endElapsed -_LocalTimeLogic:GetElapsedSecond()
			coverGUI.FillAmount = 1 - remainTime / duration
			if remainTime < 0 then
				icon.Enable = false
				_TimerService:ClearTimer(self._T.buffTween[type])
				self._T.buffTween[type] = nil
			end
		end,1)
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 포션 아이콘 및 수량 UI 업데이트
		if self.needToRefresh == false then
			return
		end
		self.needToRefresh = false
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		local storage = _UserService.LocalPlayer.PlayerStorageComponent
		local hpSlot =  ""
		local mpSlot =  ""
		if playerInfo.playerInfo.qSlot ~= nil then
			hpSlot = playerInfo.playerInfo.qSlot[1] 
			mpSlot = playerInfo.playerInfo.qSlot[2] 
		end
		
		local _T = self._T
		
		local hpSlotEnable = _UtilLogic:IsNilorEmptyString(hpSlot) == false
		local mpSlotEnable = _UtilLogic:IsNilorEmptyString(mpSlot) == false
		
		_T.potionHPIcon.Enable = hpSlotEnable
		_T.potionMPIcon.Enable = mpSlotEnable
		_T.potionHPMobileIcon.Enable = hpSlotEnable
		_T.potionMPMobileIcon.Enable = mpSlotEnable
		
		
		if hpSlotEnable then
			local itemData = _ItemDataLogic:GetItemData(hpSlot)
		
		
			if itemData ~= nil then
				_T.potionHPIcon.SpriteGUIRendererComponent.ImageRUID = "thumbnail://".. itemData.ruid
				_T.potionHPMobileIcon.SpriteGUIRendererComponent.ImageRUID = "thumbnail://".. itemData.ruid
			else
				_T.potionHPIcon.Enable = false
				_T.potionHPMobileIcon.Enable = false
			
				
			end
		end
		if mpSlotEnable then
			local itemData = _ItemDataLogic:GetItemData(mpSlot)
		
			
			if itemData ~= nil then
				_T.potionMPIcon.SpriteGUIRendererComponent.ImageRUID = "thumbnail://".. itemData.ruid
				_T.potionMPMobileIcon.SpriteGUIRendererComponent.ImageRUID = "thumbnail://".. itemData.ruid
		
			else
				_T.potionMPIcon.Enable = false
				_T.potionMPMobileIcon.Enable = false
				
		
			end
		end
		
		local hpCount = storage:GetItemCount(hpSlot)
		local mpCount = storage:GetItemCount(mpSlot)
		
		
		_T.potionHPCountText.Text = hpSlotEnable and string.format("%d",hpCount) or ""
		_T.potionMPCountText.Text = hpSlotEnable and string.format("%d",mpCount) or ""
		_T.potionHPMobileCountText.Text = hpSlotEnable and string.format("%d",hpCount) or ""
		_T.potionMPMobileCountText.Text = hpSlotEnable and string.format("%d",mpCount) or ""
		
		
		_T.emptyPotionHPIcon.Enable = not _T.potionHPIcon.Enable
		_T.emptyPotionMPIcon.Enable = not _T.potionMPIcon.Enable
		
		_T.emptyMobilePotionHPIcon.Enable = not _T.potionHPMobileIcon.Enable
		_T.emptyMobilePotionMPIcon.Enable = not _T.potionMPMobileIcon.Enable
		
		
	end

	method void BlinkPosionIcon(string type)
		-- 포션 사용 시 아이콘 깜빡임 효과
		
		local _T = self._T
		if type == "HP" then
			if self._T.blinkHPEventId  ~= nil then
				_TimerService:ClearTimer(self._T.blinkHPEventId)
				self._T.blinkHPEventId = nil
			end
			_T.potionHPIcon.SpriteGUIRendererComponent.Color = Color(0.5,0.5,0.5,1)
			_T.potionHPMobileIcon.SpriteGUIRendererComponent.Color = Color(0.5,0.5,0.5,1)
			
			self._T.blinkHPEventId = _TimerService:SetTimerOnce(function() 
				_T.potionHPIcon.SpriteGUIRendererComponent.Color = Color.white
				_T.potionHPMobileIcon.SpriteGUIRendererComponent.Color = Color.white
				self._T.blinkHPEventId  = nil
			end,1)
		elseif type == "MP" then
			if self._T.blinkMPEventId  ~= nil then
				_TimerService:ClearTimer(self._T.blinkMPEventId)
				self._T.blinkMPEventId = nil
			end
			_T.potionMPIcon.SpriteGUIRendererComponent.Color = Color(0.5,0.5,0.5,1)
			_T.potionMPMobileIcon.SpriteGUIRendererComponent.Color = Color(0.5,0.5,0.5,1)
			self._T.blinkMPEventId = _TimerService:SetTimerOnce(function() 
				_T.potionMPIcon.SpriteGUIRendererComponent.Color = Color.white
				_T.potionMPMobileIcon.SpriteGUIRendererComponent.Color = Color.white
				self._T.blinkMPEventId  = nil
			end,1)
		end
	end

	method void PlayDieTween()
		-- 사망 시 카운트다운 UI 애니메이션
		self.panelDie.Enable = true
		
		local time = 5
		local dieCntEventId = 0
		local nickName = _UserService.LocalPlayer.PlayerComponent.Nickname
		dieCntEventId = _TimerService:SetTimerRepeat(function() 
			self.textDie.Text = string.format(_LocalizeLogic:GetText("etcStr77"),nickName,time)
			time -=1
			if time < 0 then
				self.panelDie.Enable = false
				_TimerService:ClearTimer(dieCntEventId)
			end
		end,1,0)
	end

	method void ClearBuffIcon()
		-- 모든 버프 아이콘 제거 및 타이머 정리
		if self.buffIcons ~= nil then
			for k,v in pairs(self.buffIcons) do
				v:Destroy()
			end
			table.clear(self.buffIcons)
		end
		if self._T.buffTween ~= nil then
			for k,v in pairs(self._T.buffTween) do
				_TimerService:ClearTimer(v)
			end
			table.clear(self._T.buffTween)
		end
	end

	@EventSender("LocalPlayer")
	handler HandleChangePlayerAbilityData(ChangePlayerAbilityData event)
		-- 플레이어 능력치 변경 이벤트 처리
		
		local ability = event.ability
		
		self:RefreshAbility(ability)
	end

	@EventSender("LocalPlayer")
	handler HandleDBLoadedEvent(DBLoadedEvent event)
		-- DB 로드 완료 이벤트 처리 시 UI 새로고침
		local ppsn = event.ppsn
		self:RefreshAbility(_UserService.LocalPlayer.PlayerAbilityComponent.ability)
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f3511af6-46fc-4658-aa56-838508207a23")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 마을로 돌아가기 버튼 클릭 이벤트
		
		local Entity = event.Entity
		_UIPopup:Open(_LocalizeLogic:GetText("popup13"), _LocalizeLogic:GetText("popup14"),function()
			_BattleUIManager.loadingUI:Show()
			_UserService.LocalPlayer.PlayerFieldMapComponent:TeleportToTown()
		end,nil)
	end

	@EventSender("Entity", "76174a56-dc90-4d81-809b-c9393c441093")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 확장 메뉴 버튼 클릭 이벤트
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		
		if self.panelExpandMenu.Enable then
			self.panelExpandMenu.UICommonPopup:Hide()	
		else
			self.panelExpandMenu.UICommonPopup:Show()	
		end
	end

	@EventSender("LocalPlayer")
	handler HandleOnChangeNewMergeItem(OnChangeNewMergeItem event)
		-- 새로운 매지 아이템 변경 이벤트 처리
		local uniqueKey = event.uniqueKey
		local itemData = event.itemData
		if self.multiHUDGroup.Enable == false then
			return
		end
		self:Refresh()
	end

	@EventSender("LocalPlayer")
	handler HandleOnEnterCampFire(OnEnterCampFire event)
		-- 캐프파이어 진입/탈출 이벤트 처리
		local enter = event.enter
		self.enableOpenCampFirePopup = enter
		self.panelFireInfo.Enable = not enter
	end

	@EventSender("Entity", "7fff8590-ea35-4682-a69d-265a92e54cf0")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 창고 버튼 클릭 이벤트 (캐프파이어에서만 사용 가능)
		
		local Entity = event.Entity
		
		if self.enableOpenCampFirePopup == false then
			return
		end
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		_UIGroupManager.uiMergePopup:Show()
	end

	@EventSender("Entity", "de2d78cc-84fd-45ea-8988-9897529a29fe")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 파티 버튼 클릭 이벤트
		
		local Entity = event.Entity
		if _UIGroupManager:IsEnableOpenPopup() == false then
