	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		-- 화면 터치 이벤트 처리 (확장 메뉴 닫기)
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		
		if _InputService:IsPointerOverUI() then return end
		
		if self.panelExpandMenu.UICommonPopup.isOpen then
			self.panelExpandMenu.UICommonPopup:Hide()
		end
	end

	@EventSender("Entity", "39b958d0-c767-4b0d-a7ca-e4d81ed4a61f")
	handler HandleButtonClickEvent14(ButtonClickEvent event)
		-- 캐시샵 버튼 클릭 이벤트 (캐프파이어에서만 사용 가능)
		
		local Entity = event.Entity
		if self.enableOpenCampFirePopup == false then
			return
		end
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		_CashShopLogic.cashShopUI:Show()
	end

	@EventSender("Logic", "InteractionUtil")
	handler HandleOnEnableInteraction(OnEnableInteraction event)
		-- 상호작용 활성화/비활성화 이벤트 처리
		local enable = event.enable
		if self.multiHUDGroup.Enable == false then
			return
		end
		self.weaponStatusPanel.MultiPlayerWeaponStatusUIComponent.fieldSkillMobile.Entity.Enable = not enable
		self.buttonInteractionMobile.Enable = enable
	end

	@EventSender("Entity", "636f65ad-1873-4606-bf56-cc4267e7930e")
	handler HandleButtonClickEvent15(ButtonClickEvent event)
		-- 가이드 버튼 클릭 이벤트
		
		local Entity = event.Entity
		
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		_UIGroupManager.guideUI:Show()
		
	end

	@EventSender("LocalPlayer")
	handler HandleEquipEvent(EquipEvent event)
		-- 장비 장착/해제 이벤트 처리 시 UI 새로고침
		local slotNum = event.slotNum
		local isEquip = event.isEquip
		local uniqueKey = event.uniqueKey
		
		self:Refresh()
	end

end