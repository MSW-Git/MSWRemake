	@ExecSpace("Client")
	method void SetBuffEnable(string itemId, number time)
		-- 버프 활성화 설정
		self:SetBuff(itemId,time)
	end

	method number GetBuffValue(string type)
		-- 지정된 타입의 버프 값 반환
		if self.fieldBuff[type] == nil then
			return 0
		end
		if self.fieldBuff[type].time < _LocalTimeLogic:GetElapsedSecond() then
			return 0
		end
		return self.fieldBuff[type].value
	end

	method void SetBuff(string itemId, number time)
		-- 버프 설정 및 지속 시간 관리
		local elapsed = _LocalTimeLogic:GetElapsedSecond() 
		if time < elapsed then
			return
		end
		local itemData = _ItemDataLogic:GetItemData(itemId)
		local itemOption = itemData.option
		
		if self.fieldBuff[itemOption.buff] == nil then
			self.fieldBuff[itemOption.buff] = {}
		end
		self.fieldBuff[itemOption.buff].value = itemOption.value
		self.fieldBuff[itemOption.buff].time = time
		if self:IsServer() then
			local playerInfo = self.Entity.PlayerInfoComponent.playerInfo
			if playerInfo.fieldBuff == nil then
				playerInfo.fieldBuff = {}
			end
			
			if playerInfo.fieldBuff[itemOption.buff] == nil then
				 playerInfo.fieldBuff[itemOption.buff] = {
					id = itemId,
					time = time
				}
			else
				 playerInfo.fieldBuff[itemOption.buff].id = itemId
				playerInfo.fieldBuff[itemOption.buff].time = time
			end
			
			self:SetBuffEnable(itemId,time,self.Entity.PlayerComponent.UserId)
		else
			if itemOption.buff == "Speed" then
				if self._T.buffSpeedEventId  ~= nil then
					_TimerService:ClearTimer(self._T.buffSpeedEventId)
					self._T.buffSpeedEventId  = nil
				end
				self:SetMovementSpeed(self:GetSpeed())
				self._T.buffSpeedEventId = _TimerService:SetTimerOnce(function()
					self:SetMovementSpeed(self:GetSpeed() - self:GetBuffValue("Speed"))
					self._T.buffSpeedEventId  = nil
				 end,time - _LocalTimeLogic:GetElapsedSecond())
				
		
			end
			local duration = itemOption.duration
			_MultiHUDManager:SetEnableBuffIcon(itemOption.buff,time,itemOption.icon,_LocalizeLogic:GetItemDesc(itemId),duration)
		end
	end

	@ExecSpace("Server")
	method void LoadWeapon()
		-- 서버에서 무기 데이터 로드 및 동기화
		table.clear(self.syncWeaponData)
		table.clear(self.serverWeaponId)
		table.clear(self.weaponKeys)
		table.clear(self.cachedDamageBySlot)
		local weaponData = self.Entity.PlayerStorageComponent:GetAllEquippedWeapon()
			table.sort(weaponData,function(a,b) 
				return a.equippedSlotNum < b.equippedSlotNum
			end)
		for k,v in pairs(weaponData) do
			self.syncWeaponData[v.equippedSlotNum] = _HttpService:JSONEncode(v)
			self.serverWeaponId[v.equippedSlotNum] = v.originalId
			self.weaponKeys[v.equippedSlotNum] = v.uniqueKey
		end
	end

	method number GetWeaponDamageBySlot(integer slot)
		-- 슬롯별 무기 데미지 계산 및 캐시 처리
		if self.cachedDamageBySlot[slot] ~= nil then
			return self.cachedDamageBySlot[slot]
		end
		local itemId = self.serverWeaponId[slot]
		local accDamageRate= 1
		local weaponSpec = _WeaponSpecLogic:GetWeaponSpec(itemId)
		local uniqueKey = self.weaponKeys[slot]
		local physicalWeapon = weaponSpec.attribute == "physical"
		local isMeleeWeapon = false
		local weaponType = weaponSpec.type
		
		local damageByLevel = _CalcLogic:GetWeaponAttackInFieldMap(uniqueKey, self.Entity.PlayerComponent.UserId)
		local status = self.Entity.PlayerCharacterData.statusTable
		
		local playerCharacterData = self.Entity.PlayerCharacterData
		if playerCharacterData == nil then
			return 1
		end
		
		local accStat = _AccessoryLogic:GetStatusTable(self.Entity.PlayerComponent.UserId)
		
		if weaponType == "pistol" then 
			accDamageRate += accStat["1"]
		elseif weaponType == "wristband" then
			accDamageRate += accStat["10"]
		elseif weaponType == "fireStaff" then
			accDamageRate += accStat["7"]
		elseif weaponType == "polearm" then
			accDamageRate += accStat["13"]
			isMeleeWeapon = true
		elseif weaponType == "bow" then
			accDamageRate += accStat["4"]
		elseif weaponType == "fan" then
			accDamageRate += accStat["11"]
		elseif weaponType == "demonSword" then
			accDamageRate += accStat["15"]
			isMeleeWeapon = true
		elseif weaponType == "cannon" then
			accDamageRate += accStat["2"]
		elseif weaponType == "breathShooter" then
			accDamageRate += accStat["5"]
		elseif weaponType == "lightningWand" then
			accDamageRate += accStat["8"]
		elseif weaponType == "soundShooter" then
			accDamageRate += accStat["3"]
		elseif weaponType == "chessPiece" then
			accDamageRate += accStat["9"]
		elseif weaponType == "hammer" then
			accDamageRate += accStat["14"]
			isMeleeWeapon = true
		elseif weaponType == "birdBow" then
			accDamageRate += accStat["6"]
		elseif weaponType == "dagger" then
			accDamageRate += accStat["12"]
			isMeleeWeapon = true
		end
		
		if accDamageRate ~= 0 then
			accDamageRate /= 100
		end
		
		local totalDamage = 1 * (1 + status["totalDamage"])
		local typeDamage = 1 * (1 + status["physicalDamage"])
		
		if not physicalWeapon then 
			typeDamage = 1 * (1 + status["magicalDamage"])
		end
		
		
		
		
		local damageRate = accDamageRate + totalDamage + typeDamage
		
		if isMeleeWeapon == false then 
			local damage = (damageRate) * 
				(
					damageByLevel 
				)
			return damage
		else 
			
			local damage = (damageRate) *
				(
					damageByLevel
				)
		
			return damage
		end
	end

	method number GetWeaponCriticalDamageMultiflyBySlot(integer slot)
		-- 슬롯별 무기 크리티컬 데미지 배율 반환
		local itemId = self.serverWeaponId[slot]
		local weaponSpec = _WeaponSpecLogic:GetWeaponSpec(itemId)
		
		return weaponSpec.criticalDamage / weaponSpec.damage
	end

	method boolean IsEnableUsedPotion(string type)
		-- 포션 사용 가능 여부 확인 (쿨다운 처리)
		if self._T.lastUsedQuickSlotTime == nil then
			self._T.lastUsedQuickSlotTime = {}
		end
		if self._T.lastUsedQuickSlotTime[type] == nil then
			self._T.lastUsedQuickSlotTime[type] = 0
		end
		if (_UtilLogic.ServerElapsedSeconds - self._T.lastUsedQuickSlotTime[type]) < 0.99 then
			return false
		end
		
		self._T.lastUsedQuickSlotTime[type] = _UtilLogic.ServerElapsedSeconds
		return true
	end

	@ExecSpace("ServerOnly")
	method void OnMapLeave(Entity leftMap)
		-- 맵 떠날 때 그리드 시스템에서 제거
		if _UtilLogic:IsNilorEmptyString(self.key) == false then
			local battleMap = leftMap.MultiBattleMap
			local ppsn = self.Entity.PlayerComponent.UserId
			if isvalid(battleMap) then
				battleMap.usersGridTable[self.key][ppsn] = nil
				self.key = ""
			end
		end
	end

	method void AddSP(number sp)
		-- SP 추가 (현재 비어있음)
		
	end

	method void SetSP(number sp)
		-- SP 설정 및 필드 데이터 업데이트
		__base:SetSP(sp)
		if self:IsServer() then
			self.Entity.PlayerInfoComponent.playerInfo.fieldSp = self.sp
		end
	end

	method void UseChargeSkill()
		-- 차지 스킬 사용 및 유효성 검사
		if self.hp <= 0 then 
			return 
		end
		if self:IsEnableSoulSkill() == false then
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage165"),"neg")
			return
		end
		local battleMap = self.Entity.CurrentMap.MultiBattleMap 
		local room = battleMap:GetRoomNumber(self:GetPosition())
		if room < 0 then
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage170"),"neg")
			return
		end
		if room == battleMap.safeAreaRoom then
			_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage160"),"neg")
			return
		end
		if self.sp < self.maxSp then
			_SystemMessageLogic:ShowMessage(string.format(_LocalizeLogic:GetText("systemMessage158"),(self.maxSp - self.sp)*2),"neg")
			return
		end
		
		self:RequestSoulSkill()
		
		
	end

	@ExecSpace("Server")
	method void RequestSoulSkill()
		-- 서버에서 소울 스킬 요청 처리
		if self.sp < self.maxSp then
			return
		end
		self:SetSP(0)
		self:UseSpecialBuff(self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("ServerOnly")
	method void OnMapEnter(Entity enteredMap)
		-- 맵 진입 시 무기 로드
		self:LoadWeapon()
	end

	method boolean IsEnableSuperDash()
		-- 슈퍼 대시 사용 가능 여부 확인
		return self:GetBuffValue("Range") > 0
	end

	method number GetSuperDashSpeed()
		-- 슈퍼 대시 속도 반환
		return self:GetBuffValue("Range")
	end

	method number GetSpeed()
		-- 버프를 고려한 현재 이동 속도 반환
		return __base:GetSpeed() * (1 + self:GetBuffValue("Speed"))
	end

	method boolean IsEnableSoulSkill()
		-- 소울 스킬 사용 가능 여부 확인 (매칭 무기 체크)
		local equippedSoul = self.Entity.PlayerCharacterData.charIndex
		
		for i, weapon in pairs(self.equipGun) do
			if _CharacterLogic:CheckMatchExWeapon(weapon.id, tostring(math.floor(equippedSoul))) then		
				return true
			end
		end
		return false
	end

	method number CalculateMaxHp(string ppsn)
		-- 최대 HP 계산 (능력치 + 액세서리 스테이터스 반영)
		local player = _UserService:GetUserEntityByUserId(ppsn)
		local playerStatus = player.PlayerCharacterData.statusTable
		local accessoryStatus = _AccessoryLogic:GetStatusTable(ppsn)
		
		local abilityHp = _AbilityLogic:GetAbilityHpStatus(ppsn) 
		local outgameHp = playerStatus["maxHp"]
		
		return (abilityHp + outgameHp) * (1 + accessoryStatus["16"] / 100)
	end

	method void UnequipGun(number slot)
		-- 무기 장착 해제 (현재 비어있음)
		
	end

	method number GetEnableUseItemCount(string uniqueKey, integer cnt, boolean auto)
		-- 아이템 사용 가능 개수 계산 및 유효성 검사
		local itemId = self.Entity.PlayerStorageComponent.storage[uniqueKey].originalId
		local itemData = _ItemDataLogic:GetItemData(itemId)
		if itemData == nil then
			return 0
		end
		local storageCnt = self.Entity.PlayerStorageComponent.storage[uniqueKey].count
		local itemOption = itemData.option
		local itemCnt = cnt
		if itemOption.type == "HP" then
			if self.Entity.StateComponent.CurrentStateName == "DEAD" then
				return 0
			end
			if self.hp == self.maxHp then
				if auto == false then
					_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage171"),"pos")
				end
				return 0
			end
			if self:IsEnableUsedPotion(itemOption.type) == false then
				return 0
			end
			_MultiHUDManager:BlinkPosionIcon(itemOption.type)
			itemCnt = math.max(1,math.min(cnt,math.ceil((self.maxHp - self.hp) / (self.maxHp*itemOption.value))))
			if itemCnt > 0 and itemCnt > cnt then
				_SystemMessageLogic:ShowMessage(string.format(_LocalizeLogic:GetText("systemMessage159"),itemCnt),"pos")
			end
		elseif itemOption.type == "MP" then
			if self.Entity.StateComponent.CurrentStateName == "DEAD" then
				return 0
			end
			if self.mp == self.maxMp then
				if auto == false then
					_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage157"),"pos")
				end
				return 0
			end
			if self:IsEnableUsedPotion(itemOption.type) == false then
				return 0
			end
			_MultiHUDManager:BlinkPosionIcon(itemOption.type)
			itemCnt = math.max(1,math.min(cnt,math.ceil((self.maxMp - self.mp) / (self.maxMp*itemOption.value))))
			if itemCnt > 0 and itemCnt > cnt then
				_SystemMessageLogic:ShowMessage(string.format(_LocalizeLogic:GetText("systemMessage159"),itemCnt),"pos")
			end
		elseif itemOption.type == "Buff" then
			if cnt > 1 then
				_UIOnlyConfirmPopUp:Open(_LocalizeLogic:GetText("confirmPopup13"),"",nil)
				return 0
			else
				if self:GetBuffValue(itemOption.buff) > 0 then
					_UIPopup:Open("",_LocalizeLogic:GetText("popup12"),function()
						self.Entity.PlayerStorageComponent:RequestUseItem(uniqueKey,1)
					end,nil)
					return 0
				end
			end
		elseif itemOption.type == "Teleport" then
			local multiBattleMap = self.Entity.CurrentMap.MultiBattleMap
		
			local roomNumber = multiBattleMap:GetRoomNumber(self:GetPosition())
			if roomNumber == multiBattleMap.safeAreaRoom then
				_SystemMessageLogic:ShowMessage(_LocalizeLogic:GetText("systemMessage160"), "neg")
				return 0
			end
			
		end
		
		return itemCnt
	end

	@ExecSpace("Client")
	method void OnDeadOnField()
		-- 필드에서 사망 시 클라이언트 처리 및 리스폰
		
		self.Entity:SendEvent(BattlePlayerHPChange(0, self.maxHp))
		self.Entity.PlayerControllerComponent.Enable = false
		self.isInvincible = true
		self.Entity.MovementComponent.Enable = false
		_MultiHUDManager:PlayDieTween()
		_InputService:SendEvent(KeyDownEvent(KeyboardKey.Escape))
		_InputLogic.joystick.canControl = false
		_InputLogic.joystick:ForceKeyRelease()
		self.Entity.MovementComponent:Stop()
		
		_TimerService:SetTimerOnce(function() 
			self.Entity.MovementComponent:Stop()
			self.Entity:SendEvent(BattlePlayerHPChange(self.maxHp * 0.05, self.maxHp))
			_InputLogic.joystick:ForceKeyRelease()
			self.Entity.PlayerControllerComponent.Enable = true
			self.Entity.PlayerComponent:Respawn()
			self.Entity.MovementComponent.Enable = true
			self.isInvincible = true
			self.Entity.PlayerFieldMapComponent:RespawnCurrentMap()
			_ResourceService:UnloadUnusedResources(0)
			_InputLogic.joystick.canControl = true
		end,5)
		
	end

	method void Dash()
		-- 대시 스킬 사용 및 이동 처리
		if self.hp <= 0 then 
			return 
		end
		if self.stamina < self.needDashStamina then
			return
		end
		
		if self.Entity.KinematicbodyComponent.MoveVelocity:Magnitude() == 0 then
			return
		end
		
		
		if not self.Entity.PlayerControllerComponent.Enable then return end
		
		self._T.lastDashTime = _UtilLogic.ElapsedSeconds
		
		local option = { ["FlipX"] = true, ["PlayRate"] = 2 }
		local moveDelta = self.Entity.KinematicbodyComponent.MoveVelocity:Normalize() * 3 * 1.5
		self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(3 * 1.5)
		local duration =  0.06
		
		if self:IsEnableSuperDash() then
			moveDelta = moveDelta * self:GetSuperDashSpeed()
			self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(3 * 1.5 * 2)
		end
		local lookDirection = self.Entity.PlayerControllerComponent.LookDirectionX
		
		if lookDirection < 0 then
			option.FlipX = false
		else
			option.FlipX = true
		end
		
		if moveDelta.x < 0 then
			option.FlipX = false
		end
		
		_EffectService:PlayEffectAttached("d78c0195e5b9452fbc01aef903ff590a",self.Entity,Vector3.zero,0,Vector3.one, false, option)
		self:ApplyInvincible(0.3)
		self.isDashingNow = true
		self.stamina = self.stamina - self.needDashStamina
		
		self.Entity.PlayerControllerComponent.Enable = false
		self.Entity.KinematicbodyComponent.MoveVelocity = moveDelta
		
		_TimerLogic:SetTimerOnce(function()
			
				self.Entity.KinematicbodyComponent.MoveVelocity = Vector2.zero
			
				local isOpenPoup = _UIGroupManager:IsOpenPlayerControlBlockPopup()
				if isOpenPoup then
					self.Entity.PlayerControllerComponent.Enable = false		
				else
					self.Entity.PlayerControllerComponent.Enable = true
				end
			
				
			
		end, 0.2, "BattlePlayer.Dash_knockback")
		
		_TimerLogic:SetTimerOnce(function()
				self.isDashingNow = false 
				self.Entity.ExtendKinematicbodyComponent:SetVelocityRatio(1)
				local animEvent = BodyActionStateChangeEvent()
				animEvent.needResetAction = true
				if self.Entity.ExtendKinematicbodyComponent.MoveVelocity:Magnitude() == 0 then
					animEvent.ActionState = MapleAvatarBodyActionState.Stand
				else
					animEvent.ActionState = MapleAvatarBodyActionState.Walk
				end
				self.Entity:SendEvent(animEvent)
		end, 0.3, "BattlePlayer.Dash_actionInit")
		
		local animEvent = BodyActionStateChangeEvent()
		animEvent.needResetAction = true
		animEvent.ActionState = MapleAvatarBodyActionState.Fly
		self.Entity:SendEvent(animEvent)
		self.usedDashCount += 1
		
		
		
		_TimerLogic:SetTimerOnce(function()
				_EffectService:PlayEffectAttached("e95dc8def28745c8b8d436ccbfb4c949",self.Entity,Vector3.zero,0,Vector3.one * 1.5)
			end, duration, "BattlePlayer.Dash_PlayerEffect")
		
		if _BuffLogic.appliedBuff.trickery then
			self:UntargetedDash()
			_TimerLogic:SetTimerOnce(function()
					self:SetTargetAfterDash()
				end, 2, "BattlePlayer.Dash_trickeryReset")
		end
		
		
		self.Entity:SendEvent(UseDashEvent())
	end

	@ExecSpace("Server")
	method void RefreshHp()
		-- 서버에서 HP 새로고침 및 비율 유지
		local userId = self.Entity.PlayerComponent.UserId
		local playerStatus = self.Entity.PlayerCharacterData.statusTable
		local accessoryStatus = _AccessoryLogic:GetStatusTable(userId)
		
		local abilityHp = _AbilityLogic:GetAbilityHpStatus(userId) 
		local outgameHp = playerStatus["maxHp"]
		self.hp = math.min(self.maxHp, self.hp)
		
		if self.hp < 0 then
			self:SetFieldHP(0)
		else
			local ratio = self.hp / self.maxHp
			 
			self.maxHp = (abilityHp + outgameHp) * (1 + accessoryStatus["16"] / 100)
			self:SetFieldHP(self.maxHp * ratio)
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleChangePlayerAbilityData(ChangePlayerAbilityData event)
		-- 플레이어 능력치 변경 이벤트 처리 시 MP 및 HP 업데이트
		local ability = event.ability
		local ppsn = event.userId
		self.maxMp = _AbilityLogic:GetAbilityManaStatus(ppsn)
		self.mp = math.min(self.maxMp, self.mp)
		self:RefreshHp()
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleCalculateStatusEvent(CalculateStatusEvent event)
		-- 스테이터스 계산 이벤트 처리 시 HP 새로고침
		local ppsn = event.ppsn
		self:RefreshHp()
	end

end