@Component
script UIExplorePopup extends UICommonPopup

	property Entity rewardSlot = "6478dcb9-ad9f-49e1-8987-43a3f436ff60"

	property Entity goldSlot = "6478dcb9-ad9f-49e1-8987-43a3f436ff60"

	property Entity scrollSlot = "21f4a535-6f83-4a70-9d22-e41c3cba1082"

	property Entity essenceSlot = "f6d2c7e7-2ac7-4928-bb35-7d71e4ff31b9"

	property Entity timeText = "52aeed79-e7ed-4dda-b876-8e1c3c10a181"

	property Entity timeSubText = "115b285e-8fd4-4699-941f-a8da31e147b0"

	property Entity startButton = "ee6e198b-9c39-46a8-8494-6a43c259cb07"

	property Entity getButton = "85be4376-60de-41f9-8571-ea62aec1f2be"

	property Entity playerLevel = "f2b4f0e0-5b0f-4c04-bc21-f13423d81e40"

	method void Show()
		-- 탐색 팝업 표시 (컨텐츠 잠금 상태 확인 후)
		
		if self.Entity.ContentLockComponent:CheckUIAvailable() then
			__base:Show()
			_UIOpenQuestLogic:CheckQuestInProgress("gathering",self.Entity)
		end
	end

	method void Hide()
		-- 탐색 팝업 숨김
		
		__base:Hide()
	end

	@ExecSpace("Client")
	method void ResetAutoGathering()
		-- 자동 수집 상태 초기화 및 UI 리셋
		self.timeText.TextComponent.Text = _LocalizeLogic:GetText("UIExplorePopup_Text_1") 
		self.timeSubText.TextComponent.Text = _LocalizeLogic:GetText("UIExplorePopup_Text_2")
		
		
		self.startButton.Enable = true
		self.goldSlot.Enable = false
		self.scrollSlot.Enable = false
		self.essenceSlot.Enable = false
	end

	@ExecSpace("Client")
	method void RefreshRewardSlots(number totalMinute, string userId)
		-- 수집 시간에 따른 보상 슬롯 갱신
		local user = _UserService:GetUserEntityByUserId(userId)
		
		local hour = math.floor(totalMinute / 60) 
		local minute = math.floor(totalMinute % 60)
		
		local rewardTable = _RewardLogic.gatheringRewardData[_UserService.LocalPlayer.PlayerAccount.accountTable.level]
		local player = _UserService.LocalPlayer
		local curPlayerStage = player.PlayerAccount.accountTable.level 
		
		local rewardSlotRefresh = function()
			if hour < 1 then 
				self.scrollSlot:SetEnable(false)
				self.essenceSlot:SetEnable(false)
			else		
				self.scrollSlot:SetEnable(true)
				self.essenceSlot:SetEnable(true)
			end
			if self.goldSlot.Enable == false then
				self.goldSlot.Enable = true
			end
		
		
			self.goldSlot:GetChildByName("Count").TextComponent.Text = _NumberSeparator:ConvertToMetricPrefixString(
				user.PlayerAutoGathering:GetGatheringRewardTable(user.PlayerAutoGathering.GatherRewardTable["gold"]), "ko") 
			self.scrollSlot:GetChildByName("Count").TextComponent.Text =  _NumberSeparator:ConvertToMetricPrefixString(
				user.PlayerAutoGathering:GetGatheringRewardTable(user.PlayerAutoGathering.GatherRewardTable["scroll"]),"ko") 
			self.essenceSlot:GetChildByName("Count").TextComponent.Text =_NumberSeparator:ConvertToMetricPrefixString(
				user.PlayerAutoGathering:GetGatheringRewardTable(user.PlayerAutoGathering.GatherRewardTable["essence"]),"ko") 
		
		end
		
		if hour < user.PlayerAutoGathering.GatherRewardTable["maxHourTime"].value then 
			
			self.timeText.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UIExplorePopup_Text_3", tostring(hour), tostring(minute))
			self.timeSubText.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UIExplorePopup_Text_4", tostring(user.PlayerAutoGathering.GatherRewardTable["maxHourTime"].value))
		elseif hour >= user.PlayerAutoGathering.GatherRewardTable["maxHourTime"].value then 
			self.timeText.TextComponent.Text = _LocalizationService.LocalTranslator:GetTextFormat("UIExplorePopup_Text_5", tostring(user.PlayerAutoGathering.GatherRewardTable["maxHourTime"].value))
		self.timeSubText.TextComponent.Text = _LocalizeLogic:GetText("UIExplorePopup_Text_6")
		
		end
		
		if _UserService.LocalPlayer.PlayerAccount.accountTable.level ~= nil then
			self.playerLevel.TextComponent.Text = "Lv ".._UserService.LocalPlayer.PlayerAccount.accountTable.level
		end
		
		local avatarUI = _EntityService:GetEntity("f3f657fb-232c-44e9-b0a0-5263e6829878")
		
		local animEvent = BodyActionStateChangeEvent()
		animEvent.needResetAction = false
		animEvent.ActionState = MapleAvatarBodyActionState.Attack
		avatarUI:SendEvent(animEvent)
		
		_TimerService:SetTimerOnce(rewardSlotRefresh, 0)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "ee6e198b-9c39-46a8-8494-6a43c259cb07")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 탐색 시작 버튼 클릭 처리
		
		local Entity = event.Entity
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		 _UserService.LocalPlayer.PlayerAutoGathering:RequestLoadDataInServer() 
		
		
		Entity:SetEnable(false)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "85be4376-60de-41f9-8571-ea62aec1f2be")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 탐색 보상 수령 버튼 클릭 처리
		
		local Entity = event.Entity
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		_UserService.LocalPlayer.PlayerAutoGathering:GetGatheringReward()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "73187497-03f8-41a8-9653-fb7f0ee53c84")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 팝업 닫기 버튼 클릭 처리
		
		local Entity = event.Entity
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		self:Hide()
	end

end