@Component
script Kariaine_Attack3SkillEffect extends SkillEffectObject

	@ExecSpace("ClientOnly")
	method void StartAttack()
		-- 카리아인 공격3 스킬 시작 (지연 후 트리거 활성화)
		self.Entity.TriggerComponent.Enable = false
		
		_TimerLogic:SetTimerOnce(function()
				self.Entity.TriggerComponent.Enable = true
			end, 1.2, "Kariaine_Attack3SkillEffect.StartAttack")
	end

	method void Init(number damage, boolean isPlayerSkill, string weaponUniqueKey, string skillId)
		-- 카리아인 공격3 스킬 이펙트 초기화
		__base:Init(damage,isPlayerSkill,weaponUniqueKey,skillId)
		self.ownerId = "Boss_Kariaine"
	end

end