@Component
script Kariaine_Attack4SkillEffect extends SkillEffectObject

	method void SetTarget(Entity target)
		-- 카리아인 공격4 스킬 타겟 설정 및 방향 조정
		__base:SetTarget(target)
		
		if self.isFaceLeft then
			if self._T.target.TransformComponent.Position.x >= self._T.transform.Position.x then
				self._T.transform.Scale.x = math.abs(self._T.transform.Scale.x) * (-1)
			else
				self._T.transform.Scale.x = math.abs(self._T.transform.Scale.x)
			end
		else
			if self._T.target.TransformComponent.Position.x >= self._T.transform.Position.x then
				self._T.transform.Scale.x = math.abs(self._T.transform.Scale.x)
			else
				self._T.transform.Scale.x = math.abs(self._T.transform.Scale.x) * (-1)
		
			end
		end
	end

end