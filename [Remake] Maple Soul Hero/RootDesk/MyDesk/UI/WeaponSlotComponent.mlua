@Component
script WeaponSlotComponent extends Component

	@HideFromInspector
	property integer slotNum = 0

	property string uniqueKey = ""

	property boolean canEquipState = false

	@ExecSpace("ClientOnly")
	method void UnEquip()
		-- 현재 슬롯에 장착된 무기를 해제하는 확인 팝업을 표시
		local storage = _UserService.LocalPlayer.PlayerStorageComponent
		for key, value in pairs(storage.storage) do
			if value.equippedSlotNum == self.slotNum then
				_UIPopup:Open("",_LocalizeLogic:GetText("popup37"), function()
						storage:UnEquip(key)
					end, nil)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Init(number slotNum)
		-- 무기 슬롯 번호를 설정하고 잠금 아이콘을 비활성화
		self.slotNum = slotNum
		self:SetLockIconEnable(false)
	end

	method void SetWeaponInfo(string uniqueKey)
		-- 무기 슬롯에 연결된 고유 키를 설정
		self.uniqueKey = uniqueKey
	end

	method void SetLockIconEnable(boolean enable)
		-- 무기 슬롯의 잠금 아이콘 활성화 상태를 설정
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 매 프레임마다 호출되는 업데이트 메서드 (현재 빈 구현)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 무기 슬롯 클릭 시 장착 가능 상태에 따라 합성 팝업 표시 또는 토스트 메시지 출력
		
		local Entity = event.Entity
		if self.canEquipState then
			_HUDManager.mergePopup:ShowByButtonClick()
		else
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast157"))
		end
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEquipGunChange(EquipGunChange event)
		-- 무기 장착 변경 시 해당 슬롯의 잠금을 해제
		local uniqueKey = event.uniqueKey
		
		if self.uniqueKey == uniqueKey then
			self:SetLockIconEnable(false)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageStartEvent(StageStartEvent event)
		-- 스테이지 시작 시 무기 슬롯을 잠금 상태로 설정
		self:SetLockIconEnable(true)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageEndEvent(StageEndEvent event)
		-- 스테이지 종료 시 무기 슬롯의 잠금을 해제
		self:SetLockIconEnable(false)
	end

end