@Component
script ExchangeButton extends Component

	property string category = ""

	property number slotNum = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 부모 엔티티 이름을 기반으로 카테고리 설정
		if string.sub(self.Entity.Parent.Name, 1, 6) == "Weapon" then
			self.category = "weapon"
		else
			self.category = "armor_"..string.sub(self.Entity.Parent.Name, 11, -1)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 교체 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
	end

end