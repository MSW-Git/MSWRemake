@Component
script UsableInventory extends Component

	property Entity ItemEntity = "7a18556b-5b0d-4458-bf43-0ad0dfc7ab2d"

	property string tab = ""

	property Entity background = "0f2189b6-1217-42c3-a661-40ff7b7f1765"

	property UIPlayerStatusPopup playerStatusUI = "b301f798-a64d-4e3c-b215-3946d7559b55"

	property boolean needToRefresh = false

	property number requestedTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 사용 가능한 아이템 인벤토리 그리드뷰 초기화
		local gridView = self.Entity.GridViewComponent
		
		gridView.ItemEntity = self.ItemEntity
		gridView.OnRefresh = function(index, entity)
			local filterData = _StorageLogic:GetItemListByCategory(self.tab, "grade")
			local sortingOption = self.playerStatusUI.sortingOption
			
			if sortingOption == 1 then
				filterData = _StorageLogic:GetItemListByCategory(self.tab, "level")
			elseif sortingOption == 2 then
			elseif sortingOption == 3 then
				filterData = _StorageLogic:GetItemListByCategory(self.tab, "id")
			end
			
			if isvalid(filterData) and #table.keys(filterData) > 0 then
				entity.UsableSlotButton.category = self.tab
				entity.UsableSlotButton:SetSlot(filterData[index + 1])
			end
		end
		
		gridView:Refresh(true, true)
		
		
	end

	@ExecSpace("Client")
	method void Refresh()
		-- 인벤토리 새로고침 플래그 설정
		self.needToRefresh = true
	end

	@ExecSpace("Client")
	method void SetEnable(boolean enable)
		-- 인벤토리 활성화/비활성화 설정
		self.Entity:SetEnable(enable) 
	end

	@ExecSpace("Client")
	method void ShowPopup(string uniqueKey)
		-- 아이템 사용 확인 팝업 표시
		local id = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId
		local name = _ItemDataLogic.itemData[id].name
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		
		local str = string.format(_LocalizeLogic:GetText("popup60"), name)
		
		_UIPopup:Open("", str, function() 
			if not _ConsumeLogic:IsCanUseItemInClient(id, 1) then return end
			if self.requestedTime + 0.5 > _UtilLogic.ServerElapsedSeconds then _UIToast:ShowMessage(_LocalizeLogic:GetText("toast23")) return end
			
			self.requestedTime = _UtilLogic.ServerElapsedSeconds
			
			_UIGroupManager.playerStatusPopup.UIPlayerStatusPopup:SetUIInputEnable(false)
			if storage.storage[uniqueKey].originalId == "6_000051" then
				_SelectSoulPiecePopUp:Open()
			else
				storage:RequestUseItem(uniqueKey, 1) 
			end
			end, nil)
	end

	@ExecSpace("Client")
	method void ChangeTab(string tab)
		-- 인벤토리 탭 변경 및 새로고침
		self.tab = tab
		
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 프레임마다 새로고침 필요 시 인벤토리 업데이트
		if self.needToRefresh then
			self.needToRefresh = false
		
			local gridView = self.Entity.GridViewComponent
			local player = _UserService.LocalPlayer
			local playerInfo = player.PlayerInfoComponent.playerInfo
			
			gridView.TotalCount = _StorageLogic:GetItemCountByCategory(self.tab)
			gridView:Refresh(true, true)
			
			if self.tab == "consume" then
				self.playerStatusUI.storageCount.Text = math.floor(gridView.TotalCount).."/"..math.floor(_GameConfig:GetConfig().LIMIT_CONSUMESLOT + playerInfo.consumeStorageSlot)
				
				if gridView.TotalCount >= _GameConfig:GetConfig().LIMIT_CONSUMESLOT + playerInfo.consumeStorageSlot then
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.FromHexCode("#FF6868")
				else
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.white
				end
			elseif self.tab == "decoration" then
				self.playerStatusUI.storageCount.Text = math.floor(gridView.TotalCount).."/"..math.floor(_GameConfig:GetConfig().LIMIT_DECORATIONSLOT)
				
				if gridView.TotalCount >= _GameConfig:GetConfig().LIMIT_DECORATIONSLOT then
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.FromHexCode("#FF6868")
				else
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.white
				end
			elseif self.tab == "etc" then
				self.playerStatusUI.storageCount.Text = math.floor(gridView.TotalCount).."/"..math.floor(_GameConfig:GetConfig().LIMIT_ETCSLOT + playerInfo.etcStorageSlot)
				
				if gridView.TotalCount >= _GameConfig:GetConfig().LIMIT_ETCSLOT + playerInfo.etcStorageSlot then
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.FromHexCode("#FF6868")
				else
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.white
				end
			elseif self.tab == "accessory" then
				self.playerStatusUI.storageCount.Text = math.floor(gridView.TotalCount).."/"..math.floor(_GameConfig:GetConfig().LIMIT_ACCESSORYSLOT + playerInfo.accessoryStorageSlot)
				
				if gridView.TotalCount >= _GameConfig:GetConfig().LIMIT_ACCESSORYSLOT + playerInfo.accessoryStorageSlot then
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.FromHexCode("#FF6868")
				else
					_UIGroupManager.uiPlayerStatusPopup.storageCount.FontColor = Color.white
				end
			end
		end
	end

end