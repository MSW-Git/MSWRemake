@Component
script UIFieldSkillCover extends Component

	property SpriteGUIRendererComponent soulSkillCover = nil

	property Entity soulSkillEff = nil

	property SpriteGUIRendererComponent soulSkillIcon = nil

	property Color enableColor = Color(1,1,1,1)

	property Color disableColor = Color(0,0,0,1)

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 비활성화 색상을 초기화
		self.disableColor = Color.FromHexCode("#818181")
	end

	@EventSender("LocalPlayer")
	handler HandleBattlePlayerSPChange(BattlePlayerSPChange event)
		-- 플레이어 SP 변화에 따라 필드 스킬 커버와 이펙트 상태를 업데이트
		local sp = event.sp
		local maxSp = event.maxSp
		local isField = event.isField
		
		if isField == false then
			return	
		end
		
		
		self.soulSkillCover.FillAmount = sp / maxSp
		local enable = sp>= maxSp
		self.soulSkillEff.Enable = enable
		if enable then
			self.soulSkillIcon.Color = self.enableColor
			self.soulSkillCover.Enable = false
		else
			self.soulSkillIcon.Color = self.disableColor
			self.soulSkillCover.Enable = true
		end
	end

end