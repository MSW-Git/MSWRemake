@Component
script DecorationButtonComponent extends Component

	property string category = ""

	property string uniqueKey = ""

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 장식 버튼 컴포넌트 초기화 및 클릭 이벤트 연결
		self.Entity.Parent:ConnectEvent(ButtonClickEvent, self.OnClick)
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 장식 아이템 클릭 시 아이템 정보 팝업 열기
		if not isvalid(_UserService.LocalPlayer) then return end
		
		if self.uniqueKey == "" or not isvalid(self.uniqueKey) then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast341"))
		else
			_UIGroupManager.uiPlayerStatusPopup.itemInfoPopUp:Open(self.uniqueKey)
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버튼 클릭 이벤트 처리
		
		local Entity = event.Entity
		self:OnClick()
	end

end