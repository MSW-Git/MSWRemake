@Component
script ArmorInventoryUI extends Component

	property Entity contentPanel = "a3a3df9c-800e-4936-b292-6ddbbef3a538"

	property Entity itemEntity = "2439425d-c082-4475-942a-d871264ea174"

	property Entity sortingOptionButton = "9a5ea8ce-9e2b-4696-99cb-f3c5e927e033"

	property Entity sortingMenu = "d789581f-3d1f-422b-bc9c-e5d782a7c3f8"

	property table arrangeTable = {}

	property UIPlayerStatusPopup playerStatusPopUp = "b301f798-a64d-4e3c-b215-3946d7559b55"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 방어구 인벤토리 UI 초기화 및 그리드뷰 설정
		
		local gridView = self.contentPanel.GridViewComponent
		gridView.ItemEntity = self.itemEntity
		gridView.OnRefresh = function(index, entity)
		
			if not isvalid(entity.InventoryItemSlot) then
				entity:AddComponent("InventoryItemSlot")
			end
			
			entity.InventoryItemSlot:Init(self.arrangeTable[index + 1], "armor") 
		end
		gridView:Refresh(true, true)
		self._T.sortingBtnOn = false
	end

	@ExecSpace("Client")
	method void Refresh()
		-- 방어구 인벤토리 목록을 정렬 옵션에 따라 새로고침
		if self.playerStatusPopUp.sortingOption == 0 then
			self.arrangeTable = _ItemDataLogic:GetUniqueKeyListByCategory("armor", _UserService.LocalPlayer.PlayerComponent.UserId)
		else
			if self.playerStatusPopUp.currentCategory == "armor" then
				self.arrangeTable = _UserService.LocalPlayer.PlayerStorageComponent:GetArmorStorageBySorting(self.playerStatusPopUp.sortingOption, _UserService.LocalPlayer)
			end
		end
		
		local gridView = self.contentPanel.GridViewComponent
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		local playerInfo = player.PlayerInfoComponent.playerInfo
		
		gridView.TotalCount = storage:GetAllArmorCount() 
		gridView:Refresh(false, true)
		
		if self.playerStatusPopUp.currentCategory == "armor" or self.playerStatusPopUp.currentCategory == "pet" then
			self.sortingMenu:GetChildByName("Btn_sort_level_ascend").Enable = true
		else
			self.sortingMenu:GetChildByName("Btn_sort_level_ascend").Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "74e45393-6b73-4ef5-85b5-6b7968a4bdaf")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 정렬 옵션 1번 버튼 클릭 처리
		
		local Entity = event.Entity
		self.playerStatusPopUp.sortingOption = 1 
		
		if self.playerStatusPopUp.currentCategory == "armor" then
			self:Refresh()
		else
			_UIGroupManager.usableInven:Refresh()
			_PetUILogic.petList:Refresh()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "da9f2f4f-9b71-46ae-a301-6411bc1a951e")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 정렬 옵션 2번 버튼 클릭 처리
		
		local Entity = event.Entity
		self.playerStatusPopUp.sortingOption = 2 
		
		if self.playerStatusPopUp.currentCategory == "armor" then
			self:Refresh()
		else
			_UIGroupManager.usableInven:Refresh()
			_PetUILogic.petList:Refresh()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "57ceb1aa-b292-4256-be4b-ad5ae1f4b82a")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 정렬 옵션 3번 버튼 클릭 처리
		
		local Entity = event.Entity
		self.playerStatusPopUp.sortingOption = 3 
		
		if self.playerStatusPopUp.currentCategory == "armor" then
			self:Refresh()
		else
			_UIGroupManager.usableInven:Refresh()
			_PetUILogic.petList:Refresh()
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "9a5ea8ce-9e2b-4696-99cb-f3c5e927e033")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 정렬 메뉴 토글 버튼 클릭 처리
		
		local Entity = event.Entity
		if self.sortingMenu.Enable then
			self.sortingMenu:SetEnable(false)
		else
			self.sortingMenu:SetEnable(true)
			if self.playerStatusPopUp.currentCategory == "armor" or self.playerStatusPopUp.currentCategory == "pet" then
				self.sortingMenu:GetChildByName("Btn_sort_level_ascend").Enable = true
			else
				self.sortingMenu:GetChildByName("Btn_sort_level_ascend").Enable = false
			end
		end
	end

end