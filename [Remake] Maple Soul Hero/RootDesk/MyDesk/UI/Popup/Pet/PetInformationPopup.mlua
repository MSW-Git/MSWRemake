@Component
script PetInformationPopup extends UICommonPopup

	method void Show()
		-- 펫 정보 팝업을 화면에 표시
		__base:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "39c06f0f-3330-413f-a221-416a02af388a")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

end