@Component
script UICommonPopup extends Component

	property boolean isOpen = false

	@HideFromInspector
	property CanvasGroupComponent canvasGroup = nil

	property number tweenDuration = 0.2

	@HideFromInspector
	property TransformComponent transform = nil

	property number tweenScale = 0.1

	property boolean togglePlayerController = true

	property boolean isShowTween = false

	property boolean AttachWealthUI = false

	property number timeOut = 10

	property boolean includeESCPopup = true

	method void Show()
		-- 팝업 표시 및 플레이어 컨트롤 비활성화
		if self.isOpen then
			return
		end
		if self.togglePlayerController then
			_UserService.LocalPlayer.MyPlayer:SetControl(false)
		end
		
		
		if self.AttachWealthUI then
			_UIGroupManager:AttachToWealthUIDefaultGroup(false,self.Entity)
		end
		
		if self.includeESCPopup then
			table.insert(_UIGroupManager.selectedPopup,self)
		end
		self.isOpen = true
		
		
		if self.canvasGroup ~= nil then
			self.isShowTween = true
			self.Entity.Enable = true
			self.canvasGroup.Interactable = false
			self.canvasGroup.GroupAlpha = 0
			local tween = _TweenLogic:PlayTween(0,1,self.tweenDuration,EaseType.SineEaseIn,function(value) 
					self.canvasGroup.GroupAlpha = value
					local scale =  1 + self.tweenScale - self.tweenScale * value
					self.transform.Scale = Vector3(scale,scale,1)
					self.canvasGroup.Interactable = true
					
				
			end)
			tween:SetOnEndCallback(function() 
				self.canvasGroup.GroupAlpha = 1
				self.transform.Scale = Vector3.one
				self.isShowTween = false
			end)
			
		else
			self.Entity.Enable = true
		end
	end

	method void Hide()
		-- 팝업 숨김 및 플레이어 컨트롤 활성화
		if self.isOpen == false then
			return
		end
		
		if self.includeESCPopup then
			for k,v in ipairs(_UIGroupManager.selectedPopup) do
				if v == self then
					table.remove(_UIGroupManager.selectedPopup,k)
				end
			end
		end
		
		self.Entity:SendEvent(OnPopupHide(self.Entity))
		
		
		
		if self.AttachWealthUI then
			_UIGroupManager:AttachToWealthUIDefaultGroup(true,nil)
		end
		
		
		self.isOpen = false
		if self.canvasGroup ~= nil then
			self.canvasGroup.Interactable = false
			local tween = _TweenLogic:PlayTween(1,0,self.tweenDuration,EaseType.SineEaseIn,function(value) 
					self.canvasGroup.GroupAlpha = value
					local scale =  1 + self.tweenScale - self.tweenScale * value
					self.transform.Scale = Vector3(scale,scale,1)
			end)
			tween:SetOnEndCallback(function() 
		
				
				self.canvasGroup.Interactable = true
				self.canvasGroup.GroupAlpha = 1
				self.Entity.Enable = false
				self.transform.Scale = Vector3.one
				if self.togglePlayerController then
					_UserService.LocalPlayer.MyPlayer:SetControl(true)
				end
			
				
				self:OnFinishHide()
			end)
			
		else
		
			
			self.Entity.Enable = false
			if self.togglePlayerController then
				_UserService.LocalPlayer.MyPlayer:SetControl(true)
			end
			
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 팝업 초기화 시 컴포넌트 참조 설정
		self.canvasGroup = self.Entity.CanvasGroupComponent
		self.transform = self.Entity.TransformComponent
	end

	method void Toggle()
		-- 팝업 열기/닫기 토글
		if self.isOpen then
			self:Hide()
		else
			self:Show()
		end
	end

	method void OnFinishHide()
		-- 팝업 숨김 완료 시 호출되는 콜백 함수
		
	end

	method void SetUIInputEnable(boolean enable)
		-- UI 입력 활성화/비활성화 및 타임아웃 처리
		if self.canvasGroup == nil then
			return
		end
		self.Entity:SendEvent(OnPopupInputEnable(enable))
		self.canvasGroup.Interactable = enable
		
		if enable == false then
			self._T.timeOutEventId = _TimerService:SetTimerOnce(function()
				self._T.timeOutEventId  = nil
				_UIOnlyConfirmPopUp:Open(_LocalizeLogic:GetText("confirmPopup26"), _LocalizeLogic:GetText("confirmPopup27"),function() 
					self:Hide()
					self.canvasGroup.Interactable = true
				end) 
			end,self.timeOut)
		else
			if self._T.timeOutEventId  ~= nil then
				_TimerService:ClearTimer(self._T.timeOutEventId)
			end
		end
		
	end

	method void ShowByButtonClick()
		-- 버튼 클릭으로 팝업 열기 (연속 클릭 방지)
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		self:Show()
	end

	method void ForceClose()
		-- 강제로 팝업 닫기 (애니메이션 없이)
		if self.isOpen == false then
			return
		end
		
		for k,v in ipairs(_UIGroupManager.selectedPopup) do
			if v == self then
				table.remove(_UIGroupManager.selectedPopup,k)
			end
		end
		
		if self.AttachWealthUI then
			_UIGroupManager:AttachToWealthUIDefaultGroup(true,nil)
		end
		
		self.isOpen = false
		
		if self.canvasGroup ~= nil then
			self.canvasGroup.Interactable = true
			self.canvasGroup.GroupAlpha = 1
			self.Entity.Enable = false
			self.transform.Scale = Vector3.one
			if self.togglePlayerController then
				_UserService.LocalPlayer.MyPlayer:SetControl(true)
			end
		
			
			self:OnFinishHide()
		else
			self.Entity.Enable = false
			if self.togglePlayerController then
				_UserService.LocalPlayer.MyPlayer:SetControl(true)
			end
		end
	end

end