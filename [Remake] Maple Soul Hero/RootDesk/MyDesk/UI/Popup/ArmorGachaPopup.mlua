@Component
script ArmorGachaPopup extends UICommonPopup

	property Entity gachaBoxOpenAnimation = "b81c832c-8cb3-4c2a-951e-32d60b3ada33"

	property Entity soloResultPanel = "6891f291-4007-4bfe-8f9f-a681738c9522"

	property Entity multiResultPanel = "8ee6f77b-0798-47a2-b1a8-37334cc70d0a"

	property table results = {}

	property Entity CloseButton = "9d810859-cd86-4979-8098-a34fb84bce28"

	property Entity GatchaBox = "35225832-b9ee-40e4-a664-2d4c23c51996"

	property boolean canGatcha = false

	property boolean gatchaClear = false

	property Entity openEffect = "f2c036e6-8cbc-4779-a91c-066f63dda902"

	property Entity openEffect_cloned = nil

	property Entity bg_result = "a7a868ce-9663-4e45-8e05-10a25e8d6eda"

	property Entity text_Bottom = "576ce20b-e9e9-4f35-9200-6db5ddd3381d"

	@ExecSpace("Client")
	method void ShowSoloGachaResult(table results)
		-- 단일 가챠 결과 표시
		if #results ~= 1 then
			return
		end
		self:InitResultSlot(self.soloResultPanel:GetChildByName("ArmorItemSlot"), results[1])
		self.soloResultPanel:SetEnable(true)
	end

	@ExecSpace("Client")
	method void ShowMultiGachaResult(table results)
		-- 다중 가챠 결과 표시 (11개)
		if #results ~= 11 then
			return
		end
		
		local num = #results
		for i = 1, num do
			self:InitResultSlot(self.multiResultPanel:GetChildByName("ArmorItemSlot_"..math.floor(i)), results[i])
		end
		
		self.multiResultPanel:SetEnable(true)
	end

	method void InitResultSlot(Entity target, string id)
		-- 가챠 결과 슬롯 초기화 및 이펙트 설정
		
		local armorTable = _ArmorSpecLogic.armorData[id]
		local grade = armorTable.grade
		
		local effect = target:GetChildByName("Effect", true).Children
		
		for i = 1, #effect do
			effect[i].Enable = false
		end
		
			target:GetChildByName("Effect_1", true):SetEnable(true)
			if grade == "unique" then
				target:GetChildByName("Effect_5", true):SetEnable(true)
			elseif grade == "epic" then
				target:GetChildByName("Effect_4", true):SetEnable(true)
			elseif grade == "rare" then
				target:GetChildByName("Effect_3", true):SetEnable(true)
			else 
				target:GetChildByName("Effect_2", true):SetEnable(true)
			end
		
		target.SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetSlotColorRUID(id) 
		target:GetChildByName("ArmorIcon").SpriteGUIRendererComponent.ImageRUID = armorTable.ruid 
		target:GetChildByName("CategorySlot").SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUID(id) 
		target:GetChildByName("CategorySlot"):GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetCategoryIconRUID(id) 
		
		if isvalid(target:GetChildByName("GetGatchaEffect")) and grade ~= "normal" then
			local targetRUID = ""
		
			if grade == "rare" then
				targetRUID = "59022fb08d8b465a9e1b44ddbb5c78de"
				target:GetChildByName("GetGatchaEffect").SpriteGUIRendererComponent.ImageRUID = targetRUID
			elseif grade == "epic" then
				targetRUID = "34e8c32ff00b44e0b694a4e25e673fbd"
				target:GetChildByName("GetGatchaEffect").SpriteGUIRendererComponent.ImageRUID = targetRUID
			elseif grade == "unique" then	
				targetRUID = "10ca913712914d5f95703566f528ce2a"
				target:GetChildByName("GetGatchaEffect").SpriteGUIRendererComponent.ImageRUID = targetRUID
			end
		
				local clone = target:GetChildByName("GetGatchaEffect"):Clone("GetEffect")
			_TimerService:SetTimerOnce(function() 
					_EntityService:Destroy(clone)
					end, 1.33)
		
		end
		
	end

	method void Hide()
		-- 가챠 팝업 숨기기 및 정리
		if self.gatchaClear == false then
			return
		end
		
		__base:Hide()
		self.multiResultPanel:SetEnable(false)
		self.soloResultPanel:SetEnable(false)
		self.CloseButton:SetEnable(false)
		self.bg_result:SetEnable(false)
		self.text_Bottom:SetEnable(false)
		
		if isvalid(self.openEffect_cloned) then
			self.openEffect_cloned:Destroy()
		end
		
		
	end

	method void Show()
		-- 가챠 팝업 표시 및 초기화
		if self.isOpen then return end
		
		self.gatchaClear = false
		self.canGatcha = true
		self.GatchaBox:SetEnable(true)
		__base:Show()
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "35225832-b9ee-40e4-a664-2d4c23c51996")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 가챠 박스 클릭 시 애니메이션 및 결과 표시
		
		local Entity = event.Entity
		if self.canGatcha == false then
			return
		end
		self.canGatcha = false
		self.GatchaBox:SetEnable(false)
		
		local target = self.gachaBoxOpenAnimation:Clone("Effect") 
		target.TransformComponent.Position = self.gachaBoxOpenAnimation.TransformComponent.Position
		_SoundService:PlaySound("94279e495a2d4c60920288e2dd3e302f",1 )
		_SoundService:PlaySound("671f7f86dd914ea8956f5663c0265c06", 1)
		
		_TimerService:SetTimerOnce(function() 
				_EntityService:Destroy(target)
				if	#self.results == 1 then 
					self:ShowSoloGachaResult(self.results)
				else 
					self:ShowMultiGachaResult(self.results)
				end
				self.CloseButton:SetEnable(true)
				table.clear(self.results)
				_TimerService:SetTimerOnce(function() self.gatchaClear = true
			self.text_Bottom:SetEnable(true) 
			end , 3)
				self.bg_result:SetEnable(true)
				self.openEffect_cloned = self.openEffect:Clone("open_Effect")
				local deleteEffect = function()
					self.openEffect_cloned:Destroy()
				
				end
				_TimerService:SetTimerOnce(deleteEffect, 0.8)
		
				 end, 1.5)
		
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		-- 화면 터치 시 가챠 결과 팝업 닫기
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.gatchaClear == false or self.isOpen == false then
			return
		end
		self:Hide()
	end

end