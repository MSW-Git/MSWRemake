@Component
script FieldUnlockPopup extends UICommonPopup

	property any onOk = nil

	property Entity buttonOK = "f88d3356-7c40-4f65-8189-2cb649d3de42"

	property TextComponent textMsg = "4f9a2f34-6404-4a69-ac85-bb8d459ef1c2"

	property TextComponent textCost = "b6f616c6-0a41-41db-8580-87cba1285016"

	property SpriteGUIRendererComponent iconWealth = "3a0879a1-32eb-49f5-9745-be490689c179"

	property TextComponent textNPC = "caacfa6a-f639-4a6a-8fec-dea65b01ece1"

	property AvatarGUIRendererComponent avatar = "88bfaa13-8aca-4582-be5e-c8cbacd98057"

	property any onCancle = nil

	method void Open(string npcName, string msg, string iconRUID, boolean enableOK, string cost, any onOk, any onCancle)
		-- 필드 언락 팝업을 열고 NPC 정보와 비용 표시
		self.onOk = onOk
		self.onCancle = onCancle
		self:Show()
		if enableOK then
			self.buttonOK.TextComponent.FontColor = Color.FromHexCode("#ffffff")
		else
			self.buttonOK.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
		end
		self.buttonOK.UIButton:SetButtonEnable(enableOK)
		self.textMsg.Text = msg
		self.iconWealth.ImageRUID = iconRUID
		self.textNPC.Text = npcName
		self.textCost.Text = enableOK and cost or string.format("<color=#FF6868>%s</color>",cost)
		
	end

	method void Hide()
		-- 팝업을 숨기고 콜백 함수 정리
		self.onOk = nil
		if self.onCancle ~= nil then
			self.onCancle()
		end
		__base:Hide()
	end

	@EventSender("Entity", "498818dd-464d-40f7-a7fe-39e628c8a44f")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 취소 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

	@EventSender("Entity", "f88d3356-7c40-4f65-8189-2cb649d3de42")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 확인 버튼 클릭 시 콜백 실행 후 팝업 닫기
		
		local Entity = event.Entity
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		if self.onOk ~= nil then
			self.onOk()
		end
		self:Hide()
	end

end