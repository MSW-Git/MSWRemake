@Component
script AccessoryInformationPopUpComponent extends UICommonPopup

	property Entity itemInfo = "d75fee31-cdd7-402a-b215-5d599366ba11"

	property Entity bottomPanel = "491981c6-ff8e-4c80-844c-073ecaf72b78"

	property string itemId = ""

	property string uniqueKey = ""

	property Entity reinforceEffect = nil

	property Entity goldHammerEffect = nil

	property Entity useHammerButton = "af09c5ec-7ea8-45d8-974f-97c784e5c6bb"

	property Entity optionLayout = "f9352d53-b639-461e-a6c0-3ca6ca5e8ee6"

	property Entity equipButton = "a2aa9eab-2b0a-4c7d-ae4d-96b33f913b60"

	property Entity unEquipButton = "afbbb124-3c4e-4381-955a-310516d0f974"

	property number requestedTime = 0

	property Entity enchantPopUp = "d8db66a6-a8d3-4a71-8b7b-5e9d55290047"

	property Entity transplantPopUp = "9c07f48b-ae2f-4d1b-b8a8-ac117fc549f1"

	property Entity materialListPopUp = "842d49fa-9956-4d87-bb2a-fa3cea79e712"

	property Entity hammerTooltip = "8ccb0fd5-eb94-4a8b-8f74-84c405d5c523"

	property AccessoryReinforcePopUp reinforcePopUp = "0ac0d320-8b0c-4297-9bda-cf155d5318f8"

	property Entity reinforceArrow = "05706817-6c9f-4bfb-a8c7-1cd40fbe8766"

	property Entity reinforceButton = "fc25dced-b3a3-4765-8ddd-cb7f5c8b464f"

	method void Show()
		-- 액세서리 정보 팝업 표시 및 새로고침
		self:Refresh()
		__base:Show()
	end

	method void Hide()
		-- 액세서리 정보 팝업 숨기기 및 초기화
		__base:Hide()
		self.itemId = ""
		self.uniqueKey = ""
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 액세서리 정보 팝업 초기화 및 이펙트 요소 설정
		__base:OnBeginPlay()
		
		self.reinforceEffect = self.itemInfo:GetChildByName("Reinforce_title"):GetChildByName("text_reinforce"):GetChildByName("effect")
		self.goldHammerEffect = self.itemInfo:GetChildByName("Remain_title"):GetChildByName("text_remain"):GetChildByName("effect")
	end

	@ExecSpace("ClientOnly")
	method void SetItemId(string uniqueKey, string itemId)
		-- 액세서리 아이템 ID와 고유 키 설정
		self.uniqueKey = uniqueKey
		self.itemId = itemId
	end

	@ExecSpace("ClientOnly")
	method void SetItemInfo()
		-- 액세서리 아이템 정보 UI 설정 및 표시
		local itemData = _ItemDataLogic.itemData[self.itemId]
		
		if not isvalid(itemData) then return end
		
		local player = _UserService.LocalPlayer
		
		local nameText = self.itemInfo:GetChildByName("textItemName")
		local categoryIcon = nameText:GetChildByName("icon_category")
		
		local slot = self.itemInfo:GetChildByName("item_slot")
		local slotBgRenderer = slot.SpriteGUIRendererComponent
		local gradeEffect = slot:GetChildByName("Effect")
		local itemIcon = slot:GetChildByName("Icon")
		local equippedText = slot:GetChildByName("equipped")
		local gradeAlphabet = slot:GetChildByName("Grade_Alphabet")
		
		local statusPanel = self.itemInfo:GetChildByName("Status_panel")
		local statusIcon = statusPanel:GetChildByName("icon")
		local statusNameText = statusPanel:GetChildByName("Name")
		local statusValueText = statusNameText:GetChildByName("Value")
		
		local reinforceText = self.itemInfo:GetChildByName("Reinforce_title"):GetChildByName("text_reinforce")
		local remainText = self.itemInfo:GetChildByName("Remain_title"):GetChildByName("text_remain")
		
		nameText.TextComponent.Text = string.format("[%s] %s", _LocalizationService.LocalTranslator:GetText(itemData.grade), _LocalizeLogic:GetItemName(itemData.id))
		nameText.SpriteGUIRendererComponent.Color = Color.FromHexCode(_ItemDataLogic:GetColorCodeByGrade(itemData.grade))
		categoryIcon.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryRUID(_ItemDataLogic:GetAccessoryDetailCategory(self.itemId))
		
		local item = player.PlayerStorageComponent.storage[self.uniqueKey]
		local grade = item.grade
		
		if itemData.grade == "normal" then
			slotBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
		elseif itemData.grade == "rare" then
			slotBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
		elseif itemData.grade == "epic" then
			slotBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
		elseif itemData.grade == "unique" then
			slotBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
		elseif itemData.grade == "legendary" then
			slotBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
		end
		
		itemIcon.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
		itemIcon.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
		gradeAlphabet.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(grade)
		
		if grade == "SSS" then
			gradeEffect.Enable = true
		else
			gradeEffect.Enable = false
		end
		
		equippedText.Enable = false
		
		if item.equippedSlotNum > 0 then 
			equippedText.Enable = true
		end
		
		local detailCategory = _ItemDataLogic:GetAccessoryDetailCategory(self.itemId)
		
		if detailCategory == "ring" then
			statusIcon.SpriteGUIRendererComponent.ImageRUID = "694059274e8a4dbda40faa7702331f7b"
			statusNameText.TextComponent.Text = _LocalizeLogic:GetText("common_IncreaseDamage")
		elseif detailCategory == "earring" then
			statusIcon.SpriteGUIRendererComponent.ImageRUID = "b51e392d219441139df0c67768eaa5b7"
			statusNameText.TextComponent.Text = _LocalizeLogic:GetText("accStr1")
		elseif detailCategory == "necklace" then
			statusIcon.SpriteGUIRendererComponent.ImageRUID = "8040aaafeb2f41e6ab73227785b5aeb7"
			statusNameText.TextComponent.Text = _LocalizeLogic:GetText("EnchantData_17")
		end
		statusValueText.TextComponent.Text = string.format("%s%%", _GameUtil:GetOptimalFloatStr(_AccessoryLogic:GetTotalStatNum(self.uniqueKey, _UserService.LocalPlayer.PlayerComponent.UserId)))
		
		local optionLayout = self.itemInfo:GetChildByName("optionLayout")
		
		for i = 1, 5 do
			local optionKey = string.format("option_%d", i) 
			local entity = optionLayout:GetChildByName(optionKey)
			
			if isvalid(item[optionKey]) then
				if item[optionKey] == "" then
					entity.TextComponent.Text = _LocalizeLogic:GetText("etcStr185")
					entity.TextComponent.FontColor = Color.FromHexCode("#6f6f6f")
					
					entity:GetChildByName("lock").SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID("")
				else
					local parse = _UtilLogic:Split(item[optionKey], "_")
					local optionId = parse[1]
					local stat = tonumber(parse[2])
					local enchantData = _AccessoryLogic.enchantData[optionId]
					local enchantGrade = _AccessoryLogic:GetEnchantGrade(optionId, stat)
					
					entity.TextComponent.Text = string.format("%s : %s%%", _LocalizeLogic:GetEnchantName(optionId), _GameUtil:GetOptimalFloatStr(stat))
					entity.TextComponent.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(enchantGrade))
					
					entity:GetChildByName("lock").SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetOptionSlotRUID(enchantGrade)
				end
				
				entity.Enable = true
			else
				entity.Enable = false
			end
		end
		
		reinforceText.TextComponent.Text = string.format("%d", item.level) 
		remainText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr176"), _AccessoryLogic:GetMaxReinforceCount(grade) - item.level - item.failCount)
		
		if player.PlayerStorageComponent:GetItemCount(_AccessoryLogic.goldHammerId) < 1 or item.level >= _AccessoryLogic:GetMaxReinforceCount(grade) then
			self.useHammerButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
			self.useHammerButton.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.useHammerButton.TextComponent.OutlineColor = Color.FromHexCode("#616161")
		else
			self.useHammerButton.SpriteGUIRendererComponent.ImageRUID = "a96386f9ef2148f48aef7b33234fe032"
			self.useHammerButton.TextComponent.FontColor = Color.white
			self.useHammerButton.TextComponent.OutlineColor = Color.FromHexCode("#3784c4")
		end
		
		if _AccessoryLogic:IsCanReinforce(player.PlayerComponent.UserId, self.uniqueKey) then
			self.reinforceArrow.Enable = true
		else
			self.reinforceArrow.Enable = false
		end
		
		if item.level >= _AccessoryLogic:GetMaxReinforceCount(grade) then
			self.reinforceButton:GetChildByName("FailPercentText").Enable = false
		else
			self.reinforceButton:GetChildByName("FailPercentText").Enable = true
		end
		
		self:SetBottomPanel()
	end

	@ExecSpace("ClientOnly")
	method void SetBottomPanel()
		-- 하단 패널 정보 설정 (강화 재료, 비용, 성공률 등)
		local player = _UserService.LocalPlayer
		
		local infoPanel = self.bottomPanel.Parent
		
		local needStoneIcon = self.bottomPanel:GetChildByName("NeedReinforceStone"):GetChildByName("Icon")
		local needStoneText = self.bottomPanel:GetChildByName("NeedReinforceStone"):GetChildByName("Value")
		local needMesoText = self.bottomPanel:GetChildByName("NeedMeso"):GetChildByName("Value")
		local successPercentText = infoPanel:GetChildByName("Button_Reinforcement"):GetChildByName("FailPercentText")
		local hammerCountText = self.bottomPanel:GetChildByName("NeedHammer"):GetChildByName("Value")
		
		local hammerCount = player.PlayerStorageComponent:GetItemCount(_AccessoryLogic.goldHammerId)
		
		local reinforceData = _AccessoryLogic.accReinforceData[tostring(player.PlayerStorageComponent.storage[self.uniqueKey].level + 1)]
		
		if not isvalid(reinforceData) then
			needStoneIcon.Enable = false
			needStoneText.TextComponent.Text = ""
			needMesoText.TextComponent.Text = ""
			successPercentText.Enable = false
		else
			local needMaterialId = _AccessoryLogic:GetReinforceMaterialId(_ItemDataLogic.itemData[player.PlayerStorageComponent.storage[self.uniqueKey].originalId])
			needStoneIcon.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic.itemData[needMaterialId].ruid
			needStoneIcon.Enable = true
			needStoneText.TextComponent.Text = string.format("%d", reinforceData.materialCount)
			needMesoText.TextComponent.Text = _NumberSeparator:ConvertToMetricPrefixString(reinforceData.meso, "ko")
			successPercentText.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr177"), _GameUtil:GetOptimalFloatStr(reinforceData.percent * 100))
			successPercentText.Enable = true
		end
		
		
		hammerCountText.TextComponent.Text = string.format("%d/1", hammerCount)
		
		if hammerCount <= 0 then
			hammerCountText.TextComponent.FontColor = Color.FromHexCode("#FF6868")
		else
			hammerCountText.TextComponent.FontColor = Color.white
		end
		
		self.equipButton.Enable = false
		self.unEquipButton.Enable = false
		
		if player.PlayerStorageComponent.storage[self.uniqueKey].equippedSlotNum > 0 then 
			self.unEquipButton.Enable = true
		else
			self.equipButton.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 액세서리 정보 새로고침
		self:SetItemInfo()
	end

	@ExecSpace("ClientOnly")
	method boolean IsElapsedRequestedTime()
		-- 요청 시간 간격 확인 (중복 요청 방지)
		if self.requestedTime + 0.2 > _UtilLogic.ServerElapsedSeconds then
			return false
		else
			self.requestedTime = _UtilLogic.ServerElapsedSeconds
			
			return true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a2aa9eab-2b0a-4c7d-ae4d-96b33f913b60")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 장착 버튼 클릭 시 액세서리 장착 처리
		
		local Entity = event.Entity
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		_UserService.LocalPlayer.PlayerStorageComponent:Equip(self.uniqueKey, _ItemDataLogic:GetAccessoryEquipSlotNum(self.itemId))
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "afbbb124-3c4e-4381-955a-310516d0f974")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 장착 해제 버튼 클릭 시 액세서리 해제 처리
		
		local Entity = event.Entity
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		_UserService.LocalPlayer.PlayerStorageComponent:UnEquip(self.uniqueKey)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "89b9a523-41fa-4a79-a8a4-d7f3e0e2d0b8")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 판매 버튼 클릭 시 확인 팝업 표시
		
		local Entity = event.Entity
		if _UtilLogic:IsNilorEmptyString(self.uniqueKey) then return end
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		local str = string.format(_LocalizeLogic:GetText("popup64"), _ItemDataLogic.itemData[self.itemId].name)
		
		_UIPopup:Open(_LocalizeLogic:GetText("popup63"), str, function() 
			_UserService.LocalPlayer.PlayerStorageComponent:RequestSellItem(self.uniqueKey)
			self:Hide()
		end, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "af09c5ec-7ea8-45d8-974f-97c784e5c6bb")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 황금 망치 사용 버튼 클릭 시 처리
		
		local Entity = event.Entity
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.uniqueKey]
		
		if _UserService.LocalPlayer.PlayerStorageComponent:GetItemCount(_AccessoryLogic.goldHammerId) < 1 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast74"))
			
			return
		end
		
		if _AccessoryLogic:GetMaxReinforceCount(item.grade) <= item.level then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast70"))
			
			return
		end
		
		if item.failCount <= 0 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast67"))
			
			return
		end
		
		_UIPopup:Open(_LocalizeLogic:GetText("popup61"), _LocalizeLogic:GetText("popup62"), 
			function() _AccessoryLogic:RequestUseGoldHammer(self.uniqueKey) end, nil)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f990ec9f-8492-4efb-b653-1db44c275dcb")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 숨기기
		
		
		local Entity = event.Entity
		self:Hide()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "fc25dced-b3a3-4765-8ddd-cb7f5c8b464f")
	handler HandleButtonClickEvent6(ButtonClickEvent event)
		-- 강화 버튼 클릭 시 강화 팝업 표시
		
		local Entity = event.Entity
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		self.reinforcePopUp:SetUniqueKey(self.uniqueKey)
		self.reinforcePopUp:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "804cda90-676c-48fc-9a50-0f9028d78cca")
	handler HandleButtonClickEvent7(ButtonClickEvent event)
		-- 인챈트 버튼 클릭 시 인챈트 팝업 표시
		
		local Entity = event.Entity
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		self.enchantPopUp.EnchantPopUp.accUniqueKey = self.uniqueKey
		self.enchantPopUp.EnchantPopUp:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleEquipEvent(EquipEvent event)
		-- 장비 장착/해제 이벤트 처리
		local slotNum = event.slotNum
		local isEquip = event.isEquip
		local uniqueKey = event.uniqueKey
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "bf536d8a-cca6-497d-9d1a-612d5fbca893")
	handler HandleButtonClickEvent8(ButtonClickEvent event)
		-- 이식 버튼 클릭 시 이식 팝업 표시
		
		local Entity = event.Entity
		if not self:IsElapsedRequestedTime() then
			return
		end
		
		self.transplantPopUp.TransplantPopUp.accUniqueKey = self.uniqueKey
		self.transplantPopUp.TransplantPopUp:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "059b433e-e445-4fce-86b4-d7e814e50fc1")
	handler HandleButtonClickEvent9(ButtonClickEvent event)
		-- 망치 툴팁 표시 버튼 클릭 처리
		
		local Entity = event.Entity
		if not self.hammerTooltip.Enable then
			self.hammerTooltip.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "9fd8dd13-330d-4608-9301-b917bead36c1")
	handler HandleButtonClickEvent10(ButtonClickEvent event)
		-- 망치 툴팁 숨기기 버튼 클릭 처리
		
		local Entity = event.Entity
		if self.hammerTooltip.Enable then
			self.hammerTooltip.Enable = false
		end
	end

end