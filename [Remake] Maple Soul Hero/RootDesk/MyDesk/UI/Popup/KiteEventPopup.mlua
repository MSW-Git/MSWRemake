@Component
script KiteEventPopup extends UICommonPopup

	property TextComponent textEventMsg = "c7daa6cb-290c-4927-87f6-9e09053f79da"

	property Entity WishSendButton = "5278987c-369a-4ca9-ae54-c31eb4f25210"

	property TextComponent RemainText = "89d3a461-2b17-4449-8a0a-a65bd1230f29"

	method void Show()
		-- 연 날리기 이벤트 팝업 표시 및 타이머 설정
		
		
		if true then return end
		--[[
		self.RemainText.Text = ""
		
		local enableSend = _UserService.LocalPlayer.KiteFlyPlayerComponent:IsEnableTryToSendKite()
		
		self.WishSendButton.UIButton:SetButtonEnable(enableSend)
		
		self.textEventMsg.Entity.Enable = enableSend
		self.RemainText.Entity.Enable = not enableSend
		
		if enableSend == false then
			
			self._T.checkEventId = _TimerService:SetTimerRepeat(function()
				enableSend = _UserService.LocalPlayer.KiteFlyPlayerComponent:IsEnableTryToSendKite()
				if enableSend then
					self.WishSendButton.UIButton:SetButtonEnable(true)
					self.textEventMsg.Entity.Enable = true
		
					self.RemainText.Entity.Enable = false
					_TimerService:ClearTimer(self._T.checkEventId)
					self._T.checkEventId = nil
				end 
			end,3)
		end
		
		
		
		local updateText = function() 
			local kitePlayer = _UserService.LocalPlayer.KiteFlyPlayerComponent
			if isvalid(kitePlayer) == false then
				return
			end	
			if kitePlayer.inited == false then
				return
			end
				
			local diffTime =  _LocalTimeLogic:GetElapsed() - kitePlayer.time
			
				local timeSpan = TimeSpan(_KiteFlyEventLogic.rewardInterval * 60 - diffTime)
				local mStr = timeSpan:ToFormattedString("mm")
				local secStr = timeSpan:ToFormattedString("ss")
				if (_KiteFlyEventLogic.rewardInterval * 60 - diffTime) > 0 then
					self.RemainText.Text = string.format(_LocalizeLogic:GetText("etcStr189"),mStr,secStr)
		
					
					
				end
		end
		updateText()
		self._T.updateEventId = _TimerService:SetTimerRepeat(function() 
			updateText()
		end,1)
		__base:Show()]]--
	end

	method void Hide()
		-- 팝업 숨김 시 모든 타이머 정리
		__base:Hide()
		if self._T.checkEventId ~= nil then
			_TimerService:ClearTimer(self._T.checkEventId)
			self._T.checkEventId = nil
		end
		
		if self._T.updateEventId  ~= nil then
			_TimerService:ClearTimer(self._T.updateEventId)
			self._T.updateEventId  = nil
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5278987c-369a-4ca9-ae54-c31eb4f25210")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 소원 전송 버튼 클릭 시 이벤트 처리
		
		local Entity = event.Entity
		if true then return end
		
		
		--[[
		
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return 
		end
		
		if _UtilLogic:IsNilorEmptyString(self.textEventMsg.Text) then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast360"))
			return
		
		end
		
		
		
		_KiteFlyEventLogic:RequestRandomDia(self.textEventMsg.Text)
		self:Hide()
		self.textEventMsg.Text = ""]]--
	end

	@EventSender("Entity", "516dcdcf-856f-4f86-9764-f912fad31a18")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		
		self:Hide()
	end

end