@Component
script EnchantPopUp extends UICommonPopup

	property Entity accSlot = "2ce7ba1d-4961-4e01-a932-aa635eb5529f"

	property Entity magicStoneSlot = "634d6429-12d3-47ac-8610-6fe929d3d043"

	property string accUniqueKey = ""

	property string magicStoneUniqueKey = ""

	property AccessoryInformationPopUpComponent accInfo = "3a71eaa2-da46-4afe-9fe1-1c8cedb2e1a7"

	property Entity contentPanel = "9214aa08-c785-40ce-8f37-f82a572fb203"

	property integer selectedOptionNum = 1

	property Entity accButton = "7648a933-79ec-47fc-a138-51f290a59f37"

	property Entity magicalStoneButton = "53850acb-93c1-4260-9ad1-63a6b9203a77"

	property Entity bottomPanel = "a6c59a5e-f525-43d7-81f7-837925849696"

	property Entity clickEffect = "2cbbca31-9ba8-4c7d-875d-a8f8ade6cff3"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 인챈트 팝업 초기화 및 버튼 이벤트 연결
		__base:OnBeginPlay()
		
		self.accButton:ConnectEvent(ButtonClickEvent, self.OnClickAccSlot)
		self.magicalStoneButton:ConnectEvent(ButtonClickEvent, self.OnClickMagicStoneSlot)
		
		local optionPanel = self.contentPanel:GetChildByName("OptionPanel"):GetChildByName("OptionPanel")
		
		for i = 1, 5 do
			local str = string.format("optionSlot_%d", i)
			local slot = optionPanel:GetChildByName(str)
			local button = slot:GetChildByName("bg")
			
			button:ConnectEvent(ButtonClickEvent, function () self:OnClickOptionSlot(i) end)
		end
	end

	method void Show()
		-- 팝업 표시 전 내용 새로고침
		self:Refresh()
		__base:Show()
	end

	method void Hide()
		-- 팝업 숨김 시 선택된 아이템 정보 초기화
		self.accUniqueKey = ""
		self.magicStoneUniqueKey = ""
		self.selectedOptionNum = 1
		
		__base:Hide()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 인챈트 UI 전체 새로고침 및 상태 업데이트
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		
		local accBgRenderer = self.accSlot.SpriteGUIRendererComponent
		local accSprite = self.accSlot:GetChildByName("Sprite")
		local accCategory = self.accSlot:GetChildByName("Category")
		local accReinforceText = self.accSlot:GetChildByName("reinforceText")
		local accGrade = self.accSlot:GetChildByName("Grade_Alphabet")
		
		local optionPanel = self.contentPanel:GetChildByName("OptionPanel"):GetChildByName("OptionPanel")
		local possibleOptionPanel = self.contentPanel:GetChildByName("PossibleOptionPanel"):GetChildByName("PossibleOptionPanel")
		
		local materialText = self.bottomPanel:GetChildByName("MaterialText")
		local mesoText = self.bottomPanel:GetChildByName("MesoText")
		
		self.clickEffect.Enable = false
		
		if self.accUniqueKey == "" then
			accReinforceText.Enable = false
			
			self.accSlot.Enable = false
			accGrade.Enable = false
			
			materialText.TextComponent.Text = ""
			mesoText.TextComponent.Text = ""
		else
			local item = storage.storage[self.accUniqueKey]
			local itemData =  _ItemDataLogic.itemData[item.originalId]
				
			if itemData.grade == "normal" then
				accBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			elseif itemData.grade == "rare" then
				accBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
			elseif itemData.grade == "epic" then
				accBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
			elseif itemData.grade == "unique" then
				accBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
			elseif itemData.grade == "legendary" then
				accBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
			end
			accCategory.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
			accCategory:GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryRUID(_ItemDataLogic:GetAccessoryDetailCategory(item.originalId))
			
			accSprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
			accSprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
			accReinforceText.TextComponent.Text = string.format("%d", item.level)
			accReinforceText.Enable = true
			
			accGrade.SpriteGUIRendererComponent.ImageRUID = _AccessoryLogic:GetAlphabetGradeRUID(item.grade)
			accGrade.Enable = true
			
			for i = 1, 5 do
				local key = string.format("option_%d", i) 
				local slot = optionPanel:GetChildByName(string.format("optionSlot_%d", i))
				local bg = slot:GetChildByName("bg")
				local desc = slot:GetChildByName("desc")
				
				if i == self.selectedOptionNum then
					slot:GetChildByName("selected").Enable = true
				else
					slot:GetChildByName("selected").Enable = false
				end
				
				if isvalid(item[key]) then
					if item[key] ~= "" then
						local parse = _UtilLogic:Split(item[key], "_")
						local optionId = parse[1]
						local stat = tonumber(parse[2])
						
						desc.TextComponent.Text = string.format("%s : %s%%", _LocalizeLogic:GetEnchantName(_AccessoryLogic.enchantData[optionId].id), _GameUtil:GetOptimalFloatStr(stat))
						desc.TextComponent.FontColor = Color.FromHexCode(_GameUtil:GetTextColorByItemGrade(_AccessoryLogic:GetEnchantGrade(optionId, stat)))
					else
						desc.TextComponent.Text = string.format(_LocalizeLogic:GetText("etcStr185"))
						desc.TextComponent.FontColor = Color.FromHexCode("#6f6f6f")
					end
					
					slot.Enable = true
				else
					slot.Enable = false
				end
			end
			
			local userId = _UserService.LocalPlayer.PlayerComponent.UserId
			local accessoryData = _AccessoryLogic.accessoryData[item.originalId]
			local currency = player.PlayerCurrencyData
			local scroll = storage:GetItemCount("105_000001")
			local needScroll = accessoryData.enchantScroll
			local needMeso = accessoryData.enchantMeso
			
			materialText.TextComponent.Text = 
				string.format("%s/%s", _NumberSeparator:ConvertToMetricPrefixString(scroll, "ko"), _NumberSeparator:ConvertToMetricPrefixString(needScroll, "ko"))
			mesoText.TextComponent.Text = 
				string.format("%s/%s", _NumberSeparator:ConvertToMetricPrefixString(currency.gold, "ko"), _NumberSeparator:ConvertToMetricPrefixString(needMeso, "ko"))
			
			if storage:GetItemCount("105_000001") < needScroll then
				materialText.TextComponent.FontColor = Color.FromHexCode("#E55454")
			else
				materialText.TextComponent.FontColor = Color.white
			end
			
			if not _CheckLogic:IsEnoughWealth(userId, _GameConfig:GetConfig().WEALTHTYPE_MESO, needMeso) then
				mesoText.TextComponent.FontColor = Color.FromHexCode("#E55454")
			else
				mesoText.TextComponent.FontColor = Color.white
			end
			
			self.accSlot.Enable = true
		end
		
		local magicStoneBgRenderer = self.magicStoneSlot.SpriteGUIRendererComponent
		local magicStoneSprite = self.magicStoneSlot:GetChildByName("Sprite")
		local magicStoneCategory = self.magicStoneSlot:GetChildByName("Category")
		local countText = self.magicStoneSlot:GetChildByName("CountText")
		
		if self.magicStoneUniqueKey == "" or not isvalid(storage.storage[self.magicStoneUniqueKey]) then
			self.magicStoneSlot.Enable = false
			possibleOptionPanel:GetChildByName("Desc").TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			possibleOptionPanel:GetChildByName("Desc").TextComponent.Text = _LocalizeLogic:GetText("etcStr221")
			self.clickEffect.Enable = true
		else
			local item = storage.storage[self.magicStoneUniqueKey]
			local itemData =  _ItemDataLogic.itemData[item.originalId]
				
			if itemData.grade == "normal" then
				magicStoneBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
			elseif itemData.grade == "rare" then
				magicStoneBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
			elseif itemData.grade == "epic" then
				magicStoneBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
			elseif itemData.grade == "unique" then
				magicStoneBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
			elseif itemData.grade == "legendary" then
				magicStoneBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
			end
			magicStoneCategory.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(itemData.grade)
			magicStoneCategory:GetChildByName("CategoryIcon").SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryRUID(itemData.category)
			
			local optionData = _AccessoryLogic.enchantData[itemData.fixedItem]
			
			local optionName = _LocalizeLogic:GetEnchantName(optionData.id)
			
			if itemData.fixedItem == "28" then
				optionName = _LocalizeLogic:GetText("etcStr222")
			end
			
			possibleOptionPanel:GetChildByName("Desc").TextComponent.FontColor = Color.white
			possibleOptionPanel:GetChildByName("Desc").TextComponent.Text = 
				string.format("%s\n(%s%% ~ %s%%)", optionName, _GameUtil:GetOptimalFloatStr(optionData.min), _GameUtil:GetOptimalFloatStr(optionData.max))
			magicStoneSprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
			magicStoneSprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
			countText.TextComponent.Text = string.format("%d", item.count)
			
			self.magicStoneSlot.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void OnClickAccSlot()
		-- 액세서리 슬롯 클릭 시 재료 목록 팝업 열기
		self.accInfo.materialListPopUp.MaterialListPopUp:SetCategory("Enchant", "accessory", "normal")
		self.accInfo.materialListPopUp.MaterialListPopUp:Show()
	end

	@ExecSpace("ClientOnly")
	method void OnClickMagicStoneSlot()
		-- 마법석 슬롯 클릭 시 재료 목록 팝업 열기
		self.accInfo.materialListPopUp.MaterialListPopUp:SetCategory("Enchant", "magicStone", "normal")
		self.accInfo.materialListPopUp.MaterialListPopUp:Show()
	end

	@ExecSpace("ClientOnly")
	method void OnClickOptionSlot(integer slotNum)
		-- 옵션 슬롯 클릭 시 선택 옵션 변경
		self.selectedOptionNum = slotNum
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "d075c4c0-6f7f-415e-bf93-0df044058c24")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 인챈트 실행 버튼 클릭 시 유효성 검사 후 인챈트 요청
		
		local Entity = event.Entity
		if not self.accInfo:IsElapsedRequestedTime() then return end
		if self.accUniqueKey == "" then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast359"))
			
			return
		end
		
		if self.magicStoneUniqueKey == "" then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast358"))
			
			return
		end
		
		local str = string.format(_LocalizeLogic:GetText("etcStr186"))
		
		_UIPopup:Open(_LocalizeLogic:GetText("common_Enchant"), str, function()
			_AccessoryLogic:RequestEnchant(self.accUniqueKey, self.magicStoneUniqueKey, self.selectedOptionNum)
			self.accInfo.requestedTime = _UtilLogic.ServerElapsedSeconds
		end, nil)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "d0598a00-9c21-4300-b461-c0b26b5fbabe")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

end