@Component
script ArmorBatchLevelupPopup extends UICommonPopup

	property string uniqueKey = ""

	property Entity currentLevel = "aa064c7a-7bc3-4aca-a9e9-fa35d5436907"

	property Entity nextLevel = "0cfe8569-998c-4978-980c-c9094fb4c694"

	property Entity maxLevel = "2d945869-bf0f-42a7-afc6-a79a59bab2a1"

	property Entity meso = "ba05d30a-5c85-41fc-a5f2-193aaf72c418"

	property Entity scroll = "ed4a688c-a26e-4b2f-91f4-de65d77e2ff2"

	property Entity canUpgrade = "c7c3d3a6-848c-453a-928c-e664a480d34b"

	property Entity cantUpgrade = "5e36b895-f958-4f98-ba91-c0ea1ff9646c"

	property Entity levelupButton = "54f39395-8d0b-4d8d-83ae-4348910c3e99"

	property boolean canLevelup = false

	property Entity LevelUpEffect = "96c994ea-74e4-4804-9fe7-f0e73b76520a"

	method void Hide()
		-- 방어구 일괄 레벨업 팝업 숨기기 및 초기화
		__base:Hide()
		self.canUpgrade.Enable = false
		self.cantUpgrade.Enable = false
		self.canLevelup = false
		
		self.uniqueKey = ""
	end

	method void ShowByButtonClick()
		-- 버튼 클릭으로 팝업 표시
		__base:ShowByButtonClick()
	end

	method void RefreshMainPanel()
		-- 메인 패널 정보 새로고침 및 일괄 레벨업 가능 여부 확인
		
		local item = _UserService.LocalPlayer.PlayerStorageComponent.storage[self.uniqueKey]
		local itemData = _ItemDataLogic.equipmentData[item.originalId]
		local currency = _UserService.LocalPlayer.PlayerCurrencyData.currencyTable
		
		if item == nil or itemData == nil or self.uniqueKey == nil then
			return
		end
		
		local needGold =  0 
		local needScroll = 0 
		
		local armorLevelupData = _ArmorSpecLogic.armorLevelUpData
		local levelUpCount = 0
		local failedMessage = ""
		
		for i = item.level, #armorLevelupData do
		
			if i >= itemData.maxLevel then 
				failedMessage = _LocalizeLogic:GetText("toast15")
				break
			end
			
			needGold = needGold + tonumber(_ArmorSpecLogic.armorLevelUpData[i + 1].needGold)
			needScroll = needScroll + tonumber(_ArmorSpecLogic.armorLevelUpData[i + 1].needScroll)
		
			if currency["Gold"].amount < needGold or currency["WeaponScroll"].amount < needScroll then
				failedMessage = _LocalizeLogic:GetText("toast16")
				needGold = needGold - tonumber(_ArmorSpecLogic.armorLevelUpData[i + 1].needGold)
				needScroll = needScroll - tonumber(_ArmorSpecLogic.armorLevelUpData[i + 1].needScroll) 
				break
			else
				levelUpCount = levelUpCount + 1
			end
		end
		
		if levelUpCount == 0 then
			self.canUpgrade.Enable = false
			self.cantUpgrade.Enable = true
			
			self.maxLevel.TextComponent.Text = item.level
			self.levelupButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
			self.levelupButton.TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.levelupButton.TextComponent.OutlineColor = Color.FromHexCode("#616161")
			
			self.canLevelup = false
			self.cantUpgrade:GetChildByName("message").TextComponent.Text = failedMessage
		else
			self.canUpgrade.Enable = true
			self.cantUpgrade.Enable = false
			
			self.currentLevel.TextComponent.Text = item.level
			self.nextLevel.TextComponent.Text = item.level + levelUpCount
		
			self.meso.TextComponent.Text = needGold
			self.scroll.TextComponent.Text = needScroll
			
			self.levelupButton.SpriteGUIRendererComponent.ImageRUID = "fc7aab99a8e549e58d891d50f594ecd6"
			self.levelupButton.TextComponent.FontColor = Color.white
			self.levelupButton.TextComponent.OutlineColor = Color.FromHexCode("#589334")
			
			self.canLevelup = true
		end
	end

	method void Open(string uniqueKey)
		-- 지정된 방어구로 일괄 레벨업 팝업 열기
		self.uniqueKey = uniqueKey
		self:RefreshMainPanel()
		self:ShowByButtonClick()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "54f39395-8d0b-4d8d-83ae-4348910c3e99")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 일괄 레벨업 버튼 클릭 시 실행
		
		local Entity = event.Entity
		if self.canLevelup == true then
			_ArmorSystemLogic:BatchLevelUp(self.uniqueKey)
			local effect = self.LevelUpEffect:Clone("Effect")
			_TimerService:SetTimerOnce(function() effect:Destroy() end, 0.8)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a8d9f994-54c8-4087-abbf-5e87ef2d6f3e")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 숨기기
		
		local Entity = event.Entity
		self:Hide()
	end

end