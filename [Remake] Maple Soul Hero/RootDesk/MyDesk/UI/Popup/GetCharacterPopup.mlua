@Component
script GetCharacterPopup extends UICommonPopup

	property string index = ""

	property Entity slot = "ddaacdf0-c82c-495d-86e4-dc0c5344378f"

	@ExecSpace("Client")
	method void Init(string index)
		-- 캐릭터 인덱스로 슬롯 초기화 후 팝업 표시
		self.index = index
		_UIGroupManager:SetCharacterSlot(self.slot, self.index)
		self:Show()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "51b01669-b4dc-4d97-bc89-220170f33446")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐릭터 획득 버튼 클릭 시 서버에 요청
		
		local Entity = event.Entity
		_CharacterLogic:RequestGetCharacterFromClient(self.index)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "c3b5cff3-d819-4382-9b21-bf426e60437d")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 취소 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

end