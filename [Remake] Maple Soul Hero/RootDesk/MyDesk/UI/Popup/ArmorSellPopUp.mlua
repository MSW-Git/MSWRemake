@Component
script ArmorSellPopUp extends UICommonPopup

	property Entity slot = "6375adb9-a845-4d8f-8156-968409cd133e"

	property Entity price = "240e5802-ed3a-4a27-b450-273c95a23bc9"

	property Entity sellPopup = "29f12784-dc0e-4c95-b06a-728b386b1f42"

	property Entity checkPopup = "f05e50b4-7878-426c-b7d8-14d7ef088ad1"

	property string uniqueKey = ""

	property Entity armorInformationUI = "1e53cb2f-bf1d-49d6-a663-28399405fcb4"

	property Entity goldPrice = "697f4b80-176a-43ce-b020-438dd6b308ae"

	@ExecSpace("Client")
	method void Init(string uniqueKey)
		-- 방어구 판매 팝업 초기화 및 가격 설정
		
		_UIGroupManager:SetItemSlot(self.slot, 2, uniqueKey, "") 
		
		local originalId = _UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId
		local grade = _ItemDataLogic.equipmentData[originalId].grade
		
		self.price.TextComponent.Text = _ArmorSpecLogic.armorSellPriceData[grade].scroll
		self.goldPrice.TextComponent.Text = _ArmorSpecLogic.armorSellPriceData[grade].meso
		
		self.uniqueKey = uniqueKey
		self:Show()
	end

	method void Hide()
		-- 방어구 판매 팝업 숨기기 및 초기화
		__base:Hide()
		self.uniqueKey = ""
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f2ed7332-46bc-490c-8577-acf38410bbcf")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 판매 확인 버튼 클릭 시 방어구 판매 실행
		
		local Entity = event.Entity
		if self.uniqueKey ~= ""then
			self.armorInformationUI.ArmorInformationUI:CloseInventory()
			_ArmorSystemLogic:SellArmor(self.uniqueKey)
			self:Hide()
			self.uniqueKey = ""
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "706c071d-b2d6-44d2-af66-061068337167")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 취소 버튼 클릭 시 팝업 숨기기
		
		local Entity = event.Entity
		
		self:Hide()
		
	end

end