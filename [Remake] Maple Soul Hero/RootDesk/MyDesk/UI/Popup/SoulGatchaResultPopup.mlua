@Component
script SoulGatchaResultPopup extends UICommonPopup

	property Entity gachaBoxOpenAnimation = "ddba45da-878c-4d03-8554-a2457636f20f"

	property Entity soloResultPanel = "52ada174-1ed6-486d-8858-c6b53b2e3227"

	property Entity multiResultPanel = "2331c175-0648-464f-8e76-3bc96edc62f8"

	property table results = {}

	property table essence_results = {}

	property Entity closeButton = "d3e9f57d-1a05-4da8-adbe-c73ff7bb5a0d"

	property Entity openBox = "151bf032-9b68-4cd7-87a8-994d344e19e4"

	property boolean canGatcha = false

	property boolean gatchaClear = false

	property Entity openEffect = "604eb604-7ac2-48a2-af6c-31f5d11afae0"

	property Entity openEffect_cloned = nil

	property Entity bg_result = "3aace6ab-077a-4651-b866-31cb78892163"

	property table meso_results = {}

	property Entity text_Bottom = "8feeeb5e-fc9b-4123-918d-0210aa336d86"

	@ExecSpace("Client")
	method void ShowSoloGachaResult(table results)
		-- 단일 가차 결과 표시
		
		if #results ~= 1 then
			return
		end
		
		self:SetResultSlot(results[1], self.soloResultPanel:GetChildByName("Card"))
		self.soloResultPanel:GetChildByName("Card"):GetChildByName("essence_count",true).TextComponent.Text = tostring(self.essence_results[1])
		self.soloResultPanel:GetChildByName("Card"):GetChildByName("gold_count",true).TextComponent.Text = tostring(self.meso_results[1])
		self.soloResultPanel:SetEnable(true)
	end

	@ExecSpace("Client")
	method void ShowMultiGachaResult(table results)
		-- 11연차 가차 결과 표시
		if #results ~= 11 then
			return
		end
		
		for i = 1, #results do
			self:SetResultSlot(results[i], self.multiResultPanel:GetChildByName("Card_"..math.floor(i)))
			self.multiResultPanel:GetChildByName("Card_"..math.floor(i)):GetChildByName("essence_count",true).TextComponent.Text = tostring(self.essence_results[i])
			self.multiResultPanel:GetChildByName("Card_"..math.floor(i)):GetChildByName("gold_count",true).TextComponent.Text = tostring(self.meso_results[i])
		end
		
		self.multiResultPanel:SetEnable(true)
	end

	@ExecSpace("Client")
	method void SetResultSlot(string index, Entity slot)
		-- 가차 결과 슬롯에 캐릭터 정보 설정
		local character = _UserService.LocalPlayer.PlayerCharacterData
		local charLevel = 0
		local charTier = 0
		
		local bar = slot:GetChildByName("bar", true)
		local count = slot:GetChildByName("pieceCount", true)
		local essence_count = slot:GetChildByName("essence_count", true)
		local charDeck = character.charDeckStorage[tonumber(index)]
		
		local lock = slot:GetChildByName("lock", true)
		local outline = slot:GetChildByName("outline", true)
		
		slot.SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[index].pieceLargeRUID
		slot:GetChildByName("name").TextComponent.Text = _LocalizationService:GetText("soul_name_"..index)
		slot:GetChildByName("pieceIcon", true).SpriteGUIRendererComponent.ImageRUID = _CharacterLogic.characterTable[index].pieceRUID	
		
		if isvalid(charDeck) then 
			charLevel = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(index)].level
			charTier = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(index)].tier
		end
		
			local maxPieceCount = _CharacterLogic:GetMaxPieceCount(charTier, math.floor(tonumber(index)), _UserService.LocalPlayer)
		
			bar.Parent.SpriteGUIRendererComponent.ImageRUID = "f7964d3e9b344d5daa7d663a10557837"
		
			local charPieceTable = character.charPieceStorage
			bar.SliderComponent.Value = charPieceTable[tonumber(index)].count/maxPieceCount
			count.TextComponent.Text = math.floor(charPieceTable[tonumber(index)].count).."/"..math.floor(maxPieceCount)	
			bar.SliderComponent.FillRectImageRUID = "7ed0e6e6e26c44e792c0e405ca96a980"
			bar.Parent.Enable = true
		
		
			
			if isvalid(charDeck) then
				lock.Enable = false
				if charDeck.tier < 5 then
			
					if charPieceTable[tonumber(index)].count >= maxPieceCount then
						outline.Enable = true
					else
						outline.Enable = false
					end
				else 
					count.TextComponent.Text = "MAX!"
				end
			else
				if charPieceTable[tonumber(index)].count >= maxPieceCount then
					lock.Enable = false
					outline.Enable = true
				else
					lock.Enable = true
					outline.Enable = false
					bar.SliderComponent.FillRectImageRUID = "7ed0e6e6e26c44e792c0e405ca96a980"
				end
			end
		
	end

	method void Show()
		-- 가차 결과 팝업 표시 및 초기 상태 설정
		if self.isOpen then return end
		
		self.Entity.Parent:SetEnable(true)
		self.gatchaClear = false
		self.canGatcha = true
		self.openBox:SetEnable(true)
		__base:Show()
		
	end

	method void Hide()
		-- 가차 결과 팝업 숨김 및 정리
		if self.gatchaClear == false then
			return
		end
		
		if isvalid(self.openEffect_cloned) then
			self.openEffect_cloned:Destroy()
		end
		self.bg_result:SetEnable(false)
		self.Entity.Parent:SetEnable(false)
		__base:Hide()
		self.multiResultPanel:SetEnable(false)
		self.soloResultPanel:SetEnable(false)
		self.closeButton:SetEnable(false)
		self.text_Bottom:SetEnable(false)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 팝업 초기화 시 가차 박스 애니메이션 비활성화
		__base:OnBeginPlay()
		self.gachaBoxOpenAnimation.Enable = false
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "151bf032-9b68-4cd7-87a8-994d344e19e4")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 가차 박스 열기 버튼 클릭 시 애니메이션 실행
		
		local Entity = event.Entity
		if self.canGatcha == false then
			return
		end
		self.canGatcha = false
		self.openBox:SetEnable(false)
		
		local target = self.gachaBoxOpenAnimation:Clone("Effect")
		target.TransformComponent.Position = self.gachaBoxOpenAnimation.TransformComponent.Position
		
		_SoundService:PlaySound("94279e495a2d4c60920288e2dd3e302f",1 )
		_SoundService:PlaySound("671f7f86dd914ea8956f5663c0265c06", 1)
		
		_TimerService:SetTimerOnce(function() 
				_EntityService:Destroy(target)
				if #self.results == 1 then 
					self:ShowSoloGachaResult(self.results)
				else 
					self:ShowMultiGachaResult(self.results)
				end
				self.closeButton:SetEnable(true)
		
				table.clear(self.results)
				_TimerService:SetTimerOnce(function() 
					self.gatchaClear = true
					self.text_Bottom:SetEnable(true)
				end , 3)
			
				self.bg_result:SetEnable(true)
				self.openEffect_cloned = self.openEffect:Clone("open_Effect")
		
				local deleteEffect = function()
					self.openEffect_cloned:Destroy()
				end
				_TimerService:SetTimerOnce(deleteEffect, 0.8)
		end, 1.5)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		-- 화면 터치 시 가차 결과 팝업 닫기
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if self.gatchaClear == false or self.isOpen == false then
			return
		end
		self:Hide()
	end

end