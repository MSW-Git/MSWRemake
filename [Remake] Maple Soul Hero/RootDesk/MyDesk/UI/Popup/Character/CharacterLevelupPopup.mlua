@Component
script CharacterLevelupPopup extends UICommonPopup

	property TextComponent currentLevel = "8ab87bb2-54f0-48bf-a450-5856cd6b8245"

	property TextComponent nextLevel = "1ccf52f8-bbae-4ad4-81b2-96f330fdde75"

	property TextComponent needGold = "d456ee87-4734-4d10-9ec0-e827920a3691"

	property TextComponent needEssence = "83ff43e1-7e6c-4c10-8ac9-acba20822540"

	property Entity maxLevelPanel = "4506439d-0e39-42d2-a586-3f80d95f2b5a"

	property Entity noneMaxLevelPanel = "e245e14f-840d-4a01-be09-c6ef03a9bf32"

	property Entity EnablePanel = "959f005b-d53e-4c65-bbdb-55be008d7d01"

	property Entity DisablePanel = "8a6208aa-9858-4a67-bd6a-b5e6eee15b9a"

	property Entity upEffect = "fa9a203f-15ec-4518-8f84-e236e7fb4103"

	@ExecSpace("Client")
	method void Init(integer charId, boolean showPopup)
		-- 캐릭터 레벨업 팝업 초기화 및 비용 계산
		local myCharData = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[charId]
		local currencyData = _UserService.LocalPlayer.PlayerCurrencyData.currencyTable
		
		
		self.EnablePanel:SetEnable(false)
		self.DisablePanel:SetEnable(false)
		local maxLv=  self.DisablePanel:GetChildByName("maxLevel", true)
		
		
		self._T.upButton.TextComponent.FontColor = Color.FromHexCode("#D1D1D1")
		self._T.upButton.TextComponent.OutlineColor = Color.FromHexCode("#616161")
		
		
		if myCharData.level >= 50 then 
			self.DisablePanel:SetEnable(true)
			self.DisablePanel:GetChildByName("message", true).TextComponent.Text = _LocalizeLogic:GetText("ui_charLvUpPopup_disablePanel_state_1")
			maxLv.TextComponent.Text = tostring(_CharacterLogic.charMaxLevel)
			self._T.upButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
			
		else
			local needGold = tonumber(_CharacterLogic:GetCharLevelupGoldCost("gold", myCharData.level))	
			local needEssence = tonumber(_CharacterLogic:GetCharLevelupGoldCost("essence", myCharData.level))
		
			if myCharData.level >= myCharData.maxLevel then 
				self._T.upButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
				self.DisablePanel:SetEnable(true)
				maxLv.TextComponent.Text = tostring(myCharData.maxLevel)
				self.DisablePanel:GetChildByName("message", true).TextComponent.Text = _LocalizeLogic:GetText("ui_charLvUpPopup_disablePanel_state_2")
			
		
			else 
				self.currentLevel.Text = tostring(math.floor(myCharData.level))
				self.nextLevel.Text = tostring(math.floor(myCharData.level + 1))
				
				
				if (currencyData["Gold"].amount >= needGold) and (currencyData["Essence"].amount >= needEssence) then
					self.needGold.FontColor = Color.white
					self.needEssence.FontColor = Color.white
					self.EnablePanel:GetChildByName("message", true).Enable = false
					self._T.upButton.SpriteGUIRendererComponent.ImageRUID = "a96386f9ef2148f48aef7b33234fe032"
		
					self._T.upButton.TextComponent.FontColor = Color.FromHexCode("#ffffff")
					self._T.upButton.TextComponent.OutlineColor = Color.FromHexCode("#3784c4")
				else
					self._T.upButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
					if currencyData["Gold"].amount >= needGold then 
						self.needGold.FontColor = Color.white
					else
						self.needGold.FontColor = Color.FromHexCode("#FF6868")
					end
					
					if currencyData["Essence"].amount >= needEssence then
						self.needEssence.FontColor = Color.white
					else
						self.needEssence.FontColor = Color.FromHexCode("#FF6868")
					end	
					self.EnablePanel:GetChildByName("message", true).Enable = true
				end
					self.needGold.Text = string.format("%d",needGold)
					self.needEssence.Text = string.format("%d",needEssence) 
		
				self.EnablePanel:SetEnable(true)		
			end
		end
		
		if showPopup then
			self:Show()
		end
	end

	method void Show()
		-- 캐릭터 레벨업 팝업을 화면에 표시
		__base:Show()
	end

	method void Hide()
		-- 캐릭터 레벨업 팝업을 숨김
		
		__base:Hide()
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 시 레벨업 버튼 설정
		__base:OnBeginPlay()
		
		self._T.upButton = self.Entity:GetChildByName("Button_LevelUp", true)
	end

	@ExecSpace("Client")
	method void RefreshPanel()
		-- 팝업 패널 새로고침 (현재 비어있음)
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "f7443f70-9d97-418b-8e6b-8b072c31f6d5")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 닫기 버튼 클릭 시 팝업 닫기
		
		local Entity = event.Entity
		self:Hide()
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleLevelUpCharacterEvent(LevelUpCharacterEvent event)
		-- 캐릭터 레벨업 이벤트 처리 및 이팩트 표시
		local charData = event.charData
		
		self:Init(charData.index, false)
		
		local effect = self.upEffect:Clone("lvUpEffect")  
		_TimerService:SetTimerOnce(function() 
				_EntityService:Destroy(effect)
				end, 0.5)
		_UIToast:ShowMessage(_LocalizeLogic:GetText("toast373"))
	end

end