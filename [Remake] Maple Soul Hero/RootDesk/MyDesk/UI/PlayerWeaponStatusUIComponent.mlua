@Component
script PlayerWeaponStatusUIComponent extends Component

	property table weaponInfo = {}

	property table slots = {}

	@ExecSpace("ClientOnly")
	method void Init()
		-- 플레이어 무기 상태 UI를 초기화하고 장착된 무기 정보를 표시
		table.clear(self.weaponInfo)
		table.clear(self.slots)
		
		local weaponLayout = self.Entity:GetChildByName("WeaponLayout")
		local originalSlot = weaponLayout:GetChildByName("originalSlot")
		
		local player = _UserService.LocalPlayer
		local storageCompo = player.PlayerStorageComponent
		
		originalSlot.Enable = false
		
		
		for _, entity in pairs(weaponLayout.Children) do
			if entity ~= originalSlot then
				entity:Destroy()
			end
		end
		
		for i = 1, 6 do
			local entity = originalSlot:Clone(string.format("weaponSlot_%d", i))
			entity.Enable = true
			entity:GetChildByName("state_empty").Enable = true
			entity:GetChildByName("state_equip").Enable = false
			entity:GetChildByName("state_equip"):GetChildByName("effect_ultimate").Enable = false
			entity:GetChildByName("state_equip"):GetChildByName("cover_dark").Enable = true
			
			if i > _UserService.LocalPlayer.PlayerCharacteristicData.canEquipCount then
				entity:GetChildByName("state_empty"):GetChildByName("icon_locked").Enable = true
			else
				entity:GetChildByName("state_empty"):GetChildByName("icon_locked").Enable = false
			end
			
			for _, entity in pairs(entity:GetChildByName("state_equip"):GetChildByName("GradeStar").Children) do
				entity.Enable = true
			end
			
			self.slots[i] = entity
			
			
			local slot = entity:GetChildByName("state_equip")
			local slotBG = slot:GetChildByName("bg_grade")
			local sprite = slot:GetChildByName("icon_weapon")
			local weaponCategory = slot:GetChildByName("WeaponCategory")
			
			sprite.SpriteGUIRendererComponent.ImageRUID = ""
			slotBG.SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetHUDWeaponSlotByGrade("normal")
			
			weaponCategory.SpriteGUIRendererComponent:ChangeMaterial("")
			weaponCategory:GetChildByName("icon_weapon_category").SpriteGUIRendererComponent.ImageRUID = ""
			weaponCategory.Enable = false
		end
		
		for key, value in pairs(storageCompo.storage) do
			if value.equippedSlotNum >= 1 and value.equippedSlotNum <= 6 then
				self.weaponInfo[value.equippedSlotNum] = key
				
				local item = storageCompo:GetItem(key)
				local id = item.originalId
				
				local type = _WeaponSpecLogic.weaponData[id].type
				local category = _ItemDataLogic.equipmentData[id].category 
				local grade = _ItemDataLogic.equipmentData[id].grade
				
				---@type Entity
				local slot = self.slots[value.equippedSlotNum]:GetChildByName("state_equip")
				local slotBG = slot:GetChildByName("bg_grade")
				local sprite = slot:GetChildByName("icon_weapon")
				local weaponCategory = slot:GetChildByName("WeaponCategory")
				local level = slot:GetChildByName("level_panel"):GetChildByName("level_txt")
			
				local weaponSpec = _WeaponSpecLogic.weaponData[id]
				local equipmentData = _ItemDataLogic.equipmentData[id]
			
				local ruid = equipmentData.ruid
			
				if _UtilLogic:IsNilorEmptyString(ruid) == true then
					sprite.SpriteGUIRendererComponent.ImageRUID = weaponSpec.ruid
				else
					sprite.SpriteGUIRendererComponent.ImageRUID = equipmentData.ruid
				end
			
				sprite.SpriteGUIRendererComponent.Enable = true
				slotBG.SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetHUDWeaponSlotByGrade(grade) 
			
				weaponCategory.SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetHUDCategorySlotByGrade(grade)
				
				level.TextComponent.Text = tostring(value.level)
				
				if _CharacterLogic:CheckMatchExWeapon(id, tostring(math.floor(_UserService.LocalPlayer.PlayerCharacterData.charIndex))) then
					weaponCategory.SpriteGUIRendererComponent:ChangeMaterial("material://128cb24f-4eab-4abe-b385-f55cc170785e")
				else
					weaponCategory.SpriteGUIRendererComponent:ChangeMaterial("")
				end
			
				self.slots[value.equippedSlotNum]:GetChildByName("state_empty"):SetEnable(false)
				self.slots[value.equippedSlotNum]:GetChildByName("state_equip"):SetEnable(true)
				
				weaponCategory:SetEnable(true)
			
				weaponCategory:GetChildByName("icon_weapon_category").SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(type)
			end
		end
		
		
		local charId = _HUDManager.currentCharId
		
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		for key, value in pairs(storage) do
			if not _UtilLogic:IsNilorEmptyString(value.originalId) and _ItemDataLogic.equipmentData[value.originalId] ~= nil then
				if _ItemDataLogic.equipmentData[value.originalId].category == "weapon" then
					if value.equippedSlotNum > 0 then
						local slot = self.slots[value.equippedSlotNum]
						if _CharacterLogic:CheckMatchExWeapon(value.originalId, charId) then
							slot:GetChildByName("WeaponCategory", true).SpriteGUIRendererComponent:ChangeMaterial("material://128cb24f-4eab-4abe-b385-f55cc170785e")
						else		 
							slot:GetChildByName("WeaponCategory", true).SpriteGUIRendererComponent:ChangeMaterial("")
						end		
					end
				end
			end
		end
		
		
		local characterInfo = self.Entity:GetChildByName("EquipCharacterInfoPanel"):GetChildByName("LevelPanel")
		local characterData = _CharacterLogic.characterTable[charId]
		local exWeaponId = characterData.exWeaponId[1]
		local illust = characterInfo:GetChildByName("Illust")
		local level = characterInfo:GetChildByName("Level")
		local characterWeapon = characterInfo:GetChildByName("panel_weapon")
		
		illust.SpriteGUIRendererComponent.ImageRUID = characterData.thumbnailRUID
		level.TextComponent.Text = tostring(math.floor(player.PlayerCharacterData.charLevel))
		characterWeapon:GetChildByName("icon_weapon").SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[exWeaponId].type)
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 무기 슬롯의 카드 레벨과 궁극기 상태를 실시간으로 갱신
		local battlePlayer = _UserService.LocalPlayer.BattlePlayer 
		
		for i = 1, 6 do
			local entity = self.slots[i]
			
			if isvalid(self.weaponInfo[i]) then
				local ultimate = entity:GetChildByName("state_equip"):GetChildByName("effect_ultimate")
				local gradeStar = entity:GetChildByName("state_equip"):GetChildByName("GradeStar")
				local cardLevel = battlePlayer:GetEquipCardLevel(self.weaponInfo[i])
				local maxCardLV = _GameConfig:GetConfig().CARD_LV_MAX 
				
				if cardLevel > 0 then
					entity:GetChildByName("state_equip"):GetChildByName("cover_dark").Enable = false
				end
				
				for j = 1, cardLevel do
					---@type Entity
					local starEntity = gradeStar:GetChildByName(string.format("Star_%d", j))
					if isvalid(starEntity) then
						starEntity.SpriteGUIRendererComponent.ImageRUID = "877d010d8bfe46bc881f26f1c7adc3ba"
					end
				end
				
				if cardLevel > maxCardLV then
					ultimate.Enable = true
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "BuffLogic")
	handler HandleSelectBuffCardEvent(SelectBuffCardEvent event)
		-- 버프 카드 선택 시 무기 상태 UI를 갱신
		self:Refresh()
	end

end