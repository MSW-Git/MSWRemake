@Component
script WeaponDetailUIComponent extends Component

	@HideFromInspector
	property Entity panel = "db4a93a6-a992-4c42-8385-e9c51dcefdd1"

	@HideFromInspector
	property Entity title = "5126bd79-1bea-40c0-a0d5-de5a49b220e7"

	@HideFromInspector
	property Entity exitButton = "8f80b512-649f-4615-9004-8831323995db"

	@HideFromInspector
	property Entity slotSprite = "0c27139f-adce-467c-a0bd-79ff58bf871c"

	@HideFromInspector
	property Entity atkText = "31fd0c3e-d3fd-48a5-ae15-ab5d4ea206bd"

	@HideFromInspector
	property Entity description = "ad8b8365-1831-4b13-b077-b795f55b05ea"

	@HideFromInspector
	property Entity optionTitle = "617f6216-cb0b-4b49-81ec-98c9cf5d48e9"

	@HideFromInspector
	property Entity optionLayout = "b7a69726-03cc-4d0a-95d3-27b5f944281a"

	@HideFromInspector
	property Entity goldText = "e48ff86a-601f-415e-9294-6359a7779ade"

	@HideFromInspector
	property Entity scrollText = "3cc12bb0-97b2-4044-ab8f-1c250750cf83"

	@HideFromInspector
	property Entity registerButton = "d3bc35cc-c58a-4bc9-92f2-1d2e5c69e85f"

	@HideFromInspector
	property Entity levelUpButton = "8d3de842-8452-48ae-95a3-aa52d6f72fb4"

	@HideFromInspector
	property Entity allLevelUpButton = "51b8ea4f-2c9e-4859-b697-7b3a066cfc65"

	@HideFromInspector
	property string currentUniqueKey = ""

	@HideFromInspector
	property string currentItemId = ""

	@HideFromInspector
	property Entity currentStorageItem = nil

	@HideFromInspector
	property Entity sellButton = "addc2697-c259-47b9-b369-2257bf4c7603"

	@ExecSpace("ClientOnly")
	method void Show(string uniqueKey, Entity storageItemEntity, string category)
		-- 무기/방어구 상세 정보 UI를 표시하고 데이터를 설정
		
		self.currentUniqueKey = uniqueKey
		self.currentStorageItem = storageItemEntity
		
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		
		self.currentItemId = storage.storage[self.currentUniqueKey].originalId
		
		local itemData = _ItemDataLogic.equipmentData[self.currentItemId]
		if not isvalid(itemData) then
			itemData = _ItemDataLogic.itemData[self.currentItemId]
		end
		
		local weaponSpec = _WeaponSpecLogic:GetWeaponSpec(self.currentItemId)
		local weaponLevelUpData = _ItemDataLogic:GetWeaponLevelUpData(storage.storage[self.currentUniqueKey].level)
		
		if category == "armor" then 
			weaponSpec = _ArmorSpecLogic:GetArmorSpec(self.currentItemId)
			weaponLevelUpData = _ArmorSpecLogic:GetArmorLevelUpData(storage.storage[self.currentUniqueKey].level)
		end
		
		local titleStr = ""
		
		if itemData.star == "1" then
			titleStr = "(★)"
		elseif itemData.star == "2" then
			titleStr = "(★★)"
		elseif itemData.star == "3" then
			titleStr = "(★★★)"
		elseif itemData.star == "4" then
			titleStr = "(★★★★)"
		elseif itemData.star == "5" then
			titleStr = "(★★★★★)"
		end
		
		titleStr = "Lv." .. tostring(storage.storage[self.currentUniqueKey].level) .. " " .. itemData.name .. titleStr
		
		self.title.TextComponent.Text = titleStr
		self.slotSprite.SpriteGUIRendererComponent.ImageRUID = weaponSpec.ruid 
		
		if category == "weapon" then
			self.atkText.TextComponent.Text = string.format("%d", _CalcLogic:GetWeaponAttackDamageByKey(uniqueKey, _UserService.LocalPlayer))
		elseif category == "armor" then 
			local originCategory = _ItemDataLogic.equipmentData[_UserService.LocalPlayer.PlayerStorageComponent.storage[uniqueKey].originalId].category
		
			if originCategory == "armor_helmet" then
				self.atkText.TextComponent.Text = string.format("%d", _ArmorSpecLogic.armorLevelUpData[tonumber(storage.storage[uniqueKey].level)].helmet_hp)
			elseif originCategory == "armor_suit" then
				self.atkText.TextComponent.Text = string.format("%d", _ArmorSpecLogic.armorLevelUpData[tonumber(storage.storage[uniqueKey].level)].suit_hp)
			elseif originCategory == "armor_glove" then
				self.atkText.TextComponent.Text = string.format("%d", _ArmorSpecLogic.armorLevelUpData[tonumber(storage.storage[uniqueKey].level)].glove_hp)
			elseif originCategory == "armor_shoes" then
				self.atkText.TextComponent.Text = string.format("%d", _ArmorSpecLogic.armorLevelUpData[tonumber(storage.storage[uniqueKey].level)].shoes_hp)
			end
		end
		
		self.description.TextComponent.Text = "설명"
		
		local optionTitle = ""
		local gradeFunction = function(num)
			for _, entity in pairs(self.optionLayout.Children) do
				local entityName = entity.Name
				local split = _UtilLogic:Split(entityName, "_")
				local entityNum = tonumber(split[2])
				local optionStr = string.format("option_%d", entityNum)
				local itemName = _ItemDataLogic.equipmentData[self.currentItemId].name
				itemName = _UtilLogic:Split(itemName, "0")[1]
				
				if entityNum == 2 then
					entity.TextComponent.FontColor = Color.cyan
				elseif entityNum == 3 then
					entity.TextComponent.FontColor = Color.yellow
				elseif entityNum == 4 then
					entity.TextComponent.FontColor = Color.magenta
				elseif entityNum == 5 then
					entity.TextComponent.FontColor = Color.red
				end
				
				if num >= entityNum then
					entity.TextComponent.Text = _ItemDataLogic.equipmentOptionData[itemName][optionStr]
					entity.Enable = true
				else
					entity.Enable = false
				end
			end
		end
		
		if itemData.grade == "normal" then
			optionTitle = "노멀 등급 옵션"
			gradeFunction(1)
		elseif itemData.grade == "rare" then
			optionTitle = "레어 등급 옵션"
			gradeFunction(2)
		elseif itemData.grade == "epic" then
			optionTitle = "에픽 등급 옵션"
			gradeFunction(3)
		elseif itemData.grade == "unique" then
			optionTitle = "유니크 등급 옵션"
			gradeFunction(4)
		elseif itemData.grade == "legendary" then
			optionTitle = "레전더리 등급 옵션"
			gradeFunction(5)
		end
		
		self.optionTitle.TextComponent.Text = optionTitle
		
		self.goldText.TextComponent.Text = string.format("%d / %d", _UserService.LocalPlayer.PlayerCurrencyData.gold, weaponLevelUpData.needGold)
		self.scrollText.TextComponent.Text = string.format("%d / %d", _UserService.LocalPlayer.PlayerCurrencyData.weaponScroll, weaponLevelUpData.needScroll)
		
		if storage.storage[self.currentUniqueKey].equippedSlotNum > 0 then
			self.registerButton.TextComponent.Text = "장착 해제"
		else
			self.registerButton.TextComponent.Text = "등록"
		end
		self.Entity.Enable = true
		self.Entity:GetChildByName("WeaponDetailPanel").SpriteGUIRendererComponent.RaycastTarget = true
	end

	@ExecSpace("Client")
	method void LevelUp()
		-- 아이템 레벨업 처리 (서버 통신 필요)
		
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- UI 컴포넌트 초기화 및 버튼 이벤트 연결
		local player = _UserService.LocalPlayer
		local storage = player.PlayerStorageComponent
		
		self.exitButton:ConnectEvent(ButtonClickEvent, function()
				self:Close()
			end)
		
		self.registerButton:ConnectEvent(ButtonClickEvent, function()
				self.currentStorageItem.StorageItemComponent:Equip()
				_InteractionUtil:HideInteraction(self.currentStorageItem)
				if storage.storage[self.currentUniqueKey].equippedSlotNum > 0 then
					self.registerButton.TextComponent.Text = "등록"
				else
					self.registerButton.TextComponent.Text = "해제"
				end
			end)
		
		self.levelUpButton:ConnectEvent(ButtonClickEvent, function()
				local str = _UtilLogic:Split(self.currentItemId, "_")[1]
				self:LevelUp()
			end)
		
		self.allLevelUpButton:ConnectEvent(ButtonClickEvent, function()
				local str = _UtilLogic:Split(self.currentItemId, "_")[1]
				self:LevelUpByOneClick()
			end)
		
	end

	@ExecSpace("ClientOnly")
	method void Close()
		-- 무기 상세 UI를 닫고 레이캐스트 타겟 비활성화
		self.Entity.Enable = false
		self.Entity:GetChildByName("WeaponDetailPanel").SpriteGUIRendererComponent.RaycastTarget = false
	end

	@ExecSpace("Client")
	method void LevelUpByOneClick()
		-- 원클릭으로 최대 레벨까지 업그레이드 처리
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "ItemReinforceLogic")
	handler HandleItemLevelUpEvent(ItemLevelUpEvent event)
		-- 아이템 레벨업 이벤트 처리하여 UI 갱신
		local level = event.level
		local uniqueKey = event.uniqueKey
		local category = event.category
		if uniqueKey == self.currentUniqueKey then
			self:Show(uniqueKey, self.currentStorageItem, category)	
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleExitStorageEvent(ExitStorageEvent event)
		-- 스토리지 종료 이벤트 처리하여 UI 닫기
		self:Close()
	end

end