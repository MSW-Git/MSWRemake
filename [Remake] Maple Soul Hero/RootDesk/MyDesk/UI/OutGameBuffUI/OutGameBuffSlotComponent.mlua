@Component
script OutGameBuffSlotComponent extends Component

	@HideFromInspector
	property table buffData = {}

	@ExecSpace("ClientOnly")
	method void SetSlot(integer index)
		-- 플레이어의 적용된 버프 정보를 기반으로 슬롯 설정
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent.playerInfo
		local splits = _UtilLogic:Split(playerInfo.appliedBuff, "/")[index]
		
		if _UtilLogic:IsNilorEmptyString(splits) then
		else
			local buffId = _UtilLogic:Split(splits, "_")[1]
			local buffCount = tonumber(_UtilLogic:Split(splits, "_")[2])
			local buffData = _ConsumeLogic.consumeEffectData[buffId]
			self.buffData = buffData
			
			self.Entity.SpriteGUIRendererComponent.ImageRUID = buffData.ruid
			self.Entity.SpriteGUIRendererComponent.LocalPosition = Vector2(buffData.offsetX, buffData.offsetY)
			self.Entity.TextComponent.Text = string.format("%d", buffCount)
			
			self.Entity.Enable = true
		end
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 버프 슬롯 클릭 시 툴팁 표시
		
		local Entity = event.Entity
		_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetConsumeEffectDesc(self.buffData.id), self.Entity, Vector2(0, 0), _LocalizeLogic:GetConsumeEffectName(self.buffData.id))
	end

end