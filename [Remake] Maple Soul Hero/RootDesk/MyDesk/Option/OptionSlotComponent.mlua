@Component
script OptionSlotComponent extends Component

	@HideFromInspector
	property Entity button = nil

	property string optionName = ""

	@HideFromInspector
	property Entity text = nil

	property string normalButtonRuid = "825da1c6c2b7456dae71d2bf3e99cf5f"

	property string selectedButtonRuid = "6e191185c11f4b629837a49158255852"

	property Entity linkedOption = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 옵션 슬롯 컴포넌트 초기화 및 버튼 이벤트 연결
		self.button = self.Entity:GetChildByName("UIButton")
		
		if self.button == nil then
			return
		end
		
		self.button:ConnectEvent(ButtonClickEvent,
			function()
				if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
				
				self:OnClickButton()
			end)
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 옵션 값에 따라 버튼 UI를 새로고침
		local currentValue = _OptionLogic[self.optionName]
		if currentValue == nil then return end
		
		if currentValue == true then
			self.button.SpriteGUIRendererComponent.ImageRUID = self.selectedButtonRuid
		else
			self.button.SpriteGUIRendererComponent.ImageRUID = self.normalButtonRuid
		end
		if isvalid(self.linkedOption) then
			self.linkedOption.Enable = currentValue
		end
		
	end

	method void OnClickButton()
		-- 버튼 클릭 시 옵션 값을 토글하고 UI 업데이트
		local currentValue = _OptionLogic[self.optionName]
		if currentValue == nil then return end
		
		local onOff = false
		
		if currentValue then
			self.button.SpriteGUIRendererComponent.ImageRUID = "825da1c6c2b7456dae71d2bf3e99cf5f"
		else
			self.button.SpriteGUIRendererComponent.ImageRUID = "6e191185c11f4b629837a49158255852"
		end
		
		if self.optionName == "showDamageSkin"  then
			if currentValue then
				onOff = false
			else
				onOff = true
			end
		elseif self.optionName == "usedAutoPotion" then
			if currentValue then
				onOff = false
			else
				onOff = true
			end
		elseif self.optionName == "usedAutoMPPotion" then
			if currentValue then
				onOff = false
			else
				onOff = true
			end
		
		end
		if isvalid(self.linkedOption) then
			self.linkedOption.Enable = onOff
		end
		_OptionLogic:SetOption(self.optionName, onOff)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "OptionLogic")
	handler HandleOptionDataLoadedEvent(OptionDataLoadedEvent event)
		-- 옵션 데이터 로드 완료 시 UI 새로고침
		self:Refresh()
	end

end