	@ExecSpace("Client")
	method void CloseGetCharacterPopUp()
		-- 캐릭터 획득 팝업 닫기
		self.uiCharacterInfoPopup:CloseGetCharacterPopUp()
	end

	@ExecSpace("Client")
	method void RefreshMainPanel()
		-- 캐릭터 정보 메인 패널 새로고침
		self.uiCharacterInfoPopup:RefreshMainPanel()
	end

	@ExecSpace("Client")
	method void RefreshLevelUpCostText(number charId)
		-- 캐릭터 레벨업 비용 텍스트 업데이트
		self.uiCharacterInfoPopup.popup_levelUp.CharacterLevelupPopup:Init(charId, false) 
	end

	@ExecSpace("Client")
	method void RefreshCharInfo(number index, number level)
		-- 캐릭터 정보 새로고침
		self.uiCharacterInfoPopup:RefreshCharInfo(index, level)
	end

	@ExecSpace("Client")
	method void RefreshBreakLimitCostText(number charId)
		-- 캐릭터 돌파 비용 텍스트 업데이트
		 self.uiCharacterInfoPopup.popup_breakLimit.CharacterBreakupPopup:Init(charId, false) 
	end

	@ExecSpace("Client")
	method void RefreshRelationSlot(string id, table table)
		-- 캐릭터 관계 슬롯 새로고침
		self.uiCharacterInfoPopup:RefreshRelationSlot(id, table)
	end

	@ExecSpace("Client")
	method void RefreshCharSlotLevelOnly(string relationId, integer slotNum, integer level, boolean valid)
		-- 관계 슬롯의 특정 캐릭터 레벨만 업데이트
		self.uiCharacterInfoPopup:RefreshCharSlotLevelOnly(relationId, slotNum, level, valid)
	end

	@ExecSpace("Client")
	method void SetCharacterSlot(Entity targetSlot, string index)
		-- 캐릭터 슬롯 정보 설정 및 UI 업데이트
		local allCharTable = _CharacterLogic.characterTable[index] 
		local character = _UserService.LocalPlayer.PlayerCharacterData
		
		local stars = targetSlot:GetChildByName("stars", true)
		local state = targetSlot:GetChildByName("state", true)
		local name = targetSlot:GetChildByName("name", true)
		local level = targetSlot:GetChildByName("level", true)
		local equipped = targetSlot:GetChildByName("equipped", true)
		local maxTier = targetSlot:GetChildByName("maxTier", true)
		local pieceIcon = targetSlot:GetChildByName("pieceIcon", true)
		local pieceOutline = targetSlot:GetChildByName("outline", true)
		local gauge = targetSlot:GetChildByName("pieceGauge", true)
		local lock = targetSlot:GetChildByName("lock", true)
		local desc = targetSlot.Parent:GetChildByName("desc")
		
		stars:SetEnable(false)
		state:SetEnable(false)
		name:SetEnable(false)
		level:SetEnable(false)
		equipped:SetEnable(false)
		maxTier:SetEnable(false)
		lock:SetEnable(false)
		
		pieceIcon.SpriteGUIRendererComponent.ImageRUID = allCharTable.pieceRUID
		targetSlot.SpriteGUIRendererComponent.ImageRUID = allCharTable.illustRUID 
		targetSlot:GetChildByName("exWeaponIcon", true).SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[allCharTable.exWeaponId[1]].type) 
		
		
		name.TextComponent.Text = _LocalizationService:GetText("soul_name_"..index) 
		name.TextComponent.FontColor = Color.white
		
		name:SetEnable(true)
		if isvalid(character.charDeckStorage[tonumber(index)]) then 
			local myCharTable = character.charDeckStorage[tonumber(index)]	
			local charLevel = myCharTable.level
			local tier = myCharTable.tier 
			targetSlot.SpriteGUIRendererComponent.Color.a = 1
			level:SetEnable(true)
			level.TextComponent.Text = myCharTable.level 
			
			for i = 1 , #stars.Children do
				if tier >= i then
					stars:GetChildByName("star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "877d010d8bfe46bc881f26f1c7adc3ba"
				else
					stars:GetChildByName("star_"..math.floor(i)).SpriteGUIRendererComponent.ImageRUID = "cdb4f75585614caa9647d7eb04545dfe"
				end
			end
			stars:SetEnable(true)
			
			targetSlot.SpriteGUIRendererComponent:ChangeMaterial("") 
		
		else 
			targetSlot.SpriteGUIRendererComponent.Color.a = 0.5
			targetSlot.SpriteGUIRendererComponent:ChangeMaterial("material://a58cbfd6-0988-4bd4-a30b-89e51565bef4") 
			name.TextComponent.FontColor = Color.gray 
			desc.TextComponent.Text = _LocalizationService:GetTextFormat("ui_CharacterGroup_text_9", "soul_name_"..index)
			
			state.TextComponent.Text = _LocalizeLogic:GetText("common_Not_Possesion")
			state.TextComponent.FontColor = Color.gray
			state:SetEnable(true)
		end
		
		
		local charLevel = 0
		local charTier = 0 
		
		if isvalid(character.charDeckStorage[tonumber(index)]) then 
			charLevel = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(index)].level
			charTier = _UserService.LocalPlayer.PlayerCharacterData.charDeckStorage[tonumber(index)].tier
		end
		
		local charDeck = character.charDeckStorage[tonumber(index)]
		local maxPieceCount = _CharacterLogic:GetMaxPieceCount(charTier,math.floor(tonumber(index)), _UserService.LocalPlayer)
		local charPieceTable = character.charPieceStorage
		
		local charPieceCount = 0
		if charPieceTable[tonumber(index)] ~= nil then
			charPieceCount = charPieceTable[tonumber(index)].count
		end
		
		if not isvalid(charDeck) or charDeck.tier < 5 then 
			if not isvalid(charDeck) then 
				lock:SetEnable(true)
				if charPieceCount >= maxPieceCount then 
					lock:SetEnable(false)
					state.TextComponent.Text = _LocalizeLogic:GetText("common_PossibleUnlock")
					state.TextComponent.FontColor = Color.yellow
					gauge:GetChildByName("arrow", true):SetEnable(true)
					pieceOutline.Enable = true	
				else
					state.TextComponent.Text = _LocalizeLogic:GetText("common_Not_Possesion")
					state.TextComponent.FontColor = Color.gray
					pieceOutline.Enable = false
					gauge:GetChildByName("bar", true).SliderComponent.FillRectImageRUID = "4d3053287ce54dec9a07146e9ad80b6f" 
				end	
			else
				if charPieceCount >= maxPieceCount then
					state.TextComponent.FontColor = Color.yellow
					gauge:GetChildByName("arrow", true):SetEnable(true)
					pieceOutline.Enable = true	
				else
					state.TextComponent.FontColor = Color.gray
					pieceOutline.Enable = false
				end
			end
		
			gauge:GetChildByName("bar", true).SliderComponent.FillRectImageRUID = "7ed0e6e6e26c44e792c0e405ca96a980"
			gauge:GetChildByName("bar", true).SliderComponent.Value = charPieceCount/maxPieceCount
			gauge:GetChildByName("pieceCount", true).TextComponent.Text = math.floor(charPieceCount).."/"..math.floor(maxPieceCount)
		
			gauge:SetEnable(true)
			targetSlot:GetChildByName("maxTier",true):SetEnable(false)
		else 
			gauge:SetEnable(false)
			targetSlot:GetChildByName("maxTier",true):SetEnable(true)
		end
		
		
	end

	@ExecSpace("Client")
	method void SetItemSlot(Entity slot, integer enum, string uniqueKey, string option)
		-- 아이템 슬롯 정보 설정 및 인벤토리 데이터 처리
		
		local storage = _UserService.LocalPlayer.PlayerStorageComponent.storage
		local petStorage = _UserService.LocalPlayer.PlayerPetStorageComponent.petInventory
		local storageId = ""
		
		if isvalid(storage[uniqueKey]) then
			storageId = storage[uniqueKey].originalId
		elseif isvalid(petStorage[uniqueKey]) then
			storageId = petStorage[uniqueKey].originalId
		else
			storageId = option
		end
		
		local petId = ""
		
		if isvalid(petStorage[uniqueKey]) then
			petId = petStorage[uniqueKey].originalId
		else
			petId = option
		end
		
		slot.SpriteGUIRendererComponent.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
		
		local sprite = slot:GetChildByName("Sprite", true)
		local equipped = slot:GetChildByName("equipped", true)
		
		local category= slot:GetChildByName("Category", true)
		local categoryIcon = slot:GetChildByName("CategoryIcon", true)
		
		local panel_Pet = slot:GetChildByName("PetContentPanel", true)
		local petLevel = slot:GetChildByName("pet_level", true)
		local petGrade = slot:GetChildByName("Grade", true)
		
		local panel_Armor = slot:GetChildByName("ArmorOptions", true)
		local armorLevel = slot:GetChildByName("armor_level", true)
		local armorGrade = slot:GetChildByName("GradeStar", true)
		
		local count = slot:GetChildByName("Usable_count", true)
		
		category:SetEnable(true)
		count:SetEnable(false)
		equipped:SetEnable(false)
				
		slot.SpriteGUIRendererComponent.ImageRUID ="2502dac4d15a46f4ab26445abd1cc7f9"
		sprite.SpriteGUIRendererComponent.ImageRUID = ""
		equipped:SetEnable(false)
		petLevel:SetEnable(false)
		armorLevel:SetEnable(false)
		
		if storageId == "" then
			if enum == 2 then
				panel_Pet:SetEnable(false)
				panel_Armor:SetEnable(true)
				
				for i = 1, #armorGrade.Children do
					armorGrade.Children[i].Enable = false
				end
			elseif enum == 3 then
				panel_Armor:SetEnable(false)
				panel_Pet:SetEnable(true)
			elseif enum == 4 then 
				panel_Armor:SetEnable(false)
				panel_Pet:SetEnable(false)
				
				category.Enable = false
				count:SetEnable(false)
			end
			
			return
		end
		
		local result, error = pcall(function()
			if enum == 1 then 
				local itemData = _ItemDataLogic.equipmentData[storageId]
				panel_Pet:SetEnable(false)
				armorGrade:SetEnable(false)
				panel_Armor:SetEnable(true)
			
				sprite.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetWeaponRuidByEquipmentData(storageId)
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2.zero
				category.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUID(storageId)	
				categoryIcon.SpriteGUIRendererComponent.ImageRUID = _WeaponSpecLogic:GetWeaponCategoryIcon(_WeaponSpecLogic.weaponData[storageId].type)
			
				if isvalid(storage[uniqueKey]) then
					armorLevel.TextComponent.Text = storage[uniqueKey].level
					armorLevel:SetEnable(true)
				else
					armorLevel:SetEnable(false)
				end
			
				local grade = _UtilLogic:Split(_WeaponSpecLogic.weaponData[storageId].grade, "_")
				
				if grade[1] == "normal" then
					slot.SpriteGUIRendererComponent.ImageRUID ="2502dac4d15a46f4ab26445abd1cc7f9"
				elseif grade[1] == "rare" then
					slot.SpriteGUIRendererComponent.ImageRUID ="ee76a77c3f60420786df557ca6cb29ba"
				elseif grade[1] == "epic" then
					slot.SpriteGUIRendererComponent.ImageRUID ="8cd3e973b6f04b67a5d425eaed80e916"
				elseif grade[1] == "unique" then
					slot.SpriteGUIRendererComponent.ImageRUID ="401b646213b241c59f4ebc3712e7aad6"
				elseif grade[1] == "legendary" then
					slot.SpriteGUIRendererComponent.ImageRUID ="87f20108334748dc94da9983a1e7e96c"
				end
				
			
			elseif enum == 2 then 
				panel_Pet:SetEnable(false)
				panel_Armor:SetEnable(true)
				
				sprite.SpriteGUIRendererComponent.ImageRUID = _ArmorSpecLogic.armorData[storageId].ruid
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2.zero
			
				category.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUID(storageId)
				categoryIcon.SpriteGUIRendererComponent.ImageRUID = _ArmorSystemLogic:GetCategoryIconRUID(storageId)
				
				if isvalid(storage[uniqueKey]) then
					armorLevel.TextComponent.Text = storage[uniqueKey].level
					armorLevel:SetEnable(true)
					if _ItemDataLogic:CheckItemEquipped(uniqueKey, _UserService.LocalPlayer, enum) then
						equipped:SetEnable(true)
					end
				else
					armorLevel:SetEnable(false)
				end
				
				local grade = _UtilLogic:Split(_ArmorSpecLogic.armorData[storageId].grade, "_")
				
				if grade[1] == "normal" then
					slot.SpriteGUIRendererComponent.ImageRUID ="2502dac4d15a46f4ab26445abd1cc7f9"
				elseif grade[1] == "rare" then
					slot.SpriteGUIRendererComponent.ImageRUID ="ee76a77c3f60420786df557ca6cb29ba"
				elseif grade[1] == "epic" then
					slot.SpriteGUIRendererComponent.ImageRUID ="8cd3e973b6f04b67a5d425eaed80e916"
				elseif grade[1] == "unique" then
					slot.SpriteGUIRendererComponent.ImageRUID ="401b646213b241c59f4ebc3712e7aad6"
				elseif grade[1] == "legendary" then
					slot.SpriteGUIRendererComponent.ImageRUID ="87f20108334748dc94da9983a1e7e96c"
				end
				
				local starCount = tonumber(_ArmorSpecLogic.armorData[storageId].star)
			
				for i = 1, #armorGrade.Children do
					if i <= starCount then
						armorGrade.Children[i].Enable = true
					else
						armorGrade.Children[i].Enable = false
					end
				end
					
			elseif enum == 3 then 
				panel_Armor:SetEnable(false)
				panel_Pet:SetEnable(true) 
				
				local petData = _PetLogic.petData[petId]
				
				if petData.grade == "S" then
					slot.SpriteGUIRendererComponent.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
				elseif petData.grade == "A" then
					slot.SpriteGUIRendererComponent.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
				elseif petData.grade == "B" then
					slot.SpriteGUIRendererComponent.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
				end
				
				sprite.SpriteGUIRendererComponent.ImageRUID = petData.ruid
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(tonumber(petData.pivotX), tonumber(petData.pivotY))
				
				category.SpriteGUIRendererComponent.ImageRUID = _PetLogic:GetCategoryColorRUID(petId)
				categoryIcon.SpriteGUIRendererComponent.ImageRUID = "87cf429145814827a1b159aac55234b3"
			
				petGrade.SpriteGUIRendererComponent.ImageRUID = _PetLogic:GetGradeIconRUID(petId)
			
				if isvalid(petStorage[uniqueKey]) then
					petLevel.TextComponent.Text = petStorage[uniqueKey].level
					petLevel:SetEnable(true)
					if _ItemDataLogic:CheckItemEquipped(uniqueKey, _UserService.LocalPlayer, enum) then
						equipped:SetEnable(true)
					end
				else
					petLevel:SetEnable(false)
				end
				
			
			elseif enum == 4 then 
				panel_Armor:SetEnable(false)
				panel_Pet:SetEnable(false)
			
				local itemData = _ItemDataLogic.itemData[storageId]
				sprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
				
				category.Enable = true
			
				count:SetEnable(true)
				count.TextComponent.Text = storage[uniqueKey].count
			elseif enum == 5 then 
				panel_Pet:SetEnable(false)
				panel_Armor:SetEnable(true)
				armorGrade:SetEnable(false)
				
				local itemData = _ItemDataLogic.itemData[storageId]
				
				sprite.SpriteGUIRendererComponent.ImageRUID = itemData.ruid
				sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			
				category.SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUID(storageId)
				
				local iconRUID = ""
				if string.sub(storageId, 1, 3) == "101" then
					iconRUID = _GameUtil:GetCategoryIconRUID("ring")
				elseif string.sub(storageId, 1, 3) == "102"  then
					iconRUID = _GameUtil:GetCategoryIconRUID("earring")
				elseif string.sub(storageId, 1, 3) == "103"  then
					iconRUID = _GameUtil:GetCategoryIconRUID("necklace")
				end
		
				categoryIcon.SpriteGUIRendererComponent.ImageRUID = iconRUID
				
				if isvalid(storage[uniqueKey]) then
					armorLevel.TextComponent.Text = storage[uniqueKey].level
					armorLevel:SetEnable(true)
					if _ItemDataLogic:CheckItemEquipped(uniqueKey, _UserService.LocalPlayer, enum) then
						equipped:SetEnable(true)
					end
				else
					armorLevel:SetEnable(false)
				end
				
				local grade = itemData.grade
				
				if grade == "normal" then
					slot.SpriteGUIRendererComponent.ImageRUID ="2502dac4d15a46f4ab26445abd1cc7f9"
				elseif grade == "rare" then
					slot.SpriteGUIRendererComponent.ImageRUID ="ee76a77c3f60420786df557ca6cb29ba"
				elseif grade == "epic" then
					slot.SpriteGUIRendererComponent.ImageRUID ="8cd3e973b6f04b67a5d425eaed80e916"
				elseif grade == "unique" then
					slot.SpriteGUIRendererComponent.ImageRUID ="401b646213b241c59f4ebc3712e7aad6"
				elseif grade == "legendary" then
					slot.SpriteGUIRendererComponent.ImageRUID ="87f20108334748dc94da9983a1e7e96c"
				end
			end
			end)
		
		if not result then
		end
		
	end

	method void AttachToWealthUIDefaultGroup(boolean attached, Entity entity)
		-- 재화 UI를 기본 그룹에 연결하거나 분리
		if attached then
			self.WealthUI:AttachTo(_UIGroupManager.defalutGroup)
			self.WealthUI.UITransformComponent.anchoredPosition = self._T.wealthUIPos 
		else
			self._T.wealthUIPos = self.WealthUI.UITransformComponent.anchoredPosition
			self.WealthUI:AttachTo(entity)
		end
	end

	method boolean IsEnableOpenPopup()
		-- 팝업 열기가 가능한지 시간 간격 확인
		local diff = _UtilLogic.ElapsedSeconds - _UIGroupManager.lastShowTime
		
		if diff < 0.2 then
			return false
		end
		_UIGroupManager.lastShowTime = _UtilLogic.ElapsedSeconds
		
		return true
	end

	method boolean IsOpenPlayerControlBlockPopup()
		-- 플레이어 컨트롤을 차단하는 팝업이 열려있는지 확인
		local toggleControllerCnt = 0
		
		for k,v in pairs(self.selectedPopup) do
			---@type UICommonPopup
				local popup = v
				if isvalid(popup) then
					if _TutorialLogic.group.Enable then return end
					if _UIDialog.dialog.Enable then return end
					if isvalid(popup.Entity) then 
						if popup.togglePlayerController then
							toggleControllerCnt+=1
						end
					else
					end
				end
				
			
		end
		
		return toggleControllerCnt > 0
	end

	@EventSender("Entity", "d3d48b39-44ed-490e-b18e-d3b835767790")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 일일 선물 팝업 열기 버튼 클릭
		
		local Entity = event.Entity
		
		self.uiDailyGiftPopup:ShowByButtonClick()
	end

	@EventSender("Entity", "33ce4859-9c58-4951-b9b8-da0c9ffc192c")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 펫 팝업 열기 버튼 클릭
		
		local Entity = event.Entity
		
		self.petPopup:ShowByButtonClick()
	end

	@EventSender("Entity", "69cc4d33-1860-4ea9-a309-8841be3dd042")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 특성 팝업 열기 버튼 클릭
		
		local Entity = event.Entity
		self.uiCharacteristicPopup:ShowByButtonClick()
	end

	@EventSender("Entity", "b3aae438-7815-4313-b994-36f4ba7dccce")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 스테이지 이동 팝업 열기 버튼 클릭
		
