	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- ESC 키 입력 시 팝업 닫기 처리
		
		local key = event.key
		
		if key == KeyboardKey.Escape then
			if #self.selectedPopup > 0 then
				local popup = self.selectedPopup[#self.selectedPopup]
				if isvalid(popup) then
					if _TutorialLogic.group.Enable then return end
					if _UIDialog.dialog.Enable then return end
					if isvalid(popup.Entity) then 
						popup:Hide()
					else
						if popup.isTweenPlaying then
							return
						end
						
						if isvalid(_UserService.LocalPlayer.CurrentMap.BattleMap) then
							popup:OnClickCancel()
						else
							popup:Close()
						end
					end
				end
				
			end
			
			if _UserService.LocalPlayer.CurrentMapName == "Town" then
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleScreenTouchEvent(ScreenTouchEvent event)
		-- 화면 터치 이벤트 처리 및 확장 메뉴 닫기
		
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if _InputService:IsPointerOverUI() then return end
		
		if self.expandMenuPanel.UICommonPopup.isOpen then
			self.expandMenuPanel.UICommonPopup:Hide()
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandleBreakLimitEvent(BreakLimitEvent event)
		-- 캐릭터 돌파 이벤트 처리 및 UI 갱신
		local charData = event.charData
		self:RefreshMainPanel()
		self:RefreshBreakLimitCostText(charData.index)
		self:RefreshCharInfo(charData.index, charData.level)
		
	end

