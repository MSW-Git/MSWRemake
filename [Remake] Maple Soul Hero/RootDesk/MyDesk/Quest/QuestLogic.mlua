@Logic
script QuestLogic extends Logic

	property table questData = {}

	property table contentOpenData = {}

	property integer lastQuestNum = 0

	method void OnBeginPlay()
		-- 퀘스트 데이터 및 컨텐츠 오픈 데이터 초기화
		local data = _DataService:GetTable("QuestData")
		
		for i = 1, data:GetRowCount() do
			local quest = {}
			quest.id = data:GetCell(i,"id")
			quest.name = data:GetCell(i, "name")
			quest.description = data:GetCell(i, "description")
			quest.subInfo = data:GetCell(i, "subInfo")
			quest.category = data:GetCell(i, "category")
			quest.questType = data:GetCell(i, "questType")
			quest.requiredLevel = tonumber(data:GetCell(i, "requiredLevel"))
			quest.objectiveType = data:GetCell(i, "objectiveType")
			quest.objectiveId = data:GetCell(i, "objectiveId")
			quest.objectiveNum = data:GetCell(i, "objectiveNum")
			quest.rewardType = data:GetCell(i, "rewardType")
			quest.rewardId = data:GetCell(i, "rewardId")
			quest.rewardNum = data:GetCell(i, "rewardNum")
			quest.dialogId = data:GetCell(i, "dialogId")
			quest.stageGuide = data:GetCell(i, "stageGuide")
			quest.npcDialogueId = data:GetCell(i, "npcDialogueId")
			
			if quest.category == "main" then
				if tonumber(quest.id) > self.lastQuestNum then
					self.lastQuestNum = tonumber(quest.id)
				end
			end
		
			self.questData[quest.id] = quest
		end
		
		local data2 = _DataService:GetTable("ContentUIData")
		
		for i=1, data2:GetRowCount() do
			local contentOpen = {}
			contentOpen.id = data2:GetCell(i,"id")
			contentOpen.name = data2:GetCell(i,"name")
			contentOpen.localizationKey = data2:GetCell(i,"localizationKey")
			contentOpen.unlockQuestId = data2:GetCell(i,"unlockQuestId")
			
			self.contentOpenData[contentOpen.id] = contentOpen
		end
	end

	method integer GetObjectiveCount(string questId, string objectiveId)
		-- 퀘스트 목표 진행 수치 조회
		local count = 0
		local playerQuest = _UserService.LocalPlayer.PlayerQuestComponent
		
		if #table.keys(playerQuest.questProgress) < 1 then return end
		if _QuestUILogic.questUI.currentCategory == "COMPLETE" then return 0 end
		if not isvalid(playerQuest.questProgress[questId]) or not isvalid(playerQuest.questProgress[questId].questObjective) then return 0 end
		
		local currentQuestObjective = _UtilLogic:Split(playerQuest.questProgress[questId].questObjective, "/")
		
		for i = 1, #currentQuestObjective do
			if currentQuestObjective[i] == objectiveId then
				count = tonumber(currentQuestObjective[i + 1])
				
				break
			end
		end
		
		if not isvalid(count) then
			return 0
		else
			return count
		end
	end

end