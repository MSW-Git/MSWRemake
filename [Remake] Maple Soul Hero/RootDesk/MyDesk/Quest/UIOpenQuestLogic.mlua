@Logic
script UIOpenQuestLogic extends Logic

	@ExecSpace("Client")
	method void CheckQuestInProgress(string questId, Entity popupEntity)
		-- UI 오픈 퀘스트 진행 상태 확인 및 처리
		local playerQuest = _UserService.LocalPlayer.PlayerQuestComponent
		local currentQuestId = playerQuest.currentQuestId
		local questData = _QuestLogic.questData[currentQuestId]
		if isvalid(questData) == false then return end
		
		if questData.objectiveType == "openUI" and playerQuest.questProgress[currentQuestId].questStatus == "INPROGRESS" then
			local currentQuestObjective = _UtilLogic:Split(playerQuest.questProgress[currentQuestId].questObjective, "/")
			if _UtilLogic:Split(currentQuestObjective[1],"_")[1] == questId then
				if tonumber(currentQuestObjective[2]) == 0 then
					if currentQuestObjective[1] ~= questId then
						if questId == "myInfo" then
							popupEntity.UIPlayerStatusPopup:ChangeTab(_UtilLogic:Split(currentQuestObjective[1],"_")[2])
						elseif questId == "soul" then					
							if tostring(popupEntity.UICharacterInfoPopup.selectedCharIndex) ~= _UtilLogic:Split(currentQuestObjective[1],"_")[2] then return end
						end
					end
					local dialogueId = questData.npcDialogueId
					playerQuest:AddObjectiveCount("openUI", currentQuestObjective[1], 1, currentQuestId, true, "ui")
					_WorldLog:RequestLogQuestFlow(playerQuest.questProgress[playerQuest.currentQuestId], _WorldLog.FlowType_Quest_Change, "ui")
					_DialogDataLogic:StartScene(dialogueId, "uiOpen", function() 
						
						if currentQuestObjective[1] == "weapon" then
							_UIGroupManager.uiMergePopup:StartTutorial()
						elseif currentQuestObjective[1] == "characteristic" then
							_TutorialLogic:StartTutorial("characteristic_tutorial_1",function() end)
						elseif currentQuestObjective[1] == "gathering" then
							_TutorialLogic:StartTutorial("gathering_tutorial_1",function() end)				
						elseif currentQuestObjective[1] == "randomBoss" then
							_TutorialLogic:StartTutorial("randomBoss_tutorial_1",function() end)
						end
					end)
				end
			end
		end
	end

end