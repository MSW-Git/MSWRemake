@Component
script QuestRewardSlotComponent extends Component

	property string rewardType = ""

	property string rewardId = ""

	@ExecSpace("ClientOnly")
	method void SetSlot(string rewardType, integer rewardNum, string rewardId)
		-- 퀘스트 보상 슬롯 설정 및 아이콘 업데이트
		local icon = self.Entity:GetChildByName("Icon")
		local renderer = icon.SpriteGUIRendererComponent
		
		icon.TextComponent.Text = tostring(rewardNum)
		if rewardType == "meso" then
			renderer.ImageRUID.DataId = _GameConfig:GetConfig().RUID_MESO
			renderer.LocalPosition = Vector2.zero
		elseif rewardType == "item" then
			local itemData = _ItemDataLogic.itemData[rewardId]
			
			if not isvalid(itemData) then
				itemData = _ItemDataLogic.equipmentData[rewardId]
				
				if itemData.category == "weapon" then
					itemData = _WeaponSpecLogic.weaponData[rewardId]
				end
			end
			
			renderer.ImageRUID.DataId = itemData.ruid
			renderer.LocalPosition = Vector2.zero
			
			if isvalid(itemData.offsetX) then
				renderer.LocalPosition = Vector2(itemData.offsetX, itemData.offsetY)
			end
		elseif rewardType == "essence" then
			renderer.ImageRUID.DataId = _GameConfig:GetConfig().RUID_ESSENCE
			renderer.LocalPosition = Vector2(-15, -15)
		elseif rewardType == "weaponScroll" then
			renderer.ImageRUID.DataId = _GameConfig:GetConfig().RUID_SCROLL
			renderer.LocalPosition = Vector2(-17.5, -15)
		elseif rewardType == "diamond" then
			renderer.ImageRUID.DataId = _GameConfig:GetConfig().RUID_DIAMOND
			renderer.LocalPosition = Vector2.zero
		elseif rewardType == "soulPiece" then
			renderer.ImageRUID.DataId = _CharacterLogic.characterTable[rewardId].pieceRUID
		elseif rewardType == "pet" then
			renderer.ImageRUID.DataId = _PetLogic.petData[rewardId].ruid
			renderer.LocalPosition = Vector2(-17.5,-30)
		elseif rewardType == "characteristic" then
			renderer.ImageRUID.DataId = "acbc2a04e46845f8b5b52aa4ff5704e4"
			renderer.LocalPosition = Vector2(-16, -16)
		end
		
		self.rewardType = rewardType
		self.rewardId = rewardId
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 보상 슬롯 클릭 시 툴팁 표시
		
		local Entity = event.Entity
		if self.rewardType == "meso" then
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr1"), self.Entity, Vector2.zero, _LocalizeLogic:GetText("common_meso"))
		elseif self.rewardType == "item" then
			local itemData = _ItemDataLogic.itemData[self.rewardId]
			local title = ""
			local str = ""
			
			if not isvalid(itemData) then
				itemData = _ItemDataLogic.equipmentData[self.rewardId]
				
				if itemData.category == "weapon" then
					itemData = _WeaponSpecLogic.weaponData[self.rewardId]
					
					title = _LocalizeLogic:GetText("weapon")
					str = _LocalizeLogic:GetText("tooltipStr2")
				else
					title = _LocalizeLogic:GetText("armor")
					str = _LocalizeLogic:GetText("tooltipStr3")
				end
			else
				title = _LocalizeLogic:GetItemName(self.rewardId)
				str = _LocalizeLogic:GetItemDesc(self.rewardId) .. "                                          "
				if self.rewardId == "6_000008" then
					str = _LocalizeLogic:GetItemDesc(self.rewardId) .. " \n"
				end
			end
			
			_TooltipLogic:ShowTooltipByString(str, self.Entity, Vector2.zero, title)
		elseif self.rewardType == "essence" then
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr4"), self.Entity, Vector2.zero, _LocalizeLogic:GetText("common_energyStone"))
		elseif self.rewardType == "weaponScroll" then
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr5"), self.Entity, Vector2.zero, _LocalizeLogic:GetText("scroll"))
		elseif self.rewardType == "diamond" then
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr6"), self.Entity, Vector2.zero, _LocalizeLogic:GetText("common_diamond"))
		elseif self.rewardType == "soulPiece" then
			local str = string.format(_LocalizeLogic:GetText("tooltipStr10"), _LocalizationService:GetText("soul_name_"..self.rewardId))
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr7"), self.Entity, Vector2.zero, str)
		elseif self.rewardType == "pet" then
			local str = string.format(_LocalizeLogic:GetText("tooltipStr11"), _LocalizeLogic:GetPetName(self.rewardId))
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr8"), self.Entity, Vector2.zero, str)
		elseif self.rewardType == "characteristic" then
			_TooltipLogic:ShowTooltipByString(_LocalizeLogic:GetText("tooltipStr9"), self.Entity, Vector2.zero, _LocalizeLogic:GetText("common_characteristicCoin"))
		end
	end

end