@Logic
script QuestUILogic extends Logic

	property QuestUIComponent questUI = "b1d82416-19d2-42c7-8477-6418930bdd3d"

	property QuestHUDComponent questHUD = "290c79e5-bf48-4b80-a8b5-c704ab620da1"

	@ExecSpace("Client")
	method void Refresh()
		-- 퀘스트 UI 및 HUD 상태 갱신
		self.questUI:Refresh()
		self.questHUD:Refresh()
	end

	@ExecSpace("Client")
	method void OffQuestHUD()
		-- 퀘스트 HUD 비활성화
		self.questHUD:OffUI()
	end

end