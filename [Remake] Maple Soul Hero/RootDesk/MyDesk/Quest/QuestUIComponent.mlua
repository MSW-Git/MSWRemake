@Component
script QuestUIComponent extends UICommonPopup

	property Entity questPanelText = "84d17e67-8063-447d-bb7a-9de0c805a49b"

	property Entity progressCategoryButton = "a6432416-7fe3-4c92-a848-1a86d450fcdc"

	property Entity completeCategoryButton = "ff27b956-7079-4bd6-9615-f1cc61e46947"

	property Entity closeButton = "955fc541-5ec9-4081-a85a-161cb6943874"

	property Entity questListPanel = "09afe068-c0ef-4c53-ace7-f173fb383bae"

	property Entity questContentPanel = "2c3235fb-ac0e-458b-b4d9-ea02744d0ce6"

	property Entity questCompleteButton = "5460cf17-dfb5-4e44-b9dc-6d0a14ae931a"

	@HideFromInspector
	property string currentCategory = "PROGRESS"

	@HideFromInspector
	property string selectedQuestId = "1"

	property Entity objectiveSlot = "c976fcb3-ec5d-49aa-839a-57245ad4b1dc"

	property Entity rewardSlot = "b459d55f-5d0d-4b92-97ea-3bdb8aed497c"

	property Entity emptyPanel = "a0373203-f4e0-4ae8-8c0b-e4787e775aa6"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 퀘스트 UI 컴포넌트 초기화 및 그리드뷰 설정
		__base:OnBeginPlay()
		self.currentCategory = "PROGRESS"
		self:InitGridView()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 퀘스트 UI 전체 상태 갱신 및 버튼 상태 업데이트
		local playerQuestCompo = _UserService.LocalPlayer.PlayerQuestComponent
		
		if _UIDialog.isShow then
			self._T.dialogEndHandler = _UIDialog:ConnectEvent(DialogEndEvent,function()
				self:RefreshTopPanel()
				self:RefreshQuestList()
		
				self:RefreshContentPanel()
				_UIDialog:DisconnectEvent(DialogEndEvent,self._T.dialogEndHandler)
			end)
		else
			self:RefreshTopPanel()
			self:RefreshQuestList()
			self:RefreshContentPanel()
		end
		
		local questId = self.selectedQuestId
		local canComplete = playerQuestCompo:IsCanComplete(questId)
		
		if not isvalid(playerQuestCompo.questProgress[questId]) or playerQuestCompo.questProgress[questId].questStatus ~= "INPROGRESS" then
			self.questCompleteButton.ButtonComponent.Enable = false
			self.questCompleteButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
			
		else
			if not self:IsLastAndCompleteMainQuest() then
				self.questCompleteButton.ButtonComponent.Enable = true
			end
		
			
			if canComplete then
				self.questCompleteButton.SpriteGUIRendererComponent.ImageRUID = "fc7aab99a8e549e58d891d50f594ecd6"
			else
				self.questCompleteButton.SpriteGUIRendererComponent.ImageRUID = "dcb7b47e9c5048e09f56691f1b29fd29"
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshTopPanel()
		-- 퀘스트 상단 패널 텍스트 갱신
		if self.currentCategory == "PROGRESS" then
			self.questPanelText.TextComponent.Text = _LocalizeLogic:GetText("questStr1")
			
		elseif self.currentCategory == "COMPLETE" then
			self.questPanelText.TextComponent.Text = _LocalizeLogic:GetText("questStr2")
		end
	end

	@ExecSpace("ClientOnly")
	method void RefreshQuestList()
		-- 퀘스트 목록 그리드뷰 갱신
		local gridView = self.questListPanel.GridViewComponent
		
		self:SetTotalCount()
		gridView:Refresh(true, true)
	end

	@ExecSpace("ClientOnly")
	method void RefreshContentPanel()
		-- 퀘스트 상세 컨텐츠 패널 갱신 및 목표/보상 표시
		local questData = _QuestLogic.questData[self.selectedQuestId]
		local questCompo = _UserService.LocalPlayer.PlayerQuestComponent
		local questProgress = questCompo.questProgress[questCompo.currentQuestId]
		
		local titlePanel = self.questContentPanel:GetChildByName("QuestTitlePanel")
		local objectivePanel = self.questContentPanel:GetChildByName("QuestObjectivePanel")
		local descriptionPanel = self.questContentPanel:GetChildByName("QuestDescriptionText",true)
		local bottomPanel = self.questContentPanel:GetChildByName("QuestBottomPanel")
		
		
		local titleText = titlePanel:GetChildByName("QuestTitle", true)
		local infoText = titlePanel:GetChildByName("QuestInfo", true)
		
		if isvalid(questData) and self.selectedQuestId ~= "" then
			self.emptyPanel.Enable = false
			self.questContentPanel.Enable = true
			
			titleText.TextComponent.Text = "#"..questData.id.." ".._LocalizationService:GetText("quest_"..questData.id.."_name")
			if questData.id == "24" then
				titleText.TextComponent.Text = "#"..questData.id.." ".._LocalizationService:GetText("ui_open_limitLand")
			end
			infoText.TextComponent.Text = _LocalizationService:GetText("quest_"..questData.id.."_subinfo")
			
			if self:IsLastAndCompleteMainQuest() then
				if self.currentCategory == "PROGRESS" then
					titleText.TextComponent.Text = _LocalizeLogic:GetText("questStr3")
					infoText.TextComponent.Text = " "
				end
			end
		else
			if self.currentCategory == "PROGRESS" then
				titleText.TextComponent.Text = _LocalizeLogic:GetText("questStr3")
				infoText.TextComponent.Text = " "
					
				self.emptyPanel.Enable = false
				self.questContentPanel.Enable = true
			else
				titleText.TextComponent.Text = _LocalizeLogic:GetText("questStr4")
				infoText.TextComponent.Text = _LocalizeLogic:GetText("questStr5")
					
				self.emptyPanel.Enable = true
				self.questContentPanel.Enable = false
			end
		end
		
		
		local objectiveSlot = objectivePanel:GetChildByName("ObjectiveSlot")
		
		for _, entity in pairs(objectivePanel.Children) do
			if entity ~= self.objectiveSlot then
				entity:Destroy()
			end
		end
		
		if isvalid(questData) and self.selectedQuestId ~= "" and not self:IsLastAndCompleteMainQuest() then
			local objectiveTypes = _UtilLogic:Split(questData.objectiveType, "/")
			local objectiveNums = _UtilLogic:Split(questData.objectiveNum, "/")
			local objectiveIds = _UtilLogic:Split(questData.objectiveId, "/")
			local stageGuide = _UtilLogic:Split(questData.stageGuide,"/")
			
			for i = 1, #objectiveTypes do
				local objectiveType = objectiveTypes[i]
				local objectiveNum = tonumber(objectiveNums[i])
				local objectiveId = objectiveIds[i]
				local stageInfo = ""
				if #stageGuide > 0 then
					stageInfo = stageGuide[i]
				end
				
				local slot = self.objectiveSlot:Clone("ObjectiveSlot")
				slot.QuestObjectiveSlot:SetSlot(objectiveType, objectiveNum, objectiveId, stageInfo)
				slot.Enable = true
			end
		end
		
		
		if isvalid(questData) and self.selectedQuestId ~= "" and not self:IsLastAndCompleteMainQuest() then
			descriptionPanel.TextComponent.Text = _LocalizationService:GetText("quest_"..questData.id.."_description")
		else
			descriptionPanel.TextComponent.Text = ""
		end
		
		
		local rewardPanel = bottomPanel:GetChildByName("QuestRewardPanel")
		
		for _, entity in pairs(rewardPanel.Children) do
			if entity ~= self.rewardSlot then
				entity:Destroy()
			end
		end
		
		if isvalid(questData) and self.selectedQuestId ~= "" and not self:IsLastAndCompleteMainQuest() then
			local rewardTypes = _UtilLogic:Split(questData.rewardType, "/")
			local rewardNums = _UtilLogic:Split(questData.rewardNum, "/")
			local rewardIds = _UtilLogic:Split(questData.rewardId, "/")
			
			for i = 1, #rewardTypes do
				local rewardType = rewardTypes[i]
				local rewardNum = tonumber(rewardNums[i])
				local rewardId = rewardIds[i]
				
				local slot = self.rewardSlot:Clone("RewardSlot")
				slot.QuestRewardSlotComponent:SetSlot(rewardType, rewardNum, rewardId)
				slot.Enable = true
			end
		end
		
		
		local buttonPanel = bottomPanel:GetChildByName("QuestButtonPanel")
		local completeButton = buttonPanel:GetChildByName("QuestCompleteButton")
		local checkMark = buttonPanel:GetChildByName("CheckMark")
		
		if self.currentCategory == "PROGRESS" then
			completeButton.Enable = true
			checkMark.Enable = false
			
		elseif self.currentCategory == "COMPLETE" then
			completeButton.Enable = false
			checkMark.Enable = true
		end
		
		if self.selectedQuestId == "" or self:IsLastAndCompleteMainQuest() then
			completeButton.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void SetEnable(boolean onOff)
		-- 퀘스트 UI 활성화/비활성화 및 초기 상태 설정
		if onOff then
			self.emptyPanel.Enable = true
			self.questContentPanel.Enable = false
		
			if self:IsLastAndCompleteMainQuest() then
				self.questCompleteButton.Enable = false
			end
			
			local questCompo = _UserService.LocalPlayer.PlayerQuestComponent
		
			self.selectedQuestId = ""
			
			if questCompo.currentQuestId ~= "" then
				if questCompo.questProgress[questCompo.currentQuestId] ~= "COMPLETE" then
					self.selectedQuestId = _UserService.LocalPlayer.PlayerQuestComponent.currentQuestId
				end
			end
			
			self:Refresh()
			
			self.currentCategory = "PROGRESS"
			self.completeCategoryButton.SpriteGUIRendererComponent.ImageRUID = "6cb1470eea884424886399b0fc9f3c95"
			self.progressCategoryButton.SpriteGUIRendererComponent.ImageRUID = "994e2ad676fe4b4c9782186b06f02a4a"
			
			self:Show()
		else
			self:Hide()
		end
	end

	@ExecSpace("ClientOnly")
	method void InitGridView()
		-- 퀘스트 목록 그리드뷰 초기화 및 콜백 설정
		local gridView = self.questListPanel.GridViewComponent
		
		gridView.CellSize = Vector2(750, 100)
		gridView.ItemEntity = self.questListPanel:GetChildByName("QuestSlot")
		self:SetTotalCount()
		
		gridView.OnRefresh = function(index, entity)
			local playerQuest = _UserService.LocalPlayer.PlayerQuestComponent
			---@type QuestSlotComponent
			local questSlot = entity.QuestSlotComponent
			
			local quests = {}
			local i = 1
			
			if self.currentCategory == "PROGRESS" then
				for key, value in pairs(playerQuest.questProgress) do
					if value.questStatus == "INPROGRESS" then
						quests[i] = value.id
						i += 1
					end
				end
			elseif self.currentCategory == "COMPLETE" then
				for key, value in pairs(playerQuest.questProgress) do
					if value.questStatus == "COMPLETE" then
						quests[i] = value.id
						i += 1
					end
				end
			end
			
			if isvalid(quests) then
				table.sort(quests, function(a, b) return tonumber(a) < tonumber(b) end)
			end
			
			if tonumber(playerQuest.currentQuestId) >= _QuestLogic.lastQuestNum then
				if playerQuest.questProgress[playerQuest.currentQuestId].questStatus == "COMPLETE" then
					if self.currentCategory == "PROGRESS" then
						questSlot:SetEnable(false)
					else
						questSlot:SetSlot(quests[index + 1])
					end
				else
					questSlot:SetSlot(quests[index + 1])
				end
			else
				questSlot:SetSlot(quests[index + 1])
			end
		end
		
		gridView:Refresh(true, true)
	end

	@ExecSpace("ClientOnly")
	method void SetTotalCount()
		-- 퀘스트 목록 총 개수 설정
		local gridView = self.questListPanel.GridViewComponent
		local playerQuest = _UserService.LocalPlayer.PlayerQuestComponent
		local questCount = 0
		if self.currentCategory == "PROGRESS" then
			for key, value in pairs(playerQuest.questProgress) do
				if value.questStatus == "INPROGRESS" then
					questCount += 1
				end
			end
		elseif self.currentCategory == "COMPLETE" then
			for key, value in pairs(playerQuest.questProgress) do
				if value.questStatus == "COMPLETE" then
					questCount += 1
				end
			end
		end
		
		gridView.TotalCount = questCount
	end

	method void Hide()
		-- 퀘스트 UI 숨김 및 선택 상태 초기화
		__base:Hide()
		self.selectedQuestId = ""
	end

	@ExecSpace("ClientOnly")
	method boolean IsLastAndCompleteMainQuest()
		-- 마지막 메인 퀘스트 완료 여부 확인
		if self.currentCategory == "COMPLETE" then
			return false
		end
		
		local questCompo = _UserService.LocalPlayer.PlayerQuestComponent
		local questProgress = questCompo.questProgress[questCompo.currentQuestId]
		
		if questProgress.questStatus == "COMPLETE" and tonumber(self.selectedQuestId) == _QuestLogic.lastQuestNum then
			return true
		else
			return false
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "a6432416-7fe3-4c92-a848-1a86d450fcdc")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 진행 중 퀘스트 카테고리 버튼 클릭 처리
		
		local Entity = event.Entity
		self.currentCategory = "PROGRESS"
			
		local questCompo = _UserService.LocalPlayer.PlayerQuestComponent
		
		self.selectedQuestId = ""
		
		if questCompo.currentQuestId ~= "" then
			if questCompo.questProgress[questCompo.currentQuestId] ~= "COMPLETE" then
				self.selectedQuestId = _UserService.LocalPlayer.PlayerQuestComponent.currentQuestId
			end
		end
		self.completeCategoryButton.SpriteGUIRendererComponent.ImageRUID = "6cb1470eea884424886399b0fc9f3c95"
		Entity.SpriteGUIRendererComponent.ImageRUID = "994e2ad676fe4b4c9782186b06f02a4a"
		self:RefreshContentPanel()
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "ff27b956-7079-4bd6-9615-f1cc61e46947")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 완료된 퀘스트 카테고리 버튼 클릭 처리
		
		local Entity = event.Entity
		self.currentCategory = "COMPLETE"
		self.selectedQuestId = ""
		self.progressCategoryButton.SpriteGUIRendererComponent.ImageRUID = "6cb1470eea884424886399b0fc9f3c95"
		Entity.SpriteGUIRendererComponent.ImageRUID = "994e2ad676fe4b4c9782186b06f02a4a"
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "5460cf17-dfb5-4e44-b9dc-6d0a14ae931a")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 퀘스트 완료 버튼 클릭 처리
		
		local Entity = event.Entity
		if self.currentCategory == "PROGRESS" then
			_UIPopup:Open("", _LocalizeLogic:GetText("popup30"), function()
					_UserService.LocalPlayer.PlayerQuestComponent:RequestCompleteQuest(self.selectedQuestId)
				end, nil)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "955fc541-5ec9-4081-a85a-161cb6943874")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 퀘스트 UI 닫기 버튼 클릭 처리
		
		local Entity = event.Entity
		self:SetEnable(false)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Entity", "834089a6-704e-4e68-b68d-94121d4b7b40")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 퀘스트 UI 열기 버튼 클릭 처리
		
		local Entity = event.Entity
		self:SetEnable(true)
	end

end