@Component
script Joystick extends Component

	property boolean isPressed = false

	property UITransformComponent group = "50387418-b879-43ce-a5df-1702a6293721"

	property UITransformComponent rect = nil

	property Vector2 pos = Vector2(0,0)

	property Vector2 touchPos = Vector2(0,0)

	property Vector2 originPos = Vector2(0,0)

	property number range = 50

	property Vector2 value = Vector2(0,0)

	property boolean isLeft = false

	property boolean isRight = false

	property boolean isDown = false

	property boolean isUp = false

	property number threshold = 0.1

	property CanvasGroupComponent canvasGroup = nil

	property UITransformComponent stick = "466c8a33-6a77-46a1-bae1-509fed524581"

	property boolean canControl = true

	method Vector2 TouchToCanvasPosition(Vector2 pos)
		-- 터치 좌표를 캔버스 좌표로 변환
		local ratio = self.group.RectSize.y / (_UILogic.ScreenHeight)
		return pos * ratio
	end

	method Vector2 GetDelta(Vector2 TouchDelta)
		-- 터치 델타값을 UI 비율에 맞게 변환
		local ratio = self.group.RectSize.y / (_UILogic.ScreenHeight)
		return TouchDelta * ratio
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 조이스틱 컴포넌트 초기화
		self.rect = self.Entity.UITransformComponent
		self.originPos = self.rect.anchoredPosition
		self.canvasGroup = self.Entity.CanvasGroupComponent
	end

	method boolean IsKeyDown()
		-- 조이스틱이 어느 방향으로든 눌려있는지 확인
		return self.isUp or self.isDown or self.isLeft or self.isRight
	end

	@ExecSpace("ClientOnly")
	method void ForceKeyRelease()
		-- 조이스틱 입력을 강제로 해제
		self.isDown = false
		self.isUp = false
		self.isLeft = false
		self.isRight = false
		self.value = Vector2.zero
		_InputLogic:OnChangeJoystickValue(self.value)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchDownEvent(UITouchDownEvent event)
		-- 조이스틱 터치 시작 시 위치 설정 및 초기화
		
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if not self.canControl then return end
		
		local worldPos = _GameUtil:ScreenPosToUIPosByRect(TouchPoint) 
		
		self.isPressed = true
		self.touchPos = TouchPoint
		self.rect.AlignmentOption = AlignmentType.Center
		self.pos = _GameUtil:ScreenPosToUIPos(TouchPoint) 
		self.rect.anchoredPosition = self.pos:Clone()
		self.value = Vector2.zero
		_InputLogic:OnChangeJoystickValue(self.value)
		self.canvasGroup.GroupAlpha = 0.5
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchDragEvent(UITouchDragEvent event)
		-- 조이스틱 드래그 중 방향값 계산 및 키보드 이벤트 발생
		
		local Entity = event.Entity
		local TouchDelta = event.TouchDelta
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if not self.canControl then return end
		
		local diff = TouchPoint - self.touchPos
		if Vector2.Magnitude(diff) > self.range then
			diff = Vector2.Normalize(diff) * self.range
		end
		self.rect.anchoredPosition = self.pos +  self:GetDelta(diff)
		self.value = diff / self.range
		_InputLogic:OnChangeJoystickValue(self.value)
		
		
		
		if self.value.x > self.threshold then
			if self.isRight == false then
				self.isRight = true
				_InputService:SendEvent(KeyDownEvent(KeyboardKey.RightArrow))
			else
				_InputService:SendEvent(KeyHoldEvent(KeyboardKey.RightArrow))
			end
		else
			if self.isRight then
				self.isRight = false
				_InputService:SendEvent(KeyUpEvent(KeyboardKey.RightArrow))
			end
		end
		
		if self.value.x < -self.threshold then
			if self.isLeft == false then
				self.isLeft = true
				_InputService:SendEvent(KeyDownEvent(KeyboardKey.LeftArrow))
			else
				_InputService:SendEvent(KeyHoldEvent(KeyboardKey.LeftArrow))
			end
		else
			if self.isLeft then
				self.isLeft = false
				_InputService:SendEvent(KeyUpEvent(KeyboardKey.LeftArrow))
			end
		end
		
		
		if self.value.y > self.threshold then
			if self.isUp == false then
				self.isUp = true
				_InputService:SendEvent(KeyDownEvent(KeyboardKey.UpArrow))
			else
				_InputService:SendEvent(KeyHoldEvent(KeyboardKey.UpArrow))
			end
		else
			if self.isUp then
				self.isUp = false
				_InputService:SendEvent(KeyUpEvent(KeyboardKey.UpArrow))
			end
		end
		
		if self.value.y < -self.threshold then
			if self.isDown == false then
				self.isDown = true
				_InputService:SendEvent(KeyDownEvent(KeyboardKey.DownArrow))
			else
				_InputService:SendEvent(KeyHoldEvent(KeyboardKey.DownArrow))
			end
		else
			if self.isDown then
				self.isDown = false
				_InputService:SendEvent(KeyUpEvent(KeyboardKey.DownArrow))
			end
		end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleUITouchUpEvent(UITouchUpEvent event)
		-- 조이스틱 터치 종료 시 원위치 복원 및 입력 해제
		
		local Entity = event.Entity
		local TouchId = event.TouchId
		local TouchPoint = event.TouchPoint
		if not self.canControl then return end
		
		self.isPressed = false
		self.rect.AlignmentOption = AlignmentType.BottomLeft
		self.rect.anchoredPosition = self.originPos
		self.value = Vector2.zero
		_InputLogic:OnChangeJoystickValue(self.value)
		
		if self.isDown then
			self.isDown = false
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.DownArrow))
		end
		if self.isUp then
			self.isUp = false
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.UpArrow))
		end
		if self.isLeft then
			self.isLeft = false
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.LeftArrow))
		end
		if self.isRight then
			self.isRight = false
			_InputService:SendEvent(KeyUpEvent(KeyboardKey.RightArrow))
		end
		self.canvasGroup.GroupAlpha = 1
	end

end