@Component
script FieldShopUIComponent extends ShopUIComponent

	property table fieldShopTable = {}

	property boolean togglePlayerController = false

	property string selectedProductId = ""

	property number buyCount = 1

	property Entity buyingCountText = "eceb5902-2cb7-4e4c-bbad-9f884282c511"

	property Entity WealthText = "cf8478cb-98e6-4361-9e38-0cf07c8f6971"

	property BaggageUIComponent baggage = "d73efe4a-a3c4-403b-ba30-63519e5981d6"

	property string selectedProductPrice = ""

	property Entity buyingCost = "54d06312-5a49-4990-a4a3-fac466f96d1f"

	property Entity afterBuyingCost = "e59fba41-be0f-491c-aa0e-8ff238144d4c"

	property Entity selectedOutline = "b5e25e86-867f-4a2f-9823-da155c0a6172"

	property Entity buyButton = "0b3e3799-69a0-454e-8b83-303988f58125"

	property string shopId = "2"

	property Entity purchaseGroup = "921e65a1-c008-4343-8ba8-c33e71087ac6"

	property Vector2 offset = Vector2(-5,-5)

	property Entity multiWealthPanel = "153dd9bb-932a-46b3-826c-19751b892624"

	property table shopData = {}

	method void Show()
		-- 필드 샵 UI를 표시하고 초기화
		__base:Show()
		self.canvasGroup.BlocksRaycasts = true
		
		self:ClearSelectedSlot()
		
		
		self:Init(self.shopId)
		
		self:Refresh()
		self.baggage:SetHeight(true)
		self.multiWealthPanel:SetEnable(true)
		
		_MultiHUDManager:SetEnable(false)
		
	end

	method void Hide()
		-- 필드 샵 UI를 숨기고 HUD 다시 활성화
		__base:Hide()
		
		
		_MultiHUDManager:SetEnable(true)
	end

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 컴포넌트 초기화 및 UI 요소 설정
		__base:OnBeginPlay()
		
		self.canvasGroup = self.Entity.CanvasGroupComponent
		self.canvasGroup.BlocksRaycasts = false
		
		
		self.buyingCountText.TextComponent.Text = string.format("%d", self.buyCount) 
		local gridView = self.productLayout.GridViewComponent
		self:SetWealthPanel()
		
		
		
	end

	@ExecSpace("ClientOnly")
	method void RefreshDateText()
		-- 날짜 텍스트 새로고침 (현재 비어있음)
	end

	@ExecSpace("ClientOnly")
	method void StartTimer()
		-- 타이머 시작 (현재 비어있음)
	end

	@ExecSpace("ClientOnly")
	method void OnRefresh()
		-- 샵 데이터 새로고침 및 재화 패널 업데이트
		if _UtilLogic:IsNilorEmptyString(self.shopId) then
			return
		end
		
		local gridView = self.productLayout.GridViewComponent
		
		gridView:Refresh(false, true)
		self:SetWealthPanel()
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		-- 샵 UI 전체 새로고침 및 HUD 업데이트
		self:OnRefresh()
		_MultiHUDManager:Refresh()
	end

	method void OnClikcSLot(string productId, Entity btn)
		-- 상품 슬롯 클릭 시 선택 상태 및 구매 패널 표시
		if self.selectedProductId == productId then return end
		
		self.selectedProductId = productId
		
		self.selectedOutline:AttachTo(btn)
		self.selectedOutline.UITransformComponent.OffsetMin = self.offset
		self.selectedOutline.UITransformComponent.OffsetMax = -self.offset
		self.selectedOutline.Enable = true
		
		local data = _ShopLogic.shopData[self.shopId][self.selectedProductId]
		self.purchaseGroup.Enable = true
		
		self:SetBuyCount(1)
		
	end

	method void OnRefreshGridView(number index, Entity entity)
		-- 그리드뷰 아이템 새로고침 및 선택 상태 업데이트
		---@type ProductSlotComponent
			local productSlot = entity.FieldShopSlotComponent
			local productData = self.shopData[index + 1]
			productSlot:SetSlot(productData, self.shopId, productData.id)
		
		
		if self.selectedProductId == entity.FieldShopSlotComponent.productId then
			self.selectedOutline:AttachTo(entity)
			self.selectedOutline.UITransformComponent.OffsetMin = self.offset
			self.selectedOutline.UITransformComponent.OffsetMax = -self.offset
			self.selectedOutline.Enable = true
		else
			if self.selectedOutline.Parent == entity then
				self.selectedOutline.Enable = false
			end
		end
		
	end

	method void ClearSelectedSlot()
		-- 선택된 슬롯 초기화 및 구매 수량 리셋
		
		self.selectedProductId = ""
		self.selectedOutline:AttachTo(self.Entity)
		self.selectedOutline.Enable = false
		
		self:SetBuyCount(1)
	end

	method void SetBuyCount(number cnt)
		-- 구매 수량 설정 및 비용 새로고침
		self.buyCount = math.max(1, cnt)
		self:RefreshCost()
	end

	method void RefreshCost()
		-- 선택된 상품의 총 비용 및 구매 버튼 상태 업데이트
		if _UtilLogic:IsNilorEmptyString(self.selectedProductId) then
			self.buyingCost.TextComponent.Text = ""
			self.purchaseGroup.Enable = false	
			return
		end
		
		local data = _ShopLogic.shopData[self.shopId][self.selectedProductId]
		if data == nil then
			self.buyingCost.TextComponent.Text = ""
			self.purchaseGroup.Enable = false
			return
		end
		
		self.buyingCountText.TextComponent.Text = string.format("%d", self.buyCount) 
		self.buyingCost.TextComponent.Text = string.format("%d", self.buyCount * data.price)
		if _UserService.LocalPlayer.PlayerCurrencyData.fieldGem < self.buyCount * data.price then 
			self.buyButton.SpriteGUIRendererComponent.ImageRUID = "1b817e998fc340709279e8d9b92b4b8e"
			self.buyButton:GetChildByName("BuyButtonText",true).TextComponent.FontColor = Color.FromHexCode("#d1d1d1")
			self.buyButton:GetChildByName("BuyButtonText",true).TextComponent.OutlineColor = Color.FromHexCode("#616161")
			
			self.afterBuyingCost.TextComponent.Text = string.format("<color=#ff3c3c>%d</color>", 0)
			self.buyButton.ButtonComponent.Enable = false
			self.buyButton:GetChildByName("BuyButtonText").TextComponent.OutlineColor = Color.FromHexCode("#616161")
			
			
		else 
			self.afterBuyingCost.TextComponent.Text = string.format("<color=#FFFFFF>%d</color>", _UserService.LocalPlayer.PlayerCurrencyData.fieldGem - self.buyCount * data.price)
			self.buyButton.ButtonComponent.Enable = true
			self.buyButton.SpriteGUIRendererComponent.ImageRUID = "680e8f1997ed470a8f599c1f671a36a8"
			self.buyButton:GetChildByName("BuyButtonText",true).TextComponent.FontColor = Color.FromHexCode("#ffffff")
			self.buyButton:GetChildByName("BuyButtonText",true).TextComponent.OutlineColor = Color.FromHexCode("#589334")
			
		end
		self.purchaseGroup.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void Init(string id)
		-- 샵 ID로 초기화하고 현재 맵에 맞는 상품 데이터 로드
		self.shopId = id
		
		local gridView = self.productLayout.GridViewComponent
		
		local currentMap = _MultiMapDataLogic:GetCurrentMapId()
		local shopData = _ShopLogic:GetShopdataByMapfilter(self.shopId,currentMap)
		self.shopData= shopData
		
		gridView.TotalCount = #shopData
		
		gridView:Refresh(true, true)
		
		self:SetWealthPanel()
		self:SetLeftShopPanel()
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleEntityMapChangedEvent(EntityMapChangedEvent event)
		-- 맵 변경 시 상점 데이터 업데이트 (현재 미구현)
		
		local NewMap = event.NewMap
		local OldMap = event.OldMap
		local Entity = event.Entity
		local fieldMapCompo = Entity.PlayerFieldMapComponent
		local currentMapNum = _MultiMapDataLogic.multiMapData[NewMap.Name].mapNum
		local npc = _MultiMapDataLogic.multiMapData[NewMap.NPCComponent]
		
		--local merchantNPC = _EntityService:GetEntityByPath(_MultiMapDataLogic.multiMapData[mapName].destinationPath)
		
		
		if currentMapNum == "1" then 
			
			
		elseif currentMapNum == "2" then 
			
			
		end
		
		
		
	end

	@EventSender("Self")
	handler HandleFieldShopSlotTouchEvent(FieldShopSlotTouchEvent event)
		-- 필드 샵 슬롯 터치 이벤트 처리 (현재 비어있음)
		
		
	end

	@EventSender("Entity", "0b3e3799-69a0-454e-8b83-303988f58125")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 구매 버튼 클릭 시 구매 확인 팝업 표시
		
		local Entity = event.Entity
		
		if _UIGroupManager:IsEnableOpenPopup() == false then
			return
		end
		
		local data = _ShopLogic.shopData[self.shopId][self.selectedProductId]
		if data == nil then
			return
		end
		
		local str = _LocalizationService:GetTextFormat("popup47", _LocalizeLogic:GetItemName(data.rewardId), tostring(self.buyCount))
		_UIPopup:OpenPurchasePopup(_LocalizeLogic:GetText("popup46"),str,"","fieldGem", data.price * self.buyCount,function() 
			
			
			_ShopLogic:RequestBuyProduct(_GameConfig:GetConfig().WEALTHTYPE_FIELDGEM,self.shopId,self.selectedProductId,self.buyCount)
			self:ClearSelectedSlot()
			_UIPopup:Close()
			
			end, nil)
		
	end

	@EventSender("Entity", "f675c567-dba4-40fe-a378-513436a1c266")
	handler HandleButtonClickEvent2(ButtonClickEvent event)
		-- 구매 수량 증가 버튼 클릭 처리
		
		local Entity = event.Entity
		
		self:SetBuyCount(self.buyCount + 1)
		
	end

	@EventSender("Entity", "eb06312c-5b22-4651-801a-279e0fad3b79")
	handler HandleButtonClickEvent3(ButtonClickEvent event)
		-- 구매 수량 감소 버튼 클릭 처리
		
		local Entity = event.Entity
		
		self:SetBuyCount(math.max(1, self.buyCount - 1))
		
	end

	@EventSender("Entity", "eceb5902-2cb7-4e4c-bbad-9f884282c511")
	handler HandleTextInputEndEditEvent(TextInputEndEditEvent event)
		-- 구매 수량 입력 필드 편집 완료 시 처리
		
		local text = event.text
		
		local count = tonumber(text)
		if count == nil then
			return
		end
		self:SetBuyCount(count)
	end

	@EventSender("Entity", "0e70383f-86c3-43e4-8344-30e19f7f1e33")
	handler HandleButtonClickEvent4(ButtonClickEvent event)
		-- 구매 수량을 1로 리셋하는 버튼 클릭 처리
		
		local Entity = event.Entity
		self:SetBuyCount(1)
	end

	@EventSender("Entity", "e25b838e-c02a-4a36-8bb1-d97ed3c7a44f")
	handler HandleButtonClickEvent5(ButtonClickEvent event)
		-- 최대 구매 가능 수량으로 설정하는 버튼 클릭 처리
		
		local Entity = event.Entity
		local data = _ShopLogic.shopData[self.shopId][self.selectedProductId]
		if data == nil then
			return
		end
		
		local maxCount =  math.floor(_UserService.LocalPlayer.PlayerCurrencyData.fieldGem / ( data.price))
		self:SetBuyCount(maxCount)
	end

end