@Component
script FieldShopSlotComponent extends Component

	property Entity nameText = nil

	property Entity thumbnail = nil

	property Entity priceText = nil

	property Entity description = nil

	property FieldShopUIComponent shopUI = "296e3e62-981c-4030-b37f-61947c802a31"

	property string productId = ""

	property string shopId = ""

	property number index = 0

	property any data = nil

	property table productData = {}

	property Entity itemSlot = nil

	property Entity selectedLine = nil

	property string selectedUniqueKey = ""

	property Entity background = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 슬롯 컴포넌트 초기화 및 클릭 이벤트 연결
		self.productId = ""
		
		self.itemSlot = self.Entity
		self.nameText = self.Entity:GetChildByName("FieldItemName")
		self.thumbnail = self.Entity:GetChildByName("FieldItemSprite",true)
		self.priceText = self.Entity:GetChildByName("FieldItemPrice")
		self.description = self.Entity:GetChildByName("FieldItemdescription")
		self.background = self.Entity:GetChildByName("panel_slot_bg",true)
		
		
		
		
		
		self.itemSlot:ConnectEvent(ButtonClickEvent, function()
		
			self:Selected(true)
			
			end)
		
		
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(table productData, string shopId, string productId)
		-- 상품 데이터로 슬롯 UI 설정 (이름, 이미지, 가격, 등급별 배경)
		
		self.productId = productId
		local data = _ItemDataLogic.itemData[productData.rewardId]
		
		
		self.productData = productData
		self.shopId = shopId
		
		
		
		local playerInfo = _UserService.LocalPlayer.PlayerInfoComponent
		local slotBgRenderer = self.background.SpriteGUIRendererComponent
		
		
		self.nameText.TextComponent.Text = _LocalizeLogic:GetItemName(productData.rewardId) 
		self.thumbnail.SpriteGUIRendererComponent.ImageRUID = "thumbnail://".. productData.ruid
		self.priceText.TextComponent.Text = string.format("%d", productData.price)
		self.description.TextComponent.Text = _LocalizeLogic:GetItemDesc(productData.rewardId) 
		
		self.Entity:GetChildByName("Category",true).SpriteGUIRendererComponent.ImageRUID = _ItemDataLogic:GetCategoryColorRUIDByGrade(data.grade)
		self.Entity:GetChildByName("Category",true):GetChildByName("CategoryIcon",true).SpriteGUIRendererComponent.ImageRUID = _CraftingLogic:GetCraftingCategoryIconByItemId(productData.rewardId)
		
		if data.grade == "normal" then
			slotBgRenderer.ImageRUID = "2502dac4d15a46f4ab26445abd1cc7f9"
		elseif data.grade == "rare" then
			slotBgRenderer.ImageRUID = "ee76a77c3f60420786df557ca6cb29ba"
		elseif data.grade == "epic" then
			slotBgRenderer.ImageRUID = "8cd3e973b6f04b67a5d425eaed80e916"
		elseif data.grade == "unique" then
			slotBgRenderer.ImageRUID = "401b646213b241c59f4ebc3712e7aad6"
		elseif data.grade == "legendary" then
			slotBgRenderer.ImageRUID = "87f20108334748dc94da9983a1e7e96c"
		end
		
		
		self.itemSlot:ConnectEvent(ButtonClickEvent, function()
		
			self:OpenPurchasePopup()
			
			end)
		
	end

	method void Clear()
		-- 슬롯 내용 초기화
		self.thumbnail.SpriteGUIRendererComponent.ImageRUID = nil
		self.nameText.TextComponent.Text = ""
		
	end

	@ExecSpace("ClientOnly")
	method void OpenPurchasePopup()
		-- 구매 팝업 열기 (현재 미구현)
		
		if not isvalid(self.Entity) then return end
		
		
		
		local data = _ItemDataLogic.itemData[self.productId]
		
		
		
	end

	method void Selected(boolean isSelected)
		-- 슬롯 선택 상태 시각적 표시
		if isSelected then
			self.Entity:GetChildByName("selectedLine",true).Enable = true
		else
			self.Entity:GetChildByName("selectedLine",true).Enable = false
		end
	end

	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 슬롯 클릭 시 상위 UI에 선택 알림
		
		local Entity = event.Entity
		
		self.shopUI:OnClikcSLot(self.productId,self.Entity)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleFieldShopSlotTouchEvent(FieldShopSlotTouchEvent event)
		-- 필드 샵 슬롯 터치 이벤트 처리 (현재 비어있음)
		local touchedSlot = event.touchedSlot
		
	end

end