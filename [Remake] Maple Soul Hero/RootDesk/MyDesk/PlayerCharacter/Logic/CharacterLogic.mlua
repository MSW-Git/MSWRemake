@Logic
script CharacterLogic extends Logic

	property table characterTable = {}

	property table characterSkillTable = {}

	property table characterIdTable = {}

	property Entity charSlot = "3f764945-8068-4eaf-8be3-0ecfdd2fa91d"

	property number maxLevelCountInSameType = 0

	property EntityRef originCharSlot = "80bc6bfe-3818-41f9-94d6-f2eed045f4c0"

	property table charLevelEffectTable = {}

	property table relationTable = {}

	property table relationIdTable = {}

	property table characterTierEffectTable = {}

	property table levelStatusTable = {}

	property integer charMaxLevel = 0

	property table indexAndId = {}

	method void OnBeginPlay()
		-- 캐릭터 데이터, 관계 데이터, 티어 효과 데이터 초기화
		local data = _DataService:GetTable("CharacterData")
		for i = 1, data:GetRowCount() do
			local char = {}
			char.id = data:GetCell(i,"id")
			char.type = data:GetCell(i,"type")
			char.tier = data:GetCell(i, "tier")
			char.defaultHp = data:GetCell(i,"defaultHp")
			char.defaultAtk = data:GetCell(i,"defaultAtk")
			char.defaultCriProb = data:GetCell(i,"defaultCriProb")
			char.addHp = data:GetCell(i,"addHp")
			char.addAtk = data:GetCell(i,"addAtk")
			char.attackType = data:GetCell(i, "attackType")
			char.minLevel = data:GetCell(i,"minLevel")
			char.maxLevel = data:GetCell(i,"maxLevel")
			char.illustRUID = data:GetCell(i,"illustRUID")
			char.iconRUID = data:GetCell(i,"iconRUID")
			char.thumbnailRUID = data:GetCell(i,"thumbnailRUID")
			char.pieceRUID = data:GetCell(i, "pieceRUID")
			char.pieceLargeRUID = data:GetCell(i, "pieceLargeRUID")
			char.valueDiamond = data:GetCell(i, "value_diamond")
			char.valueCard = data:GetCell(i, "value_card")
			
			char.fieldSkillRUID = data:GetCell(i, "fieldSkillRUID")
		 	local exWeaponId = data:GetCell(i, "exWeaponId")
			
			local numId = tonumber(string.sub(exWeaponId, 8, -1))
		
			local exWeaponTable = 
			{string.sub(exWeaponId,1,7)..tostring(numId), string.sub(exWeaponId,1,7)..tostring(numId+1), string.sub(exWeaponId,1,7)..tostring(numId+2),
					string.sub(exWeaponId,1,7)..tostring(numId+3), string.sub(exWeaponId,1,7)..tostring(numId+4)}
			
			char.exWeaponId = exWeaponTable
			char.exWeaponValue = data:GetCell(i, "exWeaponValue")
		
		
			char.defaultGoldPrice = data:GetCell(i, "defaultGoldPrice")
			char.defaultEssencePrice = data:GetCell(i, "defaultEssencePrice")
			char.cardRUID = data:GetCell(i, "cardRUID")
		
			char.charRUID = data:GetCell(i, "charRUID")
			char.desc = data:GetCell(i, "charDesc")
			char.levelEffectDesc = data:GetCell(i, "levelEffectDesc")
			char.lvEffect_desc_0 = data:GetCell(i, "lvEffect_desc_0")
			char.lvEffect_desc_1 = data:GetCell(i, "lvEffect_desc_1")
			char.lvEffect_desc_2 = data:GetCell(i, "lvEffect_desc_2")
			char.lvEffect_desc_3 = data:GetCell(i, "lvEffect_desc_3")
			char.lvEffect_desc_4 = data:GetCell(i, "lvEffect_desc_4")
			char.lvEffect_desc_5 = data:GetCell(i, "lvEffect_desc_5")
			
			char.relationId = data:GetCell(i, "relationId")
			
			self.characterTable[char.id] = char
			self.indexAndId[i] = tonumber(char.id)
			
			table.insert(self.characterIdTable, char.id)
		
			if self:IsClient() then
			end
		end
		
		local relationData =  _DataService:GetTable("CharacterRelationData")
		local relationStoryData = _DataService:GetTable("CharacterRelationStoryData")
		
		for i = 1, relationData:GetRowCount() do
			local relation = {}
			relation.id = relationData:GetCell(i, "id")
			relation.name = relationData:GetCell(i, "name")
			relation.desc = relationData:GetCell(i, "desc")
			
			relation.member_1 = relationData:GetCell(i, "member_1")
			relation.member_2 = relationData:GetCell(i, "member_2")
			relation.member_3 = relationData:GetCell(i, "member_3")
		
			relation.effect_1 = relationData:GetCell(i, "effectType_Lv1")
			relation.effect_2 = relationData:GetCell(i, "effectType_Lv2")
			relation.effect_3 = relationData:GetCell(i, "effectType_Lv3")
			relation.effect_4 = relationData:GetCell(i, "effectType_Lv4")
			relation.effect_5 = relationData:GetCell(i, "effectType_Lv5")
		
			relation.value_1 = tonumber(relationData:GetCell(i, "effectValue_Lv1")) / 100
			relation.value_2 = tonumber(relationData:GetCell(i, "effectValue_Lv2")) / 100
			relation.value_3 = tonumber(relationData:GetCell(i, "effectValue_Lv3")) / 100
			relation.value_4 = tonumber(relationData:GetCell(i, "effectValue_Lv4")) / 100
			relation.value_5 = tonumber(relationData:GetCell(i, "effectValue_Lv5")) / 100
		
			relation.story_name_1 = relationStoryData:GetCell(i, "name_level1")
			relation.story_name_2 = relationStoryData:GetCell(i, "name_level2")
			relation.story_name_3 = relationStoryData:GetCell(i, "name_level3")
			relation.story_name_4 = relationStoryData:GetCell(i, "name_level4")
			relation.story_name_5 = relationStoryData:GetCell(i, "name_level5")
			
			relation.story_desc_1 = relationStoryData:GetCell(i, "desc_level1")
			relation.story_desc_2 = relationStoryData:GetCell(i, "desc_level2")
			relation.story_desc_3 = relationStoryData:GetCell(i, "desc_level3")
			relation.story_desc_4 = relationStoryData:GetCell(i, "desc_level4")
			relation.story_desc_5 = relationStoryData:GetCell(i, "desc_level5")
		
			table.insert(self.relationIdTable, relation.id)
			self.relationTable[relation.id] = relation
			if self:IsClient() then
				_WeaponSpecLogic:DataInit()
				_UIGroupManager.uiCharacterInfoPopup:CloneRelationSlot(self.relationTable[relation.id])
			end
		end
		
		local tierSkillData = _DataService:GetTable("CharacterLevelSpecialEffect")
		for i = 1 , tierSkillData:GetRowCount() do
			local skillData = {}
			local skillTable = {tonumber(tierSkillData:GetCell(i, "1")), tonumber(tierSkillData:GetCell(i, "2")), tonumber(tierSkillData:GetCell(i, "3")),
				 tonumber(tierSkillData:GetCell(i, "4")), tonumber(tierSkillData:GetCell(i, "5"))} 
		
			skillData.id = tonumber(tierSkillData:GetCell(i, "id"))
			skillData.skillTable = skillTable
		
			self.characterTierEffectTable[skillData.id] = skillData
		end
		
		
		local hpData = _DataService:GetTable("CharacterLevelupData_Hp")
		local damageRateData = _DataService:GetTable("CharacterLevelupData_DamageRate")
		local attackSpeedData = _DataService:GetTable("CharacterLevelupData_AttackSpeed")
		local moveSpeedData = _DataService:GetTable("CharacterLevelupData_MoveSpeed")
		local criticalRateData = _DataService:GetTable("CharacterLevelupData_CriticalRate")
		local criticalDamageRateData = _DataService:GetTable("CharacterLevelupData_CriticalDamageRate")
		local typeDamageRateData = _DataService:GetTable("CharacterLevelupData_TypeDamageRate")
		local bossDamageRateData =_DataService:GetTable("CharacterLevelupData_BossDamageRate")
		
		self.charMaxLevel = hpData:GetRowCount()
		for i = 1 , hpData:GetRowCount() do
			for key, value in pairs (self.characterIdTable) do
				local status = {}
				status.id = value
				
				status.maxHp = tonumber(hpData:GetCell(i, value))
				status.damageRate = tonumber(damageRateData:GetCell(i, value)) 
				status.attackSpeed = tonumber(attackSpeedData:GetCell(i, value)) / 100
				status.moveSpeed = tonumber(moveSpeedData:GetCell(i, value)) / 100
				status.criticalRate = tonumber(criticalRateData:GetCell(i, value))
				status.criticalDamageRate = tonumber(criticalDamageRateData:GetCell(i, value)) / 100
				status.typeDamageRate = tonumber(typeDamageRateData:GetCell(i, value)) / 100
				status.bossDamageRate = tonumber(bossDamageRateData:GetCell(i, value)) / 100
				
				if i == 1 then
					self.levelStatusTable[status.id] = {}
				end
				self.levelStatusTable[status.id][i] = status
			end
		end
	end

	method number GetCharLevelupGoldCost(string type, number level)
		-- 캐릭터 레벨업 비용 계산 (골드/에센스)
		local costData = _DataService:GetTable("CharacterLevelupData_Cost")
		
		if type == "gold" then
			return tonumber(costData:GetCell(level + 1 , "gold"))	
		elseif type == "essence" then
			if costData:GetCell(level, "essence") ~= "" then
				return tonumber(costData:GetCell(level + 1, "essence"))
			else
				return  0
			end
		end
	end

	method table GetCharBreakLimitCost(number tier)
		-- 캐릭터 돌파 비용 및 요구사항 조회
		local costData = _DataService:GetTable("CharacterBreakLimit_Cost")
		
		if tier >= 5 then
			return
		end
		
		local data = {}
		
		data.needPiece = tonumber(costData:GetCell(tier + 1, "piece"))
		data.nextMaxLevel = tonumber(costData:GetCell(tier + 1, "nextMaxLevel"))
		data.prevMaxLevel = tonumber(costData:GetCell(tier + 1, "prevMaxLevel"))
		
		return data
	end

	method number FindLevelUpEffectValue(number index, string type)
		-- 캐릭터 레벨업 특수 효과 값 조회
		local sfData = _DataService:GetTable("CharacterLevelSpecialEffect")
		return tonumber(sfData:GetCell(index, type)) 
	end

	method table GetCharacterStatus(number index, number level)
		-- 캐릭터 레벨별 스테이터스 정보 조회
		local data = {}
		
		data = self.levelStatusTable[tostring(math.floor(index))][level]
		
		return data
	end

	method number GetCharacterRelationLevel(string relationId, string charId)
		-- 캐릭터 관계 레벨 조회
		
		return 0
	end

	method table GetCharacterRelationEffect(number level, string id)
		-- 캐릭터 관계 효과 정보 조회
		local tdata = self.relationTable[id]
		
		local effectName = {tdata.effect_1, tdata.effect_2, tdata.effect_3, tdata.effect_4, tdata.effect_5}
		local effectValue = {tdata.value_1, tdata.value_2, tdata.value_3, tdata.value_4, tdata.value_5}
		
		local data ={}
		
		local tempName ={}
		local tempValue = {}
		
		for i = 1 , level do
			table.insert(tempName, effectName[i])
			table.insert(tempValue, effectValue[i])
		end
		
		data.effectName = tempName
		data.effectValue = tempValue
		
		
		
		
		
		return data
		
	end

	method table GetStoryNumber(number page, string id)
		-- 캐릭터 관계 스토리 정보 조회
		local data = {}
		
		if page == 1 then
			data.name = self.relationTable[id].story_name_1
			data.desc =	self.relationTable[id].story_desc_1
		elseif page == 2 then
			data.name = self.relationTable[id].story_name_2
			data.desc =	self.relationTable[id].story_desc_2
		elseif page  == 3 then
			data.name = self.relationTable[id].story_name_3
			data.desc =	self.relationTable[id].story_desc_3
		elseif page == 4 then	
			data.name = self.relationTable[id].story_name_4
			data.desc =	self.relationTable[id].story_desc_4
		elseif page == 5 then
			data.name = self.relationTable[id].story_name_5
			data.desc =	self.relationTable[id].story_desc_5
		end
		
		return data
	end

	@ExecSpace("Client")
	method void RefreshCharacterSlot(string charIndex)
		-- 캐릭터 슬롯 UI 갱신
		_UIGroupManager.uiCharacterInfoPopup:RefreshCharacterSlot(charIndex)
	end

	method table GetRelationStatusTable(table relationTable)
		-- 캐릭터 관계 스테이터스 테이블 생성
		local relationStatusTable = {}
		
		relationStatusTable["attackSpeed"] = 0
		relationStatusTable["criticalPercent"] = 0
		relationStatusTable["physicalDamage"] = 0
		relationStatusTable["magicalDamage"] = 0
		relationStatusTable["criticalDamage"] = 0
		
		for key, value in pairs(relationTable) do
			for i = 1, #value.effect do
				if value.effect[i] == "attackSpeed" then
					relationStatusTable["attackSpeed"] = relationStatusTable["attackSpeed"] + value.value[i]
				elseif value.effect[i] == "criticalPercent" then
					relationStatusTable["criticalPercent"] = relationStatusTable["criticalPercent"] + value.value[i]
				elseif value.effect[i] == "physicalDamage" then
					relationStatusTable["physicalDamage"] = relationStatusTable["physicalDamage"] + value.value[i]
				elseif value.effect[i] == "magicalDamage" then		
					relationStatusTable["magicalDamage"] = relationStatusTable["magicalDamage"] + value.value[i]
				elseif value.effect[i] == "criticalDamage" then	
					relationStatusTable["criticalDamage"] = relationStatusTable["criticalDamage"] + value.value[i]
				end
			end
		end
		
		return relationStatusTable
	end

	method boolean CheckMatchExWeapon(string weaponId, string charId)
		-- 캐릭터와 전용 무기 매칭 여부 확인
		if not isvalid(self.characterTable[charId]) then
			return false
		end
		
		for i = 1 , #self.characterTable[charId].exWeaponId do
			
			if weaponId == self.characterTable[charId].exWeaponId[i] then
				
				return true
			end	
		end
		
		return false
	end

	method integer GetMaxPieceCount(integer tier, integer index, Entity user)
		-- 캐릭터 티어별 최대 조각 개수 조회
		local findMaxCount = 0
		
		if not isvalid(user.PlayerCharacterData.charDeckStorage[index]) then 
			return 1	
		end
		
		if tier == 0 then 
			findMaxCount = 4
		elseif tier == 1 then 
			findMaxCount = 5
		elseif tier == 2 then 
			findMaxCount = 10
		elseif tier == 3 then 
			findMaxCount = 10
		elseif tier == 4 then 
			findMaxCount = 20
		else 
			findMaxCount = 100
		end
		
		return findMaxCount
	end

	method boolean GetLevelUpEnable(Entity player, integer level)
		-- 캐릭터 레벨업 가능 여부 확인
		
		if level >= 50 then
			return false
		end
		
		local playerMeso = player.PlayerCurrencyData.currencyTable["Gold"].amount
		local playerEssence = player.PlayerCurrencyData.currencyTable["Essence"].amount
		
		local needMeso = self:GetCharLevelupGoldCost("gold", level)
		local needEssence = self:GetCharLevelupGoldCost("essence", level)
		
		if (playerMeso >= needMeso) and (playerEssence >= needEssence) then 
			return true	
		else
			return false
		end
	end

	method boolean GetBreakLimitEnable(Entity player, integer tier, integer index)
		-- 캐릭터 돌파 가능 여부 확인
		
		if tier >= 5 then
			return false
		end
		
		local playerPieceCount = player.PlayerCharacterData.charPieceStorage[index].count
		
		local data = self:GetCharBreakLimitCost(tier)
		local needPieceCount = data.needPiece
		
		if playerPieceCount >= needPieceCount then
			return true
		else
			return false
		end
	end

	method table GetExWeaponTable(string id)
		-- 캐릭터의 전용 무기 테이블 반환
		return self.characterTable[id].exWeaponId
		
	end

	method string GetExWeaponCategoryIconRUID(string id)
		-- 캐릭터 전용 무기 카테고리 아이콘 RUID 반환
		local weapons = self:GetExWeaponTable(id)
		if weapons == nil or #weapons == 0 then
			return
		end
		local weapnSpec = _WeaponSpecLogic:GetWeaponSpec(weapons[1])
		if weapnSpec == nil then
			return ""
		end
		
		return _WeaponSpecLogic:GetWeaponCategoryIcon(weapnSpec.type)
	end

	@ExecSpace("Server")
	method void RequestGetCharacterFromClient(string index)
		-- 클라이언트에서 캐릭터 획득 요청 처리
		local playerEntity = _UserService:GetUserEntityByUserId(senderUserId)
		
		if not isvalid(playerEntity) then
			return
		end
		
		playerEntity.PlayerCharacterData:GetCharacter(index)
	end

end