@Component
script PetSlotComponent extends Component

	@HideFromInspector
	property Entity sprite = nil

	@HideFromInspector
	property Entity gradeText = nil

	@HideFromInspector
	property Entity levelText = nil

	@HideFromInspector
	property Entity petTitleText = nil

	@HideFromInspector
	property Entity skillDescriptionText = nil

	@HideFromInspector
	property string currentId = ""

	@HideFromInspector
	property string currentUniqueKey = ""

	property integer slotNum = 0

	@HideFromInspector
	property Entity petSpriteSlot = nil

	property Entity background = nil

	property Entity category = nil

	property Entity categoryIcon = nil

	property Entity gradeIcon = nil

	property UIPetPopup petList = "7daa4e55-82eb-4357-9158-8f056e0145d2"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- 펫 슬롯 UI 요소들을 초기화하고 클릭 이벤트 연결
		self.sprite = self.Entity:GetChildByName("Sprite", true)
		self.levelText = self.Entity:GetChildByName("level", true)
		self.slotNum = tonumber(_UtilLogic:Split(self.Entity.Name, "_")[2])
		
		
		self.Entity.Parent:ConnectEvent(ButtonClickEvent, self.OnClick)
		self.Entity:ConnectEvent(ButtonClickEvent, self.OnClick)
	end

	@ExecSpace("ClientOnly")
	method void SetUniqueKey(string uniqueKey)
		-- 펫의 고유 키를 설정하고 인벤토리에서 아이디 가져오기
		
		self.currentUniqueKey = uniqueKey
		if not _UtilLogic:IsNilorEmptyString(uniqueKey) then
			local playerStorage = _UserService.LocalPlayer.PlayerPetStorageComponent
			self.currentId = playerStorage.petInventory[self.currentUniqueKey].originalId
			_UIGroupManager:SetItemSlot(self.Entity, 3 , uniqueKey, "")
			self.Entity:GetChildByName("equipped", false)	
		end
		
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string id)
		-- 펫 슬롯에 펫 데이터를 설정하고 등급에 따른 UI 색상 적용
		local petData = _PetLogic.petData[self.currentId]
		self.sprite.SpriteGUIRendererComponent.ImageRUID = petData.ruid
		
		self.sprite.SpriteGUIRendererComponent.Color.a = 1
		self.sprite.SpriteGUIRendererComponent.LocalPosition = Vector2(tonumber(petData.pivotX), tonumber(petData.pivotY))
		
		self.levelText.TextComponent.Text = _UserService.LocalPlayer.PlayerPetStorageComponent.petInventory[self.currentUniqueKey].level
		
		local grade = petData.grade
		local slotRUID = _PetUILogic:GetPetColorByGrade(grade)
		self.background.SpriteGUIRendererComponent.ImageRUID = slotRUID.backgroundRUID
		self.category.SpriteGUIRendererComponent.ImageRUID = slotRUID.categoryRUID
		self.categoryIcon.SpriteGUIRendererComponent.ImageRUID = slotRUID.categoryIconRUID
		self.gradeIcon.SpriteGUIRendererComponent.ImageRUID = slotRUID.gradeIconRUID
		
		self.Entity:GetChildByName("equipped", true):SetEnable(false)
		
	end

	@ExecSpace("ClientOnly")
	method void Init()
		-- 펫 슬롯 초기화 (현재 비활성화됨)
		
		if true then 
			return
		end
		--[[
		self.petSpriteSlot.SpriteGUIRendererComponent.Outline = false
		self.sprite.SpriteGUIRendererComponent.ImageRUID = ""
		self.sprite.SpriteGUIRendererComponent.Color.a = 0
		self.sprite.SpriteGUIRendererComponent.LocalPosition = Vector2.zero
		self.levelText.TextComponent.Text = ""
		self.currentId = ""
		self.currentUniqueKey = ""]]--
	end

	@ExecSpace("ClientOnly")
	method void OnClick()
		-- 펫 슬롯 클릭 시 펫 정보 팝업 표시 또는 빈 슬롯 메시지 표시
		if self.currentUniqueKey == "" then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast229"))
		else
			local petList = _UIGroupManager.uiPlayerStatusPopup.petList.PetListComponent
			local petInfo = petList.petInformationPanel.PetInformationPopup
			
			petList:SetDescriptionPanel(self.currentUniqueKey)	
			petList.petInformationPanel.PetInformationPopup:ShowByButtonClick()
		end
	end

	@ExecSpace("ClientOnly")
	method void RequestEquip()
		-- 펫 장착 요청 처리 및 UI 새로고침
		local player = _UserService.LocalPlayer
		local petStorage = player.PlayerPetStorageComponent
		local petData = _PetLogic.petData[self.currentId]
		_PetUILogic.currentSlotNum = self.slotNum
		
		local equipPet = function()
			petStorage:EquipPet(_PetUILogic.selectedUniqueKey, _PetUILogic.currentSlotNum)
			_PetUILogic.selectedUniqueKey = ""
			_PetUILogic.selectableEquipSlot = false
		end
		
		if self.currentUniqueKey == "" then
			if _PetUILogic.selectableEquipSlot then
				equipPet()
			end
		end
		self.petList:Refresh()
	end

end