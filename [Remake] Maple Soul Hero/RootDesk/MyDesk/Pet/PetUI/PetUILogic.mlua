@Logic
script PetUILogic extends Logic

	property UIPetPopup petGroup = "7daa4e55-82eb-4357-9158-8f056e0145d2"

	property PetListComponent petList = "7daa4e55-82eb-4357-9158-8f056e0145d2"

	property integer currentSlotNum = 1

	property PetRandomPickUIComponent petRandomPick = "560a2100-9a96-4a26-9855-129677a73838"

	property PetLevelUpListComponent petLevelUpList = "ac154e24-e3c4-45bc-a567-b71197406a76"

	property Entity petUI = "fc518843-2058-4e56-b41c-99055d3a5a5b"

	property Entity petLevelUpUI = "d4b96257-424c-4f77-9b73-3c485b6e92aa"

	property boolean selectableEquipSlot = false

	property string selectedUniqueKey = ""

	property UIPetPopup petInformationUI = "7daa4e55-82eb-4357-9158-8f056e0145d2"

	property Entity petInformation = "3b9bb7f1-3580-4db9-9d82-c8a129665976"

	@ExecSpace("ClientOnly")
	method void RefreshPetList()
		-- 펫 리스트 UI를 새로고침
		self.petList:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void RefreshPetUI()
		-- 펫 UI 그룹을 초기화하고 새로고침
		self.petGroup:Init()
		self.petGroup:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void SetPetListEnable(boolean onOff)
		-- 펫 리스트의 활성화 상태를 설정
		self.petList:SetEnable(onOff)
	end

	@ExecSpace("ClientOnly")
	method void RefreshPetLevelUpList()
		-- 펫 레벨업 리스트를 새로고침하고 예상 경험치 계산
		self.petLevelUpList:SetPetInfo(self.petLevelUpList.currentUniqueKey)
		self.petLevelUpList:Refresh()
		self.petLevelUpList:CalcPredictExp()
	end

	method table GetPetColorByGrade(string grade)
		-- 펫 등급에 따른 색상 정보를 반환
		local results = {}
		results.backgroundRUID = ""
		results.categoryRUID = ""
		results.gradeIconRUID = ""
		results.categoryIconRUID = "5b473b73c1374e6ead911e6e55c4348a"
		
		if grade == "S" then
			results.backgroundRUID = "a23dc02712e94ba7a9aa82e819171486"
			results.categoryRUID = "a23dc02712e94ba7a9aa82e819171486"
			results.gradeIconRUID = "a3754baddd9846ca94c9ba733cc736f4"
		elseif grade == "A" then
			results.backgroundRUID = "a921b49abb4c4808a9749bdfa1bd049d"
			results.categoryRUID = "a921b49abb4c4808a9749bdfa1bd049d"
			results.gradeIconRUID = "21a9dc4302a343f282876c38dc621fb7"
		elseif grade == "B" then
			results.backgroundRUID = "345bb836122d431881f04f4603f0ea1f"
			results.categoryRUID = "345bb836122d431881f04f4603f0ea1f"
			results.gradeIconRUID = "5a92ea9d310849fd85f9a4b61de6b963"
		end
		
		return results
	end

	@ExecSpace("ClientOnly")
	@EventSender("LocalPlayer")
	handler HandlePetLevelUpEvent(PetLevelUpEvent event)
		-- 펫 레벨업 이벤트 발생 시 레벨업 리스트 새로고침
		self:RefreshPetLevelUpList()
	end

end