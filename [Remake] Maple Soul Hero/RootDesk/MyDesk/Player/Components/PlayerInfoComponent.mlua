		-- 필드 로그아웃 시간을 기록
		self.playerInfo.fieldLogoutTime = _LocalTimeLogic:GetElapsedSecond()
	end

	@ExecSpace("ServerOnly")
	method void RefreshDecoration()
		-- 장식 아이템들을 새로고침하고 장착 상태 동기화
		local storageCompo = self.Entity.PlayerStorageComponent
		
		if not storageCompo.isLoaded then
			_TimerService:SetTimerOnce(function() self:RefreshDecoration() end, 1)
			
			return
		end
		
		local storage = storageCompo.storage
		
		local equipNameTag = "5_000002"
		local equipChatBalloon = "5_000003"
		
		for key, value in pairs(storage) do
			if value.equippedSlotNum == _GameEnum.EQUIPNUM_NAMETAG then
				equipNameTag = value.originalId
			elseif value.equippedSlotNum == _GameEnum.EQUIPNUM_CHATBALLOON then
				equipChatBalloon = value.originalId
			end
		end
		
		self:BroadcastSetDecoration("NameTag", equipNameTag)
		self:BroadcastSetDecoration("ChatBalloon", equipChatBalloon)
		
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- 네임태그와 채팅벌룬 동기화 시 UI 업데이트
		if name == "nameTag" then
			local data = _ItemDataLogic.decorationData[value] 
			local ruid = data.ruid
			local offset = Vector2(data.offsetX, data.offsetY)
			
			self.Entity.NameTagComponent.NameTagRUID = ruid
			self.Entity.NameTagComponent.FontColor = Color.FromHexCode(data.color)
			self.Entity.NameTagComponent.FontOffset = offset
		elseif name == "chatBalloon" then
			local data = _ItemDataLogic.decorationData[value]
			local ruid = data.ruid
			local offset = Vector2(data.offsetX, data.offsetY)
			
			self.Entity.ChatBalloonComponent.ChatBalloonRUID = ruid
			self.Entity.ChatBalloonComponent.FontColor = Color.FromHexCode(data.color)
			self.Entity.ChatBalloonComponent.FontOffset = offset
		end
	end

	@ExecSpace("Client")
	method void ShowGetFieldTutorialReward()
		-- 필드 튜토리얼 보상 획득 UI 표시
		local itemInfos = {}
		itemInfos[1] = {["id"] = "101_000001", ["itemType"] = "item", ["count"] = 1, ["grade"] = "B"}
		itemInfos[2] = {["id"] = "", ["itemType"] = "fieldStatusPoint" , ["count"] = 1 , ["grade"] = ""}
		_ItemListPopUp:Open(itemInfos, nil, "획득")
	end

	@ExecSpace("ServerOnly")
	method void CheckEnteredDate()
		-- 접속 날짜를 확인하고 주간 리셋 처리
		local currentSeasonWeek = _LocalTimeLogic:GetCurrentSeasonWeek()
		
		if currentSeasonWeek ~= self.playerInfo.recordedBestLimitLandWeek then 
			self:SetLimitLandRewardedNum(0)
			self.playerInfo.prevLimitLandWave = self.playerInfo.weekBestLimitLandWave
			self.playerInfo.prevLimitLandRecordedTime = self.playerInfo.weekLimitLandRecordedTime
			
			self:SetPlayerInfoInClient(_HttpService:JSONEncode(self.playerInfo), self.userId)
		end
	end

end