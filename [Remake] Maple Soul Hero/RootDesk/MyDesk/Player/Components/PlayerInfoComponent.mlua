	@ExecSpace("Server")
	method void RequestGetRecommendStage()
		-- 추천 스테이지를 계산하고 클라이언트에 전송
		
		self.minRecommendStage = self.playerInfo.stageStep - 9
		if self.minRecommendStage < 0 then
			self.minRecommendStage = 1
		end
		
		if self.playerInfo.stageStep - 9 >= self.minRecommendStage and self.playerInfo.stageStep < 80 then
			self.minRecommendStage += 1
		end
		
		self:SetRecommendStageInClient(self.minRecommendStage)
	end

	@ExecSpace("Client")
	method void SetRecommendStageInClient(integer num)
		-- 클라이언트에서 추천 스테이지 번호를 설정
		self.minRecommendStage = num
	end

