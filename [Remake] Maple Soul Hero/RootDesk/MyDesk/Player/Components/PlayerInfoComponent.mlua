		self.isInvalidRecord = false
	end

	@ExecSpace("Server")
	method void RefreshClearInfo()
		-- 일일 클리어 정보를 갱신하고 날짜별 초기화 처리
		if not isvalid(self.playerInfo.clearCount) or self.playerInfo.enteredDate == "" then
			self.playerInfo.enteredDate = tostring(_LocalTimeLogic:GetKST())
			self.playerInfo.clearCount = 0
			pcall(function()
				_WorldLog:LogInitDataFlow(self.userId, _WorldLog.DataType_RecommendStageClearCount, "1", "1", "0", "0")
				end)
		else
			local enteredDate = ""
		
			if self.playerInfo.enteredDate ~= "" then
				enteredDate = DateTime(self.playerInfo.enteredDate)
			end
			
			local currentDate = _LocalTimeLogic:GetKST()
		
			
			if enteredDate.Year ~= currentDate.Year or enteredDate.Month ~= currentDate.Month or enteredDate.Day ~= currentDate.Day then
				pcall(function()
					_WorldLog:LogInitDataFlow(self.userId, _WorldLog.DataType_RecommendStageClearCount, "1", "2", tostring(self.playerInfo.clearCount), "0")
					end)
				self.playerInfo.clearCount = 0
				self.playerInfo.enteredDate = tostring(_LocalTimeLogic:GetKST())
				
			end
		end
		
		self:SetClearInfoInClient(self.playerInfo.enteredDate, self.playerInfo.clearCount, self.userId)
	end

	@ExecSpace("ServerOnly")
	method void AddClearCount()
		-- 일일 클리어 횟수를 1 증가
		self:RefreshClearInfo()
		
		self.playerInfo.clearCount += 1
		self:SetClearInfoInClient(self.playerInfo.enteredDate, self.playerInfo.clearCount, self.userId)
	end

