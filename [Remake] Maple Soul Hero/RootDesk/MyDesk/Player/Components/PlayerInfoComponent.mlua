	@ExecSpace("ServerOnly")
	method void SetChatBalloon(string itemId, boolean causeDBLoad)
		-- 채팅벌룬을 설정하고 장착 처리
		local storageCompo = self.Entity.PlayerStorageComponent
		
		if not storageCompo.isLoaded then
			_TimerService:SetTimerOnce(function() self:SetChatBalloon(itemId, causeDBLoad) end, 1)
			
			return
		end
		
		local storage = storageCompo.storage
		local unEquip = ""
		local equip = ""
		
		for key, value in pairs(storage) do
			if value.equippedSlotNum == _GameEnum.EQUIPNUM_CHATBALLOON then
				if causeDBLoad then
					equip = key
				else
					unEquip = key
				end
			elseif value.originalId == itemId then
				equip = key
			end
		end
		
		if not _UtilLogic:IsNilorEmptyString(unEquip) then
			storageCompo:UnEquip(unEquip)
		
		
		end
		
		if itemId ~= "5_000003" and not _UtilLogic:IsNilorEmptyString(equip) then
			storageCompo:Equip(equip, _GameEnum.EQUIPNUM_CHATBALLOON)
		else
			itemId = "5_000003"
		end
		
		self.playerInfo.chatBalloon = itemId
		self.chatBalloon = itemId
			
		self:SetPlayerInfoData()
		self:SetPlayerInfoInClient(_HttpService:JSONEncode(self.playerInfo), self.userId)
		self:BroadcastSetDecoration("ChatBalloon", itemId)
	end

	@ExecSpace("ServerOnly")
	method void SetDecoration(string itemId)
		-- 장식 아이템을 카테고리에 따라 설정
		local decorationData = _ItemDataLogic.decorationData[itemId]
		
		if decorationData.category == "damageSkin" then
			self:SetDamageSkin(itemId, false)
		elseif decorationData.category == "nameTag" then
			self:SetNameTag(itemId, false)
		elseif decorationData.category == "chatBalloon" then
			self:SetChatBalloon(itemId, false)
		end
		
		self:NoticeSuccessDecorate(itemId, self.userId)
	end

	@ExecSpace("Client")
	method void NoticeSuccessDecorate(string itemId)
		-- 장식 아이템 장착 성공 알림 표시
		local name = _LocalizeLogic:GetItemName(itemId) 
		
		_UIToast:ShowMessage(string.format(_LocalizeLogic:GetText("toast243"), name))
	end

	@ExecSpace("ServerOnly")
	method void AddBuff(string buffId, integer count)
		-- 버프를 추가하고 기존 버프와 합치거나 새로 생성
		local buffStr = self.playerInfo.appliedBuff
		
		if buffStr == nil or buffStr == "" then
			buffStr = string.format("%s_%d", buffId, count)
		else
			local splits = _UtilLogic:Split(buffStr, "/")
			local found = false
			local newStr = ""
			
			for key, value in pairs(splits) do
				local buffSplits = _UtilLogic:Split(value, "_")
				
				if buffSplits[1] == buffId then
					if newStr == "" then
						newStr = string.format("%s_%d", buffId, tonumber(buffSplits[2]) + count)
					else
						newStr = string.format("%s/%s_%d", newStr, buffId, tonumber(buffSplits[2]) + count)
					end
					
					found = true
				else
					if newStr == "" then
						newStr = string.format("%s", value)
					else
						newStr = string.format("%s/%s", newStr, value)
					end
				end
			end
			
			if not found then
				buffStr = string.format("%s/%s_%d", newStr, buffId, count)
			else
				buffStr = newStr
			end
		end
		
		self:SetBuff(buffStr)
	end

	@ExecSpace("ServerOnly")
	method void ReduceBuff(string buffId, integer count)
		-- 버프를 감소시키고 0이 되면 제거
		local buffStr = self.playerInfo.appliedBuff
		
		if buffStr == "" then
			
			return
		else
			local splits = _UtilLogic:Split(buffStr, "/")
			local found = false
			local newStr = ""
			
			for key, value in pairs(splits) do
				local buffSplits = _UtilLogic:Split(value, "_")
				local id = buffSplits[1]
				local buffCount = tonumber(buffSplits[2])
				
				if id == buffId then
					if buffCount - count > 0 then
						if newStr == "" then
							newStr = string.format("%s_%d", buffId, buffCount - count)
						else
							newStr = string.format("%s/%s_%d", newStr, buffId, buffCount - count)
						end
					end
				else
					if newStr == "" then
						newStr = string.format("%s", value)
					else
						newStr = string.format("%s/%s", newStr, value)
					end
				end
			end
			
			buffStr = newStr
		end
		
		self:SetBuff(buffStr)
	end

	@ExecSpace("ServerOnly")
	method boolean CheckAndReduceBuff(string buffId)
		-- 버프 존재 여부를 확인하고 1개 감소
		local buffStr = self.playerInfo.appliedBuff
		
		if buffStr == "" then
		else
			local splits = _UtilLogic:Split(buffStr, "/")
			local found = false
			
			for key, value in pairs(splits) do
				local buffSplits = _UtilLogic:Split(value, "_")
				local id = buffSplits[1]
				
				if id == buffId then
					self:ReduceBuff(buffId, 1)
					
					return true
				end
			end
		end
		
		return false
	end

	method void CheckValidFields()
		-- 플레이어 정보 필드의 유효성을 검사하고 초기화
		if not isvalid(self.playerInfo.stageStep) then
			self:InitData()
			
			return
		end
		
		if not isvalid(self.playerInfo.armorStorageSlot) then
			self.playerInfo.armorStorageSlot = 0
			self.playerInfo.weaponStorageSlot = 0
			self.playerInfo.petStorageSlot = 0
			self.playerInfo.consumeStorageSlot = 0
			self.playerInfo.etcStorageSlot = 0
		end
		
		if not isvalid(self.playerInfo.accessoryStorageSlot) then
			self.playerInfo.accessoryStorageSlot = 0
		end
	end

	@ExecSpace("ServerOnly")
	method void SetStorageSlot(string slotType, integer slotNum)
		-- 스토리지 슬롯 수를 타입별로 설정
		if slotType == "armor" then
			self.playerInfo.armorStorageSlot = slotNum
		elseif slotType == "weapon" then
			self.playerInfo.weaponStorageSlot = slotNum
		elseif slotType == "pet" then
			self.playerInfo.petStorageSlot = slotNum
		elseif slotType == "consume" then
			self.playerInfo.consumeStorageSlot = slotNum
		elseif slotType == "etc" then
			self.playerInfo.etcStorageSlot = slotNum
		elseif slotType == "accessory" then
			self.playerInfo.accessoryStorageSlot = slotNum
		end
		
		self:SetPlayerInfoInClient(_HttpService:JSONEncode(self.playerInfo), self.userId)
	end

	@ExecSpace("Server")
	method void AddTotalPlayedTime(number delta)
		-- 총 플레이 시간을 추가 (분 단위)
		if self.Entity.PlayerDBComponent.dbInited == false then
			return
		end
		if self.playerInfo.totalPlayedTime == nil then
			self.playerInfo.totalPlayedTime = 0
		end
		self.playerInfo.totalPlayedTime = self.playerInfo.totalPlayedTime + delta / 60
	end

	@ExecSpace("Server")
	method void AddStageStart()
		-- 스테이지 시작 횟수를 증가
		if self.Entity.PlayerDBComponent.dbInited == false then
			return
		end
		if self.playerInfo.totalStageStart == nil then
			self.playerInfo.totalStageStart = 0
		end
		self.playerInfo.totalStageStart = self.playerInfo.totalStageStart + 1
	end

	@ExecSpace("Server")
	method void AddStageEnd(number time)
		-- 스테이지 종료 횟수를 증가하고 플레이 시간 기록
		if self.Entity.PlayerDBComponent.dbInited == false then
			return
		end
		self:AddTotalPlayedTime(time)
		if self.playerInfo.totalStageEnd == nil then
			self.playerInfo.totalStageEnd = 0
		end
		self.playerInfo.totalStageEnd = self.playerInfo.totalStageEnd + 1
	end

	@ExecSpace("Client")
	method void BroadcastSetDecoration(string decorationType, string itemId)
		-- 장식 아이템 설정을 브로드캐스트하고 UI에 반영
		if not isvalid(_ItemDataLogic.decorationData[itemId]) then
			
			return
		end
		
		local data = _ItemDataLogic.decorationData[itemId] 
		local ruid = data.ruid
		local offset = Vector2(data.offsetX, data.offsetY)
		
		if decorationType == "NameTag" then
			self.Entity.NameTagComponent.NameTagRUID = ruid
			self.Entity.NameTagComponent.FontOffset = offset
		elseif decorationType == "ChatBalloon" then
			self.Entity.ChatBalloonComponent.ChatBalloonRUID = ruid
			self.Entity.ChatBalloonComponent.FontOffset = offset
		end
	end

