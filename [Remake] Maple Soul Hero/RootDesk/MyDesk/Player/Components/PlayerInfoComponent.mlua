	@ExecSpace("Server")
	method void SetQuickSlot(integer slot, string itemId)
		-- 퀵 슬롯에 아이템을 설정하거나 해제
		if senderUserId ~= self.userId then
			return
		end
		
		if self.playerInfo.qSlot == nil then
			self.playerInfo.qSlot = {
				"",""
			}
		end
		
		
		if self.playerInfo.qSlot[slot] == itemId then
			self.playerInfo.qSlot[slot] = ""
		else
			self.playerInfo.qSlot[slot] = itemId
		end
		
		
		self:SetPlayerInfoInClient(_HttpService:JSONEncode(self.playerInfo), self.userId)
	end

