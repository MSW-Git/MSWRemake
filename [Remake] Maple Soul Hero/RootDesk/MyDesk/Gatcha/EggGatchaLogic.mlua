@Logic
script EggGatchaLogic extends Logic

	property table gatchaData = {}

	method void OnBeginPlay()
		-- 알 가차 데이터 테이블을 로드하여 가중치와 레벨 정보 초기화
		local data = _DataService:GetTable("EggGatcha")
		
		for i = 1, data:GetRowCount() do
			local id = data:GetCell(i, "id")
			local lv = tonumber(data:GetCell(i, "lv"))
			local weight = tonumber(data:GetCell(i, "weight"))
			if self.gatchaData[id] == nil then
				self.gatchaData[id] = {}
			end
			if self.gatchaData[id].weight == nil then
				self.gatchaData[id].weight = weight
			else
				self.gatchaData[id].weight = self.gatchaData[id].weight + weight
			end
			if self.gatchaData[id].randomTable == nil then
				 self.gatchaData[id].randomTable = {}
			end
			table.insert(self.gatchaData[id].randomTable,{lv=lv;weight=self.gatchaData[id].weight})
			
		end
	end

	@ExecSpace("ServerOnly")
	method number RequestEggLevel(string gatchaId)
		-- 가중치에 따라 랜덤하게 알의 레벨을 결정하여 반환
		local gatchaData = self.gatchaData[gatchaId]
		
		if gatchaData == nil then
			return -1
		end
		if gatchaData.weight == nil then
			return -1
		end
		
		if gatchaData.randomTable == nil or #gatchaData.randomTable == 0 then
			return -1
		end
		
		local random = _UtilLogic:RandomIntegerRange(1,gatchaData.weight)
		for k,v in pairs(gatchaData.randomTable) do
			if random <= v.weight then
				return v.lv
			end
		end
		
		return gatchaData.randomTable[1].lv
		
		
	end

	@ExecSpace("ServerOnly")
	method string EggLevelToGrade(integer level)
		-- 알의 레벨에 따라 등급(normal, rare, epic, unique, legendary)을 결정
		local grade = "normal"
		if level < 2 then
			grade = "normal"
		elseif level < 6 then
			grade = "rare" 
		elseif level < 14 then
			grade = "epic"
		elseif level < 30 then
			grade = "unique"
		else
			grade = "legendary"
		end
		
		return grade
	end

end