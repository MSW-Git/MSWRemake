@Component
script CashShopCategoryButtonComponent extends Component

	property string categoryId = ""

	property CashShopUIComponent cashShopUI = "7b5fa4aa-7adc-4def-ba00-23f3efc06ef0"

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 캐시샵 카테고리 버튼 클릭 시 해당 카테고리로 전환
		
		local Entity = event.Entity
		if self.categoryId == "4" then
			if _CashShopLogic.cashShopUI.Entity.ContentLockComponent:CheckUIAvailable() == false then
				return
			end
		end
		self.cashShopUI.currentShopCategory = self.categoryId
		self.cashShopUI:ChangeTapButton(self.Entity)
		_UserService.LocalPlayer.PlayerInfoComponent:RefreshPurchasedCount()
	end

end