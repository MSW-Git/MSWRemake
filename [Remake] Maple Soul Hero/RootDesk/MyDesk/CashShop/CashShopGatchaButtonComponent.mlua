@Component
script CashShopGatchaButtonComponent extends Component

	property string gatchaId = ""

	property CashShopUIComponent cashShopUI = "7b5fa4aa-7adc-4def-ba00-23f3efc06ef0"

	@ExecSpace("ClientOnly")
	method void RequestGatcha()
		-- 가챠 요청을 서버로 전송
		_GatchaLogic:RequestGatcha(self.gatchaId)
	end

	@ExecSpace("ClientOnly")
	method void SetSlot(string gatchaId)
		-- 가챠 버튼의 UI 정보를 설정
		self.gatchaId = gatchaId
		
		local data = _GatchaLogic.gatchaData[self.gatchaId]
		local str = ""
		if data.gatchaType == "armor" then
			if data.gatchaNum == 1 then
				str = _LocalizeLogic:GetText("cashShopStr1")
			else
				str = _LocalizeLogic:GetText("cashShopStr2")
			end
		else
			if data.gatchaNum == 1 then
				str = _LocalizeLogic:GetText("cashShopStr1")
			else
				str = _LocalizeLogic:GetText("cashShopStr2")
			end
		end
		
		if isvalid(self.Entity:GetChildByName("NameText")) then 
			self.Entity.TextComponent.Text = ""
			self.Entity:GetChildByName("NameText").TextComponent.Text = str
		else
			self.Entity.TextComponent.Text = str	
		end
		
		
		local text = self.Entity:GetChildByName("PriceText")
		local icon = self.Entity:GetChildByName("Icon", true)
		local renderer = icon.SpriteGUIRendererComponent
		
		text.TextComponent.Text = string.format("%d", data.price)
		
		if data.wealthType == "diamond" then
			renderer.ImageRUID = _GameConfig:GetConfig().RUID_DIAMOND
			renderer.LocalPosition = Vector2.zero
		elseif data.wealthType == "worldCoin" then
			renderer.ImageRUID = _GameConfig:GetConfig().RUID_WORLDCOIN
			renderer.LocalPosition = Vector2.zero
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 가챠 버튼 클릭 시 구매 확인 팝업 표시 후 가챠 실행
		
		local Entity = event.Entity
		if _UtilLogic.ServerElapsedSeconds < self.cashShopUI.buttonClickedTime + 1 then
			_UIToast:ShowMessage(_LocalizeLogic:GetText("toast23"))
		
			return 
		end
		if _UtilLogic.ServerElapsedSeconds < self.cashShopUI.purchaseRequestedTime + 1 then return end
		if _UIPopup.isOpen then return end
		
		local data = _GatchaLogic.gatchaData[self.gatchaId]
		
		if not _GatchaLogic:CheckCanGatchaOnClient(data) then
			return
		end
		
		if data.wealthType == "diamond" then
			_UIPopup:Open("",string.format(_LocalizeLogic:GetText("popup1"), _LocalizeLogic:GetGatchaName(self.gatchaId)), function()
					self:RequestGatcha()
					self.cashShopUI.purchaseRequestedTime = _UtilLogic.ServerElapsedSeconds
				end, nil)
		elseif data.wealthType == "worldCoin" then
			_WorldShopService:PromptPurchase(data.id)
			_CashShopLogic.cashShopUI.purchaseRequestedTime = _UtilLogic.ServerElapsedSeconds
		end
		
		self.cashShopUI.buttonClickedTime = _UtilLogic.ServerElapsedSeconds
	end

end