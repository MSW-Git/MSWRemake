@Component
script ButtonCheat extends Component

	property string key = ""

	property TextInputComponent connectedInputText = nil

	property Entity connectedTextLayout = nil

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonClickEvent(ButtonClickEvent event)
		-- 치트 버튼 클릭 시 연결된 입력값과 함께 치트 명령 실행
		--------------- Native Event Sender Info ----------------
		-- Sender: ButtonComponent
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local Entity = event.Entity
		---------------------------------------------------------
		if isvalid(self.connectedInputText) then
			_CheatLogic:OnCheatKey(_UserService.LocalPlayer,self.key, self.connectedInputText.Text)
		else
			if isvalid(self.connectedTextLayout) then
				local str = ""
				
				for _, entity in pairs(self.connectedTextLayout.Children) do
					if isvalid(entity.TextComponent) then
						local text = entity.TextComponent.Text
						
						if text == "Item 개수 입력" then
							text = "1"
						end
						
						if text == "" then
							_UIToast:ShowMessage("빈 값이 있습니다.")
							
							return
						else
							if str == "" then
								str = string.format("%s", text)
							else
								str = string.format("%s,%s", str, text)
							end
						end
					end
				end
				
				_CheatLogic:OnCheatKey(_UserService.LocalPlayer, self.key, str)
			else
				_CheatLogic:OnCheatKey(_UserService.LocalPlayer,self.key, "")
			end
		end
	end

end