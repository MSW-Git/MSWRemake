	@ExecSpace("Server")
	method void GetAccessories(string grade)
		-- 액세서리 지급 치트 (지정된 등급 또는 랜덤 등급)
		local isRandGrade = true
		
		if grade == "B" or grade == "A" or grade == "S" or grade == "SS" or grade == "SSS" then
			isRandGrade = false
		end 
		
		for i = 1, 3 do
			local prefix = string.format("10%d", i)
			for j = 1, 10 do
				local tailfix = "00000"
				
				if j >= 10 then
					tailfix = "0000"
				end
				local id = string.format("%s_%s%d", prefix, tailfix, j)
				
				local randGrade = grade
				if isRandGrade then
					local rand = _UtilLogic:RandomIntegerRange(1, 5)
					randGrade = "B"
					
					if rand == 2 then
						randGrade = "A"
					elseif rand == 3 then
						randGrade = "S"
					elseif rand == 4 then
						randGrade = "SS"
					elseif rand == 5 then
						randGrade = "SSS"
					end
				end
				
				_AccessoryLogic:AddAccessory(id, randGrade, "Cheat", "", self.Entity.PlayerComponent.UserId)
			end
			
			wait(0.02)
		end
	end

	@ExecSpace("Server")
	method void GetWeapons1()
		-- 무기 그룹 1 지급 치트 (1~3등급 무기)
		local userId = self.Entity.PlayerComponent.UserId
		for k,v in pairs(_WeaponSpecLogic.weaponData) do
			if string.sub(k,-1,-1)=="1" then
				self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 1, userId,"Cheat","")
			end
			
			if string.sub(k,-1,-1)=="2" then
				self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 2, userId,"Cheat","")
			end
			
			if string.sub(k,-1,-1)=="3" then
				self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 6, userId,"Cheat","")
			end
		end
	end

	@ExecSpace("Server")
	method void GetWeapons2()
		-- 무기 그룹 2 지급 치트 (4~5등급 무기)
		local userId = self.Entity.PlayerComponent.UserId
		for k,v in pairs(_WeaponSpecLogic.weaponData) do
			if string.sub(k,-1,-1)=="4" then
				self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 14, userId,"Cheat","")
			end
			
			if string.sub(k,-1,-1)=="5" then
				self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 30, userId,"Cheat","")
			end
			
			if string.sub(k,-1,-1)=="5" then
				self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 50, userId,"Cheat","")
			end
		end
	end

	@ExecSpace("Server")
	method void TestWeaponBalance()
		-- 무기 밸런스 테스트 치트 (자동 공격 시작)
		local weapon = {}
		local index = 1
		local multiPlayer = self.Entity.MultiBattlePlayer
		
		table.clear(multiPlayer.syncWeaponData)
		table.clear(multiPlayer.serverWeaponId)
		table.clear(multiPlayer.weaponKeys)
		
		for k,v in pairs(self.Entity.PlayerStorageComponent.storage) do
			if isvalid(_ItemDataLogic.equipmentData[v.originalId]) and _ItemDataLogic.equipmentData[v.originalId].category == "weapon" then
				multiPlayer.syncWeaponData[index] = _HttpService:JSONEncode(v)
				multiPlayer.serverWeaponId[index] = v.originalId
				multiPlayer.weaponKeys[index] = k
				
				index += 1
			end
		end
		
		
		self:StartAutoAttack()
	end

	@ExecSpace("Client")
	method void StartAutoAttack()
		-- 자동 공격 시작 치트 (무기 밸런스 테스트용)
		local multiPlayer = self.Entity.MultiBattlePlayer
		multiPlayer._T.syncWeaponInited = false
		_TimerService:ClearTimer(multiPlayer._T.autoSkillEventId)
		multiPlayer.autoSkill = true
		
		----------
		
		
		for k,v in pairs(multiPlayer.equipGun) do
			v.gun:Destroy()
		end
		table.clear(multiPlayer.equipGun)
		
		local dealy = 1
		if multiPlayer._T.syncWeaponInited then
			dealy = 0.01
		end
		multiPlayer._T.syncWeaponInited = true
		
		_TimerService:SetTimerOnce(function()
			local weaponCount = 0
			local totalMana = 0
			local i = 1
		
				for k,v in pairs(multiPlayer.syncWeaponData) do
					local each = _HttpService:JSONDecode(v)
					
					local slot = i
					multiPlayer:EquipGun(slot,each.originalId,each.uniqueKey,false)
					local weaponSpec = _WeaponSpecLogic:GetWeaponSpec(each.originalId)
					totalMana = totalMana + weaponSpec.mana
					multiPlayer.weaponMana[slot] = weaponSpec.mana
					weaponCount+=1
					i += 1
				end
		
			multiPlayer.avgManaCost = totalMana / weaponCount
			
			if _UserService.LocalPlayer == multiPlayer.Entity then
				local damage = {}
				for k,v in pairs(multiPlayer.syncWeaponData) do
					local each = _HttpService:JSONDecode(v)
					damage[each.uniqueKey] = _CalcLogic:GetWeaponAttackDamageByKey(each.uniqueKey,multiPlayer.Entity)
				end
				_MultiHUDManager:InitWeaponStatus()
			end
			
			
		end,dealy)
		
		
		
		_TimerService:SetTimerRepeat(function()
			for i = 1, 15 do
		
				multiPlayer:CheckUseMultiSkill(i)
			end
		end, 1)
		
		_TimerService:SetTimerOnce(function() 
			local storage = self.Entity.PlayerStorageComponent.storage
			local temp = {}
			local index = 1
			
			for key, value in pairs(_DPSLogic.damageInfo) do
				local weaponType = _WeaponSpecLogic:GetWeaponSpec(storage[key].originalId).type
		        local mana = multiPlayer._T.usedMana[weaponType]
				
		
				temp[weaponType] = {}
				temp[weaponType]["damage"] = value
				temp[weaponType]["mana"] = mana
		
			end
		
			
			local result = {}
			
			for key, value in pairs(_DPSLogic.attackCount) do
				local weaponType = _WeaponSpecLogic:GetWeaponSpec(storage[key].originalId).type
				
				temp[weaponType]["count"] = value
		
			end
			
			for key, value in pairs(temp) do
				result[index] = {}
				result[index]["waeaponType"] = key
				result[index]["damage"] = value.damage
				result[index]["count"] = value.count
				result[index]["mana"] = value.mana
				
				index += 1
			end
			
			table.sort(result, function(a, b) return a.damage > b.damage end)
			
			local mergedTable = {}
			
			for i = 1, #result do
				local value = result[i]
				mergedTable[i] = string.format("[%s] 대미지 : %d / 공격 횟수 : %d / 소모 마나 : %d", value.waeaponType, value.damage, value.count, value.mana)
			end
		
		
		end, 60)
	end

	@ExecSpace("Multicast")
	method void ResetLimitLandRecord()
		-- 무한대지 기록 초기화 치트
		local playerInfo = self.Entity.PlayerInfoComponent.playerInfo
		
		playerInfo.enteredLimitLandCount = 0
		playerInfo.enteredLimitLandDate = ""
		playerInfo.bestLimitLandWave = 0 
		playerInfo.limitLandRecordedTime = ""
		playerInfo.weekBestLimitLandWave = 0
		playerInfo.weekLimitLandRecordedTime = ""
		playerInfo.recordedBestLimitLandWeek = _LocalTimeLogic:GetSeasonWeek(DateTime("2023-11-20")) 
		playerInfo.rewardedWeeklyBestLimitLandDate = "" 
		playerInfo.limitLandRewardedNum = 0 
		playerInfo.prevLimitLandWave = 0 
		playerInfo.prevLimitLandRecordedTime = ""
		
		if self:IsServer() then
			local limitLandRecordDB = _DataStorageService:GetSortableDataStorage(_RankingLogic.limitLandRecordDBName)
			limitLandRecordDB:DeleteAsync(self.Entity.PlayerComponent.UserId, nil)
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Service", "InputService")
	handler HandleKeyDownEvent(KeyDownEvent event)
		-- 키보드 입력 이벤트 처리 (다양한 테스트 키 조합)
		--------------- Native Event Sender Info ----------------
		-- Sender: InputService
		-- Space: Client
		---------------------------------------------------------
		
		-- Parameters
		local key = event.key
		---------------------------------------------------------
		if key == KeyboardKey.Plus then
			self:TestWeaponBalance()
		elseif key == KeyboardKey.Minus then
			_BattleUIManager.remainSeconds = 1
		elseif key == KeyboardKey.PageUp then
			_UserService.LocalPlayer.CameraComponent.ZoomRatio -= 20
		elseif key == KeyboardKey.PageDown then
			_UserService.LocalPlayer.CameraComponent.ZoomRatio += 20
		elseif key == KeyboardKey.Home then
			_UserService.LocalPlayer.CameraComponent.IsAllowZoomInOut = true
		end
	end

end