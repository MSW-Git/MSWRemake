@Component
script DevelopPlayerComponent extends Component

	property boolean test1 = false

	property boolean test2 = false

	property boolean test3 = false

	property boolean test4 = false

	property integer dateTimer = 0

	@ExecSpace("Server")
	method void OpenAllStage()
		-- 모든 스테이지 열기 치트
		self.Entity.PlayerInfoComponent:SetPlayerStep(80)
		self.Entity.PlayerInfoComponent:SetChapterStoryProgress(90001)
	end

	@ExecSpace("Server")
	method void GetAllWeapons()
		-- 모든 무기 지급 치트
		for k,v in pairs(_WeaponSpecLogic.weaponData) do
			self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 1, self.Entity.PlayerComponent.UserId,"Cheat","")
		end
	end

	@ExecSpace("Client")
	method void EquipAllWeapon()
		-- 모든 무기 장착 치트
		local storage = self.Entity.PlayerStorageComponent
		
		for i = 1, _GameConfig:GetConfig().MAX_EQUIPMENT_CNT do
			self.Entity.BattlePlayer:AddWeapon("")
		end
	end

	@ExecSpace("Server")
	method void DeleteAllEquipments()
		-- 모든 장비 삭제 치트
		local storage = self.Entity.PlayerStorageComponent
		
		for key, value in pairs(storage.storage) do
			if value.equippedSlotNum > 0 then
				storage:UnEquip(key)
			end
			storage:RemoveItemById(value.originalId, 999999, "Cheat")
		end
	end

	@ExecSpace("Server")
	method void GetItem(string str)
		-- 아이템 지급 치트 (문자열 파싱하여 아이템 생성)
		local storage = self.Entity.PlayerStorageComponent
		local found = false
		local newStr = _UtilLogic:Split(str, ",")
		local id = newStr[1]
		local count = tonumber(newStr[2])
		local category = ""
		
		if _ItemDataLogic.equipmentData[id] ~= nil then
			found = true
			category = _ItemDataLogic.equipmentData[id].category
		end
		
		if _ItemDataLogic.itemData[id] ~= nil then
			found = true
			category =  _ItemDataLogic.itemData[id].category
		end
		
		if not found then
			_UIToast:ShowMessage("없는 아이템입니다.", self.Entity.PlayerComponent.UserId)
			return
		end
		
		
		local maxCount = self.Entity.PlayerStorageComponent.maxCount
		
		if _UtilLogic:Split(id, "_")[1] == _GameConfig:GetConfig().ITEMTYPE_EGG then
			storage:RequestAddEgg(id, count, id, 1, "", 0,"Cheat")
		elseif category == "consume" or category == "etc" or category == "ingredient" or category == "magicStone" or category == "" then
			local loop = math.ceil(count / 1000)
			local remain = count
			
			for i = 1, loop do
				if remain > maxCount then
					storage:RequestAddItemFromServer(id, maxCount, id, 1, self.Entity.PlayerComponent.UserId,"Cheat","")
					remain -= maxCount
				else
					storage:RequestAddItemFromServer(id, remain, id, 1, self.Entity.PlayerComponent.UserId,"Cheat","")
					remain = 0
				end
			end
		elseif category == "accessory" then
			log(id)
			local randGrade = newStr[2]
			local isRandGrade = true
		
			if randGrade == "B" or randGrade == "A" or randGrade == "S" or randGrade == "SS" or randGrade == "SSS" then
				isRandGrade = false
			end 
			
			if isRandGrade then
				local rand = _UtilLogic:RandomIntegerRange(1, 5)
				randGrade = "B"
				
				if rand == 2 then
					randGrade = "A"
				elseif rand == 3 then
					randGrade = "S"
				elseif rand == 4 then
					randGrade = "SS"
				elseif rand == 5 then
					randGrade = "SSS"
				end
			end
			
			_AccessoryLogic:AddAccessory(id, randGrade, "Cheat", "", self.Entity.PlayerComponent.UserId)
		else
			for i = 1, count do
				storage:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, id, 1, self.Entity.PlayerComponent.UserId,"Cheat","")
			end
		end
	end

	@ExecSpace("Client")
	method void DestroyItemEntities()
		-- 아이템 엔티티 삭제 치트
		for k, v in pairs(_StorageLogic.townStorage.Children) do
			v:Destroy()
		end
	end

	@ExecSpace("Server")
	method void GetAllPet()
		-- 모든 펫 지급 치트
		for k,v in pairs(_PetLogic.petData) do
			self.Entity.PlayerPetStorageComponent:RequestAddPet(_GameUtil:CreateGUID(), 1, v.id, 1, self.Entity.PlayerComponent.UserId, "Cheat", "")
		end
	end

	@ExecSpace("Server")
	method void DeleteAllPet()
		-- 모든 펫 삭제 치트
		local petStorage = self.Entity.PlayerPetStorageComponent
		
		for key, value in pairs(petStorage.petInventory) do
			petStorage:RemovePet(value.uniqueKey, "Cheat")
			petStorage:SyncPetInventoryInClient(value.uniqueKey, petStorage.petInventory[value.uniqueKey], self.Entity.PlayerComponent.UserId)
		end
	end

	@ExecSpace("Server")
	method void GetAllEggs()
		-- 모든 소울 에그 지급 치트
		for k,v in pairs(_ItemDataLogic.itemData) do
			if _UtilLogic:Contains(v.name, "소울 에그") then
				self.Entity.PlayerStorageComponent:RequestAddEgg(v.id, 1, v.id, 1, "", 0,"Cheat")
			end
		end
	end

	@ExecSpace("Server")
	method void GetMergeTestWeapons()
		-- 합성 테스트용 무기 지급 치트
		for k,v in pairs(_WeaponSpecLogic.weaponData) do
			if _UtilLogic:RandomIntegerRange(0,100) < 5 then
				for i = 1, 4 do
					self.Entity.PlayerStorageComponent:RequestAddItemFromServer(_GameUtil:CreateGUID(), 1, v.id, 1, senderUserId,"Cheat","")
				end
			end
		end
	end

	@ExecSpace("Client")
	method void AppearSuddenMission()
		-- 돌발 미션 강제 발생 치트
		_SuddenMissionLogic:ClearMission()
		_SuddenMissionLogic:SelectMission()
		_SuddenMissionLogic:AppearMission()
	end

	@ExecSpace("Server")
	method void GetBundle(string id)
		-- 번들 보상 지급 치트
		if _RewardLogic:CheckCanGetBundleReward(id, self.Entity.PlayerComponent.UserId, nil) then
			_RewardLogic:RequestGetBundleReward(id, self.Entity.PlayerComponent.UserId, true)
		end
	end

	@ExecSpace("Server")
	method void ChangeRewardedDate()
		-- 일일 보상 수령 날짜 변경 치트
		local playerInfo = self.Entity.PlayerInfoComponent
		local timeSpan = TimeSpan(1, 0, 0, 0)
		
		playerInfo.playerInfo.dailyGiftRewardedTime = tostring(_LocalTimeLogic:GetKST() - timeSpan)
		playerInfo:SetPlayerInfoData()
		playerInfo:SetPlayerInfoInClient(_HttpService:JSONEncode(playerInfo.playerInfo), self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void SetCurrentDate(string inputText)
		-- 현재 날짜 설정 치트
		local values = _UtilLogic:Split(inputText, ",")
		
		local year = tonumber(values[1])
		local month = tonumber(values[2])
		local day = tonumber(values[3])
		local hour = tonumber(values[4])
		local minute = tonumber(values[5])
		
		_LocalTimeLogic:SetCurrentDate(year, month, day, hour, minute)
		print(_LocalTimeLogic:GetKST())
		_RankingLogic:LoadLimitLandRecord()
		_RankingLogic:TempLoadLimitLandRecord(nil)
	end

	@ExecSpace("Server")
	method void InitDB()
		-- 데이터베이스 초기화 치트
		local playerDB = self.Entity.PlayerDBComponent
		
		_DataStorageService:DeleteUserDataStorageAsync(self.Entity.PlayerComponent.UserId, function(errorCode, userId)
			playerDB.dbInited = false
				wait(1)
			_UserService:KickUser(self.Entity.PlayerComponent.UserId, KickReason.Profanity)
			end)
	end

	@ExecSpace("Server")
	method void ForceClearQuest(string questId)
		-- 퀴스트 강제 완료 치트
		local questCompo = self.Entity.PlayerQuestComponent
		
		
		for key, value in pairs(_QuestLogic.questData) do
			if tonumber(key) <= tonumber(questId) then
		
				questCompo.questProgress[key] = {["id"] = key, ["questStatus"] = "COMPLETE"}
				questCompo:SyncQuestInClient(key, questCompo.questProgress[key], self.Entity.PlayerComponent.UserId)
		
			end
		end
		
		local questData = _QuestLogic.questData[questId]
		
		if questData.category == "main" then 
			local id = tonumber(questId)
			local min = math.maxinteger
			
			for key, value in pairs(_QuestLogic.questData) do
				if id < tonumber(value.id) and value.category == "main" then
					if tonumber(value.id) < min then
						min = tonumber(value.id)
					end
				end
			end
			questCompo:RequestAcceptQuest(tostring(min))
		end
		
		_RewardLogic:GiveQuestReward(questId, self.Entity.PlayerComponent.UserId)
		wait(2)
		_QuestUILogic:Refresh(self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void SetDecoration(string itemId)
		-- 데코레이션 아이템 설정 치트
		local playerInfo = self.Entity.PlayerInfoComponent
		
		playerInfo:SetDecoration(itemId)
	end

	@ExecSpace("Server")
	method void OpenNewbiePlayMission()
		-- 초보자 플레이 미션 열기 치트
		local playerMissionCompo = self.Entity.PlayerMissionComponent
		local missionInfo = playerMissionCompo.missionInfo
		
		playerMissionCompo.missionInfo.newbieMissionDay = 7
		playerMissionCompo:SyncDataInClient(_HttpService:JSONEncode(missionInfo), self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Server")
	method void GetNewbieMissionPlayPoint()
		-- 초보자 미션 플레이 포인트 지급 치트
		local playerMission = self.Entity.PlayerMissionComponent
		
		playerMission.missionInfo.newbieMissionPoint += 50
		playerMission:SyncDataInClient(_HttpService:JSONEncode(playerMission.missionInfo))
	end

	@ExecSpace("Client")
	method void AppearTargetSuddenMission(string id)
		-- 특정 돌발 미션 발생 치트
		_SuddenMissionLogic:ClearMission()
		
		local suddenMissionLogic = _SuddenMissionLogic
		
		local data = _DataService:GetTable("SuddenMissionData")
		local battlePlayer = _UserService.LocalPlayer.BattlePlayer
		
		_SuddenMissionLogic.currentMissionId = id
		_SuddenMissionLogic.currentMission = _SuddenMissionLogic.suddenMissionData[_SuddenMissionLogic.currentMissionId]
		_SuddenMissionLogic.limitTime = _SuddenMissionLogic.currentMission.limitTime
		
		if _SuddenMissionLogic.currentMission.objective ~= "0" then
			_SuddenMissionLogic.objectiveNum = tonumber(_SuddenMissionLogic.currentMission.objective)
		end
		
		if _SuddenMissionLogic.currentMissionId == "15" then
			_SuddenMissionLogic.willStartWave = _WaveLogic:GetLastWave(_UserService.LocalPlayer.CurrentMap.BattleMap.chapter)
		end
		
		_SuddenMissionLogic:AppearMission()
	end

	@ExecSpace("Client")
	method void SimulateStageDrops(string stageId, integer simulationCount)
		-- 스테이지 드롭 시뮬레이션 치트 (지정된 횟수만큼 드롭 확률 계산)
		local playerEntity = self.Entity
		local playerDrops = playerEntity.PlayerDropsComponent
		
		for loop = 1, simulationCount do
			local monsterCount = 0
			local eliteCount = 0
			local bossCount = 0
			
			local dropTable = {}
			
			for i = 1, 3 do
				dropTable[i] = {}
			end
			
		
			
			for key, value in pairs(_WaveLogic.chapterData) do 
				if key == tonumber(stageId) then
					for i = 1, value.lastWave do
						local waveData = _WaveLogic:GetChapterWave(key, i)
						
						for k, waveRow in pairs(waveData) do
							if waveRow.monster ~= "WAVE" then
								local averageNum = ((waveRow.spawnMin + waveRow.spawnMax) / 2) * waveRow.spawnCount * waveRow.life -- 평균 스폰 마릿수
								
								if _MonsterLogic.monsterData[waveRow.monster].type == "monster" then
									monsterCount += averageNum
								else
									if _UtilLogic:Contains(waveRow.monster, "EliteBoss") then
										eliteCount += averageNum
									else
										bossCount += averageNum
									end
								end
							end
						end
					end
					
					break
				end
			end
			
			local stageData = _StageLogic.stageData[stageId]
			local stageStep = stageData.step
			
			-- 시뮬레이션 --
			
			for key, value in pairs(_StageLogic.stageDropData) do
				if value.stageStep == stageStep then
					local monsterType = value.monsterType
			
					local reward = value.reward
					local rewardCount = value.rewardCount
					local rewardPercent = value.rewardPercent
					local monsterNum = 0
					local typeIndex = _GameConfig:GetConfig().MONSTERTYPE_MONSTER
					
					if monsterType == "monster" then
						monsterNum = monsterCount
					elseif monsterType == "elite" then
						monsterNum = eliteCount
						typeIndex = _GameConfig:GetConfig().MONSTERTYPE_ELITE
					elseif monsterType == "boss" then
						monsterNum = bossCount
						typeIndex = _GameConfig:GetConfig().MONSTERTYPE_BOSS
					end
					
					for i = 1, monsterNum do
						local dropItems = _UtilLogic:Split(reward, "/")
						local dropItemCount = _UtilLogic:Split(rewardCount, "/")
						local dropItemPercent = _UtilLogic:Split(rewardPercent, "/")
						local index = 1
						
						if typeIndex == _GameConfig:GetConfig().MONSTERTYPE_MONSTER then
							index = playerDrops.monsterIndex
						elseif typeIndex == _GameConfig:GetConfig().MONSTERTYPE_ELITE then
							index = playerDrops.eliteIndex
						elseif typeIndex == _GameConfig:GetConfig().MONSTERTYPE_BOSS then
							index = playerDrops.bossIndex
						end
						
						for j = 1, #dropItems do
							local rand = _UtilLogic:RandomIntegerRange(1, 100000)
							local percent = tonumber(dropItemPercent[j])
							local percentSum = percent
							
							percentSum = percentSum * (1 + _PetLogic:GetTotalItemDropBonus(playerEntity.PlayerComponent.UserId) / 100) -- 보너스 펫 드롭률
							if percentSum >= 100000 then
								percentSum = 100000
							end
						
							if rand <= percentSum then
								if not isvalid(dropTable[typeIndex][index]) then
									dropTable[typeIndex][index] = playerDrops:GetDropString(dropItems[j], tonumber(dropItemCount[j]), "")
								else
									dropTable[typeIndex][index] = string.format("%s,%s", dropTable[typeIndex][index], playerDrops:GetDropString(dropItems[j], tonumber(dropItemCount[j]), ""))
								end
								
								local str = "몬스터"
								
								if typeIndex == 2 then
									str = "엘리트"
								elseif typeIndex == 3 then
									str = "보스"
								end
								_CheatLogic.smiulateText.Text = string.format("%s[%s] %d : %s\t", _CheatLogic.smiulateText.Text, str, index, dropTable[typeIndex][index])
							end
						end
						
						if typeIndex == _GameConfig:GetConfig().MONSTERTYPE_MONSTER then
							playerDrops.monsterIndex += 1
						elseif typeIndex == _GameConfig:GetConfig().MONSTERTYPE_ELITE then
							playerDrops.eliteIndex += 1
						elseif typeIndex == _GameConfig:GetConfig().MONSTERTYPE_BOSS then
							playerDrops.bossIndex += 1
						end
					end
				end
			end
			
			_CheatLogic.smiulateText.Text = string.format("%s\n", _CheatLogic.smiulateText.Text)
			if loop % 10 == 0 then
				log(string.format("시뮬레이션 중 : %d%%/100%%", loop / simulationCount * 100))
				wait(0.02)
			end
		end
		
		
	end

	@ExecSpace("Server")
	method void SetStage(string id)
		-- 스테이지 설정 치트 (지정된 스테이지로 이동)
		self.Entity.PlayerInfoComponent:SetPlayerStep(tonumber(id))
		
		local tonumberId = tonumber(id)
		local targetStoryId = "1"
		if id%10 == 0 then
			targetStoryId = tostring(math.floor(tonumberId/10)+1)
		else
			targetStoryId = tostring(math.floor(tonumberId/10)+2)
		end
		self.Entity.PlayerInfoComponent:SetChapterStoryProgress(tonumber(targetStoryId.."0001"))
	end

	@ExecSpace("Server")
	method void RegisterCollection(string id)
		-- 도감 등록 치트
		local collection = self.Entity.PlayerCollectionComponent
		local targetTable = collection.eCollectionTable[id]
		
		collection.eCollectionTable[id] = _GameUtil:SetNumValueTen(collection.eCollectionTable[id], 1000) 
		collection.eCollectionTable[id] = _GameUtil:SetBoolValue(collection.eCollectionTable[id], 1000, 1)
		 
		collection:SynClient(collection.eCollectionTable, nil, self.Entity.PlayerComponent.UserId)
		collection:TransferToPlayerData()
		
		-- 도감 스탯 갱신
		collection:SetStatusTable(true)
		
		collection.Entity:SendEvent(NewbieMissionUpdateEvent("registerCollection", "0", 1))
	end

	@ExecSpace("Server")
	method void InitDailyMission()
		-- 일일 미션 초기화 치트
		local playerMission = self.Entity.PlayerDailyMissionComponent
		playerMission:SetMissionData()
	end

	@ExecSpace("Server")
	method void DailyMissionAllComplete()
		-- 일일/주간 미션 모두 완료 치트
		local dailyMissionCompo = self.Entity.PlayerDailyMissionComponent
		local isChangedValue = false
		
		for i = 1, 5 do
			local newKey = string.format("dm_%d", i) -- dailyMission_1
			local newKey2 = string.format("wm_%d", i) -- weeklyMission_1
			
			local dailyMission = dailyMissionCompo.missionInfo[newKey]
			local weeklyMission = dailyMissionCompo.missionInfo[newKey2]
			dailyMission.prg += 1000000
			weeklyMission.prg += 1000000
		end
		
		dailyMissionCompo:SyncDataInClient(_HttpService:JSONEncode(dailyMissionCompo.missionInfo), self.Entity.PlayerComponent.UserId)
	end

	@ExecSpace("Multicast")
	method void StartDateTimer()
		-- 날짜 타이머 시작 치트
		_TimerService:ClearTimer(self.dateTimer)
		
		if isvalid(_LocalTimeLogic.currentDate) then
			self.dateTimer = _TimerService:SetTimerRepeat(function()
				_LocalTimeLogic.currentDate = DateTime(_LocalTimeLogic.currentDate.Elapsed + 1000)
				end, 1, 1)
		end
	end

	@ExecSpace("Server")
	method void SetClearedRecommendStage(integer clearCount)
		-- 추천 스테이지 클리어 횟수 설정 치트
		self.Entity.PlayerInfoComponent.playerInfo.clearCount = clearCount
	end

	@ExecSpace("Server")
	method void GetMagicalStones()
		-- 모든 마법석 지급 치트
		for i = 1, 56 do
			local prefix = "100"
			local tailfix = "00000"
			
			if i >= 10 then
				tailfix = "0000"
			end
			
			local id = string.format("%s_%s%d", prefix, tailfix, i)
			
			self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, id, 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
			wait(0.02)
		end
		
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000138", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000139", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000140", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000141", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000142", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
		
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000133", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
		self.Entity.PlayerStorageComponent:AddItem(_GameUtil:CreateGUID(), 1000, "100_000134", 1, 0, 0, 0, false, false, 0, true, "Cheat", "")
