@Component
script TooltipComponent extends Component

	property string tooltipId = ""

	property Vector2 offset = Vector2(0,0)

	property boolean usedCustomMessage = false

	property string NewValue1 = ""

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleButtonStateChangeEvent(ButtonStateChangeEvent event)
		-- 버튼 상태 변화에 따라 툴팁을 표시 (PC는 호버, 모바일은 터치)
		
		local state = event.state
		if not Environment:IsPlay() then return end
		
		if isvalid(_UserService.LocalPlayer.CurrentMap.BattleMap) then
			if Environment:IsPCPlatform() then
				if state == ButtonState.Hover then
					_TooltipLogic:ShowTooltip(self.tooltipId, self.Entity, self.offset)
				end
			else
				if state == ButtonState.Pressed then
					_TooltipLogic:ShowTooltip(self.tooltipId, self.Entity, self.offset)
				end
			end
		else
			if state == ButtonState.Pressed then
				_TooltipLogic:ShowTooltip(self.tooltipId, self.Entity, self.offset)
			end
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Logic", "StageLogic")
	handler HandleStageEndEvent(StageEndEvent event)
		-- 스테이지 종료 시 툴팁을 숨김
		_TooltipLogic:HideTooltip()
	end

end