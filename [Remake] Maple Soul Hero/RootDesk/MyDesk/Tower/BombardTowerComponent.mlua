@Component
script BombardTowerComponent extends TowerComponent

	property table monsters = {}

	@HideFromInspector
	property number attackDelay = 0

	@ExecSpace("ClientOnly")
	method void Attack()
		-- 범위 내 몬스터들을 거리순으로 정렬하여 폭격 공격 실행
		__base:Attack()
		
		local attackCount = 0
		
		table.sort(self.monsters, function(a, b) 
				return self.Entity.TransformComponent.Position:Distance(a.TransformComponent.Position) < self.Entity.TransformComponent.Position:Distance(b.TransformComponent.Position)
			end)
		
		for entity, monster in pairs(self.monsters) do
			if attackCount >= self.attackCount then break end
			if attackCount == 0 then
				_SoundService:PlaySound("0a739c21a2444c468701f360b49f5220", _SoundLogic.effectRatio)
			end
			
			local options = {["PlayRate"] = 3, ["Color"] = Color(1,1,1,_OptionLogic.myEffectTransparency)} 
		
			local effect = _EffectService:PlayEffectAttached("2df72666adb84235abaccb5cbcd12133", entity, Vector3.zero, 0, Vector3.one, false, options)
			_TimerLogic:SetTimerOnce(function()
					 if isvalid(monster) then
						monster:SetDamage(self.damage * (1 + _BuffLogic:GetEngineering() / 100), Vector2.zero, false, "Tower")
						_EffectService:RemoveEffect(effect)
					end
				end, self.attackDelay, "BombardTowerComponent.Attack_setDamage")
			
			attackCount = attackCount + 1
		end
	end

	@ExecSpace("ClientOnly")
	method void Init(number lifeDuration, number attackInterval, integer attackCount, number range, number damage, boolean destroyable)
		-- 폭격 타워 초기화 및 공격 타이머 설정
		__base:Init(lifeDuration,attackInterval,attackCount,range,damage, destroyable)
		_TimerLogic:ClearTimer(self.attackTimer)
		self.attackDelay = 1.18 
		
		if isvalid(self.Entity:GetChildByName("RangeSprite", true)) then
			self.Entity:GetChildByName("RangeSprite", true).SpriteRendererComponent.SortingLayer =  _UserService.LocalPlayer.AvatarRendererComponent.SortingLayer
			self.Entity:GetChildByName("RangeSprite", true).SpriteRendererComponent.OrderInLayer = 1
		end
		
		self.attackTimer = _TimerLogic:SetTimerRepeat(function()
				if not isvalid(self) then
					_TimerLogic:ClearTimer(self.attackTimer)
					_TimerLogic:ClearTimer(self.destroyTimer)
				
					return
				end
			
				self.Entity.SpriteRendererComponent.Color.a = _OptionLogic.myEffectTransparency
				self.Entity:GetChildByName("RangeSprite", true).SpriteRendererComponent.Color.a = _OptionLogic.myEffectTransparency
			
				self:Attack()
			end, self.attackInterval, self.attackInterval, "BombardTowerComponent.Init_attack") 
	end

	@ExecSpace("ClientOnly")
	method void OnDestroy()
		-- 타워 파괴 시 모든 타이머 정리
		_TimerLogic:ClearTimer(self.attackTimer)
		_TimerLogic:ClearTimer(self.destroyTimer)
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleSpriteAnimPlayerEndFrameEvent(SpriteAnimPlayerEndFrameEvent event)
		-- 스프라이트 애니메이션 프레임 종료 이벤트 처리
		
		local FrameIndex = event.FrameIndex
		local ReversePlaying = event.ReversePlaying
		local TotalFrameCount = event.TotalFrameCount
		local AnimPlayer = event.AnimPlayer
		if _TimerLogic.pause then return end
		
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 몬스터가 타워 범위에 진입했을 때 공격 대상 목록에 추가
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		local monster = TriggerBodyEntity.MonsterObject
		
		if isvalid(TriggerBodyEntity) then
			self.monsters[TriggerBodyEntity] = monster
		end
	end

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerLeaveEvent(TriggerLeaveEvent event)
		-- 몬스터가 타워 범위에서 벗어났을 때 공격 대상 목록에서 제거
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		local monster = TriggerBodyEntity.MonsterObject
		
		if isvalid(TriggerBodyEntity) then
			self.monsters[TriggerBodyEntity] = nil
		end
		
	end

end