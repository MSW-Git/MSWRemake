@Component
script TowerComponent extends Component

	property number lifeDuration = 0

	property number attackInterval = 0

	property integer attackCount = 0

	property string attackType = ""

	@HideFromInspector
	property integer attackTimer = 0

	@HideFromInspector
	property integer destroyTimer = 0

	property number range = 0

	property number damage = 0

	property boolean destroyable = false

	property Vector3 pos = Vector3(0,0,0)

	@ExecSpace("ClientOnly")
	method void Attack()
		-- 기본 타워 공격 메서드 (하위 클래스에서 오버라이드)
		
	end

	@ExecSpace("ClientOnly")
	method void Init(number lifeDuration, number attackInterval, integer attackCount, number range, number damage, boolean destroyable)
		-- 타워의 기본 속성을 설정하고 공격 및 파괴 타이머 초기화
		self.lifeDuration = lifeDuration
		self.attackInterval = attackInterval
		self.attackCount = attackCount
		self.range = range
		self.Entity.TriggerComponent.CircleRadius = range
		self.damage = damage
		self.destroyable = destroyable
		
		
		if self.destroyable then
			self.destroyTimer = _TimerLogic:SetTimerOnce(function()
					self:DestroyThis()
				end, self.lifeDuration, "TowerComponent.Init_destroy")
		end
		
		self.attackTimer = _TimerLogic:SetTimerRepeat(function()
				self:Attack()
			end, self.attackInterval, self.attackInterval, "TowerComponent.Init_attack") 
	end

	@ExecSpace("ClientOnly")
	method void DestroyThis()
		-- 타워를 파괴하고 관련 타이머들을 정리
		_TimerLogic:ClearTimer(self.attackTimer)
		_TimerLogic:ClearTimer(self.destroyTimer)
		
		_TimerLogic:SetTimerOnce(function() _ArmorSkillLogic:ExcuteWeaponGlove(_UserService.LocalPlayer)  end, 30, "TowerComponent.DestroyThis")
		
		_PoolingLogic:DestroyEntity(self.Entity)
		
	end

end