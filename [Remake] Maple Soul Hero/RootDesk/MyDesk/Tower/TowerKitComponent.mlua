@Component
script TowerKitComponent extends Component

	property string towerCategory = ""

	@HideFromInspector
	property number damage = 0

	@ExecSpace("ClientOnly")
	@EventSender("Self")
	handler HandleTriggerEnterEvent(TriggerEnterEvent event)
		-- 플레이어가 타워 키트에 접촉하면 해당 타워를 생성하고 키트 제거
		
		local TriggerBodyEntity = event.TriggerBodyEntity
		if _TimerLogic.pause then return end
		
		_PoolingLogic:DestroyEntity(self.Entity)
		
		if self.towerCategory == "Bombard" then
			local bombardTower = _PoolingLogic:SpawnModel(_EntryService:GetModelIdByName("Model_BombardTower"), self.Entity.TransformComponent.Position, self.Entity.Parent)
			bombardTower.BombardTowerComponent:Init(60, 2.49, 5, 15, self.damage, true)
		end
		
	end

end