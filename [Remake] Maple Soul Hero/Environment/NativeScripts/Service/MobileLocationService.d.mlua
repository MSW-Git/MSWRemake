---@sealed
---@description "This is the superclass of all Services. Provides basic functions of Service."
@Service
script MobileLocationService extends Service

	---@sealed
	@ExecSpace("ClientOnly")
	method float GetLastAltitude() end

	---@sealed
	@ExecSpace("ClientOnly")
	method float GetLastHorizontalAccuracy() end

	---@sealed
	@ExecSpace("ClientOnly")
	method float GetLastLatitude() end

	---@sealed
	@ExecSpace("ClientOnly")
	method float GetLastLongitude() end

	---@sealed
	@ExecSpace("ClientOnly")
	method number GetLastTimeStamp() end

	---@sealed
	@ExecSpace("ClientOnly")
	method float GetLastVerticalAccuracy() end

	---@sealed
	@ExecSpace("ClientOnly")
	method LocationServiceStatus GetStatus() end

	---@sealed
	@ExecSpace("ClientOnly")
	method boolean IsHWSupported() end

	---@sealed
	@ExecSpace("ClientOnly")
	method LocationServiceStartResult StartAndWait(float desiredAccuracyInMeters = 10, float updateDistanceInMeters = 10) end

	---@sealed
	@ExecSpace("ClientOnly")
	method void StopAndWait() end

end